# MCP config (platform-specific, installed via config/mcp/install.shs)
.mcp.json

# Private example repos (not linked as submodules)
/examples/korean_stock_mcp/
/examples/llm_cli_tools/

# Build artifacts (consolidated under build/)
/build/
.simple_eval_*.spl

# Mold linker (auto-downloaded by simple mold-setup)
/bin/mold/

# QEMU resources (downloads and build artifacts)
/resources/qemu/

# Object files and native libraries
*.o
*.a
*.so
*.dylib
*.dll

# Rust build artifacts (all under src/compiler_rust/target/ or build/)
/rust/
**/target/
**/*.rs.bk
*.pdb

# Cargo.lock is typically committed for binaries, uncomment to ignore
# Cargo.lock

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Python bytecode
__pycache__/
*.pyc

# Cache files
**/*cache*.json
**/simple_watch_cache.json

# Claude Code local settings and worktrees
.claude/settings.local.json
.claude/worktrees/

# Local config overrides (not shared)
*.local.sdn

# jscpd report output
/report/

# Temporary files
/tmp/
.fileio_temp*/
*.tmp
*.temp
*.bak
*.backup
*.deleted
*.bak2
*.bak3

# Build directories (cmake/ninja output)
build/cross-*/

# Windows reserved device names
NUL
# Large runtime binaries removed - use bin/release/simple only

# Experimental run data now in build/experiments/

# Debug files
*.log
/debug/
!src/app/debug/

# Generated SMF files (Simple Module Format)
*.smf
.simple/
# .simple logs now in build/logs/

# Obsolete test formats (keep only .spl)
test/**/*.py
test/**/*.sdt

# Coverage output (now in build/coverage/)
lcov.info
*.profraw
*.profdata
htmlcov/

# Node.js (for jscpd)
node_modules/

# Backup and original files
*.orig

# Lean 4 build artifacts
verification/**/.lake/
verification/**/lake-manifest.json
**/.lake/

# Jujutsu version control
.jj/

# Binaries — all compiled/bootstrap/release binaries in bin/
# Keep .spl, .shs, .md, .txt scripts/docs tracked
bin/simple
bin/simple_*
bin/simple-*
bin/srt2
bin/task
bin/korean_stock_mcp_server
bin/t32_mcp_server
bin/t32_lsp_mcp_server
bin/lib*.so
bin/__pycache__/
bin/alt_release/
bin/bootstrap/
bin/freebsd/simple
bin/freebsd/simple-full
bin/release/**
!bin/release/README.md

# Package build artifacts
package_tmp/
*.tar.gz
*.zip
*.deb
*.spk

# Stale root dirs (runtime bug artifacts, old build output)
/nil/
/bootstrap/
/bootstrap_freebsd/
/pkg-deb/

# Auto-generated test checkpoints
tmp/.simple-test-checkpoint.sdn
.simple-test-checkpoint.sdn
.crates.toml
.crates2.json

# Secret patterns for pre-commit hook (contains partial key fragments)
scripts/hooks/secrets.patterns
