# Mobile Tauri shell Android build output + Gradle caches (regenerated by
# `tauri android build`). These volatile trees are what bloated a bad working-copy
# snapshot into ~298k files / 75M lines — never commit them. The committed
# gen/android scaffolding (generated Kotlin, tauri.*.gradle) stays tracked.
**/.gradle/
tools/tauri-shell/src-tauri/gen/android/build/
tools/tauri-shell/src-tauri/gen/android/app/build/
tools/tauri-shell/src-tauri/gen/android/buildSrc/build/

# Production WM host bridge builders are source, not generated build output.
!scripts/build/
!scripts/build/build_spl_winit.shs
!scripts/build/build_simple_runtime_sffi.shs
tools/tauri-shell/src-tauri/gen/android/local.properties
tools/tauri-shell/src-tauri/gen/android/.idea/

# Vendored cargo sources must stay hermetic (src/compiler_rust/.cargo/config.toml
# replaces crates-io with this directory); earlier rules like log/, third_party/,
# system/, *.o, *.lib silently drop crate files and break offline CI builds.
# Keep last so it wins over every rule above.
!src/compiler_rust/vendor/**
examples/10_tooling/simple_ide/platform/vscode/node_modules/

# Test runner transient state (rewritten every run; was polluting every WC snapshot)
test-results/

# Deploy backups (dated .bak files next to deployed binaries)
bin/release/*/*.bak-*
bin/release/*/*.bak
