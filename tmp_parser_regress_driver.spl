use compiler.core.parser.{parse_module}
use std.fs.{read_file}

fn check_src(src: text, label: text):
    print("=== {label}")
    parse_module(src, "regress_snippet.spl")
    print("=== done {label}")

fn main():
    val chain = "fn c(x: i64) -> i64:\n    if x > 10:\n        return 1\n    elif x > 5:\n        return 2\n    else if x > 2:\n        return 3\n    else:\n        return 4\n"
    val ifvar = "fn v(o: Option<i64>) -> i64:\n    if var y = o:\n        y = y + 1\n        return y\n    else:\n        return 0\n"
    val ifvar_ctor = "fn w(o: Option<i64>) -> i64:\n    if var Some(y) = o:\n        y = y + 1\n        return y\n    return 0\n"
    val elif_after_val = "fn e(o: Option<i64>, z: i64) -> i64:\n    if val Some(v) = o:\n        return v\n    elif z > 0:\n        return z\n    else:\n        return -1\n"

    check_src(chain, "plain if/elif/else-if/else chain")
    check_src(ifvar, "if var plain binding")
    check_src(ifvar_ctor, "if var ctor pattern")
    check_src(elif_after_val, "if val ctor + elif + else")

    val s1 = read_file("test/01_unit/compiler_core/parser/compose_operator_spec.spl")
    check_src(s1, "compose_operator_spec.spl")
    val s2 = read_file("test/01_unit/compiler_core/parser/short_grammar_combined_spec.spl")
    check_src(s2, "short_grammar_combined_spec.spl")
    print("REGRESS_DRIVER_DONE")
