{
  "name": "simple-lang",
  "version": "0.9.6",
  "description": "Simple Language compiler integration for Gemini CLI — 10 custom commands + MCP servers for code intelligence, debugging, build, and VCS",
  "commands_dir": ".gemini/commands",
  "mcp_servers": {
    "simple-mcp": {
      "command": "bin/simple_mcp_server",
      "args": [],
      "env": {
        "SIMPLE_LOG": "error"
      }
    },
    "simple-lsp-mcp": {
      "command": "bin/simple_lsp_mcp_server",
      "args": [],
      "env": {
        "SIMPLE_LOG": "error"
      }
    }
  },
  "system_instructions_file": "GEMINI.md",
  "keywords": ["compiler", "programming-language", "mcp", "debugger", "lsp"],
  "license": "MIT",
  "repository": "https://github.com/ormastes/simple"
}
