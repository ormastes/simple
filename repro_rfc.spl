use os.crypto.curve25519_smalllimb.{x25519_base_smalllimb}
use std.common.crypto.types.{bytes_to_hex}

fn alice_sk() -> [u8]:
    var v: [u8] = []
    v.push(0x77u8)
    v.push(0x07u8)
    v.push(0x6du8)
    v.push(0x0au8)
    v.push(0x73u8)
    v.push(0x18u8)
    v.push(0xa5u8)
    v.push(0x7du8)
    v.push(0x3cu8)
    v.push(0x16u8)
    v.push(0xc1u8)
    v.push(0x72u8)
    v.push(0x51u8)
    v.push(0xb2u8)
    v.push(0x66u8)
    v.push(0x45u8)
    v.push(0x16u8)
    v.push(0x1fu8)
    v.push(0x9eu8)
    v.push(0x5fu8)
    v.push(0x4eu8)
    v.push(0x5cu8)
    v.push(0x6eu8)
    v.push(0x1fu8)
    v.push(0x6du8)
    v.push(0x2eu8)
    v.push(0xabu8)
    v.push(0xdeu8)
    v.push(0x80u8)
    v.push(0x31u8)
    v.push(0xb4u8)
    v.push(0xe9u8)
    v

fn main():
    val pk = x25519_base_smalllimb(alice_sk())
    print(bytes_to_hex(pk))
    # Expected: 8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a
