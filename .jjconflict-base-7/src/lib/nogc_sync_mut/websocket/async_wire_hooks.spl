# Async WebSocket raw I/O hook owner.

extern fn rt_async_ws_read_raw(fd: i64, max_size: i64) -> List<i64>
extern fn rt_async_ws_write_raw(fd: i64, data: List<i64>) -> i64

fn async_ws_read_raw(fd: i64, max_size: i64) -> List<i64>:
    rt_async_ws_read_raw(fd, max_size)

fn async_ws_write_raw(fd: i64, data: List<i64>) -> i64:
    rt_async_ws_write_raw(fd, data)
