# SDN filter_in with OR-semantics batch scan, returning a RowBitmap.
#
# Phase 2 of std.db.accel — extends the shared accel layer with a
# multi-value OR-predicate helper that replaces repeated Eq scans with
# a single bitmap pass, consistent with SDN query batching conventions.

struct FilterInResult:
    matched_count: i64
    row_ids: [i64]

fn filter_in_text(values: [text], needles: [text]) -> FilterInResult:
    var row_ids: [i64] = []
    val n = values.len()
    val m = needles.len()
    var i = 0
    while i < n:
        var j = 0
        var matched = false
        while j < m and (matched == false):
            if values[i as i32] == needles[j as i32]:
                matched = true
            j = j + 1
        if matched:
            row_ids.push(i)
        i = i + 1
    FilterInResult(matched_count: row_ids.len(), row_ids: row_ids)

fn filter_in_int(values: [i64], needles: [i64]) -> FilterInResult:
    var row_ids: [i64] = []
    val n = values.len()
    val m = needles.len()
    var i = 0
    while i < n:
        var j = 0
        var matched = false
        while j < m and (matched == false):
            if values[i as i32] == needles[j as i32]:
                matched = true
            j = j + 1
        if matched:
            row_ids.push(i)
        i = i + 1
    FilterInResult(matched_count: row_ids.len(), row_ids: row_ids)

fn filter_in_text_count(values: [text], needles: [text]) -> i64:
    filter_in_text(values, needles).matched_count

fn filter_in_int_count(values: [i64], needles: [i64]) -> i64:
    filter_in_int(values, needles).matched_count

fn filter_in_result_ids(r: FilterInResult) -> [i64]:
    r.row_ids

fn filter_in_result_count(r: FilterInResult) -> i64:
    r.matched_count
