# ============================================================================
# common/search/exact.spl — exact single-pattern matching (AC-2)
#
# memmem-style scan, Two-Way (Crochemore-Perrin), and Boyer-Moore-Horspool,
# plus a find_all over Haystack/Pattern returning typed MatchSpan values.
#
# Behavior is carried on the custom types: the first-byte seam is
# Haystack.find_from, verification is Haystack.matches_at, and the bad-character
# skip is Pattern.skip_for. Raw [u8] is touched only inside Two-Way's inner
# comparison loop (the one place where index discipline is unavoidable), via
# the typed .get(i) accessors — never raw slice indexing.
#
# Conventions (settled, identical across every function AND the naive oracle in
# the spec):
#   * Empty pattern matches at every position 0..=haystack.len() (Rust memmem
#     rule). find returns a zero-width MatchSpan.of(0, 0); find_all returns one
#     zero-width span per position.
#   * Pattern longer than haystack, or empty haystack with a non-empty pattern,
#     yields no match.
#   * No-match sentinel is MatchSpan.of(-1, -1) (start() == -1). We deliberately
#     avoid Option<MatchSpan> because the interpreter has live Option::Some
#     forwarding bugs.
#   * find_all advances by pos+1 (NOT pos+plen) so overlapping matches are all
#     reported, e.g. "ana" in "banana" -> {1, 3}.
#
# Plan: doc/03_plan/lib/search/custom_type_alpha_search_team_plan_2026-06-15.md
# ============================================================================

use std.common.search.types.{Haystack, Pattern, MatchSpan, MatchPos}
use std.common.bytes.span.{ByteSpan}

# ----------------------------------------------------------------------------
# Sentinel + small helpers
# ----------------------------------------------------------------------------
fn no_match() -> MatchSpan:
    """The canonical no-match result. Callers test `.start() == -1`."""
    MatchSpan.of(0 - 1, 0 - 1)

fn empty_match_at(pos: i64) -> MatchSpan:
    """A zero-width match (used for the empty pattern)."""
    MatchSpan.of(pos, pos)

# ----------------------------------------------------------------------------
# memmem-style scan: first-byte seam (Haystack.find_from) + verify
# ----------------------------------------------------------------------------
fn memmem(hay: Haystack, pat: Pattern) -> MatchSpan:
    """First match via the first-byte seam then full verification.

    Lands on each candidate first byte using the Haystack.find_from hook, then
    confirms the whole needle with Haystack.matches_at. This is the path the
    SIMD/memchr seam will later accelerate by overriding find_from."""
    val plen = pat.len()
    val hlen = hay.len()
    if plen == 0:
        return empty_match_at(0)
    if plen > hlen:
        return no_match()
    val first = pat.get(0)
    var i = 0
    while i <= hlen - plen:
        val cand = hay.find_from(i, first)
        if cand < 0:
            return no_match()
        if cand > hlen - plen:
            return no_match()
        if hay.matches_at(cand, pat):
            return MatchSpan.at_len(cand, plen)
        i = cand + 1
    no_match()

# ----------------------------------------------------------------------------
# Boyer-Moore-Horspool: reuse the precomputed bad-character table on Pattern
# ----------------------------------------------------------------------------
fn boyer_moore_horspool(hay: Haystack, pat: Pattern) -> MatchSpan:
    """BMH first match. The bad-character skip table is already built on the
    Pattern (Pattern.skip_for); we never rebuild it. On a mismatch we shift by
    skip_for(the haystack byte aligned with the pattern's last position)."""
    val plen = pat.len()
    val hlen = hay.len()
    if plen == 0:
        return empty_match_at(0)
    if plen > hlen:
        return no_match()
    var pos = 0
    while pos <= hlen - plen:
        if hay.matches_at(pos, pat):
            return MatchSpan.at_len(pos, plen)
        # Align the pattern's last index with the haystack; shift by that byte.
        val tail = hay.get(pos + plen - 1)
        pos = pos + pat.skip_for(tail)
    no_match()

# ----------------------------------------------------------------------------
# Two-Way (Crochemore-Perrin)
# ----------------------------------------------------------------------------
# The critical factorization splits the needle x into (u, v) with x = u v such
# that the period of the match is maximal. We compute the factorization via the
# maximal-suffix computation for both the <= and >= orders and take the split
# point with the larger period; the search then alternates a forward scan of v
# and a backward scan of u, using the period to memorize matched suffix length.
#
# Helper returns a (suffix_index, period) pair through a tiny struct because
# Simple has no tuple-return idiom we rely on here.
struct MaxSuf:
    idx: i64
    period: i64

fn max_suffix(pat: Pattern, want_greater: bool) -> MaxSuf:
    """Maximal suffix of the pattern under the chosen byte order.

    want_greater = true computes the maximal suffix for the `>` order; false for
    the `<` order. Returns the start index of that suffix and its period."""
    val n = pat.len()
    var ms = 0 - 1      # current best suffix start (ms+1 is the suffix index)
    var j = 0           # candidate position
    var k = 1           # offset within the period
    var p = 1           # current period
    while j + k < n:
        val a = pat.get(j + k)
        val b = pat.get(ms + k)
        var smaller = a < b
        if want_greater:
            smaller = a > b
        if smaller:
            # candidate worse than current suffix: jump past it
            j = j + k
            k = 1
            p = j - ms
        else:
            if a == b:
                if k == p:
                    j = j + p
                    k = 1
                else:
                    k = k + 1
            else:
                # a is "more extreme": new best suffix begins at j
                ms = j
                j = ms + 1
                k = 1
                p = 1
    MaxSuf(idx: ms + 1, period: p)

fn two_way(hay: Haystack, pat: Pattern) -> MatchSpan:
    """Two-Way (Crochemore-Perrin) first match.

    Computes the critical factorization (the split giving the larger period),
    then alternates a forward scan of the right factor with a backward scan of
    the left factor, using the period to memorize how much of a periodic match
    is already known (the case where naive Two-Way regresses)."""
    val n = pat.len()
    val hlen = hay.len()
    if n == 0:
        return empty_match_at(0)
    if n > hlen:
        return no_match()

    # Critical factorization: larger of the two maximal-suffix splits.
    val sa = max_suffix(pat, false)
    val sb = max_suffix(pat, true)
    var ell = sa.idx
    var per = sa.period
    if sb.idx > ell:
        ell = sb.idx
        per = sb.period

    # Decide whether the pattern's two halves are equal under the period (the
    # periodic / memory case) vs. the short-period generic case.
    var periodic = false
    var i = 0
    var halves_equal = true
    while i < ell:
        if pat.get(i) != pat.get(i + per):
            halves_equal = false
            i = ell
        else:
            i = i + 1
    if ell < n - ell and halves_equal:
        periodic = true

    if periodic:
        # Memorized scan: `memory` tracks how much suffix is already matched.
        var pos = 0
        var memory = 0 - 1
        while pos <= hlen - n:
            # forward scan of right factor v
            var jj = ell
            if jj < memory + 1:
                jj = memory + 1
            var ok = true
            while jj < n and ok:
                if pat.get(jj) != hay.get(pos + jj):
                    ok = false
                else:
                    jj = jj + 1
            if not ok:
                pos = pos + (jj - ell + 1)
                memory = 0 - 1
            else:
                # backward scan of left factor u
                var kk = ell - 1
                var ok2 = true
                while kk > memory and ok2:
                    if pat.get(kk) != hay.get(pos + kk):
                        ok2 = false
                    else:
                        kk = kk - 1
                if kk <= memory:
                    return MatchSpan.at_len(pos, n)
                pos = pos + per
                memory = n - per - 1
        return no_match()
    else:
        # Generic short-suffix case: period is at least max(ell, n-ell)+1.
        var per2 = ell
        if n - ell > per2:
            per2 = n - ell
        per2 = per2 + 1
        var pos2 = 0
        while pos2 <= hlen - n:
            var jx = ell
            var okx = true
            while jx < n and okx:
                if pat.get(jx) != hay.get(pos2 + jx):
                    okx = false
                else:
                    jx = jx + 1
            if not okx:
                pos2 = pos2 + (jx - ell + 1)
            else:
                var kx = ell - 1
                var okx2 = true
                while kx >= 0 and okx2:
                    if pat.get(kx) != hay.get(pos2 + kx):
                        okx2 = false
                    else:
                        kx = kx - 1
                if kx < 0:
                    return MatchSpan.at_len(pos2, n)
                pos2 = pos2 + per2
        return no_match()

# ----------------------------------------------------------------------------
# find_all: every (possibly overlapping) match, advancing by pos+1
# ----------------------------------------------------------------------------
fn find_all(hay: Haystack, pat: Pattern) -> [MatchSpan]:
    """All matches, including overlaps. Advances by pos+1 so e.g. "ana" in
    "banana" reports both 1 and 3. The empty pattern matches at every position
    0..=len (one zero-width span each). Verification uses Haystack.matches_at."""
    var out: [MatchSpan] = []
    val plen = pat.len()
    val hlen = hay.len()
    if plen == 0:
        var p = 0
        while p <= hlen:
            out.push(empty_match_at(p))
            p = p + 1
        return out
    if plen > hlen:
        return out
    var i = 0
    while i <= hlen - plen:
        if hay.matches_at(i, pat):
            out.push(MatchSpan.at_len(i, plen))
        i = i + 1
    out
