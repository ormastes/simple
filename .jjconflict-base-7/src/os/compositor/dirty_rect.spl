# dirty_rect.spl — dirty region tracking for minimal repaint
#
# DirtyRegion accumulates invalidated rectangles and computes the
# minimal bounding box for the next present call.  Pure functions,
# no SFFI.

struct IRect:
    x: i32
    y: i32
    w: i32
    h: i32

fn irect_new(x: i32, y: i32, w: i32, h: i32) -> IRect:
    IRect(x: x, y: y, w: w, h: h)

fn irect_empty() -> IRect:
    IRect(x: 0, y: 0, w: 0, h: 0)

fn _max_i32(a: i32, b: i32) -> i32:
    if a > b: a else: b

fn _min_i32(a: i32, b: i32) -> i32:
    if a < b: a else: b

# Returns the union (bounding box) of two non-empty rects.
fn irect_union(a: IRect, b: IRect) -> IRect:
    val ax2 = a.x + a.w
    val ay2 = a.y + a.h
    val bx2 = b.x + b.w
    val by2 = b.y + b.h
    val nx = _min_i32(a.x, b.x)
    val ny = _min_i32(a.y, b.y)
    val nx2 = _max_i32(ax2, bx2)
    val ny2 = _max_i32(ay2, by2)
    IRect(x: nx, y: ny, w: nx2 - nx, h: ny2 - ny)

# Returns true if two rects overlap (intersection is non-empty).
fn irect_intersects(a: IRect, b: IRect) -> bool:
    val ax2 = a.x + a.w
    val ay2 = a.y + a.h
    val bx2 = b.x + b.w
    val by2 = b.y + b.h
    a.x < bx2 and ax2 > b.x and a.y < by2 and ay2 > b.y

# Returns the intersection of two rects, or empty if they don't overlap.
fn irect_intersection(a: IRect, b: IRect) -> IRect:
    if not irect_intersects(a, b):
        return irect_empty()
    val ax2 = a.x + a.w
    val ay2 = a.y + a.h
    val bx2 = b.x + b.w
    val by2 = b.y + b.h
    val nx = _max_i32(a.x, b.x)
    val ny = _max_i32(a.y, b.y)
    val nx2 = _min_i32(ax2, bx2)
    val ny2 = _min_i32(ay2, by2)
    IRect(x: nx, y: ny, w: nx2 - nx, h: ny2 - ny)

fn irect_is_empty(r: IRect) -> bool:
    r.w <= 0 or r.h <= 0

fn irect_area(r: IRect) -> i32:
    if irect_is_empty(r): 0 else: r.w * r.h

# DirtyRegion — accumulates invalidation rects each frame.
class DirtyRegion:
    rects: [IRect]
    has_any: bool

    static fn new() -> DirtyRegion:
        DirtyRegion(rects: [], has_any: false)

    # Add a rectangle to the dirty set.
    me add_rect(x: i32, y: i32, w: i32, h: i32):
        if w <= 0 or h <= 0:
            return
        val r = IRect(x: x, y: y, w: w, h: h)
        self.rects.push(r)
        self.has_any = true

    # Add a whole-screen dirty rect (convenience).
    me add_full_screen(screen_w: i32, screen_h: i32):
        self.add_rect(0, 0, screen_w, screen_h)

    # Merge all accumulated rects into a single bounding box.
    me bounding_box() -> IRect:
        if not self.has_any or self.rects.len() == 0:
            return irect_empty()
        var result = self.rects[0]
        var i = 1
        while i < self.rects.len():
            result = irect_union(result, self.rects[i])
            i = i + 1
        result

    # Returns true when there is at least one dirty rect.
    me is_dirty() -> bool:
        self.has_any

    # Returns true when no dirty rects are pending.
    me is_empty() -> bool:
        not self.has_any

    # Clear all dirty rects after a present.
    me clear():
        self.rects = []
        self.has_any = false

    # Number of pending dirty rects.
    me count() -> i32:
        self.rects.len().to_i32()
