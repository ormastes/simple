# Tool Schemas — Window and Widget tools
#
# Schema builder functions for the MCP OS server tool registry.
# Window tools: window_create, window_close, window_list, window_focus
# Widget tools: widget_set, widget_read, widget_action

use os.services.llm.tool_schema_helpers.{llm_tool_property, llm_tool_props0, llm_tool_props1, llm_tool_props2, llm_tool_props3, llm_tool_required0, llm_tool_required1, llm_tool_required2, llm_tool_input_schema, llm_tool_annotations, llm_tool_schema}

fn schema_window_create() -> text:
    """Schema for window_create tool."""
    val props = llm_tool_props3(
        "title", llm_tool_property("string", "Window title"),
        "width", llm_tool_property("number", "Window width in pixels"),
        "height", llm_tool_property("number", "Window height in pixels")
    )
    val schema = llm_tool_input_schema(props, llm_tool_required1("title"))
    val annot = llm_tool_annotations("false", "false", "false")
    return llm_tool_schema("window_create", "Create a new window with title and dimensions", schema, annot)

fn schema_window_close() -> text:
    """Schema for window_close tool."""
    val props = llm_tool_props1("id", llm_tool_property("number", "Window ID to close"))
    val schema = llm_tool_input_schema(props, llm_tool_required1("id"))
    val annot = llm_tool_annotations("false", "true", "true")
    return llm_tool_schema("window_close", "Close a window by ID", schema, annot)

fn schema_window_list() -> text:
    """Schema for window_list tool."""
    val schema = llm_tool_input_schema(llm_tool_props0(), llm_tool_required0())
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("window_list", "List all open windows with ID, title, size, and focus state", schema, annot)

fn schema_window_focus() -> text:
    """Schema for window_focus tool."""
    val props = llm_tool_props1("id", llm_tool_property("number", "Window ID to focus"))
    val schema = llm_tool_input_schema(props, llm_tool_required1("id"))
    val annot = llm_tool_annotations("false", "false", "true")
    return llm_tool_schema("window_focus", "Focus a window by ID", schema, annot)

fn schema_widget_set() -> text:
    """Schema for widget_set tool."""
    val props = llm_tool_props2(
        "window_id", llm_tool_property("number", "Window ID to set widget tree for"),
        "widget_dsl", llm_tool_property("string", "Widget DSL string. Indentation-based format: column:/row:/panel(title: ...) with text(), button(), progress(), table(), etc.")
    )
    val schema = llm_tool_input_schema(props, llm_tool_required2("window_id", "widget_dsl"))
    val annot = llm_tool_annotations("false", "false", "true")
    return llm_tool_schema("widget_set", "Set window contents using widget DSL. Renders to both GUI and CLI. The DSL supports: column, row, panel, text, label, button, input, progress, table, statusbar, list, checkbox, divider, image, heading.", schema, annot)

fn schema_widget_read() -> text:
    """Schema for widget_read tool."""
    val props = llm_tool_props1("window_id", llm_tool_property("number", "Window ID to read widget tree from"))
    val schema = llm_tool_input_schema(props, llm_tool_required1("window_id"))
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("widget_read", "Read current widget tree as text description. LLM can inspect UI state to understand what the user sees.", schema, annot)

fn schema_widget_action() -> text:
    """Schema for widget_action tool."""
    val props = llm_tool_props2(
        "window_id", llm_tool_property("number", "Window ID"),
        "action", llm_tool_property("string", "Action name to trigger (matches button action property)")
    )
    val schema = llm_tool_input_schema(props, llm_tool_required2("window_id", "action"))
    val annot = llm_tool_annotations("false", "false", "false")
    return llm_tool_schema("widget_action", "Trigger a UI action on a window (button click, menu select)", schema, annot)
