# Simple CLI - compile command
# Startup-light wrapper that delegates real compile work to the Rust CLI.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn print_help():
    print "Usage: simple compile <source.spl> [options]"
    print "Compiles source to SMF or native binary."
    print ""
    print "Options:"
    print "  -o <output>              Output file"
    print "  --native                 Compile to standalone native binary"
    print "  --list-optimizations     Print implemented optimization groups and levels"
    print "  --opt-level <level>      none, basic, standard, aggressive"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("compile", log_opts.error)
        return 1

    val args = compile_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"compile\",\"status\":\"error\",\"error\":\"compile requires a source file\"}"
            return 1
        print "error: compile requires a source file"
        print_help()
        return 1
    delegate_compile(args)

fn delegate_compile(args: [text]) -> i64:
    var forwarded: [text] = ["compile"]
    for arg in args:
        forwarded.push(arg)
    val (stdout, stderr, code) = rt_process_run("./bin/simple", forwarded)
    if stdout != "":
        print stdout
    if stderr != "":
        print stderr
    code

fn compile_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn compile_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if compile_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
