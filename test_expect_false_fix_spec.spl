describe "expect(false).to_equal(false) fix" {
    it "passes when expect(false).to_equal(false)" {
        val result = false
        expect(result).to_equal(false)
    }

    it "passes when expect(true).to_equal(true)" {
        val result = true
        expect(result).to_equal(true)
    }

    it "fails when expect(true).to_equal(false)" {
        val result = true
        expect(result).to_equal(false)
    }
}
