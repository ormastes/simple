extern fn rt_file_read_bytes(path: text) -> [u8]?

fn main() -> i64:
    val opt = rt_file_read_bytes("scratch_p3/noparam.spl")
    var n: i64 = -1
    if opt != nil:
        val value: [u8] = opt
        print "non-nil branch, len={value.len()}"
        n = value.len()
    else:
        print "nil branch"
    print "n={n}"

    # ?? [] proven native-safe (mirrors mcp_tools_helpers.spl /
    # launch_meta_check.spl, both natively-compiled bootstrap stdlib callers
    # of this same extern) -- confirm it also passes the bare array through
    # unchanged rather than only working via explicit != nil narrowing.
    val via_coalesce: [u8] = rt_file_read_bytes("scratch_p3/noparam.spl") ?? []
    print "via_coalesce len={via_coalesce.len()}"
    return via_coalesce.len()
