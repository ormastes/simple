extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool

fn main() -> i64:
    val input = "build/gui/libpure_gui_hot.so"
    val output = "/tmp/simple_gui_write_readback_probe.bin"
    val data = rt_file_read_bytes(input) ?? []
    if data.len() == 0:
        print "WRITE_READBACK ok=false step=read"
        return 1
    if not rt_file_write_bytes(output, data):
        print "WRITE_READBACK ok=false step=write"
        return 1
    val reread = rt_file_read_bytes(output) ?? []
    print "WRITE_READBACK ok=true len=" + reread.len().to_text()
    if reread.len() != data.len():
        return 1
    0
