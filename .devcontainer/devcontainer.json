{
    "name": "Simple Lang - UI Debug",
    "build": { "dockerfile": "Dockerfile", "context": ".." },
    "forwardPorts": [6080, 3000, 4711],
    "portsAttributes": {
        "6080": { "label": "noVNC GUI", "onAutoForward": "openBrowser" },
        "3000": { "label": "Web UI", "onAutoForward": "notify" },
        "4711": { "label": "DAP Debugger", "onAutoForward": "silent" }
    },
    "postCreateCommand": "cargo build --manifest-path src/compiler_rust/Cargo.toml -p simple-driver",
    "postStartCommand": "sh .devcontainer/setup-vnc.shs &",
    "capAdd": ["SYS_PTRACE"],
    "securityOpt": ["seccomp=unconfined"],
    "customizations": {
        "vscode": {
            "extensions": ["vadimcn.vscode-lldb", "rust-lang.rust-analyzer"],
            "settings": {
                "rust-analyzer.linkedProjects": ["src/compiler_rust/Cargo.toml"]
            }
        }
    },
    "remoteEnv": {
        "SIMPLE_HOME": "/workspace",
        "SIMPLE_DEBUG": "1"
    }
}
