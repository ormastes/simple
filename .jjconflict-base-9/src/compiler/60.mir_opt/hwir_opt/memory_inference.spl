# HWIR memory inference.

use compiler.mir.hwir.types.{HwModule, HwMemory}
use compiler.mir_opt.hwir_opt.pass_model.{HwirOptPassResult, hwir_cost_with_resource_delta}

class HwirMemoryPattern:
    """Recognized memory-like structure in HWIR."""
    name: text
    element_width: i32
    depth: i32
    read_ports: i32
    write_ports: i32
    constant_contents: bool
    fifo_access: bool

    me template_kind() -> text:
        if self.fifo_access:
            return "fifo"
        if self.constant_contents:
            return "rom"
        if self.read_ports >= 2 or self.write_ports >= 2:
            return "true_dual_port_ram"
        return "single_port_ram"

fn hwir_memory_from_pattern(pattern: HwirMemoryPattern) -> HwMemory:
    return HwMemory(
        name: pattern.name,
        element_type: "bits",
        element_width: pattern.element_width,
        depth: pattern.depth,
        ports: pattern.read_ports + pattern.write_ports,
        template_kind: pattern.template_kind()
    )

fn hwir_memory_inference_pass(module: HwModule, patterns: [HwirMemoryPattern]) -> HwirOptPassResult:
    if patterns.len() == 0:
        return HwirOptPassResult.unchanged("memory_inference", module, "no memory patterns")
    var brams = 0
    var removed_regs = 0
    for pattern in patterns:
        if pattern.depth * pattern.element_width >= 1024:
            brams = brams + 1
        removed_regs = removed_regs + pattern.depth
    return HwirOptPassResult.changed("memory_inference", module, hwir_cost_with_resource_delta(module.cost, 0, 0 - removed_regs, 0, brams, 0), removed_regs, 0, 0, 0, "converted register structures into memory templates")
