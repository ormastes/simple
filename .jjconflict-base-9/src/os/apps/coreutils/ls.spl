# coreutils/ls — list directory entries
#
# Pure library module. Entry point: main_ls(args).
# Filesystem access via VFS extern shims resolved at link time.
#
# MDSOC: feature dimension, apps/coreutils layer

use os.userlib.log.{log_info, log_error}

extern fn vfs_opendir(path: text) -> i64
extern fn vfs_readdir(handle: i64) -> text
extern fn vfs_closedir(handle: i64) -> i32

fn ls_list_one(path: text) -> i32:
    """List entries in one directory. Returns 0 on success, 1 on error."""
    val handle = vfs_opendir(path)
    if handle < 0:
        log_error("[ls] cannot open dir: {path}")
        return 1
    var entry = vfs_readdir(handle)
    while entry != "":
        log_info("{entry}")
        entry = vfs_readdir(handle)
    vfs_closedir(handle)
    0

fn main_ls(args: [text]) -> i32:
    """List directory contents.

    Usage: ls [-1] [path...]
    Flags:
      -1        single-column output (default; accepted and ignored)
      --help    print usage and exit 0
    """
    # Parse flags
    var paths: [text] = []
    var i: i32 = 0
    while i < args.len() as i32:
        val arg = args[i as u64]
        if arg == "--help":
            log_info("usage: ls [-1] [path...]")
            return 0
        elif arg == "-1":
            pass_dn  # single-column is default; flag accepted silently
        else:
            paths.push(arg)
        i = i + 1

    # Default to "." when no paths given
    if paths.len() == 0:
        paths.push(".")

    var rc: i32 = 0
    var j: i32 = 0
    while j < paths.len() as i32:
        val r = ls_list_one(paths[j as u64])
        if r != 0:
            rc = 1
        j = j + 1
    rc
