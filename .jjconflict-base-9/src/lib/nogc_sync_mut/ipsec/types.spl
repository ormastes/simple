# IPsec protocol constants + typed structures (RFC 4303 / 4302 / 7296).
#
# Reuses only the common.net SecurityParameterIndex + AntiReplayWindow; all
# framing/SA/IKE structures are new (no TLS analog). Dispatch values are plain
# integer `val` constants (IP protocol numbers, IKE exchange/payload types),
# never payload-enums.

use std.common.net.anti_replay.{SecurityParameterIndex}

# --- IANA IP protocol numbers (ESP/AH next_header) ---
val IPSEC_NH_TCP = 6
val IPSEC_NH_UDP = 17
val IPSEC_NH_ESP = 50
val IPSEC_NH_AH = 51
val IPSEC_NH_IPV6_NO_NEXT = 59

# --- IKEv2 exchange types (RFC 7296 §3.1) ---
val IKE_EXCHANGE_SA_INIT = 34
val IKE_EXCHANGE_AUTH = 35
val IKE_EXCHANGE_CREATE_CHILD_SA = 36
val IKE_EXCHANGE_INFORMATIONAL = 37

# --- IKEv2 payload types (RFC 7296 §3.2) ---
val IKE_PAYLOAD_NONE = 0
val IKE_PAYLOAD_SA = 33
val IKE_PAYLOAD_KE = 34
val IKE_PAYLOAD_ID_INITIATOR = 35
val IKE_PAYLOAD_AUTH = 39
val IKE_PAYLOAD_NONCE = 40
val IKE_PAYLOAD_NOTIFY = 41
val IKE_PAYLOAD_ENCRYPTED = 46

# --- IKEv2 version + flag bits (RFC 7296 §3.1) ---
val IKE_VERSION_2 = 0x20
val IKE_FLAG_INITIATOR = 0x08
val IKE_FLAG_VERSION = 0x10
val IKE_FLAG_RESPONSE = 0x20

# ============================================================================
# EspPacket -- Encapsulating Security Payload (RFC 4303 §2)
# ============================================================================

struct EspPacket:
    """ESP packet. spi + seq are clear; payload is encrypted (IV||ciphertext);
    pad/pad_length/next_header form the ESP trailer; icv is the integrity tag.
    """
    spi: SecurityParameterIndex
    sequence_number: u32
    payload: [u8]
    pad: [u8]
    pad_length: u8
    next_header: u8
    icv: [u8]

impl EspPacket:
    static fn new(spi: SecurityParameterIndex, sequence_number: u32, payload: [u8], pad: [u8], next_header: u8, icv: [u8]) -> EspPacket:
        EspPacket(spi: spi, sequence_number: sequence_number, payload: payload, pad: pad, pad_length: pad.len().to_u8(), next_header: next_header, icv: icv)

# ============================================================================
# AhHeader -- Authentication Header (RFC 4302 §2), integrity only
# ============================================================================

struct AhHeader:
    """AH header. payload_length is AH length in 32-bit words minus 2; icv
    covers the immutable IP fields + payload (computed by the caller)."""
    next_header: u8
    payload_length: u8
    reserved: u16
    spi: SecurityParameterIndex
    sequence_number: u32
    icv: [u8]

impl AhHeader:
    static fn new(next_header: u8, spi: SecurityParameterIndex, sequence_number: u32, icv: [u8]) -> AhHeader:
        # Fixed AH header is 12 bytes (3 words); total words = 3 + icv_words;
        # payload_length field = total_words - 2.
        var icv_words = icv.len().to_u8() / 4
        var pl = (3 + icv_words) - 2
        AhHeader(next_header: next_header, payload_length: pl, reserved: 0, spi: spi, sequence_number: sequence_number, icv: icv)

# ============================================================================
# IkeHeader -- IKEv2 fixed header (RFC 7296 §3.1, 28 bytes)
# ============================================================================

struct IkeHeader:
    initiator_spi: u64
    responder_spi: u64
    next_payload: u8
    version: u8
    exchange_type: u8
    flags: u8
    message_id: u32
    length: u32

impl IkeHeader:
    static fn new(initiator_spi: u64, responder_spi: u64, next_payload: u8, exchange_type: u8, flags: u8, message_id: u32, length: u32) -> IkeHeader:
        IkeHeader(initiator_spi: initiator_spi, responder_spi: responder_spi, next_payload: next_payload, version: IKE_VERSION_2, exchange_type: exchange_type, flags: flags, message_id: message_id, length: length)

# ============================================================================
# IkePayloadHeader -- generic IKEv2 payload (RFC 7296 §3.2)
# ============================================================================

struct IkePayloadHeader:
    next_payload: u8
    critical: bool
    length: u16             # total payload length incl. the 4-byte header
    body: [u8]

impl IkePayloadHeader:
    static fn new(next_payload: u8, critical: bool, body: [u8]) -> IkePayloadHeader:
        IkePayloadHeader(next_payload: next_payload, critical: critical, length: (body.len() + 4).to_u16(), body: body)

# ============================================================================
# IkeMessage -- header + ordered payloads
# ============================================================================

struct IkeMessage:
    header: IkeHeader
    payloads: [IkePayloadHeader]

impl IkeMessage:
    static fn new(header: IkeHeader, payloads: [IkePayloadHeader]) -> IkeMessage:
        IkeMessage(header: header, payloads: payloads)
