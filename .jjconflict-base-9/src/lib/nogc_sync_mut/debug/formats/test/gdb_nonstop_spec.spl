#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.protocol.gdb_mi_nonstop.GdbMiNonStopController
use std.nogc_sync_mut.debug.remote.feature.features.FeatureId

fn main():
    describe("GdbMiNonStopController command builders"):
        it("builds thread interrupt command"):
            val cmd = GdbMiNonStopController.build_thread_interrupt_cmd(3)
            expect(cmd).to_equal("exec-interrupt --thread 3")

        it("builds thread interrupt command for thread 1"):
            val cmd = GdbMiNonStopController.build_thread_interrupt_cmd(1)
            expect(cmd).to_equal("exec-interrupt --thread 1")

        it("builds thread continue command"):
            val cmd = GdbMiNonStopController.build_thread_continue_cmd(5)
            expect(cmd).to_equal("exec-continue --thread 5")

        it("builds thread continue command for thread 2"):
            val cmd = GdbMiNonStopController.build_thread_continue_cmd(2)
            expect(cmd).to_equal("exec-continue --thread 2")

        it("builds enable non-stop command"):
            val cmd = GdbMiNonStopController.build_enable_nonstop_cmd()
            expect(cmd).to_equal("gdb-set non-stop on")

        it("builds enable async command"):
            val cmd = GdbMiNonStopController.build_enable_async_cmd()
            expect(cmd).to_equal("gdb-set target-async on")

        it("builds disable non-stop command"):
            val cmd = GdbMiNonStopController.build_disable_nonstop_cmd()
            expect(cmd).to_equal("gdb-set non-stop off")

        it("builds stop all threads command"):
            val cmd = GdbMiNonStopController.build_stop_all_cmd()
            expect(cmd).to_equal("exec-interrupt --all")

        it("interrupt command contains thread flag"):
            val cmd = GdbMiNonStopController.build_thread_interrupt_cmd(42)
            expect(cmd).to_contain("--thread")

        it("continue command contains thread flag"):
            val cmd = GdbMiNonStopController.build_thread_continue_cmd(7)
            expect(cmd).to_contain("--thread")

    describe("FeatureId non-stop variants"):
        it("has NonStopMode"):
            expect(FeatureId.NonStopMode.to_string()).to_equal("NonStopMode")

        it("has AsyncInterrupt"):
            expect(FeatureId.AsyncInterrupt.to_string()).to_equal("AsyncInterrupt")
