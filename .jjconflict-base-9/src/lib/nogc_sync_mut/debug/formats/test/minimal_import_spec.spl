"""Minimal test."""

use std.binary_io.{BinaryReader, ByteOrder}

describe "Reader":
    it "reads u32":
        val data: [u8] = [0x01, 0x02, 0x03, 0x04]
        var reader = BinaryReader.new(data)
        val order = ByteOrder.LittleEndian
        val v = reader.read_u32(order)
        expect(v.?).to_equal(true)
