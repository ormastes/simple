# MCP Resource Utilities
#
# Shared utilities for MCP resource providers.
# Eliminates duplication across bugdb_resource, testdb_resource, featuredb_resource.
#
# Usage:
#   use std.nogc_async_mut.mcp.resource_utils.{
#       extract_json_string, extract_json_int, extract_json_float, extract_json_array,
#       current_timestamp, items_to_json
#   }

use std.io.{rt_timestamp_now}

fn escape_json(s: text) -> text:
    var out = ""
    for ch in s:
        if ch == "\\":
            out = out + "\\\\"
        elif ch == "\"":
            out = out + "\\\""
        elif ch == "\n":
            out = out + "\\n"
        elif ch == "\t":
            out = out + "\\t"
        elif ch == "\r":
            out = out + "\\r"
        else:
            out = out + ch
    out


# ============================================================================
# JSON Parsing Helpers
# ============================================================================

# Extract a string value from JSON by key
fn extract_json_string(json: text, key: text) -> text:
    val pattern = "\"{key}\""
    val start = json.find(pattern)
    if start < 0:
        return ""

    var pos = start + pattern.len()
    while pos < json.len() and json.char_at(pos) != ':':
        pos = pos + 1
    if pos >= json.len():
        return ""
    pos = pos + 1
    while pos < json.len() and (json.char_at(pos) == ' ' or json.char_at(pos) == '\t'):
        pos = pos + 1
    if pos >= json.len() or json.char_at(pos) != '"':
        return ""

    val value_start = pos + 1
    pos = value_start
    var escaped = false
    while pos < json.len():
        val ch = json.char_at(pos)
        if ch == '"' and not escaped:
            return json.substring(value_start, pos)
        escaped = ch == '\\' and not escaped
        if ch != '\\':
            escaped = false
        pos = pos + 1

    ""

# Extract an integer value from JSON by key
fn extract_json_int(json: text, key: text) -> i64:
    val pattern = "\"{key}\""
    val start = json.find(pattern)
    if start < 0:
        return 0

    var value_start = start + pattern.len()
    while value_start < json.len() and json.char_at(value_start) != ':':
        value_start = value_start + 1
    if value_start >= json.len():
        return 0
    value_start = value_start + 1
    while value_start < json.len() and (json.char_at(value_start) == ' ' or json.char_at(value_start) == '\t'):
        value_start = value_start + 1

    var value_end = value_start
    while value_end < json.len():
        val ch = json.char_at(value_end)
        if ch < '0' or ch > '9':
            if ch != '-':
                break
        value_end = value_end + 1

    if value_end == value_start:
        return 0

    val num_str = json.substring(value_start, value_end)
    num_str.parse_int() ?? 0

# Extract a float value from JSON by key
fn extract_json_float(json: text, key: text) -> f64:
    val pattern = "\"{key}\""
    val start = json.find(pattern)
    if start < 0:
        return 0.0

    var value_start = start + pattern.len()
    while value_start < json.len() and json.char_at(value_start) != ':':
        value_start = value_start + 1
    if value_start >= json.len():
        return 0.0
    value_start = value_start + 1
    while value_start < json.len() and (json.char_at(value_start) == ' ' or json.char_at(value_start) == '\t'):
        value_start = value_start + 1

    var value_end = value_start
    while value_end < json.len():
        val ch = json.char_at(value_end)
        if (ch < '0' or ch > '9') and ch != '.' and ch != '-':
            break
        value_end = value_end + 1

    if value_end == value_start:
        return 0.0

    val num_str = json.substring(value_start, value_end)
    num_str.parse_float() ?? 0.0

# Extract a string array from JSON by key
fn extract_json_array(json: text, key: text) -> [text]:
    val pattern = "\"{key}\""
    val start = json.find(pattern)
    if start < 0:
        return []

    var array_start = start + pattern.len()
    while array_start < json.len() and json.char_at(array_start) != ':':
        array_start = array_start + 1
    if array_start >= json.len():
        return []
    array_start = array_start + 1
    while array_start < json.len() and (json.char_at(array_start) == ' ' or json.char_at(array_start) == '\t'):
        array_start = array_start + 1
    if array_start >= json.len() or json.char_at(array_start) != '[':
        return []
    array_start = array_start + 1

    val array_end = json.find("]", array_start)
    if array_end < 0:
        return []

    val array_str = json.substring(array_start, array_end)

    var items: [text] = []
    var pos = 0
    while pos < array_str.len():
        val quote_start = array_str.find("\"", pos)
        if quote_start < 0:
            break
        val quote_end = array_str.find("\"", quote_start + 1)
        if quote_end < 0:
            break
        items.push(array_str.substring(quote_start + 1, quote_end))
        pos = quote_end + 1

    items

# ============================================================================
# Timestamp Helpers
# ============================================================================

# Get current timestamp in ISO 8601 format
fn current_timestamp() -> text:
    val micros = rt_timestamp_now()
    timestamp_to_iso(micros)

# Convert microseconds to ISO 8601 format
fn timestamp_to_iso(micros: i64) -> text:
    # For now, return raw timestamp - can be improved later
    "{micros}"

# ============================================================================
# Generic Response Helpers
# ============================================================================

# Convert a list of items to JSON array using a converter function
fn items_to_json<T>(items: [T], item_key: text, converter: fn(T) -> text) -> text:
    var raw_items: [text] = []
    for item in items:
        raw_items.push(converter(item))

    "{\"total\":" + str(items.len()) + ",\"" + escape_json(item_key) + "\":[" + raw_items.join(",") + "]}"

# Create an error response
fn error_json(message: text) -> text:
    "{\"error\":\"" + escape_json(message) + "\"}"

# Create a success response
fn success_json(id: text) -> text:
    "{\"success\":true,\"id\":\"" + escape_json(id) + "\"}"

# Create a success response with custom key
fn success_json_with_key(key: text, value: text) -> text:
    "{\"success\":true,\"" + escape_json(key) + "\":\"" + escape_json(value) + "\"}"
