struct ZstdLiteralsSection:
    literals: [u8]
    bytes_used: i64

struct ZstdSequenceCount:
    count: i64
    bytes_used: i64

struct ZstdSequenceModes:
    literals_length_mode: i64
    offsets_mode: i64
    match_length_mode: i64
    bytes_used: i64

struct ZstdSequence:
    literal_length: i64
    match_length: i64
    offset_value: i64

struct ZstdRepeatOffsets:
    rep1: i64
    rep2: i64
    rep3: i64

struct ZstdRleSequenceTables:
    literal_length_code: i64
    offset_code: i64
    match_length_code: i64
    bytes_used: i64

struct ZstdSequenceTables:
    literal_lengths_mode: i64
    literal_lengths_rle: i64?
    literal_lengths: ZstdFseDecodeTable?
    offsets_mode: i64
    offsets_rle: i64?
    offsets: ZstdFseDecodeTable?
    match_lengths_mode: i64
    match_lengths_rle: i64?
    match_lengths: ZstdFseDecodeTable?
    bytes_used: i64

struct ZstdSequenceTableHistory:
    literal_lengths: ZstdFseDecodeTable
    offsets: ZstdFseDecodeTable
    match_lengths: ZstdFseDecodeTable

struct ZstdHufTableState:
    table_bits: i64
    table: [ZstdHufDecodeEntry]

struct ZstdLiteralsDecodeResult:
    literals: [u8]
    table_state: ZstdHufTableState?

struct ZstdFrameHeader:
    bytes_used: i64
    checksum_flag: bool
    window_size: i64
    content_size: i64?
    dictionary_id: i64?

val ZSTD_XXH64_PRIME1: u64 = 0x9E3779B185EBCA87u64
val ZSTD_XXH64_PRIME2: u64 = 0xC2B2AE3D27D4EB4Fu64
val ZSTD_XXH64_PRIME3: u64 = 0x165667B19E3779F9u64
val ZSTD_XXH64_PRIME4: u64 = 0x85EBCA77C2B2AE63u64
val ZSTD_XXH64_PRIME5: u64 = 0x27D4EB2F165667C5u64

# ============================================================================
# Utility helpers — used by zstd sub-modules to avoid importing from utilities
# (utilities.spl imports zstd.spl which imports these sub-modules, causing a
# circular dependency if sub-modules also imported from utilities).
# ============================================================================

fn read_u32_le(data: [u8], pos: i64) -> Result<u32, CompressionError>:
    if pos < 0 or pos + 4 > data.len():
        return Err(CompressionError.TruncatedInput("need 4 bytes"))
    Ok(data[pos].to_u32() |
        (data[pos + 1].to_u32() << 8u32) |
        (data[pos + 2].to_u32() << 16u32) |
        (data[pos + 3].to_u32() << 24u32))

fn write_u32_le(buf: [u8], value: u32) -> [u8]:
    var out = buf
    out.push((value & 0xFFu32).to_u8())
    out.push(((value >> 8u32) & 0xFFu32).to_u8())
    out.push(((value >> 16u32) & 0xFFu32).to_u8())
    out.push(((value >> 24u32) & 0xFFu32).to_u8())
    out

fn write_u64_le(buf: [u8], value: u64) -> [u8]:
    var out = buf
    var shift: u64 = 0u64
    while shift < 64u64:
        out.push(((value >> shift) & 0xFFu64).to_u8())
        shift = shift + 8u64
    out

fn append_bytes(buf: [u8], bytes: [u8]) -> [u8]:
    var out = buf
    var i = 0
    while i < bytes.len():
        out.push(bytes[i])
        i = i + 1
    out

fn append_self_overlap_copy(buf: [u8], offset: i64, count: i64) -> Result<[u8], CompressionError>:
    if offset <= 0 or offset > buf.len():
        return Err(CompressionError.CorruptStream("invalid overlap copy offset"))
    if count < 0:
        return Err(CompressionError.CorruptStream("invalid overlap copy count"))
    var out = buf
    var i = 0
    while i < count:
        val src = out.len() - offset
        out.push(out[src])
        i = i + 1
    Ok(out)

fn compression_simd_tier_detect() -> CompressionSimdTier:
    # Project the canonical std.simd runtime profile onto the compression tier
    # seam (kept in agreement with utilities.compression_simd_tier_detect).
    match detect_profile():
        case SimdTier.x86_64_avx2:
            CompressionSimdTier.avx2
        case SimdTier.x86_64_avx512:
            CompressionSimdTier.avx2
        case SimdTier.aarch64_neon:
            CompressionSimdTier.neon
        case SimdTier.aarch64_sve:
            CompressionSimdTier.neon
        case SimdTier.aarch64_sve2:
            CompressionSimdTier.neon
        case _:
            CompressionSimdTier.scalar
