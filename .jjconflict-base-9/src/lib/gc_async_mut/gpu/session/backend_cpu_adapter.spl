# CPU reference backend adapter — pure Simple, no externs needed.
# Always available; supports software rasterization but not direct present.

use std.io

class BackendCpuAdapter:
    handle: i64
    device_name: text
    initialized: bool
    session_mode: text

    static fn create(mode: text) -> BackendCpuAdapter:
        BackendCpuAdapter(
            handle: 0,
            device_name: "cpu-reference",
            initialized: false,
            session_mode: mode,
        )

    me init_device() -> text:
        self.handle = 1
        self.initialized = true
        ""

    me submit_commands(cmd_count: i64) -> text:
        if self.initialized == false:
            return "cpu: device not initialized"
        if cmd_count < 0:
            return "cpu: invalid cmd_count"
        ""

    me present() -> text:
        if self.initialized == false:
            return "cpu: device not initialized"
        "cpu: present requires a window manager surface"

    me readback(x: i64, y: i64, w: i64, h: i64) -> text:
        if self.initialized == false:
            return "cpu: device not initialized"
        if w <= 0 or h <= 0:
            return "cpu: invalid readback dimensions"
        ""

    me supports_compute() -> bool:
        true

    me supports_graphics() -> bool:
        true

    me supports_present() -> bool:
        false

    me device_info() -> text:
        "cpu-reference mode=" + self.session_mode + " initialized=" + self.initialized.to_text()

    me cleanup() -> text:
        self.initialized = false
        self.handle = 0
        ""
