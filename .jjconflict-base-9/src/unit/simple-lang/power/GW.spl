# Unit: GigaWatt
# Kind: Power
# Symbol: GW
# Canonical scale: 1000000000.0 W

class GigaWatt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: GigaWatt) -> GigaWatt: GigaWatt(value: self.value + other.value)
    fn sub(other: GigaWatt) -> GigaWatt: GigaWatt(value: self.value - other.value)

    static fn kind() -> text: "Power"
    static fn symbol() -> text: "GW"
    static fn scale_to_base() -> f64: 1000000000.0
    static fn base_unit() -> text: "W"
    static fn zero() -> GigaWatt: GigaWatt(value: 0.0)

export GigaWatt
