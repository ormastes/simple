use app.wm_compare.html_compat_geometry_probe.{html_compat_fixture_simple_boxes_from_html}

fn _fixture_html(name: text) -> text:
    if name == "06_card_panel":
        return "<body style='margin:0;background-color:#ffffff'><section id='card_panel' style='margin:16px;padding:14px;width:210px;background-color:#f1f5f9;border:1px solid #94a3b8'><h3 id='card_title' style='margin:0;font-size:16px;color:#0f172a'>Panel</h3><p id='card_body' style='margin-top:8px;color:#334155'>Status ready</p></section></body>"
    if name == "24_flex_wrap_reverse_basic":
        return "<body><div id='wrap_reverse_shell' style='margin:16px;width:140px;display:flex;flex-direction:row;flex-wrap:wrap-reverse'><div id='wrap_reverse_a' style='width:60px;height:24px'></div><div id='wrap_reverse_b' style='width:60px;height:24px'></div><div id='wrap_reverse_c' style='width:60px;height:24px'></div></div></body>"
    ""

fn _require_count(name: text, expected: i32) -> bool:
    val boxes = html_compat_fixture_simple_boxes_from_html(name, _fixture_html(name), 320, 240)
    print "fixture=" + name + " count=" + boxes.len().to_string()
    if boxes.len() != expected:
        print "status=fail"
        print "reason=count"
        print "fixture=" + name
        return false
    true

fn main() -> i64:
    if not _require_count("06_card_panel", 3): return 1
    if not _require_count("24_flex_wrap_reverse_basic", 4): return 1
    print "status=pass"
    0
