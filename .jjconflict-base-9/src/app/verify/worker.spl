# Heavy verify worker for src/app/verify/main.spl.

use std.cli.cli_util.{get_cli_args}
use app.verify.full_verify.{run_full_verify}
use verification.state.{VerificationState}
use verification.proof_unit.{ProofUnit, ProofUnitSet}
use verification.report.{VerificationReport, ReportLevel}

fn run_lean_status(args: [text]) -> i64:
    val units = discover_proof_units()

    var level = ReportLevel.File
    for arg in args:
        if arg == "--detail":
            level = ReportLevel.Theorem

    var use_sdn = false
    for arg in args:
        if arg == "--format=sdn":
            use_sdn = true

    val timestamp = "2026-04-04T00:00:00Z"
    val report = VerificationReport.from_units(
        "Lean Verification Status", "project", units, timestamp
    )

    if use_sdn:
        print report.render_sdn()
    else:
        print report.render(level)

    val counts = units.state_counts()
    if counts.failed > 0:
        1
    else:
        0

fn discover_proof_units() -> ProofUnitSet:
    use std.io_runtime.{file_exists, read_dir}

    var units = ProofUnitSet.empty()
    val gen_dir = "build/verification/generated"

    if not file_exists(gen_dir):
        return units

    val entries = read_dir(gen_dir)
    for entry in entries:
        if entry.ends_with(".lean"):
            val lean_path = "{gen_dir}/{entry}"
            val module_name = entry.replace(".lean", "")
            val unit = ProofUnit.create(
                source_file="(discovered)",
                source_symbol="*",
                lean_module="Verification.{module_name}",
                lean_file=lean_path
            ).with_state(VerificationState.NotChecked)
            units = units.add(unit)

    units

fn main() -> i64:
    val args = get_cli_args()
    for arg in args:
        if arg == "--lean-status":
            return run_lean_status(args)
    run_full_verify(args)
