# Chromium Shell Snapshot / Record-Replay Test Mode (V3, Row 5 — M11)
#
# Per `doc/03_plan/v3_simple_browser_milestones.md` §M11, V3 needs a
# deterministic frame-by-frame log of a `ui.chromium` session so visual
# regressions can be triaged offline. The three acceptance criteria are:
#
#   1. A `--record session.bin` flag on `ui.chromium`.
#   2. Replay produces byte-identical frames (see `snapshot_replay.spl`).
#   3. At least one `wm_compare` regression test uses the flow.
#
# This file owns piece (1) and the on-wire frame model. Replay lives in
# `snapshot_replay.spl` — keeping the record side and the replay side
# in separate modules means a crashing replay can't corrupt the
# recorder, which is the point of a "triage offline" format.
#
# All M11 code is NEW — this file does not touch any existing
# `src/app/ui.chromium/*.spl`. SFFI placeholders are used where the
# real pipeline eventually needs to reach into the compositor; M11
# itself is pure in-memory record-and-replay.

# ─── Record-mode CLI flag ──────────────────────────────────────────────
#
# The flag surface is kept minimal because M11 is S-effort. The
# recorder only needs to answer two questions:
#
#   * "Is record mode on?"
#   * "Where do I write the session?"

class RecordFlag:
    """Parsed `--record session.bin` flag state.

    Intentionally immutable — `ui.chromium` parses argv once at
    startup, hands a `RecordFlag` to the shell, and never mutates it
    again. A missing flag is represented by `RecordFlag.disabled()`
    rather than a nullable option so downstream code can uniformly
    call `.is_recording()`."""

    enabled: bool
    path: text

    static fn disabled() -> RecordFlag:
        """The default state — recording is off, path is empty."""
        RecordFlag(enabled: false, path: "")

    static fn enabled_at(path: text) -> RecordFlag:
        """Record mode on, writing to `path`.

        An empty path is still accepted here — the argv parser is the
        place that rejects `--record` with no argument. This keeps the
        value type a dumb record."""
        RecordFlag(enabled: true, path: path)

    me is_recording() -> bool:
        self.enabled

    me target_path() -> text:
        self.path


fn parse_record_flag(argv: [text]) -> RecordFlag:
    """Scan argv for `--record <path>` and return a `RecordFlag`.

    Accepted shapes:
        --record session.bin
        --record=session.bin

    Unknown flags are ignored — argv parsing belongs to the main
    `ui.chromium` driver. This helper is only the §M11 criterion #1
    surface and only speaks about `--record`."""

    val n = argv.len()
    var i = 0
    while i < n:
        val arg = argv[i]
        if arg == "--record":
            val next_index = i + 1
            if next_index < n:
                return RecordFlag.enabled_at(argv[next_index])
            # `--record` with no following token — fall through to
            # disabled. The argv parser in `ui.chromium/main.spl` is
            # what surfaces the user-visible error.
            return RecordFlag.disabled()
        if arg.starts_with("--record="):
            val path = arg.slice("--record=".len(), arg.len())
            return RecordFlag.enabled_at(path)
        i = i + 1
    RecordFlag.disabled()


# ─── Frame record model ────────────────────────────────────────────────
#
# A frame is a tuple of (sequence number, width, height, pixel hash,
# byte length). The "byte-identical" acceptance criterion is served by
# the pixel hash — replay recomputes the hash and compares. The actual
# pixels are referenced by an opaque `blob_id` so the format is still
# small enough to check into the repo as a test fixture.

class SnapshotFrame:
    """One frame in a recorded session.

    `blob_id` is a content-addressed handle into whichever backing
    store the session uses (in-memory arena in tests, file offset in
    production). `pixel_hash` is a deterministic digest computed from
    the pixels at record time — this is the exact quantity the replay
    side compares against."""

    seq: i64
    width: i64
    height: i64
    blob_id: i64
    byte_len: i64
    pixel_hash: i64

    static fn new(
        seq: i64,
        width: i64,
        height: i64,
        blob_id: i64,
        byte_len: i64,
        pixel_hash: i64
    ) -> SnapshotFrame:
        SnapshotFrame(
            seq: seq,
            width: width,
            height: height,
            blob_id: blob_id,
            byte_len: byte_len,
            pixel_hash: pixel_hash
        )

    me pixel_count() -> i64:
        self.width * self.height

    me matches(other: SnapshotFrame) -> bool:
        """Two frames are equivalent iff every field lines up.

        The replay driver in `snapshot_replay.spl` uses this to
        implement the "byte-identical frames" acceptance bullet —
        shape, length, and hash all have to match."""
        if self.seq != other.seq:
            return false
        if self.width != other.width:
            return false
        if self.height != other.height:
            return false
        if self.byte_len != other.byte_len:
            return false
        if self.pixel_hash != other.pixel_hash:
            return false
        true


# ─── Deterministic pixel hashing ───────────────────────────────────────
#
# The hash is an FNV-1a-style rolling accumulator over the pixel
# stream. It is NOT cryptographic — the job is to catch "one pixel
# moved" bugs during wm_compare triage, not to defend against
# tampering. Using a pure Simple implementation (instead of SFFI to a
# native hasher) is what makes the function deterministic across the
# three bootstrap stages, which is a hidden requirement of the
# "byte-identical replay" bullet.

val SNAPSHOT_FNV_OFFSET: i64 = 1469598103934665603
val SNAPSHOT_FNV_PRIME: i64 = 1099511628211

fn snapshot_hash_init() -> i64:
    SNAPSHOT_FNV_OFFSET

fn snapshot_hash_step(acc: i64, byte_val: i64) -> i64:
    """Absorb one byte of pixel data into a rolling hash."""
    val mixed = acc ^ byte_val
    mixed * SNAPSHOT_FNV_PRIME

fn snapshot_hash_bytes(bytes: [i64]) -> i64:
    """Hash a byte buffer. Exposed for tests and for the replay driver."""
    var acc = snapshot_hash_init()
    for b in bytes:
        acc = snapshot_hash_step(acc: acc, byte_val: b)
    acc


# ─── Session recorder ──────────────────────────────────────────────────
#
# `SnapshotRecorder` is the object that `ui.chromium`'s render loop
# hands frames to. It assigns sequence numbers, maintains the running
# hash set, and produces a `SnapshotSession` when finalised. The
# recorder is deliberately dumb — it does not know how the session is
# serialised; that is `SnapshotSession::to_wire()` below.

class SnapshotRecorder:
    """Collects `SnapshotFrame`s from the render loop."""

    flag: RecordFlag
    frames: [SnapshotFrame]
    next_seq: i64
    next_blob_id: i64

    static fn new(flag: RecordFlag) -> SnapshotRecorder:
        SnapshotRecorder(
            flag: flag,
            frames: [],
            next_seq: 0,
            next_blob_id: 0
        )

    me is_active() -> bool:
        self.flag.is_recording()

    me frame_count() -> i64:
        self.frames.len()

    me record_pixels(width: i64, height: i64, pixels: [i64]) -> SnapshotFrame:
        """Hash `pixels` and append a `SnapshotFrame` to the session.

        Returns the freshly assigned frame so the caller can log it,
        tee it into `wm_compare`, etc. Even when the recorder is
        inactive we still hash and return a frame value — this keeps
        the call-site branchless and means inactive mode costs the
        caller the same amount of Simple it would cost to ignore the
        return value."""

        val hash = snapshot_hash_bytes(pixels)
        val frame = SnapshotFrame.new(
            self.next_seq,
            width,
            height,
            self.next_blob_id,
            pixels.len(),
            hash
        )
        if self.flag.is_recording():
            self.frames.push(frame)
            self.next_seq = self.next_seq + 1
            self.next_blob_id = self.next_blob_id + 1
        frame

    me finalize() -> SnapshotSession:
        """Close recording and produce a replayable session."""
        SnapshotSession.new(self.flag.target_path(), self.frames)


# ─── Serialised session ────────────────────────────────────────────────
#
# `SnapshotSession` is what gets written to `session.bin` at shutdown
# and read back by the replay driver. The on-wire format is a
# sequence of (seq, width, height, blob_id, byte_len, pixel_hash)
# i64 records — six i64s per frame — preceded by a magic word and a
# frame count. Keeping the wire format small lets us check a session
# fixture into the repo for the wm_compare regression without blowing
# up the tree.

val SNAPSHOT_MAGIC: i64 = 1397639251  # "SBIN" as i64
val SNAPSHOT_VERSION: i64 = 1
val SNAPSHOT_FIELDS_PER_FRAME: i64 = 6

class SnapshotSession:
    """A finished recording ready to be written out or replayed."""

    path: text
    frames: [SnapshotFrame]

    static fn new(path: text, frames: [SnapshotFrame]) -> SnapshotSession:
        SnapshotSession(path: path, frames: frames)

    me frame_count() -> i64:
        self.frames.len()

    me destination() -> text:
        self.path

    me to_wire() -> [i64]:
        """Serialise to the `.bin` wire format.

        Layout: [magic, version, frame_count, (seq, w, h, blob, len, hash)*]

        Pure Simple for determinism — replay across bootstrap stages
        has to see the same bytes, and that rules out any SFFI-based
        marshalling for now."""

        var out: [i64] = []
        out.push(SNAPSHOT_MAGIC)
        out.push(SNAPSHOT_VERSION)
        out.push(self.frames.len())
        for f in self.frames:
            out.push(f.seq)
            out.push(f.width)
            out.push(f.height)
            out.push(f.blob_id)
            out.push(f.byte_len)
            out.push(f.pixel_hash)
        out

    me wire_word_count() -> i64:
        """Expected word count for `to_wire()` output.

        Used by the spec to assert the wire format has not drifted."""
        3 + (self.frames.len() * SNAPSHOT_FIELDS_PER_FRAME)
