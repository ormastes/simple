"""
POSIX Baseline Runner

Provides benchmark workloads that exercise the host filesystem (via
rt_file_* externs) so performance can be compared against Simple
in-process FS drivers.

All run_posix_* functions take no arguments and return a PosixBenchResult
with driver_name = "posix".
"""

use std.io_runtime.{time_now_unix_micros, getpid, file_write, file_read, file_delete, file_exists, dir_create}

# PosixBenchResult is defined here rather than imported from bench_harness to avoid
# the deep import chain (bench_harness → nvfs/dbfs/ramfs/mount_table) that
# combined with os.services.fat32 in the spec causes interpreter stack overflow.
# The interpreter matches struct field access by name, so callers using the
# bench_harness.PosixBenchResult type annotation still work at runtime.
struct PosixBenchResult:
    workload_name: text
    driver_name: text
    p50_us: i64
    p99_us: i64
    bytes_written: i64
    logical_bytes: i64
    recovery_time_us: i64
    mount_time_us: i64
    rss_kib: i64
    cache_hit_ratio: i64

# ---- POSIX timing helper ----

fn posix_now_us() -> i64:
    time_now_unix_micros()

fn posix_elapsed_us(start_us: i64) -> i64:
    time_now_unix_micros() - start_us

# ---- Temp directory helper ----

fn posix_tmp_dir() -> text:
    val pid = getpid()
    val dir = "/tmp/simple_posix_bench_" + pid.to_text()
    dir_create(dir, true)
    dir

# ---- Workload: metadata storm (create/rename/unlink N files) ----

fn run_posix_metadata_storm() -> PosixBenchResult:
    val tmp = posix_tmp_dir()
    var total: i64 = 0
    var worst: i64 = 0
    var i: i64 = 0
    while i < 5:
        val path = tmp + "/storm_" + i.to_text() + ".txt"
        val path_r = path + "_r"
        val t0 = posix_now_us()
        file_write(path, "x")
        file_exists(path)
        file_write(path_r, "x")
        file_delete(path)
        file_delete(path_r)
        val elapsed = posix_elapsed_us(t0)
        total = total + elapsed
        if elapsed > worst:
            worst = elapsed
        i = i + 1
    PosixBenchResult(
        workload_name: "metadata_storm",
        driver_name: "posix",
        p50_us: total / 5,
        p99_us: worst,
        bytes_written: 0,
        logical_bytes: 0,
        recovery_time_us: 0,
        mount_time_us: 0,
        rss_kib: 0,
        cache_hit_ratio: 0,
    )

# ---- Workload: append-heavy log ----

fn run_posix_append_log() -> PosixBenchResult:
    val tmp = posix_tmp_dir()
    val path = tmp + "/append_log.bin"
    var total: i64 = 0
    var worst: i64 = 0
    var bytes_written: i64 = 0
    var i: i64 = 0
    while i < 5:
        val t0 = posix_now_us()
        file_write(path, "aaaa")
        val elapsed = posix_elapsed_us(t0)
        total = total + elapsed
        if elapsed > worst:
            worst = elapsed
        bytes_written = bytes_written + 4
        i = i + 1
    file_delete(path)
    PosixBenchResult(
        workload_name: "append_heavy_log",
        driver_name: "posix",
        p50_us: total / 5,
        p99_us: worst,
        bytes_written: bytes_written,
        logical_bytes: bytes_written,
        recovery_time_us: 0,
        mount_time_us: 0,
        rss_kib: 0,
        cache_hit_ratio: 0,
    )

# ---- Workload: random overwrite ----

fn run_posix_random_overwrite() -> PosixBenchResult:
    val tmp = posix_tmp_dir()
    val path = tmp + "/random_ow.bin"
    file_write(path, "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    var total: i64 = 0
    var worst: i64 = 0
    var bytes_written: i64 = 0
    var i: i64 = 0
    while i < 5:
        val t0 = posix_now_us()
        file_write(path, "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb")
        val elapsed = posix_elapsed_us(t0)
        total = total + elapsed
        if elapsed > worst:
            worst = elapsed
        bytes_written = bytes_written + 64
        i = i + 1
    file_delete(path)
    PosixBenchResult(
        workload_name: "random_overwrite",
        driver_name: "posix",
        p50_us: total / 5,
        p99_us: worst,
        bytes_written: bytes_written,
        logical_bytes: bytes_written,
        recovery_time_us: 0,
        mount_time_us: 0,
        rss_kib: 0,
        cache_hit_ratio: 0,
    )

# ---- Workload: mmap read-mostly ----

fn run_posix_mmap_read() -> PosixBenchResult:
    val tmp = posix_tmp_dir()
    val path = tmp + "/mmap_read.bin"
    file_write(path, "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    var total: i64 = 0
    var worst: i64 = 0
    var i: i64 = 0
    while i < 5:
        val t0 = posix_now_us()
        file_read(path)
        val elapsed = posix_elapsed_us(t0)
        total = total + elapsed
        if elapsed > worst:
            worst = elapsed
        i = i + 1
    file_delete(path)
    PosixBenchResult(
        workload_name: "mmap_read_mostly",
        driver_name: "posix",
        p50_us: total / 5,
        p99_us: worst,
        bytes_written: 0,
        logical_bytes: 0,
        recovery_time_us: 0,
        mount_time_us: 0,
        rss_kib: 0,
        cache_hit_ratio: 0,
    )

# ---- run_posix_all ----

fn run_posix_all() -> [PosixBenchResult]:
    var results: [PosixBenchResult] = []
    results.push(run_posix_metadata_storm())
    results.push(run_posix_append_log())
    results.push(run_posix_random_overwrite())
    results.push(run_posix_mmap_read())
    results

# ---- Comparison report ----

fn format_comparison_report(simple_results: [PosixBenchResult], posix_results: [PosixBenchResult]) -> text:
    var lines: [text] = []
    lines.push("workload | driver | p50_us | p99_us")
    lines.push("---------|--------|--------|-------")
    var i: i64 = 0
    while i < simple_results.len():
        val r = simple_results[i]
        val row = r.workload_name + " | " + r.driver_name + " | " + r.p50_us.to_text() + " | " + r.p99_us.to_text()
        lines.push(row)
        i = i + 1
    var j: i64 = 0
    while j < posix_results.len():
        val r = posix_results[j]
        val row = r.workload_name + " | " + r.driver_name + " | " + r.p50_us.to_text() + " | " + r.p99_us.to_text()
        lines.push(row)
        j = j + 1
    var out: text = ""
    var k: i64 = 0
    while k < lines.len():
        out = out + lines[k] + "\n"
        k = k + 1
    out
