use std.spec.{describe, it, assert_equal}
use std.common.encoding.yaml.{yaml_parse, yaml_parse_mapping}
use lib.yaml.types.{is_yaml_null, is_yaml_sequence, is_yaml_mapping}
use lib.yaml.parse.{yaml_parse_flow_sequence, yaml_parse_flow_mapping}

describe "YAML flow collection guards":
    it "keeps valid flow collections":
        assert_equal(is_yaml_sequence(yaml_parse("[a, b]")), true)
        assert_equal(is_yaml_mapping(yaml_parse("{name: Alice}")), true)

    it "rejects unterminated flow collections through public parse":
        assert_equal(is_yaml_null(yaml_parse("[a, b")), true)
        assert_equal(is_yaml_null(yaml_parse("{name: Alice")), true)

    it "rejects unterminated flow collections through direct parsers":
        assert_equal(is_yaml_null(yaml_parse_flow_sequence("[a, b")), true)
        assert_equal(is_yaml_null(yaml_parse_flow_mapping("{name: Alice")), true)

    it "does not expose malformed flow mappings as entries":
        val entries = yaml_parse_mapping("{name: Alice")
        assert_equal(entries.length(), 0)
