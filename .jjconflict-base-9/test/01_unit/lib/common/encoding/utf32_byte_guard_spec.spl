use std.spec.{describe, it, assert_equal}
use std.common.encoding.utf32.{utf32_from_bytes_le, utf32_from_bytes_be}

describe "utf32 byte conversion guards":
    it "keeps valid little-endian bytes":
        assert_equal(utf32_from_bytes_le([0x41, 0x00, 0x00, 0x00]), [0x41])

    it "keeps valid big-endian bytes":
        assert_equal(utf32_from_bytes_be([0x00, 0x00, 0x00, 0x41]), [0x41])

    it "rejects malformed little-endian bytes":
        assert_equal(utf32_from_bytes_le([-1, 0x00, 0x00, 0x00, 0x41, 300, 0x00, 0x00]), [0xFFFD, 0xFFFD])

    it "rejects malformed big-endian bytes":
        assert_equal(utf32_from_bytes_be([0x00, 0x00, 0x00, -1, 0x00, 300, 0x00, 0x41]), [0xFFFD, 0xFFFD])
