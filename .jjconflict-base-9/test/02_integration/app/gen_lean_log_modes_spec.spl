use std.spec.{describe, it, expect}
use std.io_runtime.{process_run}

fn _run_gen_lean(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/gen_lean/main.spl\" " + joined
    ])

describe "gen lean log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_gen_lean(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: simple gen-lean")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_gen_lean(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"gen-lean\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_gen_lean(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: simple gen-lean")

    it "rejects invalid log mode":
        val (out, err, code) = _run_gen_lean(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "emits json for unknown options":
        val (out, err, code) = _run_gen_lean(["--log-mode=json", "--bogus"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"gen-lean\"")
        expect(out).to_contain("\"status\":\"error\"")
