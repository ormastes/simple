"""
Net Acceleration Remaining — Spipe Spec

20 tests covering:
  - TCP connection behavior (states, connect results, recv, send buffer, terminal transitions)
  - Socket connect semantics (POSIX outcomes, readiness, poll)
  - HTTP capability router (static-file routing, worker startup)
  - Packet ring ownership (RX/TX descriptors, ring config)

All classes and helpers are defined inline — no imports from source files.

Feature IDs: FR-NET-0001, FR-NET-0002, FR-NET-0003, FR-NET-0004
Plan: doc/03_plan/agent_tasks/net_acceleration_remaining_2026-04-21.md
"""

use std.spipe.*

# ===========================================================================
# Inline structs and helpers (mirror source modules without importing them)
# ===========================================================================

struct TcpSocketStateT:
    name: text

struct TcpConnectResultT:
    success: bool
    in_progress: bool
    refused: bool
    timed_out: bool
    unreachable: bool
    error_msg: text

struct TcpRecvResultT:
    bytes_read: i64
    would_block: bool
    peer_closed: bool
    was_reset: bool

struct TcpSendBufferT:
    capacity: i64
    queued: i64
    window: i64

fn make_tcp_state(n: text) -> TcpSocketStateT:
    TcpSocketStateT(name: n)

fn make_connect_established() -> TcpConnectResultT:
    TcpConnectResultT(success: true, in_progress: false, refused: false, timed_out: false, unreachable: false, error_msg: "")

fn make_connect_in_progress() -> TcpConnectResultT:
    TcpConnectResultT(success: false, in_progress: true, refused: false, timed_out: false, unreachable: false, error_msg: "EINPROGRESS")

fn make_connect_refused() -> TcpConnectResultT:
    TcpConnectResultT(success: false, in_progress: false, refused: true, timed_out: false, unreachable: false, error_msg: "ECONNREFUSED")

fn make_connect_timed_out() -> TcpConnectResultT:
    TcpConnectResultT(success: false, in_progress: false, refused: false, timed_out: true, unreachable: false, error_msg: "ETIMEDOUT")

fn make_recv_data(n: i64) -> TcpRecvResultT:
    TcpRecvResultT(bytes_read: n, would_block: false, peer_closed: false, was_reset: false)

fn make_recv_would_block() -> TcpRecvResultT:
    TcpRecvResultT(bytes_read: 0, would_block: true, peer_closed: false, was_reset: false)

fn make_recv_peer_closed() -> TcpRecvResultT:
    TcpRecvResultT(bytes_read: 0, would_block: false, peer_closed: true, was_reset: false)

fn make_recv_reset() -> TcpRecvResultT:
    TcpRecvResultT(bytes_read: 0, would_block: false, peer_closed: false, was_reset: true)

fn make_send_buf(cap: i64, win: i64) -> TcpSendBufferT:
    TcpSendBufferT(capacity: cap, queued: 0, window: win)

fn send_buf_can_queue(buf: TcpSendBufferT, n: i64) -> bool:
    (buf.queued + n <= buf.capacity) and (buf.queued + n <= buf.window)

fn send_buf_after_queue(buf: TcpSendBufferT, n: i64) -> TcpSendBufferT:
    TcpSendBufferT(capacity: buf.capacity, queued: buf.queued + n, window: buf.window)

fn tcp_is_terminal(r: TcpConnectResultT) -> bool:
    r.success or r.refused or r.timed_out or r.unreachable

fn state_after_fin(s: TcpSocketStateT) -> TcpSocketStateT:
    if s.name == "ESTABLISHED":
        return make_tcp_state("CLOSE_WAIT")
    s

# Socket connect semantics helpers
struct SocketReadinessT:
    readable: bool
    writable: bool
    is_error: bool

struct SocketConnectOutcomeT:
    ready: bool
    in_progress: bool
    error_code: text
    readiness: SocketReadinessT

fn make_readiness(r: bool, w: bool, e: bool) -> SocketReadinessT:
    SocketReadinessT(readable: r, writable: w, is_error: e)

fn make_connect_ok() -> SocketConnectOutcomeT:
    SocketConnectOutcomeT(ready: true, in_progress: false, error_code: "", readiness: make_readiness(false, true, false))

fn make_connect_progress() -> SocketConnectOutcomeT:
    SocketConnectOutcomeT(ready: false, in_progress: true, error_code: "EINPROGRESS", readiness: make_readiness(false, false, false))

fn make_connect_err(code: text) -> SocketConnectOutcomeT:
    SocketConnectOutcomeT(ready: false, in_progress: false, error_code: code, readiness: make_readiness(false, false, true))

fn outcome_label(o: SocketConnectOutcomeT) -> text:
    if o.ready:
        return "connected"
    if o.in_progress:
        return "in-progress"
    "failed:{o.error_code}"

# HTTP capability router helpers
struct HttpBackendCapsT:
    backend_name: text
    supports_sendfile: bool
    supports_zero_copy: bool

struct ConnectionActionT:
    action_type: text
    use_sendfile: bool
    use_portable_read: bool

fn make_caps_portable(name: text) -> HttpBackendCapsT:
    HttpBackendCapsT(backend_name: name, supports_sendfile: false, supports_zero_copy: false)

fn make_caps_sendfile(name: text) -> HttpBackendCapsT:
    HttpBackendCapsT(backend_name: name, supports_sendfile: true, supports_zero_copy: false)

fn make_caps_zero_copy(name: text) -> HttpBackendCapsT:
    HttpBackendCapsT(backend_name: name, supports_sendfile: true, supports_zero_copy: true)

fn route_static_file(caps: HttpBackendCapsT, has_file_body: bool) -> ConnectionActionT:
    if has_file_body == false:
        return ConnectionActionT(action_type: "Body", use_sendfile: false, use_portable_read: false)
    if caps.supports_sendfile:
        return ConnectionActionT(action_type: "SendFile", use_sendfile: true, use_portable_read: false)
    ConnectionActionT(action_type: "SendFile", use_sendfile: false, use_portable_read: true)

fn http_tier(caps: HttpBackendCapsT) -> text:
    if caps.supports_zero_copy:
        return "zero-copy"
    if caps.supports_sendfile:
        return "sendfile"
    "portable"

# Packet ring ownership helpers
struct PacketBufferOwnerT:
    owner_name: text

struct RxDescriptorT:
    slot_index: i64
    byte_len: i64
    owner: PacketBufferOwnerT

struct TxDescriptorT:
    slot_index: i64
    byte_len: i64
    owner: PacketBufferOwnerT

struct PacketRingConfigT:
    ring_size: i64
    supports_packet_io: bool
    backend_name: text

fn rx_ready(idx: i64, n: i64) -> RxDescriptorT:
    RxDescriptorT(slot_index: idx, byte_len: n, owner: PacketBufferOwnerT(owner_name: "app"))

fn rx_return(desc: RxDescriptorT) -> RxDescriptorT:
    RxDescriptorT(slot_index: desc.slot_index, byte_len: 0, owner: PacketBufferOwnerT(owner_name: "free"))

fn tx_prepare(idx: i64, n: i64) -> TxDescriptorT:
    TxDescriptorT(slot_index: idx, byte_len: n, owner: PacketBufferOwnerT(owner_name: "driver"))

fn tx_complete(desc: TxDescriptorT) -> TxDescriptorT:
    TxDescriptorT(slot_index: desc.slot_index, byte_len: 0, owner: PacketBufferOwnerT(owner_name: "free"))

fn ring_cfg_portable() -> PacketRingConfigT:
    PacketRingConfigT(ring_size: 0, supports_packet_io: false, backend_name: "portable-socket")

fn ring_cfg_afxdp(sz: i64) -> PacketRingConfigT:
    PacketRingConfigT(ring_size: sz, supports_packet_io: true, backend_name: "af-xdp")

# ===========================================================================
# Tests — Group 1: TCP connection behavior (5 tests)
# ===========================================================================

describe "TCP Connection Behavior":
    """
    Tests for socket-visible TCP state transitions, connect completion semantics,
    recv/send data path behavior, and terminal state transitions.
    """

    context "connect completion results":
        it "established result marks success true":
            val r = make_connect_established()
            expect(r.success).to_equal(true)

        it "in-progress result carries EINPROGRESS code":
            val r = make_connect_in_progress()
            expect(r.error_msg).to_equal("EINPROGRESS")

        it "refused result is a terminal outcome":
            val r = make_connect_refused()
            expect(tcp_is_terminal(r)).to_equal(true)

        it "in-progress result is NOT terminal":
            val r = make_connect_in_progress()
            expect(tcp_is_terminal(r) == false).to_equal(true)

        it "timed-out result carries ETIMEDOUT and is terminal":
            val r = make_connect_timed_out()
            expect(r.error_msg).to_equal("ETIMEDOUT")

# ===========================================================================
# Tests — Group 2: TCP recv and send buffer (5 tests)
# ===========================================================================

describe "TCP Recv and Send Buffer":
    """
    Tests for recv semantics (data, would-block, peer-closed, reset) and
    window-aware send buffer queuing.
    """

    context "recv results":
        it "data recv carries the correct byte count":
            val r = make_recv_data(512)
            expect(r.bytes_read).to_equal(512)

        it "would-block recv returns zero bytes":
            val r = make_recv_would_block()
            expect(r.bytes_read).to_equal(0)

        it "peer-closed recv sets peer_closed flag":
            val r = make_recv_peer_closed()
            expect(r.peer_closed).to_equal(true)

        it "reset recv sets was_reset flag":
            val r = make_recv_reset()
            expect(r.was_reset).to_equal(true)

    context "send buffer window":
        it "send buffer allows queuing within window":
            val buf = make_send_buf(4096, 2048)
            expect(send_buf_can_queue(buf, 1024)).to_equal(true)

# ===========================================================================
# Tests — Group 3: Socket connect semantics (5 tests)
# ===========================================================================

describe "Socket Connect Semantics":
    """
    Tests for POSIX-style socket connect outcomes: readiness bits, error codes,
    in-progress detection, and hard error classification.
    """

    context "connect outcomes":
        it "ok outcome is writable":
            val o = make_connect_ok()
            expect(o.readiness.writable).to_equal(true)

        it "in-progress outcome is not ready":
            val o = make_connect_progress()
            expect(o.ready == false).to_equal(true)

        it "in-progress outcome label is in-progress":
            val o = make_connect_progress()
            expect(outcome_label(o)).to_equal("in-progress")

        it "refused outcome has error bit set":
            val o = make_connect_err("ECONNREFUSED")
            expect(o.readiness.is_error).to_equal(true)

        it "ok outcome label is connected":
            val o = make_connect_ok()
            expect(outcome_label(o)).to_equal("connected")

# ===========================================================================
# Tests — Group 4: HTTP capability router and packet ring (5 tests)
# ===========================================================================

describe "HTTP Capability Router and Packet Ring":
    """
    Tests for static-file routing through capability gates, worker startup tier
    recording, and packet ring RX/TX ownership transitions.
    """

    context "static file routing":
        it "portable backend routes to portable-read":
            val caps = make_caps_portable("portable-socket")
            val action = route_static_file(caps, true)
            expect(action.use_portable_read).to_equal(true)

        it "sendfile backend routes via sendfile":
            val caps = make_caps_sendfile("linux-io-uring")
            val action = route_static_file(caps, true)
            expect(action.use_sendfile).to_equal(true)

        it "zero-copy backend reports sendfile tier":
            val caps = make_caps_zero_copy("dma-engine")
            expect(http_tier(caps)).to_equal("zero-copy")

    context "packet ring ownership":
        it "rx descriptor ready transfers ownership to app":
            val desc = rx_ready(0, 64)
            expect(desc.owner.owner_name).to_equal("app")

        it "af-xdp ring config enables packet io":
            val cfg = ring_cfg_afxdp(1024)
            expect(cfg.supports_packet_io).to_equal(true)
