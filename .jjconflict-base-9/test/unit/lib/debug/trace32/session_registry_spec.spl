# Session Registry spec — tests session management logic

describe "T32 Session Registry":
    it "registers a session":
        var sessions: [text] = []
        sessions.push("session_1")
        expect(sessions.len()).to_equal(1)
        expect(sessions[0]).to_equal("session_1")

    it "finds session by id":
        var sessions: [text] = ["s1", "s2", "s3"]
        var found = ""
        for s in sessions:
            if s == "s2":
                found = s
        expect(found).to_equal("s2")

    it "removes session":
        var sessions: [text] = ["s1", "s2", "s3"]
        var filtered: [text] = []
        for s in sessions:
            if s != "s2":
                filtered.push(s)
        expect(filtered.len()).to_equal(2)
        expect(filtered[0]).to_equal("s1")
        expect(filtered[1]).to_equal("s3")

    it "tracks current session":
        var current = ""
        current = "session_amp0"
        expect(current).to_equal("session_amp0")

    it "manages multiple cores":
        var cores: [text] = []
        cores.push("a53_0")
        cores.push("a53_1")
        cores.push("m4_0")
        expect(cores.len()).to_equal(3)
        expect(cores[0]).to_equal("a53_0")

    it "selects core":
        var cores: [text] = ["a53_0", "a53_1", "m4_0"]
        var selected = ""
        val target = "a53_1"
        for c in cores:
            if c == target:
                selected = c
        expect(selected).to_equal("a53_1")

    it "handles empty session list":
        var sessions: [text] = []
        expect(sessions.len()).to_equal(0)

    it "prevents duplicate session ids":
        var sessions: [text] = ["s1"]
        var exists = false
        val new_id = "s1"
        for s in sessions:
            if s == new_id:
                exists = true
        expect(exists).to_equal(true)
