# Async Command Execution
#
# Runs commands asynchronously using the OS executor.
# Supports both sync built-in commands and async external commands.
# CommandFuture wraps a spawned process PID and polls for completion
# via non-blocking waitpid.
#
# MDSOC: feature dimension, shell layer

use os.async.os_executor.{OsExecutor}
use os.async.os_future.{OsFuture}
use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}
use os.posix.process_compat.{posix_waitpid, WNOHANG}
use os.services.launcher.launcher.{launcher_launch_path_with_args, launcher_resolve_command_path}

# ============================================================================
# Async Command Result
# ============================================================================

struct AsyncCommandResult:
    """Result of an async command execution."""
    exit_code: i32
    output: text

# ============================================================================
# Command Future
# ============================================================================

struct CommandFuture:
    """Future for an external command execution.

    Wraps a spawned child PID and polls for completion using
    non-blocking waitpid (WNOHANG). When the child exits, the
    future resolves with the exit status.
    """
    pid: u64
    completed: bool
    exit_code: i32

impl CommandFuture:
    static fn new(pid: u64) -> CommandFuture:
        """Create a future tracking the given child PID."""
        CommandFuture(pid: pid, completed: false, exit_code: 0)

    fn poll(waker: OsWaker) -> OsPoll<i64>:
        """Poll for child process completion.

        Uses non-blocking waitpid (WNOHANG). If the child has exited,
        returns Ready with the exit status. Otherwise returns Pending.
        """
        if self.completed:
            return OsPoll.Ready(value: self.exit_code as i64)

        # Non-blocking waitpid check
        val status = posix_waitpid(self.pid as i64, WNOHANG)
        if status >= 0:
            # Child exited
            self.completed = true
            self.exit_code = status as i32
            return OsPoll.Ready(value: status)

        # Not yet complete — register waker for later notification.
        # In a real implementation, the kernel would signal the waker
        # when the child process exits. For now, the executor will
        # re-poll on its next round.
        OsPoll.Pending

    fn is_completed() -> bool:
        """Check if the command has completed."""
        self.completed

    fn get_exit_code() -> i32:
        """Get the exit code (only valid after completion)."""
        self.exit_code

# ============================================================================
# Spawn Helpers
# ============================================================================

fn spawn_command_async(path: text, args: [text], cwd: text, path_env: text) -> Result<CommandFuture, text>:
    """Spawn an external command and return a future for its completion.

    Resolves the command using the shared launcher path so shell
    execution uses the same binary lookup rules as desktop launch.
    """
    val resolved = launcher_resolve_command_path(path, cwd, path_env)
    if resolved == "":
        return Err("Failed to resolve: {path}")
    val pid = launcher_launch_path_with_args(resolved, args)
    if pid < 0:
        return Err("Failed to spawn: {resolved}")
    Ok(CommandFuture.new(pid as u64))

fn spawn_command_bg(path: text, args: [text], cwd: text, path_env: text) -> Result<u64, text>:
    """Spawn an external command in the background. Returns PID.

    The caller is responsible for tracking the PID (e.g., in a JobTable)
    and eventually calling waitpid to reap the child.
    """
    val resolved = launcher_resolve_command_path(path, cwd, path_env)
    if resolved == "":
        return Err("Failed to resolve: {path}")
    val pid = launcher_launch_path_with_args(resolved, args)
    if pid < 0:
        return Err("Failed to spawn: {resolved}")
    Ok(pid as u64)
