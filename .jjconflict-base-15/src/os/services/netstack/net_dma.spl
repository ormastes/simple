use std.io_runtime

class NetDmaBuffer:
    buffer_id: i32
    byte_length: i32
    direction: text
    owner_device: text
    is_mapped: bool

    static fn rx_buffer(bid: i32, length: i32, device: text) -> NetDmaBuffer:
        return NetDmaBuffer(buffer_id: bid, byte_length: length, direction: "rx", owner_device: device, is_mapped: false)

    static fn tx_buffer(bid: i32, length: i32, device: text) -> NetDmaBuffer:
        return NetDmaBuffer(buffer_id: bid, byte_length: length, direction: "tx", owner_device: device, is_mapped: false)

    me map_dma() -> NetDmaBuffer:
        return NetDmaBuffer(buffer_id: self.buffer_id, byte_length: self.byte_length, direction: self.direction, owner_device: self.owner_device, is_mapped: true)

    me unmap_dma() -> NetDmaBuffer:
        return NetDmaBuffer(buffer_id: self.buffer_id, byte_length: self.byte_length, direction: self.direction, owner_device: self.owner_device, is_mapped: false)

    me is_ready() -> bool:
        return self.is_mapped


class NetDmaPool:
    b0_id: i32
    b0_dir: text
    b0_mapped: bool
    b1_id: i32
    b1_dir: text
    b1_mapped: bool
    b2_id: i32
    b2_dir: text
    b2_mapped: bool
    b3_id: i32
    b3_dir: text
    b3_mapped: bool
    total: i32

    static fn empty() -> NetDmaPool:
        return NetDmaPool(b0_id: -1, b0_dir: "", b0_mapped: false, b1_id: -1, b1_dir: "", b1_mapped: false, b2_id: -1, b2_dir: "", b2_mapped: false, b3_id: -1, b3_dir: "", b3_mapped: false, total: 0)

    me mapped_count() -> i32:
        var count = 0
        if self.b0_mapped:
            count = count + 1
        if self.b1_mapped:
            count = count + 1
        if self.b2_mapped:
            count = count + 1
        if self.b3_mapped:
            count = count + 1
        return count

    me rx_count() -> i32:
        var count = 0
        if self.b0_dir == "rx":
            count = count + 1
        if self.b1_dir == "rx":
            count = count + 1
        if self.b2_dir == "rx":
            count = count + 1
        if self.b3_dir == "rx":
            count = count + 1
        return count

    me tx_count() -> i32:
        var count = 0
        if self.b0_dir == "tx":
            count = count + 1
        if self.b1_dir == "tx":
            count = count + 1
        if self.b2_dir == "tx":
            count = count + 1
        if self.b3_dir == "tx":
            count = count + 1
        return count


class SriovCapability:
    has_iommu: bool
    vf_count: i32
    isolation_mode: text

    static fn isolated(vf_count: i32) -> SriovCapability:
        return SriovCapability(has_iommu: true, vf_count: vf_count, isolation_mode: "isolated")

    static fn trusted(vf_count: i32) -> SriovCapability:
        return SriovCapability(has_iommu: false, vf_count: vf_count, isolation_mode: "trusted")

    static fn none() -> SriovCapability:
        return SriovCapability(has_iommu: false, vf_count: 0, isolation_mode: "none")

    me can_advertise_isolation() -> bool:
        return self.has_iommu and self.isolation_mode == "isolated"

    me is_trusted_only() -> bool:
        return self.isolation_mode == "trusted"

    me vf_available() -> bool:
        return self.vf_count > 0 and self.has_iommu


class NetAccelReport:
    dma_buffers: i32
    sriov_vfs: i32
    isolation_mode: text
    accel_tier: text

    static fn create(bufs: i32, vfs: i32, isol: text, tier: text) -> NetAccelReport:
        return NetAccelReport(dma_buffers: bufs, sriov_vfs: vfs, isolation_mode: isol, accel_tier: tier)

    me is_accelerated() -> bool:
        return self.accel_tier != "basic"

    me summary() -> text:
        return "dma=" + self.dma_buffers.to_text() + " sriov_vfs=" + self.sriov_vfs.to_text() + " isolation=" + self.isolation_mode + " tier=" + self.accel_tier
