class H3FrameHeader:
    frame_type: i32
    payload_length: i32
    stream_id: i32

    me type_name() -> text:
        if frame_type == 0:
            return "DATA"
        if frame_type == 1:
            return "HEADERS"
        if frame_type == 3:
            return "CANCEL_PUSH"
        if frame_type == 4:
            return "SETTINGS"
        if frame_type == 5:
            return "PUSH_PROMISE"
        if frame_type == 7:
            return "GOAWAY"
        if frame_type == 13:
            return "MAX_PUSH_ID"
        return "UNKNOWN"

    me is_data() -> bool:
        return frame_type == 0

    me is_headers() -> bool:
        return frame_type == 1

    me is_settings() -> bool:
        return frame_type == 4

    me is_control() -> bool:
        return frame_type == 4 or frame_type == 7 or frame_type == 13

    static fn data(length: i32, stream: i32) -> H3FrameHeader:
        return H3FrameHeader(frame_type: 0, payload_length: length, stream_id: stream)

    static fn headers(length: i32, stream: i32) -> H3FrameHeader:
        return H3FrameHeader(frame_type: 1, payload_length: length, stream_id: stream)

    static fn settings(length: i32) -> H3FrameHeader:
        return H3FrameHeader(frame_type: 4, payload_length: length, stream_id: 0)

    static fn goaway(stream: i32) -> H3FrameHeader:
        return H3FrameHeader(frame_type: 7, payload_length: 8, stream_id: 0)


class H3Settings:
    max_field_section_size: i32
    qpack_max_table_capacity: i32
    qpack_blocked_streams: i32
    enable_connect_protocol: bool
    h3_datagram: bool

    me has_qpack() -> bool:
        return qpack_max_table_capacity > 0

    me is_default() -> bool:
        return max_field_section_size == 0 and qpack_max_table_capacity == 0

    static fn defaults() -> H3Settings:
        return H3Settings(
            max_field_section_size: 0,
            qpack_max_table_capacity: 0,
            qpack_blocked_streams: 0,
            enable_connect_protocol: false,
            h3_datagram: false)

    static fn with_qpack(table_cap: i32, blocked: i32) -> H3Settings:
        return H3Settings(
            max_field_section_size: 16384,
            qpack_max_table_capacity: table_cap,
            qpack_blocked_streams: blocked,
            enable_connect_protocol: false,
            h3_datagram: false)


class QpackStaticEntry:
    index: i32
    header_name: text
    header_value: text

    me is_pseudo() -> bool:
        return header_name.starts_with(":")

    me has_value() -> bool:
        return header_value != ""

    static fn pseudo(idx: i32, name: text, value: text) -> QpackStaticEntry:
        return QpackStaticEntry(index: idx, header_name: name, header_value: value)

    static fn authority() -> QpackStaticEntry:
        return QpackStaticEntry(index: 0, header_name: ":authority", header_value: "")

    static fn method_get() -> QpackStaticEntry:
        return QpackStaticEntry(index: 15, header_name: ":method", header_value: "GET")

    static fn status_200() -> QpackStaticEntry:
        return QpackStaticEntry(index: 25, header_name: ":status", header_value: "200")


class QpackDecoderState:
    required_insert_count: i32
    base_delta: i32
    max_table_capacity: i32
    current_entries: i32
    acknowledged_insert: i32

    me base() -> i32:
        return required_insert_count + base_delta

    me can_decode() -> bool:
        return acknowledged_insert >= required_insert_count

    me table_utilization() -> i32:
        if max_table_capacity > 0:
            return (current_entries * 100) / max_table_capacity
        return 0

    static fn initial(capacity: i32) -> QpackDecoderState:
        return QpackDecoderState(
            required_insert_count: 0,
            base_delta: 0,
            max_table_capacity: capacity,
            current_entries: 0,
            acknowledged_insert: 0)

    static fn with_inserts(ric: i32, delta: i32, cap: i32, entries: i32, acked: i32) -> QpackDecoderState:
        return QpackDecoderState(
            required_insert_count: ric,
            base_delta: delta,
            max_table_capacity: cap,
            current_entries: entries,
            acknowledged_insert: acked)


fn main():
    print("http3_frame loaded")
