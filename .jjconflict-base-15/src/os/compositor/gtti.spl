# Simple Gui Texture Tree Interface (SGTTI) — compositor adapter.
#
# Thin producer that bridges Compositor surfaces into WinTextSnapshot
# for the unified win_text_access query/action core.

use os.compositor.compositor.{Compositor, WindowSurface}
use os.compositor.wm_core.{WM_MODE_NORMAL, WM_MODE_HIDDEN, wm_mode_is_hidden}
use common.ui.win_text_access.{GttiSurface, WinTextSnapshot, win_text_compositor_snapshot}

pub fn gtti_snapshot_from_compositor(comp: Compositor, wm_mode: i32, captured_at_ms: i64, now_ms: i64) -> WinTextSnapshot:
    var gtti_surfaces: [GttiSurface] = []
    var i = 0
    while i < comp.surfaces.len():
        val s = comp.surfaces[i]
        val focused = comp.focused_idx >= 0 and comp.focused_idx < comp.surfaces.len() and comp.surfaces[comp.focused_idx].id == s.id
        gtti_surfaces = gtti_surfaces.push(GttiSurface(
            window_id: "{s.id}",
            title: s.title,
            x: s.x,
            y: s.y,
            width: s.width,
            height: s.height,
            visible: s.visible,
            focused: focused,
            app_id: s.app_id
        ))
        i = i + 1
    val mode_label = if wm_mode_is_hidden(wm_mode): "hidden" else: "normal"
    win_text_compositor_snapshot(gtti_surfaces: gtti_surfaces, wm_mode: mode_label, captured_at_ms: captured_at_ms, max_age_ms: 5000, now_ms: now_ms)
