"""
Zstd noalloc decompressor — API surface and structural constraints spec.

Verifies that zstd_noalloc.spl exposes the expected public API, declares the
correct RFC 8878 constants, and respects noalloc structural rules.  Tests use
source-grep via rt_process_run rather than calling the externs directly, since
rt_riscv_uart_put / rt_mem_read_u8 / rt_mem_write_u8 are RISC-V baremetal
externs unavailable in host interpreter.
"""

use std.spec.*

val SRC: text = "src/os/kernel/boot/zstd_noalloc.spl"

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _rg(pattern: text) -> bool:
    val (out, _err, code) = rt_process_run("rg", ["-qF", pattern, SRC])
    code == 0

fn _rg_re(pattern: text) -> bool:
    val (out, _err, code) = rt_process_run("rg", ["-q", pattern, SRC])
    code == 0

describe "zstd_noalloc — Zstd magic and constants":
    it "declares ZSTD_MAGIC = 0xFD2FB528":
        expect(_rg("ZSTD_MAGIC:       u64 = 0xFD2FB528")).to_equal(true)

    it "declares ZSTD_SKIPPABLE_MAGIC_BASE":
        expect(_rg("ZSTD_SKIPPABLE_MAGIC_BASE")).to_equal(true)

    it "declares block type constants Raw=0 RLE=1 Compressed=2 Reserved=3":
        expect(_rg("ZSTD_BLOCK_RAW:        u64 = 0")).to_equal(true)
        expect(_rg("ZSTD_BLOCK_RLE:        u64 = 1")).to_equal(true)
        expect(_rg("ZSTD_BLOCK_COMPRESSED: u64 = 2")).to_equal(true)
        expect(_rg("ZSTD_BLOCK_RESERVED:   u64 = 3")).to_equal(true)

    it "declares state codes Init=0 FrameHeader=1 Block=2 Done=3 Error=4":
        expect(_rg("ZSTD_S_INIT:            u64 = 0")).to_equal(true)
        expect(_rg("ZSTD_S_FRAME_HEADER:    u64 = 1")).to_equal(true)
        expect(_rg("ZSTD_S_BLOCK:           u64 = 2")).to_equal(true)
        expect(_rg("ZSTD_S_DONE:            u64 = 3")).to_equal(true)
        expect(_rg("ZSTD_S_ERROR:           u64 = 4")).to_equal(true)

    it "declares all error codes":
        expect(_rg("ZSTD_OK:                u64 = 0")).to_equal(true)
        expect(_rg("ZSTD_ERR_BAD_MAGIC:     u64 = 1")).to_equal(true)
        expect(_rg("ZSTD_ERR_TRUNCATED:     u64 = 2")).to_equal(true)
        expect(_rg("ZSTD_ERR_OUTPUT_FULL:   u64 = 3")).to_equal(true)
        expect(_rg("ZSTD_ERR_BLOCK_TYPE:    u64 = 4")).to_equal(true)
        expect(_rg("ZSTD_ERR_RESERVED:      u64 = 5")).to_equal(true)
        expect(_rg("ZSTD_ERR_NOT_READY:     u64 = 6")).to_equal(true)

describe "zstd_noalloc — public API surface":
    it "exposes zstd_noalloc_init":
        expect(_rg_re("^fn zstd_noalloc_init")).to_equal(true)

    it "exposes zstd_noalloc_decompress":
        expect(_rg_re("^fn zstd_noalloc_decompress")).to_equal(true)

    it "exposes zstd_noalloc_out_len":
        expect(_rg_re("^fn zstd_noalloc_out_len")).to_equal(true)

    it "exposes zstd_noalloc_error_code":
        expect(_rg_re("^fn zstd_noalloc_error_code")).to_equal(true)

    it "exposes zstd_noalloc_blocks_done":
        expect(_rg_re("^fn zstd_noalloc_blocks_done")).to_equal(true)

    it "exposes zstd_noalloc_is_done":
        expect(_rg_re("^fn zstd_noalloc_is_done")).to_equal(true)

    it "exposes zstd_noalloc_is_error":
        expect(_rg_re("^fn zstd_noalloc_is_error")).to_equal(true)

    it "exposes zstd_noalloc_expected_size":
        expect(_rg_re("^fn zstd_noalloc_expected_size")).to_equal(true)

describe "zstd_noalloc — noalloc structural constraints":
    it "declares no heap allocations — no rt_alloc":
        expect(_rg("rt_alloc")).to_equal(false)

    it "uses only u64 globals — no arrays or Option globals":
        expect(_rg("var g_zstd_ready:")).to_equal(true)
        expect(_rg("var g_zstd_state:")).to_equal(true)
        expect(_rg("var g_zstd_in_ptr:")).to_equal(true)
        expect(_rg("var g_zstd_out_ptr:")).to_equal(true)

    it "does not import std heap modules":
        expect(_rg("use std.nogc_async_mut")).to_equal(false)
        expect(_rg("use std.gc_async_mut")).to_equal(false)

    it "uses raw pointer externs for memory access":
        expect(_rg("extern fn rt_mem_read_u8")).to_equal(true)
        expect(_rg("extern fn rt_mem_write_u8")).to_equal(true)

    it "uses uart extern for diagnostics only":
        expect(_rg("extern fn rt_riscv_uart_put")).to_equal(true)

describe "zstd_noalloc — compressed block handling":
    it "rejects compressed blocks with ZSTD_ERR_BLOCK_TYPE":
        expect(_rg("ZSTD_ERR_BLOCK_TYPE")).to_equal(true)

    it "references unsupported block type path":
        expect(_rg("ZSTD_BLOCK_COMPRESSED")).to_equal(true)
        expect(_rg("_line_zstd_unsupported")).to_equal(true)

describe "zstd_noalloc — frame header parsing":
    it "validates Zstd magic number before processing":
        expect(_rg("ZSTD_ERR_BAD_MAGIC")).to_equal(true)
        expect(_rg("ZSTD_MAGIC")).to_equal(true)

    it "parses frame header descriptor fields":
        expect(_rg("fcs_flag")).to_equal(true)
        expect(_rg("single_segment")).to_equal(true)
        expect(_rg("checksum_flag")).to_equal(true)

    it "handles all Frame_Content_Size widths per RFC 8878":
        expect(_rg("fcs_flag == 1")).to_equal(true)
        expect(_rg("fcs_flag == 2")).to_equal(true)
        expect(_rg("fcs_flag == 3")).to_equal(true)
