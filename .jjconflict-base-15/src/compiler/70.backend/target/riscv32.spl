# RISC-V 32-bit Target Configuration
#
# Defines the RV32 target triple, register info, calling convention,
# and data layout for ILP32 (32-bit pointers, 32-bit long).
#
# Target triple: riscv32-unknown-none (bare-metal)
#                riscv32-unknown-linux-gnu (Linux)
#
# ISA: RV32IM (base integer + multiply/divide)
# ABI: ILP32 (int=32, long=32, pointer=32)
#
# Register set:
#   x0-x31 (32-bit integer registers)
#   f0-f31 (32-bit float registers, optional F extension)


# ============================================================================
# Target Triples
# ============================================================================

val RV32_TARGET_TRIPLE: text = "riscv32-unknown-none"
val RV32_TARGET_TRIPLE_LINUX: text = "riscv32-unknown-linux-gnu"
val RV32_TARGET_TRIPLE_BAREMETAL: text = "riscv32-unknown-none-elf"

# ============================================================================
# CPU and Features
# ============================================================================

val RV32_CPU_DEFAULT: text = "generic-rv32"
val RV32_FEATURES_DEFAULT: [text] = ["+m", "+a", "+f", "+d", "+c"]

# LLVM data layout for RV32 ILP32:
#   e         - little-endian
#   m:e       - ELF name mangling
#   p:32:32   - 32-bit pointers, 32-bit aligned
#   i64:64    - 64-bit integers, 64-bit aligned
#   n32       - native 32-bit integer
#   S128      - 128-bit stack alignment
val RV32_DATA_LAYOUT: text = "e-m:e-p:32:32-i64:64-n32-S128"

# ============================================================================
# Target Info
# ============================================================================

class Rv32TargetInfo:
    """Complete RV32 target description for the compiler."""
    triple: text
    cpu: text
    features: [text]
    data_layout: text
    pointer_size: i64       # 4 bytes
    pointer_align: i64      # 4 bytes
    max_atomic_width: i64   # 32 bits
    stack_align: i64         # 16 bytes (ABI requirement)
    has_fpu: bool
    endianness: text        # "little"

impl Rv32TargetInfo:
    static fn create() -> Rv32TargetInfo:
        """Create default RV32IM target info."""
        Rv32TargetInfo(
            triple: RV32_TARGET_TRIPLE,
            cpu: RV32_CPU_DEFAULT,
            features: RV32_FEATURES_DEFAULT,
            data_layout: RV32_DATA_LAYOUT,
            pointer_size: 4,
            pointer_align: 4,
            max_atomic_width: 32,
            stack_align: 16,
            has_fpu: false,  # RV32IM has no FPU; RV32IMFD does
            endianness: "little"
        )

    static fn create_with_fpu() -> Rv32TargetInfo:
        """Create RV32IMFD target info (with F and D extensions)."""
        Rv32TargetInfo(
            triple: RV32_TARGET_TRIPLE,
            cpu: RV32_CPU_DEFAULT,
            features: ["+m", "+a", "+f", "+d", "+c"],
            data_layout: RV32_DATA_LAYOUT,
            pointer_size: 4,
            pointer_align: 4,
            max_atomic_width: 32,
            stack_align: 16,
            has_fpu: true,
            endianness: "little"
        )

    static fn create_linux() -> Rv32TargetInfo:
        """Create RV32 Linux target info."""
        Rv32TargetInfo(
            triple: RV32_TARGET_TRIPLE_LINUX,
            cpu: RV32_CPU_DEFAULT,
            features: ["+m", "+a", "+f", "+d", "+c"],
            data_layout: RV32_DATA_LAYOUT,
            pointer_size: 4,
            pointer_align: 4,
            max_atomic_width: 32,
            stack_align: 16,
            has_fpu: true,
            endianness: "little"
        )

    static fn create_baremetal() -> Rv32TargetInfo:
        """Create RV32 bare-metal target info (no OS, minimal extensions)."""
        Rv32TargetInfo(
            triple: RV32_TARGET_TRIPLE_BAREMETAL,
            cpu: RV32_CPU_DEFAULT,
            features: ["+m"],
            data_layout: RV32_DATA_LAYOUT,
            pointer_size: 4,
            pointer_align: 4,
            max_atomic_width: 32,
            stack_align: 16,
            has_fpu: false,
            endianness: "little"
        )

    fn is_baremetal() -> bool:
        """Check if this is a bare-metal target (no OS)."""
        self.triple.contains("none")

    fn native_int_type() -> text:
        """LLVM native integer type for RV32."""
        "i32"

    fn pointer_type() -> text:
        """LLVM pointer type."""
        "ptr"

    fn size_type() -> text:
        """LLVM type for size_t on RV32 (i32)."""
        "i32"

# ============================================================================
# Register Info
# ============================================================================

enum Rv32RegisterClass:
    """RISC-V 32-bit register classes."""
    GPR        # General-purpose registers (x0-x31, 32-bit)
    FPR_S      # Single-precision float registers (f0-f31, 32-bit, F extension)
    FPR_D      # Double-precision float registers (f0-f31, 64-bit, D extension)

class Rv32RegisterInfo:
    """RV32 register file description."""
    gpr_count: i64       # 32 integer registers
    fpr_count: i64       # 32 float registers (if F/D extension)
    has_float: bool      # F extension present
    has_double: bool     # D extension present

impl Rv32RegisterInfo:
    static fn create() -> Rv32RegisterInfo:
        """Create register info for base RV32IM (no float)."""
        Rv32RegisterInfo(
            gpr_count: 32,
            fpr_count: 0,
            has_float: false,
            has_double: false
        )

    static fn create_with_fd() -> Rv32RegisterInfo:
        """Create register info for RV32IMFD (with float + double)."""
        Rv32RegisterInfo(
            gpr_count: 32,
            fpr_count: 32,
            has_float: true,
            has_double: true
        )

    fn gpr_name(index: i64) -> text:
        """Get GPR name by index (0-31)."""
        match index:
            case 0: "zero"
            case 1: "ra"
            case 2: "sp"
            case 3: "gp"
            case 4: "tp"
            case 5: "t0"
            case 6: "t1"
            case 7: "t2"
            case 8: "s0"
            case 9: "s1"
            case 10: "a0"
            case 11: "a1"
            case 12: "a2"
            case 13: "a3"
            case 14: "a4"
            case 15: "a5"
            case 16: "a6"
            case 17: "a7"
            case 18: "s2"
            case 19: "s3"
            case 20: "s4"
            case 21: "s5"
            case 22: "s6"
            case 23: "s7"
            case 24: "s8"
            case 25: "s9"
            case 26: "s10"
            case 27: "s11"
            case 28: "t3"
            case 29: "t4"
            case 30: "t5"
            case 31: "t6"
            case _: "x{index}"

    fn fpr_name(index: i64) -> text:
        """Get FPR name by index (0-31)."""
        match index:
            case 0: "ft0"
            case 1: "ft1"
            case 2: "ft2"
            case 3: "ft3"
            case 4: "ft4"
            case 5: "ft5"
            case 6: "ft6"
            case 7: "ft7"
            case 8: "fs0"
            case 9: "fs1"
            case 10: "fa0"
            case 11: "fa1"
            case 12: "fa2"
            case 13: "fa3"
            case 14: "fa4"
            case 15: "fa5"
            case 16: "fa6"
            case 17: "fa7"
            case 18: "fs2"
            case 19: "fs3"
            case 20: "fs4"
            case 21: "fs5"
            case 22: "fs6"
            case 23: "fs7"
            case 24: "fs8"
            case 25: "fs9"
            case 26: "fs10"
            case 27: "fs11"
            case 28: "ft8"
            case 29: "ft9"
            case 30: "ft10"
            case 31: "ft11"
            case _: "f{index}"

    fn is_callee_saved_gpr(index: i64) -> bool:
        """Check if GPR is callee-saved (s0-s11, x8-x9, x18-x27)."""
        (index >= 8 and index <= 9) or (index >= 18 and index <= 27)

    fn is_caller_saved_gpr(index: i64) -> bool:
        """Check if GPR is caller-saved (t0-t6, a0-a7)."""
        (index >= 5 and index <= 7) or (index >= 10 and index <= 17) or (index >= 28 and index <= 31)

    fn is_callee_saved_fpr(index: i64) -> bool:
        """Check if FPR is callee-saved (fs0-fs11)."""
        (index >= 8 and index <= 9) or (index >= 18 and index <= 27)

# ============================================================================
# Calling Convention (ILP32)
# ============================================================================

class Rv32CallingConvention:
    """RV32 ILP32 calling convention details."""
    name: text

impl Rv32CallingConvention:
    static fn ilp32() -> Rv32CallingConvention:
        """Standard ILP32 calling convention (soft-float)."""
        Rv32CallingConvention(name: "ilp32")

    static fn ilp32f() -> Rv32CallingConvention:
        """ILP32F calling convention (single-float in registers)."""
        Rv32CallingConvention(name: "ilp32f")

    static fn ilp32d() -> Rv32CallingConvention:
        """ILP32D calling convention (double-float in registers)."""
        Rv32CallingConvention(name: "ilp32d")

    fn arg_gpr_count() -> i64:
        """Number of GPR registers available for arguments (a0-a7)."""
        8

    fn arg_fpr_count() -> i64:
        """Number of FPR registers available for float arguments."""
        match self.name:
            case "ilp32": 0    # No float args in registers
            case "ilp32f": 8   # fa0-fa7 for float args
            case "ilp32d": 8   # fa0-fa7 for float/double args
            case _: 0

    fn ret_gpr_count() -> i64:
        """Number of GPR registers for return value (a0, a1)."""
        2

    fn stack_alignment() -> i64:
        """Required stack alignment in bytes."""
        16

    fn arg_gprs() -> [text]:
        """Argument GPR names."""
        ["a0", "a1", "a2", "a3", "a4", "a5", "a6", "a7"]

    fn ret_gprs() -> [text]:
        """Return value GPR names."""
        ["a0", "a1"]

    fn callee_saved_gprs() -> [text]:
        """Callee-saved GPR names."""
        ["s0", "s1", "s2", "s3", "s4", "s5", "s6", "s7", "s8", "s9", "s10", "s11"]

    fn caller_saved_gprs() -> [text]:
        """Caller-saved GPR names."""
        ["t0", "t1", "t2", "t3", "t4", "t5", "t6",
         "a0", "a1", "a2", "a3", "a4", "a5", "a6", "a7"]

# ============================================================================
# Helper Functions
# ============================================================================

fn rv32_abi_info() -> Rv32CallingConvention:
    """Get the default ILP32 ABI info."""
    Rv32CallingConvention.ilp32()

fn rv32_register_class(has_fpu: bool) -> Rv32RegisterInfo:
    """Get register info based on FPU availability."""
    if has_fpu:
        Rv32RegisterInfo.create_with_fd()
    else:
        Rv32RegisterInfo.create()

fn rv32_data_layout_string() -> text:
    """Get the LLVM data layout string for RV32."""
    RV32_DATA_LAYOUT

fn rv32_supported_extensions() -> [text]:
    """List of supported RISC-V extensions for RV32 targets.
    Each is an LLVM feature flag."""
    [
        "+m",      # Integer multiply/divide (RV32M)
        "+a",      # Atomics (RV32A)
        "+f",      # Single-precision float (RV32F)
        "+d",      # Double-precision float (RV32D)
        "+c",      # Compressed instructions (RV32C)
        "+zicsr",  # CSR instructions
        "+zifencei"  # Fence.I instruction
    ]

# ============================================================================
# Type Sizes for ILP32
# ============================================================================

# ILP32 type sizes (in bytes):
#   bool:    1
#   i8/u8:   1
#   i16/u16: 2
#   i32/u32: 4
#   i64/u64: 8
#   f32:     4
#   f64:     8
#   pointer: 4  (32-bit!)
#   size_t:  4  (32-bit!)
#   long:    4  (32-bit, unlike LP64 where long is 8)

fn rv32_type_size(type_name: text) -> i64:
    """Get size in bytes of a type on RV32 ILP32."""
    match type_name:
        case "bool" | "i8" | "u8": 1
        case "i16" | "u16": 2
        case "i32" | "u32" | "f32" | "ptr" | "usize" | "isize": 4
        case "i64" | "u64" | "f64": 8
        case _: 4  # Default to pointer size

fn rv32_type_align(type_name: text) -> i64:
    """Get alignment in bytes of a type on RV32 ILP32."""
    match type_name:
        case "bool" | "i8" | "u8": 1
        case "i16" | "u16": 2
        case "i32" | "u32" | "f32" | "ptr": 4
        case "i64" | "u64" | "f64": 4  # 4-byte aligned on RV32 (not 8)
        case _: 4
