# Shared image GPU mailbox metadata and usage flags

use std.skia.entity.geometry.{SkISize}
use std.skia.entity.enums.{SkColorType, SkAlphaType}

class SharedImageUsage:
    display: bool
    raster: bool
    scanout: bool
    oop_raster: bool

class SharedImageMailbox:
    bytes: [u8]

class SharedImageMetadata:
    mailbox: SharedImageMailbox
    size: SkISize
    color_type: SkColorType
    alpha_type: SkAlphaType
    usage: SharedImageUsage
