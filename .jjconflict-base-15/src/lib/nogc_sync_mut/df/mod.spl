use std.ndarray.*

extern fn rt_intern_symbol(value: text) -> i64

struct Symbol:
    text: text
    id: i64

    static fn from(value: text) -> Symbol:
        Symbol(text: value, id: rt_intern_symbol(value))

    fn intern_id(self) -> i64:
        self.id

    fn label(self) -> text:
        self.text

fn symbol_eq(left: Symbol, right: Symbol) -> bool:
    left.id == right.id

fn symbol_ne(left: Symbol, right: Symbol) -> bool:
    left.id != right.id

enum DfError:
    ShapeMismatch
    ColumnNotFound
    DuplicateColumn
    ParseError

enum NaHow:
    Any
    All

enum ConcatAxis:
    Rows
    Cols

enum JoinHow:
    Inner
    Left
    Right
    Outer

enum DfValue:
    F64(Float64)
    I64(Int64)
    B(Bool)
    Txt(text)
    Na

struct RowEntry:
    key: Symbol
    value: DfValue

    static fn new(key: Symbol, value: DfValue) -> RowEntry:
        RowEntry(key: key, value: value)

struct Series:
    name: Symbol
    values: NDArray
    dtype: DType
    missing: [Bool]

    static fn from_values(name: Symbol, values: [Float64]) -> Series:
        match infer_series_dtype(values):
            case DType.I64:
                val coerced = coerce_i64_values(values)
                Series(name: name, values: array_i64(coerced), dtype: DType.I64, missing: no_missing_values(coerced.len()))
            case _:
                Series(name: name, values: array(values), dtype: DType.F64, missing: no_missing_values(values.len()))

    static fn from_f64_masked(name: Symbol, values: [Float64], missing: [Bool]) -> Result<Series, DfError>:
        if values.len() != missing.len():
            return Err(DfError.ShapeMismatch)
        Ok(Series(name: name, values: array(values), dtype: DType.F64, missing: missing))

    static fn from_i64_masked(name: Symbol, values: [Int64], missing: [Bool]) -> Result<Series, DfError>:
        if values.len() != missing.len():
            return Err(DfError.ShapeMismatch)
        Ok(Series(name: name, values: array_i64(values), dtype: DType.I64, missing: missing))

    fn len(self) -> Index:
        self.values.len()

    fn name(self) -> Symbol:
        self.name

    fn dtype(self) -> DType:
        self.dtype

    fn is_missing(self, index: Index) -> Result<bool, DfError>:
        if index.value < 0 or index.value >= self.len().value:
            return Err(DfError.ShapeMismatch)
        Ok(self.missing[index.value].value)

    fn get(self, index: Index) -> Any:
        self.values.get(index)

    fn add(self, other: Series) -> Series:
        var out: [Float64] = []
        var i = 0
        while i < self.values.data_f64.len():
            out.push(Float64.new(self.values.data_f64[i].value + other.values.data_f64[i].value))
            i = i + 1
        Series(name: self.name, values: array(out), dtype: DType.F64, missing: combine_missing(self.missing, other.missing))

    fn filter(self, mask: NDArray) -> Result<Series, DfError>:
        match self.values.try_mask(mask):
            case Ok(values):
                Ok(Series(name: self.name, values: values, dtype: self.dtype, missing: filter_missing(self.missing, mask)?))
            case Err(_):
                Err(DfError.ShapeMismatch)

    fn add_scalar(self, rhs: Float64) -> Series:
        var out: [Float64] = []
        var i = 0
        while i < self.values.len().value:
            if self.missing[i].value:
                out.push(Float64.new(0.0))
            else:
                out.push(Float64.new(self.values.flat_f64(i).value + rhs.value))
            i = i + 1
        Series(name: self.name, values: array(out), dtype: DType.F64, missing: self.missing)

    fn sub_scalar(self, rhs: Float64) -> Series:
        var out: [Float64] = []
        var i = 0
        while i < self.values.len().value:
            if self.missing[i].value:
                out.push(Float64.new(0.0))
            else:
                out.push(Float64.new(self.values.flat_f64(i).value - rhs.value))
            i = i + 1
        Series(name: self.name, values: array(out), dtype: DType.F64, missing: self.missing)

    fn mul_scalar(self, rhs: Float64) -> Series:
        var out: [Float64] = []
        var i = 0
        while i < self.values.len().value:
            if self.missing[i].value:
                out.push(Float64.new(0.0))
            else:
                out.push(Float64.new(self.values.flat_f64(i).value * rhs.value))
            i = i + 1
        Series(name: self.name, values: array(out), dtype: DType.F64, missing: self.missing)

    fn div_scalar(self, rhs: Float64) -> Result<Series, DfError>:
        if rhs.value == 0.0:
            return Err(DfError.ShapeMismatch)
        var out: [Float64] = []
        var i = 0
        while i < self.values.len().value:
            if self.missing[i].value:
                out.push(Float64.new(0.0))
            else:
                out.push(Float64.new(self.values.flat_f64(i).value / rhs.value))
            i = i + 1
        Ok(Series(name: self.name, values: array(out), dtype: DType.F64, missing: self.missing))

    fn is_na(self) -> Series:
        var out: [Bool] = []
        var i = 0
        while i < self.missing.len():
            out.push(self.missing[i])
            i = i + 1
        Series(name: self.name, values: array_bool(out), dtype: DType.Bool, missing: no_missing_values(out.len()))

    fn fill_na(self, value: Float64) -> Series:
        var new_missing: [Bool] = []
        var i = 0
        while i < self.missing.len():
            new_missing.push(Bool.new(false))
            i = i + 1
        if self.dtype == DType.I64:
            var out: [Int64] = []
            var j = 0
            while j < self.values.len().value:
                if self.missing[j].value:
                    out.push(Int64.new(value.value as i64))
                else:
                    out.push(self.values.flat_i64(j))
                j = j + 1
            return Series(name: self.name, values: array_i64(out), dtype: DType.I64, missing: new_missing)
        var out: [Float64] = []
        var j = 0
        while j < self.values.len().value:
            if self.missing[j].value:
                out.push(value)
            else:
                out.push(self.values.flat_f64(j))
            j = j + 1
        Series(name: self.name, values: array(out), dtype: DType.F64, missing: new_missing)

    fn unique_f64(self) -> Series:
        var seen: [Float64] = []
        var seen_missing = false
        var out_missing: [Bool] = []
        var i = 0
        while i < self.values.len().value:
            if self.missing[i].value:
                if not seen_missing:
                    seen_missing = true
                    seen.push(Float64.new(0.0))
                    out_missing.push(Bool.new(true))
            else:
                val v = self.values.flat_f64(i)
                val found = f64_group_index(seen, v) >= 0
                if not found:
                    seen.push(v)
                    out_missing.push(Bool.new(false))
            i = i + 1
        Series(name: self.name, values: array(seen), dtype: DType.F64, missing: out_missing)

    fn unique_i64(self) -> Series:
        var seen: [Int64] = []
        var seen_missing = false
        var out_missing: [Bool] = []
        var i = 0
        while i < self.values.len().value:
            if self.missing[i].value:
                if not seen_missing:
                    seen_missing = true
                    seen.push(Int64.new(0))
                    out_missing.push(Bool.new(true))
            else:
                val v = self.values.flat_i64(i)
                val found = i64_group_index(seen, v) >= 0
                if not found:
                    seen.push(v)
                    out_missing.push(Bool.new(false))
            i = i + 1
        Series(name: self.name, values: array_i64(seen), dtype: DType.I64, missing: out_missing)

    fn nunique(self) -> Index:
        if self.dtype == DType.I64:
            val u = self.unique_i64()
            return u.len()
        val u = self.unique_f64()
        u.len()

struct CategoricalEncoding:
    series: Series
    labels: [Symbol]

struct SeriesDType:
    values: [DType]

    fn len(self) -> Index:
        Index.new(self.values.len())

    fn dtype_at(self, index: Index) -> DType:
        self.values[index.value]

enum SeriesErased:
    F64Series(Series)
    I64Series(Series)

struct DataFrameShape:
    rows: Index
    cols: Index

struct JoinPairs:
    left: [Int64]
    right: [Int64]

struct DataFrame:
    columns_internal: [Series]

    static fn from_columns(columns_internal: [SeriesErased]) -> Result<DataFrame, DfError>:
        var cols: [Series] = []
        var i = 0
        while i < columns_internal.len():
            match columns_internal[i]:
                case SeriesErased.F64Series(s):
                    cols.push(s)
                case SeriesErased.I64Series(s):
                    cols.push(s)
            i = i + 1
        if cols.len() > 0:
            val expected = cols[0].len().value
            i = 1
            while i < cols.len():
                if cols[i].len().value != expected:
                    return Err(DfError.ShapeMismatch)
                i = i + 1
        Ok(DataFrame(columns_internal: cols))

    static fn from_rows(rows: [[RowEntry]]) -> Result<DataFrame, DfError>:
        if rows.len() == 0:
            return Ok(DataFrame(columns_internal: []))
        var cols_f64: {text: [Float64]} = {}
        var cols_i64: {text: [Int64]} = {}
        var order: [Symbol] = []
        var kinds: {text: DType} = {}
        var row = 0
        for current_row in rows:
            for entry in current_row:
                val key = entry.key
                val value = entry.value
                if row == 0:
                    order.push(key)
                    kinds[key.text] = dtype_of(value)
                    if dtype_of(value) == DType.F64:
                        cols_f64[key.text] = []
                    else:
                        cols_i64[key.text] = []
                match value:
                    case DfValue.F64(v):
                        var column = cols_f64[key.text]
                        column.push(v)
                        cols_f64[key.text] = column
                    case DfValue.I64(v):
                        var column = cols_i64[key.text]
                        column.push(v)
                        cols_i64[key.text] = column
                    case _:
                        return Err(DfError.ShapeMismatch)
            row = row + 1
        var built: [SeriesErased] = []
        var i = 0
        while i < order.len():
            val key = order[i]
            if kinds[key.text] == DType.F64:
                built.push(SeriesErased.F64Series(Series.from_values(key, cols_f64[key.text])))
            else:
                built.push(SeriesErased.I64Series(Series.from_values(key, cols_i64[key.text])))
            i = i + 1
        DataFrame.from_columns(built)

    fn columns(self) -> [Symbol]:
        var out: [Symbol] = []
        var i = 0
        while i < self.columns_internal.len():
            out.push(self.columns_internal[i].name)
            i = i + 1
        out

    fn num_rows(self) -> Index:
        if self.columns_internal.len() == 0:
            return Index.new(0)
        self.columns_internal[0].len()

    fn num_cols(self) -> Index:
        Index.new(self.columns_internal.len())

    fn column_count(self) -> Index:
        self.num_cols()

    fn shape(self) -> DataFrameShape:
        DataFrameShape(rows: self.num_rows(), cols: self.num_cols())

    fn dtypes(self) -> SeriesDType:
        var out: [DType] = []
        var i = 0
        while i < self.columns_internal.len():
            out.push(self.columns_internal[i].dtype)
            i = i + 1
        SeriesDType(values: out)

    fn col(self, name: Symbol) -> Result<Series, DfError>:
        val index = column_index(self.columns_internal, name)
        if index < 0:
            return Err(DfError.ColumnNotFound)
        Ok(self.columns_internal[index])

    fn row(self, index: Index) -> Result<[RowEntry], DfError>:
        if index.value < 0 or index.value >= self.num_rows().value:
            return Err(DfError.ShapeMismatch)
        var out: [RowEntry] = []
        var col = 0
        while col < self.columns_internal.len():
            val series = self.columns_internal[col]
            out.push(RowEntry.new(series.name, series_value_at(series, index.value)))
            col = col + 1
        Ok(out)

    fn select(self, names: [Symbol]) -> Result<DataFrame, DfError>:
        var out: [Series] = []
        var i = 0
        while i < names.len():
            out.push(self.col(names[i])?)
            i = i + 1
        Ok(DataFrame(columns_internal: out))

    fn assign(self, name: Symbol, series: SeriesErased) -> DataFrame:
        val new_series = unwrap_series(series, name)
        val index = column_index(self.columns_internal, name)
        if index < 0:
            var out = self.columns_internal
            out.push(new_series)
            return DataFrame(columns_internal: out)
        DataFrame(columns_internal: replace_series_at(self.columns_internal, index, new_series))

    fn drop(self, name: Symbol) -> Result<DataFrame, DfError>:
        val index = column_index(self.columns_internal, name)
        if index < 0:
            return Err(DfError.ColumnNotFound)
        Ok(DataFrame(columns_internal: remove_series_at(self.columns_internal, index)))

    fn rename(self, old_name: Symbol, new_name: Symbol) -> Result<DataFrame, DfError>:
        if column_index(self.columns_internal, new_name) >= 0:
            return Err(DfError.DuplicateColumn)
        val old_index = column_index(self.columns_internal, old_name)
        if old_index < 0:
            return Err(DfError.ColumnNotFound)
        Ok(DataFrame(columns_internal: replace_series_at(self.columns_internal, old_index, rename_series(self.columns_internal[old_index], new_name))))

    fn astype(self, name: Symbol, dtype: DType) -> Result<DataFrame, DfError>:
        val index = column_index(self.columns_internal, name)
        if index < 0:
            return Err(DfError.ColumnNotFound)
        val current = self.columns_internal[index]
        var converted = current
        if dtype == DType.F64:
            converted = to_f64_series(current)
        else:
            converted = to_i64_series(current)
        Ok(DataFrame(columns_internal: replace_series_at(self.columns_internal, index, converted)))

    fn filter(self, mask: NDArray) -> Result<DataFrame, DfError>:
        if mask.dtype != DType.Bool or mask.len() != self.num_rows():
            return Err(DfError.ShapeMismatch)
        var out: [Series] = []
        var i = 0
        while i < self.columns_internal.len():
            out.push(self.columns_internal[i].filter(mask)?)
            i = i + 1
        Ok(DataFrame(columns_internal: out))

    fn sort_values(self, by: Symbol) -> Result<DataFrame, DfError>:
        val key = self.col(by)?
        val order = key.values.try_argsort()
        match order:
            case Ok(idx):
                self.gather_rows(idx)
            case Err(_):
                Err(DfError.ShapeMismatch)

    fn head(self, count: Index) -> Result<DataFrame, DfError>:
        if count.value < 0:
            return Err(DfError.ShapeMismatch)
        var limit = count.value
        if limit > self.num_rows().value:
            limit = self.num_rows().value
        self.gather_rows(row_range_indices(Index.new(0), Index.new(limit)))

    fn tail(self, count: Index) -> Result<DataFrame, DfError>:
        if count.value < 0:
            return Err(DfError.ShapeMismatch)
        var limit = count.value
        if limit > self.num_rows().value:
            limit = self.num_rows().value
        val start = self.num_rows().value - limit
        self.gather_rows(row_range_indices(Index.new(start), Index.new(self.num_rows().value)))

    fn gather_rows(self, idx: NDArray) -> Result<DataFrame, DfError>:
        var out: [Series] = []
        var i = 0
        while i < self.columns_internal.len():
            val current = self.columns_internal[i]
            match current.values.try_gather(idx):
                case Ok(values):
                    out.push(Series(name: current.name, values: values, dtype: current.dtype, missing: gather_missing(current.missing, idx)?))
                case Err(_):
                    return Err(DfError.ShapeMismatch)
            i = i + 1
        Ok(DataFrame(columns_internal: out))

    fn take_rows(self, idx: NDArray) -> Result<DataFrame, DfError>:
        self.gather_rows(idx)

    fn is_na(self) -> DataFrame:
        var out: [Series] = []
        var i = 0
        while i < self.columns_internal.len():
            out.push(self.columns_internal[i].is_na())
            i = i + 1
        DataFrame(columns_internal: out)

    fn fill_na(self, value: Float64) -> DataFrame:
        var out: [Series] = []
        var i = 0
        while i < self.columns_internal.len():
            out.push(self.columns_internal[i].fill_na(value))
            i = i + 1
        DataFrame(columns_internal: out)

    fn drop_na(self, how: NaHow) -> DataFrame:
        val rows = self.num_rows().value
        var keep: [Bool] = []
        var row = 0
        while row < rows:
            var any_na = false
            var all_na = true
            var col = 0
            while col < self.columns_internal.len():
                if self.columns_internal[col].missing[row].value:
                    any_na = true
                else:
                    all_na = false
                col = col + 1
            if self.columns_internal.len() == 0:
                all_na = false
            match how:
                case NaHow.Any:
                    keep.push(Bool.new(not any_na))
                case NaHow.All:
                    keep.push(Bool.new(not all_na))
            row = row + 1
        val mask = array_bool(keep)
        match self.filter(mask):
            case Ok(df): df
            case Err(_): DataFrame(columns_internal: self.columns_internal)

    fn join(self, other: DataFrame, on: Symbol, how: JoinHow) -> Result<DataFrame, DfError>:
        merge(self, other, on, how)

    fn groupby_sum(self, by: Symbol, value: Symbol) -> Result<DataFrame, DfError>:
        groupby_numeric(self, by, value, false)

    fn groupby_mean(self, by: Symbol, value: Symbol) -> Result<DataFrame, DfError>:
        groupby_numeric(self, by, value, true)

    fn melt_numeric(self, id: Symbol, value_vars: [Symbol], variable_name: Symbol, value_name: Symbol) -> Result<DataFrame, DfError>:
        melt_numeric(self, id, value_vars, variable_name, value_name)

    fn pivot_sum(self, index: Symbol, columns: Symbol, values: Symbol, value_prefix: Symbol) -> Result<DataFrame, DfError>:
        pivot_sum(self, index, columns, values, value_prefix)

    fn to_csv_text(self) -> Result<text, DfError>:
        dataframe_to_csv_text(self)

fn dtype_of(value: DfValue) -> DType:
    match value:
        case DfValue.F64(_): DType.F64
        case DfValue.I64(_): DType.I64
        case DfValue.B(_): DType.Bool
        case _:
            DType.Bool

fn infer_series_dtype(values: [Float64]) -> DType:
    if values.len() == 0:
        return DType.F64
    val raw = values[0].value
    if values[0] == Int64.new(raw as i64):
        return DType.I64
    DType.F64

fn coerce_i64_values(values: [Float64]) -> [Int64]:
    var out: [Int64] = []
    var i = 0
    while i < values.len():
        out.push(Int64.new(values[i].value as i64))
        i = i + 1
    out

fn no_missing_values(count: i64) -> [Bool]:
    var out: [Bool] = []
    var i = 0
    while i < count:
        out.push(Bool.new(false))
        i = i + 1
    out

fn combine_missing(left: [Bool], right: [Bool]) -> [Bool]:
    var out: [Bool] = []
    var i = 0
    while i < left.len():
        out.push(Bool.new(left[i].value or right[i].value))
        i = i + 1
    out

fn filter_missing(missing: [Bool], mask: NDArray) -> Result<[Bool], DfError>:
    if mask.dtype != DType.Bool or mask.len().value != missing.len():
        return Err(DfError.ShapeMismatch)
    var out: [Bool] = []
    var i = 0
    while i < missing.len():
        if mask.flat_bool(i).value:
            out.push(missing[i])
        i = i + 1
    Ok(out)

fn gather_missing(missing: [Bool], idx: NDArray) -> Result<[Bool], DfError>:
    if idx.dtype != DType.I64:
        return Err(DfError.ShapeMismatch)
    var out: [Bool] = []
    var i = 0
    while i < idx.len().value:
        val row = idx.flat_i64(i).value
        if row < 0 or row >= missing.len():
            return Err(DfError.ShapeMismatch)
        out.push(missing[row])
        i = i + 1
    Ok(out)

fn column_index(columns: [Series], name: Symbol) -> i64:
    var i = 0
    while i < columns.len():
        if symbol_eq(columns[i].name, name):
            return i
        i = i + 1
    -1

fn replace_series_at(columns: [Series], index: i64, replacement: Series) -> [Series]:
    var out: [Series] = []
    var i = 0
    while i < columns.len():
        if i == index:
            out.push(replacement)
        else:
            out.push(columns[i])
        i = i + 1
    out

fn remove_series_at(columns: [Series], index: i64) -> [Series]:
    var out: [Series] = []
    var i = 0
    while i < columns.len():
        if i != index:
            out.push(columns[i])
        i = i + 1
    out

fn rename_series(series: Series, new_name: Symbol) -> Series:
    Series(name: new_name, values: series.values, dtype: series.dtype, missing: series.missing)

fn unwrap_series(value: SeriesErased, name: Symbol) -> Series:
    match value:
        case SeriesErased.F64Series(s):
            Series(name: name, values: s.values, dtype: s.dtype, missing: s.missing)
        case SeriesErased.I64Series(s):
            Series(name: name, values: s.values, dtype: s.dtype, missing: s.missing)

fn to_f64_series(series: Series) -> Series:
    if series.dtype == DType.F64:
        return series
    var out: [Float64] = []
    var i = 0
    while i < series.values.data_i64.len():
        out.push(Float64.new(series.values.data_i64[i].value as f64))
        i = i + 1
    Series(name: series.name, values: array(out), dtype: DType.F64, missing: series.missing)

fn to_i64_series(series: Series) -> Series:
    if series.dtype == DType.I64:
        return series
    var out: [Int64] = []
    var i = 0
    while i < series.values.data_f64.len():
        out.push(Int64.new(series.values.data_f64[i].value as i64))
        i = i + 1
    Series(name: series.name, values: array_i64(out), dtype: DType.I64, missing: series.missing)

fn row_range_indices(start: Index, stop: Index) -> NDArray:
    var out: [Int64] = []
    var i = start.value
    while i < stop.value:
        out.push(Int64.new(i))
        i = i + 1
    array_i64(out)

fn series_value_at(series: Series, row: i64) -> DfValue:
    if series.missing[row].value:
        return DfValue.Na
    match series.dtype:
        case DType.F64:
            DfValue.F64(series.values.flat_f64(row))
        case DType.I64:
            DfValue.I64(series.values.flat_i64(row))
        case DType.Bool:
            DfValue.B(series.values.flat_bool(row))

fn f64_group_index(keys: [Float64], value: Float64) -> i64:
    var i = 0
    while i < keys.len():
        if keys[i] == value:
            return i
        i = i + 1
    -1

fn i64_group_index(keys: [Int64], value: Int64) -> i64:
    var i = 0
    while i < keys.len():
        if keys[i] == value:
            return i
        i = i + 1
    -1

fn value_counts(series: Series) -> DataFrame:
    if series.dtype == DType.I64:
        var keys: [Int64] = []
        var counts: [Int64] = []
        var i = 0
        while i < series.values.len().value:
            if not series.missing[i].value:
                val v = series.values.flat_i64(i)
                val idx = i64_group_index(keys, v)
                if idx < 0:
                    keys.push(v)
                    counts.push(Int64.new(1))
                else:
                    counts[idx] = Int64.new(counts[idx].value + 1)
            i = i + 1
        val key_col = Series(name: series.name, values: array_i64(keys), dtype: DType.I64, missing: no_missing_values(keys.len()))
        val cnt_col = Series(name: Symbol.from("count"), values: array_i64(counts), dtype: DType.I64, missing: no_missing_values(counts.len()))
        DataFrame(columns_internal: [key_col, cnt_col])
    else:
        var keys: [Float64] = []
        var counts: [Int64] = []
        var i = 0
        while i < series.values.len().value:
            if not series.missing[i].value:
                val v = series.values.flat_f64(i)
                val idx = f64_group_index(keys, v)
                if idx < 0:
                    keys.push(v)
                    counts.push(Int64.new(1))
                else:
                    counts[idx] = Int64.new(counts[idx].value + 1)
            i = i + 1
        val key_col = Series(name: series.name, values: array(keys), dtype: DType.F64, missing: no_missing_values(keys.len()))
        val cnt_col = Series(name: Symbol.from("count"), values: array_i64(counts), dtype: DType.I64, missing: no_missing_values(counts.len()))
        DataFrame(columns_internal: [key_col, cnt_col])
