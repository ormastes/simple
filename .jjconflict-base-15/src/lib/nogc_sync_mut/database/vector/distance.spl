use std.database.vector.types.{DistanceMetric}

extern fn rt_math_sqrt(x: f64) -> f64

fn l2_norm(v: [f64]) -> f64:
    var sum = 0.0
    var i = 0
    while i < v.len():
        sum = sum + v[i] * v[i]
        i = i + 1
    rt_math_sqrt(sum)

fn dot_product(a: [f64], b: [f64]) -> f64:
    var sum = 0.0
    var i = 0
    while i < a.len():
        sum = sum + a[i] * b[i]
        i = i + 1
    sum

fn cosine_similarity(a: [f64], b: [f64]) -> f64:
    val dot = dot_product(a, b)
    val na = l2_norm(a)
    val nb = l2_norm(b)
    if na == 0.0 or nb == 0.0:
        return 0.0
    dot / (na * nb)

fn cosine_distance(a: [f64], b: [f64]) -> f64:
    1.0 - cosine_similarity(a, b)

fn euclidean_distance(a: [f64], b: [f64]) -> f64:
    var sum = 0.0
    var i = 0
    while i < a.len():
        val diff = a[i] - b[i]
        sum = sum + diff * diff
        i = i + 1
    rt_math_sqrt(sum)

fn normalize_vector(v: [f64]) -> [f64]:
    val n = l2_norm(v)
    if n == 0.0:
        return v
    var out: [f64] = []
    var i = 0
    while i < v.len():
        out.push(v[i] / n)
        i = i + 1
    out

fn compute_distance(a: [f64], b: [f64], metric: DistanceMetric) -> f64:
    match metric:
        DistanceMetric.Cosine:
            cosine_distance(a, b)
        DistanceMetric.Euclidean:
            euclidean_distance(a, b)
        DistanceMetric.DotProduct:
            val dp = dot_product(a, b)
            0.0 - dp
