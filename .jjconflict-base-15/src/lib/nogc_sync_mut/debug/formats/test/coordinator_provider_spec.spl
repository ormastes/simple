    b = b.push(0x01)
    b

fn _make_parser() -> DwarfParser:
    val sections = DwarfSections(
        debug_info: _build_info(),
        debug_abbrev: _build_abbrev(),
        debug_line: _build_line(),
        debug_str: [],
        debug_line_str: [],
        addr_size: 4,
    )
    DwarfParser.from_sections(sections).ok()!

describe "Coordinator resolve_source":
    it "returns nil without provider":
        val coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: nil,
        )
        val loc = coord.resolve_source(0x1000)
        expect(loc == nil).to_equal(true)

    it "returns nil for resolve_addr without provider":
        val coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: nil,
        )
        val addr = coord.resolve_addr("test.spl", 10)
        expect(addr == nil).to_equal(true)

    it "returns nil for resolve_function without provider":
        val coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: nil,
        )
        val func = coord.resolve_function(0x1000)
        expect(func == nil).to_equal(true)

    it "returns empty for resolve_locals without provider":
        val coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: nil,
        )
        val locals = coord.resolve_locals(0x1000)
        expect(locals.len()).to_equal(0)

describe "Coordinator with DwarfParser provider":
    it "resolve_source delegates to provider":
        val parser = _make_parser()
        var coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: Some(parser),
        )
        val loc = coord.resolve_source(0x1000)
        expect(loc != nil).to_equal(true)
        expect(loc!.line).to_equal(10)

    it "resolve_source returns correct line for second entry":
        val parser = _make_parser()
        var coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: Some(parser),
        )
        val loc = coord.resolve_source(0x1020)
        expect(loc != nil).to_equal(true)
        expect(loc!.line).to_equal(20)

    it "resolve_function finds subprogram":
        val parser = _make_parser()
        var coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: Some(parser),
        )
        val func = coord.resolve_function(0x1000)
        expect(func != nil).to_equal(true)
        expect(func!.low_pc).to_equal(0x1000)

    it "resolve_locals returns empty":
        val parser = _make_parser()
        var coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: Some(parser),
        )
        val locals = coord.resolve_locals(0x1000)
        expect(locals.len()).to_equal(0)
