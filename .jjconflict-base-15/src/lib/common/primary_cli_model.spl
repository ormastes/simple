# Primary CLI Model
#
# Command catalog for the minimal SimpleOS shell environment.

struct PrimaryCliCommand:
    name: text
    category: text
    capability: text
    executable: text

fn primary_cli_command(name: text, category: text, capability: text, executable: text) -> PrimaryCliCommand:
    PrimaryCliCommand(name: name, category: category, capability: capability, executable: executable)

fn primary_cli_commands() -> [PrimaryCliCommand]:
    [
        primary_cli_command("shell", "shell", "interactive", "/bin/shell"),
        primary_cli_command("ls", "filesystem", "read", "/bin/ls"),
        primary_cli_command("mkdir", "filesystem", "write", "/bin/mkdir"),
        primary_cli_command("chmod", "filesystem", "write", "/bin/chmod"),
        primary_cli_command("sudo", "privilege", "privilege", "/usr/bin/sudo"),
        primary_cli_command("tmux", "terminal", "terminal", "/usr/bin/tmux"),
        primary_cli_command("ssh", "network", "network", "/usr/bin/ssh"),
        primary_cli_command("pkg", "package", "package", "/usr/sbin/pkg")
    ]

fn primary_cli_find(name: text) -> PrimaryCliCommand?:
    for command in primary_cli_commands():
        if command.name == name:
            return Some(command)
    nil

fn primary_cli_names() -> [text]:
    var names: [text] = []
    for command in primary_cli_commands():
        names = names.push(command.name)
    names

fn primary_cli_is_available(name: text) -> bool:
    match primary_cli_find(name):
        case Some(_): true
        case _: false
