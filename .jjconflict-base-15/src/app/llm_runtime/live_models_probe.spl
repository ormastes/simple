use app.llm_runtime.manifest.{LlmRuntimeManifest}
use app.mcp.main_lazy_json.{LB, RB, jp, js}

pub class LlmRuntimeLiveModelsProbeResult:
    status: text
    reason: text
    endpoint_status: text
    http_status: i64
    model_count: i64
    base_model: text
    base_model_status: text
    evidence_jsonl: text

pub fn llm_runtime_probe_vllm_models_response(manifest: LlmRuntimeManifest, http_status: i64, response_body: text) -> LlmRuntimeLiveModelsProbeResult:
    val endpoint_status = _endpoint_status(manifest.endpoint)
    val model_count = _model_id_count(response_body)
    val base_status = _base_model_status(manifest.base_model, response_body, model_count)
    val status = _live_status(endpoint_status, http_status, response_body, model_count, base_status)
    val reason = _live_reason(status, endpoint_status, http_status, response_body, model_count, base_status)
    val result = LlmRuntimeLiveModelsProbeResult(
        status: status,
        reason: reason,
        endpoint_status: endpoint_status,
        http_status: http_status,
        model_count: model_count,
        base_model: _public_text(manifest.base_model, "missing"),
        base_model_status: base_status,
        evidence_jsonl: ""
    )
    result.evidence_jsonl = llm_runtime_live_models_probe_jsonl_event(result)
    result

pub fn llm_runtime_live_models_probe_jsonl_event(result: LlmRuntimeLiveModelsProbeResult) -> text:
    LB() +
    jp("event", js("llm_runtime_vllm_models_probe")) +
    "," + jp("status", js(result.status)) +
    "," + jp("reason", js(result.reason)) +
    "," + jp("endpoint", js(result.endpoint_status)) +
    "," + jp("http_status", str(result.http_status)) +
    "," + jp("model_count", str(result.model_count)) +
    "," + jp("base_model", js(result.base_model)) +
    "," + jp("base_model_status", js(result.base_model_status)) +
    RB() + "\n"

fn _endpoint_status(endpoint: text) -> text:
    val value = endpoint.trim()
    if value == "":
        return "missing"
    if value.starts_with("http://") or value.starts_with("https://"):
        if value.contains(" "):
            return "invalid"
        return "configured"
    "invalid"

fn _live_status(endpoint_status: text, http_status: i64, body: text, model_count: i64, base_status: text) -> text:
    if endpoint_status != "configured":
        return "missing"
    if http_status == 401 or http_status == 403:
        return "blocked"
    if http_status < 200 or http_status >= 300:
        return "error"
    if not _looks_like_models_response(body):
        return "error"
    if model_count <= 0:
        return "missing"
    if base_status == "missing":
        return "missing"
    "ready"

fn _live_reason(status: text, endpoint_status: text, http_status: i64, body: text, model_count: i64, base_status: text) -> text:
    if endpoint_status == "missing":
        return "missing_endpoint"
    if endpoint_status == "invalid":
        return "invalid_endpoint"
    if http_status == 401 or http_status == 403:
        return "auth_rejected"
    if http_status < 200 or http_status >= 300:
        return "http_error"
    if not _looks_like_models_response(body):
        return "malformed_models_response"
    if model_count <= 0:
        return "no_models_returned"
    if base_status == "missing":
        return "base_model_not_served"
    if status == "ready":
        return "models_endpoint_ready"
    "models_probe_unknown"

fn _looks_like_models_response(body: text) -> bool:
    body.contains("\"data\"") and body.contains("[") and body.contains("]")

fn _base_model_status(base_model: text, body: text, model_count: i64) -> text:
    if base_model.trim() == "":
        return "missing"
    if model_count <= 0:
        return "missing"
    if _response_contains_model_id(body, base_model.trim()):
        return "present"
    "missing"

fn _model_id_count(body: text) -> i64:
    var count: i64 = 0
    var i: i64 = 0
    while i < body.len():
        val next = _find_from(body, "\"id\"", i)
        if next < 0:
            return count
        if _id_field_value(body, next) != "":
            count = count + 1
        i = next + 4
    count

fn _response_contains_model_id(body: text, model_id: text) -> bool:
    var i: i64 = 0
    while i < body.len():
        val next = _find_from(body, "\"id\"", i)
        if next < 0:
            return false
        if _id_field_value(body, next) == model_id:
            return true
        i = next + 4
    false

fn _find_from(source: text, needle: text, start: i64) -> i64:
    if start < 0 or start >= source.len():
        return -1
    val rest = source.slice(start, source.len())
    val found = rest.find(needle)
    if found < 0:
        return -1
    start + found

fn _id_field_value(source: text, id_key_start: i64) -> text:
    var i = id_key_start + 4
    while i < source.len() and source.char_at(i) == " ":
        i = i + 1
    if i >= source.len() or source.char_at(i) != ":":
        return ""
    i = i + 1
    while i < source.len() and source.char_at(i) == " ":
        i = i + 1
    if i >= source.len() or source.char_at(i) != "\"":
        return ""
    i = i + 1
    val start = i
    while i < source.len():
        if source.char_at(i) == "\"":
            return source.slice(start, i)
        i = i + 1
    ""

fn _public_text(value: text, fallback: text) -> text:
    if value.trim() == "":
        return fallback
    if _looks_sensitive(value):
        return "redacted"
    value

fn _looks_sensitive(value: text) -> bool:
    val lower = value.to_lower()
    lower.contains("token") or lower.contains("apikey") or lower.contains("api_key") or lower.contains("password") or lower.contains("secret") or lower.contains("@") or value.contains("/") or value.starts_with("~") or value.contains("\\")

export LlmRuntimeLiveModelsProbeResult
export llm_runtime_probe_vllm_models_response, llm_runtime_live_models_probe_jsonl_event
