use app.dashboard.assistant_collectors.{AssistantDashboardSnapshot}
use app.dashboard.assistant_bridge.{
    AssistantBridgePolicy, AssistantBridgeProjection, AssistantBridgeActionDecision,
    AssistantBridgeSnapshot, assistant_bridge_projection_from_snapshot,
    assistant_bridge_projection_from_empty, assistant_bridge_route_action
}
use app.mcp.assistant.{AssistantSessionRecord}

pub class AssistantDashboardLiveView:
    session_id: text
    objective: text
    status: text
    mode: text
    read_only: bool
    live_controls_enabled: bool
    freshness_state: text
    operator_notice: text
    timeline_count: i64
    task_count: i64
    notification_count: i64
    failure_state: text
    failure_detail: text
    failure_count: i64
    primary_action: AssistantBridgeActionDecision

fn _dashboard_text(value: text) -> text:
    if value.trim() == "":
        ""
    else:
        value

fn _selected_session(snapshot: AssistantDashboardSnapshot) -> AssistantSessionRecord?:
    for session in snapshot.sessions:
        if session.session_id == snapshot.selected_session_id:
            return Some(session)
    nil

fn _session_objective(session: AssistantSessionRecord) -> text:
    val objective = _dashboard_text(session.objective)
    if objective != "":
        return objective
    val summary = _dashboard_text(session.summary)
    if summary != "":
        return summary
    _dashboard_text(session.prompt)

fn _operator_notice(projection: AssistantBridgeProjection) -> text:
    if projection.live_controls_enabled:
        return "live controls routed to assistant_core"
    if projection.freshness.should_refresh:
        return "refresh required before operator actions"
    if projection.freshness.state == "replay":
        return "replay snapshot is read-only"
    "operator actions blocked"

fn _session_failure_state(session: AssistantSessionRecord, projection: AssistantBridgeProjection) -> text:
    if projection.freshness.is_degraded:
        return "bridge_degraded"
    if projection.freshness.state == "stale":
        return "bridge_stale"
    if session.error_count > 0:
        return "error"
    if session.state == "failed":
        return "failed"
    if session.last_event_kind == "error" or session.last_event_kind == "failed" or session.last_event_kind == "failure":
        return "error"
    "ok"

fn _session_failure_detail(session: AssistantSessionRecord, projection: AssistantBridgeProjection) -> text:
    if projection.freshness.is_degraded:
        return "bridge degraded; refresh before acting"
    if projection.freshness.state == "stale":
        return "bridge stale; refresh before acting"
    if session.error_count > 0 or session.state == "failed" or session.last_event_kind == "error" or session.last_event_kind == "failed" or session.last_event_kind == "failure":
        val detail = _dashboard_text(session.last_event_detail)
        if detail != "":
            return detail
        return "assistant failure recorded"
    ""

pub fn assistant_dashboard_live_view_from_snapshot(
    snapshot: AssistantDashboardSnapshot,
    policy: AssistantBridgePolicy,
    now_micros: i64,
    loaded_at_micros: i64,
    live_attachable: bool
) -> AssistantDashboardLiveView:
    val selected = _selected_session(snapshot)
    match selected:
        case Some(session):
            val bridge_snapshot = AssistantBridgeSnapshot(
                snapshot_id: "dashboard-{session.session_id}-{session.updated_at_ms}",
                session_id: session.session_id,
                source_of_truth: policy.source_of_truth,
                revision: session.updated_at_ms,
                objective: _session_objective(session),
                status: _dashboard_text(session.state),
                mode: if live_attachable: "live" else: snapshot.mode,
                timeline_count: snapshot.timeline.len(),
                task_count: session.child_tasks.len(),
                notification_count: snapshot.notifications.len(),
                digest_checkpoint_id: _dashboard_text(session.digest_checkpoint_id),
                captured_at_micros: session.updated_at_ms * 1000,
                loaded_at_micros: loaded_at_micros,
                live_attachable: live_attachable
            )
            val projection = assistant_bridge_projection_from_snapshot(bridge_snapshot, policy, now_micros)
            val action = assistant_bridge_route_action(projection, "signal")
            AssistantDashboardLiveView(
                session_id: projection.session_id,
                objective: projection.objective,
                status: projection.status,
                mode: projection.mode,
                read_only: projection.read_only,
                live_controls_enabled: projection.live_controls_enabled,
                freshness_state: projection.freshness.state,
                operator_notice: _operator_notice(projection),
                timeline_count: projection.timeline_count,
                task_count: projection.task_count,
                notification_count: projection.notification_count,
                failure_state: _session_failure_state(session, projection),
                failure_detail: _session_failure_detail(session, projection),
                failure_count: session.error_count,
                primary_action: action
            )
        case nil:
            val projection = assistant_bridge_projection_from_empty(snapshot.selected_session_id, policy, now_micros)
            val action = assistant_bridge_route_action(projection, "signal")
            AssistantDashboardLiveView(
                session_id: projection.session_id,
                objective: "",
                status: projection.status,
                mode: projection.mode,
                read_only: projection.read_only,
                live_controls_enabled: projection.live_controls_enabled,
                freshness_state: projection.freshness.state,
                operator_notice: _operator_notice(projection),
                timeline_count: 0,
                task_count: 0,
                notification_count: 0,
                failure_state: "missing",
                failure_detail: "selected session unavailable",
                failure_count: 0,
                primary_action: action
            )

pub fn assistant_dashboard_render_live_view(view: AssistantDashboardLiveView) -> [text]:
    [
        "session " + view.session_id,
        "status " + view.status,
        "mode " + view.mode,
        "freshness " + view.freshness_state,
        "objective " + view.objective,
        "timeline " + str(view.timeline_count) + " tasks " + str(view.task_count) + " notifications " + str(view.notification_count),
        "failure " + view.failure_state + " " + view.failure_detail,
        "actions " + view.primary_action.route_target,
        "notice " + view.operator_notice
    ]

export AssistantDashboardLiveView
export assistant_dashboard_live_view_from_snapshot, assistant_dashboard_render_live_view
