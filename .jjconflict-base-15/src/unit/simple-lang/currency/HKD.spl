# Unit: Hkd
# Kind: Currency
# Symbol: HKD
# Canonical scale: 1.0 USD

class Hkd:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Hkd) -> Hkd: Hkd(value: self.value + other.value)
    fn sub(other: Hkd) -> Hkd: Hkd(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "HKD"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Hkd: Hkd(value: 0.0)

export Hkd
