# Unit: PtG
# Kind: Graphics
# Symbol: pt
# Canonical scale: 1.333333 px

class PtG:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: PtG) -> PtG: PtG(value: self.value + other.value)
    fn sub(other: PtG) -> PtG: PtG(value: self.value - other.value)

    static fn kind() -> text: "Graphics"
    static fn symbol() -> text: "pt"
    static fn scale_to_base() -> f64: 1.333333
    static fn base_unit() -> text: "px"
    static fn zero() -> PtG: PtG(value: 0.0)

export PtG
