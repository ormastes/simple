# Unit: KlVol
# Kind: Volume
# Symbol: kL
# Canonical scale: 1.0 m3

class KlVol:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KlVol) -> KlVol: KlVol(value: self.value + other.value)
    fn sub(other: KlVol) -> KlVol: KlVol(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "kL"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m3"
    static fn zero() -> KlVol: KlVol(value: 0.0)

export KlVol
