# @cover src/compiler/10.frontend/parser_types.spl 80%
# @cover src/compiler/10.frontend/parser_factory.spl 80%
# Parser Declaration Specification
# Feature IDs: #PARSER-DECL-001 to #PARSER-DECL-025
# Category: Infrastructure | Parser
# Status: Implemented
#
# Tests that the parser correctly parses declaration statements including
# structs, enums, classes, traits, modules, imports, and type aliases.

use std.spec

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64


struct ParserDeclPoint:
    x: i64
    y: i64

    fn sum() -> i64:
        self.x + self.y


struct ParserDeclSingle:
    label: text


struct ParserDeclEmpty:
    marker: bool


struct ParserDeclBox<T>:
    value: T

    static fn create(value: T) -> ParserDeclBox<T>:
        ParserDeclBox(value: value)


struct ParserDeclPair<K, V>:
    key: K
    value: V


struct ParserDeclSegment:
    start: ParserDeclPoint
    finish: ParserDeclPoint

    fn total() -> i64:
        self.start.sum() + self.finish.sum()


enum ParserDeclColor:
    Red
    Green
    Blue


enum ParserDeclPayload:
    Unit
    Number(value)
    Named(name: text, count: i64)


class ParserDeclCounter:
    count: i64

    fn current() -> i64:
        self.count

    me bump():
        self.count = self.count + 1


trait ParserDeclDisplay:
    fn display() -> text


impl ParserDeclDisplay for ParserDeclPoint:
    fn display() -> text:
        "{self.x},{self.y}"


impl ParserDeclColor:
    fn label() -> text:
        match self:
            case Red: "red"
            case Green: "green"
            case Blue: "blue"


type ParserDeclIntBox = ParserDeclBox<i64>
type ParserDeclTextPoint = ParserDeclPair<text, ParserDeclPoint>


fn parser_declaration_fixture_path(name: text) -> text:
    "/tmp/simple_parser_decl_" + rt_getpid().to_text() + "_" + rt_time_now_unix_micros().to_text() + "_" + name + ".spl"


fn compile_parser_declaration_fixture(name: text, source: text) -> (text, text, i32):
    val path = parser_declaration_fixture_path(name)
    val out_path = path + ".out"
    if not rt_file_write_text(path, source):
        return ("", "failed to write parser declaration fixture: " + path, 99)
    val result = rt_process_run_timeout(
        "/bin/sh",
        [
            "-c",
            "if [ -x src/compiler_rust/target/release/simple ]; then d=src/compiler_rust/target/release/simple; elif [ -x bin/release/simple ]; then d=bin/release/simple; else d=bin/simple; fi; \"$d\" compile \"$1\" -o \"$2\"",
            "parser-declaration-compile",
            path,
            out_path
        ],
        30000
    )
    rt_file_delete(path)
    rt_file_delete(out_path)
    result


fn parser_declaration_source_status(name: text, source: text) -> text:
    val result = compile_parser_declaration_fixture(name, source)
    if result[2] != 0:
        return "fail: " + result[1]
    if not (result[0] + result[1]).contains("Compiled"):
        return "fail: missing compile marker"
    "pass"


fn parser_declaration_metadata_skip_status(name: text, source: text, expected_error: text) -> text:
    val result = compile_parser_declaration_fixture(name, source)
    val combined = result[0] + result[1]
    if result[2] == 0:
        return "fail: metadata fixture compiled as compiler attribute"
    if not combined.contains(expected_error):
        return "fail: missing expected metadata rejection"
    "skip: spipe-metadata-not-compiler-attribute"


describe "Struct Declaration Parsing":
    context "basic structs":
        it "parses struct with fields":
            val p = ParserDeclPoint(x: 2, y: 3)
            expect(p.sum()).to_equal(5)

        it "parses struct with single field":
            val single = ParserDeclSingle(label: "only")
            expect(single.label).to_equal("only")

        it "parses empty struct":
            val empty = ParserDeclEmpty(marker: true)
            assert_true(empty.marker)

    context "generic structs":
        it "parses generic struct":
            val boxed = ParserDeclBox<i64>.create(42)
            expect(boxed.value).to_equal(42)

        it "parses multi-param generic struct":
            val pair = ParserDeclPair<text, i64>(key: "answer", value: 42)
            expect(pair.key + ":" + pair.value.to_text()).to_equal("answer:42")

    context "nested structs":
        it "parses struct with struct field":
            val segment = ParserDeclSegment(start: ParserDeclPoint(x: 1, y: 2), finish: ParserDeclPoint(x: 3, y: 4))
            expect(segment.total()).to_equal(10)


describe "Enum Declaration Parsing":
    context "simple enums":
        it "parses enum without data":
            expect(ParserDeclColor.Red.label()).to_equal("red")

        it "parses enum comparison":
            assert_true(ParserDeclColor.Green == ParserDeclColor.Green)

    context "enums with data":
        it "parses enum with tuple variant":
            val value = ParserDeclPayload.Number(7)
            if val ParserDeclPayload.Number(n) = value:
                expect(n).to_equal(7)
            else:
                expect("tuple variant did not match").to_equal("")

        it "parses enum with struct variant":
            val value = ParserDeclPayload.Named(name: "items", count: 3)
            if val ParserDeclPayload.Named(name: label, count: n) = value:
                expect(label).to_equal("items")
                expect(n).to_equal(3)
            else:
                expect("struct variant did not match").to_equal("")

    context "enum matching":
        it "parses enum in match":
            val value = ParserDeclColor.Blue
            val label = match value:
                case Red: "red"
                case Green: "green"
                case Blue: "blue"
            expect(label).to_equal("blue")


describe "Class Declaration Parsing":
    context "basic classes":
        it "parses class with fields":
            val counter = ParserDeclCounter(count: 2)
            expect(counter.current()).to_equal(2)

        it "parses class with methods":
            var counter = ParserDeclCounter(count: 2)
            counter.bump()
            expect(counter.current()).to_equal(3)

    context "class inheritance":
        it "parses class with trait impl":
            val p = ParserDeclPoint(x: 6, y: 7)
            expect(p.display()).to_equal("6,7")
            expect(parser_declaration_source_status("trait_impl", "trait DisplayFixture:\n    fn display() -> text\n\nstruct DisplayPoint:\n    x: i64\n\nimpl DisplayFixture for DisplayPoint:\n    fn display() -> text:\n        \"displayed\"")).to_equal("pass")


describe "Trait Declaration Parsing":
    context "basic traits":
        it "parses trait with method":
            val p = ParserDeclPoint(x: 8, y: 9)
            expect(p.display()).to_equal("8,9")

        it "parses trait with default method":
            expect(parser_declaration_source_status("trait_default", "trait NamedFixture:\n    fn name() -> text:\n        \"default\"")).to_equal("pass")

    context "trait bounds":
        it "parses trait extending trait":
            expect(parser_declaration_source_status("trait_extends", "trait BaseFixture:\n    fn display() -> text\n\ntrait PrettyFixture: BaseFixture:\n    fn pretty() -> text")).to_equal("pass")


describe "Module Declaration Parsing":
    context "inline modules":
        it "parses inline module":
            expect(parser_declaration_source_status("mod_simple", "mod parser_decl_fixture")).to_equal("pass")

        it "parses nested modules":
            expect(parser_declaration_source_status("mod_nested", "mod parser_decl_fixture.nested")).to_equal("pass")

    context "module items":
        it "parses module with multiple items":
            expect(parser_declaration_source_status("mod_items", "mod parser_decl_fixture\nexport use parser_decl_fixture.{x, y}")).to_equal("pass")


describe "Import Declaration Parsing":
    it "parses simple import":
        expect(parser_declaration_source_status("use_simple", "use std.spec")).to_equal("pass")

    it "parses specific import":
        expect(parser_declaration_source_status("use_specific", "use std.spec." + "{" + "expect" + "}")).to_equal("pass")

    it "parses multiple imports":
        expect(parser_declaration_source_status("use_multiple", "use std.spec." + "{" + "describe, expect" + "}")).to_equal("pass")


describe "Type Alias Declaration Parsing":
    it "parses simple type alias":
        val boxed = ParserDeclIntBox.create(11)
        expect(boxed.value).to_equal(11)

    it "parses generic type alias":
        val aliased = ParserDeclBox<text>.create("typed")
        expect(aliased.value).to_equal("typed")

    it "parses complex type alias":
        val pair = ParserDeclTextPoint(key: "origin", value: ParserDeclPoint(x: 0, y: 0))
        expect(pair.value.sum()).to_equal(0)


describe "Variable Declaration Parsing":
    context "immutable variables":
        it "parses val declaration":
            val x = 42
            expect(x).to_equal(42)

        it "parses val with type annotation":
            val x: i64 = 42
            expect(x).to_equal(42)

    context "mutable variables":
        it "parses var declaration":
            var x = 0
            x = 42
            expect(x).to_equal(42)

        it "parses var with type annotation":
            var x: i64 = 0
            x = 42
            expect(x).to_equal(42)

    context "let bindings":
        it "parses let declaration":
            let x = 42
            expect(x).to_equal(42)

        it "parses let with destructuring":
            let (a, b) = (1, 2)
            expect(a + b).to_equal(3)


describe "Impl Block Parsing":
    it "parses impl block for struct":
        expect(ParserDeclColor.Red.label()).to_equal("red")

    it "parses impl block for trait":
        val p = ParserDeclPoint(x: 4, y: 5)
        expect(p.display()).to_equal("4,5")


describe "Attribute Declaration Parsing":
    it "documents SPipe @cover metadata is not a compiler function attribute":
        expect(parser_declaration_metadata_skip_status("attr_cover_metadata", "@cover src/compiler/10.frontend/parser_types.spl 80%\nfn attr_fixture(): pass", "expected Fn")).to_equal("skip: spipe-metadata-not-compiler-attribute")

    it "documents SPipe @when metadata is not a compiler function attribute":
        expect(parser_declaration_metadata_skip_status("attr_when_metadata", "@when(target = \"test\")\nfn attr_fixture(): pass", "variable `when` not found")).to_equal("skip: spipe-metadata-not-compiler-attribute")

    it "documents multiple SPipe metadata lines are not compiler attributes":
        expect(parser_declaration_metadata_skip_status("attr_multiple_metadata", "@cover a 80%\n@when(target = \"test\")\nfn attr_fixture(): pass", "expected Fn")).to_equal("skip: spipe-metadata-not-compiler-attribute")

    it "parses attribute on struct":
        expect(parser_declaration_source_status("attr_derive_struct", "@derive(Debug)\nstruct AttrFixture:\n    value: i64")).to_equal("pass")
