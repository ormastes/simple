use std.spec.{describe, it, expect}
use common.ui.style.{
    StyleRule,
    StyleSelector,
    StyleSheet,
    resolve_style
}

fn _color_rule(color: text) -> StyleRule:
    val base = StyleRule.default()
    return StyleRule(
        color: base.color.with_color(color),
        font: base.font,
        padding: base.padding,
        margin: base.margin,
        width: base.width,
        height: base.height,
        border_width: base.border_width,
        border_radius: base.border_radius,
        border_style: base.border_style,
        display: base.display,
        visibility: base.visibility
    )

describe "resolve_style":
    it "cascades lower specificity before higher specificity":
        var sheet = StyleSheet.new()
        sheet.add_rule(StyleSelector.by_id("save"), _color_rule("red"))
        sheet.add_rule(StyleSelector.by_kind("button"), _color_rule("blue"))

        val resolved = resolve_style(sheet, "save", "button", "", "")

        expect(resolved.color.color).to_equal("red")

    it "preserves sheet order for equal specificity rules":
        var sheet = StyleSheet.new()
        sheet.add_rule(StyleSelector.by_kind("button"), _color_rule("blue"))
        sheet.add_rule(StyleSelector.by_kind("button"), _color_rule("green"))

        val resolved = resolve_style(sheet, "save", "button", "", "")

        expect(resolved.color.color).to_equal("green")
