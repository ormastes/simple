# Host-local SPipe configuration for Simple.

spipe:
  upstream: https://github.com/ormastes/Spipe.git
  compatibility_submodule: .spipe/spipe
  example_project_submodule: examples/spipe
  example_project_link: .spipe/spipe_project

docs:
  host_process_doc: doc/00_llm_process
  host_process_doc_link: .spipe/doc
  default_process_doc: doc/llm_process

common_links:
  - .spipe/domain_expert
  - .spipe/spipe_docs
  - .spipe/template
  - .spipe/tool_expert/spipe_submodule
  - .spipe/project_expert/spipe
  - doc/00_llm_process/domain_expert
  - doc/00_llm_process/spipe
  - doc/00_llm_process/template
  - doc/00_llm_process/tool_expert
  - doc/00_llm_process/skill_command

llm_tuning:
  artifact_root: .spipe/llm-finetune-process
  default_doc_root: doc/llm_process
  simple_doc_root: doc/00_llm_process
  records:
    models: .spipe/llm-finetune-process/models.sdn
    data_downloads: .spipe/llm-finetune-process/data_downloads.sdn
    data_checks: .spipe/llm-finetune-process/data_checks.sdn
    process_docs: .spipe/llm-finetune-process/process_docs.sdn
    requirements_selection: .spipe/llm-finetune-process/requirements_selection.sdn
    model_research: .spipe/llm-finetune-process/model_research.sdn
    model_architecture: .spipe/llm-finetune-process/model_architecture.sdn
    tuning_methods: .spipe/llm-finetune-process/tuning_methods.sdn
    training_scripts: .spipe/llm-finetune-process/training_scripts.sdn
    eval_results: .spipe/llm-finetune-process/eval_results.sdn
    decisions: .spipe/llm-finetune-process/decisions.sdn
    app_handoffs: .spipe/llm-finetune-process/app_handoffs.sdn
    retune_requests: .spipe/llm-finetune-process/retune_requests.sdn
    attempts: .spipe/llm-finetune-process/attempts.sdn
