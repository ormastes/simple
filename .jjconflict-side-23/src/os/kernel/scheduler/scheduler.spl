# Preemptive Scheduler — Computation Dimension
#
# Priority-based preemptive scheduler with round-robin within same priority.
# Fixed-size task table (MAX_TASKS slots). Timer interrupt drives preemption.
#
# Hub file: imports types from scheduler_types.spl; algorithm bodies live in
# scheduler_task_mgmt.spl, scheduler_algorithm.spl, and scheduler_exec.spl.
#
# Consumes: SchedulerInputPort (interrupts, memory)
# Produces: SchedulerOutputPort (task lifecycle, blocking)

# Split into the _Scheduler/ transparent package to keep module cohesion under the 800-line source limit.
export use os.kernel.scheduler._Scheduler.scheduler_imports.*
export use os.kernel.scheduler._Scheduler.scheduler_lifecycle.*
export use os.kernel.scheduler._Scheduler.scheduler_priority_exec.*
export use os.kernel.scheduler._Scheduler.scheduler_helpers.*
