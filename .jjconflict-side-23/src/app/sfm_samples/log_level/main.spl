# AC-8: native entry driving the SFM log-level changer.
#
# Sets a level, emits at various levels, and prints OK/FAIL showing that
# above-threshold messages are suppressed, at/over-threshold are visible, and
# the get(set(x))==x round-trip holds.
# Run: bin/simple run src/app/sfm_samples/log_level/main.spl

use app.sfm_samples.log_level.log_level_sfm.{sfm_set_log_level, sfm_get_log_level, sfm_log_emit}
use std.log.{LOG_DEBUG, LOG_INFO, LOG_WARN}

fn ok(cond: bool, label: text):
    if cond:
        print("OK " + label)
    else:
        print("FAIL " + label)

fn main():
    # Set level to WARN: INFO/DEBUG suppressed, WARN visible.
    sfm_set_log_level(LOG_WARN)
    ok(sfm_get_log_level() == LOG_WARN, "set WARN round-trip")
    ok(not sfm_log_emit(LOG_INFO, "info-msg"), "INFO suppressed at WARN")
    ok(not sfm_log_emit(LOG_DEBUG, "debug-msg"), "DEBUG suppressed at WARN")
    ok(sfm_log_emit(LOG_WARN, "warn-msg"), "WARN visible at WARN")

    # Lower to DEBUG: now INFO and DEBUG become visible.
    sfm_set_log_level(LOG_DEBUG)
    ok(sfm_get_log_level() == LOG_DEBUG, "set DEBUG round-trip")
    ok(sfm_log_emit(LOG_INFO, "info-msg"), "INFO visible at DEBUG")
    ok(sfm_log_emit(LOG_DEBUG, "debug-msg"), "DEBUG visible at DEBUG")
