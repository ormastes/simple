# Simple Settlement Stub (Written in Simple)
#
# Minimal executable stub for Simple settlement executables.
# When run, it loads the settlement data appended to itself and executes it.

# I/O imports
use app.io.cli_ops (cli_get_args, settlement_main)
use std.cli.log_modes.{parse_log_options, log_options_help}
use std.log.{error}

fn print_help():
    print "Usage: simple stub [options]"
    print ""
    print "Run an appended Simple settlement payload."
    print ""
    print "Options:"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help   Show this help"

fn main() -> i64:
    val args = cli_get_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("stub", log_opts.error)
        return 1
    for arg in args:
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
    settlement_main()
