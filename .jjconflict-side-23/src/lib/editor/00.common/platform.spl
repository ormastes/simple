# Editor Platform
#
# Platform detection and configuration for Desktop, SimpleOS, and Web.

enum EditorPlatform:
    Desktop
    SimpleOS
    Web

struct PlatformConfig:
    platform: EditorPlatform
    max_open_files: i64
    max_undo_depth: i64
    auto_save_interval_ms: i64
    file_watcher_enabled: bool

fn platform_default_config(platform: EditorPlatform) -> PlatformConfig:
    match platform:
        EditorPlatform.Desktop:
            PlatformConfig(
                platform: platform,
                max_open_files: 256,
                max_undo_depth: 128,
                auto_save_interval_ms: 30000,
                file_watcher_enabled: true
            )
        EditorPlatform.SimpleOS:
            PlatformConfig(
                platform: platform,
                max_open_files: 32,
                max_undo_depth: 32,
                auto_save_interval_ms: 60000,
                file_watcher_enabled: false
            )
        EditorPlatform.Web:
            PlatformConfig(
                platform: platform,
                max_open_files: 64,
                max_undo_depth: 64,
                auto_save_interval_ms: 30000,
                file_watcher_enabled: false
            )

fn platform_name(platform: EditorPlatform) -> text:
    match platform:
        EditorPlatform.Desktop => "desktop"
        EditorPlatform.SimpleOS => "simpleos"
        EditorPlatform.Web => "web"

extern fn parse_int(text: text) -> Option<i64>

fn platform_config_get_by_key(config: PlatformConfig, key: text) -> text:
    if key == "max_open_files":
        config.max_open_files.to_text()
    else if key == "max_undo_depth":
        config.max_undo_depth.to_text()
    else if key == "auto_save_interval_ms":
        config.auto_save_interval_ms.to_text()
    else if key == "file_watcher_enabled":
        if config.file_watcher_enabled:
            "true"
        else:
            "false"
    else if key == "platform":
        platform_name(config.platform)
    else:
        ""

fn platform_config_set_by_key(config: PlatformConfig, key: text, value: text) -> PlatformConfig:
    if key == "max_open_files":
        val n = parse_int(value) ?? config.max_open_files
        PlatformConfig(
            platform: config.platform,
            max_open_files: n,
            max_undo_depth: config.max_undo_depth,
            auto_save_interval_ms: config.auto_save_interval_ms,
            file_watcher_enabled: config.file_watcher_enabled
        )
    else if key == "max_undo_depth":
        val n = parse_int(value) ?? config.max_undo_depth
        PlatformConfig(
            platform: config.platform,
            max_open_files: config.max_open_files,
            max_undo_depth: n,
            auto_save_interval_ms: config.auto_save_interval_ms,
            file_watcher_enabled: config.file_watcher_enabled
        )
    else if key == "auto_save_interval_ms":
        val n = parse_int(value) ?? config.auto_save_interval_ms
        PlatformConfig(
            platform: config.platform,
            max_open_files: config.max_open_files,
            max_undo_depth: config.max_undo_depth,
            auto_save_interval_ms: n,
            file_watcher_enabled: config.file_watcher_enabled
        )
    else if key == "file_watcher_enabled":
        PlatformConfig(
            platform: config.platform,
            max_open_files: config.max_open_files,
            max_undo_depth: config.max_undo_depth,
            auto_save_interval_ms: config.auto_save_interval_ms,
            file_watcher_enabled: value == "true"
        )
    else if key == "platform":
        val p = if value == "desktop":
            EditorPlatform.Desktop
        else if value == "simpleos":
            EditorPlatform.SimpleOS
        else if value == "web":
            EditorPlatform.Web
        else:
            config.platform
        PlatformConfig(
            platform: p,
            max_open_files: config.max_open_files,
            max_undo_depth: config.max_undo_depth,
            auto_save_interval_ms: config.auto_save_interval_ms,
            file_watcher_enabled: config.file_watcher_enabled
        )
    else:
        config
