# std.game2d.render.sprite_batch — SpriteBatch for game2d
#
# Groups multiple `DrawSprite` submissions by texture_id so that the
# backend sees one logical draw-call per unique texture rather than one
# per sprite.  Internally, each sprite submission is kept as a
# `SpriteEntry`; `flush` emits sorted `RenderCommand.DrawSprite` entries
# into a `RenderCommandBuffer`.
#
# Sorting strategy: entries are first ordered by z_order (ascending) and
# then by texture_id (ascending) within the same z-band, minimising both
# painter-order violations and texture-switch overhead.
#
# Usage:
#   var batch = SpriteBatch.create()
#   batch.add(tex_id, src, dst, tint, z)
#   batch.add(tex_id, src2, dst2, tint2, z)
#   batch.flush(cmd_buf)   # emits sorted DrawSprite commands
#   batch.clear()
#
# ============================================================================
# SpriteEntry — one pending sprite submission
# ============================================================================

use std.common.engine.ids.{TextureId}
use std.common.engine.rect.{Rect2}
use std.common.engine.color.{EngineColor}
use std.common.engine.units.{ZIndex}
use std.nogc_sync_mut.engine.render.command.{RenderCommand, RenderCommandBuffer}

struct SpriteEntry:
    texture_id: TextureId
    src_rect: Rect2
    dst_rect: Rect2
    tint: EngineColor
    z_order: ZIndex

# ============================================================================
# SpriteBatch
# ============================================================================

class SpriteBatch:
    """Accumulates sprite submissions for a single frame and flushes them
    as sorted DrawSprite commands into a RenderCommandBuffer.

    Call `clear()` between frames to reset without reallocating."""
    entries: [SpriteEntry]

    static fn create() -> SpriteBatch:
        SpriteBatch(entries: [])

    fn add(self, tid: TextureId, src: Rect2, dst: Rect2, tint: EngineColor, z: ZIndex):
        """Enqueue one sprite for this frame."""
        val entry = SpriteEntry(
            texture_id: tid,
            src_rect: src,
            dst_rect: dst,
            tint: tint,
            z_order: z
        )
        self.entries = self.entries.push(entry)

    fn add_simple(self, tid: TextureId, src: Rect2, dst: Rect2):
        """Enqueue one sprite with white tint at z=0."""
        self.add(tid, src, dst, EngineColor.white(), ZIndex(value: 0))

    fn count(self) -> i64:
        self.entries.len()

    fn clear(self):
        """Reset for the next frame (does not free memory)."""
        self.entries = []

    fn flush(self, buf: RenderCommandBuffer):
        """Sort entries and push DrawSprite commands into `buf`.

        Sort key: (z_order.value ascending, texture_id.raw ascending).
        Insertion sort — stable and efficient for the small N typical of
        a single game2d frame.
        """
        val sorted = _sort_entries(self.entries)
        var i = 0
        while i < sorted.len():
            val e = sorted[i]
            buf.push(RenderCommand.DrawSprite(
                texture_id: e.texture_id,
                src_rect: e.src_rect,
                dst_rect: e.dst_rect,
                tint: e.tint,
                z_order: e.z_order
            ))
            i = i + 1

# ============================================================================
# Helpers — insertion sort by (z_order, texture_id)
# ============================================================================

fn _entry_key(e: SpriteEntry) -> i64:
    # Pack z (upper 32 bits) and texture_id (lower 32 bits) into one i64
    # so a single integer comparison drives the sort.
    # z_order.value is expected to be a small non-negative i64.
    val z = e.z_order.value
    val t = e.texture_id.raw
    z * 4294967296 + t

fn _sort_entries(entries: [SpriteEntry]) -> [SpriteEntry]:
    """Stable insertion sort on `_entry_key`."""
    var arr = entries
    var i = 1
    while i < arr.len():
        val key_i = _entry_key(arr[i])
        var j = i - 1
        while j >= 0 and _entry_key(arr[j]) > key_i:
            # Swap arr[j] and arr[j+1]
            val tmp = arr[j + 1]
            arr[j + 1] = arr[j]
            arr[j] = tmp
            j = j - 1
        i = i + 1
    arr
