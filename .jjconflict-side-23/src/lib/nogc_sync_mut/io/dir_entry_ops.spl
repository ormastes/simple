"""
# Directory Entry Runtime Backend

No-GC sync owner for low-level directory entry and simple create/remove
runtime hooks used by async file metadata helpers.
"""

extern fn rt_readdir(path: text) -> i64
extern fn rt_readdir_count(handle: i64) -> i64
extern fn rt_readdir_entry(handle: i64, index: i64) -> text
extern fn rt_readdir_free(handle: i64)
extern fn rt_mkdir(path: text, mode: i64) -> i64
extern fn rt_remove(path: text) -> i64

export rt_readdir, rt_readdir_count, rt_readdir_entry, rt_readdir_free, rt_mkdir, rt_remove
