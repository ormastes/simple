# Tests for mcpgdb JSON brace helpers.

use app.mcpgdb.json_helpers.{LB, RB, jo1, jp, js}

describe "app.mcpgdb.json_helpers brace helpers":
    it "builds JSON object braces without char casts":
        expect(LB()).to_equal("{")
        expect(RB()).to_equal("}")
        expect(jo1(jp("kind", js("debug")))).to_equal("{\"kind\":\"debug\"}")
