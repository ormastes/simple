# variants/ui/renderer/vulkan — renderer_select override
#
# Vulkan-first build target: Vulkan leads, then remaining GPU backends,
# followed by CPU fallbacks. Always ends with "cpu".

fn renderer_priority_order() -> [text]:
    """Vulkan-first build: Vulkan, then other GPU backends, then CPU fallbacks."""
    ["vulkan", "metal", "cuda", "rocm", "qualcomm", "directx", "opencl", "opengl", "intel", "webgpu", "cpu_simd", "software", "cpu"]
