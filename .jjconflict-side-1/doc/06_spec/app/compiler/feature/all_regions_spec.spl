use std.spec.SSpec

describe "all regions language strategy":
    describe "REQ-001: region map":
        it "keeps SDN as carrier rather than universal authoring surface":
            val sdn_primary = "config manifests metadata snapshots catalogs generated-ir"
            expect(sdn_primary).to_contain("metadata")

    describe "REQ-003: priority order":
        it "starts with schema and style/ui":
            val first = "schema"
            val second = "style/ui"
            expect(first).to_equal("schema")
            expect(second).to_equal("style/ui")

    describe "REQ-004: interchange anchors":
        it "names standards for heavy domains":
            val anchors = "MusicXML IFC bSDD gbXML CityGML STEP AP242 VHDL SystemVerilog"
            expect(anchors).to_contain("MusicXML")
            expect(anchors).to_contain("STEP AP242")

