"""
# ARM FS Exec VFS Alias Spec

Verifies the ARM FAT32 bridge maps the migrated guest filesystem apps and
toolchain manifests to the same canonical disk aliases used by the generic VFS.
"""

use std.spec.{describe, it, expect}
use os.services.vfs.arm_fs_exec_vfs.{arm_fs_exec_disk_alias}

describe "arm_fs_exec_vfs aliases":
    it "maps canonical tool app ids onto FAT32 short names":
        expect arm_fs_exec_disk_alias("/sys/apps/hello_world.smf") == "/SYS/APPS/HELLOSMF.SMF"
        expect arm_fs_exec_disk_alias("/sys/apps/simple_compiler") == "/SYS/APPS/SCOMPSMF.SMF"
        expect arm_fs_exec_disk_alias("/sys/apps/simple_interpreter") == "/SYS/APPS/SINTSMF.SMF"
        expect arm_fs_exec_disk_alias("/sys/apps/simple_loader") == "/SYS/APPS/SLOADSMF.SMF"
        expect arm_fs_exec_disk_alias("/sys/apps/llvm") == "/SYS/APPS/LLVMSMF.SMF"
        expect arm_fs_exec_disk_alias("/sys/apps/rust") == "/SYS/APPS/RUSTSMF.SMF"

    it "maps toolchain manifests through the ARM SYS directory":
        expect arm_fs_exec_disk_alias("/SYS/LLVMMAN.TXT") == "/SYS/LLVMMAN.TXT"
        expect arm_fs_exec_disk_alias("/SYS/RUSTMAN.TXT") == "/SYS/RUSTMAN.TXT"
        expect arm_fs_exec_disk_alias("/SYS/TOOLSET.SDN") == "/SYS/TOOLSET.SDN"