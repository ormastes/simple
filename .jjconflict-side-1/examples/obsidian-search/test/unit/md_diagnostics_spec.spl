# Unit tests for markdown diagnostics module

use src.core.md_diagnostics.{MdDiagnostic, md_diag, check_md_frontmatter, check_md_empty_note, check_md_heading_gaps, check_md_list_markers, check_md_image_alt, check_md_large_note, check_md_local, check_markdown_diagnostics, md_severity_label, format_md_diagnostics_block, md_diagnostics_to_json}

describe "MdDiagnostics":
    """Tests for markdown diagnostic checks"""

    context "severity labels":
        """Severity integer to label mapping"""

        it "maps Error":
            expect(md_severity_label(1)).to_equal("Error")

        it "maps Warning":
            expect(md_severity_label(2)).to_equal("Warning")

        it "maps Information":
            expect(md_severity_label(3)).to_equal("Information")

        it "maps Hint":
            expect(md_severity_label(4)).to_equal("Hint")

        it "maps Unknown for invalid":
            expect(md_severity_label(0)).to_equal("Unknown")
            expect(md_severity_label(5)).to_equal("Unknown")

    context "factory":
        """MdDiagnostic factory function"""

        it "creates diagnostic with obsidian-lsp source":
            val d = md_diag(1, 10, 5, "test message", "MD-E001")
            expect(d.severity).to_equal(1)
            expect(d.line).to_equal(10)
            expect(d.col).to_equal(5)
            expect(d.message).to_equal("test message")
            expect(d.code).to_equal("MD-E001")
            expect(d.source).to_equal("obsidian-lsp")

    context "frontmatter checks":
        """MD-W001 and MD-E002"""

        it "warns on missing frontmatter":
            val diags = check_md_frontmatter("# Hello\n\nSome content")
            expect(diags.len()).to_equal(1)
            expect(diags[0].code).to_equal("MD-W001")
            expect(diags[0].severity).to_equal(2)

        it "errors on unclosed frontmatter":
            val diags = check_md_frontmatter("---\ntitle: Test\nNo closing marker")
            expect(diags.len()).to_equal(1)
            expect(diags[0].code).to_equal("MD-E002")
            expect(diags[0].severity).to_equal(1)

        it "clean for valid frontmatter":
            val diags = check_md_frontmatter("---\ntitle: Test\n---\n\n# Content")
            expect(diags.len()).to_equal(0)

    context "empty note checks":
        """MD-W002"""

        it "warns on empty note after frontmatter":
            val diags = check_md_empty_note("---\ntitle: Test\n---\n\n")
            expect(diags.len()).to_equal(1)
            expect(diags[0].code).to_equal("MD-W002")
            expect(diags[0].severity).to_equal(2)

        it "clean for note with content":
            val diags = check_md_empty_note("---\ntitle: Test\n---\n\n# Real content here")
            expect(diags.len()).to_equal(0)

        it "warns on completely empty note":
            val diags = check_md_empty_note("")
            expect(diags.len()).to_equal(1)
            expect(diags[0].code).to_equal("MD-W002")

    context "heading gap checks":
        """MD-H001"""

        it "detects heading level gap":
            val diags = check_md_heading_gaps("# Title\n\n### Subsection\n")
            expect(diags.len()).to_equal(1)
            expect(diags[0].code).to_equal("MD-H001")
            expect(diags[0].severity).to_equal(4)

        it "clean for sequential headings":
            val diags = check_md_heading_gaps("# Title\n\n## Section\n\n### Subsection")
            expect(diags.len()).to_equal(0)

        it "clean for no headings":
            val diags = check_md_heading_gaps("Just plain text\nwith no headings")
            expect(diags.len()).to_equal(0)

    context "list marker checks":
        """MD-H002"""

        it "detects inconsistent markers":
            val diags = check_md_list_markers("- item one\n* item two\n")
            expect(diags.len()).to_equal(1)
            expect(diags[0].code).to_equal("MD-H002")
            expect(diags[0].severity).to_equal(4)

        it "clean for consistent markers":
            val diags = check_md_list_markers("- item one\n- item two\n- item three")
            expect(diags.len()).to_equal(0)

        it "clean for no lists":
            val diags = check_md_list_markers("No lists here")
            expect(diags.len()).to_equal(0)

    context "image alt text checks":
        """MD-H003"""

        it "detects missing alt text":
            val diags = check_md_image_alt("Here is an image ![](photo.png) inline")
            expect(diags.len()).to_equal(1)
            expect(diags[0].code).to_equal("MD-H003")
            expect(diags[0].severity).to_equal(4)

        it "clean for image with alt text":
            val diags = check_md_image_alt("![A photo](photo.png)")
            expect(diags.len()).to_equal(0)

    context "large note checks":
        """MD-I001"""

        it "warns on large notes":
            var lines: [text] = []
            var i = 0
            while i < 1001:
                lines.push("line " + str(i))
                i = i + 1
            val content = lines.join("\n")
            val diags = check_md_large_note(content)
            expect(diags.len()).to_equal(1)
            expect(diags[0].code).to_equal("MD-I001")
            expect(diags[0].severity).to_equal(3)

        it "clean for small notes":
            val diags = check_md_large_note("Short note\nwith few lines")
            expect(diags.len()).to_equal(0)

    context "local orchestrator":
        """check_md_local combines all local checks"""

        it "finds multiple issues":
            val content = "# Title\n\n### Jump\n\n- item\n* mixed\n\n![](no-alt.png)"
            val diags = check_md_local(content)
            # Should find: MD-W001 (missing frontmatter), MD-H001 (heading gap), MD-H002 (markers), MD-H003 (alt)
            expect(diags.len()).to_be_greater_than(2)

        it "clean for well-formed note":
            val content = "---\ntitle: Test\ntags: [test]\n---\n\n# Title\n\n## Section\n\n- item one\n- item two\n\n![Photo](img.png)"
            val diags = check_md_local(content)
            expect(diags.len()).to_equal(0)

    context "format diagnostics block":
        """<new-diagnostics> output format"""

        it "returns empty for no diagnostics":
            var diags: [MdDiagnostic] = []
            val block = format_md_diagnostics_block("test.md", diags)
            expect(block).to_equal("")

        it "formats single diagnostic":
            var diags: [MdDiagnostic] = []
            diags.push(md_diag(1, 5, 3, "Broken wikilink", "MD-E001"))
            val block = format_md_diagnostics_block("notes/test.md", diags)
            expect(block).to_contain("<new-diagnostics>")
            expect(block).to_contain("</new-diagnostics>")
            expect(block).to_contain("notes/test.md:")
            expect(block).to_contain("Error (line 5, col 3): Broken wikilink [MD-E001] (obsidian-lsp)")

        it "formats multiple diagnostics":
            var diags: [MdDiagnostic] = []
            diags.push(md_diag(1, 5, 1, "Error msg", "MD-E001"))
            diags.push(md_diag(2, 10, 1, "Warning msg", "MD-W001"))
            diags.push(md_diag(4, 20, 1, "Hint msg", "MD-H001"))
            val block = format_md_diagnostics_block("test.md", diags)
            expect(block).to_contain("Error (line 5")
            expect(block).to_contain("Warning (line 10")
            expect(block).to_contain("Hint (line 20")

    context "JSON serialization":
        """md_diagnostics_to_json"""

        it "serializes empty list":
            var diags: [MdDiagnostic] = []
            val json = md_diagnostics_to_json(diags)
            expect(json).to_equal("[]")

        it "serializes diagnostics to JSON array":
            var diags: [MdDiagnostic] = []
            diags.push(md_diag(1, 5, 3, "Broken link", "MD-E001"))
            val json = md_diagnostics_to_json(diags)
            expect(json).to_contain("\"severity\":1")
            expect(json).to_contain("\"line\":5")
            expect(json).to_contain("\"code\":\"MD-E001\"")
            expect(json).to_contain("\"source\":\"obsidian-lsp\"")

    context "full diagnostics":
        """check_markdown_diagnostics sorts by severity"""

        it "sorts errors before warnings before hints":
            val content = "# Title\n\n### Jump\n"
            val diags = check_markdown_diagnostics("test.md", content, "")
            # Should have MD-W001 (warning, sev 2) and MD-H001 (hint, sev 4)
            if diags.len() >= 2:
                expect(diags[0].severity).to_be_less_than(diags[diags.len() - 1].severity)
