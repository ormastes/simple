#![allow(export_outside_init)]
# Obsidian LSP — Method Dispatch
# Routes LSP methods to their respective handlers.
#
# Supported methods:
#   initialize, initialized, shutdown, exit
#   textDocument/didOpen, textDocument/didChange, textDocument/didClose
#   textDocument/completion, textDocument/hover, textDocument/definition
#   textDocument/semanticTokens/full

export dispatch_method, handle_initialize

use src.util.json_helpers.{js, jp, jo, jo1, jo2, jo3, jo4, jo5, ja, ji, jb, jnull}
use src.lsp.lsp_json.{make_response, make_error_response, make_notification}
use src.lsp.lsp_json.{extract_method, extract_id, extract_params}
use src.lsp.lsp_json.{extract_td_uri, extract_td_text, extract_td_version}
use src.lsp.lsp_json.{extract_content_changes_text}
use src.lsp.lsp_document.{doc_store_open, doc_store_change, doc_store_close, vault_init}
use src.lsp.lsp_completion.{handle_completion}
use src.lsp.lsp_hover.{handle_hover}
use src.lsp.lsp_definition.{handle_definition}
use src.lsp.lsp_semantic.{handle_semantic_tokens_full, semantic_tokens_legend}
use src.lsp.lsp_diagnostics.{publish_diagnostics, publish_empty_diagnostics}

extern fn rt_stderr_write(s: text)

# ---------------------------------------------------------------------------
# Initialize handler
# ---------------------------------------------------------------------------

fn handle_initialize(params: text) -> text:
    # Scan vault on initialize
    vault_init()

    # Build server capabilities
    val text_doc_sync = ji(1)  # Full sync

    # Completion provider
    val completion_triggers = ja([js("["), js("#")])
    val completion_provider = jo1(jp("triggerCharacters", completion_triggers))

    # Semantic tokens provider
    val legend = semantic_tokens_legend()
    val semantic_provider = jo2(
        jp("legend", legend),
        jp("full", jb(true))
    )

    # Capabilities
    val capabilities = jo([
        jp("textDocumentSync", text_doc_sync),
        jp("completionProvider", completion_provider),
        jp("hoverProvider", jb(true)),
        jp("definitionProvider", jb(true)),
        jp("semanticTokensProvider", semantic_provider)
    ])

    # Server info
    val server_info = jo2(
        jp("name", js("obsidian-lsp")),
        jp("version", js("0.1.0"))
    )

    # Result
    jo2(jp("capabilities", capabilities), jp("serverInfo", server_info))

# ---------------------------------------------------------------------------
# Message dispatch
# ---------------------------------------------------------------------------

struct DispatchResult:
    response: text
    should_exit: bool

fn dispatch_method(json_text: text) -> DispatchResult:
    val method = extract_method(json_text)
    val msg_id = extract_id(json_text)
    val params = extract_params(json_text)

    # --- Requests (have an id, expect a response) ---

    if method == "initialize":
        val result = handle_initialize(params)
        return DispatchResult(
            response: make_response(msg_id, result),
            should_exit: false
        )

    if method == "shutdown":
        rt_stderr_write("obsidian-lsp: shutdown requested\n")
        return DispatchResult(
            response: make_response(msg_id, jnull()),
            should_exit: false
        )

    if method == "textDocument/completion":
        val result = handle_completion(params)
        return DispatchResult(
            response: make_response(msg_id, result),
            should_exit: false
        )

    if method == "textDocument/hover":
        val result = handle_hover(params)
        return DispatchResult(
            response: make_response(msg_id, result),
            should_exit: false
        )

    if method == "textDocument/definition":
        val result = handle_definition(params)
        return DispatchResult(
            response: make_response(msg_id, result),
            should_exit: false
        )

    if method == "textDocument/semanticTokens/full":
        val result = handle_semantic_tokens_full(params)
        return DispatchResult(
            response: make_response(msg_id, result),
            should_exit: false
        )

    # --- Notifications (no id, no response expected) ---

    if method == "textDocument/didOpen":
        val uri = extract_td_uri(params)
        val text_content = extract_td_text(params)
        val version = extract_td_version(params)
        doc_store_open(uri, text_content, version)
        rt_stderr_write("obsidian-lsp: opened {uri}\n")
        # Publish diagnostics after open
        val diag_notif = publish_diagnostics(uri)
        return DispatchResult(response: diag_notif, should_exit: false)

    if method == "textDocument/didChange":
        val uri = extract_td_uri(params)
        val text_content = extract_content_changes_text(params)
        val version = extract_td_version(params)
        doc_store_change(uri, text_content, version)
        # Publish diagnostics after change
        val diag_notif = publish_diagnostics(uri)
        return DispatchResult(response: diag_notif, should_exit: false)

    if method == "textDocument/didClose":
        val uri = extract_td_uri(params)
        doc_store_close(uri)
        rt_stderr_write("obsidian-lsp: closed {uri}\n")
        val diag_notif = publish_empty_diagnostics(uri)
        return DispatchResult(response: diag_notif, should_exit: false)

    if method == "initialized":
        rt_stderr_write("obsidian-lsp: client initialized\n")
        return DispatchResult(response: "", should_exit: false)

    if method == "exit":
        rt_stderr_write("obsidian-lsp: exit\n")
        return DispatchResult(response: "", should_exit: true)

    # Unknown method
    if msg_id != "" and msg_id != "null":
        val err = make_error_response(msg_id, -32601, "Method not found: {method}")
        return DispatchResult(response: err, should_exit: false)

    DispatchResult(response: "", should_exit: false)
