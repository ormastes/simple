# Obsidian LSP — Entry Point
# Starts the Obsidian-flavored markdown LSP server.
#
# Usage:
#   bin/simple run examples/obsidian-search/src/main_lsp.spl
#
# Environment:
#   OBSIDIAN_VAULT_PATH — path to the Obsidian vault directory
#
# The server communicates over stdio using JSON-RPC 2.0 with
# Content-Length framing (standard LSP transport).

use src.lsp.lsp_server.{start_lsp_server}

fn main():
    start_lsp_server()
