app:
  name: "simple-restaurant"
  env: "development"
  secret_key: "${RESTAURANT_SECRET_KEY}"

server:
  listen: "0.0.0.0:3001"
  worker_count: 0

database:
  path: "restaurant.db"

session:
  store: "database"
  ttl_seconds: 86400
  cookie_name: "_restaurant_session"

assets:
  path: "public"
  fingerprint: false
