# 32-bit Width Support Library
#
# Wires RV32I decoder + runtime (memory, I/O, interrupts) into a
# complete 32-bit emulation environment. Provides a factory for creating
# fully configured Rv32Emulator instances.

use core.types.{IrTcTypeKind, GuestArch}
use core.ops.{IrTcOp}
use core.block.{IrTcModule, IrTcModuleMode}
use core.builder.{IrTcBuilder}
use guest.cpu_def.{GuestCpuDef, GuestState}
use guest.riscv.cpu32.{build_rv32_cpu_def}
use guest.riscv.decoder32.{Rv32Decoder}
use runtime.memory.{GuestMemory}
use runtime.io.{IoController, RiscvUartIO}
use runtime.interrupt.{InterruptController}
use rtl.types.{SimBackendKind, Rv32Checkpoint}
use rtl.sim_engine.{NativeRtlBackend, VerilatorRtkBackend}
use rtl.bridge.{RtlStateBridge}
use transform.irtc_to_guest.{IrtcToGuestAdapter}
use std.io_runtime.{time_now_micros}

# ============================================================================
# Width32 Library
# ============================================================================

class Width32Lib:
    """32-bit width support library for RISC-V RV32I architecture.

    Provides factory methods and configuration for complete 32-bit
    emulation environments.
    """
    cpu_def: GuestCpuDef

impl Width32Lib:
    static fn new() -> Width32Lib:
        Width32Lib(cpu_def: build_rv32_cpu_def())

    fn word_size() -> i64:
        32

    fn arch() -> GuestArch:
        GuestArch.Riscv32

    fn create_rv32_emulator() -> Rv32Emulator:
        """Factory: create a fully wired RV32I emulation environment.

        Includes:
        - Guest CPU state (32 GPRs + PC + 9 CSRs)
        - 128MB flat memory (single address space)
        - I/O controller with QEMU virt UART
        - Interrupt controller
        - RV32I instruction decoder
        """
        val cpu_def = self.cpu_def
        val state = GuestState.new(cpu_def)
        val memory = GuestMemory.new(cpu_def)

        # Wire I/O devices
        var io = IoController.new()
        # QEMU virt machine UART at 0x10000000
        io.register_riscv_uart(0x10000000, RiscvUartIO.new())

        val interrupt = InterruptController.new(GuestArch.Riscv32)

        # Keep a decoder instance for structural compatibility; execution now
        # rebuilds an IR_TC TB per step and applies it through the transform path.
        var builder = IrTcBuilder.new("rv32_tb", IrTcModuleMode.Emulation)
        val decoder = Rv32Decoder(builder: builder, cpu_def: cpu_def)

        Rv32Emulator(
            cpu_def: cpu_def,
            state: state,
            memory: memory,
            decoder: decoder,
            io: io,
            interrupt: interrupt,
            cycle_count: 0,
            halted: false
        )

    fn create_rv32_rtl_sim() -> Rv32RtlSimulator:
        """Factory: create RV32I simulator with native RTL-style observability."""
        val emu = self.create_rv32_emulator()
        Rv32RtlSimulator(
            emulator: emu,
            rtl: NativeRtlBackend.new(),
            bridge: RtlStateBridge.new(),
            last_inst_word: 0
        )

    fn create_rv32_sim(backend: SimBackendKind) -> Rv32Simulator:
        """Factory: create a unified RV32 simulator facade."""
        Rv32Simulator(
            backend_kind: backend,
            fast: self.create_rv32_emulator(),
            rtl: self.create_rv32_rtl_sim(),
            verilator: VerilatorRtkBackend.detect_default(),
            bridge: RtlStateBridge.new()
        )

# ============================================================================
# RV32 Emulator
# ============================================================================

class Rv32Emulator:
    """Complete RV32I emulation environment.

    Combines guest state, memory, decoder, I/O, and interrupts into
    a single step-able emulation engine.
    """
    cpu_def: GuestCpuDef
    state: GuestState
    memory: GuestMemory
    decoder: Rv32Decoder
    io: IoController
    interrupt: InterruptController
    cycle_count: i64
    halted: bool

impl Rv32Emulator:
    me step() -> i64:
        """Execute one RV32I instruction.

        Returns the number of cycles consumed (1 per instruction).
        Fetches a 32-bit instruction word from memory at the current PC,
        decodes and applies it to the guest state.
        """
        if self.halted:
            return 0

        # Check and deliver pending interrupts
        self.state = self.interrupt.deliver_riscv(self.state)

        val pc = self.state.pc

        # Fetch 32-bit instruction from memory (little-endian)
        val b0 = self.memory.read_byte(pc) & 0xFF
        val b1 = self.memory.read_byte(pc + 1) & 0xFF
        val b2 = self.memory.read_byte(pc + 2) & 0xFF
        val b3 = self.memory.read_byte(pc + 3) & 0xFF
        val inst_word = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

        # Decode into a single-instruction TB and execute it through the IR_TC
        # guest-state transform path so fast mode shares the same IR boundary.
        var builder = IrTcBuilder.new("rv32_tb", IrTcModuleMode.Emulation)
        builder.set_target(GuestArch.Riscv32)
        builder.begin_function("tb", [], IrTcTypeKind.Void)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val decoder = Rv32Decoder(builder: builder, cpu_def: self.cpu_def)
        val result = decoder.decode_instruction(inst_word, pc)
        match result:
            Ok(bytes_consumed):
                val module = builder.finish()
                var adapter = IrtcToGuestAdapter.new()
                self.state = adapter.apply_to_state_with_memory(module, self.state, self.memory)
                if self.state.pc == pc:
                    self.state.pc = pc + bytes_consumed
                self.cycle_count = self.cycle_count + 1
                1
            Err(_):
                # Unknown instruction: halt
                self.halted = true
                0

    me run(max_cycles: i64):
        """Run the RV32I emulator until halted or max_cycles reached."""
        var remaining = max_cycles
        while not self.halted:
            if remaining <= 0:
                return
            val cycles = self.step()
            if cycles == 0:
                return
            remaining = remaining - cycles

    me load_program(data: [i64]):
        """Load a program into memory at the reset address (0x80000000).

        Data is an array of bytes to be placed starting at 0x80000000.
        """
        val base = 0x80000000
        for i in 0..data.len():
            self.memory.write_byte(base + i, data[i] & 0xFF)

    me load_program_at(addr: i64, data: [i64]):
        """Load a program into memory at a specific address."""
        for i in 0..data.len():
            self.memory.write_byte(addr + i, data[i] & 0xFF)

    me reset():
        """Reset the RV32I to initial state.

        Sets PC to 0x80000000 (QEMU virt machine RAM base).
        """
        self.state = GuestState.new(self.cpu_def)
        self.state.pc = 0x80000000
        self.cycle_count = 0
        self.halted = false

    fn get_reg(name: text) -> i64?:
        """Read a register by name (e.g., "a0", "sp", "pc", "mstatus")."""
        if name == "pc":
            return Some(self.state.pc)
        self.state.get_reg_by_name(name)

    me set_reg(name: text, value: i64) -> bool:
        """Write a register by name."""
        if name == "pc":
            self.state.pc = value
            return true
        self.state.set_reg_by_name(name, value)

    fn stats_text() -> text:
        """Return emulation statistics as text."""
        "RV32I: {self.cycle_count} cycles, PC=0x{self.state.pc}, halted={self.halted}"

    fn checkpoint() -> Rv32Checkpoint:
        Rv32Checkpoint.from_state(self.state, self.memory.memory, self.memory.read_count, self.memory.write_count, self.cycle_count, self.halted)

    me restore(checkpoint: Rv32Checkpoint):
        self.state.reg_values = checkpoint.reg_values
        self.state.pc = checkpoint.pc
        self.memory.memory = checkpoint.memory
        self.memory.read_count = checkpoint.read_count
        self.memory.write_count = checkpoint.write_count
        self.cycle_count = checkpoint.cycle_count
        self.halted = checkpoint.halted

# ============================================================================
# RV32 Native RTL Simulator
# ============================================================================

class Rv32RtlSimulator:
    """RV32I emulator wrapped with a native RTL-style signal surface."""
    emulator: Rv32Emulator
    rtl: NativeRtlBackend
    bridge: RtlStateBridge
    last_inst_word: i64

impl Rv32RtlSimulator:
    me step() -> i64:
        """Execute one architectural step and update visible RTL signals."""
        val pc_before = self.emulator.state.pc
        val inst_word = self.emulator.memory.read32(pc_before)
        self.last_inst_word = inst_word

        self.rtl.begin_cycle(self.emulator.cycle_count + 1)
        val start_us = time_now_micros()

        val cycles = self.emulator.step()
        val end_us = time_now_micros()
        self._sync_signals()
        self.rtl.record_host_time_ns((end_us - start_us) * 1000)
        self.rtl.sample_all()
        cycles

    me run(max_cycles: i64):
        var remaining = max_cycles
        while not self.emulator.halted:
            if remaining <= 0:
                return
            val used = self.step()
            if used == 0:
                return
            remaining = remaining - used

    me load_program(data: [i64]):
        self.emulator.load_program(data)
        self._sync_signals()

    me load_program_at(addr: i64, data: [i64]):
        self.emulator.load_program_at(addr, data)
        self._sync_signals()

    me reset():
        self.emulator.reset()
        self.last_inst_word = 0
        self._sync_signals()

    fn get_reg(name: text) -> i64?:
        self.emulator.get_reg(name)

    me set_reg(name: text, value: i64) -> bool:
        val ok = self.emulator.set_reg(name, value)
        self._sync_signals()
        ok

    me enable_trace():
        self.rtl.enable_trace()

    me disable_trace():
        self.rtl.disable_trace()

    fn read_signal(name: text) -> i64?:
        self.rtl.read_signal(name)

    fn waveform_text() -> text:
        self.rtl.waveform_text()

    fn stats_text() -> text:
        self.rtl.stats(self.checkpoint()).to_text()

    fn checkpoint() -> Rv32Checkpoint:
        self.bridge.make_checkpoint(self.emulator.state, self.emulator.memory, self.emulator.cycle_count, self.emulator.halted)

    me restore(checkpoint: Rv32Checkpoint):
        self.emulator.restore(checkpoint)
        self._sync_signals()

    me _sync_signals():
        val checkpoint = self.checkpoint()
        var a0_value: i64 = 0
        var sp_value: i64 = 0
        if val Some(a0) = self.emulator.get_reg("a0"):
            a0_value = a0
        if val Some(sp) = self.emulator.get_reg("sp"):
            sp_value = sp
        self.rtl.refresh(checkpoint, a0_value, sp_value, self.last_inst_word, self.emulator.memory.read_count, self.emulator.memory.write_count)

# ============================================================================
# Unified RV32 Simulator Facade
# ============================================================================

class Rv32Simulator:
    backend_kind: SimBackendKind
    fast: Rv32Emulator
    rtl: Rv32RtlSimulator
    verilator: VerilatorRtkBackend
    bridge: RtlStateBridge

impl Rv32Simulator:
    me step() -> i64:
        match self.backend_kind:
            SimBackendKind.FastIrTc: self.fast.step()
            SimBackendKind.NativeRtl: self.rtl.step()
            SimBackendKind.RtkVerilator:
                val start_us = time_now_micros()
                val checkpoint = self.checkpoint()
                val inst_word = self._current_inst_word()
                self.verilator.prepare_run(checkpoint, 1, inst_word)
                val returned = self.verilator.consume_result(checkpoint)
                self.restore(returned)
                self.verilator.refresh(returned)
                val end_us = time_now_micros()
                self.verilator.record_host_time_ns((end_us - start_us) * 1000)
                0

    me run(max_cycles: i64):
        match self.backend_kind:
            SimBackendKind.FastIrTc: self.fast.run(max_cycles)
            SimBackendKind.NativeRtl: self.rtl.run(max_cycles)
            SimBackendKind.RtkVerilator:
                val start_us = time_now_micros()
                var remaining = max_cycles
                while remaining > 0:
                    val checkpoint = self.checkpoint()
                    if checkpoint.halted:
                        break
                    val inst_word = self._current_inst_word()
                    self.verilator.prepare_run(checkpoint, 1, inst_word)
                    val returned = self.verilator.consume_result(checkpoint)
                    self.restore(returned)
                    self.verilator.refresh(returned)
                    remaining = remaining - 1
                val end_us = time_now_micros()
                self.verilator.record_host_time_ns((end_us - start_us) * 1000)

    me load_program(data: [i64]):
        self.fast.load_program(data)
        self.rtl.load_program(data)
        self.verilator.refresh(self.checkpoint())

    me load_program_at(addr: i64, data: [i64]):
        self.fast.load_program_at(addr, data)
        self.rtl.load_program_at(addr, data)
        self.verilator.refresh(self.checkpoint())

    me reset():
        self.fast.reset()
        self.rtl.reset()
        self.verilator.refresh(self.checkpoint())

    fn get_reg(name: text) -> i64?:
        match self.backend_kind:
            SimBackendKind.FastIrTc: self.fast.get_reg(name)
            SimBackendKind.NativeRtl: self.rtl.get_reg(name)
            SimBackendKind.RtkVerilator: self.fast.get_reg(name)

    me set_reg(name: text, value: i64) -> bool:
        val ok_fast = self.fast.set_reg(name, value)
        self.rtl.set_reg(name, value)
        self.verilator.refresh(self.checkpoint())
        ok_fast

    fn read_signal(name: text) -> i64?:
        match self.backend_kind:
            SimBackendKind.FastIrTc: nil
            SimBackendKind.NativeRtl: self.rtl.read_signal(name)
            SimBackendKind.RtkVerilator: self.verilator.read_signal(name)

    fn waveform_text() -> text:
        match self.backend_kind:
            SimBackendKind.FastIrTc: ""
            SimBackendKind.NativeRtl: self.rtl.waveform_text()
            SimBackendKind.RtkVerilator: ""

    fn checkpoint() -> Rv32Checkpoint:
        match self.backend_kind:
            SimBackendKind.FastIrTc: self.fast.checkpoint()
            SimBackendKind.NativeRtl: self.rtl.checkpoint()
            SimBackendKind.RtkVerilator: self.fast.checkpoint()

    me restore(checkpoint: Rv32Checkpoint):
        self.fast.restore(checkpoint)
        self.rtl.restore(checkpoint)
        self.verilator.refresh(checkpoint)

    me select_backend(backend: SimBackendKind):
        if backend == self.backend_kind:
            return
        val checkpoint = self.checkpoint()
        self.restore(checkpoint)
        self.backend_kind = backend

    fn stats_text() -> text:
        match self.backend_kind:
            SimBackendKind.FastIrTc: self.fast.stats_text()
            SimBackendKind.NativeRtl: self.rtl.stats_text()
            SimBackendKind.RtkVerilator: self.verilator.stats(self.checkpoint()).to_text()

    fn _current_inst_word() -> i64:
        val checkpoint = self.checkpoint()
        self.fast.memory.read32(checkpoint.pc)
