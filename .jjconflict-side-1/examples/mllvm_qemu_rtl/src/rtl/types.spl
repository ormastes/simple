# RTL Types
#
# Entity-dimension contracts shared between fast IR_TC execution and RTL/RTK
# execution backends.

use guest.cpu_def.{GuestState}

enum SimBackendKind:
    FastIrTc
    NativeRtl
    RtkVerilator

impl SimBackendKind:
    fn to_text() -> text:
        match self:
            FastIrTc: "fast-irtc"
            NativeRtl: "native-rtl"
            RtkVerilator: "rtk-verilator"

struct Rv32Checkpoint:
    """Architecture checkpoint shared across simulator backends."""
    reg_values: [i64]
    pc: i64
    memory: [i64]
    read_count: i64
    write_count: i64
    cycle_count: i64
    halted: bool

impl Rv32Checkpoint:
    static fn from_state(state: GuestState, memory: [i64], read_count: i64, write_count: i64, cycle_count: i64, halted: bool) -> Rv32Checkpoint:
        Rv32Checkpoint(
            reg_values: state.reg_values,
            pc: state.pc,
            memory: memory,
            read_count: read_count,
            write_count: write_count,
            cycle_count: cycle_count,
            halted: halted
        )

struct VerilatorBackendConfig:
    executable: text
    runner_path: text
    work_dir: text
    top_module: text
    top_source: text
    trace_path: text

impl VerilatorBackendConfig:
    static fn new(executable: text, runner_path: text, work_dir: text, top_module: text, top_source: text, trace_path: text) -> VerilatorBackendConfig:
        VerilatorBackendConfig(
            executable: executable,
            runner_path: runner_path,
            work_dir: work_dir,
            top_module: top_module,
            top_source: top_source,
            trace_path: trace_path
        )

    fn to_text() -> text:
        "exe={self.executable} runner={self.runner_path} top={self.top_module} top_source={self.top_source} workdir={self.work_dir} trace={self.trace_path}"

struct BackendRunStats:
    """Common run statistics surface for fast and RTL modes."""
    backend: SimBackendKind
    cycle_count: i64
    signal_count: i64
    trace_count: i64
    halted: bool
    has_host_time_ns: bool
    host_time_ns: i64
    note: text

impl BackendRunStats:
    static fn new(backend: SimBackendKind, cycle_count: i64, signal_count: i64, trace_count: i64, halted: bool, note: text) -> BackendRunStats:
        BackendRunStats(
            backend: backend,
            cycle_count: cycle_count,
            signal_count: signal_count,
            trace_count: trace_count,
            halted: halted,
            has_host_time_ns: false,
            host_time_ns: 0,
            note: note
        )

    fn with_host_time(host_time_ns: i64) -> BackendRunStats:
        BackendRunStats(..self, has_host_time_ns: true, host_time_ns: host_time_ns)

    fn to_text() -> text:
        var out = "backend={self.backend.to_text()} cycles={self.cycle_count} halted={self.halted}"
        out = out + " signals={self.signal_count} trace={self.trace_count}"
        if self.has_host_time_ns:
            out = out + " host_ns={self.host_time_ns}"
        if self.note != "":
            out = out + " note={self.note}"
        out
