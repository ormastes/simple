# RISC-V 32-bit Guest CPU Definition
#
# RV32I base integer ISA
# - 32 x 32-bit general purpose registers (x0-x31, x0 hardwired to 0)
# - 32-bit program counter (PC)
# - No flags register (RISC-V uses compare-and-branch)
# - 9 M-mode CSRs for interrupt handling
# - Little-endian, flat address space

use core.types.{GuestArch}
use core.mem_op.{Endian, GuestRegId, ADDR_SPACE_DEFAULT}
use guest.cpu_def.{GuestCpuDef, GuestRegDef, GuestRegAlias, AddrSpaceDef}
use guest.riscv.common.{
    RV_REG_PC, RV_CSR_MSTATUS, RV_CSR_MTVEC, RV_CSR_MEPC,
    RV_CSR_MCAUSE, RV_CSR_MTVAL, RV_CSR_MIE, RV_CSR_MIP,
    RV_CSR_MSCRATCH, RV_CSR_MHARTID, RV_TOTAL_REGS, rv_gpr_name
}

# ============================================================================
# RV32I CPU Definition Builder
# ============================================================================

fn build_rv32_cpu_def() -> GuestCpuDef:
    """Build the complete RV32I CPU definition.

    Registers:
        [0..31]  x0-x31: 32-bit general purpose registers (x0 hardwired to 0)
        [32]     PC: 32-bit program counter
        [33..41] M-mode CSRs: mstatus, mtvec, mepc, mcause, mtval, mie, mip, mscratch, mhartid
    """
    var registers: [GuestRegDef] = []

    # x0-x31: 32-bit general purpose registers
    for i in 0..32:
        val reg_id = GuestRegId.new(GuestArch.Riscv32, i, rv_gpr_name(i))
        registers.push(GuestRegDef.new(reg_id, 32))

    # PC: 32-bit program counter
    val pc_id = GuestRegId.new(GuestArch.Riscv32, RV_REG_PC, "pc")
    registers.push(GuestRegDef.new(pc_id, 32))

    # M-mode CSRs: 32-bit each
    val csr_names = ["mstatus", "mtvec", "mepc", "mcause", "mtval", "mie", "mip", "mscratch", "mhartid"]
    val csr_indices = [RV_CSR_MSTATUS, RV_CSR_MTVEC, RV_CSR_MEPC, RV_CSR_MCAUSE, RV_CSR_MTVAL, RV_CSR_MIE, RV_CSR_MIP, RV_CSR_MSCRATCH, RV_CSR_MHARTID]
    for i in 0..csr_names.len():
        val csr_id = GuestRegId.new(GuestArch.Riscv32, csr_indices[i], csr_names[i])
        registers.push(GuestRegDef.new(csr_id, 32))

    # sp_reg is x2
    val sp_id = GuestRegId.new(GuestArch.Riscv32, 2, "sp")

    # Single flat address space (no Harvard, no segmentation)
    val addr_spaces = [
        AddrSpaceDef.new(ADDR_SPACE_DEFAULT, "memory", 32, 134217728)  # 128MB practical limit
    ]

    GuestCpuDef(
        name: "riscv32",
        arch: GuestArch.Riscv32,
        word_size: 32,
        endian: Endian.Little,
        registers: registers,
        pc_reg: pc_id,
        sp_reg: Some(sp_id),
        flags_reg: nil,         # RISC-V has no flags register
        addr_spaces: addr_spaces
    )
