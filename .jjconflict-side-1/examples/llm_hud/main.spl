use std.nogc_async_mut.concurrent.thread.{thread_sleep}
use examples.llm_hud.src.collect.{parse_options, collect_state}
use examples.llm_hud.src.render.{render_output, help_text}
use examples.llm_hud.src.types.{HudOptions}

fn main() -> i64:
    val options = parse_options()
    if options.help:
        print help_text()
        return 0

    if options.watch:
        return run_watch_loop(options)

    val state = collect_state(options)
    print render_output(state, options)
    0

fn run_watch_loop(options: HudOptions) -> i64:
    while true:
        val state = collect_state(options)
        print ""
        print "----- llm hud refresh -----"
        print render_output(state, options)
        thread_sleep(options.interval_ms)
    0
