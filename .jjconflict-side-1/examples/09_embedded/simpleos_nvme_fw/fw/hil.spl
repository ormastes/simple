"""
hil — Host Interface Layer.

The NVMe controller front end: fetch a command from the submission queue, validate
it, drive it through the FTL behind a generation-handle task context (the cooperative
write-task state machine), and post a completion to the completion queue.

Composes hil_queue (SQ/CQ rings) + hil_command (decode/validate) + fw_pool (task
contexts) + ftl (the translation layer).
"""

use nvme_types.*
use hil_queue.*
use hil_command.*
use fw_pool.*
use ftl.*
use dram.*

struct Hil:
    q:    NvmeQueues
    ftl:  Ftl
    pool: TaskPool
    wb:   DramWriteBuffer

fn hil_new() -> Hil:
    Hil(q: nvme_queues_new(), ftl: ftl_new(), pool: task_pool_new(), wb: dram_write_buffer_new())

impl Hil:
    # Host submits a command to the submission queue. False if the SQ is full.
    me submit(c: NvmeCmd) -> bool:
        me.q.sq_submit(c)

    # Process one pending submission-queue command end-to-end. Returns 1 if a
    # command was handled, 0 if the SQ was empty.
    me tick() -> i64:
        val pend: i64 = me.q.sq_pending()
        if pend == 0:
            return 0
        if not me.q.sq_can_fetch():
            return 0
        if me.q.cq_is_full():
            return 0
        val cmd: NvmeCmd = me.q.sq_fetch()
        var status: i64 = cmd_validate(cmd)
        var rdata: i64 = 0
        if status == SC_SUCCESS:
            if cmd_is_write(cmd) or cmd_is_write_zero(cmd):
                # Drive the write behind a generation-handle task context.
                val h: Handle = me.pool.acquire(cmd.cid, cmd.lba, cmd.nblocks, cmd.data)
                if not me.pool.valid(h):
                    status = SC_NS_NOT_READY
                me.pool.set_phase(h, PH_PROGRAM)
                var i: i64 = 0
                val span: DramSpan = me.wb.alloc(cmd.nblocks)
                if not span.ok:
                    status = SC_NS_NOT_READY
                if status == SC_SUCCESS and not me.ftl.can_write_blocks(cmd.nblocks):
                    status = SC_NS_NOT_READY
                while i < cmd.nblocks and status == SC_SUCCESS:
                    status = me.wb.stage(span, i, host_write_byte(cmd, i))
                    i = i + 1
                i = 0
                while i < cmd.nblocks and status == SC_SUCCESS:
                    status = me.ftl.write(cmd.lba + i, me.wb.byte(span, i))
                    i = i + 1
                me.wb.release(span)
                me.pool.set_status(h, status)
                me.pool.set_phase(h, PH_DONE)
                me.pool.release(h)
            else:
                if cmd_is_read(cmd):
                    status = me.ftl.read_range_status(cmd.lba, cmd.nblocks)
                    if status == SC_SUCCESS:
                        rdata = me.ftl.read(cmd.lba)
                else:
                    if cmd_is_trim(cmd):
                        var i: i64 = 0
                        while i < cmd.nblocks and status == SC_SUCCESS:
                            status = me.ftl.trim(cmd.lba + i)
                            i = i + 1
                    else:
                        if cmd_is_flush(cmd):
                            me.ftl.checkpoint()
                            status = SC_SUCCESS
                        else:
                            status = SC_INVALID_OPCODE
        me.q.cq_post(cpl_make(cmd.cid, status, rdata))
        1

    # Drain every pending submission-queue command.
    me run() -> i64:
        var n: i64 = 0
        var pend: i64 = me.q.sq_pending()
        while pend > 0:
            val handled: i64 = me.tick()
            if handled == 0:
                return n
            n = n + handled
            pend = me.q.sq_pending()
        n

    # Host reaps the next completion (caller checks completions() first).
    me reap() -> NvmeCpl:
        me.q.cq_reap()

    me completions() -> i64:
        me.q.cq_pending()

    me pending() -> i64:
        me.q.sq_pending()

    # Trigger one GC pass (background maintenance). Returns reclaimed block or UNMAP.
    me gc() -> i64:
        me.ftl.gc_once()

    me free_blocks() -> i64:
        me.ftl.free_blocks()

    me checkpoint():
        me.ftl.checkpoint()

    # Simulate a dirty shutdown + power-on recovery of the translation layer.
    me crash():
        me.ftl.crash()

    me recover():
        me.ftl.recover()

# ── Self-test ─────────────────────────────────────────────────────────────────

fn hil_selftest() -> i64:
    var fail: i64 = 0
    var hil: Hil = hil_new()

    # write LBA 30 = 0x7E, then read it back via the queues
    var ok: bool = hil.submit(cmd_make(1, OP_WRITE, 30, 1, 0x7E))
    var sub: i64 = 0
    if ok:
        sub = 1
    fail = fail + expect_eq(sub, 1, "submit write accepted")
    hil.submit(cmd_make(2, OP_READ, 30, 1, 0))
    val n: i64 = hil.run()
    fail = fail + expect_eq(n, 2, "processed 2 commands")
    fail = fail + expect_eq(hil.completions(), 2, "2 completions queued")

    val c1: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c1.cid, 1, "cpl1 is the write (FIFO)")
    fail = fail + expect_eq(c1.status, SC_SUCCESS, "write completed SC_SUCCESS")
    val c2: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c2.cid, 2, "cpl2 is the read")
    fail = fail + expect_eq(c2.status, SC_SUCCESS, "read completed SC_SUCCESS")
    fail = fail + expect_eq(c2.data, 0x7E, "read returns the written byte")

    # Multi-block write pulls distinct bytes from the simulated PRP stream.
    hil.submit(cmd_make(21, OP_WRITE, 40, 3, prp_pack(0x20, 0x90)))
    hil.run()
    val c21: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c21.status, SC_SUCCESS, "multi-block write completed")
    hil.submit(cmd_make(22, OP_READ, 40, 1, 0))
    hil.submit(cmd_make(23, OP_READ, 41, 1, 0))
    hil.submit(cmd_make(24, OP_READ, 42, 1, 0))
    hil.run()
    val c22: NvmeCpl = hil.reap()
    val c23: NvmeCpl = hil.reap()
    val c24: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c22.data, 0x20, "multi-block read byte 0")
    fail = fail + expect_eq(c23.data, 0x21, "multi-block read byte 1")
    fail = fail + expect_eq(c24.data, 0x90, "multi-block read byte 2")

    hil.submit(cmd_make(29, OP_WRITE_ZERO, 40, 3, 0))
    hil.run()
    val c29: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c29.status, SC_SUCCESS, "write-zero completed")
    hil.submit(cmd_make(30, OP_READ, 41, 1, 0))
    hil.run()
    val c30: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c30.data, 0, "write-zero clears written LBA")

    # Oversized writes fail before any partial media update.
    hil.submit(cmd_make(25, OP_WRITE, 80, WRITE_BUFFER_CAP_BLOCKS + 1, 0x40))
    hil.run()
    val c25: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c25.status, SC_NS_NOT_READY, "oversized write buffer command rejected")
    hil.submit(cmd_make(26, OP_READ, 80, 1, 0))
    hil.run()
    val c26: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c26.data, 0, "oversized write leaves first LBA untouched")

    hil.ftl.band.active_blk = 0
    hil.ftl.band.blk_state[0] = BLK_OPEN
    hil.ftl.band.active_wp = PAGES_PER_BLOCK - 1
    hil.ftl.band.free_count = GC_RESERVE
    hil.submit(cmd_make(27, OP_WRITE, 82, 2, prp_pack(0x55, 0x66)))
    hil.run()
    val c27: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c27.status, SC_NS_NOT_READY, "write rejected when media cannot fit whole command")
    hil.submit(cmd_make(28, OP_READ, 82, 1, 0))
    hil.run()
    val c28: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c28.data, 0, "media-capacity rejection leaves first LBA untouched")

    val saved_hil_cq_tail: i64 = hil.q.cq_tail
    hil.q.cq_tail = hil.q.depth
    hil.submit(cmd_make(34, OP_READ, 30, 1, 0))
    fail = fail + expect_eq(hil.tick(), 0, "HIL tick backs off on invalid CQ tail")
    fail = fail + expect_eq(hil.pending(), 1, "HIL preserves command behind invalid CQ tail")
    hil.q.cq_tail = saved_hil_cq_tail
    fail = fail + expect_eq(hil.run(), 1, "HIL drains command after CQ tail repair")
    hil.reap()

    val saved_hil_cq_head: i64 = hil.q.cq_head
    hil.q.cq_head = hil.q.depth
    hil.submit(cmd_make(35, OP_READ, 30, 1, 0))
    fail = fail + expect_eq(hil.run(), 0, "HIL run backs off on invalid CQ head")
    fail = fail + expect_eq(hil.pending(), 1, "HIL preserves command behind invalid CQ head")
    hil.q.cq_head = saved_hil_cq_head
    fail = fail + expect_eq(hil.run(), 1, "HIL drains command after CQ head repair")
    hil.reap()

    val saved_hil_sq_head: i64 = hil.q.sq_head
    hil.q.sq_head = hil.q.depth
    hil.submit(cmd_make(36, OP_READ, 30, 1, 0))
    fail = fail + expect_eq(hil.run(), 0, "HIL run backs off on invalid SQ head")
    fail = fail + expect_eq(hil.pending(), 1, "HIL preserves command behind invalid SQ head")
    hil.q.sq_head = saved_hil_sq_head
    fail = fail + expect_eq(hil.run(), 1, "HIL drains command after SQ head repair")
    hil.reap()

    # out-of-range write is rejected by validation
    hil.submit(cmd_make(3, OP_WRITE, LBA_COUNT + 5, 1, 0))
    hil.run()
    val c3: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c3.status, SC_LBA_RANGE, "out-of-range write -> SC_LBA_RANGE")

    hil.submit(cmd_make_nsid(37, 0, OP_READ, 30, 1, 0))
    hil.run()
    val c37: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c37.status, SC_INVALID_FIELD, "invalid IO namespace -> SC_INVALID_FIELD")

    # a malformed command never crashes the controller: an i64-overflow lba/nblocks is
    # rejected with SC_LBA_RANGE and still produces a completion the host can reap.
    hil.submit(cmd_make(31, OP_WRITE, FW_OVERFLOW_TEST_SIZE, FW_OVERFLOW_TEST_SIZE, 0))
    hil.run()
    val c31: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c31.status, SC_LBA_RANGE, "overflow command rejected, completion posted (no crash)")

    # an unknown opcode is rejected with SC_INVALID_OPCODE (not SC_INTERNAL).
    hil.submit(cmd_make(32, 0x7F, 0, 1, 0))
    hil.run()
    val c32: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c32.status, SC_INVALID_OPCODE, "unknown opcode -> SC_INVALID_OPCODE")

    # multi-block trim then read -> 0 across the whole range
    hil.submit(cmd_make(33, OP_WRITE, 30, 2, prp_pack(0x44, 0x54)))
    hil.run()
    hil.reap()
    hil.submit(cmd_make(4, OP_DSM_TRIM, 30, 2, 0))
    hil.submit(cmd_make(5, OP_READ, 30, 1, 0))
    hil.submit(cmd_make(6, OP_READ, 31, 1, 0))
    hil.run()
    val c4: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c4.status, SC_SUCCESS, "trim completed")
    val c5: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c5.data, 0, "read after trim -> 0")
    val c6: NvmeCpl = hil.reap()
    fail = fail + expect_eq(c6.data, 0, "read second block after trim -> 0")

    fail
