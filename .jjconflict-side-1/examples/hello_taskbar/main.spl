# hello_taskbar — Wave 6 demo content
#
# Minimal HTML body the Simple Web Engine can render inside a rect
# supplied by the compositor (host wm_bridge path or SimpleOS
# COMP_CREATE_WEB_WINDOW path). Kept intentionally within the engine's
# current capabilities: basic HTML + inline CSS, no tables, no flex,
# no JS, no web fonts.

fn hello_html() -> text:
    "<!doctype html>" +
    "<html><head><meta charset='utf-8'>" +
    "<title>Hello Taskbar</title>" +
    "<style>" +
    "body { margin: 0; padding: 24px; background: #0b0f1a; color: #e4eefc;" +
    " font-family: monospace; }" +
    "h1 { margin: 0 0 12px 0; font-size: 22px; }" +
    "p  { margin: 0; font-size: 14px; opacity: 0.8; }" +
    "</style></head>" +
    "<body>" +
    "<h1>Hello from the taskbar shell</h1>" +
    "<p>Rendered by the Simple Web Engine &mdash; same content on host and SimpleOS.</p>" +
    "</body></html>"

fn hello_title() -> text:
    "Hello Taskbar"

fn hello_size_width()  -> i32: 480
fn hello_size_height() -> i32: 240
