#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# DOM attribute types for element attribute storage and token lists.
# Attr represents a single name-value pair with optional namespace.
# NamedNodeMap and DOMTokenList provide collection wrappers.

class Attr:
    name: text
    value: text
    ns: text

    static fn create(name: text, value: text) -> Attr:
        Attr(name: name, value: value, ns: "")

    static fn with_ns(name: text, value: text, ns: text) -> Attr:
        Attr(name: name, value: value, ns: ns)

class NamedNodeMap:
    attrs: [Attr]

    static fn empty() -> NamedNodeMap:
        NamedNodeMap(attrs: [Attr]())

class DOMTokenList:
    tokens: [text]

    static fn empty() -> DOMTokenList:
        DOMTokenList(tokens: [text]())
