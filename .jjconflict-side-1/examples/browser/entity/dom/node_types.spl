#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Core DOM node types representing the document object model tree.
# Nodes are identified by integer IDs; parent/child relationships use ID references.

enum NodeKind:
    Document
    Element
    Text
    Comment
    DocumentFragment
    Attribute

class DomNode:
    id: i64
    kind: NodeKind
    parent_id: i64
    children: [i64]
    data: text

    static fn create(id: i64, kind: NodeKind, parent_id: i64, data: text) -> DomNode:
        DomNode(id: id, kind: kind, parent_id: parent_id, children: [i64](), data: data)

class Element:
    node_id: i64
    tag_name: text
    attributes: [Attr]
    ns: text

    static fn create(node_id: i64, tag_name: text, ns: text) -> Element:
        Element(node_id: node_id, tag_name: tag_name, attributes: [Attr](), ns: ns)

class TextNode:
    node_id: i64
    content: text

    static fn create(node_id: i64, content: text) -> TextNode:
        TextNode(node_id: node_id, content: content)

class Comment:
    node_id: i64
    content: text

    static fn create(node_id: i64, content: text) -> Comment:
        Comment(node_id: node_id, content: content)

class DocumentFragment:
    node_id: i64
    children: [i64]

    static fn create(node_id: i64) -> DocumentFragment:
        DocumentFragment(node_id: node_id, children: [i64]())
