# Image types for decoded image data and animated frame sequences.
# Supports common web image formats.

use std.common.color.types.{Color, from_rgba}

enum ImageFormat:
    Png
    Jpeg
    Gif
    Webp
    Svg
    Bmp
    Ico

class ImageData:
    width: i64
    height: i64
    format: ImageFormat
    data: [i64]

    static fn create(width: i64, height: i64, format: ImageFormat) -> ImageData:
        ImageData(width: width, height: height, format: format, data: [i64]())

    fn get_pixel(x: i64, y: i64) -> Color:
        val idx = (y * self.width + x) * 4
        if idx + 3 < self.data.length():
            return from_rgba(self.data[idx], self.data[idx + 1], self.data[idx + 2], self.data[idx + 3])
        from_rgba(0, 0, 0, 0)

    me set_pixel(x: i64, y: i64, color: Color):
        val idx = (y * self.width + x) * 4
        if idx + 3 < self.data.length():
            self.data[idx] = color.r
            self.data[idx + 1] = color.g
            self.data[idx + 2] = color.b
            self.data[idx + 3] = color.a

class DecodedFrame:
    image: ImageData
    duration_ms: i64
    frame_index: i64

    static fn create(image: ImageData, duration_ms: i64, frame_index: i64) -> DecodedFrame:
        DecodedFrame(image: image, duration_ms: duration_ms, frame_index: frame_index)
