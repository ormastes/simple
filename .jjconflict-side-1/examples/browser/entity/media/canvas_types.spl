# Canvas 2D types for the HTML Canvas API.
# Models drawing operations, paths, and rendering context state.
#
# CanvasContext is a software-model of the Canvas 2D state machine. GPU acceleration
# (sprite batching, path tessellation, texture atlas) is deferred to a future integration
# with feature/gpu/graphics.spl.
#
# CanvasOp uses text for color strings (e.g. "#000000") matching the HTML Canvas API surface.
# Use parse_canvas_color() to convert to a typed Color when interfacing with the paint pipeline.
# Point coordinates are inlined as (x,y) f64 pairs to match Canvas 2D API conventions directly.

use std.common.color.types.{Color, from_rgba}
use std.common.color.convert.{from_hex}

# Parse a CSS color string (e.g. "#ff0000", "#rgb") into a typed Color.
# Returns opaque black for unrecognised values.
fn parse_canvas_color(color_str: text) -> Color:
    if color_str == "" or color_str == "transparent":
        return from_rgba(0, 0, 0, 0)
    if color_str.starts_with("#"):
        return from_hex(color_str)
    # Fallback — opaque black
    from_rgba(0, 0, 0, 255)

enum CanvasOp:
    MoveTo(x: f64, y: f64)
    LineTo(x: f64, y: f64)
    ArcTo(x: f64, y: f64, radius: f64)
    ClosePath
    Fill(color: text)
    Stroke(color: text, width: f64)
    FillText(text_content: text, x: f64, y: f64)
    DrawImage(id: i64, x: f64, y: f64, w: f64, h: f64)

class Path2D:
    ops: [CanvasOp]

    static fn empty() -> Path2D:
        Path2D(ops: [CanvasOp]())

class CanvasContext:
    width: i64
    height: i64
    ops: [CanvasOp]
    fill_style: text
    stroke_style: text
    line_width: f64

    static fn create(width: i64, height: i64) -> CanvasContext:
        CanvasContext(
            width: width, height: height,
            ops: [CanvasOp](),
            fill_style: "#000000",
            stroke_style: "#000000",
            line_width: 1.0
        )
