# Window types for browser window geometry and state.
# Models window position, size, and display modes.

class WindowGeometry:
    x: i64
    y: i64
    width: i64
    height: i64

    static fn create(x: i64, y: i64, width: i64, height: i64) -> WindowGeometry:
        WindowGeometry(x: x, y: y, width: width, height: height)

class BrowserWindow:
    id: i64
    geometry: WindowGeometry
    is_fullscreen: bool
    is_maximized: bool
    title: text

    static fn create(id: i64, geometry: WindowGeometry, title: text) -> BrowserWindow:
        BrowserWindow(
            id: id, geometry: geometry,
            is_fullscreen: false, is_maximized: false,
            title: title
        )
