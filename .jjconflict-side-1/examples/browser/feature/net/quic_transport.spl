#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

"""
QUIC transport — RFC 9000 connection model.
NewReno congestion control, three packet-number spaces, UDP-backed send/recv.
No TLS crypto — wire format model only.
"""

use examples.browser.entity.net.quic_types.{QuicConfig, QuicConnectionId, QuicPacketHeader, QuicCongestionState, QuicStream, QuicFrame}

extern fn rt_io_udp_bind(addr: text) -> i64
extern fn rt_io_udp_connect(fd: i64, addr: text) -> bool
extern fn rt_io_udp_send(fd: i64, data: [u8]) -> i64
extern fn rt_io_udp_recv(fd: i64, size: i64) -> [u8]
extern fn rt_io_udp_close(fd: i64) -> bool
extern fn rt_random_bytes(n: i64) -> [u8]

val QUIC_VERSION: i64 = 1
val QUIC_PMTU: i64 = 1472
val QUIC_INITIAL_CWND: i64 = 14720
val QUIC_MAX_CID_LEN: i64 = 20

class QuicConnection:
    """QUIC connection over UDP. Manages packet-number spaces and NewReno congestion."""
    config: QuicConfig
    local_cid: QuicConnectionId
    remote_cid: QuicConnectionId
    congestion: QuicCongestionState
    fd: i64
    connected: bool
    pn_initial: i64
    pn_handshake: i64
    pn_app: i64
    next_stream_id: i64

    static fn new(config: QuicConfig) -> QuicConnection:
        var empty_bytes: [u8] = []
        val empty_cid = QuicConnectionId.new(empty_bytes, 0)
        QuicConnection(
            config: config,
            local_cid: empty_cid,
            remote_cid: empty_cid,
            congestion: QuicCongestionState.new(),
            fd: -1,
            connected: false,
            pn_initial: 0,
            pn_handshake: 0,
            pn_app: 0,
            next_stream_id: 0
        )

    me connect(host: text, port: i64) -> bool:
        val addr = "{host}:{port}"
        val bind_fd = rt_io_udp_bind("0.0.0.0:0")
        if bind_fd < 0:
            return false
        self.fd = bind_fd
        val ok = rt_io_udp_connect(self.fd, addr)
        if not ok:
            return false
        self.local_cid = self.generate_connection_id(8)
        self.connected = true
        return true

    me send_packet(ptype: i64, payload: [u8]) -> bool:
        if not self.connected:
            return false
        val pn = self.next_packet_number_for(ptype)
        var wire: [u8] = []
        wire.push(ptype & 0xff)
        wire.push((QUIC_VERSION >> 24) & 0xff)
        wire.push((QUIC_VERSION >> 16) & 0xff)
        wire.push((QUIC_VERSION >> 8) & 0xff)
        wire.push(QUIC_VERSION & 0xff)
        wire.push(self.local_cid.length & 0xff)
        var ci = 0
        loop:
            if ci >= self.local_cid.length:
                break
            wire.push(self.local_cid.bytes[ci])
            ci = ci + 1
        wire.push(pn & 0xff)
        var pi = 0
        val plen = payload.len()
        loop:
            if pi >= plen:
                break
            wire.push(payload[pi])
            pi = pi + 1
        val sent = rt_io_udp_send(self.fd, wire)
        val ok = sent >= 0
        if ok:
            self.on_packet_sent(plen)
        return ok

    me recv_packet() -> QuicPacketHeader:
        var empty_bytes: [u8] = []
        val empty_cid = QuicConnectionId.new(empty_bytes, 0)
        if not self.connected:
            return QuicPacketHeader.new(0, 0, empty_cid, empty_cid, 0, 0)
        val raw = rt_io_udp_recv(self.fd, 65535)
        if raw.len() < 6:
            return QuicPacketHeader.new(0, 0, empty_cid, empty_cid, 0, 0)
        val ptype = raw[0] & 0xff
        val ver = ((raw[1] & 0xff) << 24) | ((raw[2] & 0xff) << 16) | ((raw[3] & 0xff) << 8) | (raw[4] & 0xff)
        val cid_len = raw[5] & 0xff
        var dcid_bytes: [u8] = []
        var ci = 6
        loop:
            if ci >= 6 + cid_len or ci >= raw.len():
                break
            dcid_bytes.push(raw[ci])
            ci = ci + 1
        val dcid = QuicConnectionId.new(dcid_bytes, cid_len)
        val pn_offset = 6 + cid_len
        val pn = if pn_offset < raw.len(): raw[pn_offset] & 0xff else 0
        val payload_len = raw.len() - pn_offset - 1
        return QuicPacketHeader.new(ptype, ver, dcid, empty_cid, pn, payload_len)

    me open_stream() -> i64:
        val sid = self.next_stream_id
        self.next_stream_id = self.next_stream_id + 4
        return sid

    me send_stream_data(stream_id: i64, data: [u8], fin: bool) -> bool:
        var frame: [u8] = []
        frame.push(0x08)
        frame.push(stream_id & 0xff)
        val dlen = data.len()
        frame.push((dlen >> 8) & 0xff)
        frame.push(dlen & 0xff)
        var di = 0
        loop:
            if di >= dlen:
                break
            frame.push(data[di])
            di = di + 1
        if fin:
            frame.push(0x01)
        return self.send_packet(3, frame)

    me recv_stream_data(stream_id: i64) -> [u8]:
        val hdr = self.recv_packet()
        var empty: [u8] = []
        if hdr.payload_length <= 0:
            return empty
        return rt_io_udp_recv(self.fd, hdr.payload_length)

    me close() -> void:
        if self.connected:
            var conn_close: [u8] = []
            conn_close.push(0x1c)
            self.send_packet(3, conn_close)
            rt_io_udp_close(self.fd)
            self.connected = false

    me connection_id() -> QuicConnectionId:
        return self.local_cid

    me generate_connection_id(length: i64) -> QuicConnectionId:
        val l = if length > QUIC_MAX_CID_LEN: QUIC_MAX_CID_LEN else length
        val b = rt_random_bytes(l)
        return QuicConnectionId.new(b, l)

    me next_packet_number() -> i64:
        val pn = self.pn_app
        self.pn_app = self.pn_app + 1
        return pn

    me next_packet_number_for(ptype: i64) -> i64:
        if ptype == 0:
            val pn = self.pn_initial
            self.pn_initial = self.pn_initial + 1
            return pn
        elif ptype == 1:
            val pn = self.pn_handshake
            self.pn_handshake = self.pn_handshake + 1
            return pn
        else:
            return self.next_packet_number()

    me congestion_window() -> i64:
        return self.congestion.cwnd

    me on_packet_sent(size: i64) -> void:
        self.congestion.bytes_in_flight = self.congestion.bytes_in_flight + size

    me on_packet_acked(size: i64) -> void:
        self.congestion.bytes_in_flight = self.congestion.bytes_in_flight - size
        if self.in_slow_start():
            self.congestion.cwnd = self.congestion.cwnd + size
        else:
            val inc = QUIC_PMTU * size / self.congestion.cwnd
            self.congestion.cwnd = self.congestion.cwnd + inc

    me on_packet_lost(size: i64) -> void:
        self.congestion.ssthresh = self.congestion.cwnd / 2
        self.congestion.cwnd = self.congestion.ssthresh
        self.congestion.bytes_in_flight = self.congestion.bytes_in_flight - size

    me in_slow_start() -> bool:
        return self.congestion.cwnd < self.congestion.ssthresh
