# Credential management for the Simple Browser Platform.
# Stores saved usernames and passwords per origin.
#
# WARNING: Passwords are stored in plaintext in memory. A real implementation
# would need encryption via crypto SFFI (e.g., AES-256-GCM or similar).
# The hash_password function below is a trivial placeholder — NOT cryptographically secure.

use sbp.shared.logging.{Logger, LogLevel}

class SavedCredential:
    id: i64
    origin: text
    username: text
    password_hash: text
    created_at: i64
    last_used: i64

    static fn create(id: i64, origin: text, username: text, password_hash: text) -> SavedCredential:
        SavedCredential(
            id: id, origin: origin, username: username,
            password_hash: password_hash,
            created_at: 0, last_used: 0
        )

class PasswordStore:
    credentials: [SavedCredential]
    next_id: i64
    logger: Logger

    static fn new(logger: Logger) -> PasswordStore:
        PasswordStore(
            credentials: [SavedCredential](),
            next_id: 1,
            logger: logger
        )

    me save_credential(origin: text, username: text, password: text) -> i64:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val pw_hash = hash_password(password)
        # Check if credential already exists for origin+username and update
        for i in 0..self.credentials.len():
            if self.credentials[i].origin == origin and self.credentials[i].username == username:
                self.credentials[i].password_hash = pw_hash
                self.logger.info("Credential updated for {origin} user={username}")
                return self.credentials[i].id
        val cred = SavedCredential.create(id: id, origin: origin, username: username, password_hash: pw_hash)
        self.credentials.push(cred)
        self.logger.info("Credential saved id={id} for {origin} user={username}")
        id

    fn get_credentials(origin: text) -> [SavedCredential]:
        var results = [SavedCredential]()
        for c in self.credentials:
            if c.origin == origin:
                results.push(c)
        results

    me remove_credential(id: i64):
        var idx = -1
        for i in 0..self.credentials.len():
            if self.credentials[i].id == id:
                idx = i
        if idx >= 0:
            self.credentials.remove(idx)
            self.logger.info("Credential removed id={id}")

    me update_last_used(id: i64):
        for i in 0..self.credentials.len():
            if self.credentials[i].id == id:
                # In a real implementation, this would set to current timestamp
                self.credentials[i].last_used = self.credentials[i].last_used + 1
                self.logger.debug("Credential id={id} last_used updated")
                return

    fn has_credentials(origin: text) -> bool:
        for c in self.credentials:
            if c.origin == origin:
                return true
        false

    me clear_all():
        self.credentials = [SavedCredential]()
        self.next_id = 1
        self.logger.info("All credentials cleared")

    fn get_credential_count() -> i64:
        self.credentials.len()

    me remove_credential_by_origin(origin: text, username: text):
        # Remove a specific credential identified by origin + username
        var idx = -1
        for i in 0..self.credentials.len():
            if self.credentials[i].origin == origin and self.credentials[i].username == username:
                idx = i
        if idx >= 0:
            self.credentials.remove(idx)
            self.logger.info("Credential removed for {origin} user={username}")

    me update_credential(origin: text, username: text, new_password: text):
        # Update the password for an existing credential
        val pw_hash = hash_password(new_password)
        for i in 0..self.credentials.len():
            if self.credentials[i].origin == origin and self.credentials[i].username == username:
                self.credentials[i].password_hash = pw_hash
                self.logger.info("Credential password updated for {origin} user={username}")
                return
        # If no existing credential, save as new
        self.save_credential(origin: origin, username: username, password: new_password)

    fn get_all_origins() -> [text]:
        # Return a deduplicated list of all origins with stored credentials
        var origins = [text]()
        for c in self.credentials:
            var found = false
            for o in origins:
                if o == c.origin:
                    found = true
            if found == false:
                origins.push(c.origin)
        origins

fn hash_password(password: text) -> text:
    # Simple DJB2-style hash for demonstration purposes.
    # WARNING: NOT cryptographically secure. A real implementation must use
    # bcrypt, argon2, or scrypt via SFFI.
    var h: i64 = 5381
    for i in 0..password.len():
        val c = password.char_at(i)
        h = h * 33 + c
    "hash:{h}"
