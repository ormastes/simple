#![allow(REQC001)]
# Legacy bytecode compiler module retained for old browser source paths.
#
# The active browser tests use the shared JavaScript engine. This shim avoids
# duplicate Expression/Statement imports during grouped example compilation.

class BrowserLegacyBytecodeCompiler:
    static fn new(logger: any) -> BrowserLegacyBytecodeCompiler:
        BrowserLegacyBytecodeCompiler()
