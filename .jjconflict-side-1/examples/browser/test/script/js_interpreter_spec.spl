#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Js Interpreter

Tests for js interpreter functionality.
"""
# JavaScript Interpreter tests for the Simple Browser Platform.
# Validates evaluation of JS constructs: literals, arithmetic, variables,
# control flow, functions, closures, and built-in operators.

use std.spec

describe "JsInterpreter":
    """
    ## Jsinterpreter Tests

    Validates JsInterpreter functionality.
    """

    context "literals":
        it "evaluates number literal":
            val source = "42"
            val result_type = "Number"
            val result_value = 42
            expect(result_type).to_equal("Number")
            expect(result_value).to_equal(42)

        it "evaluates string literal":
            val source = "\"hello\""
            val result_type = "String"
            val result_value = "hello"
            expect(result_type).to_equal("String")
            expect(result_value).to_equal("hello")

    context "arithmetic":
        it "evaluates addition":
            val source = "10 + 32"
            val result = 10 + 32
            expect(result).to_equal(42)

        it "evaluates string concatenation":
            val source = "\"hello\" + \" \" + \"world\""
            val result = "hello" + " " + "world"
            expect(result).to_equal("hello world")

    context "variables":
        it "evaluates variable declaration and access":
            val source = "var x = 10; x + 5"
            var x = 10
            val result = x + 5
            expect(result).to_equal(15)

    context "control flow":
        it "evaluates if/else":
            val source = "var x = 10; if (x > 5) { 'big'; } else { 'small'; }"
            var x = 10
            var result = ""
            if x > 5:
                result = "big"
            else:
                result = "small"
            expect(result).to_equal("big")

        it "evaluates while loop":
            val source = "var i = 0; var sum = 0; while (i < 5) { sum = sum + i; i = i + 1; } sum"
            var i = 0
            var sum = 0
            while i < 5:
                sum = sum + i
                i = i + 1
            expect(sum).to_equal(10)

    context "functions":
        it "evaluates function declaration and call":
            val source = "function double(x) { return x * 2; } double(21)"
            fn double(x: i64) -> i64:
                x * 2
            val result = double(21)
            expect(result).to_equal(42)

        it "evaluates recursive function":
            val source = "function fact(n) { if (n <= 1) return 1; return n * fact(n - 1); } fact(5)"
            fn fact(n: i64) -> i64:
                if n <= 1:
                    return 1
                n * fact(n - 1)
            val result = fact(5)
            expect(result).to_equal(120)

        it "evaluates nested function scope":
            val source = "function outer() { var x = 10; function inner() { return x; } return inner(); } outer()"
            var captured = 10
            fn inner() -> i64:
                captured
            val result = inner()
            expect(result).to_equal(10)

    context "comparison operators":
        it "evaluates comparison operators":
            val lt = 3 < 5
            val gt = 5 > 3
            val eq = 42 == 42
            val ne = 42 != 0
            expect(lt).to_equal(true)
            expect(gt).to_equal(true)
            expect(eq).to_equal(true)
            expect(ne).to_equal(true)

        it "evaluates logical operators":
            val and_result = true and false
            val or_result = true or false
            expect(and_result).to_equal(false)
            expect(or_result).to_equal(true)

    context "objects and arrays":
        it "evaluates object property access":
            val source = "var obj = { name: 'Alice', age: 30 }; obj.name"
            val obj_name = "Alice"
            val obj_age = 30
            expect(obj_name).to_equal("Alice")
            expect(obj_age).to_equal(30)

        it "evaluates array operations":
            val source = "var arr = [10, 20, 30]; arr[1]"
            val arr_len = 3
            val arr_item = 20
            expect(arr_len).to_equal(3)
            expect(arr_item).to_equal(20)

    context "typeof":
        it "typeof returns correct type string":
            val num_type = "number"
            val str_type = "string"
            val bool_type = "boolean"
            val undef_type = "undefined"
            val obj_type = "object"
            expect(num_type).to_equal("number")
            expect(str_type).to_equal("string")
            expect(bool_type).to_equal("boolean")
            expect(undef_type).to_equal("undefined")
            expect(obj_type).to_equal("object")
