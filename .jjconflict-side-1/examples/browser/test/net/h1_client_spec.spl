#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# H1 Client

Tests for HTTP/1.1 transport serialization and response parsing.
"""

use std.spec
use std.js.types.pair.{Pair}
use examples.browser.entity.net.url_types.{Url}
use examples.browser.entity.net.request_types.{FetchRequest, HttpMethod, RequestCredentials, RequestMode}
use examples.browser.feature.net.h1_client.{H1Client, MockResponseRegistry, set_mock_registry, build_request_bytes, parse_http_response, find_header}
use examples.browser.feature.net.dns.{DnsResolver}
use examples.browser.feature.net.tls.{TlsManager}
use examples.browser.entity.net.tls_types.{TlsConfig}
use examples.browser.shared.logging.{Logger}

fn make_url() -> Url:
    Url.create("http", "example.com", 80, "/index.html")

fn make_get(headers: [Pair<text, text>]) -> FetchRequest:
    FetchRequest(
        url: make_url(),
        method: HttpMethod.Get,
        headers: headers,
        body: "",
        mode: RequestMode.Cors,
        credentials: RequestCredentials.SameOrigin
    )

describe "H1Client transport helpers":
    it "returns mock responses before opening network transport":
        val logger = Logger(name: "h1-client-test")
        var registry = MockResponseRegistry.create()
        registry.register("offline.test", 200, "<html>offline</html>")
        set_mock_registry(registry)
        var client = H1Client.new(logger, DnsResolver.new(logger, 60), TlsManager.new(logger, TlsConfig.default()))
        val req = FetchRequest(
            url: Url.parse("https://offline.test/page"),
            method: HttpMethod.Get,
            headers: [],
            body: "",
            mode: RequestMode.Navigate,
            credentials: RequestCredentials.Include
        )
        match client.request(req):
            Ok(response):
                expect(response.status).to_equal(200)
                expect(response.body).to_equal("<html>offline</html>")
            Err(e):
                expect(e.message).to_equal("mock response should not use network")

    it "defaults real HTTP requests to connection close for EOF-delimited reads":
        val req = make_get([])
        val raw = build_request_bytes(req)
        expect(raw).to_contain("GET /index.html HTTP/1.1\r\n")
        expect(raw).to_contain("Host: example.com\r\n")
        expect(raw).to_contain("Connection: close\r\n")

    it "preserves caller supplied connection header":
        val req = make_get([Pair(first: "Connection", second: "keep-alive")])
        val raw = build_request_bytes(req)
        expect(raw).to_contain("Connection: keep-alive\r\n")

    it "parses a content-length response":
        val raw = "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: 5\r\n\r\nhello-extra"
        val parsed = parse_http_response(raw)
        match parsed:
            Ok(response):
                expect(response.status).to_equal(200)
                expect(response.status_text).to_equal("OK")
                expect(response.body).to_equal("hello")
                val content_type = find_header(response.headers, "content-type")
                match content_type:
                    Some(value): expect(value).to_equal("text/plain")
                    nil: expect("content-type header should exist").to_equal("")
            Err(e):
                expect(e.message).to_equal("ok")

    it "parses a chunked response body":
        val raw = "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\n5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n"
        val parsed = parse_http_response(raw)
        match parsed:
            Ok(response):
                expect(response.body).to_equal("hello world")
            Err(e):
                expect(e.message).to_equal("ok")
