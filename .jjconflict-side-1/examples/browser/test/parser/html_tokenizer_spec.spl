"""
# Html Tokenizer

Tests for html tokenizer functionality.
"""
# HTML Tokenizer Tests
#
# Category: Browser Platform Parser
# Status: Active
#
# Validates the HTML tokenizer: conversion of raw HTML text into a sequence
# of tokens (start tags, end tags, self-closing tags, text, comments, doctype).
# Each test feeds an HTML string to the tokenizer and verifies the resulting
# token sequence (token type, tag name, attributes, text content).
#
# Run with: bin/simple test examples/browser/test/parser/html_tokenizer_spec.spl

use std.spec
use sbp.feature.parser.html_tokenizer.{tokenize, HtmlToken, TokenKind}

# ============================================================================
# Helpers
# ============================================================================

fn token_kind(tok: HtmlToken) -> text:
    match tok.kind:
        TokenKind.StartTag: "start_tag"
        TokenKind.EndTag: "end_tag"
        TokenKind.SelfClosing: "self_closing"
        TokenKind.Text: "text"
        TokenKind.Comment: "comment"
        TokenKind.Doctype: "doctype"

fn token_tag(tok: HtmlToken) -> text:
    tok.tag_name

fn token_text(tok: HtmlToken) -> text:
    tok.data

# ============================================================================
# Basic tokenization
# ============================================================================

describe "HtmlTokenizer":
    """
    ## Htmltokenizer Tests

    Validates HtmlTokenizer functionality.
    """

    context "text nodes":
        it "tokenizes simple text":
            val tokens = tokenize("Hello, world!")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("text")
            expect(token_text(tokens.get(0))).to_equal("Hello, world!")

    context "start tags":
        it "tokenizes start tag":
            val tokens = tokenize("<div>")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("start_tag")
            expect(token_tag(tokens.get(0))).to_equal("div")

    context "end tags":
        it "tokenizes end tag":
            val tokens = tokenize("</div>")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("end_tag")
            expect(token_tag(tokens.get(0))).to_equal("div")

    context "self-closing tags":
        it "tokenizes self-closing tag":
            val tokens = tokenize("<br/>")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("self_closing")
            expect(token_tag(tokens.get(0))).to_equal("br")

    context "attributes":
        it "tokenizes tag with attributes":
            val tokens = tokenize("<div class=main>")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("start_tag")
            expect(token_tag(tokens.get(0))).to_equal("div")
            val attrs = tokens.get(0).attributes
            expect(attrs.len()).to_equal(1)
            expect(attrs.get(0).name).to_equal("class")
            expect(attrs.get(0).value).to_equal("main")

        it "tokenizes tag with quoted attribute values":
            val tokens = tokenize("<a href=\"https://example.com\" title=\"Example\">")
            expect(tokens.len()).to_equal(1)
            expect(token_tag(tokens.get(0))).to_equal("a")
            val attrs = tokens.get(0).attributes
            expect(attrs.len()).to_equal(2)
            expect(attrs.get(0).name).to_equal("href")
            expect(attrs.get(0).value).to_equal("https://example.com")
            expect(attrs.get(1).name).to_equal("title")
            expect(attrs.get(1).value).to_equal("Example")

    context "comments":
        it "tokenizes comment":
            val tokens = tokenize("<!-- a comment -->")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("comment")
            expect(token_text(tokens.get(0))).to_equal(" a comment ")

    context "doctype":
        it "tokenizes doctype":
            val tokens = tokenize("<!DOCTYPE html>")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("doctype")
            expect(token_text(tokens.get(0))).to_equal("html")

    context "multiple elements":
        it "tokenizes multiple elements":
            val tokens = tokenize("<p>Hello</p>")
            expect(tokens.len()).to_equal(3)
            expect(token_kind(tokens.get(0))).to_equal("start_tag")
            expect(token_tag(tokens.get(0))).to_equal("p")
            expect(token_kind(tokens.get(1))).to_equal("text")
            expect(token_text(tokens.get(1))).to_equal("Hello")
            expect(token_kind(tokens.get(2))).to_equal("end_tag")
            expect(token_tag(tokens.get(2))).to_equal("p")

    context "whitespace handling":
        it "handles whitespace in tags":
            val tokens = tokenize("<  div  class = \"main\"  >")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("start_tag")
            expect(token_tag(tokens.get(0))).to_equal("div")
            val attrs = tokens.get(0).attributes
            expect(attrs.len()).to_equal(1)
            expect(attrs.get(0).name).to_equal("class")
            expect(attrs.get(0).value).to_equal("main")

    context "character references":
        it "decodes basic character references":
            val tokens = tokenize("&amp; &lt; &gt; &quot;")
            expect(tokens.len()).to_equal(1)
            expect(token_kind(tokens.get(0))).to_equal("text")
            expect(token_text(tokens.get(0))).to_equal("& < > \"")

    context "raw text elements":
        it "tokenizes script content as raw text":
            val tokens = tokenize("<script>var x = 1 < 2;</script>")
            expect(tokens.len()).to_equal(3)
            expect(token_kind(tokens.get(0))).to_equal("start_tag")
            expect(token_tag(tokens.get(0))).to_equal("script")
            expect(token_kind(tokens.get(1))).to_equal("text")
            expect(token_text(tokens.get(1))).to_equal("var x = 1 < 2;")
            expect(token_kind(tokens.get(2))).to_equal("end_tag")
            expect(token_tag(tokens.get(2))).to_equal("script")

        it "tokenizes style content as raw text":
            val tokens = tokenize("<style>body { color: red; }</style>")
            expect(tokens.len()).to_equal(3)
            expect(token_kind(tokens.get(0))).to_equal("start_tag")
            expect(token_tag(tokens.get(0))).to_equal("style")
            expect(token_kind(tokens.get(1))).to_equal("text")
            expect(token_text(tokens.get(1))).to_equal("body { color: red; }")
            expect(token_kind(tokens.get(2))).to_equal("end_tag")
            expect(token_tag(tokens.get(2))).to_equal("style")

    context "edge cases":
        it "handles empty document":
            val tokens = tokenize("")
            expect(tokens.len()).to_equal(0)

        it "handles unclosed tag gracefully":
            val tokens = tokenize("<div")
            # Tokenizer should produce at least something (possibly an error token
            # or a partial start tag). The key is it does not crash.
            val count = tokens.len()
            val has_tokens = count >= 0
            expect(has_tokens).to_equal(true)
