#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# WPT Compatibility Check — standalone browser engine test
#
# Tests the Simple browser engine against WPT-style HTML/CSS patterns
# without external dependencies. Renders test HTML directly and checks
# pixel output for expected patterns.
#
# Usage:
#   bin/simple native-build \
#     --entry examples/browser/test/compat/wpt_compat_check.spl \
#     --source src/lib -o /tmp/wpt_check --strip
#   /tmp/wpt_check

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}

fn main() -> i64:
    print "=========================================="
    print "  Browser Compatibility Check"
    print "=========================================="

    var passed = 0
    var failed = 0
    var total = 0

    # --- Test 1: Inline style rendering ---
    total = total + 1
    val t1 = check_render("inline-style",
        "<div style=\"width: 100px; height: 100px; background-color: red;\"></div>",
        "<div style=\"width: 100px; height: 100px; background-color: red;\"></div>")
    if t1:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 2: <style> block - tag selector ---
    total = total + 1
    val t2 = check_render("style-block-tag",
        "<style>div { background-color: blue; width: 100px; height: 100px; }</style><div></div>",
        "<div style=\"background-color: blue; width: 100px; height: 100px;\"></div>")
    if t2:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 3: <style> block - class selector ---
    total = total + 1
    val t3 = check_render("style-block-class",
        "<style>.box { background-color: green; width: 80px; height: 80px; }</style><div class=\"box\"></div>",
        "<div style=\"background-color: green; width: 80px; height: 80px;\"></div>")
    if t3:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 4: <style> block - ID selector ---
    total = total + 1
    val t4 = check_render("style-block-id",
        "<style>#main { background-color: yellow; width: 120px; height: 60px; }</style><div id=\"main\"></div>",
        "<div style=\"background-color: yellow; width: 120px; height: 60px;\"></div>")
    if t4:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 5: Flexbox - display:flex ---
    total = total + 1
    val t5 = check_nonwhite("flexbox-display",
        "<style>div { display: flex; width: 200px; height: 50px; background-color: black; }</style><div><span></span></div>")
    if t5:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 6: Flexbox margin (WPT-style) ---
    total = total + 1
    val t6 = check_render("flexbox-margin",
        "<style>div { background: black; margin: 16px; height: 64px; display: flex; justify-content: space-around; }</style><div></div>",
        "<style>div { background: black; margin: 16px; height: 64px; }</style><div></div>")
    if t6:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 7: CSS color - named colors ---
    total = total + 1
    val t7 = check_nonwhite("css-color-named",
        "<style>div { background-color: navy; width: 100px; height: 100px; }</style><div></div>")
    if t7:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 8: CSS color - hex ---
    total = total + 1
    val t8 = check_nonwhite("css-color-hex",
        "<style>div { background-color: #FF6600; width: 100px; height: 100px; }</style><div></div>")
    if t8:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 9: CSS color - rgb() ---
    total = total + 1
    val t9 = check_nonwhite("css-color-rgb",
        "<style>div { background-color: rgb(128, 0, 255); width: 100px; height: 100px; }</style><div></div>")
    if t9:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 10: Box model - margin + padding ---
    total = total + 1
    val t10 = check_render("box-model-margin-padding",
        "<style>div { margin: 10px; padding: 10px; background: green; width: 80px; height: 80px; }</style><div></div>",
        "<div style=\"margin: 10px; padding: 10px; background-color: green; width: 80px; height: 80px;\"></div>")
    if t10:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 11: Border ---
    total = total + 1
    val t11 = check_nonwhite("border-solid",
        "<style>div { border: 2px solid red; width: 100px; height: 100px; }</style><div></div>")
    if t11:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 12: Display none ---
    total = total + 1
    val t12_html = "<style>.hidden { display: none; background: red; width: 100px; height: 100px; }</style><div class=\"hidden\"></div>"
    val r12 = BrowserRenderer.create(200, 200)
    val res12 = r12.render_html_to_pixels(t12_html)
    var nw12 = count_nonwhite(res12.pixel_data)
    if nw12 == 0:
        print "  PASS display-none: hidden element produces no colored pixels"
        passed = passed + 1
    else:
        print "  FAIL display-none: {nw12} non-white pixels (expected 0)"
        failed = failed + 1

    # --- Test 13: Flex direction column ---
    total = total + 1
    val t13 = check_nonwhite("flex-direction-column",
        "<style>.col { display: flex; flex-direction: column; width: 100px; } .item { background: blue; height: 30px; width: 100px; }</style><div class=\"col\"><div class=\"item\"></div><div class=\"item\"></div></div>")
    if t13:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 14: justify-content center ---
    total = total + 1
    val t14 = check_nonwhite("justify-content-center",
        "<style>.flex { display: flex; justify-content: center; width: 300px; height: 50px; background: gray; } .item { width: 50px; height: 50px; background: red; }</style><div class=\"flex\"><div class=\"item\"></div></div>")
    if t14:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 15: align-items center ---
    total = total + 1
    val t15 = check_nonwhite("align-items-center",
        "<style>.flex { display: flex; align-items: center; width: 200px; height: 100px; background: gray; } .item { width: 50px; height: 30px; background: blue; }</style><div class=\"flex\"><div class=\"item\"></div></div>")
    if t15:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 16: Multiple selectors (comma) ---
    total = total + 1
    val t16 = check_nonwhite("comma-selectors",
        "<style>p, span { background-color: red; width: 50px; height: 50px; display: block; }</style><p></p><span></span>")
    if t16:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 17: Opacity ---
    total = total + 1
    val t17 = check_nonwhite("opacity",
        "<style>div { background: blue; width: 100px; height: 100px; opacity: 0.5; }</style><div></div>")
    if t17:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 18: Position relative ---
    total = total + 1
    val t18 = check_nonwhite("position-relative",
        "<style>div { position: relative; top: 20px; left: 20px; background: green; width: 80px; height: 80px; }</style><div></div>")
    if t18:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 19: Flex wrap ---
    total = total + 1
    val t19 = check_nonwhite("flex-wrap",
        "<style>.wrap { display: flex; flex-wrap: wrap; width: 100px; } .item { width: 60px; height: 30px; background: blue; }</style><div class=\"wrap\"><div class=\"item\"></div><div class=\"item\"></div></div>")
    if t19:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Test 20: Flex gap ---
    total = total + 1
    val t20 = check_nonwhite("flex-gap",
        "<style>.g { display: flex; gap: 10px; width: 200px; } .i { width: 50px; height: 50px; background: red; }</style><div class=\"g\"><div class=\"i\"></div><div class=\"i\"></div></div>")
    if t20:
        passed = passed + 1
    else:
        failed = failed + 1

    # --- Now test external WPT files ---
    print "\n--- External WPT Reftests ---"
    val wpt_base = "examples/browser/test/compat/external/wpt"
    val cats = ["flexbox", "colors", "display", "backgrounds", "positioning", "normal-flow", "floats"]
    for cat in cats:
        val cat_result = run_wpt_category(wpt_base, cat)
        passed = passed + cat_result.passed
        failed = failed + cat_result.failed
        total = total + cat_result.total

    # --- Acid tests ---
    print "\n--- Acid Tests ---"
    val acid_base = "examples/browser/test/compat/external"
    val acid1_html = rt_file_read_text("{acid_base}/acid1.html") ?? ""
    if acid1_html.len() > 0:
        total = total + 1
        val r_a1 = BrowserRenderer.create(800, 600)
        val res_a1 = r_a1.render_html_to_pixels(acid1_html)
        val nw_a1 = count_nonwhite(res_a1.pixel_data)
        val pct_a1 = if res_a1.pixel_data.len() > 0: (nw_a1.to_f64() / res_a1.pixel_data.len().to_f64()) * 100.0 else: 0.0
        if nw_a1 > 1000:
            print "  PASS acid1: {nw_a1} non-white pixels ({pct_a1}% coverage)"
            passed = passed + 1
        else:
            print "  FAIL acid1: only {nw_a1} non-white pixels"
            failed = failed + 1
    else:
        print "  SKIP acid1: file not found"

    val acid2_html = rt_file_read_text("{acid_base}/acid2.html") ?? ""
    if acid2_html.len() > 0:
        total = total + 1
        val r_a2 = BrowserRenderer.create(800, 600)
        val res_a2 = r_a2.render_html_to_pixels(acid2_html)
        val nw_a2 = count_nonwhite(res_a2.pixel_data)
        val pct_a2 = if res_a2.pixel_data.len() > 0: (nw_a2.to_f64() / res_a2.pixel_data.len().to_f64()) * 100.0 else: 0.0
        if nw_a2 > 100:
            print "  PASS acid2: {nw_a2} non-white pixels ({pct_a2}% coverage)"
            passed = passed + 1
        else:
            print "  FAIL acid2: only {nw_a2} non-white pixels"
            failed = failed + 1
    else:
        print "  SKIP acid2: file not found"

    # Summary
    print "\n=========================================="
    print "  SUMMARY"
    print "=========================================="
    val rate = if total > 0: (passed.to_f64() / total.to_f64()) * 100.0 else: 0.0
    print "Total: {total}, Passed: {passed}, Failed: {failed}"
    print "Pass rate: {rate}%"
    print "=========================================="

    0

# =========================================================================
# Helpers
# =========================================================================

fn check_render(name: text, test_html: text, ref_html: text) -> bool:
    val renderer_t = BrowserRenderer.create(200, 200)
    val renderer_r = BrowserRenderer.create(200, 200)
    val test_res = renderer_t.render_html_to_pixels(test_html)
    val ref_res = renderer_r.render_html_to_pixels(ref_html)

    if test_res.pixel_data.len() == 0 or ref_res.pixel_data.len() == 0:
        print "  FAIL {name}: no pixels rendered"
        return false

    var matching = 0
    var total = test_res.pixel_data.len()
    if ref_res.pixel_data.len() < total:
        total = ref_res.pixel_data.len()
    var i = 0
    while i < total:
        if test_res.pixel_data[i] == ref_res.pixel_data[i]:
            matching = matching + 1
        i = i + 1
    val pct = if total > 0: (matching.to_f64() / total.to_f64()) * 100.0 else: 0.0
    if pct >= 95.0:
        print "  PASS {name}: {pct}% match"
        return true
    print "  FAIL {name}: {pct}% match (need 95%)"
    false

fn check_nonwhite(name: text, html: text) -> bool:
    val renderer = BrowserRenderer.create(200, 200)
    val res = renderer.render_html_to_pixels(html)
    if res.pixel_data.len() == 0:
        print "  FAIL {name}: no pixels rendered"
        return false
    val nw = count_nonwhite(res.pixel_data)
    if nw > 100:
        print "  PASS {name}: {nw} non-white pixels"
        return true
    print "  FAIL {name}: only {nw} non-white pixels"
    false

fn count_nonwhite(pixels: [u32]) -> i64:
    var count = 0
    for px in pixels:
        if px != 0xFFFFFFFF:
            count = count + 1
    count

class CatResult:
    total: i32
    passed: i32
    failed: i32

fn run_wpt_category(base: text, category: text) -> CatResult:
    var total = 0
    var passed = 0
    var failed = 0

    # Try to read each known test file
    val cat_path = "{base}/{category}"

    # Read test files by trying common names from the manifest
    # Since rt_list_dir may not be available, we read the files directly
    val test_files = get_wpt_test_files(category)

    for test_name in test_files:
        val test_path = "{cat_path}/{test_name}.html"
        val ref_path = "{cat_path}/{test_name}-ref.html"

        val test_html = rt_file_read_text(test_path) ?? ""
        val ref_html = rt_file_read_text(ref_path) ?? ""

        if test_html.len() == 0 or ref_html.len() == 0:
            continue

        total = total + 1
        val renderer_t = BrowserRenderer.create(800, 600)
        val renderer_r = BrowserRenderer.create(800, 600)
        val test_res = renderer_t.render_html_to_pixels(test_html)
        val ref_res = renderer_r.render_html_to_pixels(ref_html)

        if test_res.pixel_data.len() == 0 or ref_res.pixel_data.len() == 0:
            print "  ERR  {category}/{test_name}: no pixels"
            failed = failed + 1
            continue

        var matching = 0
        val pixel_count = test_res.pixel_data.len()
        var i = 0
        while i < pixel_count:
            if i < ref_res.pixel_data.len() and test_res.pixel_data[i] == ref_res.pixel_data[i]:
                matching = matching + 1
            i = i + 1
        val pct = if pixel_count > 0: (matching.to_f64() / pixel_count.to_f64()) * 100.0 else: 0.0
        if pct >= 95.0:
            print "  PASS {category}/{test_name}: {pct}%"
            passed = passed + 1
        else:
            print "  FAIL {category}/{test_name}: {pct}%"
            failed = failed + 1

    CatResult(total: total, passed: passed, failed: failed)

fn get_wpt_test_files(category: text) -> [text]:
    if category == "flexbox":
        return ["flexbox_margin", "flexbox_inline", "flexbox_display",
            "flexbox_direction-column", "flexbox_direction-row-reverse",
            "flexbox_justifycontent-center", "flexbox_justifycontent-spacebetween",
            "flexbox_align-items-center", "flexbox_align-items-stretch",
            "flexbox_align-items-flexstart", "flexbox_flex-1-1-0", "flexbox_flex-none",
            "flexbox_wrap", "gap-001-ltr", "flex-direction-row-vertical",
            "flexbox_flow-row-wrap", "flexbox_align-self-center", "flexbox_align-self-stretch"]
    if category == "colors":
        return ["background-color-rgb-001", "background-color-rgb-002",
            "background-color-rgb-003", "background-color-hsl-001",
            "background-color-hsl-002", "hex-003", "t424-hsl-values-b-1",
            "opacity-overlapping-letters", "border-color-currentcolor", "currentcolor-003"]
    if category == "display":
        return ["display-contents-text-only-001", "display-contents-flex-001",
            "display-flow-root-001", "display-flow-root-002", "display-contents-block-002"]
    if category == "backgrounds":
        return ["background-clip-color", "background-none-none-and-color",
            "border-radius-012", "box-shadow-calc", "box-shadow-currentcolor"]
    if category == "positioning":
        return ["absolute-non-replaced-max-001", "auto-position-rtl-child-viewport-scrollbar",
            "absolute-non-replaced-min-max-001", "abspos-float-with-inline-container",
            "line-break-after-leading-oof-001"]
    if category == "normal-flow":
        return ["block-in-inline-baseline-001", "block-in-inline-margins-003"]
    if category == "floats":
        return ["float-nowrap-3", "overflow-scroll-float-paint-order",
            "float-root", "float-nowrap-5", "floats-wrap-bfc-with-margin-010"]
    []
