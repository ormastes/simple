use examples.browser.shared.logging.{Logger}
use examples.browser.entity.net.url_types.{Url}
use examples.browser.entity.net.request_types.{FetchRequest, HttpMethod, RequestMode, RequestCredentials}
use examples.browser.feature.net.fetch.{FetchEngine}

fn load_navigation_document(url: text, logger: Logger) -> text:
    if url == "" or url == "about:blank":
        return about_blank_document()
    if url.starts_with("about:"):
        return internal_document_for(url)

    var fetch = FetchEngine.new(logger)
    val request = FetchRequest(
        url: Url.parse(url),
        method: HttpMethod.Get,
        headers: [Pair("Accept", "text/html,application/xhtml+xml")],
        body: "",
        mode: RequestMode.Navigate,
        credentials: RequestCredentials.Include
    )
    match fetch.fetch(request):
        Ok(response):
            if response.status >= 200 and response.status < 300:
                return response.body
            error_document_for(url, "HTTP {response.status} {response.status_text}")
        Err(e):
            error_document_for(url, e.message)

fn about_blank_document() -> text:
    "<html><body><h1>New Tab</h1><p>about:blank</p><div>ready</div></body></html>"

fn internal_document_for(url: text) -> text:
    "<html><body><h1>Simple Browser</h1><p>{url}</p><div>internal page</div></body></html>"

fn error_document_for(url: text, reason: text) -> text:
    "<html><body><h1>Navigation Error</h1><p>{url}</p><div>{reason}</div></body></html>"
