use std.db.dbfs_driver.dbfs_driver.{DbFsDriver}
use std.fs_driver.types.{OpenFlags, Path}

fn main():
    val d = DbFsDriver.new_hosted()
    val fh_r = d.open_path(Path(raw: "hello.txt"), OpenFlags.write_only().with_create())
    print "open_ok={fh_r.is_ok()}"
    if fh_r.is_err():
        print "open_err={fh_r.unwrap_err()}"
        return
    val fh = fh_r.unwrap()
    val wr = d.write_bytes_handle(fh, [104u8, 101u8, 108u8, 108u8, 111u8])
    print "write_ok={wr.is_ok()}"
    if wr.is_err():
        print "write_err={wr.unwrap_err()}"
    val rd = d.read_bytes_handle(fh, 5)
    print "read_ok={rd.is_ok()}"
    if rd.is_err():
        print "read_err={rd.unwrap_err()}"
    else:
        val data = rd.unwrap()
        print "read_len={data.len()}"
    val cl = d.close_handle(fh)
    print "close_ok={cl.is_ok()}"
    if cl.is_err():
        print "close_err={cl.unwrap_err()}"
