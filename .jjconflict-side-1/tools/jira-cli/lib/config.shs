#!/bin/sh
# jira-cli config helpers
# Config stored at: ~/.config/jira-cli/config.json

CONFIG_DIR="${HOME}/.config/jira-cli"
CONFIG_FILE="${CONFIG_DIR}/config.json"

jira_config_dir() {
  mkdir -p "$CONFIG_DIR"
}

jira_config_exists() {
  [ -f "$CONFIG_FILE" ]
}

jira_config_get() {
  local key="$1"
  if jira_config_exists; then
    jq -r ".${key} // empty" "$CONFIG_FILE" 2>/dev/null
  fi
}

jira_config_set() {
  local key="$1" value="$2"
  jira_config_dir
  if jira_config_exists; then
    local tmp="${CONFIG_FILE}.tmp"
    jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  else
    printf '{\n  "%s": "%s"\n}\n' "$key" "$value" > "$CONFIG_FILE"
  fi
  chmod 600 "$CONFIG_FILE"
}

jira_config_delete() {
  local key="$1"
  if jira_config_exists; then
    local tmp="${CONFIG_FILE}.tmp"
    jq --arg k "$key" 'del(.[$k])' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  fi
}

jira_config_list() {
  if jira_config_exists; then
    jq '.' "$CONFIG_FILE"
  else
    echo "{}"
  fi
}

# Load auth credentials into variables
jira_load_auth() {
  if ! jira_config_exists; then
    echo "error: not logged in. Run 'jira auth login' first." >&2
    return 1
  fi
  JIRA_SERVER=$(jira_config_get "server")
  JIRA_EMAIL=$(jira_config_get "email")
  JIRA_TOKEN=$(jira_config_get "token")
  JIRA_DEFAULT_PROJECT=$(jira_config_get "default_project")
  JIRA_DEFAULT_SPACE=$(jira_config_get "default_space")

  if [ -z "$JIRA_SERVER" ] || [ -z "$JIRA_EMAIL" ] || [ -z "$JIRA_TOKEN" ]; then
    echo "error: incomplete credentials. Run 'jira auth login' to reconfigure." >&2
    return 1
  fi

  # Allow env var overrides
  JIRA_SERVER="${JIRA_SERVER_OVERRIDE:-$JIRA_SERVER}"
  JIRA_EMAIL="${JIRA_EMAIL_OVERRIDE:-$JIRA_EMAIL}"
  JIRA_TOKEN="${JIRA_TOKEN_OVERRIDE:-$JIRA_TOKEN}"
}

# Base64 encode for Basic Auth
jira_auth_header() {
  printf '%s:%s' "$JIRA_EMAIL" "$JIRA_TOKEN" | base64
}
