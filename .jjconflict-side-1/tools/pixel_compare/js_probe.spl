# Temporary probe: JS pipeline health — small canonical page + google's
# 11 inline scripts through the real ScriptRunner (js_transpile -> run).
use std.gc_async_mut.gpu.browser_engine.script.script_runner.{
    ScriptRunner, run_script_with_type, script_runner_dom_dirty}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts}
use app.io.mod.{file_read_text}

# --- canonical small page: var, arithmetic, console.log, DOM-independent ---
var runner = ScriptRunner.new()
run_script_with_type(runner, "var a = 2; var b = 3; console.log(a + b);", "text/javascript")
val logs = runner.console_buffer.entries()
print("SMALL-JS: console_entries=" + logs.len().to_text())
var li = 0
while li < logs.len():
    print("SMALL-JS-LOG: " + logs[li])
    li = li + 1

# --- google inline scripts ---
val html = file_read_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_live.html")
val tree = html_tree_builder_build_with_scripts(html)
print("GOOGLE-JS: scripts=" + tree.scripts.len().to_text())
var ok = 0
var failed = 0
var i = 0
while i < tree.scripts.len():
    var r2 = ScriptRunner.new()
    run_script_with_type(r2, tree.scripts[i], "text/javascript")
    # honest health signal: console buffer may hold error diagnostics
    val es = r2.console_buffer.entries()
    var has_err = false
    var j = 0
    while j < es.len():
        if es[j].contains("error") or es[j].contains("Error") or es[j].contains("parse"):
            has_err = true
        j = j + 1
    if has_err:
        failed = failed + 1
        if failed <= 3:
            print("GOOGLE-JS-ERR[" + i.to_text() + "]: " + es[es.len() - 1])
    else:
        ok = ok + 1
    i = i + 1
print("GOOGLE-JS: ok=" + ok.to_text() + " with_errors=" + failed.to_text())
