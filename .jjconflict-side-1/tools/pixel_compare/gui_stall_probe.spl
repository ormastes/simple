# gui_stall_probe.spl — instrumented copy of web_render_file_gui.spl to diagnose
# the large-page present stall. cli_get_args is stubbed in the GUI driver, so the
# fallback path below is what actually gets rendered.

use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    simple_web_render_html_to_pixels_with_engine2d_backend,
    simple_web_resolved_engine2d_backend_name}
use common.ui.builder.{button, column, build_tree_with_title, with_icon}
use common.ui.state.{init_state}
use app.ui.render.html_widgets.{render_html_tree}
use std.io.window_winit.{WinitLoop, WinitWindow, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_close_requested}
use std.sffi.cli.{cli_get_args}

use std.io_runtime.{env_get, read_file, file_exists}

fn html_path() -> text:
    val args = cli_get_args()
    var i = 0
    while i < args.len():
        if args[i].ends_with(".html"):
            return args[i]
        i = i + 1
    "/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_live.html"

val RW: i32 = 480
val RH: i32 = 360
val W: i32 = 480
val H: i32 = 360
val SAMPLE_MARKER: text = "data-simple-actual-gui-button"

fn pack_pixels(src: [u32]) -> [i64]:
    var out: [i64] = [0; src.len()]
    var i = 0
    while i < src.len():
        out[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    out

fn actual_gui_button_html() -> text:
    val btn = with_icon(button("actual_gui_button", "RUN", "run_actual_gui_button"), "image")
    val root = column("actual_gui_root", [btn])
    val tree = build_tree_with_title(root, "Actual GUI Button", "light")
    val state = init_state(tree)
    render_html_tree(state.tree.root_node(), state)

fn html_for_render(html: text) -> text:
    if html.contains(SAMPLE_MARKER):
        return actual_gui_button_html()
    html

fn main() -> i64:
    val path = html_path()
    print "[PROBE] start path={path}"
    if not file_exists(path):
        print "HTML file not found: {path}"
        return 1
    val raw_html = read_file(path)
    val html = html_for_render(raw_html)
    print "[PROBE] render_start bytes={html.len()}"
    val pixels = simple_web_render_html_to_pixels_with_engine2d_backend(html, RW, RH, "cpu_simd")
    print "[PROBE] render_done px={pixels.len()}"

    var nonwhite = 0
    var first_nw: u32 = 0u32
    var k = 0
    while k < pixels.len():
        val p = pixels[k].to_i64() & 0xFFFFFF
        if p != 0xFFFFFF and p != 0x000000:
            if nonwhite == 0:
                first_nw = pixels[k]
            nonwhite = nonwhite + 1
        k = k + 1
    print "[PROBE] pixel_stats nonwhite={nonwhite} first_nw={first_nw.to_i64()}"

    if env_get("SIMPLE_GUI") != "1":
        print "No GUI requested; headless render only."
        return 0

    print "[PROBE] pack_start"
    val packed = pack_pixels(pixels)
    print "[PROBE] pack_done packed={packed.len()}"

    print "[PROBE] loop_new"
    val lp = winit_loop_new()
    if not lp.is_valid:
        print "No GUI runtime available."
        return 0
    print "[PROBE] window_new"
    val win = winit_window_new(lp, W.to_i64(), H.to_i64(), "gui_stall_probe {path}")
    if not win.is_valid:
        print "Window creation failed."
        winit_loop_free(lp)
        return 0
    print "[PROBE] present_first_called"
    winit_present_rgba(win, RW.to_i64(), RH.to_i64(), packed)
    print "[PROBE] present_first_ret"
    var running = true
    var iters = 0
    while running and iters < 2000000:
        if winit_poll_close_requested(lp):
            running = false
        if iters % 200 == 0:
            winit_present_rgba(win, RW.to_i64(), RH.to_i64(), packed)
        if iters % 2000 == 0:
            print "[PROBE] poll_iter {iters}"
        iters = iters + 1
    print "[PROBE] loop_exit iters={iters}"
    winit_window_free(win)
    winit_loop_free(lp)
    return 0
