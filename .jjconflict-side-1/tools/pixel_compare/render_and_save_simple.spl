# Render HTML through Simple renderer and save as PPM + ARGB JSON.
# Uses the native binary (src/compiler_rust/target/release/simple).

use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_env_get(key: text) -> text

var html_path = rt_env_get("PIXEL_HTML")
var w_str = rt_env_get("PIXEL_W")
var h_str = rt_env_get("PIXEL_H")
var output_json = rt_env_get("PIXEL_OUT_JSON")
var output_ppm = rt_env_get("PIXEL_OUT_PPM")

var width: i32 = 320
var height: i32 = 240
if w_str.len() > 0:
    width = w_str.to_int()
if h_str.len() > 0:
    height = h_str.to_int()

var html = rt_file_read_text(html_path)
print("rendering " + html_path + " " + width.to_text() + "x" + height.to_text())

var pixels = simple_web_render_html_to_pixels(html, width, height)
print("pixels=" + pixels.len().to_text())

# Write ARGB JSON
if output_json.len() > 0:
    var json = "{\"width\":" + width.to_text() + ",\"height\":" + height.to_text()
    json = json + ",\"format\":\"argb-u32\",\"producer\":\"simple-web-renderer\""
    json = json + ",\"pixels\":["
    var i = 0
    while i < pixels.len():
        if i > 0:
            json = json + ","
        json = json + pixels[i].to_text()
        i = i + 1
    json = json + "]}"
    rt_file_write_text(output_json, json)
    print("wrote " + output_json)

# Write PPM (P3 ASCII)
if output_ppm.len() > 0:
    var ppm = "P3\n" + width.to_text() + " " + height.to_text() + "\n255\n"
    var i = 0
    while i < pixels.len():
        var px = pixels[i]
        var r = (px >> 16) & 0xFF
        var g = (px >> 8) & 0xFF
        var b = px & 0xFF
        ppm = ppm + r.to_text() + " " + g.to_text() + " " + b.to_text() + "\n"
        i = i + 1
    rt_file_write_text(output_ppm, ppm)
    print("wrote " + output_ppm)
