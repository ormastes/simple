# Render HTML through Simple's layout renderer and dump ARGB pixels as JSON.
#
# Usage:
#   PIXEL_HTML=test/fixtures/pixel_compare/simple_text.html \
#   PIXEL_W=320 PIXEL_H=240 PIXEL_BACKEND=cpu_simd \
#   PIXEL_OUT=build/pixel_compare/simple_simple_text.json \
#   SIMPLE_LIB=src bin/release/simple tools/pixel_compare/render_simple_html.spl

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_env_get(key: text) -> text

use std.common.web_layout.layout_renderer.{simple_web_layout_render_html_pixels}

fn to_i32(n: i64) -> i32:
    var r: i32 = 0
    r = r + n
    r

var html_path = rt_env_get("PIXEL_HTML")
var backend = rt_env_get("PIXEL_BACKEND")
var output_path = rt_env_get("PIXEL_OUT")

var width: i32 = to_i32(rt_env_get("PIXEL_W").to_int())
var height: i32 = to_i32(rt_env_get("PIXEL_H").to_int())

var html = rt_file_read_text(html_path).unwrap()
print("rendering " + html_path + " " + width.to_string() + "x" + height.to_string() + " backend=" + backend)

var pixels = simple_web_layout_render_html_pixels(html, width, height, backend)
print("pixels=" + pixels.len().to_string())

var json = "{\"width\":" + width.to_string() + ",\"height\":" + height.to_string()
json = json + ",\"format\":\"argb-u32\",\"producer\":\"simple-web-layout-renderer\""
json = json + ",\"backend\":\"" + backend + "\""
json = json + ",\"pixels\":["
var i = 0
while i < pixels.len():
    if i > 0:
        json = json + ","
    json = json + pixels[i].to_string()
    i = i + 1
json = json + "]}"

var ok = rt_file_write_text(output_path, json)
if ok:
    print("wrote " + output_path)
