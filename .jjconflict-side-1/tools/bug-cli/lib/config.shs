#!/bin/bash
# bug-cli config helpers
# Config stored at: ~/.config/bug-cli/config.json

BUG_CONFIG_DIR="${HOME}/.config/bug-cli"
BUG_CONFIG_FILE="${BUG_CONFIG_DIR}/config.json"

bug_config_dir() {
  mkdir -p "$BUG_CONFIG_DIR"
}

bug_config_exists() {
  [ -f "$BUG_CONFIG_FILE" ]
}

bug_config_get() {
  local key="$1"
  if bug_config_exists; then
    jq -r ".${key} // empty" "$BUG_CONFIG_FILE" 2>/dev/null
  fi
}

bug_config_set() {
  local key="$1" value="$2"
  bug_config_dir
  if bug_config_exists; then
    local tmp="${BUG_CONFIG_FILE}.tmp"
    jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$BUG_CONFIG_FILE" > "$tmp" && mv "$tmp" "$BUG_CONFIG_FILE"
  else
    cat > "$BUG_CONFIG_FILE" <<EOF
{
  "github_enabled": true,
  "jira_enabled": false,
  "default_labels": ["bug"],
  "default_jira_type": "Bug"
}
EOF
  fi
}

bug_config_init() {
  bug_config_dir
  if ! bug_config_exists; then
    cat > "$BUG_CONFIG_FILE" <<'EOF'
{
  "github_enabled": true,
  "jira_enabled": false,
  "default_labels": ["bug"],
  "default_jira_type": "Bug",
  "severity_keywords": {
    "critical": ["crash", "data loss", "security", "vulnerability", "segfault", "corruption"],
    "high": ["broken", "fails", "error", "exception", "regression", "blocker"],
    "medium": ["incorrect", "wrong", "unexpected", "inconsistent", "slow"],
    "low": ["cosmetic", "typo", "minor", "enhancement", "improvement"]
  }
}
EOF
  fi
}

bug_config_list() {
  if bug_config_exists; then
    jq '.' "$BUG_CONFIG_FILE"
  else
    echo "{}"
  fi
}
