# md5sum / sha256sum — Compute checksums
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error}

fn tool_md5sum(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Compute MD5 checksum of files."""
    return _checksum_files(vfs, cwd, args, "md5", terminal)

fn tool_sha256sum(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Compute SHA-256 checksum of files."""
    return _checksum_files(vfs, cwd, args, "sha256", terminal)

fn _checksum_files(vfs: VfsManager?, cwd: text, args: [text], algo: text, terminal: Terminal) -> i32:
    """Compute checksum for each file in args."""
    if args.len() == 0:
        write_error(terminal, "{algo}sum: missing file operand")
        return 1
    if vfs == nil:
        write_error(terminal, "{algo}sum: no filesystem mounted")
        return 1
    var exit_code: i32 = 0
    for filename in args:
        val path = resolve_path(cwd, filename)
        val result = vfs.read_text(path)
        if result.is_err():
            write_error(terminal, "{algo}sum: {path}: {result.unwrap_err()}")
            exit_code = 1
        else:
            val content = result.unwrap()
            val hash = _simple_hash(content, algo)
            write_line(terminal, "{hash}  {filename}")
    return exit_code

fn _simple_hash(content: text, algo: text) -> text:
    """Compute a simple hash. Uses DJB2 variant as placeholder until crypto lib is wired."""
    var hash: u64 = 5381
    for ch in content:
        hash = ((hash << 5) + hash) + ch.to_i32()
    # Format as hex string
    return _to_hex(hash)

fn _to_hex(n: u64) -> text:
    """Convert u64 to 16-char hex string."""
    val hex_chars = "0123456789abcdef"
    var result = ""
    var val_remaining = n
    var i = 0
    while i < 16:
        val nibble = (val_remaining >> (60 - i * 4)) & 0xF
        result = "{result}{hex_chars.char_at(nibble as i32)}"
        i = i + 1
    return result
