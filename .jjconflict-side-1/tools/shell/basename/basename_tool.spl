# basename — Strip directory from path
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.tools.shell.shell_helpers.{write_line, write_error}

fn tool_basename(args: [text], terminal: Terminal) -> i32:
    """Strip directory and optionally suffix from filename."""
    if args.len() == 0:
        write_error(terminal, "basename: missing operand")
        return 1
    val path = args[0]
    val suffix = if args.len() > 1: args[1] else: ""

    # Find last '/' and take everything after it
    var name = path
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash >= 0:
        name = path.slice(last_slash + 1, path.len())

    # Strip suffix if provided
    if suffix != "" and name.ends_with(suffix):
        name = name.slice(0, name.len() - suffix.len())

    write_line(terminal, name)
    return 0
