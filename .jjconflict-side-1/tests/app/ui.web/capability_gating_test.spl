# Capability Gating Tests
#
# Exercises origin/token/capability enforcement at the string level —
# no real sockets or runtime required for most cases.
#
# NOTE: SessionToken.issue() calls rt_time_ms() and rt_random_hex() — these
# are runtime builtins. If the test runner cannot supply them, cases 4a-4d
# will fail as RUNTIME-AVAILABILITY findings, not test bugs.
#
# NOTE: require_for_window / require_for_surface return Result<bool, NotSupported>,
# not Result<bool, AuthError>. WmBridge wraps NotSupported into AuthError.Forbidden
# internally. Capability tests use NotSupported directly.
#
# NOTE: WmBridge.handle_input returns Err(AuthError.Forbidden) when surface_id
# is not registered — not AuthError.UnknownSurface (no such variant). Verified
# by reading wm_bridge.spl lines 30-31.

use std.sspec.*
use app.ui.web.origin_guard.{OriginGuard, AuthError}
use app.ui.web.session_token.{SessionToken, verify}
use common.ui.capability.{Capability, NotSupported}
use common.ui.capability_policy.{
    CapabilityPolicy,
    check_capability,
    grant,
    require_for_surface,
    require_for_window
}
use common.ui.session.{UISession}
use common.ui.widget.{UITree, WidgetNode}
use app.ui.web.wm_bridge.{WmBridge}
use common.window_protocol.window_protocol.{WmInputEvent, WmEventType}
use common.window_protocol.geometry.{Point, WindowId}
use common.window_protocol.window_protocol.{KeyCode, Modifiers}

# ============================================================================
# Helper
# ============================================================================

fn _make_session() -> UISession:
    val node = WidgetNode(id: "root")
    val tree = UITree.new(node)
    return UISession.new(tree)

# ============================================================================
# Test Group 1: OriginGuard
# ============================================================================

describe "OriginGuard.check":
    """
    ## Origin header validation

    OriginGuard enforces an explicit allowlist.  Returns Ok(origin) on match,
    Err(MissingOrigin) when no Origin header is present,
    Err(DisallowedOrigin) for an unrecognised origin.
    """

    it "allows a matching origin":
        val guard = OriginGuard(allowed: ["https://app.example.com"])
        val headers = "Origin: https://app.example.com\r\nHost: app.example.com\r\n"
        val result = guard.check(headers)
        expect(result.is_ok()).to_equal(true)
        expect(result.unwrap()).to_equal("https://app.example.com")

    it "rejects a disallowed origin":
        val guard = OriginGuard(allowed: ["https://app.example.com"])
        val headers = "Origin: https://evil.com\r\nHost: evil.com\r\n"
        val result = guard.check(headers)
        expect(result.is_err()).to_equal(true)
        val err = result.unwrap_err()
        expect(err).to_equal(AuthError.DisallowedOrigin)

    it "returns MissingOrigin when no Origin header present":
        val guard = OriginGuard(allowed: ["https://app.example.com"])
        val headers = "Host: app.example.com\r\nContent-Type: text/plain\r\n"
        val result = guard.check(headers)
        expect(result.is_err()).to_equal(true)
        val err = result.unwrap_err()
        expect(err).to_equal(AuthError.MissingOrigin)

    it "is case-insensitive for the Origin: header name":
        val guard = OriginGuard(allowed: ["https://app.example.com"])
        val headers = "origin: https://app.example.com\r\n"
        val result = guard.check(headers)
        expect(result.is_ok()).to_equal(true)

    it "rejects empty origin value":
        val guard = OriginGuard(allowed: ["https://app.example.com"])
        val headers = "Origin: \r\n"
        val result = guard.check(headers)
        expect(result.is_err()).to_equal(true)

# ============================================================================
# Test Group 2: SessionToken issue + verify
# ============================================================================

describe "SessionToken issue and verify":
    """
    ## Token lifecycle

    SessionToken.issue mints a signed token. verify checks expiry, origin,
    and HMAC signature.

    RUNTIME NOTE: issue() calls rt_time_ms() and rt_random_hex(). If the
    test runner cannot supply these builtins, all cases in this group will
    fail as a RUNTIME-AVAILABILITY finding.
    """

    it "verify returns Ok for a freshly issued token":
        val secret = "test-secret-key"
        val origin = "https://app.example.com"
        val tok = SessionToken.issue("dev", origin, 60000u64, secret)
        val serialized = tok.serialize()
        val now = tok.expires_at_ms - 1000u64
        val result = verify(serialized, origin, secret, now)
        expect(result.is_ok()).to_equal(true)

    it "verify returns Err(OriginMismatch) for wrong origin":
        val secret = "test-secret-key"
        val origin = "https://app.example.com"
        val tok = SessionToken.issue("dev", origin, 60000u64, secret)
        val serialized = tok.serialize()
        val now = tok.expires_at_ms - 1000u64
        val result = verify(serialized, "https://other.example.com", secret, now)
        expect(result.is_err()).to_equal(true)
        val err = result.unwrap_err()
        expect(err).to_equal(AuthError.OriginMismatch)

    it "verify returns Err(ExpiredToken) when now_ms > expires_at_ms":
        val secret = "test-secret-key"
        val origin = "https://app.example.com"
        val tok = SessionToken.issue("dev", origin, 1000u64, secret)
        val serialized = tok.serialize()
        val expired_now = tok.expires_at_ms + 1u64
        val result = verify(serialized, origin, secret, expired_now)
        expect(result.is_err()).to_equal(true)
        val err = result.unwrap_err()
        expect(err).to_equal(AuthError.ExpiredToken)

    it "verify returns Err(InvalidToken) for a tampered signature":
        val secret = "test-secret-key"
        val origin = "https://app.example.com"
        val tok = SessionToken.issue("dev", origin, 60000u64, secret)
        val serialized = tok.serialize()
        # Tamper: replace last char of signature
        val tampered = serialized[0: serialized.len() - 1] + "X"
        val now = tok.expires_at_ms - 1000u64
        val result = verify(tampered, origin, secret, now)
        expect(result.is_err()).to_equal(true)
        val err = result.unwrap_err()
        expect(err).to_equal(AuthError.InvalidToken)

# ============================================================================
# Test Group 3: CapabilityPolicy
# ============================================================================

describe "CapabilityPolicy enforcement":
    """
    ## Default-deny capability gating

    CapabilityPolicy.new creates a default-deny policy.
    grant adds a capability. require_for_window / require_for_surface
    return Result<bool, NotSupported>.
    """

    it "default-deny policy denies InputInject":
        val policy = CapabilityPolicy.new("win-1")
        val result = check_capability(policy, Capability.InputInject)
        expect(result.is_err()).to_equal(true)

    it "granting InputInject allows it":
        val policy = CapabilityPolicy.new("win-1")
        val granted_policy = grant(policy, Capability.InputInject)
        val result = check_capability(granted_policy, Capability.InputInject)
        expect(result.is_ok()).to_equal(true)

    it "require_for_window returns Err(NotSupported) when capability not granted":
        val policy = CapabilityPolicy.new("win-1")
        val result = require_for_window(policy, 42u64, Capability.InputInject)
        expect(result.is_err()).to_equal(true)

    it "require_for_window returns Ok after granting capability":
        val policy = CapabilityPolicy.new("win-1")
        val granted_policy = grant(policy, Capability.InputInject)
        val result = require_for_window(granted_policy, 42u64, Capability.InputInject)
        expect(result.is_ok()).to_equal(true)

    it "require_for_surface returns Err(NotSupported) when not granted":
        val policy = CapabilityPolicy.new("win-2")
        val result = require_for_surface(policy, "surf-1", Capability.SurfaceSubscribe)
        expect(result.is_err()).to_equal(true)

    it "require_for_surface returns Ok after granting capability":
        val policy = CapabilityPolicy.new("win-2")
        val granted_policy = grant(policy, Capability.SurfaceSubscribe)
        val result = require_for_surface(granted_policy, "surf-1", Capability.SurfaceSubscribe)
        expect(result.is_ok()).to_equal(true)

    it "allow_all policy permits any capability without explicit grant":
        val policy = CapabilityPolicy.allow_all("win-3")
        val result = check_capability(policy, Capability.InputInject)
        expect(result.is_ok()).to_equal(true)

# ============================================================================
# Test Group 4: WmBridge rejects unknown surface
# ============================================================================

describe "WmBridge.handle_input rejects unknown surface":
    """
    ## Surface resolution via UiWindowSurfaceRegistry

    WmBridge.handle_input looks up surface_id via
    session.window_surfaces.for_surface(). If the surface is not registered,
    it returns Err(AuthError.Forbidden) — there is no UnknownSurface variant;
    the bridge maps all unresolvable surfaces to Forbidden.
    """

    it "handle_input returns Err(Forbidden) for unregistered surface_id":
        val session = _make_session()
        val bridge = WmBridge.new(session)
        # Empty UiWindowSurfaceRegistry — "bogus" surface is not registered
        val event = WmInputEvent(
            window_id: WindowId(id: 0u64),
            event_type: WmEventType.KeyDown,
            key_code: KeyCode(code: 0u32),
            mouse_pos: Point(x: 0i32, y: 0i32),
            modifiers: Modifiers(shift: false, ctrl: false, alt: false, meta: false)
        )
        val result = bridge.handle_input("bogus", "w1", event)
        expect(result.is_err()).to_equal(true)
        val err = result.unwrap_err()
        expect(err).to_equal(AuthError.Forbidden)
