# broadcast_parity — Source Contract Tests
#
# Verifies that TlsWebServer and AsyncWebServer both expose the same
# ws-client field and broadcast method contract. This avoids importing
# tls_serve_loop directly because that module currently triggers a trailing
# "cannot convert dict to int" semantic failure during test-file teardown.

use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

val TLS_SERVE_LOOP_PATH = "src/app/ui.web/tls_serve_loop.spl"
val ASYNC_SERVER_PATH = "src/app/ui.web/async_server.spl"

fn read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "TlsWebServer broadcast symmetry":
    """
    ## TLS and async server source contracts stay aligned

    This spec checks the declared field and method surface directly in the
    source files until the imported TLS module teardown bug is fixed.
    """

    it "TlsWebServer declares a ws_clients field":
        val tls_source = read_source(TLS_SERVE_LOOP_PATH)
        expect(tls_source).to_contain("ws_clients: [i64]")

    it "TlsWebServer declares broadcast_render(html: text)":
        val tls_source = read_source(TLS_SERVE_LOOP_PATH)
        expect(tls_source).to_contain("me broadcast_render(html: text):")

    it "AsyncWebServer declares the matching ws-client and broadcast members":
        val async_source = read_source(ASYNC_SERVER_PATH)
        expect(async_source).to_contain("ws_clients: [TcpStream]")
        expect(async_source).to_contain("me broadcast_render():")
