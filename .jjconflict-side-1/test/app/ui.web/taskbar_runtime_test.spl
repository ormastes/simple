## Source-contract spec for the host taskbar runtime.
##
## The old runtime-heavy version had large expectation drift against the
## current host-shell implementation and also tripped the trailing teardown
## semantic failure. This file now verifies the authoritative taskbar/runtime
## contracts directly in source.

use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

val TASKBAR_RUNTIME_PATH = "src/app/ui.web/taskbar_runtime.spl"
val HOST_ADAPTER_CONTRACT_PATH = "src/app/ui.web/host_adapter_contract.spl"

fn _read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "taskbar_runtime mode and capability contracts":
    it "keeps legacy aliases and canonical modes in the parser":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("DesktopEmbedded")
        expect(source).to_contain("TaskbarOnly")
        expect(source).to_contain("HiddenTaskbar")
        expect(source).to_contain("\"desktop_embedded\"")
        expect(source).to_contain("\"taskbar_only\"")

    it "tracks adapter capabilities for embedded native and headless hosts":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("supports_native_windows")
        expect(source).to_contain("supports_embedded_surfaces")
        expect(source).to_contain("supports_headless_session")
        expect(source).to_contain("requires_js_host_bridge")

describe "taskbar_runtime launch and frame contracts":
    it "queues native spawn commands for taskbar-only native launches":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("if _mode_is_taskbar_only(rt.mode) and _backend_is_native_host(backend):")
        expect(source).to_contain("action: \"spawn_native_window\"")
        expect(source).to_contain("session.bind_window_surface_with_kind(window_id, surface_id, process_id, app_id, title, UI_SURFACE_KIND_ELECTRON)")

    it "opens embedded SimpleWeb surfaces when native launch is not selected":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("val _ = session.open_surface(surface_id, _build_app_tree(surface_id, title, width, height, true))")
        expect(source).to_contain("session.bind_window_surface_with_kind(window_id, surface_id, process_id, app_id, title, UI_SURFACE_KIND_SIMPLE_WEB)")

    it "records headless launches without opening a local surface":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("if rt.adapter_capabilities.supports_headless_session:")
        expect(source).to_contain("UI_SURFACE_KIND_HEADLESS")
        expect(source).to_contain("return Ok(())")

    it "builds taskbar_model frames from registry windows pinned apps and minimized ids":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("fn host_taskbar_runtime_taskbar_frame(session_id: text, session: UISession) -> text:")
        expect(source).to_contain("build_taskbar_model_with_minimized(")
        expect(source).to_contain("taskbar_model_to_json_with_launch_errors")

describe "taskbar_runtime native lifecycle command contracts":
    it "keeps pending host-window command emission on the shared adapter wire":
        val runtime_source = _read_source(TASKBAR_RUNTIME_PATH)
        val contract_source = _read_source(HOST_ADAPTER_CONTRACT_PATH)
        expect(runtime_source).to_contain("fn host_taskbar_runtime_take_client_frames(session_id: text) -> [text]:")
        expect(runtime_source).to_contain("_make_frame(\"host_window_command\", session_id, \"null\", payload)")
        expect(contract_source).to_contain("fn host_window_command_to_json(cmd: HostWindowCommand) -> text:")

    it "covers focus minimize restore close and geometry native actions":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("action: \"focus_native_window\"")
        expect(source).to_contain("action: \"minimize_native_window\"")
        expect(source).to_contain("action: \"restore_native_window\"")
        expect(source).to_contain("action: \"close_native_window\"")
        expect(source).to_contain("action: \"move_native_window\"")
        expect(source).to_contain("action: \"resize_native_window\"")
        expect(source).to_contain("action: \"maximize_native_window\"")
        expect(source).to_contain("action: \"unmaximize_native_window\"")
        expect(source).to_contain("action: \"set_native_window_title\"")

    it "retains sync helpers for native feedback without re-queueing commands":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("fn host_taskbar_runtime_sync_focus(session: UISession, surface_id: text) -> Result<Unit, text>:")
        expect(source).to_contain("fn host_taskbar_runtime_sync_minimize(session: UISession, surface_id: text) -> Result<Unit, text>:")
        expect(source).to_contain("fn host_taskbar_runtime_sync_restore(session: UISession, surface_id: text) -> Result<Unit, text>:")
        expect(source).to_contain("fn host_taskbar_runtime_sync_close(session: UISession, surface_id: text) -> Result<Unit, text>:")
        expect(source).to_contain("fn host_taskbar_runtime_sync_move(session: UISession, surface_id: text, x: i32, y: i32) -> Result<Unit, text>:")
        expect(source).to_contain("fn host_taskbar_runtime_sync_resize(session: UISession, surface_id: text, width: i32, height: i32) -> Result<Unit, text>:")
        expect(source).to_contain("fn host_taskbar_runtime_sync_maximize(session: UISession, surface_id: text) -> Result<Unit, text>:")
        expect(source).to_contain("fn host_taskbar_runtime_sync_unmaximize(session: UISession, surface_id: text) -> Result<Unit, text>:")
        expect(source).to_contain("fn host_taskbar_runtime_sync_set_title(session: UISession, surface_id: text, title: text) -> Result<Unit, text>:")

describe "taskbar_runtime catalog and native html contracts":
    it "keeps the hello taskbar app and desktop manifests in the catalog":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("fn host_taskbar_runtime_catalog() -> [HostTaskbarApp]:")
        expect(source).to_contain("_hello_catalog_app()")
        expect(source).to_contain("for manifest in default_manifests():")

    it "resolves native window html through the catalog app lookup":
        val source = _read_source(TASKBAR_RUNTIME_PATH)
        expect(source).to_contain("fn host_taskbar_runtime_native_window_html(app_id: text) -> text?:")
        expect(source).to_contain("val app = _find_app(app_id)")
        expect(source).to_contain("return app.native_html")
