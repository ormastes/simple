# @cover src/app/sspec_docgen/ 80%
"""
# Documentation Navigation Generation Specification

**Feature IDs:** #1210-1215 (doc navigation generation)
**Category:** Tooling / Documentation
**Difficulty:** 3/5
**Status:** Implemented

## Overview

Tests that the REAL `bin/simple sspec-docgen` generator produces correct
documentation with navigation structure from SSpec test files.

Exercises the actual sspec-docgen binary and reads the real generated
markdown to verify heading hierarchy, metadata tables, scenario counts,
source references, and cross-navigation links.
"""

use std.io_runtime.{read_file, file_exists}
use std.ffi.system.{process_run}

# ============================================================================
# Real sspec-docgen Execution
# ============================================================================

describe "Real sspec-docgen output":

    context "generates markdown for math_render_spec":
        it "runs sspec-docgen successfully":
            val (stdout, stderr, code) = process_run("bin/simple", ["sspec-docgen", "test/feature/usage/math_render_spec.spl"])
            expect(code).to_equal(0)
            expect(stdout).to_contain("Generated")

        it "creates output file":
            # sspec-docgen generates to doc/spec/ by default
            val exists = file_exists("doc/spec/math_render_spec.md")
            expect(exists).to_equal(true)

    context "markdown heading structure":
        it "has H1 title from docstring":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("# Math Block Rendering Specification")

        it "has metadata table with Feature IDs":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Feature IDs")
            expect(md).to_contain("#1090")

        it "has metadata table with Category":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Category")
            expect(md).to_contain("Math DSL")

        it "has metadata table with Difficulty":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Difficulty")
            expect(md).to_contain("3/5")

        it "has metadata table with Status":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Status")
            expect(md).to_contain("Implemented")

        it "has source file reference":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Source")
            expect(md).to_contain("math_render_spec.spl")

        it "has date stamp":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Updated")
            expect(md).to_contain("2026")

        it "has generator attribution":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("sspec-docgen")

    context "scenario summary table":
        it "reports total scenario count":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Total scenarios")
            expect(md).to_contain("129")

        it "reports active scenarios":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Active scenarios")
            expect(md).to_contain("129")

        it "reports zero skipped scenarios":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("Skipped scenarios")
            expect(md).to_contain("0")

    context "overview section from docstring":
        it "includes overview content":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("## Overview")

        it "includes renderer list":
            val md = read_file("doc/spec/math_render_spec.md")
            expect(md).to_contain("to_text()")
            expect(md).to_contain("to_debug()")
            expect(md).to_contain("to_pretty()")
            expect(md).to_contain("render_latex_raw()")


# ============================================================================
# Real sspec-docgen on loss_nograd spec
# ============================================================================

describe "Real sspec-docgen for loss_nograd_blocks_spec":

    it "runs sspec-docgen successfully":
        val (stdout, stderr, code) = process_run("bin/simple", ["sspec-docgen", "test/feature/usage/loss_nograd_blocks_spec.spl"])
        expect(code).to_equal(0)

    it "creates output file":
        val exists = file_exists("doc/spec/loss_nograd_blocks_spec.md")
        expect(exists).to_equal(true)

    it "has title from docstring":
        val md = read_file("doc/spec/loss_nograd_blocks_spec.md")
        expect(md).to_contain("loss{}")
        expect(md).to_contain("nograd{}")

    it "reports 38 scenarios":
        val md = read_file("doc/spec/loss_nograd_blocks_spec.md")
        expect(md).to_contain("38")

    it "has feature IDs":
        val md = read_file("doc/spec/loss_nograd_blocks_spec.md")
        expect(md).to_contain("#1099")


# ============================================================================
# Real sspec-docgen on math_blocks_spec
