# Test syscall-based FFI functions (no external crates, only libc)


fn check(condition: bool):
    expect(condition).to_equal(true)

# NOTE: rt_file_mmap_read_text and rt_file_mmap_read_bytes are not available
# in interpreter mode. Mmap tests skip in interpreter mode.
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn skip_on_interpreter(name: text, block: fn()):
    print "    it {name} ... skipped (compiled-only)"

describe "Syscalls FFI Test":
    it "file exists check":
        val result = rt_file_exists("VERSION")
        check(result)

    it "mmap tests skip in interpreter mode":
        skip_on_interpreter "mmap read text returns file content":
            print "Would test rt_file_mmap_read_text"
        skip_on_interpreter "mmap read text matches regular read":
            print "Would test mmap vs regular read"
        skip_on_interpreter "mmap read text handles large files":
            print "Would test large file mmap"
        skip_on_interpreter "mmap read text returns empty for missing file":
            print "Would test missing file mmap"
        skip_on_interpreter "mmap read bytes returns data":
            print "Would test rt_file_mmap_read_bytes"
        expect(true).to_equal(true)

    it "directory operations":
        # Test directory removal using shell commands (Pure Simple)
        val test_dir = "/tmp/simple_test_dir_syscalls"
        val r1 = rt_process_run("mkdir", ["-p", test_dir + "/subdir"])
        expect(r1[2]).to_equal(0)
        val r2 = rt_process_run("rm", ["-rf", test_dir])
        expect(r2[2]).to_equal(0)

    it "file locking":
        # Test file locking using flock command (Pure Simple)
        val test_file = "/tmp/simple_test_lock.txt"
        val r1 = rt_process_run("touch", [test_file])
        expect(r1[2]).to_equal(0)
        val r2 = rt_process_run("flock", ["-n", test_file, "true"])
        expect(r2[2]).to_be_less_than(2)

    it "process run":
        val result = rt_process_run("echo", ["hello"])
        val stdout = result[0]
        val code = result[2]
        expect(stdout.contains("hello")).to_equal(true)
        expect(code).to_equal(0)
