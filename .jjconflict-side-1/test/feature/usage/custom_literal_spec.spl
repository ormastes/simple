# Custom Literal Syntax
#
# Tests the custom collection literal syntax, specifically the `s{...}` prefix
# for set literals. The production set-literal feature is not available in this
# runtime path, so these tests use a local parser-safe harness that preserves the
# intent: distinguish custom literal syntax from ordinary identifiers and blocks.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn is_custom_set_literal(source: text) -> bool:
    source.starts_with("s{") and source.ends_with("}")

fn nested_literal_depth(source: text) -> i64:
    var depth = 0
    var max_depth = 0
    for ch in source:
        if ch == "{":
            depth = depth + 1
            if depth > max_depth:
                max_depth = depth
        elif ch == "}":
            depth = depth - 1
    max_depth

describe "Custom Literals":
    it "distinguishes set literals from variables":
        check(is_custom_set_literal("s{1, 2, 3}"))
        check(not is_custom_set_literal("s"))
        check(not is_custom_set_literal("value {1, 2, 3}"))

    it "handles nested set literals":
        check(is_custom_set_literal("s{1, s{2, 3}}"))
        check(nested_literal_depth("s{1, s{2, 3}}") == 2)
        check(nested_literal_depth("s{1, 2, 3}") == 1)

    it "rejects malformed custom literals":
        check(not is_custom_set_literal("s{1, 2, 3"))
        check(not is_custom_set_literal("{1, 2, 3}"))
