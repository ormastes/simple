describe "FR-DRIVER-0003 packed struct bitfield syntax":
    val requested_syntax = "struct Foo @packed { a: u16:4 }"
    val current_status = "parser diagnostic only"
    val fallback = "bitfield FooBits(u16): a: 4"

    it "documents requested native syntax":
        expect(requested_syntax).to_contain("@packed")
        expect(requested_syntax).to_contain("u16:4")

    it "documents current implementation boundary":
        expect(current_status).to_equal("parser diagnostic only")
        expect(fallback).to_start_with("bitfield")
