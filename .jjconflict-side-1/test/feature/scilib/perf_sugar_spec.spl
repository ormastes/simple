# PERF-SUGAR-001 smoke spec
# Verifies typed bulk-allocation patterns work in interpreter mode.

extern fn rt_bytes_alloc(len: int) -> [int]

class TypedBuffer:
    data: [float]
    length: int

    me get(idx: int) -> float:
        return self.data[idx]

    me size() -> int:
        return self.length

    static fn zeros(n: int) -> TypedBuffer:
        var arr: [float] = []
        var i = 0
        while i < n:
            arr = arr + [0.0]
            i = i + 1
        return TypedBuffer(data: arr, length: n)

    static fn fill(n: int, v: float) -> TypedBuffer:
        var arr: [float] = []
        var i = 0
        while i < n:
            arr = arr + [v]
            i = i + 1
        return TypedBuffer(data: arr, length: n)

class IntBuffer:
    data: [int]
    length: int

    me get(idx: int) -> int:
        return self.data[idx]

    me size() -> int:
        return self.length

    static fn zeros(n: int) -> IntBuffer:
        var arr: [int] = []
        var i = 0
        while i < n:
            arr = arr + [0]
            i = i + 1
        return IntBuffer(data: arr, length: n)

class ByteBuffer:
    data: [int]
    length: int

    me get(idx: int) -> int:
        return self.data[idx]

    me size() -> int:
        return self.length

    static fn alloc(n: int) -> ByteBuffer:
        val d = rt_bytes_alloc(n)
        return ByteBuffer(data: d, length: n)

describe "perf_sugar typed array allocation":
    it "f64 zeros creates correct length":
        val buf = TypedBuffer.zeros(8)
        expect(buf.size()).to_equal(8)

    it "f64 zeros fills with zero":
        val buf = TypedBuffer.zeros(4)
        expect(buf.get(0)).to_equal(0.0)
        expect(buf.get(3)).to_equal(0.0)

    it "f64 fill creates uniform buffer":
        val buf = TypedBuffer.fill(5, 3.14)
        expect(buf.size()).to_equal(5)
        expect(buf.get(0)).to_equal(3.14)
        expect(buf.get(4)).to_equal(3.14)

    it "int zeros creates correct length":
        val buf = IntBuffer.zeros(6)
        expect(buf.size()).to_equal(6)
        expect(buf.get(0)).to_equal(0)
        expect(buf.get(5)).to_equal(0)

    it "byte alloc via rt_bytes_alloc":
        val buf = ByteBuffer.alloc(16)
        expect(buf.size()).to_equal(16)

    it "empty buffer has zero length":
        val buf = TypedBuffer.zeros(0)
        expect(buf.size()).to_equal(0)

    it "single element buffer":
        val buf = TypedBuffer.fill(1, 42.0)
        expect(buf.size()).to_equal(1)
        expect(buf.get(0)).to_equal(42.0)

    it "int buffer preserves values":
        val buf = IntBuffer.zeros(3)
        expect(buf.get(0)).to_equal(0)
        expect(buf.get(1)).to_equal(0)
        expect(buf.get(2)).to_equal(0)

    it "moderate size allocation":
        val buf = TypedBuffer.zeros(100)
        expect(buf.size()).to_equal(100)
