use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_brief_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + " && printf 'fn main() -> i64:\\n    0\\n' > " + FIXTURE_DIR + "/main.spl"
    ])

fn _run_brief(args: [text]) -> (text, text, i64):
    rt_process_run("bin/simple", args)

describe "brief log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_brief(["run", "src/app/brief/main.spl", "--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_brief(["run", "src/app/brief/main.spl", FIXTURE_DIR, "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"files\":1")
        expect(out).to_contain("\"lines\":3")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_brief(["run", "src/app/brief/main.spl", FIXTURE_DIR, "--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_brief(["run", "src/app/brief/main.spl", FIXTURE_DIR, "--log-mode=noisy"])
        expect(code).to_equal(1)
