use std.spec.{describe, expect, slow_it}
use std.process.{run}

describe "cli_run_file inherited stdio":
    slow_it "streams stdin and stdout and propagates the delegated exit code":
        val command = "printf 'stream-me\\n' | SIMPLE_BOOTSTRAP_DRIVER=src/compiler_rust/target/release/simple bin/simple run test/fixtures/cli/inherited_stdio_child.spl"
        val result = run("/bin/sh", ["-c", command])
        expect(result.stdout).to_contain("inherited:stream-me")
        expect(result.exit_code).to_equal(23)
