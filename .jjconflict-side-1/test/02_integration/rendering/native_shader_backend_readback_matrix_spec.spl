"""Shared native shader backend readback matrix.

@tag: rendering, engine2d, backend-matrix, metal, vulkan, readback
@cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 20%
@cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl 20%
@cover src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl 20%

Runs the same strict probe + readback parity case through a small backend
config matrix:

- Vulkan on Linux expects `spirv`
- Metal on macOS expects `msl`

The host-specific branch is selected only by config. Off-host runs still assert
typed diagnostics rather than skipping the spec entirely.
"""

use std.spec.*
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.gc_async_mut.gpu.engine2d.generated_kernel_dispatch.{generated_2d_dispatch_for_backend}
use std.nogc_sync_mut.env.platform.{detect_os, is_macos}

class NativeShaderBackendConfig:
    row_name: text
    backend_name: text
    expected_shader_format: text
    execution_os: text
    expect_native_success: bool
    unavailable_gate: text
    unavailable_reason_token: text
    generated_dispatch_active: bool
    generated_source_format: text
    generated_binary_format: text
    generated_scroll_entry: text

fn _configs() -> [NativeShaderBackendConfig]:
    [
        NativeShaderBackendConfig(row_name: "vulkan-linux-native", backend_name: "vulkan", expected_shader_format: "spirv", execution_os: "linux", expect_native_success: true, unavailable_gate: "vulkan", unavailable_reason_token: "vulkan", generated_dispatch_active: false, generated_source_format: "none", generated_binary_format: "none", generated_scroll_entry: ""),
        NativeShaderBackendConfig(row_name: "metal-linux-strict-fail", backend_name: "metal", expected_shader_format: "msl", execution_os: "linux", expect_native_success: false, unavailable_gate: "macos", unavailable_reason_token: "macOS", generated_dispatch_active: true, generated_source_format: "metal-shading-language", generated_binary_format: "metallib", generated_scroll_entry: "simple_2d_scroll_u32"),
        NativeShaderBackendConfig(row_name: "metal-macos-native", backend_name: "metal", expected_shader_format: "msl", execution_os: "macos", expect_native_success: true, unavailable_gate: "macos", unavailable_reason_token: "macOS", generated_dispatch_active: true, generated_source_format: "metal-shading-language", generated_binary_format: "metallib", generated_scroll_entry: "simple_2d_scroll_u32")
    ]

fn _host_matches(config: NativeShaderBackendConfig) -> bool:
    if config.execution_os == "linux":
        return detect_os() == "linux"
    if config.execution_os == "macos":
        return is_macos()
    false

fn _pixel_checksum(pixels: [u32]) -> i64:
    var checksum: i64 = 0
    var i = 0
    while i < pixels.len():
        checksum = checksum + (pixels[i].to_i64() * ((i % 251) + 1))
        i = i + 1
    checksum

fn _pixels_equal(a: [u32], b: [u32]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _render_reference_scene(backend_name: text) -> [u32]:
    var engine = Engine2D.create_with_backend(24, 24, backend_name)
    val src = [
        0xff0000ffu32, 0xff00ff00u32,
        0xffff0000u32, 0xffffffffu32
    ]
    engine.clear(rgb(8, 12, 16))
    engine.draw_rect_filled(2, 2, 8, 6, rgb(37, 99, 235))
    engine.draw_rect(1, 1, 10, 8, rgb(168, 85, 247))
    engine.draw_line(0, 12, 23, 12, rgb(250, 204, 21), 1)
    engine.draw_circle(8, 8, 4, rgb(34, 197, 94))
    engine.draw_circle_filled(16, 8, 4, rgb(34, 197, 94))
    engine.draw_rounded_rect(2, 3, 10, 8, 2, rgb(217, 119, 6))
    engine.draw_triangle_filled(12, 16, 8, 22, 20, 22, rgb(239, 68, 68))
    engine.draw_gradient_rect(4, 2, 7, 10, 0xffff0000u32, 0xff00ff00u32)
    engine.draw_image(18, 2, 2, 2, src)
    engine.draw_image_scaled(14, 14, 4, 4, 2, 2, src)
    engine.draw_image_transform(10, 1, 2, 2, 256, 64, 0, 256, 0, 0, src)
    engine.draw_text(1, 18, "Hi", 0xffffffffu32, 8)
    engine.draw_text_bg(7, 18, "A", 0xff102030u32, 0xff80c040u32, 8)
    engine.draw_rect_blend(4, 14, 3, 3, 0x80ff0000u32)
    engine.draw_image_blend(18, 8, 2, 2, src)
    engine.draw_rect_blend_mode(9, 14, 3, 3, 0x8000ff00u32, 1)
    engine.draw_gradient_rect_h(0, 10, 6, 2, 0xffff0000u32, 0xff00ff00u32)
    engine.draw_radial_gradient(20, 18, 3, 0xffffffffu32, 0xff0000ffu32)
    engine.draw_blur_rect(2, 2, 5, 4, 1)
    engine.draw_shadow_rect(12, 3, 4, 3, 1, 1, 1, 0x80000000u32)
    engine.draw_circle_thick(6, 18, 3, 0xff00ff00u32, 2)
    engine.draw_rounded_rect_outline(10, 5, 8, 7, 2, 0xffff00ffu32, 2)
    engine.draw_ellipse(18, 18, 4, 2, 0xff80ffffu32)
    engine.draw_ellipse_filled(18, 18, 2, 1, 0xff335577u32)
    engine.draw_arc(12, 12, 6, 30, 160, 0xffaa5500u32, 2)
    engine.draw_bezier(2, 18, 6, 2, 18, 4, 21, 18, 0xff55ffaau32, 1)
    val poly_xs = [4, 12, 19, 15, 7]
    val poly_ys = [18, 4, 8, 19, 16]
    engine.draw_polygon_filled(poly_xs, poly_ys, 5, 0xffcc8844u32)
    val line_xs = [2, 8, 14, 20]
    val line_ys = [18, 6, 16, 8]
    engine.draw_polyline(line_xs, line_ys, 4, 0xff44ffaau32, 1)
    engine.draw_triangle_outline(8, 2, 3, 11, 12, 13, 0xffaa44ffu32, 1)
    engine.present()
    val pixels = engine.read_pixels()
    engine.shutdown()
    pixels

fn _render_reference_clear(backend_name: text, fill: u32) -> [u32]:
    var engine = Engine2D.create_with_backend(24, 24, backend_name)
    engine.clear(fill)
    engine.present()
    val pixels = engine.read_pixels()
    engine.shutdown()
    pixels

fn _render_reference_clip_scene(backend_name: text) -> [u32]:
    var engine = Engine2D.create_with_backend(24, 24, backend_name)
    engine.clear(0xff000000u32)
    engine.set_clip(4, 4, 6, 4)
    engine.draw_rect_filled(2, 4, 10, 3, 0xffff0000u32)
    engine.clear_clip()
    engine.present()
    val pixels = engine.read_pixels()
    engine.shutdown()
    pixels

fn _render_reference_mask_scene(backend_name: text) -> [u32]:
    var engine = Engine2D.create_with_backend(24, 24, backend_name)
    val mask = [
        0u8, 0u8, 0u8, 0u8,
        0u8, 1u8, 1u8, 0u8,
        0u8, 1u8, 1u8, 0u8,
        0u8, 0u8, 0u8, 0u8
    ]
    val src = [
        0xff0000ffu32, 0xff00ff00u32,
        0xffff0000u32, 0xffffffffu32
    ]
    engine.clear(0xff000000u32)
    engine.set_mask(mask, 4, 4)
    engine.draw_rect_filled(1, 1, 4, 4, 0xff3366ccu32)
    engine.draw_image(1, 1, 2, 2, src)
    engine.clear_mask()
    engine.present()
    val pixels = engine.read_pixels()
    engine.shutdown()
    pixels

fn _assert_shared_backend_case(config: NativeShaderBackendConfig):
    val probe = Engine2D.probe_backend(24, 24, config.backend_name)
    val repeat_probe = Engine2D.probe_backend(24, 24, config.backend_name)
    val dispatch = generated_2d_dispatch_for_backend(config.backend_name)
    expect(probe.requested_name).to_equal(config.backend_name)
    expect(probe.selected_name).to_equal(config.backend_name)
    expect(probe.api_name).to_equal(config.backend_name)
    expect(probe.backend_name).to_equal(config.backend_name)
    expect(probe.shader_format).to_equal(config.expected_shader_format)
    expect(probe.has_compute).to_equal(config.backend_name == "vulkan" or config.backend_name == "metal")
    expect(probe.has_graphics).to_equal(config.backend_name == "vulkan" or config.backend_name == "metal")
    expect(probe.diagnostic_text().len()).to_be_greater_than(0)
    expect(probe.diagnostic_text().contains("api={config.backend_name}")).to_equal(true)
    expect(probe.diagnostic_text().contains("shader={config.expected_shader_format}")).to_equal(true)
    expect(repeat_probe.requested_name).to_equal(config.backend_name)
    expect(repeat_probe.selected_name).to_equal(config.backend_name)
    expect(repeat_probe.api_name).to_equal(config.backend_name)
    expect(repeat_probe.backend_name).to_equal(config.backend_name)
    expect(repeat_probe.shader_format).to_equal(config.expected_shader_format)
    expect(repeat_probe.has_compute).to_equal(probe.has_compute)
    expect(repeat_probe.has_graphics).to_equal(probe.has_graphics)
    expect(repeat_probe.device_name).to_equal(probe.device_name)
    expect(repeat_probe.init_ms).to_equal(probe.init_ms)
    expect(repeat_probe.diagnostic_text()).to_equal(probe.diagnostic_text())
    expect(dispatch.active).to_equal(config.generated_dispatch_active)
    expect(dispatch.source_format).to_equal(config.generated_source_format)
    expect(dispatch.binary_format).to_equal(config.generated_binary_format)
    expect(dispatch.kernel_entry("scroll")).to_equal(config.generated_scroll_entry)
    if _host_matches(config):
        expect(detect_os()).to_equal(config.execution_os)
        if not config.expect_native_success:
            expect(probe.status == BackendStatus.Unavailable or probe.status == BackendStatus.Failed).to_equal(true)
            expect(probe.available).to_equal(false)
            expect(probe.device_name).to_equal("")
            expect(probe.init_ms).to_equal(0)
            expect(probe.feature_gate == config.unavailable_gate or probe.fallback_reason.contains(config.unavailable_reason_token)).to_equal(true)
            val strict_result = Engine2D.create_with_backend_strict(24, 24, config.backend_name)
            expect(strict_result.is_ok()).to_equal(false)
            val diag = strict_result.unwrap_err()
            expect(diag.requested_name).to_equal(config.backend_name)
            expect(diag.selected_name).to_equal(config.backend_name)
            expect(diag.api_name).to_equal(config.backend_name)
            expect(diag.backend_name).to_equal(config.backend_name)
            expect(diag.shader_format).to_equal(config.expected_shader_format)
            expect(diag.available).to_equal(false)
            expect(diag.has_compute).to_equal(false)
            expect(diag.has_graphics).to_equal(false)
            expect(diag.device_name).to_equal("")
            expect(diag.init_ms).to_equal(0)
            expect(diag.status == BackendStatus.Unavailable or diag.status == BackendStatus.Failed).to_equal(true)
            expect(diag.feature_gate == config.unavailable_gate or diag.fallback_reason.contains(config.unavailable_reason_token)).to_equal(true)
            expect(diag.diagnostic_text().contains("api={config.backend_name}")).to_equal(true)
            expect(diag.diagnostic_text().contains("shader={config.expected_shader_format}")).to_equal(true)
            val strict_result_repeat = Engine2D.create_with_backend_strict(24, 24, config.backend_name)
            expect(strict_result_repeat.is_ok()).to_equal(false)
            val repeat_diag = strict_result_repeat.unwrap_err()
            expect(repeat_diag.requested_name).to_equal(config.backend_name)
            expect(repeat_diag.selected_name).to_equal(config.backend_name)
            expect(repeat_diag.api_name).to_equal(config.backend_name)
            expect(repeat_diag.backend_name).to_equal(config.backend_name)
            expect(repeat_diag.shader_format).to_equal(config.expected_shader_format)
            expect(repeat_diag.available).to_equal(false)
            expect(repeat_diag.has_compute).to_equal(false)
            expect(repeat_diag.has_graphics).to_equal(false)
            expect(repeat_diag.device_name).to_equal("")
            expect(repeat_diag.init_ms).to_equal(0)
            expect(repeat_diag.status == BackendStatus.Unavailable or repeat_diag.status == BackendStatus.Failed).to_equal(true)
            expect(repeat_diag.feature_gate == config.unavailable_gate or repeat_diag.fallback_reason.contains(config.unavailable_reason_token)).to_equal(true)
            expect(repeat_diag.diagnostic_text()).to_equal(diag.diagnostic_text())
            return
        expect(probe.is_ok()).to_equal(true)
        expect(probe.available).to_equal(true)
        expect(probe.has_compute).to_equal(true)
        expect(probe.has_graphics).to_equal(true)
        expect(probe.device_name.len()).to_be_greater_than(0)
        expect(probe.init_ms).to_be_greater_than(0)
        expect(repeat_probe.is_ok()).to_equal(true)
        expect(repeat_probe.available).to_equal(true)
        expect(repeat_probe.has_compute).to_equal(true)
        expect(repeat_probe.has_graphics).to_equal(true)
        expect(repeat_probe.device_name.len()).to_be_greater_than(0)
        expect(repeat_probe.init_ms).to_be_greater_than(0)
        val result = Engine2D.create_with_backend_strict(24, 24, config.backend_name)
        expect(result.is_ok()).to_equal(true)
        var engine = result.unwrap()
        val src = [
            0xff0000ffu32, 0xff00ff00u32,
            0xffff0000u32, 0xffffffffu32
        ]
        expect(engine.backend_name()).to_equal(config.backend_name)
        val clear_fill = rgb(12, 34, 56)
        engine.clear(clear_fill)
        engine.present()
        val clear_pixels = engine.read_pixels()
        val clear_ref_pixels = _render_reference_clear("software", clear_fill)
        expect(clear_pixels.len()).to_equal(24 * 24)
        expect(_pixel_checksum(clear_pixels)).to_equal(_pixel_checksum(clear_ref_pixels))
        expect(_pixels_equal(clear_pixels, clear_ref_pixels)).to_equal(true)
        engine.clear(0xff000000u32)
        engine.set_clip(4, 4, 6, 4)
        engine.draw_rect_filled(2, 4, 10, 3, 0xffff0000u32)
        engine.clear_clip()
        engine.present()
        val clipped_pixels = engine.read_pixels()
        val clipped_ref_pixels = _render_reference_clip_scene("software")
        expect(clipped_pixels.len()).to_equal(24 * 24)
        expect(_pixel_checksum(clipped_pixels)).to_equal(_pixel_checksum(clipped_ref_pixels))
        expect(_pixels_equal(clipped_pixels, clipped_ref_pixels)).to_equal(true)
        val mask = [
            0u8, 0u8, 0u8, 0u8,
            0u8, 1u8, 1u8, 0u8,
            0u8, 1u8, 1u8, 0u8,
            0u8, 0u8, 0u8, 0u8
        ]
        engine.clear(0xff000000u32)
        engine.set_mask(mask, 4, 4)
        engine.draw_rect_filled(1, 1, 4, 4, 0xff3366ccu32)
        engine.draw_image(1, 1, 2, 2, src)
        engine.clear_mask()
        engine.present()
        val masked_pixels = engine.read_pixels()
        val masked_ref_pixels = _render_reference_mask_scene("software")
        expect(masked_pixels.len()).to_equal(24 * 24)
        expect(_pixel_checksum(masked_pixels)).to_equal(_pixel_checksum(masked_ref_pixels))
        expect(_pixels_equal(masked_pixels, masked_ref_pixels)).to_equal(true)
        engine.clear(rgb(8, 12, 16))
        engine.draw_rect_filled(2, 2, 8, 6, rgb(37, 99, 235))
        engine.draw_rect(1, 1, 10, 8, rgb(168, 85, 247))
        engine.draw_line(0, 12, 23, 12, rgb(250, 204, 21), 1)
        engine.draw_circle(8, 8, 4, rgb(34, 197, 94))
        engine.draw_circle_filled(16, 8, 4, rgb(34, 197, 94))
        engine.draw_rounded_rect(2, 3, 10, 8, 2, rgb(217, 119, 6))
        engine.draw_triangle_filled(12, 16, 8, 22, 20, 22, rgb(239, 68, 68))
        engine.draw_gradient_rect(4, 2, 7, 10, 0xffff0000u32, 0xff00ff00u32)
        engine.draw_image(18, 2, 2, 2, src)
        engine.draw_image_scaled(14, 14, 4, 4, 2, 2, src)
        engine.draw_image_transform(10, 1, 2, 2, 256, 64, 0, 256, 0, 0, src)
        engine.draw_text(1, 18, "Hi", 0xffffffffu32, 8)
        engine.draw_text_bg(7, 18, "A", 0xff102030u32, 0xff80c040u32, 8)
        engine.draw_rect_blend(4, 14, 3, 3, 0x80ff0000u32)
        engine.draw_image_blend(18, 8, 2, 2, src)
        engine.draw_rect_blend_mode(9, 14, 3, 3, 0x8000ff00u32, 1)
        engine.draw_gradient_rect_h(0, 10, 6, 2, 0xffff0000u32, 0xff00ff00u32)
        engine.draw_radial_gradient(20, 18, 3, 0xffffffffu32, 0xff0000ffu32)
        engine.draw_blur_rect(2, 2, 5, 4, 1)
        engine.draw_shadow_rect(12, 3, 4, 3, 1, 1, 1, 0x80000000u32)
        engine.draw_circle_thick(6, 18, 3, 0xff00ff00u32, 2)
        engine.draw_rounded_rect_outline(10, 5, 8, 7, 2, 0xffff00ffu32, 2)
        engine.draw_ellipse(18, 18, 4, 2, 0xff80ffffu32)
        engine.draw_ellipse_filled(18, 18, 2, 1, 0xff335577u32)
        engine.draw_arc(12, 12, 6, 30, 160, 0xffaa5500u32, 2)
        engine.draw_bezier(2, 18, 6, 2, 18, 4, 21, 18, 0xff55ffaau32, 1)
        val poly_xs = [4, 12, 19, 15, 7]
        val poly_ys = [18, 4, 8, 19, 16]
        engine.draw_polygon_filled(poly_xs, poly_ys, 5, 0xffcc8844u32)
        val line_xs = [2, 8, 14, 20]
        val line_ys = [18, 6, 16, 8]
        engine.draw_polyline(line_xs, line_ys, 4, 0xff44ffaau32, 1)
        engine.draw_triangle_outline(8, 2, 3, 11, 12, 13, 0xffaa44ffu32, 1)
        engine.present()
        val native_pixels = engine.read_pixels()
        engine.shutdown()
        val ref_pixels = _render_reference_scene("software")
        expect(native_pixels.len()).to_equal(24 * 24)
        expect(_pixel_checksum(native_pixels)).to_equal(_pixel_checksum(ref_pixels))
        expect(_pixels_equal(native_pixels, ref_pixels)).to_equal(true)
        val repeat_result = Engine2D.create_with_backend_strict(24, 24, config.backend_name)
        expect(repeat_result.is_ok()).to_equal(true)
        var repeat_engine = repeat_result.unwrap()
        repeat_engine.clear(0xff000000u32)
        repeat_engine.set_clip(4, 4, 6, 4)
        repeat_engine.draw_rect_filled(2, 4, 10, 3, 0xffff0000u32)
        repeat_engine.clear_clip()
        repeat_engine.present()
        val repeat_clipped_pixels = repeat_engine.read_pixels()
        expect(_pixels_equal(clipped_pixels, repeat_clipped_pixels)).to_equal(true)
        repeat_engine.clear(0xff000000u32)
        repeat_engine.set_mask(mask, 4, 4)
        repeat_engine.draw_rect_filled(1, 1, 4, 4, 0xff3366ccu32)
        repeat_engine.draw_image(1, 1, 2, 2, src)
        repeat_engine.clear_mask()
        repeat_engine.present()
        val repeat_masked_pixels = repeat_engine.read_pixels()
        expect(_pixels_equal(masked_pixels, repeat_masked_pixels)).to_equal(true)
        repeat_engine.clear(rgb(8, 12, 16))
        repeat_engine.draw_rect_filled(2, 2, 8, 6, rgb(37, 99, 235))
        repeat_engine.draw_rect(1, 1, 10, 8, rgb(168, 85, 247))
        repeat_engine.draw_line(0, 12, 23, 12, rgb(250, 204, 21), 1)
        repeat_engine.draw_circle(8, 8, 4, rgb(34, 197, 94))
        repeat_engine.draw_circle_filled(16, 8, 4, rgb(34, 197, 94))
        repeat_engine.draw_rounded_rect(2, 3, 10, 8, 2, rgb(217, 119, 6))
        repeat_engine.draw_triangle_filled(12, 16, 8, 22, 20, 22, rgb(239, 68, 68))
        repeat_engine.draw_gradient_rect(4, 2, 7, 10, 0xffff0000u32, 0xff00ff00u32)
        repeat_engine.draw_image(18, 2, 2, 2, src)
        repeat_engine.draw_image_scaled(14, 14, 4, 4, 2, 2, src)
        repeat_engine.draw_image_transform(10, 1, 2, 2, 256, 64, 0, 256, 0, 0, src)
        repeat_engine.draw_text(1, 18, "Hi", 0xffffffffu32, 8)
        repeat_engine.draw_text_bg(7, 18, "A", 0xff102030u32, 0xff80c040u32, 8)
        repeat_engine.draw_rect_blend(4, 14, 3, 3, 0x80ff0000u32)
        repeat_engine.draw_image_blend(18, 8, 2, 2, src)
        repeat_engine.draw_rect_blend_mode(9, 14, 3, 3, 0x8000ff00u32, 1)
        repeat_engine.draw_gradient_rect_h(0, 10, 6, 2, 0xffff0000u32, 0xff00ff00u32)
        repeat_engine.draw_radial_gradient(20, 18, 3, 0xffffffffu32, 0xff0000ffu32)
        repeat_engine.draw_blur_rect(2, 2, 5, 4, 1)
        repeat_engine.draw_shadow_rect(12, 3, 4, 3, 1, 1, 1, 0x80000000u32)
        repeat_engine.draw_circle_thick(6, 18, 3, 0xff00ff00u32, 2)
        repeat_engine.draw_rounded_rect_outline(10, 5, 8, 7, 2, 0xffff00ffu32, 2)
        repeat_engine.draw_ellipse(18, 18, 4, 2, 0xff80ffffu32)
        repeat_engine.draw_ellipse_filled(18, 18, 2, 1, 0xff335577u32)
        repeat_engine.draw_arc(12, 12, 6, 30, 160, 0xffaa5500u32, 2)
        repeat_engine.draw_bezier(2, 18, 6, 2, 18, 4, 21, 18, 0xff55ffaau32, 1)
        val repeat_poly_xs = [4, 12, 19, 15, 7]
        val repeat_poly_ys = [18, 4, 8, 19, 16]
        repeat_engine.draw_polygon_filled(repeat_poly_xs, repeat_poly_ys, 5, 0xffcc8844u32)
        val repeat_line_xs = [2, 8, 14, 20]
        val repeat_line_ys = [18, 6, 16, 8]
        repeat_engine.draw_polyline(repeat_line_xs, repeat_line_ys, 4, 0xff44ffaau32, 1)
        repeat_engine.draw_triangle_outline(8, 2, 3, 11, 12, 13, 0xffaa44ffu32, 1)
        repeat_engine.present()
        val repeat_pixels = repeat_engine.read_pixels()
        repeat_engine.shutdown()
        expect(_pixels_equal(native_pixels, repeat_pixels)).to_equal(true)
    else:
        expect(_host_matches(config)).to_equal(false)
        expect(probe.status == BackendStatus.Unavailable or probe.status == BackendStatus.Failed).to_equal(true)
        expect(probe.available).to_equal(false)
        expect(probe.device_name).to_equal("")
        expect(probe.init_ms).to_equal(0)
        expect(probe.feature_gate == config.unavailable_gate or probe.fallback_reason.contains(config.unavailable_reason_token)).to_equal(true)
        val strict_result = Engine2D.create_with_backend_strict(24, 24, config.backend_name)
        expect(strict_result.is_ok()).to_equal(false)
        val diag = strict_result.unwrap_err()
        expect(diag.requested_name).to_equal(config.backend_name)
        expect(diag.selected_name).to_equal(config.backend_name)
        expect(diag.api_name).to_equal(config.backend_name)
        expect(diag.backend_name).to_equal(config.backend_name)
        expect(diag.shader_format).to_equal(config.expected_shader_format)
        expect(diag.available).to_equal(false)
        expect(diag.has_compute).to_equal(false)
        expect(diag.has_graphics).to_equal(false)
        expect(diag.device_name).to_equal("")
        expect(diag.init_ms).to_equal(0)
        expect(diag.status == BackendStatus.Unavailable or diag.status == BackendStatus.Failed).to_equal(true)
        expect(diag.feature_gate == config.unavailable_gate or diag.fallback_reason.contains(config.unavailable_reason_token)).to_equal(true)
        expect(diag.diagnostic_text().contains("api={config.backend_name}")).to_equal(true)
        expect(diag.diagnostic_text().contains("shader={config.expected_shader_format}")).to_equal(true)
        val strict_result_repeat = Engine2D.create_with_backend_strict(24, 24, config.backend_name)
        expect(strict_result_repeat.is_ok()).to_equal(false)
        val repeat_diag = strict_result_repeat.unwrap_err()
        expect(repeat_diag.requested_name).to_equal(config.backend_name)
        expect(repeat_diag.selected_name).to_equal(config.backend_name)
        expect(repeat_diag.api_name).to_equal(config.backend_name)
        expect(repeat_diag.backend_name).to_equal(config.backend_name)
        expect(repeat_diag.shader_format).to_equal(config.expected_shader_format)
        expect(repeat_diag.available).to_equal(false)
        expect(repeat_diag.has_compute).to_equal(false)
        expect(repeat_diag.has_graphics).to_equal(false)
        expect(repeat_diag.device_name).to_equal("")
        expect(repeat_diag.init_ms).to_equal(0)
        expect(repeat_diag.status == BackendStatus.Unavailable or repeat_diag.status == BackendStatus.Failed).to_equal(true)
        expect(repeat_diag.diagnostic_text()).to_equal(diag.diagnostic_text())

describe "Native shader backend readback matrix":

    it "shares the same probe and readback case across Vulkan/Linux and Metal/macOS configs":
        for config in _configs():
            _assert_shared_backend_case(config)
