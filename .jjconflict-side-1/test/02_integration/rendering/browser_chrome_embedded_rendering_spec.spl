"""
# Browser Chrome Through Embedding (Rendering-Inside-Rendering, Lane E)

## Overview

Verifies that representative Simple Web *browser chrome* (a button, a
text-field-like box holding a value, a checked checkbox, and a dropdown/select
box) renders correctly on its own through the production software HTML/CSS
pixel renderer (`simple_web_layout_render_html_software_pixels`, the same
entry Lane B's iframe embedding calls into), and THEN proves the exact same
rendered chrome pixels still appear correctly once composited through the two
new embedding paths:

- **Lane A** (landed): `common.ui.draw_ir` batches whose
  `embedding.surface_id` is non-empty render through Engine2D's offscreen
  embedded-render-target path (`draw_ir_adv.spl`), honoring the embedding's
  offset and `opacity_milli`.
- **Lane C** (WM nested content frames): a `WmContentFrame` with
  `parent_window_id` set is rendered as a child blitted inside its parent's
  own content rect at `(offset_x, offset_y)`
  (`common.ui.window_scene_draw_ir._shared_wm_render_child_content_frames`),
  using a real `wm_gui_content_frame_from_pixels` producer (Lane C) and the
  `HeadlessHostCompositorBackend` fake backend (same idiom as
  `wm_gui_window_drawing_evidence.spl`'s capture-evidence driver).

All pixel positions/colors below were derived from the renderer's OWN real
output (verified empirically before being pinned here as expected values),
not memorized/fabricated — consistent with the fail-closed pixel-evidence
idiom used by `simple_web_iframe_embedding_spec.spl` (Lane B) and
`engine2d_embedded_surface_spec.spl` (Lane A).

**Honest scope note:** this software HTML/CSS box-model renderer does not
implement native `<input>` value/placeholder text or a text-cursor caret
glyph (that lives only in the separate widget-tree HTML string renderer under
`app.ui.render`); the "text field" here is a bordered box holding its value
as a text node, and "focus" is expressed as a distinct border color — a
real, testable style difference, not a caret.

## Syntax

Pixel assertions are the rendering oracle: HTML is rendered via
`simple_web_layout_render_html_software_pixels`, sampled/counted by color, and
the SAME rendered `[u32]` buffer is then fed into the Lane A Engine2D
executor (as a resolved Draw IR image) and the Lane C WM executor (as a
`WmContentFrame`'s pixels) to prove it survives both embeddings unchanged
and lands at the correct composited offset.
"""

# @tag: rendering, browser, chrome, embedding, engine2d, wm, draw_ir

use std.spec.*
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_software_pixels}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{
    engine2d_draw_ir_adv_batch_with_images,
    engine2d_resolved_draw_ir_image
}
use std.gpu.engine2d.color.{rgb, color_r, color_g, color_b, color_a}
use common.ui.draw_ir.{
    draw_ir_batch,
    draw_ir_embedding_config,
    draw_ir_image_command
}
use common.ui.window_scene.{
    SharedWmRenderInput,
    WmRenderMetrics,
    WmSceneRevision,
    simple_gui_internal_window,
    simple_gui_internal_window_scene
}
use common.ui.window_scene_draw_ir.{shared_wm_scene_render_context_to_backend}
use common.ui.wm_gui_content_frame.{wm_gui_content_frame_from_pixels}
use os.compositor.host_compositor_entry.{HeadlessHostCompositorBackend}

fn _count_color(pixels: [u32], color: u32) -> i32:
    var c = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] == color:
            c = c + 1
        i = i + 1
    c

val CHROME_W: i32 = 120
val CHROME_H: i32 = 70

# button: (4,4)-(44,20); "text field" box holding value "Hello": (4,28)-(74,44)
# with a red focus border; checked checkbox: (4,50)-(16,62); dropdown box
# holding "Item": (80,28)-(116,44). All absolutely positioned so their pixel
# boxes are pinned exactly, no flow-layout stacking math involved.
fn _chrome_html() -> text:
    "<html><head><style>html,body{margin:0;padding:0;background-color:#e5e7eb}.btn{position:absolute;left:4px;top:4px;width:40px;height:16px;background-color:#2563eb;border:2px solid #1e293b;color:#fbbf24;font-size:8px}.field{position:absolute;left:4px;top:28px;width:70px;height:16px;background-color:#ffffff;border:2px solid #ef4444;color:#0f172a;font-size:8px}.chk{position:absolute;left:4px;top:50px;width:12px;height:12px;background-color:#22c55e;border:1px solid #64748b}.dd{position:absolute;left:80px;top:28px;width:36px;height:16px;background-color:#f8fafc;border:1px solid #64748b;color:#334155;font-size:8px}</style></head><body><div class=\"btn\">OK</div><div class=\"field\">Hello</div><div class=\"chk\"></div><div class=\"dd\">Item</div></body></html>"

describe "Browser chrome pixel evidence (standalone)":

    it "renders the button's fill, border, and label ink at its computed box":
        val pixels = simple_web_layout_render_html_software_pixels(_chrome_html(), CHROME_W, CHROME_H)
        expect(pixels.len()).to_equal(CHROME_W * CHROME_H)
        # center of the button box (left=4,top=4,w=40,h=16)
        expect(pixels[24 + 12 * CHROME_W]).to_equal(0xFF2563EBu32)
        expect(_count_color(pixels, 0xFF1E293Bu32)).to_be_greater_than(0)
        expect(_count_color(pixels, 0xFFFBBF24u32)).to_be_greater_than(0)
        # just outside the button box on both axes: still page background
        expect(pixels[2 + 12 * CHROME_W]).to_equal(0xFFE5E7EBu32)
        expect(pixels[24 + 1 * CHROME_W]).to_equal(0xFFE5E7EBu32)

    it "renders the text-field-like box with its value ink and focused border":
        val pixels = simple_web_layout_render_html_software_pixels(_chrome_html(), CHROME_W, CHROME_H)
        # center of the field box (left=4,top=28,w=70,h=16), clear of the "Hello" glyphs
        expect(pixels[65 + 36 * CHROME_W]).to_equal(0xFFFFFFFFu32)
        expect(_count_color(pixels, 0xFFEF4444u32)).to_be_greater_than(0)
        expect(_count_color(pixels, 0xFF0F172Au32)).to_be_greater_than(0)

    it "renders the checked checkbox and the dropdown box at their computed positions":
        val pixels = simple_web_layout_render_html_software_pixels(_chrome_html(), CHROME_W, CHROME_H)
        # checkbox center (left=4,top=50,w=12,h=12)
        expect(pixels[10 + 56 * CHROME_W]).to_equal(0xFF22C55Eu32)
        # dropdown center (left=80,top=28,w=36,h=16)
        expect(pixels[98 + 36 * CHROME_W]).to_equal(0xFFF8FAFCu32)
        expect(_count_color(pixels, 0xFF334155u32)).to_be_greater_than(0)

describe "Browser chrome through Engine2D draw-IR embedding (Lane A)":

    it "composites the whole rendered chrome bitmap at the embedding's offset, byte-exact":
        val chrome_pixels = simple_web_layout_render_html_software_pixels(_chrome_html(), CHROME_W, CHROME_H)
        val chrome_image = engine2d_resolved_draw_ir_image("chrome://rendered", CHROME_W, CHROME_H, chrome_pixels)

        var engine = Engine2D.create_with_backend(150, 100, "cpu")
        engine.clear(rgb(0, 0, 0))
        val embed_x = 10
        val embed_y = 8
        val embedding = draw_ir_embedding_config("surf-chrome", "win-chrome", embed_x, embed_y, CHROME_W, CHROME_H, 0, 1000, true)
        val batch = draw_ir_batch("batch-chrome", "cpu", embedding, [
            draw_ir_image_command("chrome-img", 0, 0, CHROME_W, CHROME_H, "chrome://rendered", [])
        ])
        val result = engine2d_draw_ir_adv_batch_with_images(engine, batch, false, [chrome_image])
        val pixels = result.pixels

        expect(result.rendered_command_count).to_equal(1)
        # button center (local 24,12) lands at (embed_x+24, embed_y+12)
        expect(pixels[(embed_y + 12) * 150 + (embed_x + 24)]).to_equal(0xFF2563EBu32)
        # outside the embedded box entirely: untouched clear color
        expect(pixels[5 + 5 * 150]).to_equal(0xFF000000u32)
        expect(pixels[149 + 99 * 150]).to_equal(0xFF000000u32)
        engine.shutdown()

    it "opacity_milli=500 blends the embedded chrome bitmap over the background (same integer math as Lane A's flat-rect case)":
        val chrome_pixels = simple_web_layout_render_html_software_pixels(_chrome_html(), CHROME_W, CHROME_H)
        val chrome_image = engine2d_resolved_draw_ir_image("chrome://rendered", CHROME_W, CHROME_H, chrome_pixels)

        var engine = Engine2D.create_with_backend(CHROME_W, CHROME_H, "cpu")
        engine.clear(rgb(0, 0, 0))
        val embedding = draw_ir_embedding_config("surf-chrome2", "win-chrome2", 0, 0, CHROME_W, CHROME_H, 0, 500, false)
        val batch = draw_ir_batch("batch-chrome2", "cpu", embedding, [
            draw_ir_image_command("chrome-img2", 0, 0, CHROME_W, CHROME_H, "chrome://rendered", [])
        ])
        val result = engine2d_draw_ir_adv_batch_with_images(engine, batch, false, [chrome_image])
        val p = result.pixels[24 + 12 * CHROME_W]

        # Opaque button blue rgb(0x25,0x63,0xEB) scaled by opacity_milli=500 and
        # src-over'd onto opaque black: each channel halves (integer floor),
        # alpha stays opaque.
        expect(color_a(p)).to_equal(255)
        expect(color_r(p)).to_equal(18)
        expect(color_g(p)).to_equal(49)
        expect(color_b(p)).to_equal(117)
        engine.shutdown()

describe "Browser chrome through a WM nested content frame (Lane C)":

    it "blits chrome pixels as a child content frame inside a parent window's content rect at (offset_x, offset_y)":
        val chrome_pixels = simple_web_layout_render_html_software_pixels(_chrome_html(), CHROME_W, CHROME_H)

        val win_x = 20
        val win_y = 20
        val win_w = 220
        val win_h = 170
        val title_h = 28
        val window = simple_gui_internal_window("surf-win1", "win-1", 1u64, "app-1", "Browser", win_x, win_y, win_w, win_h, "", false, true, 1)
        val scene = simple_gui_internal_window_scene(300, 250, "cpu", [window])

        # Titled-window content rect: x=win_x+4, y=win_y+title_h+4,
        # w=win_w-8, h=win_h-title_h-8 (common.ui.window_scene_draw_ir
        # ._shared_wm_scene_window_content_rect_with_titlebar).
        val content_w = win_w - 8
        val content_h = win_h - title_h - 8
        val bg_pixels: [u32] = [0xFF334155u32; content_w * content_h]
        val top_frame = wm_gui_content_frame_from_pixels("win-1", "", 0, 0, content_w, content_h, bg_pixels, 1, 1)

        val offset_x = 8
        val offset_y = 8
        val child_frame = wm_gui_content_frame_from_pixels("win-1-chrome", "win-1", offset_x, offset_y, CHROME_W, CHROME_H, chrome_pixels, 1, 1)

        val input = SharedWmRenderInput(
            scene: scene,
            revision: WmSceneRevision(scene_revision: 1, input_revision: 0, taskbar_revision: 0),
            content_frames: [top_frame, child_frame],
            metrics: WmRenderMetrics(scale_milli: 1000, top_lane_height: 44, titlebar_height: title_h, taskbar_height: 56, min_hit_target: 44),
            t_micros: 0
        )

        var backend = HeadlessHostCompositorBackend.new(300, 250)
        val stats = shared_wm_scene_render_context_to_backend(backend, input)

        # Every content pixel (parent's own frame + the fully-in-bounds child)
        # was blitted (not clipped away, not rejected as invalid).
        expect(stats.content_pixel_count).to_equal((content_w * content_h + CHROME_W * CHROME_H).to_i64())

        val content_x = win_x + 4
        val content_y = win_y + title_h + 4
        val child_abs_x = content_x + offset_x
        val child_abs_y = content_y + offset_y
        # button center of the chrome bitmap (local 24,12), now at parent
        # content origin + child offset + local position
        val idx = (child_abs_y + 12) * 300 + (child_abs_x + 24)
        expect(backend.pixels[idx]).to_equal(0xFF2563EBu32)

        # Well clear of the child's own box, but still inside the parent's
        # own content rect: only the parent's background fill, not chrome.
        val bg_idx = (content_y + 100) * 300 + (content_x + 150)
        expect(backend.pixels[bg_idx]).to_equal(0xFF334155u32)
        # Immediately to the left of the child's box: parent background too
        # (proves the child was blitted only within its own bounds).
        val left_of_child_idx = child_abs_y * 300 + (child_abs_x - 3)
        expect(backend.pixels[left_of_child_idx]).to_equal(0xFF334155u32)
