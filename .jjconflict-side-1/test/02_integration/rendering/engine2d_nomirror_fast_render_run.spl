# Evidence harness: Engine2D no-mirror (native fast) render.
#
# Proves two things about the native-only fast render path added for
# desktop-resolution WM chrome (see
# doc/08_tracking/bug/engine2d_interpreted_mirror_dominates_render_2026-07-03.md
# and wm_scene_css_render_perf.md):
#
#  (a) CORRECTNESS — for a clean in-bounds rect scene the fast-mode Engine2D
#      (Metal GPU, mirror shrunk to 1x1, one-shot GPU readback) returns
#      byte-identical pixels to the software mirror path running the same
#      layout Draw IR. This is the readback + no-mirror correctness proof.
#
#  (b) WM ROUTING — at desktop resolution (above WM_SCENE_CSS_RENDER_PIXEL_CAP)
#      wm_scene.render_scene_to_backend now routes CSS chrome through the fast
#      Engine2D entry, not the themed direct-rect fallback. We prove it by
#      showing its output is byte-identical to rendering scene_to_html(scene)
#      through the fast entry directly, and that the CSS desktop-chrome color is
#      present in the framebuffer.
#
# Metal is required for the fast path; on non-macOS the harness reports skip and
# the gate passes.

use lib.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_draw_ir}
use lib.gc_async_mut.gpu.browser_engine.simple_web_layout_engine2d_fast.{simple_web_layout_render_html_pixels_engine2d, engine2d_fast_metal_available}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{engine2d_draw_ir_adv_composition}
use os.compositor.wm_scene.{WmSceneSpec, SceneElement, render_scene_to_backend, scene_to_html}

fn ob() -> text: "{"
fn cb() -> text: "}"

fn clean_html(w: i32, h: i32) -> text:
    val css = ".bg" + ob() + "position:absolute;background:#0f172a" + cb() + ".a" + ob() + "position:absolute;background:#2563eb" + cb() + ".b" + ob() + "position:absolute;background:#22c55e" + cb()
    var body = "<div class='bg' style='left:0px;top:0px;width:" + w.to_text() + "px;height:" + h.to_text() + "px'></div>"
    body = body + "<div class='a' style='left:10px;top:10px;width:40px;height:30px'></div>"
    body = body + "<div class='b' style='left:60px;top:20px;width:30px;height:40px'></div>"
    "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"

fn count_mismatch(a: [u32], b: [u32]) -> i32:
    var mism = 0
    var k = 0
    val n = if a.len() < b.len(): a.len() else: b.len()
    while k < n:
        if a[k] != b[k]:
            mism = mism + 1
        k = k + 1
    if a.len() != b.len():
        mism = mism + 1
    mism

fn count_color(px: [u32], color: u32) -> i32:
    var c = 0
    var k = 0
    while k < px.len():
        if px[k] == color:
            c = c + 1
        k = k + 1
    c

fn build_desktop_scene(w: i32, h: i32) -> WmSceneSpec:
    var elems: [SceneElement] = []
    elems = elems.push(SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: w, h: h, color: 0xFF0F172Au32, text: ""))
    elems = elems.push(SceneElement(kind: "decoration", x: 48, y: 42, w: 320, h: 34, color: 0xFF334155u32, text: ""))
    elems = elems.push(SceneElement(kind: "glass_panel", x: 48, y: 90, w: 320, h: 220, color: 0xFF1E293Bu32, text: ""))
    WmSceneSpec(name: "nomirror_fast_desktop", width: w, height: h, elements: elems)

fn main() -> i64:
    if not engine2d_fast_metal_available():
        print "engine2d-nomirror-fast: SKIP reason=metal-unavailable"
        print "SUMMARY: pass (skipped)"
        return 0

    # (a) correctness: fast-metal vs software on a clean in-bounds rect scene.
    val cw = 128
    val ch = 96
    val html = clean_html(cw, ch)
    val ir = simple_web_layout_render_html_draw_ir(html, cw, ch)
    var sw_eng = Engine2D.create_with_backend(cw, ch, "software")
    sw_eng.clear(0u32)
    val sw_res = engine2d_draw_ir_adv_composition(sw_eng, ir, true)
    val sw_px = sw_res.pixels
    sw_eng.shutdown()
    val fast_px = simple_web_layout_render_html_pixels_engine2d(html, cw, ch, "metal")
    val corr_mism = count_mismatch(sw_px, fast_px)
    val corr_full = fast_px.len() == (cw * ch)
    if corr_mism == 0 and corr_full:
        print "correctness: MATCH mism=0 px={fast_px.len()}"
    else:
        print "correctness: DIVERGE mism={corr_mism} px={fast_px.len()}"

    # (b) wm routing at desktop resolution (above the CSS pixel cap).
    val dw = 1024
    val dh = 768
    val scene = build_desktop_scene(dw, dh)
    val routed = render_scene_to_backend(scene, nil)
    val expected = simple_web_layout_render_html_pixels_engine2d(scene_to_html(scene), dw, dh, "metal")
    val route_mism = count_mismatch(routed, expected)
    val route_full = routed.len() == (dw * dh)
    val chrome_hits = count_color(routed, 0xFF0F172Au32)
    val route_ok = (route_mism == 0) and route_full and (chrome_hits > 0)
    if route_ok:
        print "wm_routing: MATCH mism=0 px={routed.len()} css_desktop_chrome_px={chrome_hits}"
    else:
        print "wm_routing: DIVERGE mism={route_mism} px={routed.len()} css_desktop_chrome_px={chrome_hits}"

    if corr_mism == 0 and corr_full and route_ok:
        print "SUMMARY: pass"
        return 0
    print "SUMMARY: fail"
    1
