## Smoke spec for the SimpleOS cross-clang toolchain setup.
##
## Gates on the canonical build/os/llvm cross clang artifact. If absent, all
## it blocks return a skip marker — the suite stays green on machines that
## have not built the cross toolchain.
##
## When LLVM_BUILD is set this spec verifies:
##   1. The cross clang binary exists at build/os/llvm/cross-x86_64-unknown-simpleos/bin/clang
##   2. If that clang is host-runnable, --print-target-triple reports x86_64-unknown-simpleos
##   3. If host-runnable, compiling examples/09_embedded/simpleos_hello_c/hello.c exits 0
##   4. If host-runnable, llvm-nm on the resulting .o shows the 'main' symbol
##   5. If host-runnable and the sysroot is present, ld.lld links a SimpleOS ELF
##   6. If host-runnable and the sysroot is present, clang driver links a
##      compiler-rt builtins user.
##
## Run:
##   bin/simple test test/integration/os/port/llvm/smoke_clang_spec.spl

use std.text
use std.process
use std.spec

val HELLO_C = "examples/09_embedded/simpleos_hello_c/hello.c"
val OUT_O   = "/tmp/smoke_clang_hello.o"
val OUT_ELF = "/tmp/smoke_clang_hello.elf"
val DRIVER_ELF = "/tmp/smoke_clang_driver_hello.elf"
val BUILTINS_C = "/tmp/smoke_clang_builtins_probe.c"
val BUILTINS_ELF = "/tmp/smoke_clang_builtins_probe.elf"
val TRIPLE_TXT = "/tmp/smoke_clang_triple.txt"
val LLVM_BIN = "build/os/llvm/cross-x86_64-unknown-simpleos/bin"
val AARCH64_LLVM_BIN = "build/os/llvm/cross-aarch64-unknown-simpleos/bin"

fn sysroot_dir() -> text:
    "build/os/sysroot"

fn sysroot_target_triple() -> text:
    process.run("cat", ["{sysroot_dir()}/share/simpleos/target-triple.txt"]).stdout.trim()

fn llvm_tool(name: text) -> text:
    "{LLVM_BIN}/{name}"

fn aarch64_llvm_tool(name: text) -> text:
    "{AARCH64_LLVM_BIN}/{name}"

fn check(condition: bool):
    expect(condition).to_equal(true)

fn regular_file_exists(path: text) -> bool:
    process.run("test", ["-f", path]).exit_code == 0

fn llvm_build_configured() -> bool:
    regular_file_exists(llvm_tool("clang"))

fn clang_probe() -> i64:
    val clang = llvm_tool("clang")
    val cmd = "timeout 5s {clang} --print-target-triple > {TRIPLE_TXT}"
    process.run("sh", ["-c", cmd]).exit_code

fn cross_clang_host_runnable() -> bool:
    if !llvm_build_configured():
        return false
    if clang_probe() != 0:
        return false
    process.run("cat", [TRIPLE_TXT]).stdout.trim() == "x86_64-unknown-simpleos"

fn cross_clang_guest_only() -> bool:
    val code = clang_probe()
    code == 126 or code == 127

describe "SimpleOS cross clang smoke":
    """Env-gated checks for a working clang cross-toolchain targeting x86_64-unknown-simpleos."""

    it "cross clang binary exists at canonical build path":
        """Skip when cross clang is absent; otherwise assert the binary is on disk."""
        if llvm_build_configured():
            check(regular_file_exists(llvm_tool("clang")))

    it "reports x86_64-unknown-simpleos as the target triple":
        """Skip when cross clang is absent or is a SimpleOS guest executable."""
        if llvm_build_configured() and !cross_clang_guest_only():
            val code = clang_probe()
            expect(code).to_equal(0)
            val triple = process.run("cat", [TRIPLE_TXT]).stdout.trim()
            expect(triple).to_equal("x86_64-unknown-simpleos")

    it "compiles hello.c to x86_64-unknown-simpleos .o with exit 0":
        """Skip when cross clang is absent or is a SimpleOS guest executable."""
        if cross_clang_host_runnable():
            val result = process.run(llvm_tool("clang"), [
                "--target=x86_64-unknown-simpleos",
                "-c",
                HELLO_C,
                "-o",
                OUT_O,
            ])
            expect(result.exit_code).to_equal(0)
            check(regular_file_exists(OUT_O))

    it "llvm-nm on the .o shows 'main' symbol":
        """Skip when cross clang is absent or is a SimpleOS guest executable."""
        if cross_clang_host_runnable():
            val result = process.run(llvm_tool("llvm-nm"), [OUT_O])
            expect(result.exit_code).to_equal(0)
            check(result.stdout.contains("main"))

    it "links the object into a SimpleOS ELF when the sysroot is available":
        """Skip when cross clang is absent, is guest-only, or the sysroot is absent."""
        if cross_clang_host_runnable():
            val sysroot = sysroot_dir()
            if regular_file_exists("{sysroot}/share/simpleos/simpleos.ld"):
                expect(sysroot_target_triple()).to_equal("x86_64-unknown-simpleos")
                val stale = process.run("sh", ["-c", "printf stale > {OUT_ELF}"])
                expect(stale.exit_code).to_equal(0)
                val result = process.run(llvm_tool("ld.lld"), [
                    "-T", "{sysroot}/share/simpleos/simpleos.ld",
                    "{sysroot}/lib/crt0.o",
                    OUT_O,
                    "-L", "{sysroot}/lib",
                    "-lsimpleos_c",
                    "-o", OUT_ELF,
                ])
                expect(result.exit_code).to_equal(0)
                check(regular_file_exists(OUT_ELF))

    it "driver compiles and links hello.c through canonical clang":
        """Skip when cross clang is absent, is guest-only, or the sysroot is absent."""
        if cross_clang_host_runnable():
            val sysroot = sysroot_dir()
            if regular_file_exists("{sysroot}/share/simpleos/simpleos.ld"):
                expect(sysroot_target_triple()).to_equal("x86_64-unknown-simpleos")
                val result = process.run(llvm_tool("clang"), [
                    "--target=x86_64-unknown-simpleos",
                    HELLO_C,
                    "-o", DRIVER_ELF,
                ])
                expect(result.exit_code).to_equal(0)
                check(regular_file_exists(DRIVER_ELF))

    it "driver links compiler-rt builtins from the staged resource dir":
        """Skip when cross clang is absent, is guest-only, or the sysroot is absent."""
        if cross_clang_host_runnable():
            val sysroot = sysroot_dir()
            if regular_file_exists("{sysroot}/share/simpleos/simpleos.ld"):
                expect(sysroot_target_triple()).to_equal("x86_64-unknown-simpleos")
                val source = "__int128 div128(__int128 a,__int128 b){return a/b;} int main(void){return (int)div128(((__int128)1<<80),3);}"
                val write = process.run("sh", ["-c", "printf '%s\n' '{source}' > {BUILTINS_C}"])
                expect(write.exit_code).to_equal(0)
                val result = process.run(llvm_tool("clang"), [
                    "--target=x86_64-unknown-simpleos",
                    BUILTINS_C,
                    "-o", BUILTINS_ELF,
                ])
                expect(result.exit_code).to_equal(0)
                check(regular_file_exists(BUILTINS_ELF))

    it "aarch64 stage 2 artifacts and seeded builtins are present when built":
        """Skip when aarch64 stage 2 is absent; otherwise pin the current artifact contract."""
        if regular_file_exists(aarch64_llvm_tool("clang-20")):
            check(regular_file_exists(aarch64_llvm_tool("clang")))
            check(regular_file_exists(aarch64_llvm_tool("lld")))
            val clang_file = process.run("file", [aarch64_llvm_tool("clang-20")])
            val lld_file = process.run("file", [aarch64_llvm_tool("lld")])
            expect(clang_file.exit_code).to_equal(0)
            expect(lld_file.exit_code).to_equal(0)
            check(clang_file.stdout.contains("ARM aarch64"))
            check(lld_file.stdout.contains("ARM aarch64"))

            val builtins = "{sysroot_dir()}/lib/libclang_rt.builtins-aarch64.a"
            check(regular_file_exists(builtins))
            val builtins_file = process.run("file", [builtins])
            expect(builtins_file.exit_code).to_equal(0)
            check(builtins_file.stdout.contains("current ar archive"))
