# Direct typed-u64 runtime setter repro.
#
# Rendering code should normally use array assignment syntax. This file exists
# only to isolate whether LLVM native corruption is in index-assignment lowering
# or in the runtime-call ABI for typed array setters.

extern fn rt_array_new_with_cap_u64(cap: i64) -> [u64]
extern fn rt_typed_words_u64_push(array: [u64], value: i64) -> bool
extern fn rt_typed_words_u64_set(array: [u64], index: i64, value: i64) -> bool

fn main():
    var data: [u64] = rt_array_new_with_cap_u64(256)
    var i: i64 = 0
    while i < 256:
        rt_typed_words_u64_push(data, 0xFF000000)
        i = i + 1

    rt_typed_words_u64_set(data, 0, 0xFF0000FF)
    rt_typed_words_u64_set(data, 64, 0xFF00FF00)
    rt_typed_words_u64_set(data, 128, 0xFFFF0000)
    rt_typed_words_u64_set(data, 192, 0xFF00FFFF)
    rt_typed_words_u64_set(data, 240, 0xFF00FFFF)

    print "TYPED_U64_SET_DIRECT p0={data[0]} p64={data[64]} p128={data[128]} p192={data[192]} p240={data[240]}"
