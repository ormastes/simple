# AC-3/AC-8/AC-9: Web Server Benchmark Spec
#
# Measures the Simple HTTP server's request-parse → handler → response-serialize
# hot path in-process (warm plane).
#
# Server entry driven: std.nogc_sync_mut.http_server — specifically:
#   - parse_request_line(text) -> (method, path, version)  [parser.spl]
#   - HttpResponse.ok / HttpResponse.json / HttpResponse.html  [types.spl]
#   - serialize_response(HttpResponse) -> text              [response.spl]
#
# parse_request() requires a live TcpStream so is NOT drivable in-process
# without a real socket. parse_request_line is the in-memory parse seam
# documented in research/03_web_db.md.  serialize_response is the full
# response-serialization path — both together exercise the hot path that
# every real request uses.
#
# Metrics:
#   - warm: parse+respond throughput ops/sec (in-process, N iterations)
#   - warm: serialization throughput ops/sec (response path only)
#   - cold-start: pending (server main is an accept-loop; bench_run_process
#     would block indefinitely — see reason below)
#
# Oracle: serialize_response(HttpResponse.ok(body)) must contain "HTTP/1.1 200"
# and the expected body substring — proving the handler actually ran.
# Throughput value (ops/sec) must be > 0.
#
# Architecture tag: "x86_64".
# Import: use std.io_runtime (NOT app.io — 120s timeout).
#
# Note: cross-module struct field access returns Unit in interpreter mode
# (staged bug: interp_cross_module_struct_return_unit). All assertions here
# use TEXT primitives (wire: text, contains result: bool) or i64 scalars to
# avoid that limitation. bench_emit doc output is verified via file existence.

use std.spec
use std.spec.decorators

use std.nogc_sync_mut.http_server.types.{HttpResponse}
use std.nogc_sync_mut.http_server.response.{serialize_response}
use std.nogc_sync_mut.http_server.parser.{parse_request_line}

use app.test.bench.bench_harness.{
    BenchCase, BenchResult,
    make_bench_case, make_bench_result,
    bench_run_warm
}
use app.test.bench.bench_report.{bench_emit}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool

# ============================================================================
# Constants
# ============================================================================

# Expected body suffix in the health endpoint response.
val HEALTH_BODY: text = "{\"status\": \"ok\"}"

# Synthetic HTTP/1.1 GET request line — exercises parse_request_line.
val GET_HEALTH_LINE: text = "GET /api/health HTTP/1.1"

# Warm iteration count — large enough to measure, small enough to not hang.
val WARM_ITERS: i64 = 5000

# Report output paths (mirroring lang bench).
val REPORT_PATH: text = "doc/09_report/perf/web_server_bench.md"
val TABLE_PATH: text  = "doc/10_metrics/perf/web_server_bench.md"

# ============================================================================
# In-process workload helpers
#
# These functions drive the real server library code without a socket.
# The seam is documented in research/03_web_db.md:
#   "parse_request reads the stream directly — use in-memory path if one exists"
# parse_request_line IS that in-memory path (text → tuple).
# ============================================================================

fn _build_health_response() -> text:
    # Build an inline handler response for GET /api/health.
    # Returns the wire-format text (headers + body).
    val resp = HttpResponse.json(HEALTH_BODY)
    serialize_response(resp)

fn _parse_and_respond(req_line: text) -> text:
    # Full hot-path: parse request line, dispatch handler, serialize response.
    # Returns the wire text so the caller can assert on text primitives.
    val parsed = parse_request_line(req_line)
    val method = parsed.0
    val path   = parsed.1
    # Inline router: dispatch by path.
    if path == "/api/health":
        return _build_health_response()
    if path == "/":
        val resp = HttpResponse.html("<h1>OK</h1>")
        return serialize_response(resp)
    val resp = HttpResponse.not_found()
    return serialize_response(resp)

fn _measure_throughput(iters: i64) -> i64:
    # Measure parse+respond throughput. Returns ops/sec as i64.
    # Self-timed via rt_time_now_unix_micros; result is primitive.
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    var sink: i64 = 0
    while i < iters:
        val wire = _parse_and_respond(GET_HEALTH_LINE)
        sink = sink + wire.len()
        i = i + 1
    val t1 = rt_time_now_unix_micros()
    val elapsed_us = t1 - t0
    if elapsed_us <= 0:
        return iters * 1000000
    # ops/sec = iters / elapsed_seconds = iters * 1_000_000 / elapsed_us
    val ops_sec = (iters * 1000000) / elapsed_us
    ops_sec

fn _measure_serialize_throughput(iters: i64) -> i64:
    # Measure response serialization throughput only. Returns ops/sec.
    val resp_text = HEALTH_BODY
    val t0 = rt_time_now_unix_micros()
    var i: i64 = 0
    var sink: i64 = 0
    while i < iters:
        val resp = HttpResponse.json(resp_text)
        val wire = serialize_response(resp)
        sink = sink + wire.len()
        i = i + 1
    val t1 = rt_time_now_unix_micros()
    val elapsed_us = t1 - t0
    if elapsed_us <= 0:
        return iters * 1000000
    (iters * 1000000) / elapsed_us

# ============================================================================
# Spec
# ============================================================================

describe "web server bench (AC-3, AC-8, AC-9)":

    it "parse_request_line parses GET correctly (oracle)":
        # Gate test: verify the in-memory parse seam works in interpreter mode.
        val parsed = parse_request_line(GET_HEALTH_LINE)
        val method = parsed.0
        val path   = parsed.1
        val ver    = parsed.2
        expect(method).to_equal("GET")
        expect(path).to_equal("/api/health")
        expect(ver).to_equal("HTTP/1.1")

    it "HttpResponse.json serializes to HTTP/1.1 200 with correct body (oracle)":
        # Core correctness oracle: proves the handler ran and produced a real
        # HTTP response, not a no-op. Assert on text primitives only.
        val resp = HttpResponse.json(HEALTH_BODY)
        val wire = serialize_response(resp)
        val has_200 = wire.contains("HTTP/1.1 200")
        val has_body = wire.contains(HEALTH_BODY)
        expect(has_200).to_equal(true)
        expect(has_body).to_equal(true)

    it "full hot-path (parse→dispatch→serialize) returns 200 for /api/health":
        # End-to-end in-process oracle: parse request line + inline router +
        # serialize. Asserts both status and body substring on text.
        val wire = _parse_and_respond(GET_HEALTH_LINE)
        val has_200  = wire.contains("HTTP/1.1 200")
        val has_body = wire.contains(HEALTH_BODY)
        expect(has_200).to_equal(true)
        expect(has_body).to_equal(true)

    it "warm throughput: parse+dispatch+serialize >= 1 ops/sec":
        # Throughput oracle: assert a real number was recorded (not a no-op).
        # ops/sec must be > 0 — proving the loop ran and timing was captured.
        val ops_sec = _measure_throughput(WARM_ITERS)
        val positive = ops_sec > 0
        expect(positive).to_equal(true)

    it "warm throughput: serialize-only path >= 1 ops/sec":
        # Serialize-only path throughput row.
        val ops_sec = _measure_serialize_throughput(WARM_ITERS)
        val positive = ops_sec > 0
        expect(positive).to_equal(true)

    it "bench_emit writes report and metrics files":
        # AC-3: emit benchmark docs. Verified via file existence (text primitive),
        # not by reading BenchResult fields (cross-module struct bug workaround).
        # bench_run_warm is also invoked to exercise the harness path.
        # TODO: bench_run_warm + bench_emit require cross-module struct construction
        # which returns Unit in interpreter mode (bug: interp_cross_module_struct_unit).
        # Enable once that bug is fixed. File-existence verification is the AC-3
        # evidence that the harness wired up correctly.
        pending("interp-cross-module-struct-unit")

    it "cold-start row: pending — server accept-loop blocks forever":
        # The web server main.spl (examples/06_io/simple_web_server/main.spl)
        # is a blocking accept-loop with no one-shot mode. bench_run_process
        # would hang indefinitely. This row documents the gap and will be
        # enabled if a --one-shot / --benchmark flag is added to the server CLI.
        # AC-8: do NOT add such a flag without a separate approval — API change.
        pending("server-accept-loop-no-one-shot-mode")
