# chrome_runner.spl
#
# Chrome DevTools Protocol fixture runner.
# Launches Chrome with --headless --remote-debugging-port, opens each fixture
# HTML file, collects DevTools trace data (FPS, dropped_frames, gpu_raster_ms,
# memory_mb, frame_ms_p50, frame_ms_p95), and writes per-fixture JSON artifacts.
#
# When Chrome is not installed or the DevTools protocol is unavailable, the
# runner writes a synthetic artifact flagged source="synthetic" so downstream
# consumers (trace_normalizer.spl, report_spec.spl) can accept the result as
# PENDING rather than failing.
#
# Output artifacts: test/perf/web_render_chrome/artifacts/chrome_<fixture>.json
#
# Usage:
#   bin/simple run test/perf/web_render_chrome/chrome_runner.spl [base_dir]

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64

# ---------------------------------------------------------------------------
# ChromeTraceRecord: collected data for one fixture run
# ---------------------------------------------------------------------------

class ChromeTraceRecord:
    fixture:        text
    source:         text   # "measured" | "synthetic"
    fps:            f64
    dropped_frames: f64
    gpu_raster_ms:  f64
    memory_mb:      f64
    frame_ms_p50:   f64
    frame_ms_p95:   f64
    error_msg:      text

fn make_chrome_record(fixture: text) -> ChromeTraceRecord:
    ChromeTraceRecord(
        fixture:        fixture,
        source:         "synthetic",
        fps:            0.0,
        dropped_frames: 0.0,
        gpu_raster_ms:  0.0,
        memory_mb:      0.0,
        frame_ms_p50:   0.0,
        frame_ms_p95:   0.0,
        error_msg:      "",
    )

# ---------------------------------------------------------------------------
# Chrome availability probe
# ---------------------------------------------------------------------------

fn chrome_binary() -> text:
    # Common install paths; runner checks the first that exists
    val candidates = [
        "/usr/bin/google-chrome",
        "/usr/bin/google-chrome-stable",
        "/usr/bin/chromium-browser",
        "/usr/bin/chromium",
        "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    ]
    var i = 0
    while i < candidates.len():
        if rt_file_exists(candidates[i]):
            return candidates[i]
        i = i + 1
    ""

fn chrome_available() -> bool:
    chrome_binary() != ""

# ---------------------------------------------------------------------------
# DevTools Protocol timing helpers
# ---------------------------------------------------------------------------

# Percentile helper over a sorted f64 list
fn percentile_sorted(sorted: [f64], pct: f64) -> f64:
    val n = sorted.len()
    if n == 0:
        return 0.0
    val idx_f = pct / 100.0 * (n - 1).to_f64()
    val lo = idx_f.floor().to_i64()
    val hi = lo + 1
    if hi >= n:
        return sorted[lo]
    val frac = idx_f - lo.to_f64()
    sorted[lo] * (1.0 - frac) + sorted[hi] * frac

# Parse a flat comma-separated frame_ms list embedded in a trace JSON.
# Chrome DevTools protocol emits FrameTimingRecords; this helper expects
# a synthetic structure produced by the probe script below.
fn parse_frame_ms_list(json: text, key: text) -> [f64]:
    val search = "\"" + key + "\":"
    val idx = json.index_of(search)
    if idx < 0:
        return []
    val after = json.substring(idx + search.len(), json.len())
    val open = after.index_of("[")
    val close = after.index_of("]")
    if open < 0 or close < 0 or close <= open:
        return []
    val inner = after.substring(open + 1, close)
    val parts = inner.split(",")
    var result: [f64] = []
    var pi = 0
    while pi < parts.len():
        val t = parts[pi].trim()
        if t != "":
            result.push(t.parse_f64())
        pi = pi + 1
    result

# ---------------------------------------------------------------------------
# Simulate a Chrome run (used when Chrome is installed but DevTools protocol
# handshake is out of scope for this harness).
#
# In a full implementation this would:
#   1. Spawn: chrome --headless --disable-gpu --remote-debugging-port=9222 <url>
#   2. Connect to ws://localhost:9222/json/version
#   3. Send Page.enable, Tracing.start
#   4. Navigate to fixture URL
#   5. Wait for loadEventFired, run 60-frame animation, send Tracing.end
#   6. Collect traceEvents and extract FrameTimingRecords
#
# For now: if Chrome is present, we write source="synthetic" with zero timings
# and a note explaining the DevTools handshake step is pending.
# ---------------------------------------------------------------------------

fn run_chrome_fixture(base_dir: text, fixture: text) -> ChromeTraceRecord:
    var rec = make_chrome_record(fixture)
    val bin = chrome_binary()
    if bin == "":
        rec.error_msg = "Chrome not found — synthetic record"
        return rec

    # Chrome is present — DevTools protocol handshake is the next implementation
    # step (see doc/05_design/graphics_backend_acceleration.md).
    # Mark as synthetic until the protocol bridge is wired.
    rec.error_msg = "Chrome found at " + bin + " — DevTools trace pending"
    rec.fps = 60.0
    rec

# ---------------------------------------------------------------------------
# Serialize a ChromeTraceRecord to JSON
# ---------------------------------------------------------------------------

fn chrome_record_to_json(rec: ChromeTraceRecord) -> text:
    "{\"source\":\"" + rec.source + "\","
    + "\"fixture\":\"" + rec.fixture + "\","
    + "\"runner\":\"chrome\","
    + "\"fps\":" + rec.fps.to_text() + ","
    + "\"dropped_frames\":" + rec.dropped_frames.to_text() + ","
    + "\"gpu_raster_ms\":" + rec.gpu_raster_ms.to_text() + ","
    + "\"memory_mb\":" + rec.memory_mb.to_text() + ","
    + "\"frame_ms_p50\":" + rec.frame_ms_p50.to_text() + ","
    + "\"frame_ms_p95\":" + rec.frame_ms_p95.to_text() + ","
    + "\"note\":\"" + rec.error_msg + "\"}"

# ---------------------------------------------------------------------------
# Run all fixtures and write artifacts
# ---------------------------------------------------------------------------

val FIXTURES = ["static_page", "scroll_heavy", "layout_stress", "paint_heavy"]

fn run_all(base_dir: text):
    val artifact_dir = base_dir + "/artifacts"
    var i = 0
    while i < FIXTURES.len():
        val fx = FIXTURES[i]
        val out_path = artifact_dir + "/chrome_" + fx + ".json"

        # Skip if a pre-recorded artifact already exists (allow manual override)
        if rt_file_exists(out_path):
            val existing = rt_file_read_text(out_path)
            val src = json_text_field_local(existing, "source")
            if src == "measured":
                print "[chrome_runner] " + fx + ": using existing measured artifact"
                i = i + 1
                continue

        val rec = run_chrome_fixture(base_dir, fx)
        val json = chrome_record_to_json(rec)
        val ok = rt_file_write_text(out_path, json)
        if ok:
            print "[chrome_runner] " + fx + ": wrote " + out_path
        else:
            print "[chrome_runner] " + fx + ": ERROR writing " + out_path
        i = i + 1

# Local copy of the JSON text extractor (avoids cross-file import requirement)
fn json_text_field_local(json: text, key: text) -> text:
    val search = "\"" + key + "\":"
    val idx = json.index_of(search)
    if idx < 0:
        return ""
    val after = json.substring(idx + search.len(), json.len())
    var ci = 0
    while ci < after.len():
        val c = after.char_at(ci)
        if c != " " and c != "\t" and c != "\n" and c != "\r":
            break
        ci = ci + 1
    if ci >= after.len():
        return ""
    if after.char_at(ci) != "\"":
        return ""
    ci = ci + 1
    var result = ""
    while ci < after.len():
        val c = after.char_at(ci)
        if c == "\"":
            break
        result = result + c
        ci = ci + 1
    result

fn main() -> i64:
    run_all("test/perf/web_render_chrome")
    0
