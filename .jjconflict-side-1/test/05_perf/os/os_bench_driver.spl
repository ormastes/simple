# os_bench_driver.spl — emits an OS perf benchmark doc (host-proxy, x86_64).
#
# Measures fs write/read throughput + exec/spawn latency entirely in-module
# (avoids any cross-module struct return). Emits primitive rows via bench_emit_rows.
# Run:  bin/simple run test/05_perf/os/os_bench_driver.spl
# Writes: doc/09_report/perf/perf_baseline_os_2026-06-13.md
#         doc/10_metrics/perf/perf_baseline_os_table.md

use app.test.bench.bench_report.{bench_emit_rows, bench_find_simple_bin, bench_smf_capture, bench_extract_us}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _i64_to_text_local(n: i64) -> text:
    if n == 0:
        return "0"
    var digits: [text] = []
    var v = n
    val negative = v < 0
    if negative:
        v = 0 - v
    while v > 0:
        val d = v % 10
        val ch: text = if d == 0: "0"
            elif d == 1: "1"
            elif d == 2: "2"
            elif d == 3: "3"
            elif d == 4: "4"
            elif d == 5: "5"
            elif d == 6: "6"
            elif d == 7: "7"
            elif d == 8: "8"
            else: "9"
        digits.push(ch)
        v = v / 10
    var result = if negative: "-" else: ""
    var di: i64 = digits.len() - 1
    while di >= 0:
        result = result + digits[di]
        di = di - 1
    result

fn _block_1kb() -> text:
    # 64-char unit × 16 = 1024 bytes
    val unit64 = "0123456789012345678901234567890123456789012345678901234567890123"
    var s = ""
    var i: i64 = 0
    while i < 16:
        s = s + unit64
        i = i + 1
    s

fn _payload(kb: i64) -> text:
    val blk = _block_1kb()
    var s = ""
    var i: i64 = 0
    while i < kb:
        s = s + blk
        i = i + 1
    s

fn main():
    val date_str = "2026-06-13"
    val arch = "x86_64"
    val mode = "host_x86_64"
    val report_path = "doc/09_report/perf/perf_baseline_os_2026-06-13.md"
    val table_path  = "doc/10_metrics/perf/perf_baseline_os_table.md"

    val kb: i64 = 10
    val payload = _payload(kb)
    val nbytes = payload.len()
    val path = "build/test-artifacts/os_bench_probe.txt"

    var names:   [text] = []
    var modes:   [text] = []
    var metrics: [text] = []
    var values:  [i64]  = []
    var units:   [text] = []

    # --- fs write throughput ---
    val write_iters: i64 = 20
    print("Running fs_write(" + _i64_to_text_local(kb) + "KB) x" + _i64_to_text_local(write_iters) + " ...")
    val w0 = rt_time_now_unix_micros()
    var wi: i64 = 0
    while wi < write_iters:
        val _ok = rt_file_write_text(path, payload)
        wi = wi + 1
    val w_us = rt_time_now_unix_micros() - w0

    # --- fs read throughput + correctness oracle ---
    val read_iters: i64 = 20
    print("Running fs_read(" + _i64_to_text_local(kb) + "KB) x" + _i64_to_text_local(read_iters) + " ...")
    val r0 = rt_time_now_unix_micros()
    var ri: i64 = 0
    var last_read = ""
    while ri < read_iters:
        last_read = rt_file_read_text(path)
        ri = ri + 1
    val r_us = rt_time_now_unix_micros() - r0

    # ABSOLUTE ORACLE: bytes written == bytes read AND content matches.
    val read_len = last_read.len()
    val content_ok = last_read == payload
    if read_len != nbytes or not content_ok:
        print("ORACLE FAILED: wrote " + _i64_to_text_local(nbytes) + " read " + _i64_to_text_local(read_len) + " match=" + content_ok.to_text())
        return

    # write rows
    val total_kb_w = kb * write_iters
    val w_kb_per_s: i64 = if w_us > 0: (total_kb_w * 1000000) / w_us else: 0
    val w_us_per_op: i64 = if write_iters > 0: w_us / write_iters else: 0
    val w_name = "fs_write_" + _i64_to_text_local(kb) + "kb"
    names.push(w_name)
    modes.push(mode)
    metrics.push("throughput_kb_per_s")
    values.push(w_kb_per_s)
    units.push("KB/s")
    names.push(w_name)
    modes.push(mode)
    metrics.push("latency_us_per_op")
    values.push(w_us_per_op)
    units.push("us/op")

    # read rows (note: page-cache-warm; latency may round to small int)
    val total_kb_r = kb * read_iters
    val r_kb_per_s: i64 = if r_us > 0: (total_kb_r * 1000000) / r_us else: 0
    val r_us_per_op: i64 = if read_iters > 0: r_us / read_iters else: 0
    val r_name = "fs_read_" + _i64_to_text_local(kb) + "kb"
    names.push(r_name)
    modes.push(mode)
    metrics.push("throughput_kb_per_s")
    values.push(r_kb_per_s)
    units.push("KB/s")
    names.push(r_name)
    modes.push(mode)
    metrics.push("latency_us_per_op")
    values.push(r_us_per_op)
    units.push("us/op")

    # --- exec/spawn latency ---
    val spawn_iters: i64 = 20
    print("Running exec_spawn(/bin/echo) x" + _i64_to_text_local(spawn_iters) + " ...")
    val s0 = rt_time_now_unix_micros()
    var si: i64 = 0
    while si < spawn_iters:
        val (_o, _e, _c) = rt_process_run("/bin/echo", ["x"])
        si = si + 1
    val s_us = rt_time_now_unix_micros() - s0
    val spawn_us_per: i64 = if spawn_iters > 0: s_us / spawn_iters else: 0
    names.push("exec_spawn_echo")
    modes.push(mode)
    metrics.push("latency_us_per_spawn")
    values.push(spawn_us_per)
    units.push("us/spawn")

    # --- smf rows: compile+run os_smf_workload in standalone SMF and parse ---
    # Graceful skip (never fake) when the compiled SMF produced no RESULT lines.
    val smf_iters: i64 = 20
    val simple_bin = bench_find_simple_bin()
    val smf_out = bench_smf_capture(simple_bin, "test/05_perf/os/os_smf_workload.spl", "build/test-artifacts/os_smf_workload.smf")
    val smf_w_us = bench_extract_us(smf_out, "fs_write_10kb")
    val smf_r_us = bench_extract_us(smf_out, "fs_read_10kb")
    if smf_w_us >= 0 and smf_r_us >= 0:
        val smf_w_per: i64 = if smf_iters > 0: smf_w_us / smf_iters else: 0
        val smf_r_per: i64 = if smf_iters > 0: smf_r_us / smf_iters else: 0
        names.push("fs_write_10kb")
        modes.push("smf")
        metrics.push("latency_us_per_op")
        values.push(smf_w_per)
        units.push("us/op")
        names.push("fs_read_10kb")
        modes.push("smf")
        metrics.push("latency_us_per_op")
        values.push(smf_r_per)
        units.push("us/op")
        print("smf fs_write us/op=" + _i64_to_text_local(smf_w_per) + "  smf fs_read us/op=" + _i64_to_text_local(smf_r_per))
    else:
        print("smf capture empty — skipping smf rows (no fake data)")

    print("fs_write KB/s=" + _i64_to_text_local(w_kb_per_s) + "  fs_read KB/s=" + _i64_to_text_local(r_kb_per_s) + "  spawn us=" + _i64_to_text_local(spawn_us_per))
    print("Writing OS benchmark docs ...")
    val ok = bench_emit_rows(names, modes, metrics, values, units, arch, date_str, report_path, table_path)
    if ok:
        print("Done. OS docs written.")
    else:
        print("ERROR: OS doc write failed.")
