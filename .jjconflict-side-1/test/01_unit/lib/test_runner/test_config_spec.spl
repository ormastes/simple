# Unit hardening for std.test_runner.test_config key parsing.
#
# load_test_config_from_path currently short-circuits to TestConfig.defaults()
# before ever reading a file (see the early `return config` in that function),
# so these tests exercise the real parsing surface directly instead:
# apply_test_config_value, parse_config_key_value, and parse_test_config_content.
#
# CONFIRMED DEFECT while writing this spec: apply_test_config_value's `config`
# parameter is not declared `mut`, so field writes inside it (e.g.
# `config.run_sdoctests = value == "true"`) mutate only the callee's own stack
# frame -- never the caller's struct. parse_test_config_content routes every
# top-level and cpu_throttle.* key through this same helper, so those keys are
# ALSO no-ops end to end. Direct field assignment done locally within
# parse_test_config_content itself (its CI env-var override block) is NOT
# affected -- only mutation-through-a-separate-function-call is broken. See
# doc/08_tracking/bug/test_config_apply_value_missing_mut_param_2026-07-17.md.
# The tests below pin the CURRENT (broken) contract explicitly rather than
# asserting the unreachable intended behavior, and cover the parts of the
# module that do work correctly.

use std.test_runner.test_config.{TestConfig, apply_test_config_value, parse_config_key_value, parse_test_config_content}
use std.io.{env_get, env_set}

describe "test_config key parsing (hardening)":
    context "defaults":
        it "defaults run_sdoctests and run_spl_doctests to false":
            val config = TestConfig.defaults()
            expect(config.run_sdoctests).to_equal(false)
            expect(config.run_spl_doctests).to_equal(false)

    context "apply_test_config_value":
        it "deliberate-red: an unrecognized key is a silent no-op, not a crash":
            val config = TestConfig.defaults()
            apply_test_config_value(config, "totally_bogus_key_xyz", "true")
            expect(config.run_sdoctests).to_equal(false)
            expect(config.run_spl_doctests).to_equal(false)

        it "documents a known defect: mutation does not propagate to the caller (missing `mut` on the config param)":
            val config = TestConfig.defaults()
            apply_test_config_value(config, "run_sdoctests", "true")
            # See doc/08_tracking/bug/test_config_apply_value_missing_mut_param_2026-07-17.md --
            # this SHOULD be true after the call above; it stays false because
            # the mutation lives only inside apply_test_config_value's own
            # stack frame.
            expect(config.run_sdoctests).to_equal(false)

    context "parse_config_key_value":
        it "splits a simple key: value line":
            val (key, value) = parse_config_key_value("run_sdoctests: true")
            expect(key).to_equal("run_sdoctests")
            expect(value).to_equal("true")

        it "strips a trailing comment from the value":
            val (key, value) = parse_config_key_value("run_sdoctests: true  # enable it")
            expect(key).to_equal("run_sdoctests")
            expect(value).to_equal("true")

        it "deliberate-red: a line with no colon fails closed to empty key/value":
            val (key, value) = parse_config_key_value("this line has no separator at all")
            expect(key).to_equal("")
            expect(value).to_equal("")

    context "parse_test_config_content":
        it "deliberate-red: content with no test: section leaves defaults untouched":
            val config = TestConfig.defaults()
            val content = "# just a comment file\nunrelated_top_level: true\n"
            val parsed = parse_test_config_content(config, content)
            expect(parsed.run_sdoctests).to_equal(false)
            expect(parsed.run_spl_doctests).to_equal(false)

        it "documents the same apply_test_config_value defect end-to-end: a test: section run_sdoctests/cpu_throttle line never takes effect":
            val config = TestConfig.defaults()
            val content = "test:\n  run_sdoctests: true\n  cpu_throttle:\n    enabled: true\n"
            val parsed = parse_test_config_content(config, content)
            # Both keys are routed through the broken helper -- see the bug
            # doc referenced above. If this ever starts failing (turning
            # true), the underlying defect has been fixed and this test
            # should be rewritten to assert the correct/intended values.
            expect(parsed.run_sdoctests).to_equal(false)
            expect(parsed.throttle_enabled).to_equal(false)

        it "applies the CI env var override via direct field assignment (the one path NOT routed through the broken helper)":
            val original_ci = env_get("CI") ?? ""
            env_set("CI", "true")
            val config = TestConfig.defaults()
            val parsed = parse_test_config_content(config, "")
            expect(parsed.ci_mode).to_equal(true)
            expect(parsed.run_slow_tests).to_equal(true)
            expect(parsed.fail_fast).to_equal(false)
            if original_ci != "":
                env_set("CI", original_ci)
