use std.spec.*
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport}

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

describe "has debug":
    it "has descendant badge passes":
        val html1 = "<html><head><style>body { margin: 0; background-color: #ffffff; } div:has(.badge) { width: 12px; height: 8px; background-color: #7c3aed; }</style></head><body><div><span class='badge'></span></div></body></html>"
        val r1 = render_html_to_pixels_with_viewport(html1, 32, 24)
        expect(_count_color(r1.pixel_data, 0xFF7C3AEDu32)).to_be_greater_than(0)

    it "has direct child badge":
        val html2 = "<html><head><style>body { margin: 0; background-color: #ffffff; } div:has(> .badge) { width: 12px; height: 8px; background-color: #0e7490; }</style></head><body><div><span class='badge'></span></div></body></html>"
        val r2 = render_html_to_pixels_with_viewport(html2, 32, 24)
        expect(_count_color(r2.pixel_data, 0xFF0E7490u32)).to_be_greater_than(0)
