use std.spec
use std.fs_driver.bytes_util.{alloc_zeroed_bytes, text_to_bytes_pure}

# AC-3: C extern replacement — alloc_zeroed_bytes and text_to_bytes_pure
# These specs verify pure Simple replacements for rt_bytes_alloc / rt_text_to_bytes.
# All specs FAIL until implementation exists.

describe "nvfs_pure_simple":
    describe "alloc_zeroed_bytes":
        it "AC-3: alloc_zeroed_bytes(64) returns array of length 64":
            val buf = alloc_zeroed_bytes(64)
            expect buf.len == 64

        it "AC-3: alloc_zeroed_bytes(64) first element is zero":
            val buf = alloc_zeroed_bytes(64)
            expect buf[0] == 0

        it "AC-3: alloc_zeroed_bytes(64) last element is zero":
            val buf = alloc_zeroed_bytes(64)
            expect buf[63] == 0

        it "AC-3: alloc_zeroed_bytes(0) returns empty array":
            val buf = alloc_zeroed_bytes(0)
            expect buf.len == 0

        it "AC-3: alloc_zeroed_bytes(1) returns single-element zero array":
            val buf = alloc_zeroed_bytes(1)
            expect buf.len == 1

        it "AC-3: alloc_zeroed_bytes(1) single element is zero":
            val buf = alloc_zeroed_bytes(1)
            expect buf[0] == 0

    describe "text_to_bytes_pure":
        it "AC-3: text_to_bytes_pure(\"ABC\") returns array of length 3":
            val bytes = text_to_bytes_pure("ABC")
            expect bytes.len == 3

        it "AC-3: text_to_bytes_pure(\"ABC\") first byte is 65 (A)":
            val bytes = text_to_bytes_pure("ABC")
            expect bytes[0] == 65

        it "AC-3: text_to_bytes_pure(\"ABC\") second byte is 66 (B)":
            val bytes = text_to_bytes_pure("ABC")
            expect bytes[1] == 66

        it "AC-3: text_to_bytes_pure(\"ABC\") third byte is 67 (C)":
            val bytes = text_to_bytes_pure("ABC")
            expect bytes[2] == 67

        it "AC-3: text_to_bytes_pure(\"\") returns empty array":
            val bytes = text_to_bytes_pure("")
            expect bytes.len == 0
