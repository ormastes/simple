# Extended hardening specs: callout, embed/wiki, and table edge cases.
# Covers: callout case-insensitivity, fold markers (+ and -), empty type,
# custom/unknown types, nested callouts, embed targets with UTF-8 and anchors,
# wiki-link edge cases in blocks, separator-only tables, very long lines.

use std.spec
use std.editor.render.md_renderer.*
use std.editor.render.block_model.*

# ──────────────────────────────────────────────
# Callout extended cases
# ──────────────────────────────────────────────
describe "callout extended robustness":

    it "callout type is uppercased in output":
        val src = "> [!note] My Title\n> body"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered[0].contains("NOTE")).to_equal(true)

    it "mixed-case callout type uppercased":
        val src = "> [!Warning] heads up\n> content"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered[0].contains("WARNING")).to_equal(true)

    it "callout with fold minus marker after bracket shows heading only":
        val src = "> [!note]- Hidden body\n> body text"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len()).to_equal(1)

    it "callout with fold plus marker after bracket is unfolded":
        val src = "> [!note]+ Expanded\n> body text"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 2).to_equal(true)

    it "callout fold marker inside bracket stripped from type name":
        val src = "> [!tip-] fold inside bracket\n> body"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        # type should be TIP not TIP-
        expect(rendered[0].contains("TIP-")).to_equal(false)
        expect(rendered[0].contains("TIP")).to_equal(true)

    it "empty callout type > [!] renders without crash":
        val src = "> [!] title\n> body"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("callout")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "custom unknown callout type renders uppercased":
        val src = "> [!mycustom] Custom\n> info"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered[0].contains("MYCUSTOM")).to_equal(true)

    it "nested blockquote inside callout body renders without crash":
        val src = "> [!NOTE]\n> > inner quote\n> normal line"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 2).to_equal(true)

    it "callout with no closing bracket > [!note does not crash":
        val src = "> [!note some text\n> body"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count() >= 1).to_equal(true)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "callout title with multi-byte UTF-8 renders without crash":
        val src = "> [!note] 日本語タイトル\n> body"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

# ──────────────────────────────────────────────
# Embed / wiki-link edge cases
# ──────────────────────────────────────────────
describe "embed and wiki-link edge cases":

    it "embed with anchor ![[note#section]] renders without crash":
        val model = BlockModel.from_markdown("![[note#section]]")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len()).to_equal(1)
        expect(rendered[0].contains("embed")).to_equal(true)

    it "embed with alias ![[target|label]] shows label":
        val model = BlockModel.from_markdown("![[target|my label]]")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered[0].contains("my label")).to_equal(true)

    it "embed with empty alias ![[a|]] renders without crash":
        val model = BlockModel.from_markdown("![[a|]]")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "embed with very long target does not crash":
        var long_target = ""
        var j = 0
        while j < 200:
            long_target = long_target + "a"
            j = j + 1
        val src = "![[" + long_target + "]]"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "embed with UTF-8 target renders without crash":
        val model = BlockModel.from_markdown("![[日本語ノート]]")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "empty embed ![[]] renders without crash":
        val model = BlockModel.from_markdown("![[]]")
        expect(model.block_count() >= 1).to_equal(true)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 0).to_equal(true)

    it "image embed with alt and URL renders as image":
        val model = BlockModel.from_markdown("![my alt](path/to/img.png)")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered[0].contains("image")).to_equal(true)

    it "image embed with empty alt renders without crash":
        val model = BlockModel.from_markdown("![](img.png)")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

# ──────────────────────────────────────────────
# Table edge cases
# ──────────────────────────────────────────────
describe "table edge cases":

    it "separator-only table renders without crash":
        val src = "| --- | --- |"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("table")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "table with extra columns on data row renders without crash":
        val src = "| A | B |\n| --- | --- |\n| 1 | 2 | 3 | 4 | 5 |"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len()).to_equal(3)

    it "table with fewer columns on data row renders without crash":
        val src = "| A | B | C |\n| --- | --- | --- |\n| 1 |"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len()).to_equal(3)

    it "single-column table renders without crash":
        val src = "| Col |\n| --- |\n| val |"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len()).to_equal(3)

    it "table with all empty cells renders without crash":
        val src = "|  |  |\n| --- | --- |\n|  |  |"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len()).to_equal(3)

# ──────────────────────────────────────────────
# General edge inputs
# ──────────────────────────────────────────────
describe "general edge inputs":

    it "document of only CR characters does not crash":
        val model = BlockModel.from_markdown("\r\r\r")
        expect(model.block_count() >= 0).to_equal(true)

    it "lone CR treated as whitespace or empty":
        val result = md_render_inline("\r")
        expect(result.len() >= 0).to_equal(true)

    it "very long line in paragraph renders without crash":
        var long_line = ""
        var j = 0
        while j < 500:
            long_line = long_line + "x"
            j = j + 1
        val model = BlockModel.from_markdown(long_line)
        val rendered = md_render_blocks(model)
        expect(rendered.len() >= 1).to_equal(true)

    it "deeply nested list items render without crash":
        val src = "- l1\n    - l2\n        - l3\n            - l4\n                - l5"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("list")

    it "mixed list markers in sequence each get own block":
        val src = "- dash item\n* star item\n+ plus item"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count() >= 1).to_equal(true)

    it "malformed ordered list 1text. is not a list":
        val model = BlockModel.from_markdown("1text. not a list")
        val b = model.block_at(0)
        expect(b.kind).to_equal("paragraph")

    it "ordered list with very large number renders without crash":
        val model = BlockModel.from_markdown("999999. item")
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("list")
