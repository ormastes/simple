"""
AC-10: Host CPU runtime variant selection — 20 unit tests.

Covers SIMD tier ranking, hardware clamping, dispatch name qualification,
loader probing, manifest entries, and variant selection with fallback.
All helpers are self-contained (no external imports beyond io_runtime).
"""

use std.io_runtime

# ---------------------------------------------------------------------------
# Helper 1: SimdTier
# ---------------------------------------------------------------------------
class SimdTier:
    name: text
    rank: i32

    static fn scalar() -> SimdTier:
        SimdTier(name: "scalar", rank: 0)

    static fn sse4() -> SimdTier:
        SimdTier(name: "sse4", rank: 1)

    static fn avx2() -> SimdTier:
        SimdTier(name: "avx2", rank: 3)

    static fn avx512() -> SimdTier:
        SimdTier(name: "avx512", rank: 4)

    static fn neon() -> SimdTier:
        SimdTier(name: "neon", rank: 5)

    me is_higher(other_rank: i32) -> bool:
        return self.rank > other_rank

# ---------------------------------------------------------------------------
# Helper 2: CpuFeats
# ---------------------------------------------------------------------------
class CpuFeats:
    arch: text
    has_sse4: bool
    has_avx2: bool
    has_avx512: bool
    has_neon: bool

    static fn x86_modern() -> CpuFeats:
        CpuFeats(
            arch: "x86_64",
            has_sse4: true,
            has_avx2: true,
            has_avx512: false,
            has_neon: false
        )

    static fn arm_base() -> CpuFeats:
        CpuFeats(
            arch: "aarch64",
            has_sse4: false,
            has_avx2: false,
            has_avx512: false,
            has_neon: true
        )

    me highest_rank() -> i32:
        var r = 0
        if self.has_neon:
            r = 5
        if self.has_sse4:
            if r < 1:
                r = 1
        if self.has_avx2:
            if r < 3:
                r = 3
        if self.has_avx512:
            if r < 4:
                r = 4
        return r

# ---------------------------------------------------------------------------
# Helper 3: TierClamp
# ---------------------------------------------------------------------------
class TierClamp:
    requested_rank: i32
    hw_max_rank: i32

    me effective_rank() -> i32:
        if self.requested_rank > self.hw_max_rank:
            return self.hw_max_rank
        return self.requested_rank

    me was_clamped() -> bool:
        return self.requested_rank > self.hw_max_rank

# ---------------------------------------------------------------------------
# Helper 4: VarProbe
# ---------------------------------------------------------------------------
class VarProbe:
    base: text
    suffix: text
    found: bool

    static fn attempt(base: text, suffix: text) -> VarProbe:
        VarProbe(base: base, suffix: suffix, found: false)

    me full_path() -> text:
        if self.suffix == "":
            return self.base + ".so"
        return self.base + "_" + self.suffix + ".so"

    me mark_found() -> VarProbe:
        return VarProbe(base: self.base, suffix: self.suffix, found: true)

# ---------------------------------------------------------------------------
# Helper 5: ManifestEntry
# ---------------------------------------------------------------------------
class ManifestEntry:
    platform: text
    tier: text
    path: text
    is_default: bool

    me matches(plat: text, t: text) -> bool:
        if self.platform == plat:
            return self.tier == t
        return false

    me serialize() -> text:
        return "platform=" + self.platform + " tier=" + self.tier + " path=" + self.path + " default=" + self.is_default.to_text()

# ---------------------------------------------------------------------------
# Helper 6: DispatchRoute
# ---------------------------------------------------------------------------
class DispatchRoute:
    fn_name: text
    tier: text

    me qualified() -> text:
        return self.fn_name + "_" + self.tier

# ---------------------------------------------------------------------------
# Helper 7: VariantSelect (for tests 19-20)
# ---------------------------------------------------------------------------
class VariantSelect:
    requested_tier: text
    available_tier: text

    me is_exact() -> bool:
        return self.requested_tier == self.available_tier

    me is_fallback() -> bool:
        return self.requested_tier == self.available_tier == false

# ---------------------------------------------------------------------------
# Test helpers
# ---------------------------------------------------------------------------
fn check(label: text, ok: bool):
    if ok:
        print("PASS: " + label)
    else:
        print("FAIL: " + label)

# ---------------------------------------------------------------------------
# Tests: CPU config (4)
# ---------------------------------------------------------------------------
fn test_x86_modern_highest_avx2():
    var cpu = CpuFeats.x86_modern()
    check("test_x86_modern_highest_avx2", cpu.highest_rank() == 3)

fn test_arm_baseline_neon():
    var cpu = CpuFeats.arm_base()
    var ok = cpu.has_neon
    if ok:
        ok = cpu.highest_rank() == 5
    check("test_arm_baseline_neon", ok)

fn test_scalar_lowest_rank():
    var t = SimdTier.scalar()
    check("test_scalar_lowest_rank", t.rank == 0)

fn test_avx512_higher_than_avx2():
    var a = SimdTier.avx512()
    var b = SimdTier.avx2()
    check("test_avx512_higher_than_avx2", a.rank > b.rank)

# ---------------------------------------------------------------------------
# Tests: Clamping (3)
# ---------------------------------------------------------------------------
fn test_clamp_no_change():
    var c = TierClamp(requested_rank: 3, hw_max_rank: 3)
    var ok = c.was_clamped() == false
    if ok:
        ok = c.effective_rank() == 3
    check("test_clamp_no_change", ok)

fn test_clamp_downgrade():
    var c = TierClamp(requested_rank: 4, hw_max_rank: 3)
    var ok = c.was_clamped()
    if ok:
        ok = c.effective_rank() == 3
    check("test_clamp_downgrade", ok)

fn test_clamp_scalar_unchanged():
    var c = TierClamp(requested_rank: 0, hw_max_rank: 3)
    check("test_clamp_scalar_unchanged", c.was_clamped() == false)

# ---------------------------------------------------------------------------
# Tests: Dispatch (3)
# ---------------------------------------------------------------------------
fn test_dispatch_qualified_name():
    var d = DispatchRoute(fn_name: "memcpy", tier: "avx2")
    check("test_dispatch_qualified_name", d.qualified() == "memcpy_avx2")

fn test_dispatch_scalar_suffix():
    var d = DispatchRoute(fn_name: "memcpy", tier: "scalar")
    check("test_dispatch_scalar_suffix", d.qualified() == "memcpy_scalar")

fn test_select_with_fallback():
    var d = DispatchRoute(fn_name: "memcpy", tier: "scalar")
    var primary = DispatchRoute(fn_name: "memcpy", tier: "avx512")
    var tier_unavailable = true
    var chosen = ""
    if tier_unavailable:
        chosen = d.qualified()
    else:
        chosen = primary.qualified()
    check("test_select_with_fallback", chosen == "memcpy_scalar")

# ---------------------------------------------------------------------------
# Tests: Loader probing (4)
# ---------------------------------------------------------------------------
fn test_probe_full_path():
    var p = VarProbe.attempt("libfoo", "avx2")
    check("test_probe_full_path", p.full_path() == "libfoo_avx2.so")

fn test_probe_base_only():
    var p = VarProbe.attempt("libfoo", "")
    check("test_probe_base_only", p.full_path() == "libfoo.so")

fn test_probe_found_mark():
    var p = VarProbe.attempt("libfoo", "avx2")
    var p2 = p.mark_found()
    check("test_probe_found_mark", p2.found)

fn test_probe_fallback_first_found():
    var p1 = VarProbe.attempt("libfoo", "avx512")
    var p2 = VarProbe.attempt("libfoo", "avx2")
    var p2m = p2.mark_found()
    var first_found = ""
    if p1.found:
        first_found = p1.full_path()
    else:
        if p2m.found:
            first_found = p2m.full_path()
    check("test_probe_fallback_first_found", first_found == "libfoo_avx2.so")

# ---------------------------------------------------------------------------
# Tests: Manifest (4)
# ---------------------------------------------------------------------------
fn test_manifest_entry_serialize():
    var e = ManifestEntry(platform: "linux", tier: "avx2", path: "/lib/foo_avx2.so", is_default: false)
    var s = e.serialize()
    var ok = s == "platform=linux tier=avx2 path=/lib/foo_avx2.so default=false"
    check("test_manifest_entry_serialize", ok)

fn test_manifest_entry_match():
    var e = ManifestEntry(platform: "linux", tier: "avx2", path: "/lib/foo_avx2.so", is_default: false)
    check("test_manifest_entry_match", e.matches("linux", "avx2"))

fn test_manifest_entry_no_match():
    var e = ManifestEntry(platform: "linux", tier: "avx2", path: "/lib/foo_avx2.so", is_default: false)
    check("test_manifest_entry_no_match", e.matches("windows", "avx2") == false)

fn test_manifest_default_path():
    var e = ManifestEntry(platform: "linux", tier: "scalar", path: "/lib/foo.so", is_default: true)
    check("test_manifest_default_path", e.is_default)

# ---------------------------------------------------------------------------
# Tests: Variant selection (2)
# ---------------------------------------------------------------------------
fn test_select_exact_match():
    var s = VariantSelect(requested_tier: "avx2", available_tier: "avx2")
    check("test_select_exact_match", s.is_exact())

fn test_select_fallback():
    var s = VariantSelect(requested_tier: "avx512", available_tier: "avx2")
    check("test_select_fallback", s.is_exact() == false)

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
fn main():
    test_x86_modern_highest_avx2()
    test_arm_baseline_neon()
    test_scalar_lowest_rank()
    test_avx512_higher_than_avx2()
    test_clamp_no_change()
    test_clamp_downgrade()
    test_clamp_scalar_unchanged()
    test_dispatch_qualified_name()
    test_dispatch_scalar_suffix()
    test_select_with_fallback()
    test_probe_full_path()
    test_probe_base_only()
    test_probe_found_mark()
    test_probe_fallback_first_found()
    test_manifest_entry_serialize()
    test_manifest_entry_match()
    test_manifest_entry_no_match()
    test_manifest_default_path()
    test_select_exact_match()
    test_select_fallback()
    print("DONE")
