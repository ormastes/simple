extern fn rt_file_read_text(path: text) -> text

fn _contains_deserialize_offset_guard(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn deserialize_string(bytes: list, offset: i64) -> text:") and
        source.to_contain("if offset < 0:\n        return \"\"")

describe "kafka serialization negative offset guard":
    it "guards mirrored string deserializers before indexed reads":
        expect(_contains_deserialize_offset_guard("src/lib/nogc_sync_mut/kafka/serialization.spl")).to_equal(true)
        expect(_contains_deserialize_offset_guard("src/lib/nogc_async_mut/kafka/serialization.spl")).to_equal(true)
        expect(_contains_deserialize_offset_guard("src/lib/gc_async_mut/kafka/serialization.spl")).to_equal(true)

        val facade_source = rt_file_read_text("src/lib/gc_sync_mut/kafka/serialization.spl") ?? ""
        expect(facade_source).to_contain("export use std.gc_async_mut.kafka.serialization.*")
