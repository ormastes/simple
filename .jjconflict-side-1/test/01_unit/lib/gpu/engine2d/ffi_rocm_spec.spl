"""ROCm/HIP FFI Dispatch Specification

@tag: gpu, engine2d, rocm, hip, amd, ffi
@cover src/lib/gc_async_mut/gpu/engine2d/ffi_rocm.spl 80%

Verifies RocmFfi dispatch class: static rt_rocm_* hooks plus dynamic DynLib
dlopen libamdhip64.so probes. Covers AC-3 + AC-8.
"""

use std.spec.{describe, context, it, expect}
use std.common.test_env_gate.{test_env_require, test_env_gpu_available}
use std.gpu.engine2d.sffi_rocm.{RocmFfi}

# ============================================================================
# RocmFfi
# ============================================================================

describe "RocmFfi":
    describe "create_dynamic":
        it "AC-3: attempts to load libamdhip64.so":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-8: returns nil when HIP runtime not installed":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    describe "create_static":
        it "AC-8: static mode available when runtime is built":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

# ============================================================================
# HIP API operations
# ============================================================================

    describe "HIP device management":
        it "AC-3: hipInit returns success code":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-3: device_count via hipGetDeviceCount":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    describe "HIP memory operations":
        it "AC-3: hipMalloc returns device pointer":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    describe "HIP kernel launch":
        it "AC-3: hipLaunchKernel dispatches compute kernel":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "fails closed instead of dispatching a zero HIP kernel handle":
            val ffi = RocmFfi.create_static()
            expect(ffi.launch_kernel("kernel_clear", 1, 1, 1, 1, 1, 1, 0)).to_equal(false)

        it "rejects the legacy uncounted packed-argument pointer":
            val ffi = RocmFfi.create_static()
            expect(ffi.launch_kernel_args(7, 1, 1, 1, 1, 1, 1, 0, 4096)).to_equal(false)

        it "fails closed when the dynamic HIP runtime cannot be loaded":
            val ffi = RocmFfi.create_dynamic_from("/definitely/missing/libamdhip64.so")
            expect(ffi).to_be_nil()

# ============================================================================
# Platform matrix (AC-7)
# ============================================================================

    describe "platform support":
        it "AC-7: ROCm primary on Linux":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-7: ROCm partial on Windows":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-3: ROCm dynamic-only (no Rust runtime)":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")
