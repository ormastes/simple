# @cover src/lib/gc_async_mut/gpu/engine2d/backend_webgpu.spl 40%
# @tag: unit, gpu, engine2d, webgpu, text

use std.gpu.engine2d.backend_webgpu.{WebGpuBackend}

describe "Engine2D WebGPU text fallback":

    it "skips foreground glyph buffer work before WebGPU init":
        var backend = WebGpuBackend.create()

        backend.draw_text(0, 0, "A", 0xff112233u32, 7)

        expect(backend.initialized).to_equal(false)
        expect(backend.width()).to_equal(0)
        expect(backend.height()).to_equal(0)

        backend.shutdown()

    it "skips background glyph buffer work before WebGPU init":
        var backend = WebGpuBackend.create()

        backend.draw_text_bg(0, 0, "A", 0xff112233u32, 0xff445566u32, 7)

        expect(backend.initialized).to_equal(false)
        expect(backend.width()).to_equal(0)
        expect(backend.height()).to_equal(0)

        backend.shutdown()
