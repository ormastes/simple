# @cover src/lib/gc_async_mut/gpu/engine2d/backend_rocm.spl 40%
# @tag: unit, gpu, engine2d, rocm, hip, text

use std.gpu.engine2d.backend_rocm.{RocmBackend}

describe "Engine2D ROCm text fallback":

    it "skips foreground glyph staging when ROCm is uninitialized":
        var backend = RocmBackend.create()

        backend.draw_text(0, 0, "A", 0xff112233u32, 7)

        expect(backend.initialized).to_equal(false)
        expect(backend.dirty).to_equal(true)

        backend.shutdown()

    it "skips background glyph staging when ROCm is uninitialized":
        var backend = RocmBackend.create()

        backend.draw_text_bg(0, 0, "A", 0xff112233u32, 0xff445566u32, 7)

        expect(backend.initialized).to_equal(false)
        expect(backend.dirty).to_equal(true)

        backend.shutdown()
