# @cover src/lib/nogc_sync_mut/debug/remote/target/stm32u5.spl 80%
"""
# STM32U5 Target Definition Specification

**Feature IDs:** #UNOQ-PORT
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Verifies `Stm32U5Target` creation, memory layout, core delegation,
and probe configuration. The target wraps `ArmCortexMTarget.cortex_m33()`
with STM32U585-specific memory addresses.

## Behavior

- Default factory uses `interface/stlink.cfg` probe
- `with_probe()` overrides probe config
- Flash base at 0x08000000
- SRAM base at 0x20000000, size 786432 (786 KB)
- Core name delegates to "Cortex-M33"
- 8 HW breakpoints, 4 HW watchpoints (M33 spec)
"""

use std.nogc_sync_mut.debug.remote.target.stm32u5.{Stm32U5Target}


# ============================================================================
# Test Group 1: Default factory
# ============================================================================

describe "Stm32U5Target default":
    """
    ## Default Construction

    Validates that `Stm32U5Target.default()` returns a correctly configured
    target with stlink probe and STM32U585 memory layout.
    """

    it "AC-2: name is STM32U5 (Cortex-M33)":
        val t = Stm32U5Target.default()
        expect(t.name()).to_equal("STM32U5 (Cortex-M33)")

    it "AC-2: flash_base is 0x08000000":
        val t = Stm32U5Target.default()
        expect(t.flash_base()).to_equal(0x08000000)

    it "AC-2: sram_base is 0x20000000":
        val t = Stm32U5Target.default()
        expect(t.sram_base()).to_equal(0x20000000)

    it "AC-2: sram_size is 786432":
        val t = Stm32U5Target.default()
        val ss = t.sram_size()
        expect(ss).to_equal(786432)


# ============================================================================
# Test Group 2: Core delegation (Cortex-M33 properties)
# ============================================================================

describe "Stm32U5Target core delegation":
    """
    ## Cortex-M33 Core

    Validates that hardware debug properties delegate correctly
    to the underlying ArmCortexMTarget.cortex_m33() core.
    """

    it "AC-2: core_name is Cortex-M33":
        val t = Stm32U5Target.default()
        expect(t.core_name()).to_equal("Cortex-M33")

    it "AC-2: hw_breakpoint_count is 8":
        val t = Stm32U5Target.default()
        val bp = t.hw_breakpoint_count()
        expect(bp).to_equal(8)

    it "AC-2: hw_watchpoint_count is 4":
        val t = Stm32U5Target.default()
        val wp = t.hw_watchpoint_count()
        expect(wp).to_equal(4)

    it "AC-2: word_size is 4":
        val t = Stm32U5Target.default()
        val ws = t.word_size()
        expect(ws).to_equal(4)


# ============================================================================
# Test Group 3: Custom probe configuration
# ============================================================================

describe "Stm32U5Target with_probe":
    """
    ## Probe Override

    Validates that `with_probe()` allows custom debug probe interface.
    """

    it "AC-2: with_probe overrides probe_cfg":
        val t = Stm32U5Target.with_probe("interface/jlink.cfg")
        expect(t.probe_cfg).to_equal("interface/jlink.cfg")

    it "AC-2: with_probe preserves name":
        val t = Stm32U5Target.with_probe("interface/cmsis-dap.cfg")
        expect(t.name()).to_equal("STM32U5 (Cortex-M33)")

    it "AC-2: default probe_cfg is interface/stlink.cfg":
        val t = Stm32U5Target.default()
        expect(t.probe_cfg).to_equal("interface/stlink.cfg")
