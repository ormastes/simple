# @cover src/lib/nogc_async_mut/game2d/render/evidence.spl 100%
"""
# game2d.render.evidence — pixel-evidence oracle unit specs

**Design:** src/lib/nogc_async_mut/game2d/render/evidence.spl

Direct unit specs for the pixel-evidence oracles extracted from Rollball
(`find_centroid`, `diff_count`, `dump_ppm`): absolute expected values on
small, hand-constructed pixel buffers — no rendering, no game state.
"""

use std.spec
use std.io.{file_exists, file_read}
use std.game2d.render.evidence.{find_centroid, diff_count, dump_ppm}

extern fn rt_dir_create(path: text, recursive: bool) -> bool

describe "game2d.render.evidence — find_centroid":

    it "single marked pixel in a 4x4 buffer returns its exact coordinates":
        val bg: u32 = 0xFF000000
        val mark: u32 = 0xFFFF0000
        var px: [u32] = [bg; 16]
        px[1 * 4 + 2] = mark
        val c = find_centroid(px, 4, 4, mark)
        assert_equal(c[0], 2)
        assert_equal(c[1], 1)
        assert_equal(c[2], 1)

    it "two marked pixels average to the exact integer centroid":
        val bg: u32 = 0xFF000000
        val mark: u32 = 0xFF00FF00
        var px: [u32] = [bg; 16]
        px[0 * 4 + 0] = mark
        px[3 * 4 + 2] = mark
        val c = find_centroid(px, 4, 4, mark)
        assert_equal(c[0], 1)
        assert_equal(c[1], 1)
        assert_equal(c[2], 2)

    it "no matching pixel returns the [-1, -1, 0] sentinel":
        val bg: u32 = 0xFF000000
        var px: [u32] = [bg; 16]
        val c = find_centroid(px, 4, 4, 0xFFFFFFFF)
        assert_equal(c[0], -1)
        assert_equal(c[1], -1)
        assert_equal(c[2], 0)


describe "game2d.render.evidence — diff_count":

    it "counts the exact number of differing pixels":
        var a: [u32] = [0; 16]
        var b: [u32] = [0; 16]
        b[0] = 1
        b[5] = 1
        b[15] = 1
        assert_equal(diff_count(a, b, 16), 3)

    it "identical buffers diff to exactly zero":
        var a: [u32] = [7; 16]
        var b: [u32] = [7; 16]
        assert_equal(diff_count(a, b, 16), 0)


describe "game2d.render.evidence — dump_ppm":

    it "writes an exact P3 header and pixel bytes for a known 2x1 buffer":
        val _ = rt_dir_create("build/test-scratch", true)
        val path = "build/test-scratch/evidence_dump_ppm_spec.ppm"
        val px: [u32] = [0xFFFF0000, 0xFF00FF00]
        assert_true(dump_ppm(path, px, 2, 1))
        assert_true(file_exists(path))
        val content = file_read(path)
        assert_equal(content, "P3\n2 1\n255\n255 0 0\n0 255 0\n")
