use std.spec.{describe, it, assert_equal}
use lib.common.html.entities.{decode_html_entity}

describe "HTML numeric entity guards":
    it "keeps valid decimal numeric entities":
        assert_equal(decode_html_entity("#65"), "A")

    it "leaves oversized decimal numeric entities unchanged":
        val oversized = "#123456789012345678901234567890"
        assert_equal(decode_html_entity(oversized), oversized)
