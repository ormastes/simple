# Tests for src/lib/common/math/special.spl (import path: std.math.special)
#
# Ground truths are hand/independently recomputed (not copied from the
# formula.spl callers) — see the values cited in each `it` description.
# gamma_ln(10), erf(1), erfc(0.5), incomplete_beta(2,3,0.4), and
# incomplete_gamma_p(3,2) were cross-checked against a from-scratch Python
# reimplementation of the exact same series/continued-fraction algorithms,
# not just against formula.spl's own output.

use std.math.special.{gamma_ln, gamma_fn, beta_fn, erf, erfc}
use std.math.special.{incomplete_beta, incomplete_gamma_p}
use std.math.special.{incomplete_beta_inv, incomplete_gamma_p_inv}
use std.math.special.{powf, factorial, factorial2, combin, combina}
use std.math.special.{fabs, sin_f64, cos_f64, tan_f64, atan_f64, atan2_f64, fact_i64}

fn _approx(actual: f64, target: f64, tol: f64) -> bool:
    var d = actual - target
    if d < 0.0:
        d = 0.0 - d
    d < tol

describe "std.math.special (gamma / beta)":
    context "gamma_fn":
        it "gamma_fn(5) is 24 (4! since Gamma(n) = (n-1)!)":
            val res = gamma_fn(5.0)
            expect(_approx(res, 24.0, 0.0001)).to_be(true)

        it "gamma_fn(1) is 1":
            val res = gamma_fn(1.0)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

        it "gamma_fn(0.5) is sqrt(pi) ~ 1.772454":
            val res = gamma_fn(0.5)
            expect(_approx(res, 1.7724538509, 0.0001)).to_be(true)

    context "gamma_ln":
        it "gamma_ln(10) is ln(362880) ~ 12.801827":
            val res = gamma_ln(10.0)
            expect(_approx(res, 12.801827480081467, 0.0001)).to_be(true)

        it "gamma_ln(1) is 0":
            val res = gamma_ln(1.0)
            expect(_approx(res, 0.0, 0.0001)).to_be(true)

    context "beta_fn":
        it "beta_fn(2,3) is 1/12 ~ 0.083333":
            val res = beta_fn(2.0, 3.0)
            expect(_approx(res, 0.08333333333, 0.0001)).to_be(true)

describe "std.math.special (error function)":
    context "erf":
        it "erf(1) is 0.8427008":
            val res = erf(1.0)
            expect(_approx(res, 0.8427008, 0.0001)).to_be(true)

        it "erf(0) is 0":
            val res = erf(0.0)
            expect(_approx(res, 0.0, 0.0001)).to_be(true)

        it "erf is odd: erf(-1) is -erf(1)":
            val neg = erf(-1.0)
            val pos = erf(1.0)
            expect(_approx(neg, 0.0 - pos, 0.0000001)).to_be(true)

    context "erfc":
        it "erfc(0.5) is 0.4795001":
            val res = erfc(0.5)
            expect(_approx(res, 0.4795001, 0.0001)).to_be(true)

        it "erfc(0) is 1":
            val res = erfc(0.0)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

describe "std.math.special (incomplete beta)":
    context "incomplete_beta":
        it "incomplete_beta(2,3,0.4) is 0.5248":
            val res = incomplete_beta(2.0, 3.0, 0.4)
            expect(_approx(res, 0.5248, 0.0001)).to_be(true)

        it "incomplete_beta(a,b,0.0) is 0.0 (clamped, not an error)":
            val res = incomplete_beta(2.0, 3.0, 0.0)
            expect(_approx(res, 0.0, 0.0000001)).to_be(true)

        it "incomplete_beta(a,b,1.0) is 1.0 (clamped, not an error)":
            val res = incomplete_beta(2.0, 3.0, 1.0)
            expect(_approx(res, 1.0, 0.0000001)).to_be(true)

    context "incomplete_beta_inv round-trip":
        it "incomplete_beta_inv(2,3, incomplete_beta(2,3,0.4)) is ~0.4":
            val p = incomplete_beta(2.0, 3.0, 0.4)
            val res = incomplete_beta_inv(2.0, 3.0, p)
            expect(_approx(res, 0.4, 0.000001)).to_be(true)

        it "incomplete_beta_inv(2,3, incomplete_beta(2,3,0.2)) is ~0.2":
            val p = incomplete_beta(2.0, 3.0, 0.2)
            val res = incomplete_beta_inv(2.0, 3.0, p)
            expect(_approx(res, 0.2, 0.000001)).to_be(true)

        it "incomplete_beta_inv(5,2, incomplete_beta(5,2,0.7)) is ~0.7":
            val p = incomplete_beta(5.0, 2.0, 0.7)
            val res = incomplete_beta_inv(5.0, 2.0, p)
            expect(_approx(res, 0.7, 0.000001)).to_be(true)

describe "std.math.special (incomplete gamma)":
    context "incomplete_gamma_p":
        it "incomplete_gamma_p(3,2) is 0.323324":
            val res = incomplete_gamma_p(3.0, 2.0)
            expect(_approx(res, 0.323324, 0.000001)).to_be(true)

        it "incomplete_gamma_p(a,0.0) is 0.0 (clamped, not an error)":
            val res = incomplete_gamma_p(3.0, 0.0)
            expect(_approx(res, 0.0, 0.0000001)).to_be(true)

    context "incomplete_gamma_p_inv round-trip":
        it "incomplete_gamma_p_inv(3, incomplete_gamma_p(3,2)) is ~2":
            val p = incomplete_gamma_p(3.0, 2.0)
            val res = incomplete_gamma_p_inv(3.0, p)
            expect(_approx(res, 2.0, 0.000001)).to_be(true)

        it "incomplete_gamma_p_inv(5, incomplete_gamma_p(5,4)) is ~4":
            val p = incomplete_gamma_p(5.0, 4.0)
            val res = incomplete_gamma_p_inv(5.0, p)
            expect(_approx(res, 4.0, 0.000001)).to_be(true)

        it "incomplete_gamma_p_inv(2, incomplete_gamma_p(2,1)) is ~1":
            val p = incomplete_gamma_p(2.0, 1.0)
            val res = incomplete_gamma_p_inv(2.0, p)
            expect(_approx(res, 1.0, 0.000001)).to_be(true)

describe "std.math.special (powf)":
    it "powf(2, 0.5) is 1.4142136":
        val res = powf(2.0, 0.5)
        expect(_approx(res, 1.4142136, 0.0001)).to_be(true)

    it "powf(4, 0.5) is 2.0":
        val res = powf(4.0, 0.5)
        expect(_approx(res, 2.0, 0.0001)).to_be(true)

    it "powf(2, 10) is 1024.0":
        val res = powf(2.0, 10.0)
        expect(_approx(res, 1024.0, 0.01)).to_be(true)

    it "powf on non-positive base returns 0.0 (documented quirk, not an error)":
        val res = powf(-2.0, 2.0)
        expect(_approx(res, 0.0, 0.0000001)).to_be(true)

describe "std.math.special (factorial / combinatorics)":
    context "factorial":
        it "factorial(5) is 120":
            val res = factorial(5)
            expect(_approx(res, 120.0, 0.0001)).to_be(true)

        it "factorial(0) is 1":
            val res = factorial(0)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

    context "factorial2":
        it "factorial2(7) is 105 (7*5*3*1)":
            val res = factorial2(7)
            expect(_approx(res, 105.0, 0.0001)).to_be(true)

        it "factorial2(8) is 384 (8*6*4*2)":
            val res = factorial2(8)
            expect(_approx(res, 384.0, 0.0001)).to_be(true)

    context "combin":
        it "combin(10,3) is 120":
            val res = combin(10, 3)
            expect(_approx(res, 120.0, 0.0001)).to_be(true)

        it "combin(5,0) is 1":
            val res = combin(5, 0)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

    context "combina":
        it "combina(4,3) is 20":
            val res = combina(4, 3)
            expect(_approx(res, 20.0, 0.0001)).to_be(true)

        it "combina(0,0) is 1 (k==0 special case)":
            val res = combina(0, 0)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

describe "std.math.special (trigonometric)":
    context "fabs":
        it "fabs(-3.5) is 3.5":
            val res = fabs(-3.5)
            expect(_approx(res, 3.5, 0.0001)).to_be(true)

        it "fabs(3.5) is 3.5":
            val res = fabs(3.5)
            expect(_approx(res, 3.5, 0.0001)).to_be(true)

        it "fabs(0) is 0":
            val res = fabs(0.0)
            expect(_approx(res, 0.0, 0.0001)).to_be(true)

    context "sin_f64":
        it "sin_f64(1.5707963) is ~1.0 (sin(π/2) ≈ 1)":
            val res = sin_f64(1.5707963)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

        it "sin_f64(0) is 0":
            val res = sin_f64(0.0)
            expect(_approx(res, 0.0, 0.0001)).to_be(true)

        it "sin_f64(π/6) is 0.5":
            val pi_over_6 = 3.141592653589793 / 6.0
            val res = sin_f64(pi_over_6)
            expect(_approx(res, 0.5, 0.0001)).to_be(true)

    context "cos_f64":
        it "cos_f64(0) is 1":
            val res = cos_f64(0.0)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

        it "cos_f64(π) is -1":
            val pi = 3.141592653589793
            val res = cos_f64(pi)
            expect(_approx(res, -1.0, 0.0001)).to_be(true)

        it "cos_f64(π/3) is 0.5":
            val pi_over_3 = 3.141592653589793 / 3.0
            val res = cos_f64(pi_over_3)
            expect(_approx(res, 0.5, 0.0001)).to_be(true)

    context "tan_f64":
        it "tan_f64(π/4) is ~1.0":
            val pi_over_4 = 3.141592653589793 / 4.0
            val res = tan_f64(pi_over_4)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

        it "tan_f64(0) is 0":
            val res = tan_f64(0.0)
            expect(_approx(res, 0.0, 0.0001)).to_be(true)

    context "atan_f64":
        it "atan_f64(1) is π/4 ~0.7853982":
            val res = atan_f64(1.0)
            expect(_approx(res, 0.7853982, 0.0001)).to_be(true)

        it "atan_f64(0) is 0":
            val res = atan_f64(0.0)
            expect(_approx(res, 0.0, 0.0001)).to_be(true)

        it "atan_f64(-1) is -π/4 ~-0.7853982":
            val res = atan_f64(-1.0)
            expect(_approx(res, -0.7853982, 0.0001)).to_be(true)

    context "atan2_f64":
        it "atan2_f64(1,1) is π/4 ~0.7853982":
            val res = atan2_f64(1.0, 1.0)
            expect(_approx(res, 0.7853982, 0.0001)).to_be(true)

        it "atan2_f64(0,1) is 0":
            val res = atan2_f64(0.0, 1.0)
            expect(_approx(res, 0.0, 0.0001)).to_be(true)

        it "atan2_f64(1,0) is π/2 ~1.5707963":
            val res = atan2_f64(1.0, 0.0)
            expect(_approx(res, 1.5707963, 0.0001)).to_be(true)

        it "atan2_f64(1,-1) is 3π/4 ~2.356194":
            val res = atan2_f64(1.0, -1.0)
            expect(_approx(res, 2.356194, 0.0001)).to_be(true)

    context "fact_i64":
        it "fact_i64(10) is 3628800 (10!)":
            val res = fact_i64(10)
            expect(_approx(res, 3628800.0, 0.0001)).to_be(true)

        it "fact_i64(0) is 1":
            val res = fact_i64(0)
            expect(_approx(res, 1.0, 0.0001)).to_be(true)

        it "fact_i64(5) is 120":
            val res = fact_i64(5)
            expect(_approx(res, 120.0, 0.0001)).to_be(true)
