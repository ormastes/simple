# Tests for src/lib/common/math/distributions.spl (import path: std.math.distributions)
#
# Ground truths are recomputed independently (standard textbook/Excel-doc
# values), not copied from formula.spl's own test fixtures:
#   norm_cdf(1.96,0,1) = 0.9750021        norm_inv(0.975,0,1) = 1.959964
#   t_inv(0.975,10) = 2.228139            chisq_inv(0.95,5) = 11.0705
#   f_cdf(3.0,5,10) = 0.934442 (via I_{d1*x/(d1*x+d2)}(d1/2, d2/2), d1=5, d2=10)
#   beta_cdf(0.4,2,3) = 0.5248            gamma_cdf(2,3,1) = 0.323324
#   binom_pmf(3,10,0.5) = 0.1171875       binom_cdf(3,10,0.5) = 0.171875
#   poisson_pmf(2,3) = 0.2240418          expon_cdf(1,2) = 1 - e^-2 = 0.8646647
#   hypgeom_pmf(1,4,8,20) = C(8,1)*C(12,3)/C(20,4) = 8*220/4845 = 0.363260...
#   weibull_cdf(2,1.5,3) = 1 - exp(-(2/3)^1.5) = 0.419770...
#   lognorm_cdf(4,3.5,1.2) = 0.0390836
#
# Round-trips (inv(cdf(x)) ~= x, tol 1e-5) are checked for norm/t/chisq/f/
# beta/gamma at 2 points each.

use std.math.distributions.{norm_pdf, norm_cdf, norm_inv}
use std.math.distributions.{t_cdf, t_cdf_2t, t_inv}
use std.math.distributions.{chisq_cdf, chisq_inv, f_cdf, f_inv}
use std.math.distributions.{beta_cdf, beta_inv, gamma_cdf, gamma_inv}
use std.math.distributions.{binom_pmf, binom_cdf, poisson_pmf, poisson_cdf}
use std.math.distributions.{expon_cdf, hypgeom_pmf, negbinom_pmf}
use std.math.distributions.{weibull_cdf, weibull_pdf, lognorm_cdf, lognorm_inv}

fn _approx(actual: f64, target: f64, tol: f64) -> bool:
    var d = actual - target
    if d < 0.0:
        d = 0.0 - d
    d < tol

fn _is_nan(x: f64) -> bool:
    x != x

describe "std.math.distributions (normal)":
    context "norm_pdf":
        it "norm_pdf(0,0,1) is 1/sqrt(2*pi) ~ 0.398942":
            val res = norm_pdf(0.0, 0.0, 1.0)
            expect(_approx(res, 0.3989422804, 0.0001)).to_be(true)

        it "norm_pdf domain error (sd<=0) is NaN":
            val res = norm_pdf(0.0, 0.0, 0.0)
            expect(_is_nan(res)).to_be(true)

    context "norm_cdf":
        it "norm_cdf(1.96,0,1) is 0.9750021":
            val res = norm_cdf(1.96, 0.0, 1.0)
            expect(_approx(res, 0.9750021, 0.0001)).to_be(true)

        it "norm_cdf(0,0,1) is 0.5 (median)":
            val res = norm_cdf(0.0, 0.0, 1.0)
            expect(_approx(res, 0.5, 0.0001)).to_be(true)

    context "norm_inv":
        it "norm_inv(0.975,0,1) is 1.959964":
            val res = norm_inv(0.975, 0.0, 1.0)
            expect(_approx(res, 1.959964, 0.0001)).to_be(true)

        it "round-trip: norm_inv(norm_cdf(0.5)) ~= 0.5":
            val res = norm_inv(norm_cdf(0.5, 0.0, 1.0), 0.0, 1.0)
            expect(_approx(res, 0.5, 0.00001)).to_be(true)

        it "round-trip: norm_inv(norm_cdf(-1.2)) ~= -1.2":
            val res = norm_inv(norm_cdf(-1.2, 0.0, 1.0), 0.0, 1.0)
            expect(_approx(res, -1.2, 0.00001)).to_be(true)

        it "norm_inv domain error (p out of (0,1)) is NaN":
            val res = norm_inv(1.5, 0.0, 1.0)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (Student's t)":
    context "t_cdf":
        it "t_cdf(0,10) is 0.5 (median)":
            val res = t_cdf(0.0, 10.0)
            expect(_approx(res, 0.5, 0.0001)).to_be(true)

        it "t_cdf_2t(2.228139,10) is ~0.05 (two-tailed 5%)":
            val res = t_cdf_2t(2.228139, 10.0)
            expect(_approx(res, 0.05, 0.0001)).to_be(true)

    context "t_inv":
        it "t_inv(0.975,10) is 2.228139":
            val res = t_inv(0.975, 10.0)
            expect(_approx(res, 2.228139, 0.0001)).to_be(true)

        it "t_inv(0.5,10) is 0 (median)":
            val res = t_inv(0.5, 10.0)
            expect(_approx(res, 0.0, 0.0001)).to_be(true)

        it "round-trip: t_inv(t_cdf(1.5,df=7)) ~= 1.5":
            val res = t_inv(t_cdf(1.5, 7.0), 7.0)
            expect(_approx(res, 1.5, 0.00001)).to_be(true)

        it "round-trip: t_inv(t_cdf(-0.8,df=20)) ~= -0.8":
            val res = t_inv(t_cdf(-0.8, 20.0), 20.0)
            expect(_approx(res, -0.8, 0.00001)).to_be(true)

        it "t_inv domain error (df<1) is NaN":
            val res = t_inv(0.5, 0.5)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (chi-squared)":
    context "chisq_cdf/chisq_inv":
        it "chisq_inv(0.95,5) is 11.0705":
            val res = chisq_inv(0.95, 5.0)
            expect(_approx(res, 11.0705, 0.001)).to_be(true)

        it "round-trip: chisq_inv(chisq_cdf(5.0,df=4)) ~= 5.0":
            val res = chisq_inv(chisq_cdf(5.0, 4.0), 4.0)
            expect(_approx(res, 5.0, 0.00001)).to_be(true)

        it "round-trip: chisq_inv(chisq_cdf(12.0,df=9)) ~= 12.0":
            val res = chisq_inv(chisq_cdf(12.0, 9.0), 9.0)
            expect(_approx(res, 12.0, 0.00001)).to_be(true)

        it "chisq_cdf domain error (x<0) is NaN":
            val res = chisq_cdf(-1.0, 5.0)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (F distribution)":
    context "f_cdf/f_inv":
        it "f_cdf(3.0,5,10) is 0.934442 (via incomplete beta I_{d1*x/(d1*x+d2)}(d1/2,d2/2))":
            val res = f_cdf(3.0, 5.0, 10.0)
            expect(_approx(res, 0.934442, 0.000001)).to_be(true)

        it "round-trip: f_inv(f_cdf(2.0,d1=4,d2=8)) ~= 2.0":
            val res = f_inv(f_cdf(2.0, 4.0, 8.0), 4.0, 8.0)
            expect(_approx(res, 2.0, 0.00001)).to_be(true)

        it "round-trip: f_inv(f_cdf(1.5,d1=6,d2=12)) ~= 1.5":
            val res = f_inv(f_cdf(1.5, 6.0, 12.0), 6.0, 12.0)
            expect(_approx(res, 1.5, 0.00001)).to_be(true)

        it "f_cdf domain error (d1<1) is NaN":
            val res = f_cdf(1.0, 0.5, 10.0)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (beta)":
    context "beta_cdf/beta_inv":
        it "beta_cdf(0.4,2,3) is 0.5248":
            val res = beta_cdf(0.4, 2.0, 3.0)
            expect(_approx(res, 0.5248, 0.0005)).to_be(true)

        it "round-trip: beta_inv(beta_cdf(0.3,a=2,b=3)) ~= 0.3":
            val res = beta_inv(beta_cdf(0.3, 2.0, 3.0), 2.0, 3.0)
            expect(_approx(res, 0.3, 0.00001)).to_be(true)

        it "round-trip: beta_inv(beta_cdf(0.6,a=2,b=3)) ~= 0.6":
            val res = beta_inv(beta_cdf(0.6, 2.0, 3.0), 2.0, 3.0)
            expect(_approx(res, 0.6, 0.00001)).to_be(true)

        it "beta_cdf domain error (a<=0) is NaN":
            val res = beta_cdf(0.4, 0.0, 3.0)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (gamma)":
    context "gamma_cdf/gamma_inv":
        it "gamma_cdf(2,3,1) is 0.323324":
            val res = gamma_cdf(2.0, 3.0, 1.0)
            expect(_approx(res, 0.323324, 0.0005)).to_be(true)

        it "round-trip: gamma_inv(gamma_cdf(1.5,shape=3,scale=1)) ~= 1.5":
            val res = gamma_inv(gamma_cdf(1.5, 3.0, 1.0), 3.0, 1.0)
            expect(_approx(res, 1.5, 0.00001)).to_be(true)

        it "round-trip: gamma_inv(gamma_cdf(4.0,shape=3,scale=1)) ~= 4.0":
            val res = gamma_inv(gamma_cdf(4.0, 3.0, 1.0), 3.0, 1.0)
            expect(_approx(res, 4.0, 0.00001)).to_be(true)

        it "gamma_cdf domain error (shape<=0) is NaN":
            val res = gamma_cdf(2.0, 0.0, 1.0)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (binomial)":
    context "binom_pmf/binom_cdf":
        it "binom_pmf(3,10,0.5) is 0.1171875":
            val res = binom_pmf(3, 10, 0.5)
            expect(_approx(res, 0.1171875, 0.0000001)).to_be(true)

        it "binom_cdf(3,10,0.5) is 0.171875":
            val res = binom_cdf(3, 10, 0.5)
            expect(_approx(res, 0.171875, 0.0000001)).to_be(true)

        it "binom_pmf(0,5,0.0) is 1.0 (0^0 = 1 convention)":
            val res = binom_pmf(0, 5, 0.0)
            expect(_approx(res, 1.0, 0.0000001)).to_be(true)

        it "binom_pmf domain error (k>n) is NaN":
            val res = binom_pmf(11, 10, 0.5)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (Poisson)":
    context "poisson_pmf/poisson_cdf":
        it "poisson_pmf(2,3) is 0.2240418":
            val res = poisson_pmf(2, 3.0)
            expect(_approx(res, 0.2240418, 0.0000005)).to_be(true)

        it "poisson_pmf(0,0) is 1.0 (0^0 = 1 convention)":
            val res = poisson_pmf(0, 0.0)
            expect(_approx(res, 1.0, 0.0000001)).to_be(true)

        it "poisson_pmf domain error (lambda<0) is NaN":
            val res = poisson_pmf(2, -1.0)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (exponential)":
    context "expon_cdf":
        it "expon_cdf(1,2) is 1 - e^-2 = 0.8646647":
            val res = expon_cdf(1.0, 2.0)
            expect(_approx(res, 0.8646647, 0.0000005)).to_be(true)

        it "expon_cdf domain error (lambda<=0) is NaN":
            val res = expon_cdf(1.0, 0.0)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (hypergeometric)":
    context "hypgeom_pmf":
        it "hypgeom_pmf(1,4,8,20) is C(8,1)*C(12,3)/C(20,4) = 0.363260...":
            val res = hypgeom_pmf(1, 4, 8, 20)
            expect(_approx(res, 0.36326, 0.0001)).to_be(true)

        it "hypgeom_pmf domain error (k>draws) is NaN":
            val res = hypgeom_pmf(5, 4, 8, 20)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (negative binomial)":
    context "negbinom_pmf":
        it "negbinom_pmf(2,3,0.5) is C(4,2)*0.5^3*0.5^2 = 6/32 = 0.1875":
            val res = negbinom_pmf(2, 3, 0.5)
            expect(_approx(res, 0.1875, 0.0000001)).to_be(true)

        it "negbinom_pmf domain error (s<1) is NaN":
            val res = negbinom_pmf(2, 0, 0.5)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (Weibull)":
    context "weibull_cdf":
        it "weibull_cdf(2,1.5,3) is 1 - exp(-(2/3)^1.5) ~= 0.419770":
            val res = weibull_cdf(2.0, 1.5, 3.0)
            expect(_approx(res, 0.419770, 0.000001)).to_be(true)

        it "weibull_cdf(0,shape,scale) is 0.0":
            val res = weibull_cdf(0.0, 1.5, 3.0)
            expect(_approx(res, 0.0, 0.0000001)).to_be(true)

        it "weibull_cdf domain error (shape<=0) is NaN":
            val res = weibull_cdf(2.0, 0.0, 3.0)
            expect(_is_nan(res)).to_be(true)

    context "weibull_pdf":
        it "weibull_pdf(2,1.5,3) is ~0.2366":
            val res = weibull_pdf(2.0, 1.5, 3.0)
            expect(_approx(res, 0.2366, 0.001)).to_be(true)

        it "weibull_pdf(0,shape,scale) is 0.0":
            val res = weibull_pdf(0.0, 1.5, 3.0)
            expect(_approx(res, 0.0, 0.0000001)).to_be(true)

        it "weibull_pdf domain error (shape<=0) is NaN":
            val res = weibull_pdf(2.0, 0.0, 3.0)
            expect(_is_nan(res)).to_be(true)

        it "weibull_pdf domain error (scale<=0) is NaN":
            val res = weibull_pdf(2.0, 1.5, 0.0)
            expect(_is_nan(res)).to_be(true)

        it "weibull_pdf domain error (x<0) is NaN":
            val res = weibull_pdf(-1.0, 1.5, 3.0)
            expect(_is_nan(res)).to_be(true)

describe "std.math.distributions (log-normal)":
    context "lognorm_cdf/lognorm_inv":
        it "lognorm_cdf(4,3.5,1.2) is 0.0390836":
            val res = lognorm_cdf(4.0, 3.5, 1.2)
            expect(_approx(res, 0.0390836, 0.000001)).to_be(true)

        it "round-trip: lognorm_inv(lognorm_cdf(4.0,3.5,1.2)) ~= 4.0":
            val res = lognorm_inv(lognorm_cdf(4.0, 3.5, 1.2), 3.5, 1.2)
            expect(_approx(res, 4.0, 0.0001)).to_be(true)

        it "lognorm_cdf domain error (x<=0) is NaN":
            val res = lognorm_cdf(0.0, 3.5, 1.2)
            expect(_is_nan(res)).to_be(true)
