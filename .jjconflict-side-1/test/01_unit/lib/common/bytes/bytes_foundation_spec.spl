# bytes_foundation_spec.spl — cross-type round-trips with absolute oracles
# Proves AC-3 (ByteBuffer.freeze() <-> ByteSpan) and AC-4 (BitWriter -> BitReader)
# end-to-end, plus an integer-encode -> checksum chain across all five modules.
use std.spec
use lib.common.bytes.span.{ByteSpan, ByteBuffer}
use lib.common.bytes.ints.{U32be, U32le}
use lib.common.bytes.bits.{BitWriter, BitReader}
use lib.common.bytes.checksum.{Crc32}
# Facade import exercises __init__.spl re-exports (AC-1 manifest coverage).
use std.common.bytes.{RingWindow}

describe "AC-3: ByteBuffer.freeze() <-> ByteSpan byte-exact round-trip":
    it "buffer built from a span freezes back to an equal span":
        val original: [u8] = [0xDEu8, 0xADu8, 0xBEu8, 0xEFu8, 0x00u8, 0xFFu8]
        val src = ByteSpan.new(original)
        var buf = ByteBuffer.new()
        buf.push_span(src)
        val frozen = buf.freeze()
        expect(frozen.equals(src)).to_equal(true)
        # absolute oracle: explicit bytes
        expect(frozen.get(0).to_i64()).to_equal(0xDE)
        expect(frozen.get(5).to_i64()).to_equal(0xFF)
        expect(frozen.len()).to_equal(6)

    it "mixed push_u8 + push_span assembles the expected exact bytes":
        var buf = ByteBuffer.new()
        buf.push_u8(0x01u8)
        val tail: [u8] = [0x02u8, 0x03u8]
        buf.push_span(ByteSpan.new(tail))
        val frozen = buf.freeze()
        val expected: [u8] = [0x01u8, 0x02u8, 0x03u8]
        expect(frozen.equals(ByteSpan.new(expected))).to_equal(true)

describe "AC-4: BitWriter -> BitReader bit-exact across orderings":
    it "LSB-first packs and unpacks an exact known bit pattern":
        var w = BitWriter.lsb()
        w.put_bits(0b1, 1)
        w.put_bits(0b011, 3)
        w.put_bits(0b1010, 4)
        val bytes = w.finish().to_bytes()
        # LSB-first: byte = bit0=1, bits1..3=011, bits4..7=1010 -> 0b10100111 = 0xA7
        expect(bytes[0].to_i64()).to_equal(0xA7)
        var r = BitReader.lsb(bytes)
        expect(r.read_bits(1)).to_equal(1)
        expect(r.read_bits(3)).to_equal(3)
        expect(r.read_bits(4)).to_equal(10)

    it "MSB-first packs and unpacks an exact known bit pattern":
        var w = BitWriter.msb()
        w.put_bits(0b1, 1)
        w.put_bits(0b011, 3)
        w.put_bits(0b1010, 4)
        val bytes = w.finish().to_bytes()
        # MSB-first: byte = 1 011 1010 = 0b10111010 = 0xBA
        expect(bytes[0].to_i64()).to_equal(0xBA)
        var r = BitReader.msb(bytes)
        expect(r.read_bits(1)).to_equal(1)
        expect(r.read_bits(3)).to_equal(3)
        expect(r.read_bits(4)).to_equal(10)

describe "Cross-module: encode integers, then checksum the frozen span":
    it "U32be + U32le serialized into a buffer CRC matches a recomputed CRC":
        var buf = ByteBuffer.new()
        U32be.of(0x12345678).store(buf)
        U32le.of(0x9ABCDEF0).store(buf)
        val span = buf.freeze()
        expect(span.len()).to_equal(8)
        # byte layout oracle: BE first (12 34 56 78), then LE (F0 DE BC 9A)
        expect(span.get(0).to_i64()).to_equal(0x12)
        expect(span.get(3).to_i64()).to_equal(0x78)
        expect(span.get(4).to_i64()).to_equal(0xF0)
        expect(span.get(7).to_i64()).to_equal(0x9A)
        # checksum the assembled span; recompute and compare (absolute equality)
        var c1 = Crc32.new()
        c1.update(span)
        var c2 = Crc32.new()
        c2.update(ByteSpan.new(span.to_bytes()))
        expect(c1.raw()).to_equal(c2.raw())

describe "AC-1: package facade (__init__.spl) re-exports load":
    it "RingWindow is reachable via std.common.bytes facade":
        var w = RingWindow.new(4)
        w.push(42u8)
        expect(w.at_distance(1).to_i64()).to_equal(42)
