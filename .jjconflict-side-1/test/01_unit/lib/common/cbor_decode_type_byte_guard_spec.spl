use std.spec.{describe, it, assert_equal}
use std.common.cbor.decode.{cbor_decode_type, cbor_decode_unsigned, cbor_is_unsigned_int}

describe "CBOR decode type byte value guard":
    it "rejects negative initial bytes":
        val type_info = cbor_decode_type([-1], 0)
        assert_equal(type_info.0, -1)
        assert_equal(type_info.1, -1)
        assert_equal(type_info.2, 0)
        assert_equal(cbor_is_unsigned_int([-1], 0), false)

    it "rejects initial bytes greater than one byte":
        val type_info = cbor_decode_type([300], 0)
        val unsigned_result = cbor_decode_unsigned([300], 0)
        assert_equal(type_info.0, -1)
        assert_equal(type_info.1, -1)
        assert_equal(type_info.2, 0)
        assert_equal(unsigned_result.1, 0)

    it "keeps valid single-byte unsigned integers working":
        val type_info = cbor_decode_type([1], 0)
        assert_equal(type_info.0, 0)
        assert_equal(type_info.1, 1)
        assert_equal(type_info.2, 1)
