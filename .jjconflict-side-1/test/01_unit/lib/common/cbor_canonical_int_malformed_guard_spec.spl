use std.spec.{describe, it, assert_equal}
use std.common.cbor.decode.{cbor_is_canonical_int}

describe "CBOR canonical int malformed guard":
    it "rejects malformed initial byte values":
        assert_equal(cbor_is_canonical_int(0, [-256]), false)
        assert_equal(cbor_is_canonical_int(0, [256]), false)

    it "rejects malformed integer payload bytes":
        assert_equal(cbor_is_canonical_int(24, [0x18, 300]), false)
        assert_equal(cbor_is_canonical_int(256, [0x19, -1, 0]), false)

    it "keeps valid canonical integer encodings working":
        assert_equal(cbor_is_canonical_int(0, [0]), true)
        assert_equal(cbor_is_canonical_int(24, [0x18, 24]), true)
        assert_equal(cbor_is_canonical_int(-1, [0x20]), true)
