# widget_draw_cmds_spec — unit tests for widget_tree_to_draw_cmds.
# AC-4/AC-6: pure widget-tree → draw-command projection at 3 canonical viewports.
#
# Asserts:
#   (a) cmd list non-empty and contains a cmd whose widget_id == first nav item id
#       at all three viewports.
#   (b) phone (390x844): nav-item cmd y > 844/2 (bottom bar — item is below mid-screen)
#   (c) tablet-portrait (700x1000 android): nav-item cmd x < 100 and rail container
#       rect w < 120.
#   (d) desktop (1440x900): nav sidebar container rect w >= 200.
#   (e) nav_pattern_probe label == "bottom" / "rail" / "sidebar" respectively.

use std.spec.{describe, it, expect}
use common.ui.widget_draw_cmds.{DrawCmd, widget_tree_to_draw_cmds}
use common.ui.adaptive_scaffold.{NavItem, adaptive_nav_scaffold}
use common.ui.form_factor.{compute_form_factor}
use common.ui.viewport.{new_viewport}
use common.ui.widget.{WidgetNode}
use common.ui.builder.{label, column}

# =========================================================================
# Fixture helpers
# =========================================================================

fn make_nav_items() -> [NavItem]:
    return [
        NavItem(id: "nav_home",     label: "Home",     icon: "home",     action: "go_home"),
        NavItem(id: "nav_search",   label: "Search",   icon: "search",   action: "go_search"),
        NavItem(id: "nav_library",  label: "Library",  icon: "library",  action: "go_library"),
        NavItem(id: "nav_settings", label: "Settings", icon: "settings", action: "go_settings")
    ]

fn make_content_node() -> WidgetNode:
    val items: [WidgetNode] = [
        label("content_title",  "Welcome"),
        label("content_body",   "Main content area")
    ]
    return column("content_panel", items)

fn phone_scaffold() -> WidgetNode:
    val vp = new_viewport(390, 844, "gui")
    val ff = compute_form_factor(vp, "ios", true)
    return adaptive_nav_scaffold("phone_root", make_nav_items(), make_content_node(), ff)

fn tablet_scaffold() -> WidgetNode:
    val vp = new_viewport(700, 1000, "gui")
    val ff = compute_form_factor(vp, "android", true)
    return adaptive_nav_scaffold("tablet_root", make_nav_items(), make_content_node(), ff)

fn desktop_scaffold() -> WidgetNode:
    val vp = new_viewport(1440, 900, "gui")
    val ff = compute_form_factor(vp, "macos", false)
    return adaptive_nav_scaffold("desktop_root", make_nav_items(), make_content_node(), ff)

# =========================================================================
# Helper: find first cmd for a given widget_id
# =========================================================================

fn find_cmd_for(cmds: [DrawCmd], widget_id: text) -> DrawCmd?:
    for cmd in cmds:
        if cmd.widget_id == widget_id:
            return cmd
    return nil

fn find_probe(cmds: [DrawCmd]) -> DrawCmd?:
    return find_cmd_for(cmds, "nav_pattern_probe")

fn find_rect_for(cmds: [DrawCmd], widget_id: text) -> DrawCmd?:
    for cmd in cmds:
        if cmd.widget_id == widget_id and cmd.kind == "rect":
            return cmd
    return nil

# =========================================================================
# (a) Non-empty and first nav item cmd present at all 3 viewports
# =========================================================================

describe "widget_draw_cmds non-empty — phone":
    it "cmds non-empty at 390x844":
        val root = phone_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 390, 844)
        expect(cmds.len() > 0).to_equal(true)

    it "contains cmd for nav_home at 390x844":
        val root = phone_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 390, 844)
        val cmd = find_cmd_for(cmds, "nav_home")
        expect(cmd != nil).to_equal(true)

describe "widget_draw_cmds non-empty — tablet":
    it "cmds non-empty at 700x1000":
        val root = tablet_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 700, 1000)
        expect(cmds.len() > 0).to_equal(true)

    it "contains cmd for nav_home at 700x1000":
        val root = tablet_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 700, 1000)
        val cmd = find_cmd_for(cmds, "nav_home")
        expect(cmd != nil).to_equal(true)

describe "widget_draw_cmds non-empty — desktop":
    it "cmds non-empty at 1440x900":
        val root = desktop_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 1440, 900)
        expect(cmds.len() > 0).to_equal(true)

    it "contains cmd for nav_home at 1440x900":
        val root = desktop_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 1440, 900)
        val cmd = find_cmd_for(cmds, "nav_home")
        expect(cmd != nil).to_equal(true)

# =========================================================================
# (b) Phone: nav-item y > 844/2 (bottom bar)
# =========================================================================

describe "widget_draw_cmds phone bottom bar position":
    it "nav_home cmd y > 422 (below mid-screen, bottom bar)":
        val root = phone_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 390, 844)
        val cmd = find_cmd_for(cmds, "nav_home")
        expect(cmd != nil).to_equal(true)
        expect(cmd.y > 422).to_equal(true)

# =========================================================================
# (c) Tablet rail: nav-item x < 100, rail container w < 120
# =========================================================================

describe "widget_draw_cmds tablet rail position":
    it "nav_home cmd x < 100 (left rail)":
        val root = tablet_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 700, 1000)
        val cmd = find_cmd_for(cmds, "nav_home")
        expect(cmd != nil).to_equal(true)
        expect(cmd.x < 100).to_equal(true)

    it "tablet_root_nav_rail container rect w < 120":
        val root = tablet_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 700, 1000)
        val rail_cmd = find_rect_for(cmds, "tablet_root_nav_rail")
        expect(rail_cmd != nil).to_equal(true)
        expect(rail_cmd.w < 120).to_equal(true)

# =========================================================================
# (d) Desktop sidebar: nav container w >= 200
# =========================================================================

describe "widget_draw_cmds desktop sidebar width":
    it "desktop_root_nav_sidebar container rect w >= 200":
        val root = desktop_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 1440, 900)
        val sidebar_cmd = find_rect_for(cmds, "desktop_root_nav_sidebar")
        expect(sidebar_cmd != nil).to_equal(true)
        expect(sidebar_cmd.w >= 200).to_equal(true)

# =========================================================================
# (e) nav_pattern_probe label
# =========================================================================

describe "widget_draw_cmds nav_pattern_probe labels":
    it "phone probe label == bottom":
        val root = phone_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 390, 844)
        val probe = find_probe(cmds)
        expect(probe != nil).to_equal(true)
        expect(probe.label).to_equal("bottom")

    it "tablet probe label == rail":
        val root = tablet_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 700, 1000)
        val probe = find_probe(cmds)
        expect(probe != nil).to_equal(true)
        expect(probe.label).to_equal("rail")

    it "desktop probe label == sidebar":
        val root = desktop_scaffold()
        val cmds = widget_tree_to_draw_cmds(root, 1440, 900)
        val probe = find_probe(cmds)
        expect(probe != nil).to_equal(true)
        expect(probe.label).to_equal("sidebar")
