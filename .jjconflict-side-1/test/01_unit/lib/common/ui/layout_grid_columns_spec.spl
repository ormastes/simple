# @cover src/lib/common/ui/layout.spl 80%
# @req FR-UI-LAYOUT-GRID-COLUMNS
#
# Grid layout gains an optional explicit `columns` prop (falls back to the
# sqrt "square-ish" heuristic when unset) and a per-child `col_span` prop
# that widens a cell across multiple columns, wrapping to a new row when a
# span would overflow the remaining columns.

use std.spec.{describe, it, expect}
use common.ui.widget.{WidgetNode, WidgetKind}
use common.ui.builder.{button}
use common.ui.layout.{compute_layout, find_rect}

# `grid_layout()` (common.ui.builder) wraps children in a WidgetKind.Panel
# container, and compute_layout gives panels a fixed 1px border on every
# side — which would make every expected coordinate below off-by-the-border.
# Build a border-free grid container directly (any non-"panel" kind skips
# the border trim) so the exact-pixel assertions are simple round numbers.
fn _grid(id: text, children: [WidgetNode]) -> WidgetNode:
    var node = WidgetNode.new(id, WidgetKind.Card.to_wire())
    node = node.set_layout("grid")
    for child in children:
        node = node.add_child(child)
    node

describe "layout_grid columns/col_span":

    it "still auto-computes a square-ish grid when columns is unset (regression)":
        val root = _grid("auto_grid", [
            button("auto_a", "A", "a"),
            button("auto_b", "B", "b"),
            button("auto_c", "C", "c"),
            button("auto_d", "D", "d"),
        ])
        val rects = compute_layout(WidgetNode(id: "auto_grid"), 0, 0, 80, 40)
        match find_rect(rects, "auto_b"):
            case Some(rb):
                # 4 items => cols=2, cell_w = 80/2 = 40, so item B starts at x=40.
                expect(rb.x).to_equal(40)
                expect(rb.y).to_equal(0)
            case _: assert_true(false)

    it "lays 6 items into an explicit 4-column grid as 4+2":
        val root = _grid("cols4_grid", [
            button("c4_0", "0", "a"), button("c4_1", "1", "a"),
            button("c4_2", "2", "a"), button("c4_3", "3", "a"),
            button("c4_4", "4", "a"), button("c4_5", "5", "a"),
        ])
        WidgetNode(id: "cols4_grid").set_prop("columns", "4")
        val rects = compute_layout(WidgetNode(id: "cols4_grid"), 0, 0, 400, 200)
        # cell_w = 400/4 = 100, 6 items over 4 cols => 2 rows, cell_h = 200/2 = 100.
        match find_rect(rects, "c4_3"):
            case Some(r3):
                expect(r3.x).to_equal(300)
                expect(r3.y).to_equal(0)
            case _: assert_true(false)
        # Item 4 (5th item, index 4) wraps to row 1, col 0.
        match find_rect(rects, "c4_4"):
            case Some(r4):
                expect(r4.x).to_equal(0)
                expect(r4.y).to_equal(100)
            case _: assert_true(false)
        # Item 5 (last) is row 1, col 1.
        match find_rect(rects, "c4_5"):
            case Some(r5):
                expect(r5.x).to_equal(100)
                expect(r5.y).to_equal(100)
            case _: assert_true(false)

    it "col_span widens a cell across multiple columns":
        val root = _grid("span_grid", [
            button("span_wide", "W", "a"),
            button("span_b", "B", "b"),
            button("span_c", "C", "c"),
        ])
        WidgetNode(id: "span_grid").set_prop("columns", "3")
        WidgetNode(id: "span_wide").set_prop("col_span", "2")
        val rects = compute_layout(WidgetNode(id: "span_grid"), 0, 0, 300, 100)
        # cell_w = 300/3 = 100. The first item spans 2 cols => width 200.
        match find_rect(rects, "span_wide"):
            case Some(rw):
                expect(rw.x).to_equal(0)
                expect(rw.w).to_equal(200)
            case _: assert_true(false)
        # Second item no longer fits in the remaining 1 col of row 0's 3
        # (it only needs 1, so it DOES fit at col 2, x=200).
        match find_rect(rects, "span_b"):
            case Some(rb):
                expect(rb.x).to_equal(200)
                expect(rb.y).to_equal(0)
            case _: assert_true(false)
        # Third item wraps to row 1 (row 0 is full: 2+1=3 cols used).
        match find_rect(rects, "span_c"):
            case Some(rc):
                expect(rc.x).to_equal(0)
                expect(rc.y).to_equal(50)
            case _: assert_true(false)

    it "wraps a span to a new row when it would overflow the current row":
        val root = _grid("span_wrap_grid", [
            button("wrap_a", "A", "a"),
            button("wrap_wide", "W", "b"),
        ])
        WidgetNode(id: "span_wrap_grid").set_prop("columns", "2")
        WidgetNode(id: "wrap_wide").set_prop("col_span", "2")
        val rects = compute_layout(WidgetNode(id: "span_wrap_grid"), 0, 0, 200, 100)
        # cell_w = 200/2 = 100. wrap_a takes col 0 of row 0 (span 1).
        # wrap_wide needs span 2 but only 1 col remains in row 0 => wraps to row 1.
        match find_rect(rects, "wrap_a"):
            case Some(ra):
                expect(ra.x).to_equal(0)
                expect(ra.y).to_equal(0)
            case _: assert_true(false)
        match find_rect(rects, "wrap_wide"):
            case Some(rw):
                expect(rw.x).to_equal(0)
                expect(rw.y).to_equal(50)
                expect(rw.w).to_equal(200)
            case _: assert_true(false)
