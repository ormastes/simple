# @cover src/lib/common/ui/widget_interact_model.spl 70%
# @req FR-UI-TEXT-EDIT
#
# Real caret text editing (item 1): insert at caret, backspace/delete both
# directions, home/end/left/right movement, selection replace, and UTF-8
# character-based (not byte-based) slicing. The reducer is pure, so this runs
# in the interpreter without any host key plumbing.

use std.spec.*
use common.ui.widget_interact_model.{InteractState, on_key, on_key_mod, has_selection, text_nchars}

# Key codes (mirror the module's private constants; the reducer maps A-Z -> a-z).
val K_BACKSPACE: i64 = 8
val K_END: i64 = 35
val K_HOME: i64 = 36
val K_LEFT: i64 = 37
val K_RIGHT: i64 = 39
val K_DELETE: i64 = 46

fn seed(text_val: text, caret: i32) -> InteractState:
    InteractState(counter: 0, text: text_val, caret: caret, sel_anchor: -1, scroll_offset: 0, anim_x: 0, anim_dx: 3)

describe "widget text editing reducer (item 1)":

    it "inserts a printable char AT the caret, not appended":
        var s = seed("hi", 1)          # caret between h|i
        s = on_key(s, 88)              # 'X' -> 'x'
        expect(s.text).to_equal("hxi")
        expect(s.caret).to_equal(2)

    it "backspace deletes the char before the caret":
        var s = seed("abc", 2)         # ab|c
        s = on_key(s, K_BACKSPACE)
        expect(s.text).to_equal("ac")
        expect(s.caret).to_equal(1)

    it "delete removes the char at the caret":
        var s = seed("abc", 1)         # a|bc
        s = on_key(s, K_DELETE)
        expect(s.text).to_equal("ac")
        expect(s.caret).to_equal(1)

    it "home and end move the caret to the bounds":
        var s = seed("hello", 2)
        s = on_key(s, K_HOME)
        expect(s.caret).to_equal(0)
        s = on_key(s, K_END)
        expect(s.caret).to_equal(5)

    it "left and right move the caret and clamp at the ends":
        var s = seed("ab", 0)
        s = on_key(s, K_LEFT)          # clamp at 0
        expect(s.caret).to_equal(0)
        s = on_key(s, K_RIGHT)
        s = on_key(s, K_RIGHT)
        s = on_key(s, K_RIGHT)         # clamp at 2
        expect(s.caret).to_equal(2)

    it "does not corrupt multi-byte UTF-8 on backspace (char, not byte, indexed)":
        var s = seed("héllo", 5)       # 5 chars, 6 bytes
        s = on_key(s, K_BACKSPACE)     # drop trailing 'o'
        expect(text_nchars(s.text)).to_equal(4)
        expect(s.text).to_equal("héll")
        s = on_key(s, K_HOME)
        s = on_key(s, K_RIGHT)         # caret after 'h', before 'é'
        s = on_key(s, K_DELETE)        # delete the 'é' cleanly
        expect(s.text).to_equal("hll")

    it "shift+arrow builds a selection that typing replaces":
        var s = seed("abcd", 0)
        s = on_key_mod(s, K_RIGHT, true)   # select a
        s = on_key_mod(s, K_RIGHT, true)   # select ab
        assert_true(has_selection(s))
        s = on_key(s, 90)                  # 'Z' -> 'z' replaces selection
        expect(s.text).to_equal("zcd")
        assert_true(not has_selection(s))
