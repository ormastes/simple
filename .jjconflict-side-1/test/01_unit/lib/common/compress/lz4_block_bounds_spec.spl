use std.spec
use std.common.compress.{CompressionError}
use std.common.compress.lz4.{_lz4_decode_block}

fn check(condition: bool):
    expect condition == true

describe "LZ4 block bounds validation":
    it "rejects negative block start before indexing":
        var data: [u8] = [0x00u8]
        val decoded = _lz4_decode_block(data, -1, 1)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("bounds"))
            _:
                check(false)

    it "rejects oversized block length before indexing":
        var data: [u8] = [0x00u8]
        val decoded = _lz4_decode_block(data, 0, 2)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("bounds"))
            _:
                check(false)
