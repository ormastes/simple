# @cover src/lib/common/audio/wav_decode.spl 90%
# @tag: audio, wav, decode
#
# WAV Decode Specification
#
# Verifies the RIFF/WAVE decoder against hand-built minimal WAV byte KATs
# (bytes are hand-computed, not produced by calling the encoder — an
# independent oracle), an unknown-chunk skip between "fmt " and "data", the
# encoder/decoder round-trip for both PCM16 (lossy per the documented
# trunc-then-clamp quantization at the +-1.0 clamp case) and float32
# (bit-exact), and malformed-input rejection.
#
# One `expect` per `it` — the interpreter test-runner's file-summary only
# reliably reflects the LAST `expect` in a block; verified with
# `bin/simple test` while grepping for `✗`, per the SPipe skill's
# interpreter-mode caveat.
#
# Plan: doc/03_plan/app/game_tools/sound_music_effects_plan.md (Step 1)

use std.spec.{describe, context, it, expect}
use std.common.audio.wav_decode.{decode_wav}
use std.common.audio.wav_encode.{encode_wav_pcm16, encode_wav_f32}

# Hand-built minimal mono 8kHz PCM16 WAV: one sample, u16 0x4000 (== 0.5).
val KAT_PCM16_8KHZ_ONE_SAMPLE: [u8] = [
    82u8, 73u8, 70u8, 70u8, 38u8, 0u8, 0u8, 0u8,
    87u8, 65u8, 86u8, 69u8,
    102u8, 109u8, 116u8, 32u8, 16u8, 0u8, 0u8, 0u8,
    1u8, 0u8, 1u8, 0u8, 64u8, 31u8, 0u8, 0u8, 64u8, 31u8, 0u8, 0u8, 2u8, 0u8, 16u8, 0u8,
    100u8, 97u8, 116u8, 97u8, 2u8, 0u8, 0u8, 0u8,
    0u8, 64u8
]

describe "wav_decode decode_wav":

    context "hand-built minimal PCM16 WAV (not produced by the encoder)":

        it "decodes one 0x4000 PCM16 sample to exactly 0.5":
            val r = decode_wav(KAT_PCM16_8KHZ_ONE_SAMPLE)
            var got: [f32] = []
            if val Ok(a) = r:
                got = a.samples
            expect(got).to_equal([0.5])

        it "reports sample_rate=8000 from the fmt chunk":
            val r = decode_wav(KAT_PCM16_8KHZ_ONE_SAMPLE)
            var sr: i64 = -1
            if val Ok(a) = r:
                sr = a.sample_rate
            expect(sr).to_equal(8000)

        it "reports channels=1 from the fmt chunk":
            val r = decode_wav(KAT_PCM16_8KHZ_ONE_SAMPLE)
            var ch: i64 = -1
            if val Ok(a) = r:
                ch = a.channels
            expect(ch).to_equal(1)

    context "unknown chunk between fmt and data is skipped by size, not misread":

        it "still decodes the sample after a spliced-in 4-byte unknown chunk":
            # Same fmt/data as KAT_PCM16_8KHZ_ONE_SAMPLE, with a "JUNK" chunk
            # (declared size 4, 4 zero bytes) inserted between fmt and data.
            # RIFF size = 4(WAVE) + (8+16 fmt) + (8+4 JUNK) + (8+2 data) = 50.
            val bytes: [u8] = [
                82u8, 73u8, 70u8, 70u8, 50u8, 0u8, 0u8, 0u8,
                87u8, 65u8, 86u8, 69u8,
                102u8, 109u8, 116u8, 32u8, 16u8, 0u8, 0u8, 0u8,
                1u8, 0u8, 1u8, 0u8, 64u8, 31u8, 0u8, 0u8, 64u8, 31u8, 0u8, 0u8, 2u8, 0u8, 16u8, 0u8,
                74u8, 85u8, 78u8, 75u8, 4u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
                100u8, 97u8, 116u8, 97u8, 2u8, 0u8, 0u8, 0u8,
                0u8, 64u8
            ]
            val r = decode_wav(bytes)
            var got: [f32] = []
            if val Ok(a) = r:
                got = a.samples
            expect(got).to_equal([0.5])

    context "malformed input":

        it "rejects bytes missing the RIFF tag with a clear Err":
            val bad: [u8] = [88u8, 88u8, 88u8, 88u8, 0u8, 0u8, 0u8, 0u8, 87u8, 65u8, 86u8, 69u8]
            val r = decode_wav(bad)
            var has_marker = false
            if val Err(e) = r:
                has_marker = e.contains("RIFF")
            expect(has_marker).to_equal(true)

        it "rejects an unsupported audio_format/bits combination (8-bit PCM) with a clear Err":
            # Same shape as KAT_PCM16_8KHZ_ONE_SAMPLE but bits_per_sample=8
            # and a 2-byte data chunk (2 samples of 1 byte each).
            val bytes: [u8] = [
                82u8, 73u8, 70u8, 70u8, 38u8, 0u8, 0u8, 0u8,
                87u8, 65u8, 86u8, 69u8,
                102u8, 109u8, 116u8, 32u8, 16u8, 0u8, 0u8, 0u8,
                1u8, 0u8, 1u8, 0u8, 64u8, 31u8, 0u8, 0u8, 64u8, 31u8, 0u8, 0u8, 1u8, 0u8, 8u8, 0u8,
                100u8, 97u8, 116u8, 97u8, 2u8, 0u8, 0u8, 0u8,
                128u8, 128u8
            ]
            val r = decode_wav(bytes)
            var has_marker = false
            if val Err(e) = r:
                has_marker = e.contains("unsupported format")
            expect(has_marker).to_equal(true)

describe "wav_decode / wav_encode round-trip":

    context "PCM16 — exact except at the documented +-1.0 clamp":

        it "round-trips [0.0, 0.5, -0.5, 1.0] to [0.0, 0.5, -0.5, 32767/32768]":
            val samples: [f32] = [0.0, 0.5, -0.5, 1.0]
            val bytes = encode_wav_pcm16(samples, 1, 44100)
            val r = decode_wav(bytes)
            var got: [f32] = []
            if val Ok(a) = r:
                got = a.samples
            expect(got).to_equal([0.0, 0.5, -0.5, 0.999969482421875])

    context "float32 — bit-exact":

        it "round-trips [0.0, 0.5, -0.5, 1.0] exactly":
            val samples: [f32] = [0.0, 0.5, -0.5, 1.0]
            val bytes = encode_wav_f32(samples, 1, 44100)
            val r = decode_wav(bytes)
            var got: [f32] = []
            if val Ok(a) = r:
                got = a.samples
            expect(got).to_equal([0.0, 0.5, -0.5, 1.0])
