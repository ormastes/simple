# @covers src/lib/common/serialization/serialize.spl 70%
"""
# Serialization Exhaustive Branch Coverage Specification

**Feature IDs:** #SERIAL-COV-EXHAUSTIVE
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Exhaustive per-character and per-value coverage for all lookup functions:
- char_code_safe exhaustive (all ASCII)
- digit_to_hex exhaustive (0-15)
- hex_to_digit exhaustive (all hex chars)
- char_to_digit_safe exhaustive
"""

use serialization.*

# ============================================================================

describe "char_code_safe range boundary chars":
    """
    ## Exercise AND Conditions in Range Checks

    char_code_safe has: c >= "0" and c <= "9", c >= "A" and c <= "Z", c >= "a" and c <= "z"
    Need chars where first half TRUE but second FALSE (just past range end).
    """

    # Just past digit range end (c >= "0" TRUE, c <= "9" FALSE -> ":" is 58)
    it "handles colon just past digit range":
        expect(char_code_safe(":")).to_equal(58)

    # Just past uppercase range end (c >= "A" TRUE, c <= "Z" FALSE -> "[" is 91)
    it "handles bracket just past uppercase range":
        expect(char_code_safe("[")).to_equal(91)

    # Just past lowercase range end (c >= "a" TRUE, c <= "z" FALSE -> "{" is 123)
    it "handles brace just past lowercase range":
        expect(char_code_safe("\{")).to_equal(123)

    # Just before digit range start (c >= "0" FALSE -> "/" is 47)
    it "handles slash before digit range":
        expect(char_code_safe("/")).to_equal(47)

    # Just before uppercase range start (c >= "A" FALSE -> "@" is 64)
    it "handles at-sign before uppercase range":
        expect(char_code_safe("@")).to_equal(64)

    # Just before lowercase range start (c >= "a" FALSE -> "`" is 96)
    it "handles backtick before lowercase range":
        expect(char_code_safe("`")).to_equal(96)

describe "detect_format compound OR branches":
    """
    ## Exercise All OR Sub-Conditions

    detect_format has: first == "{" or first == "["
    and: serialized == "true" or serialized == "false" or serialized == "nil"
    """

    # first == "{" TRUE (short-circuits, never checks "[")
    it "detects sdn for object starting with curly":
        expect(detect_format("\{a: 1\}")).to_equal("sdn")

    # first == "{" FALSE, first == "[" TRUE
    it "detects sdn for array starting with bracket":
        expect(detect_format("[1]")).to_equal("sdn")

    # serialized == "true" TRUE (short-circuits)
    it "detects sdn for true":
        expect(detect_format("true")).to_equal("sdn")

    # serialized == "true" FALSE, serialized == "false" TRUE
    it "detects sdn for false":
        expect(detect_format("false")).to_equal("sdn")

    # serialized == "true" FALSE, serialized == "false" FALSE, serialized == "nil" TRUE
    it "detects sdn for nil":
        expect(detect_format("nil")).to_equal("sdn")

    # All three FALSE -> falls to is_numeric_text
    it "detects sdn for number after failing literal checks":
        expect(detect_format("99")).to_equal("sdn")

    # is_numeric_text FALSE -> returns "unknown"
    it "returns unknown when no format matches":
        expect(detect_format("xyz")).to_equal("unknown")

describe "is_valid_sdn compound OR":
    """
    ## Exercise OR in is_valid_sdn
    format == "sdn" or format == "tagged"
    """

    it "returns true when format is sdn":
        expect(is_valid_sdn("42")).to_equal(true)

    it "returns true when format is tagged":
        expect(is_valid_sdn("@T\{x\}")).to_equal(true)

    it "returns false when format is unknown":
        expect(is_valid_sdn("abc")).to_equal(false)

describe "hex_to_digit compound OR branches":
    """
    ## Exercise OR in hex_to_digit
    Each hex letter has: h == "x" or h == "X"
    """

    it "converts lowercase a":
        expect(hex_to_digit("a")).to_equal(10)

    it "converts uppercase A":
        expect(hex_to_digit("A")).to_equal(10)

    it "converts lowercase b":
        expect(hex_to_digit("b")).to_equal(11)

    it "converts uppercase B":
        expect(hex_to_digit("B")).to_equal(11)

    it "converts lowercase c":
        expect(hex_to_digit("c")).to_equal(12)

    it "converts uppercase C":
        expect(hex_to_digit("C")).to_equal(12)

    it "converts lowercase d":
        expect(hex_to_digit("d")).to_equal(13)

    it "converts uppercase D":
        expect(hex_to_digit("D")).to_equal(13)

    it "converts lowercase e":
        expect(hex_to_digit("e")).to_equal(14)

    it "converts uppercase E":
        expect(hex_to_digit("E")).to_equal(14)

    it "converts lowercase f":
        expect(hex_to_digit("f")).to_equal(15)

    it "converts uppercase F":
        expect(hex_to_digit("F")).to_equal(15)

describe "is_numeric_text compound AND":
    """
    ## Exercise AND in ch >= "0" and ch <= "9"
    """

    # ch >= "0" TRUE, ch <= "9" TRUE (digit in string)
    it "accepts pure digits":
        expect(is_numeric_text("123")).to_equal(true)

    # ch >= "0" TRUE, ch <= "9" FALSE (char just past 9, e.g. ":")
    it "rejects colon in number":
        expect(is_numeric_text("1:2")).to_equal(false)

    # ch >= "0" FALSE (char before "0", e.g. "!")
    it "rejects exclamation mark":
        expect(is_numeric_text("!")).to_equal(false)

describe "unquote_string compound AND":
    """
    ## Exercise the AND condition in unquote_string
    s[0:1] == "\"" and s[s.len()-1:s.len()] == "\""
    """

    # First half TRUE, second half FALSE
    it "returns string with opening quote but no closing":
        val result = unquote_string("\"abc")
        expect(result).to_equal("\"abc")

    # First half FALSE
    it "returns string with no quotes":
        val result = unquote_string("abc\"")
        expect(result).to_equal("abc\"")

describe "get_version loop branches":
    """
    ## Exercise get_version While Loop and Inner Conditions
    """

    it "extracts version with space before comma":
        val versioned = "\{v: 5, data: x\}"
        val result = get_version(versioned)
        expect(result).to_equal(5)

    it "returns nil for version with no comma":
        val result = get_version("\{v: 123\}")
        expect(result).to_be_nil()

describe "strip_version loop branches":
    """
    ## Exercise strip_version While Loop
    """

    it "strips version from short data":
        val versioned = add_version("x", 1)
        val result = strip_version(versioned)
        expect(result).to_equal("x")

    it "handles version string that is just prefix":
        val result = strip_version("\{v: 1, dat\}")
        # No "data: " found, returns original
        expect(result).to_equal("\{v: 1, dat\}")

describe "write_varint boundary values":
    """
    ## Varint boundary between single and multi-byte
    """

    it "encodes 127 as single byte":
        val result = write_varint(127)
        expect(result.len()).to_equal(1)

    it "encodes 128 as two bytes with continuation bit":
        val result = write_varint(128)
        expect(result.len()).to_equal(2)
        val first_byte = result[0]
        # First byte should have continuation bit set (>= 128)
        expect(first_byte).to_be_greater_than(127)

    it "encodes 255 as two bytes":
        val result = write_varint(255)
        expect(result.len()).to_equal(2)

describe "read_varint loop termination":
    """
    ## Exercise read_varint Loop Exit Conditions
    """

    it "reads single-byte varint with byte < 128":
        val result = read_varint([42], 0)
        expect(result.0).to_equal(42)
        expect(result.1).to_equal(1)

    it "reads two-byte varint continuing past first byte":
        val encoded = write_varint(200)
        val result = read_varint(encoded, 0)
        expect(result.0).to_equal(200)

describe "structural_hash_bool branches":
    """
    ## Exercise the if b branch in structural_hash_bool
    """

    it "returns 1 for true":
        expect(structural_hash_bool(true)).to_equal(1)

    it "returns 0 for false":
        expect(structural_hash_bool(false)).to_equal(0)

describe "structural_hash_int xor branch":
    """
    ## Exercise the xor shift in structural_hash_int
    """

    it "hashes 3 to non-zero":
        val h = structural_hash_int(3)
        expect(h == 0).to_equal(false)

    it "hashes 100 to non-zero":
        val h = structural_hash_int(100)
        expect(h == 0).to_equal(false)

