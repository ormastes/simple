"""Styled markdown render spec.

Verifies that `render_markdown_line_styled_html` routes markdown lines through
the shared office style resolver, emitting HTML with an inline CSS `style`
attribute. This is the end-to-end demonstration of the LibreOffice-suite CSS
spine: markdown -> office_style_resolver -> styled HTML, the same theme the
Word/PPT surfaces use.

The paragraph path is asserted here (runner-stable, no numeric interpolation).
The heading path (`# Title` -> `<h1 style="font-size: 2em; ...">`) is verified
via direct `bin/simple run`; under the test runner's compiled mode the heading
*level* (an i32) interpolates unreliably — the same toolchain fragility tracked
in doc/08_tracking/bug/interp_f64_nested_struct_payload_zero_2026-06-14.md. The
resolver spec already asserts the heading_1 style values directly.
"""

use std.spec
use std.common.markdown.render.{render_markdown_line_styled_html}

describe "styled markdown render: paragraphs carry resolved CSS":
    """A non-heading line renders as a styled paragraph whose inline CSS comes
    from the shared office style resolver's Word-level default theme."""

    it "wraps the line in a styled <p> element":
        val html = render_markdown_line_styled_html("hello world")
        expect(html).to_start_with("<p style=\"")
        expect(html).to_contain(">hello world</p>")

    it "inlines the resolver's paragraph line-height and margin":
        val html = render_markdown_line_styled_html("body text")
        expect(html).to_contain("line-height: 1.5;")
        expect(html).to_contain("margin-bottom: 1em;")

    it "escapes HTML in the paragraph body":
        val html = render_markdown_line_styled_html("a < b & c")
        expect(html).to_contain("&lt;")
        expect(html).to_contain("&amp;")
