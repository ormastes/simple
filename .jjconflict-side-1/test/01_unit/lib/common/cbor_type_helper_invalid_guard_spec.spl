use std.spec.{describe, it, assert_equal}
use std.common.cbor.types.{get_additional_info, get_major_type, make_initial_byte}

describe "CBOR type helper invalid guard":
    it "rejects invalid initial byte construction fields":
        assert_equal(make_initial_byte(-1, 0), -1)
        assert_equal(make_initial_byte(8, 0), -1)
        assert_equal(make_initial_byte(0, -1), -1)
        assert_equal(make_initial_byte(0, 32), -1)

    it "rejects malformed initial bytes during extraction":
        assert_equal(get_major_type(-1), -1)
        assert_equal(get_major_type(256), -1)
        assert_equal(get_additional_info(-1), -1)
        assert_equal(get_additional_info(256), -1)

    it "keeps valid initial byte helpers working":
        assert_equal(make_initial_byte(7, 31), 255)
        assert_equal(get_major_type(255), 7)
        assert_equal(get_additional_info(255), 31)
