use std.spec.{describe, it, assert_equal}
use std.common.base_encoding.base32.{base32_decode, base32_decode_hex}
use std.common.base_encoding.utilities.{bytes_to_text}

describe "base32 padding guards":
    it "keeps valid padded standard base32 decode":
        assert_equal(bytes_to_text(base32_decode("MY======")), "f")

    it "keeps valid padded base32hex decode":
        assert_equal(bytes_to_text(base32_decode_hex("CO======")), "f")

    it "rejects standard padding before enough data":
        assert_equal(base32_decode("========").len(), 0)
        assert_equal(base32_decode("M=======").len(), 0)

    it "rejects standard data after padding":
        assert_equal(base32_decode("MY=A").len(), 0)

    it "rejects base32hex data after padding":
        assert_equal(base32_decode_hex("CO=0").len(), 0)

    it "rejects invalid standard unpadded final group lengths":
        assert_equal(base32_decode("M").len(), 0)
        assert_equal(base32_decode("MZX").len(), 0)
        assert_equal(base32_decode("MZXW6Y").len(), 0)

    it "rejects invalid base32hex unpadded final group lengths":
        assert_equal(base32_decode_hex("C").len(), 0)
        assert_equal(base32_decode_hex("CPN").len(), 0)
        assert_equal(base32_decode_hex("CPNMUO").len(), 0)
