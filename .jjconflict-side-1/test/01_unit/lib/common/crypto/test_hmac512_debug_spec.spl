use std.spipe.*
use std.crypto.hmac.{hmac_sha512_256_bytes}

describe "hmac_sha512_256 debug":
    it "basic call doesn't crash":
        var key: [i64] = []
        var data: [i64] = []
        var i = 0
        while i < 7:
            key.push(7)
            i = i + 1
        i = 0
        while i < 11:
            data.push(11)
            i = i + 1
        val result = hmac_sha512_256_bytes(key, data)
        expect(result.len()).to_equal(32)
