use std.spipe.*
use std.crypto.sha512.{sha512_bytes}

describe "lshr64 debug":
    it "sha512 bytes([0x61]) gets some output":
        val r = sha512_bytes([0x61])
        expect(r.len()).to_equal(64)
    it "sha512 empty output length":
        val r = sha512_bytes([])
        expect(r.len()).to_equal(64)
    it "empty first byte should be 0xcf":
        val r = sha512_bytes([])
        expect(r[0]).to_equal(0xcf)
