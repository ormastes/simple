use std.spipe.*

fn _lshr64(x: i64, n: i64) -> i64:
    # Logical right shift: `>>` is arithmetic (sign-extends) on i64, so mask off
    # the n sign bits AFTER shifting. (The old `(x & -1) >> n` was just an
    # arithmetic shift and never matched the logical-shift expectations below.)
    if n == 0:
        return x
    val mask = (1 << (64 - n)) - 1
    (x >> n) & mask

describe "lshr64 test":
    it "positive value shifts logically":
        # 0x6f = 111, shift right 0 = 111
        expect(_lshr64(111, 0)).to_equal(111)
    it "negative value: -1 >> 1 should be max_i64 (0x7fffffffffffffff)":
        val r = _lshr64(-1, 1)
        # Arithmetic shift: -1 >> 1 = -1 (sign extend)
        # Logical shift: 0xFFFFFFFFFFFFFFFF >> 1 = 0x7FFFFFFFFFFFFFFF
        expect(r).to_equal(9223372036854775807)
    it "negative value >> 8":
        # -1 (0xFFFFFFFFFFFF...) >> 8 should be 0x00FFFFFFFFFFFFFF
        val r = _lshr64(-1, 8)
        expect(r).to_equal(72057594037927935)
    it "mask with -1 is no-op":
        val x = -1
        val r = x & -1
        # In Python bignum, -1 & -1 = -1, same as i64 -1
        expect(r).to_equal(-1)
