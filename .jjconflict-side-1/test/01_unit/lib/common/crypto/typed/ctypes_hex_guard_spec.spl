use std.spec.{describe, it, assert_equal}
use std.common.crypto.typed.ctypes.{Digest, MacTag, SecretKey}

describe "typed crypto hex guards":
    it "keeps valid digest hex decoding":
        val d = Digest.from_hex("deadbeef")
        assert_equal(d.len(), 4)
        assert_equal(d.hex(), "deadbeef")

    it "rejects odd-length digest hex":
        val d = Digest.from_hex("abc")
        assert_equal(d.len(), 0)

    it "rejects invalid digest hex characters":
        val d = Digest.from_hex("dezg")
        assert_equal(d.len(), 0)

    it "rejects malformed MAC tag hex":
        val m = MacTag.from_hex("ca?e")
        assert_equal(m.len(), 0)

    it "rejects malformed secret key hex":
        val k = SecretKey.from_hex("00xz")
        assert_equal(k.len(), 0)
