use std.spec.{describe, it, assert_equal}
use std.common.cbor.utilities.{cbor_hexdump}

describe "CBOR hexdump invalid byte guard":
    it "rejects malformed byte values":
        assert_equal(cbor_hexdump([-1]), "")
        assert_equal(cbor_hexdump([0, 300]), "")

    it "keeps valid byte formatting working":
        assert_equal(cbor_hexdump([0, 15, 16, 255]), "00 0f 10 ff")
