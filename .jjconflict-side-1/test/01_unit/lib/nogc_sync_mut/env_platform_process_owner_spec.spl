use std.spec

describe "environment process runtime ownership":
    it "keeps rt_process_run owned by env types only":
        val platform = file_read("src/lib/nogc_sync_mut/env/platform.spl")
        val types = file_read("src/lib/nogc_sync_mut/env/types.spl")

        expect(platform).to_contain("use std.env.types.{rt_env_home, rt_hostname, rt_env_cwd, rt_process_run}")
        expect(platform.contains("extern fn rt_process_run")).to_equal(false)
        expect(types).to_contain("extern fn rt_process_run")
        expect(types).to_contain("export rt_env_get, rt_env_home, rt_env_set, rt_env_cwd, rt_env_remove, rt_hostname, rt_process_run, rt_env_vars")
