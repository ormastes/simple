extern fn rt_file_read_text(path: text) -> text

fn _contains_dwarf_abbrev_negative_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn read_uleb128(data: [u8], offset: i64) -> (i64, i64):") and
        source.to_contain("fn read_sleb128(data: [u8], offset: i64) -> (i64, i64):") and
        source.to_contain("if offset < 0:\n        return (0, 0)") and
        source.to_contain("val byte = data[pos] as i64") and
        source.to_contain("byte = data[pos] as i64")

describe "DWARF abbreviation negative offset guards":
    it "guards mirrored LEB128 readers before indexed reads":
        expect(_contains_dwarf_abbrev_negative_guards("src/lib/nogc_sync_mut/debug/formats/dwarf_abbrev.spl")).to_equal(true)
        expect(_contains_dwarf_abbrev_negative_guards("src/lib/nogc_async_mut/debug/formats/dwarf_abbrev.spl")).to_equal(true)
