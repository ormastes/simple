extern fn rt_file_read_text(path: text) -> text

fn _contains_dwarf_line_negative_guard(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn _read_null_terminated_string(data: [u8], offset: i64) -> (text, i64):") and
        source.to_contain("if offset < 0:\n        return (\"\", 0)") and
        source.to_contain("val b = data[pos]")

describe "DWARF line program negative offset guards":
    it "guards mirrored null-terminated string readers before indexed reads":
        expect(_contains_dwarf_line_negative_guard("src/lib/nogc_sync_mut/debug/formats/dwarf_line_program.spl")).to_equal(true)
        expect(_contains_dwarf_line_negative_guard("src/lib/nogc_async_mut/debug/formats/dwarf_line_program.spl")).to_equal(true)
