# SIMD UTF-8 Fuzz Regression Tests
#
# Deterministic fuzz coverage for raw-byte UTF-8 validation and text-side SIMD
# APIs. Raw valid-byte count/find-invalid has interpreter extern limitations,
# so valid UTF-8 count coverage is exercised through text values below.

use std.spec.{describe, it, expect}
use std.encoding.utf8.{rt_utf8_validate, rt_utf8_find_invalid}
use std.encoding.simd_text_ffi.{
    rt_text_count_codepoints_cached, rt_text_is_ascii, rt_text_validate_utf8,
    rt_simd_str_search, rt_simd_str_equal
}

fn continuation_byte(byte: i64) -> bool:
    byte >= 0x80 and byte <= 0xBF

fn valid_range(byte: i64, lo: i64, hi: i64) -> bool:
    byte >= lo and byte <= hi

fn scalar_find_invalid(bytes: [i64]) -> i64:
    var i = 0
    while i < bytes.len():
        val b0 = bytes[i]
        if b0 < 0 or b0 > 255:
            return i
        if b0 < 0x80:
            i = i + 1
        else if b0 >= 0xC2 and b0 <= 0xDF:
            if i + 1 >= bytes.len() or not continuation_byte(bytes[i + 1]):
                return i
            i = i + 2
        else if b0 == 0xE0:
            if i + 2 >= bytes.len() or not valid_range(bytes[i + 1], 0xA0, 0xBF) or not continuation_byte(bytes[i + 2]):
                return i
            i = i + 3
        else if b0 >= 0xE1 and b0 <= 0xEC:
            if i + 2 >= bytes.len() or not continuation_byte(bytes[i + 1]) or not continuation_byte(bytes[i + 2]):
                return i
            i = i + 3
        else if b0 == 0xED:
            if i + 2 >= bytes.len() or not valid_range(bytes[i + 1], 0x80, 0x9F) or not continuation_byte(bytes[i + 2]):
                return i
            i = i + 3
        else if b0 >= 0xEE and b0 <= 0xEF:
            if i + 2 >= bytes.len() or not continuation_byte(bytes[i + 1]) or not continuation_byte(bytes[i + 2]):
                return i
            i = i + 3
        else if b0 == 0xF0:
            if i + 3 >= bytes.len() or not valid_range(bytes[i + 1], 0x90, 0xBF) or not continuation_byte(bytes[i + 2]) or not continuation_byte(bytes[i + 3]):
                return i
            i = i + 4
        else if b0 >= 0xF1 and b0 <= 0xF3:
            if i + 3 >= bytes.len() or not continuation_byte(bytes[i + 1]) or not continuation_byte(bytes[i + 2]) or not continuation_byte(bytes[i + 3]):
                return i
            i = i + 4
        else if b0 == 0xF4:
            if i + 3 >= bytes.len() or not valid_range(bytes[i + 1], 0x80, 0x8F) or not continuation_byte(bytes[i + 2]) or not continuation_byte(bytes[i + 3]):
                return i
            i = i + 4
        else:
            return i
    -1

fn scalar_valid(bytes: [i64]) -> bool:
    scalar_find_invalid(bytes) == -1

fn generated_bytes(case_idx: i64) -> [i64]:
    var seed = ((case_idx + 1) * 110351 + 12345) % 2147483647
    val len = (seed % 32) + 1
    var bytes: [i64] = []
    var i = 0
    while i < len:
        seed = ((seed * 110351) + 12345 + i) % 2147483647
        bytes.push(seed % 256)
        i = i + 1
    bytes

fn check_bytes(bytes: [i64]):
    val valid = scalar_valid(bytes)
    expect rt_utf8_validate(bytes) == valid
    if not valid:
        expect rt_utf8_find_invalid(bytes) == scalar_find_invalid(bytes)

fn generated_text(case_idx: i64) -> text:
    var s = ""
    var i = 0
    while i < 64:
        val choice = (case_idx + i) % 6
        if choice == 0:
            s = s + "a"
        else if choice == 1:
            s = s + "Z"
        else if choice == 2:
            s = s + "é"
        else if choice == 3:
            s = s + "世"
        else if choice == 4:
            s = s + "😀"
        else:
            s = s + "\n"
        i = i + 1
    s

describe "SIMD UTF-8 raw byte fuzz":
    it "matches scalar oracles on crafted invalid boundary cases":
        check_bytes([128])
        check_bytes([192, 128])
        check_bytes([224, 128, 128])
        check_bytes([237, 160, 128])
        check_bytes([244, 144, 128, 128])
        check_bytes([240, 159, 152])

    it "matches scalar oracles across deterministic generated byte sequences":
        var case_idx = 0
        while case_idx < 100000:
            check_bytes(generated_bytes(case_idx))
            case_idx = case_idx + 1

describe "SIMD UTF-8 text fuzz":
    it "matches expected text-side results across deterministic valid corpora":
        var case_idx = 0
        while case_idx < 512:
            val s = generated_text(case_idx)
            expect rt_text_count_codepoints_cached(s) == 64
            expect rt_text_validate_utf8(s) == true
            expect rt_text_is_ascii(s) == false
            expect rt_simd_str_search(s, "世") >= 0
            expect rt_simd_str_equal(s, s) == true
            case_idx = case_idx + 1
