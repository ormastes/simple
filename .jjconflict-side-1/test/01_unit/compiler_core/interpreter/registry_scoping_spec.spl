# Registry Scoping / Cross-Module Collision Specification
# marker: pure_interp_registry_2026-07-17
#
# Overview:
# Audits the core interpreter's function/struct registry (eval_tables.spl +
# module_loader_core.spl + interp_resource_tracker.spl) for the same failure
# class documented for the Rust seed's flat function registry (see
# doc/08_tracking/bug/mcp_stdio_smoke_seed_flat_registry_len_i64_2026-07-17.md):
# a never-called module's registration corrupting an unrelated function
# elsewhere.
#
# Verdict of the 2026-07-17 pure-Simple audit: the interpreter's func_table /
# struct_table are bare-name (non-module-qualified) hash maps — two modules
# registering the same name DO collide (last-write-wins, silent, no
# module-qualified isolation). That is real and is pinned below as CURRENT
# POLICY (not aspirational fail-closed — the codebase's documented choice for
# the private-`_`-prefixed subset is warn-only, see _ftr_warn_collision in
# eval_tables.spl; this suite does not change that policy).
#
# What WAS a genuine corruption bug (fixed alongside this spec): selective
# module unload (interp_unload_module) tracked only names, not owning
# decl_ids. If module A registered "helper", then module B (loaded later)
# also registered "helper" (collision — table now holds B's decl_id), later
# unloading A blindly called func_table_remove("helper") and deleted B's LIVE
# registration. Fix: eval_tables.func_table_remove_owned /
# func_remove_return_type_owned / struct_table_remove_owned plus
# interp_resource_tracker.irt_track_func_owned / irt_track_struct_owned now
# guard removal on the recorded owner decl_id.
#
# NOTE: eval_tables.spl / interp_resource_tracker.spl depend on hm_* hashmap
# functions and AST accessor externs not available when imported standalone
# in interpreter-mode runtime (see NOTE in interp_resource_tracker_spec.spl,
# same directory). Following that established precedent, this suite uses
# self-contained mocks that mirror the REAL guarded logic byte-for-byte
# (chained-hash details omitted; the collision/guard semantics are exact).
# This is regression armor for the design, not a build-verified exercise of
# the actual compiled functions — the pure-Simple binary is too stale to
# link-verify directly (redeploy wall) and a full bootstrap is out of scope
# for this lane.

# ============================================================================
# Mock Function Table — bare-name, last-write-wins (mirrors ft_* in
# eval_tables.spl exactly: func_table_register / func_table_lookup /
# func_table_remove / func_table_remove_owned)
# ============================================================================

var rs_ft_names: [text] = []
var rs_ft_vals: [i64] = []

fn rs_ft_reset():
    rs_ft_names = []
    rs_ft_vals = []

fn rs_ft_register(name: text, decl_id: i64):
    var i: i64 = 0
    for n in rs_ft_names:
        if n == name:
            var vals = rs_ft_vals
            vals[i] = decl_id
            rs_ft_vals = vals
            return
        i = i + 1
    rs_ft_names = rs_ft_names + [name]
    rs_ft_vals = rs_ft_vals + [decl_id]

fn rs_ft_lookup(name: text) -> i64:
    var i: i64 = 0
    for n in rs_ft_names:
        if n == name:
            return rs_ft_vals[i]
        i = i + 1
    -1

fn rs_ft_remove(name: text) -> bool:
    var idx: i64 = -1
    var i: i64 = 0
    for n in rs_ft_names:
        if n == name:
            idx = i
        i = i + 1
    if idx < 0:
        return false
    var new_names: [text] = []
    var new_vals: [i64] = []
    i = 0
    for n in rs_ft_names:
        if i != idx:
            new_names = new_names + [n]
            new_vals = new_vals + [rs_ft_vals[i]]
        i = i + 1
    rs_ft_names = new_names
    rs_ft_vals = new_vals
    true

# pure_interp_registry_2026-07-17: owner-guarded remove — mirrors
# func_table_remove_owned in eval_tables.spl.
fn rs_ft_remove_owned(name: text, expected_decl_id: i64) -> bool:
    val current = rs_ft_lookup(name)
    if current != expected_decl_id:
        return false
    rs_ft_remove(name)

# ============================================================================
# Mock Tracker — per-module (name, owner decl_id) pairs, mirrors
# interp_resource_tracker.spl's irt_funcs / irt_func_decls +
# irt_track_func_owned / irt_unload_module.
# ============================================================================

var rs_mod_paths: [text] = []
var rs_mod_fn_names: [[text]] = []
var rs_mod_fn_decls: [[i64]] = []

fn rs_tracker_reset():
    rs_mod_paths = []
    rs_mod_fn_names = []
    rs_mod_fn_decls = []
    rs_ft_reset()

fn rs_begin_module(path: text):
    for p in rs_mod_paths:
        if p == path:
            return
    rs_mod_paths = rs_mod_paths + [path]
    rs_mod_fn_names = rs_mod_fn_names + [[]]
    rs_mod_fn_decls = rs_mod_fn_decls + [[]]

fn rs_find_index(path: text) -> i64:
    var i: i64 = 0
    for p in rs_mod_paths:
        if p == path:
            return i
        i = i + 1
    -1

fn rs_track_func_owned(path: text, name: text, decl_id: i64):
    val idx = rs_find_index(path)
    if idx < 0:
        return
    var names = rs_mod_fn_names[idx]
    names = names + [name]
    rs_mod_fn_names[idx] = names
    var decls = rs_mod_fn_decls[idx]
    decls = decls + [decl_id]
    rs_mod_fn_decls[idx] = decls

fn rs_unload_module_guarded(path: text) -> i64:
    """Mirrors the FIXED irt_unload_module: owner-guarded removal."""
    val idx = rs_find_index(path)
    if idx < 0:
        return 0
    var removed: i64 = 0
    val names = rs_mod_fn_names[idx]
    val decls = rs_mod_fn_decls[idx]
    var i: i64 = 0
    for name in names:
        val owner = decls[i]
        if rs_ft_remove_owned(name, owner):
            removed = removed + 1
        i = i + 1
    rs_mod_paths[idx] = ""
    rs_mod_fn_names[idx] = []
    rs_mod_fn_decls[idx] = []
    removed

fn rs_unload_module_unguarded(path: text) -> i64:
    """Mirrors the PRE-FIX behavior (blind func_table_remove(name)) — used
    only to demonstrate the corruption the guard now prevents."""
    val idx = rs_find_index(path)
    if idx < 0:
        return 0
    var removed: i64 = 0
    val names = rs_mod_fn_names[idx]
    for name in names:
        if rs_ft_remove(name):
            removed = removed + 1
    rs_mod_paths[idx] = ""
    rs_mod_fn_names[idx] = []
    rs_mod_fn_decls[idx] = []
    removed

# ============================================================================
# Group 1 — current bare-name collision policy (pinned, not aspirational)
# ============================================================================

describe "bare-name registry collision (current policy)":

    it "two modules registering the same function name collide onto ONE global entry":
        rs_tracker_reset()
        rs_begin_module("mod_a")
        rs_begin_module("mod_b")
        rs_ft_register("helper", 100)
        rs_track_func_owned("mod_a", "helper", 100)
        rs_ft_register("helper", 200)
        rs_track_func_owned("mod_b", "helper", 200)
        # Documents the ACTUAL policy: last write wins, no per-module
        # isolation. This is the same failure class as the seed's flat
        # registry — pinned here as regression armor, not fixed by adding
        # module-qualified keys (that would be a wholesale redesign, out of
        # scope for this lane).
        expect(rs_ft_lookup("helper")).to_equal(200)

    it "distinct names across modules never collide":
        rs_tracker_reset()
        rs_begin_module("mod_c")
        rs_begin_module("mod_d")
        rs_ft_register("c_only_fn", 10)
        rs_track_func_owned("mod_c", "c_only_fn", 10)
        rs_ft_register("d_only_fn", 20)
        rs_track_func_owned("mod_d", "d_only_fn", 20)
        expect(rs_ft_lookup("c_only_fn")).to_equal(10)
        expect(rs_ft_lookup("d_only_fn")).to_equal(20)

# ============================================================================
# Group 2 — owner-guarded unload (the concrete fix)
# ============================================================================

describe "owner-guarded module unload (pure_interp_registry_2026-07-17 fix)":

    it "unloading the OVERWRITTEN module does not delete the survivor's live entry":
        rs_tracker_reset()
        rs_begin_module("mod_a")
        rs_begin_module("mod_b")
        rs_ft_register("helper", 100)
        rs_track_func_owned("mod_a", "helper", 100)
        rs_ft_register("helper", 200)          # mod_b collides, now owns "helper"
        rs_track_func_owned("mod_b", "helper", 200)
        rs_unload_module_guarded("mod_a")
        # mod_b's live registration must survive mod_a's unload.
        expect(rs_ft_lookup("helper")).to_equal(200)

    it "unloading the CURRENT owner still removes its own entry":
        rs_tracker_reset()
        rs_begin_module("mod_e")
        rs_ft_register("solo_fn", 300)
        rs_track_func_owned("mod_e", "solo_fn", 300)
        val removed = rs_unload_module_guarded("mod_e")
        expect(removed).to_equal(1)
        expect(rs_ft_lookup("solo_fn")).to_equal(-1)

    it "demonstrates the PRE-FIX corruption the guard prevents (regression proof)":
        rs_tracker_reset()
        rs_begin_module("mod_a")
        rs_begin_module("mod_b")
        rs_ft_register("helper", 100)
        rs_track_func_owned("mod_a", "helper", 100)
        rs_ft_register("helper", 200)
        rs_track_func_owned("mod_b", "helper", 200)
        rs_unload_module_unguarded("mod_a")
        # Without the owner guard, unloading mod_a wrongly deletes mod_b's
        # live "helper" registration — a cross-module corruption from an
        # unrelated module's unload.
        assert_equal(rs_ft_lookup("helper"), -1)

# ============================================================================
# Group 3 — partial/failed registration does not corrupt prior entries
# ============================================================================

describe "partial registration does not shift or corrupt prior slots":

    it "a later module's partial registration leaves an earlier module's entries intact":
        rs_tracker_reset()
        rs_begin_module("mod_x")
        rs_ft_register("x_fn_1", 10)
        rs_track_func_owned("mod_x", "x_fn_1", 10)
        rs_ft_register("x_fn_2", 20)
        rs_track_func_owned("mod_x", "x_fn_2", 20)

        # mod_y registers only ONE of two intended functions (simulating a
        # module whose registration pass aborts partway, e.g. an unresolved
        # identifier later in the same file never reaches a second fn decl).
        rs_begin_module("mod_y")
        rs_ft_register("y_fn_registered", 30)
        rs_track_func_owned("mod_y", "y_fn_registered", 30)
        # y_fn_never_reached deliberately NOT registered.

        # mod_x's earlier entries are untouched — no index shifting because
        # the arena is append-based, not compacted.
        expect(rs_ft_lookup("x_fn_1")).to_equal(10)
        expect(rs_ft_lookup("x_fn_2")).to_equal(20)
        expect(rs_ft_lookup("y_fn_registered")).to_equal(30)
        expect(rs_ft_lookup("y_fn_never_reached")).to_equal(-1)

    it "unloading the partially-registered module removes only what it actually registered":
        rs_tracker_reset()
        rs_begin_module("mod_x")
        rs_ft_register("x_fn_1", 10)
        rs_track_func_owned("mod_x", "x_fn_1", 10)

        rs_begin_module("mod_y")
        rs_ft_register("y_fn_registered", 30)
        rs_track_func_owned("mod_y", "y_fn_registered", 30)

        rs_unload_module_guarded("mod_y")
        expect(rs_ft_lookup("y_fn_registered")).to_equal(-1)
        # mod_x untouched by mod_y's unload.
        expect(rs_ft_lookup("x_fn_1")).to_equal(10)
