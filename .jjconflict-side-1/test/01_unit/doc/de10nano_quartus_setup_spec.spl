# @cover doc/07_guide/fpga/de10nano_quartus_setup.md 0%
"""
# DE10-Nano Quartus Setup Guide Specification

**Feature IDs:** opensource-riscv-rtl-simpleos
**Category:** Infrastructure
**Difficulty:** 1/5
**Status:** Draft
**Requirements:** REQ-4
**Artifacts:** N/A

## Overview

Verifies AC-4: the Quartus Prime Lite setup guide for DE10-Nano exists
and contains the required version, device, and workflow information.
Tests that the guide helper module returns the correct constants.

Covers:
- AC-4 (Cyclone V / Quartus setup guide documented for DE10-Nano)
"""

use std.spipe.*
use doc.fpga.de10nano_quartus_setup.{
    quartus_setup_guide_content,
    quartus_lite_version,
    de10nano_device_string,
    litex_de10nano_build_command
}


# ============================================================================
# Helpers
# ============================================================================

fn guide() -> text:
    return quartus_setup_guide_content()


# ============================================================================
# AC-4: Guide content completeness
# ============================================================================

describe "DE10-Nano Quartus Setup Guide":
    it "AC-4: guide content is non-empty":
        val g = guide()
        val len = g.length()
        expect(len).to_be_greater_than(0)

    it "AC-4: guide contains Quartus Prime version reference":
        val g = guide()
        expect(g).to_contain("Quartus")

    it "AC-4: guide contains device string 5CSEBA6U23I7":
        val g = guide()
        expect(g).to_contain("5CSEBA6U23I7")

    it "AC-4: guide contains DE10-Nano board name":
        val g = guide()
        expect(g).to_contain("DE10-Nano")

    it "AC-4: guide contains LiteX de10nano target":
        val g = guide()
        expect(g).to_contain("de10nano")

    it "AC-4: guide contains download or install step":
        val g = guide()
        expect(g).to_contain("install")

    it "AC-4: guide contains VexRiscv or SMP reference":
        val g = guide()
        expect(g).to_contain("VexRiscv")


# ============================================================================
# AC-4: Guide module constants
# ============================================================================

describe "Quartus setup guide constants":
    it "AC-4: quartus_lite_version is non-empty":
        val v = quartus_lite_version()
        val len = v.length()
        expect(len).to_be_greater_than(0)

    it "AC-4: de10nano_device_string is 5CSEBA6U23I7":
        val d = de10nano_device_string()
        expect(d).to_equal("5CSEBA6U23I7")

    it "AC-4: litex_de10nano_build_command contains make.py":
        val cmd = litex_de10nano_build_command()
        expect(cmd).to_contain("make.py")

    it "AC-4: litex_de10nano_build_command contains de10nano":
        val cmd = litex_de10nano_build_command()
        expect(cmd).to_contain("de10nano")
