# @cover src/compiler/70.backend/target_presets.spl 80%
"""
# Cortex-M33 Target Preset Specification

**Feature IDs:** #UNOQ-PORT
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Verifies that `preset_cortex_m33()` returns the correct ARMv8-M Mainline
target configuration and that it integrates with `preset_by_name()` and
`preset_all_names()`.

## Behavior

- arch must be `thumbv8m.main` (ARMv8-M Mainline, not thumbv7em)
- ABI must be `eabihf` (STM32U585 has hardware FPU)
- Float support enabled
- Stack size 16384 (larger SRAM allows bigger stack than M4 default)
- Pointer width 32 (Cortex-M33 is 32-bit)
- Discoverable via `preset_by_name("cortex-m33")`
- Listed in `preset_all_names()`
"""

use compiler.backend.target_presets.{
    preset_cortex_m33,
    preset_by_name,
    preset_all_names
}


# ============================================================================
# Test Group 1: preset_cortex_m33() field values
# ============================================================================

describe "preset_cortex_m33":
    """
    ## Preset Fields

    Validates all fields of the Cortex-M33 target preset match the
    ARMv8-M Mainline / eabihf specification from the architecture.
    """

    it "AC-1: arch is thumbv8m.main":
        val p = preset_cortex_m33()
        expect(p.arch).to_equal("thumbv8m.main")

    it "AC-1: abi is eabihf":
        val p = preset_cortex_m33()
        expect(p.abi).to_equal("eabihf")

    it "AC-1: float_support is true":
        val p = preset_cortex_m33()
        expect(p.float_support).to_equal(true)

    it "AC-1: stack_size is 16384":
        val p = preset_cortex_m33()
        expect(p.stack_size).to_equal(16384)

    it "AC-1: pointer_width is 32":
        val p = preset_cortex_m33()
        expect(p.pointer_width).to_equal(32)


# ============================================================================
# Test Group 2: Discovery integration
# ============================================================================

describe "preset_cortex_m33 discovery":
    """
    ## Name-Based Lookup

    Verifies the new preset is reachable via the dynamic lookup functions
    so that the compiler driver can resolve "cortex-m33" by name.
    """

    it "AC-1: preset_by_name returns cortex-m33 with correct arch":
        val p = preset_by_name("cortex-m33")
        expect(p.arch).to_equal("thumbv8m.main")

    it "AC-1: preset_all_names contains cortex-m33":
        val names = preset_all_names()
        expect(names).to_contain("cortex-m33")
