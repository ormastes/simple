# test/unit/compiler/backend/neon_arith_extras_spec.spl
#
# Byte-level golden tests for Wave O2 NEON arithmetic extras.
# Verifies emit_neon_vsubq_f32, emit_neon_vminq_f32, emit_neon_vmaxq_f32,
# emit_neon_vcgtq_f32, emit_neon_vcgeq_f32 produce exact ARMv8 ARM bytes.
#
# Reference: doc/01_research/simd_isa_deep_2026-05-02.md §2 (ARMv8 encoding)
#            doc/01_research/simd_spec_verification_2026-05-02.md V-25 (FCMGT polarity)
#            ARMv8 ARM §C7.2.183 FSUB, §C7.2.135 FMIN, §C7.2.136 FMAX
#            ARMv8 ARM §C7.2.111 FCMGT, §C7.2.110 FCMGE
#
# All opcodes independently verified via:
#   llvm-mc -triple=aarch64-none-linux-gnu --show-encoding
#
# Register indices: raw 0-31 (V0=0, V1=1, ..., V31=31). NOT mach_inst ID range 64-79.
# All instructions are 4-byte fixed-width, little-endian per ARMv8 ABI.
#
# Byte derivation — 3-register same-type NEON format:
#   bits[4:0]:   Rd
#   bits[9:5]:   Rn  (Rn contributes to byte0 upper + byte1 lower)
#   bits[20:16]: Rm
#   bit[23]:     sz (0=FMAX/FCMGE/FADD/FMUL, 1=FMIN/FSUB/FCMGT)
#   bit[29]:     U  (0=Q=0x4E group, 1=U=0x6E group)
#   bit[30]:     Q=1 (128-bit .4S form always)
#
# V-25 POLARITY (FCMGT / FCMGE):
#   cmp_lt(a, b) → emit_neon_vcgtq_f32(rd, b_reg, a_reg)  [swap Vn/Vm at call site]
#   cmp_le(a, b) → emit_neon_vcgeq_f32(rd, b_reg, a_reg)  [swap Vn/Vm at call site]

use compiler.backend.native.arm_neon.{emit_neon_vsubq_f32, emit_neon_vminq_f32, emit_neon_vmaxq_f32, emit_neon_vcgtq_f32, emit_neon_vcgeq_f32}

# ============================================================================
# FSUB V0.4S, V0.4S, V0.4S
# Base opcode 0x4EA0D400: Q=1 U=0 sz=1 size=00(f32) opcode=11010
# ARMv8 ARM §C7.2.183 FSUB (vector) — llvm-mc VERIFIED
# Expected word: 0x4EA0D400 → LE: 0x00 0xD4 0xA0 0x4E
# ============================================================================

describe "NEON emit_neon_vsubq_f32 f32 golden":
    it "FSUB V0.4S V0.4S V0.4S emits 4 bytes":
        val result = emit_neon_vsubq_f32(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "FSUB V0.4S V0.4S V0.4S byte0 is 0x00":
        # Rd=0, Rn=0 → bits[9:0]=0 → byte0=0x00
        val result = emit_neon_vsubq_f32(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "FSUB V0.4S V0.4S V0.4S byte1 is 0xD4":
        # opcode=11010(26) → bits[15:11]; bit10=1 → byte1 = 26*8+4 = 212 = 0xD4
        val result = emit_neon_vsubq_f32(0, 0, 0)
        expect(result[1]).to_equal(212)

    it "FSUB V0.4S V0.4S V0.4S byte2 is 0xA0":
        # sz=1 → bit23=1; Rm=0 → bits[20:16]=0 → byte2 = 0xA0
        val result = emit_neon_vsubq_f32(0, 0, 0)
        expect(result[2]).to_equal(160)

    it "FSUB V0.4S V0.4S V0.4S byte3 is 0x4E":
        # Q=1 U=0 → 0x4E (bits[31:24])
        val result = emit_neon_vsubq_f32(0, 0, 0)
        expect(result[3]).to_equal(78)

    it "FSUB V1.4S V2.4S V3.4S byte0 encodes Rd and Rn":
        # inst = 0x4EA0D400 + 1 + 2*32 + 3*65536 = 0x4EA0D400 + 196673 = 0x4ED0D441
        # byte0 = 0x41 = 65
        val result = emit_neon_vsubq_f32(1, 2, 3)
        expect(result[0]).to_equal(65)

    it "FSUB V1.4S V2.4S V3.4S byte2 encodes Rm":
        # Rm=3 in bits[20:16]: byte2 = 0xA0 + 3 = 0xA3 = 163
        val result = emit_neon_vsubq_f32(1, 2, 3)
        expect(result[2]).to_equal(163)

    it "FSUB V31.4S V31.4S V31.4S all-ones register boundary":
        # inst = 0x4EA0D400 + 31 + 31*32 + 31*65536 = 0x4EBFD7FF
        # byte0=0xFF=255, byte1=0xD7=215, byte2=0xBF=191, byte3=0x4E=78
        val result = emit_neon_vsubq_f32(31, 31, 31)
        expect(result[0]).to_equal(255)

    it "FSUB V31.4S V31.4S V31.4S byte2 boundary":
        val result = emit_neon_vsubq_f32(31, 31, 31)
        expect(result[2]).to_equal(191)

# ============================================================================
# FMIN V0.4S, V0.4S, V0.4S
# Base opcode 0x4EA0F400: Q=1 U=0 sz=1 size=00(f32) opcode=11110
# ARMv8 ARM §C7.2.135 FMIN (vector, NaN-propagating) — llvm-mc VERIFIED
# Expected word: 0x4EA0F400 → LE: 0x00 0xF4 0xA0 0x4E
# ============================================================================

describe "NEON emit_neon_vminq_f32 f32 golden":
    it "FMIN V0.4S V0.4S V0.4S emits 4 bytes":
        val result = emit_neon_vminq_f32(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "FMIN V0.4S V0.4S V0.4S byte0 is 0x00":
        val result = emit_neon_vminq_f32(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "FMIN V0.4S V0.4S V0.4S byte1 is 0xF4":
        # opcode=11110(30) → byte1 = 30*8+4 = 244 = 0xF4
        val result = emit_neon_vminq_f32(0, 0, 0)
        expect(result[1]).to_equal(244)

    it "FMIN V0.4S V0.4S V0.4S byte2 is 0xA0":
        # sz=1 → bit23=1; Rm=0 → byte2 = 0xA0 = 160
        val result = emit_neon_vminq_f32(0, 0, 0)
        expect(result[2]).to_equal(160)

    it "FMIN V0.4S V0.4S V0.4S byte3 is 0x4E":
        val result = emit_neon_vminq_f32(0, 0, 0)
        expect(result[3]).to_equal(78)

    it "FMIN V0.4S V1.4S V0.4S byte0 encodes Rn":
        # inst = 0x4EA0F400 + 0 + 1*32 + 0 = 0x4EA0F420
        # byte0 = 0x20 = 32
        val result = emit_neon_vminq_f32(0, 1, 0)
        expect(result[0]).to_equal(32)

# ============================================================================
# FMAX V0.4S, V0.4S, V0.4S
# Base opcode 0x4E20F400: Q=1 U=0 sz=0 size=00(f32) opcode=11110
# ARMv8 ARM §C7.2.136 FMAX (vector, NaN-propagating) — llvm-mc VERIFIED
# Expected word: 0x4E20F400 → LE: 0x00 0xF4 0x20 0x4E
# ============================================================================

describe "NEON emit_neon_vmaxq_f32 f32 golden":
    it "FMAX V0.4S V0.4S V0.4S emits 4 bytes":
        val result = emit_neon_vmaxq_f32(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "FMAX V0.4S V0.4S V0.4S byte0 is 0x00":
        val result = emit_neon_vmaxq_f32(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "FMAX V0.4S V0.4S V0.4S byte1 is 0xF4":
        # opcode=11110(30) → byte1 = 30*8+4 = 244 = 0xF4
        val result = emit_neon_vmaxq_f32(0, 0, 0)
        expect(result[1]).to_equal(244)

    it "FMAX V0.4S V0.4S V0.4S byte2 is 0x20":
        # sz=0 → bit23=0; Rm=0 → byte2 = 0x20 = 32
        val result = emit_neon_vmaxq_f32(0, 0, 0)
        expect(result[2]).to_equal(32)

    it "FMAX V0.4S V0.4S V0.4S byte3 is 0x4E":
        val result = emit_neon_vmaxq_f32(0, 0, 0)
        expect(result[3]).to_equal(78)

    it "FMAX V0.4S V0.4S V1.4S byte2 encodes Rm":
        # inst = 0x4E20F400 + 0 + 0 + 1*65536 = 0x4E21F400
        # byte2 = 0x21 = 33
        val result = emit_neon_vmaxq_f32(0, 0, 1)
        expect(result[2]).to_equal(33)

# ============================================================================
# FCMGT V0.4S, V0.4S, V0.4S
# Base opcode 0x6EA0E400: Q=1 U=1 sz=1 size=00(f32) opcode=11100
# ARMv8 ARM §C7.2.111 FCMGT (vector, register form) — llvm-mc VERIFIED
# Expected word: 0x6EA0E400 → LE: 0x00 0xE4 0xA0 0x6E
#
# V-25 POLARITY: cmp_lt(a,b) → emit_neon_vcgtq_f32(rd, b_reg, a_reg)
# ============================================================================

describe "NEON emit_neon_vcgtq_f32 f32 golden":
    it "FCMGT V0.4S V0.4S V0.4S emits 4 bytes":
        val result = emit_neon_vcgtq_f32(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "FCMGT V0.4S V0.4S V0.4S byte0 is 0x00":
        val result = emit_neon_vcgtq_f32(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "FCMGT V0.4S V0.4S V0.4S byte1 is 0xE4":
        # opcode=11100(28) → byte1 = 28*8+4 = 228 = 0xE4
        val result = emit_neon_vcgtq_f32(0, 0, 0)
        expect(result[1]).to_equal(228)

    it "FCMGT V0.4S V0.4S V0.4S byte2 is 0xA0":
        # U=1 sz=1 → bit29=1 bit23=1; Rm=0 → byte2=0xA0=160
        val result = emit_neon_vcgtq_f32(0, 0, 0)
        expect(result[2]).to_equal(160)

    it "FCMGT V0.4S V0.4S V0.4S byte3 is 0x6E":
        # Q=1 U=1 → 0x6E (bits[31:24])
        val result = emit_neon_vcgtq_f32(0, 0, 0)
        expect(result[3]).to_equal(110)

    it "FCMGT V0.4S V1.4S V2.4S byte0 encodes Rn (V-25: Vn>Vm form)":
        # inst = 0x6EA0E400 + 0 + 1*32 + 2*65536 = 0x6EC0E420
        # byte0 = 0x20 = 32
        val result = emit_neon_vcgtq_f32(0, 1, 2)
        expect(result[0]).to_equal(32)

    it "FCMGT V0.4S V1.4S V2.4S byte2 encodes Rm":
        # Rm=2 in bits[20:16]: byte2 = 0xA0 + 2 = 0xA2 = 162; but Rn=1 carries into byte2 bits[25:24]...
        # Actually byte2 = bits[23:16]: sz(bit23)=1 → 0x80, size[1]=0, size[0]=0, bit21=1 → 0x20 total base = 0xA0
        # + Rm=2 in bits[20:16]: byte2 = 0xA0 + 2 = 0xA2 = 162
        # Rn bits are in bits[9:5] which falls in byte0/byte1, not byte2.
        val result = emit_neon_vcgtq_f32(0, 1, 2)
        expect(result[2]).to_equal(162)

    it "FCMGT V31.4S V31.4S V31.4S boundary byte0":
        # inst = 0x6EA0E400 + 31 + 31*32 + 31*65536 = 0x6EBFE7FF
        # byte0=0xFF=255
        val result = emit_neon_vcgtq_f32(31, 31, 31)
        expect(result[0]).to_equal(255)

    it "FCMGT V31.4S V31.4S V31.4S boundary byte3 is 0x6E":
        val result = emit_neon_vcgtq_f32(31, 31, 31)
        expect(result[3]).to_equal(110)

# ============================================================================
# FCMGE V0.4S, V0.4S, V0.4S
# Base opcode 0x6E20E400: Q=1 U=1 sz=0 size=00(f32) opcode=11100
# ARMv8 ARM §C7.2.110 FCMGE (vector, register form) — llvm-mc VERIFIED
# Expected word: 0x6E20E400 → LE: 0x00 0xE4 0x20 0x6E
#
# V-25 NOTE: cmp_le(a,b) → emit_neon_vcgeq_f32(rd, b_reg, a_reg)
# ============================================================================

describe "NEON emit_neon_vcgeq_f32 f32 golden":
    it "FCMGE V0.4S V0.4S V0.4S emits 4 bytes":
        val result = emit_neon_vcgeq_f32(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "FCMGE V0.4S V0.4S V0.4S byte0 is 0x00":
        val result = emit_neon_vcgeq_f32(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "FCMGE V0.4S V0.4S V0.4S byte1 is 0xE4":
        # opcode=11100(28) → byte1 = 28*8+4 = 228 = 0xE4
        val result = emit_neon_vcgeq_f32(0, 0, 0)
        expect(result[1]).to_equal(228)

    it "FCMGE V0.4S V0.4S V0.4S byte2 is 0x20":
        # U=1 sz=0 → bit29=1 bit23=0; Rm=0 → byte2=0x20=32
        val result = emit_neon_vcgeq_f32(0, 0, 0)
        expect(result[2]).to_equal(32)

    it "FCMGE V0.4S V0.4S V0.4S byte3 is 0x6E":
        val result = emit_neon_vcgeq_f32(0, 0, 0)
        expect(result[3]).to_equal(110)

    it "FCMGE V31.4S V0.4S V0.4S byte0 encodes Rd boundary":
        # inst = 0x6E20E400 + 31 = 0x6E20E41F → byte0=0x1F=31
        val result = emit_neon_vcgeq_f32(31, 0, 0)
        expect(result[0]).to_equal(31)

    it "FCMGE V0.4S V2.4S V1.4S byte0 encodes Rn swapped operands":
        # V-25 example: cmp_le(V1, V2) → FCMGE(rd, V2, V1)
        # inst = 0x6E20E400 + 0 + 2*32 + 1*65536 = 0x6E30E440
        # byte0 = 0x40 = 64
        val result = emit_neon_vcgeq_f32(0, 2, 1)
        expect(result[0]).to_equal(64)

    it "FCMGE V0.4S V2.4S V1.4S byte2 encodes Rm":
        # Rm=1 in bits[20:16]: byte2 = 0x20 + 1 = 0x21 = 33
        val result = emit_neon_vcgeq_f32(0, 2, 1)
        expect(result[2]).to_equal(33)
