# Host/GPU lane structural bridge regression.
#
# @cover src/compiler/10.frontend/core/parser_stmts.spl 5%
# @cover src/compiler/10.frontend/flat_ast_bridge.spl 5%
#
# The lane marker must survive parsing as rich AST metadata, not only as a
# source-text check diagnostic.

use std.spec
use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.frontend.parser_types.*

fn target_later_lane_score(src: text, fname: text) -> i64:
    val m = parse_and_build_module(src, fname + ".spl")
    val fn_ = m.functions[fname] ?? panic("missing fn " + fname)
    for s in fn_.body.stmts:
        match s.kind:
            case StmtKind.TargetLater(config, block):
                var score = 1
                match config.lane:
                    case TargetLane.Gpu:
                        score = score + 10
                    case TargetLane.Host:
                        score = score + 20
                if config.max_packet != nil:
                    score = score + 100
                score = score + block.stmts.len()
                return score
            case _:
                pass
    0

describe "Host/GPU lane structural bridge", tag: ["only-compiled"]:
    it "preserves target.later gpu lane metadata in rich AST":
        val src = "fn f():\n    target.later(max_packet: 512) gpu \\:\n        val draw_ir_batch = \"batch\"\n"
        expect(target_later_lane_score(src, "f")).to_equal(112)

