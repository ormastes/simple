use std.spec.*
use compiler.driver.driver_source_loading.{_driver_collect_sources, _driver_module_aliases, _driver_resolve_entry_import}

describe "driver source module aliases":
    it "keeps physical lib identity without colliding with std mirrors":
        val aliases = _driver_module_aliases(
            "src/lib/gc_async_mut/gpu/engine2d/simd_native_rows.spl",
            "fn marker(): pass",
            "lib.gc_async_mut.gpu.engine2d.simd_native_rows"
        )

        expect(aliases.len()).to_equal(1)
        expect(aliases[0].module_name).to_equal("lib.gc_async_mut.gpu.engine2d.simd_native_rows")

    it "resolves bare memory-family imports through the canonical lib root":
        expect(_driver_resolve_entry_import("nogc_sync_mut.path", "src/std/nogc_sync_mut")).to_equal(
            "src/lib/nogc_sync_mut/path.spl"
        )
        expect(_driver_resolve_entry_import("nogc_sync_mut.target_ext", "src/std/nogc_sync_mut")).to_equal(
            "src/lib/nogc_sync_mut/target_ext.spl"
        )
        expect(_driver_resolve_entry_import("std.nogc_sync_mut.path", "src/std/nogc_sync_mut")).to_equal(
            "src/std/nogc_sync_mut/path.spl"
        )

    it "keeps the canonical test runner despite test helper filtering":
        val sources = _driver_collect_sources("src/app/cli/test_entry.spl")
        expect(sources.len()).to_equal(1)
        expect(sources[0].path).to_equal("src/app/cli/test_entry.spl")
        expect(sources[0].module_name).to_equal("app.cli.test_entry")

        val cli_sources = _driver_collect_sources("src/app/cli")
        var found = 0
        for source in cli_sources:
            if source.path.ends_with("/src/app/cli/test_entry.spl") or source.path == "src/app/cli/test_entry.spl":
                found = found + 1
        expect(found).to_equal(1)
