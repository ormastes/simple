use std.spec
use compiler.mono.monomorphize.deferred_deserialize.{deferred_utf8_bytes_to_text}

describe "deferred monomorphization text fields":
    it "decodes valid UTF-8 bytes":
        val result = deferred_utf8_bytes_to_text([79u8, 75u8])
        match result:
            Some(value):
                expect(value).to_equal("OK")
            nil:
                expect(false).to_equal(true)

    it "rejects invalid UTF-8 before conversion":
        val result = deferred_utf8_bytes_to_text([255u8])
        match result:
            Some(_): expect(false).to_equal(true)
            nil: expect(true).to_equal(true)

    it "rejects overlong UTF-8 before conversion":
        val result = deferred_utf8_bytes_to_text([0xE0u8, 0x80u8, 0x80u8])
        match result:
            Some(_): expect(false).to_equal(true)
            nil: expect(true).to_equal(true)
