# Module-Level Non-Literal Initializer Lint Specification
#
# Verifies MODINIT001 catches module-level (top-level, non-fn-local) val/var
# declarations whose initializer is not a literal — the bug class where
# native-build --entry silently skips the initializer and the global reads a
# zero/nil default — and does not false-positive on literal initializers,
# fn-local declarations, or declarations with no initializer.

use std.spec.*
use compiler.semantics.lint.module_init_literal.{
    ModuleInitLiteralWarning,
    check_module_init_literal
}


# ============================================================================
# Test Group 1: MODINIT001 — Non-literal module-level initializer
# ============================================================================

describe "MODINIT001: Non-literal module-level initializer":
    """
    ## Module Init Literal Detection

    Catches column-0 `val`/`var` declarations whose right-hand side is not a
    bare int/float/bool/string/nil literal (a negated numeric literal counts
    as literal).
    """

    context "when initializer is not a literal":
        """
        ### Scenario: function call, collection literal, or identifier RHS

        These initializers require runtime work that native-build --entry
        does not perform for module globals today.
        """

        it "detects a function-call initializer":
            val source = "val argc: i64 = spl_arg_count()\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(1)
            expect(warnings[0].code).to_equal("MODINIT001")
            expect(warnings[0].line_num).to_equal(1)

        it "detects an array-literal initializer":
            val source = "var slots: [i64] = [0]\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(1)
            expect(warnings[0].code).to_equal("MODINIT001")

        it "detects an empty-dict initializer":
            val source = "var cache = {}\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(1)

        it "detects an identifier-reference initializer":
            val source = "val other = SOME_OTHER_CONST\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(1)

        it "detects a pub var with a struct-construction initializer":
            val source = "pub var registry = Registry(entries: [])\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(1)

        it "detects string concatenation (not a bare literal)":
            val source = "val greeting: text = \"hello, \" + name + \"!\"\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(1)

        it "detects string interpolation (needs runtime formatting)":
            val source = "val label: text = \"count=\{n\}\"\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(1)

        it "message explains the native-path bug and suggests lazy init":
            val source = "val argc: i64 = spl_arg_count()\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings[0].message).to_contain("native-build")
            expect(warnings[0].hint).to_contain("lazy-init")

    context "when initializer is a literal":
        """
        ### Scenario: no false positives on literal initializers

        int/float/bool/string/nil literals (including negated numerics) are
        const-folded today, so they are not affected by the bug.
        """

        it "accepts an int literal":
            val source = "val HIR_TYPE_VOID = 0\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts a negated int literal":
            val source = "val CACHE_ERROR: i64 = -1\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts a float literal":
            val source = "val DEFAULT_RATIO: f64 = 0.7\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts a negated float literal":
            val source = "val NEG_RATIO: f64 = -0.5\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts a bool literal":
            val source = "var g_log_enabled = false\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts a string literal":
            val source = "val NAME: text = \"hello\"\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts an empty string literal":
            val source = "val EMPTY: text = \"\"\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts a string literal with an escaped inner quote":
            val source = "val QUOTED: text = \"a\\\"b\"\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts a string literal that merely contains a '+' character":
            val source = "val OP: text = \"a + b\"\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts a nil literal":
            val source = "var _global_container: DiContainer? = nil\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

    context "when the declaration is not module-level":
        """
        ### Scenario: fn-local declarations are not this lint's concern

        Only column-0 (module-level) declarations are in scope; indented
        declarations inside a fn body run every time the fn runs.
        """

        it "ignores an indented val inside a fn body":
            val source = "fn main():\n    val x = compute()\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "ignores an indented var inside a fn body":
            val source = "fn setup():\n    var y = build_thing()\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)

    context "when there is no initializer":
        """
        ### Scenario: bare declaration without assignment

        No RHS expression means there is nothing for this lint to evaluate.
        """

        it "ignores a var declaration with no initializer":
            val source = "var x: i64\n"
            val warnings = check_module_init_literal(source, "test.spl")
            expect(warnings.len()).to_equal(0)


# ============================================================================
# Test Group 2: Warning Formatting
# ============================================================================

describe "ModuleInitLiteralWarning formatting":
    """
    ## Warning Output Format

    The fmt() method should produce a readable diagnostic string.
    """

    it "produces formatted output":
        val w = ModuleInitLiteralWarning(
            code: "MODINIT001",
            severity: "WARNING",
            message: "test message",
            hint: "test hint",
            line_num: 7,
            file_path: "foo.spl"
        )
        val output = w.fmt()
        expect(output).to_contain("MODINIT001")
        expect(output).to_contain("WARNING")
        expect(output).to_contain("foo.spl")
        expect(output).to_contain("7")
