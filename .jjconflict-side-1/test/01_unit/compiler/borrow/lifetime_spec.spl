# # Lifetime Analysis Unit Tests
#
# **Feature ID:** #COMPILER-BORROW-002
# **Category:** Compiler | Borrow | Lifetime
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Variable Lifetimes":
    it "lifetime starts at declaration":
        val x = 42
        check(x == 42)

    it "lifetime ends at scope exit":
        var result = 0
        if true:
            val temp = 42
            result = temp
        check(result == 42)

    it "nested lifetimes":
        val outer = 1
        if true:
            val middle = 2
            if true:
                val inner = 3
                check(outer + middle + inner == 6)

    it "loop variable lifetime per iteration":
        var sum = 0
        for i in 0..3:
            val temp = i * 10
            sum = sum + temp
        check(sum == 30)

    it "match arm lifetimes":
        val x = Some(42)
        var result = 0
        match x:
            Some(v):
                val doubled = v * 2
                result = doubled
            nil:
                result = 0
        check(result == 84)

describe "Reference Lifetimes":
    it "reference lives within function":
        fn get_value() -> i64:
            val x = 42
            x
        check(get_value() == 42)

    it "return value outlives function":
        fn create() -> i64:
            42
        val result = create()
        check(result == 42)

    it "closure captures extend lifetime":
        val x = 42
        val f = \: x
        check(f() == 42)

    it "array element lifetime":
        val arr = [10, 20, 30]
        val first = arr[0]
        check(first == 10)

describe "Drop Ordering":
    it "LIFO drop order":
        val first = 1
        val second = 2
        val third = 3
        check(first + second + third == 6)

    it "struct fields drop with struct":
        class Pair:
            a: i64
            b: i64
        val p = Pair(a: 1, b: 2)
        check(p.a + p.b == 3)

    it "array elements drop with array":
        val arr = [1, 2, 3]
        check(arr.len() == 3)

describe "Temporary Lifetimes":
    it "temporary in expression":
        val result = [1, 2, 3].len()
        check(result == 3)

    it "temporary in function call":
        fn sum_len(arr: [i64]) -> i64:
            arr.len()
        check(sum_len([1, 2, 3]) == 3)

    it "chained temporaries":
        val result = "hello world".len()
        check(result == 11)
