use std.spec.*
use compiler.common.diagnostics.span.{Span}
use compiler.common.dependency.visibility.{Visibility}
use compiler.hir.hir_types.{SymbolKind, SymbolTable}

describe "HIR symbol display names":
    it "reads back a renamed qualified symbol name":
        var symbols = SymbolTable.new()
        val id = symbols.define(
            "answer",
            SymbolKind.Function,
            nil,
            Span.empty(),
            Visibility.Public,
            false,
            nil
        )

        expect(symbols.symbol_display_name(id, "fallback")).to_equal("answer")
        symbols.rename_symbol(id, "provider.answer")
        expect(symbols.symbol_display_name(id, "fallback")).to_equal("provider.answer")
