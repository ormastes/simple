# Function-local array push loop + len regression spec (B1)
#
# Bug: doc/08_tracking/bug/array_push_loop_in_main_len_coredump_2026-06-11.md
# A push loop on a function-local array followed by len() dumped core in BOTH
# native and interpreter modes (module-level variant worked). Fixed by the
# x=x.push() store-miscompile family (0bf222e322 + stage4 chain fixes
# 2eae3b46c8); this spec pins the function-local pattern so it cannot regress
# silently again.

use std.spec.*

fn push_loop_len(n: i64) -> i64:
    var arr: [i64] = []
    for i in 0..n:
        arr = arr.push(i)
    arr.len()

fn push_loop_last(n: i64) -> i64:
    var arr: [i64] = []
    for i in 0..n:
        arr = arr.push(i)
    arr[arr.len() - 1]

describe "function-local array push loop + len (B1)":

    it "len after 100 pushes in a local loop is 100":
        val got = push_loop_len(100)
        expect(got).to_equal(100)

    it "len after 3 pushes is 3":
        val got = push_loop_len(3)
        expect(got).to_equal(3)

    it "last element after the loop is n-1 (contents intact)":
        val got = push_loop_last(100)
        expect(got).to_equal(99)
