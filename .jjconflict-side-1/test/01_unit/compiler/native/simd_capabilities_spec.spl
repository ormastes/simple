use std.spec
use compiler.types.simd_capabilities.{SimdFeatureSet, detect_capabilities, detect_x86_capabilities, _simd_features_none}

describe "SimdFeatureSet baseline":
    it "none() returns all-false struct":
        val f = _simd_features_none()
        expect(f.has_sse).to_be_false()
        expect(f.has_avx).to_be_false()
        expect(f.has_avx2).to_be_false()
        expect(f.has_avx512f).to_be_false()
        expect(f.has_neon).to_be_false()
        expect(f.has_sve).to_be_false()
        expect(f.has_v).to_be_false()

    it "none() returns zero vector lengths":
        val f = _simd_features_none()
        expect(f.sve_vector_length).to_equal(0)
        expect(f.vlen).to_equal(0)

describe "detect_capabilities host invariants":
    it "does not crash on the host":
        val f = detect_capabilities()
        expect(true).to_be_true()

    it "returns a SimdFeatureSet":
        val f = detect_capabilities()
        expect(f.vlen).to_be_greater_than(-1)

    it "avx2 implies avx":
        val f = detect_capabilities()
        if f.has_avx2:
            expect(f.has_avx).to_be_true()

    it "avx implies sse2":
        val f = detect_capabilities()
        if f.has_avx:
            expect(f.has_sse2).to_be_true()

    it "avx512f implies avx2":
        val f = detect_capabilities()
        if f.has_avx512f:
            expect(f.has_avx2).to_be_true()

    it "sve2 implies sve":
        val f = detect_capabilities()
        if f.has_sve2:
            expect(f.has_sve).to_be_true()

    it "apple_m never has sve":
        val f = detect_capabilities()
        if f.is_apple_m:
            expect(f.has_sve).to_be_false()
            expect(f.has_sve2).to_be_false()

describe "detect_x86_capabilities CPUID invariants":
    it "does not crash":
        val f = detect_x86_capabilities()
        expect(true).to_be_true()

    it "sse2 implies sse":
        val f = detect_x86_capabilities()
        if f.has_sse2:
            expect(f.has_sse).to_be_true()

    it "avx2 implies avx on x86":
        val f = detect_x86_capabilities()
        if f.has_avx2:
            expect(f.has_avx).to_be_true()

    it "avx512f implies avx2 on x86":
        val f = detect_x86_capabilities()
        if f.has_avx512f:
            expect(f.has_avx2).to_be_true()

    it "has no ARM fields set":
        val f = detect_x86_capabilities()
        expect(f.has_neon).to_be_false()
        expect(f.has_sve).to_be_false()
        expect(f.has_v).to_be_false()
