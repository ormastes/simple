"""
# Cross-module trait default-method dispatch, 3-method positional variant
# (task #55, interpreter half). Mirrors default_trait_dispatch_spec.spl's
# ThreeMethods/DispatchTarget exactly (m1, m2 inherited, m3 overridden) but
# splits the trait and impl across a module boundary, to specifically probe
# the positional-dispatch aliasing failure mode called out in the HIR fix
# (391e55a): "t.m1() ran m3's body" / SIGSEGV on t.m2().
"""

use std.spec.{describe, it, expect}
use test.fixtures.cross_module_trait_default.xmod_trait_impl3.{XMod3Target}

describe "cross-module trait default dispatch (3-method positional)":
    it "inherited default m1 runs its own body across modules":
        val t = XMod3Target(n: 1)
        expect(t.m1()).to_equal("default-m1")

    it "inherited default m2 runs its own body across modules":
        val t = XMod3Target(n: 2)
        expect(t.m2()).to_equal("default-m2")

    it "overridden m3 runs the impl body, not a default":
        val t = XMod3Target(n: 3)
        expect(t.m3()).to_equal("override-m3")
