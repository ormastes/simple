# Pattern-Idiom Pass Benchmark — Large MIR Coverage
#
# Synthesises large MIR modules (100+ functions, varied instruction shapes)
# and runs the pattern_idiom dispatch path to measure:
#   - Instruction count traversal correctness (MirInstCounter)
#   - Pass completes without error on large inputs
#   - Module-scope pass routing (not per-function) is consistent
#
# Note: This spec runs in interpreter mode.  Numeric timing is not available
# via the interpreter (no clock() extern), so benchmarks verify structural
# properties and relative scale.  Actual nanosecond timing requires
# --mode=native; see compile-mode false-greens memory note before enabling.

use compiler.mir.mir_instructions.{
    MirModule, MirFunction,
    MirBlock, MirInst, MirInstKind,
    MirTerminator, MirOperand, MirOperandKind,
    BlockId, MirBinOp
}
use compiler.mir.mir_types.{
    MirType, MirTypeKind, MirSignature,
    MirConstValue, LocalId, LocalKind, MirLocal
}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir_opt.mir_opt.mod.{
    run_pass_on_module, run_typed_pass_on_module,
    PassKind, PassScope,
    mir_pass_descriptor_for_name
}
use compiler.mir_opt.mir_opt.mir_visitor.{
    mir_inst_counter_new, mir_inst_counter_count_module,
    mir_inst_counter_count_function
}

# ============================================================================
# Synthetic MIR Builder Helpers
# ============================================================================

fn bench_make_local(id: i64, type_: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), type_: type_, kind: LocalKind.Temp, name: nil)

fn bench_make_i64_type() -> MirType:
    MirType(kind: MirTypeKind.I64)

fn bench_make_const_int_inst(dest_id: i64, value: i64) -> MirInst:
    MirInst(
        kind: MirInstKind.Const(
            LocalId(id: dest_id),
            MirConstValue.Int(value),
            bench_make_i64_type()
        ),
        span: nil
    )

fn bench_make_binop_add_inst(dest_id: i64, left_id: i64, right_id: i64) -> MirInst:
    MirInst(
        kind: MirInstKind.BinOp(
            LocalId(id: dest_id),
            MirBinOp.Add,
            MirOperand(kind: MirOperandKind.Copy(LocalId(id: left_id))),
            MirOperand(kind: MirOperandKind.Copy(LocalId(id: right_id)))
        ),
        span: nil
    )

fn bench_make_copy_inst(dest_id: i64, src_id: i64) -> MirInst:
    MirInst(
        kind: MirInstKind.Copy(LocalId(id: dest_id), LocalId(id: src_id)),
        span: nil
    )

fn bench_make_return_term(local_id: i64) -> MirTerminator:
    MirTerminator.Ret(
        Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: local_id))))
    )

fn bench_make_goto_term(target_id: i64) -> MirTerminator:
    MirTerminator.Goto(BlockId(id: target_id))

fn bench_make_simple_block(block_id: i64, n_insts: i64, ret_local: i64) -> MirBlock:
    # Build a block with n_insts const+binop pairs, ending with a return.
    var insts: [MirInst] = []
    var i = 0
    while i < n_insts:
        val const_id = block_id * 100 + i * 2
        val add_id   = block_id * 100 + i * 2 + 1
        insts = insts.push(bench_make_const_int_inst(const_id, i))
        if i > 0:
            insts = insts.push(bench_make_binop_add_inst(add_id, const_id - 2, const_id))
        i = i + 1
    MirBlock(
        id: BlockId(id: block_id),
        label: Some("bb{block_id}"),
        instructions: insts,
        terminator: bench_make_return_term(ret_local)
    )

fn bench_make_function(sym_id: i64, n_blocks: i64, insts_per_block: i64) -> MirFunction:
    # Build a function with n_blocks basic blocks each containing insts_per_block instructions.
    val ret_type = bench_make_i64_type()
    val sig = MirSignature(params: [], return_type: ret_type, is_variadic: false)
    var blocks: [MirBlock] = []
    var b = 0
    while b < n_blocks:
        val block = bench_make_simple_block(b, insts_per_block, 0)
        blocks = blocks.push(block)
        b = b + 1
    var locals: [MirLocal] = []
    locals = locals.push(bench_make_local(0, ret_type))
    MirFunction(
        symbol: SymbolId.new(sym_id),
        name: "bench_fn_{sym_id}",
        signature: sig,
        locals: locals,
        blocks: blocks,
        entry_block: BlockId.new(0),
        span: nil,
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )

fn bench_make_module(n_functions: i64, blocks_per_fn: i64, insts_per_block: i64) -> MirModule:
    # Build a synthetic MirModule with n_functions functions.
    var functions: Dict<SymbolId, MirFunction> = {}
    var i = 0
    while i < n_functions:
        val sym = SymbolId.new(i)
        val func = bench_make_function(i, blocks_per_fn, insts_per_block)
        functions[sym] = func
        i = i + 1
    MirModule(
        name: "bench_module_{n_functions}fn",
        functions: functions,
        statics: {},
        constants: {},
        types: {}
    )

fn count_total_instructions(module: MirModule) -> i64:
    val counter = mir_inst_counter_count_module(module)
    counter.inst_count

# ============================================================================
# Benchmark: pattern_idiom pass on large MIR
# ============================================================================

describe "pattern_idiom benchmark — large MIR":

    it "pass descriptor resolves correctly for pattern_idiom":
        val desc_opt = mir_pass_descriptor_for_name("pattern_idiom")
        expect(desc_opt.?).to_equal(true)
        val desc = desc_opt.unwrap()
        expect(desc.stable_name).to_equal("pattern_idiom")
        # PassKind is typed — confirm scope is Module
        match desc.scope:
            case Module: expect(desc.stable_name).to_equal("pattern_idiom")
            case Function: fail("pattern_idiom should be module-scoped")

    it "run_pass_on_module with pattern_idiom completes on 10-function module":
        val module = bench_make_module(10, 2, 5)
        val before_count = count_total_instructions(module)
        # pattern_idiom in bare run_pass_on_module is a structural no-op
        # (target ctx required for actual rewrites); pass must return module unchanged
        val result = run_pass_on_module("pattern_idiom", module)
        val after_count = count_total_instructions(result)
        # No instructions should be removed or added without a target context
        expect(after_count).to_equal(before_count)

    it "run_typed_pass_on_module with PatternIdiom is consistent with string dispatch":
        val module = bench_make_module(10, 2, 5)
        val result_named = run_pass_on_module("pattern_idiom", module)
        val result_typed = run_typed_pass_on_module(PassKind.PatternIdiom, module)
        val count_named = count_total_instructions(result_named)
        val count_typed = count_total_instructions(result_typed)
        expect(count_typed).to_equal(count_named)

    it "pattern_idiom pass scales linearly — 50 functions":
        val module = bench_make_module(50, 3, 8)
        val expected_insts = count_total_instructions(module)
        # 50 fns * 3 blocks/fn * 8 insts/block = 1200 instructions
        expect(expected_insts).to_be_greater_than(0)
        val result = run_pass_on_module("pattern_idiom", module)
        val after = count_total_instructions(result)
        expect(after).to_equal(expected_insts)

    it "pattern_idiom pass scales linearly — 100 functions":
        val module = bench_make_module(100, 4, 10)
        val expected_insts = count_total_instructions(module)
        expect(expected_insts).to_be_greater_than(0)
        val result = run_pass_on_module("pattern_idiom", module)
        val after = count_total_instructions(result)
        expect(after).to_equal(expected_insts)

    it "PassKind.PatternIdiom scope is Module":
        val desc = mir_pass_descriptor_for_name("pattern_idiom").unwrap()
        match desc.scope:
            case Module: expect(desc.stable_name).to_equal("pattern_idiom")
            case Function: fail("pattern_idiom should be module-scoped")

    it "PassKind.AutoVectorize scope is Module":
        val desc = mir_pass_descriptor_for_name("auto_vectorize").unwrap()
        match desc.scope:
            case Module: expect(desc.stable_name).to_equal("auto_vectorize")
            case Function: fail("auto_vectorize should be module-scoped")

    it "function-scope passes have Function scope":
        val dce_desc = mir_pass_descriptor_for_name("dead_code_elimination").unwrap()
        val cf_desc = mir_pass_descriptor_for_name("constant_folding").unwrap()
        val cp_desc = mir_pass_descriptor_for_name("copy_propagation").unwrap()
        match dce_desc.scope:
            case Function: expect(dce_desc.stable_name).to_equal("dead_code_elimination")
            case Module: fail("dead_code_elimination should be function-scoped")
        match cf_desc.scope:
            case Function: expect(cf_desc.stable_name).to_equal("constant_folding")
            case Module: fail("constant_folding should be function-scoped")
        match cp_desc.scope:
            case Function: expect(cp_desc.stable_name).to_equal("copy_propagation")
            case Module: fail("copy_propagation should be function-scoped")

# ============================================================================
# Benchmark: MirInstCounter visitor on large MIR
# ============================================================================

describe "MirInstCounter visitor — large MIR":

    it "counts instructions correctly for a single function":
        # 1 block, 4 insts (2 Const + 2 BinOp pairs)
        val func = bench_make_function(0, 1, 4)
        val counter = mir_inst_counter_count_function(mir_inst_counter_new(), func)
        expect(counter.function_count).to_equal(1)
        expect(counter.block_count).to_equal(1)
        expect(counter.inst_count).to_be_greater_than(0)

    it "counts blocks correctly for multi-block function":
        val func = bench_make_function(0, 5, 3)
        val counter = mir_inst_counter_count_function(mir_inst_counter_new(), func)
        expect(counter.block_count).to_equal(5)

    it "counts functions correctly across module":
        val module = bench_make_module(20, 2, 3)
        val counter = mir_inst_counter_count_module(module)
        expect(counter.function_count).to_equal(20)
        expect(counter.block_count).to_equal(40)

# ============================================================================
# Exports
# ============================================================================

export describe, bench_make_module, count_total_instructions
