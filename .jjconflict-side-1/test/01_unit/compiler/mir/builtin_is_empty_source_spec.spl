extern fn rt_file_read_text(path: text) -> text

describe "built-in collection is_empty MIR lowering source":
    it "compares a typed collection runtime length with zero":
        val source = rt_file_read_text("src/compiler/50.mir/_MirLoweringExpr/method_calls_literals.spl") ?? ""

        expect(source).to_contain("method == \"len\" or method == \"length\" or method == \"is_empty\"")
        expect(source).to_contain("if len_symbol == \"\" and self.local_is_runtime_array(receiver_local):")
        expect(source).to_contain("if len_symbol == \"\" and self.local_is_str(receiver_local):")
        expect(source).to_contain("if len_symbol == \"\" and method != \"is_empty\":")
        expect(source).to_contain("elif has_prelowered_method_receiver:")
        expect(source).to_contain("val empty_local = b_len.emit_binop(")
        expect(source).to_contain("MirBinOp.Eq,")
