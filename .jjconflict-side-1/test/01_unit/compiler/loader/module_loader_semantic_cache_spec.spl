use std.spec
use compiler.loader.{ModuleLoader}

describe "Module loader semantic cache invalidation":
    it "fails closed when dependency semantic fingerprints change":
        var loader = ModuleLoader.with_defaults()
        loader.record_semantic_fingerprint("A.smf", "A:abi:v1")
        loader.record_dependency_semantic_fingerprint("A.smf", "B.smf", "B:field-wrapper:v1")

        var deps_v1: Dict<text, text> = {}
        deps_v1["B.smf"] = "B:field-wrapper:v1"
        expect(loader.semantic_cache_is_fresh("A.smf", "A:abi:v1", deps_v1)).to_be(true)

        var deps_v2: Dict<text, text> = {}
        deps_v2["B.smf"] = "B:field-wrapper:v2"
        expect(loader.semantic_cache_is_fresh("A.smf", "A:abi:v1", deps_v2)).to_be(false)

    it "finds transitive dependents through dependency cycles":
        var loader = ModuleLoader.with_defaults()
        loader.record_semantic_fingerprint("A.smf", "A:abi:v1")
        loader.record_semantic_fingerprint("B.smf", "B:abi:v1")
        loader.record_dependency_semantic_fingerprint("A.smf", "B.smf", "B:field-wrapper:v1")
        loader.record_dependency_semantic_fingerprint("B.smf", "A.smf", "A:field-wrapper:v1")

        val affected = loader.semantic_dependents_of("B.smf")
        expect(affected.contains("A.smf")).to_be(true)
        expect(affected.contains("B.smf")).to_be(true)

        val invalidated = loader.invalidate_semantic_change("B.smf")
        expect(invalidated.contains("A.smf")).to_be(true)
        expect(invalidated.contains("B.smf")).to_be(true)
        expect(loader.semantic_cache_is_fresh("A.smf", "A:abi:v1", {})).to_be(false)

    it "invalidates JIT symbols compiled against a field-wrapper semantic key":
        var loader = ModuleLoader.with_defaults()
        val symbol_name = "Vec$field_wrapper"
        loader.jit.set_cache_for_test(symbol_name, [1, 2, 3], 4096)
        loader.jit.set_symbol_semantic_keys(symbol_name, ["B.value.field_wrapper"])

        expect(loader.jit.jit_cache.has(symbol_name)).to_be(true)

        val removed = loader.jit.invalidate_by_semantic_key("B.value.field_wrapper")

        expect(removed.contains(symbol_name)).to_be(true)
        expect(loader.jit.jit_cache.has(symbol_name)).to_be(false)
