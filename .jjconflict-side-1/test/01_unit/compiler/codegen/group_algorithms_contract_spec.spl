# @cover src/compiler/70.backend/gpu_intrinsics.spl 80%
# @cover src/compiler/70.backend/backend/opencl_backend.spl 80%
# @cover src/compiler/70.backend/backend/cuda_backend.spl 80%
# @tag: unit, compiler, gpu, codegen, group_algorithms

use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, compileoptions_default_options, CompileError}
use compiler.backend.opencl_backend.{OpenClBackend}
use compiler.backend.cuda_backend.{CudaBackend}
use compiler.backend.gpu_intrinsics.{is_gpu_intrinsic, recognize_gpu_intrinsic, all_gpu_intrinsic_names}
use compiler.semantics.gpu_checker.{is_gpu_builtin_call}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir.mir_data.{MirFunction, MirModule, MirSignature, BlockId, LocalId}
use compiler.mir.mir_instructions.{MirBlock, MirInst, MirInstKind, MirTerminator, MirOperand, MirOperandKind, GpuBarrierScope}
use compiler.mir.mir_types.{MirLocal, MirType, MirTypeKind, MirConstValue, LocalKind}

# ============================================================================
# Helpers (mirrored from subgroup_intrinsics_contract_spec.spl)
# ============================================================================

fn u32_type() -> MirType:
    MirType(kind: MirTypeKind.U32)

fn i32_type() -> MirType:
    MirType(kind: MirTypeKind.I32)

fn temp_local(id: i64, type_: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: nil, type_: type_, kind: LocalKind.Temp, is_ghost: false)

fn make_opencl_group_kernel(name: text, sym_id: i64, block: MirBlock) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: sym_id),
        name: name,
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [temp_local(0, i32_type()), temp_local(1, i32_type()), temp_local(2, u32_type())],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "opencl",
        gpu_backend_order: "opencl",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_cuda_group_kernel(name: text, sym_id: i64, block: MirBlock) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: sym_id),
        name: name,
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [temp_local(0, i32_type()), temp_local(1, i32_type()), temp_local(2, u32_type())],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "cuda",
        gpu_backend_order: "cuda",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_module_from(func: MirFunction) -> MirModule:
    var map: Dict<SymbolId, MirFunction> = {}
    map[func.symbol] = func
    MirModule(name: "group_algo_test_module", functions: map, statics: {}, constants: {}, types: {})

# Count substring occurrences via split (avoids interpreter .find() bug)
fn count_occurrences(haystack: text, needle: text) -> i64:
    val parts = haystack.split(needle)
    parts.len() - 1

# ============================================================================
# MIR blocks for group algorithm intrinsics
# ============================================================================

fn warp_reduce_add_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 0)), "gpu_warp_reduce_add", [MirOperand.copy(LocalId(id: 1))]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

fn warp_broadcast_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 0)), "gpu_warp_broadcast", [MirOperand.copy(LocalId(id: 1)), MirOperand.copy(LocalId(id: 2))]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

fn warp_scan_add_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 0)), "gpu_warp_scan_add", [MirOperand.copy(LocalId(id: 1))]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

# ============================================================================
# Contract spec — OpenCL backend
# ============================================================================

describe "group algorithms contract — OpenCL backend":

    it "emits sub_group_reduce_add for gpu_warp_reduce_add":
        val func = make_opencl_group_kernel("sg_reduce_add_kernel", 300, warp_reduce_add_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("sub_group_reduce_add(")

    it "emits sub_group_broadcast for gpu_warp_broadcast":
        val func = make_opencl_group_kernel("sg_broadcast_kernel", 301, warp_broadcast_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("sub_group_broadcast(")

    it "emits sub_group_scan_inclusive_add for gpu_warp_scan_add":
        val func = make_opencl_group_kernel("sg_scan_add_kernel", 302, warp_scan_add_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("sub_group_scan_inclusive_add(")

    it "does not emit unsupported placeholder for reduce_add":
        val func = make_opencl_group_kernel("sg_reduce_no_placeholder", 303, warp_reduce_add_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source.contains("// unsupported OpenCL intrinsic")).to_equal(false)

    it "does not emit unsupported placeholder for broadcast":
        val func = make_opencl_group_kernel("sg_broadcast_no_placeholder", 304, warp_broadcast_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source.contains("// unsupported OpenCL intrinsic")).to_equal(false)

    it "does not emit unsupported placeholder for scan_add":
        val func = make_opencl_group_kernel("sg_scan_no_placeholder", 305, warp_scan_add_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source.contains("// unsupported OpenCL intrinsic")).to_equal(false)

# ============================================================================
# Contract spec — CUDA/PTX backend
# ============================================================================

describe "group algorithms contract — CUDA/PTX backend":

    it "emits shfl.sync.bfly.b32 for gpu_warp_reduce_add":
        val func = make_cuda_group_kernel("cuda_reduce_add_kernel", 400, warp_reduce_add_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("shfl.sync.bfly.b32")

    it "emits exactly 5 shfl.sync.bfly.b32 steps for gpu_warp_reduce_add":
        val func = make_cuda_group_kernel("cuda_reduce_count_kernel", 401, warp_reduce_add_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        val bfly_count = count_occurrences(ptx, "shfl.sync.bfly.b32")
        expect(bfly_count).to_equal(5)

    it "emits add.s32 in reduce sequence for gpu_warp_reduce_add":
        val func = make_cuda_group_kernel("cuda_reduce_add_add_kernel", 402, warp_reduce_add_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("add.s32")

    it "emits shfl.sync.idx.b32 for gpu_warp_broadcast":
        val func = make_cuda_group_kernel("cuda_broadcast_kernel", 403, warp_broadcast_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("shfl.sync.idx.b32")

    it "emits shfl.sync.up.b32 for gpu_warp_scan_add":
        val func = make_cuda_group_kernel("cuda_scan_add_kernel", 404, warp_scan_add_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("shfl.sync.up.b32")

    it "emits exactly 5 shfl.sync.up.b32 steps for gpu_warp_scan_add":
        val func = make_cuda_group_kernel("cuda_scan_count_kernel", 405, warp_scan_add_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        val up_count = count_occurrences(ptx, "shfl.sync.up.b32")
        expect(up_count).to_equal(5)

    it "emits setp.ge.u32 predicates for gpu_warp_scan_add":
        val func = make_cuda_group_kernel("cuda_scan_setp_kernel", 406, warp_scan_add_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("setp.ge.u32")

    it "does not emit Unknown intrinsic comment for gpu_warp_reduce_add":
        val func = make_cuda_group_kernel("cuda_reduce_no_unknown", 407, warp_reduce_add_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        expect(result.unwrap().ptx.contains("Unknown intrinsic: gpu_warp_reduce_add")).to_equal(false)

    it "does not emit Unknown intrinsic comment for gpu_warp_broadcast":
        val func = make_cuda_group_kernel("cuda_broadcast_no_unknown", 408, warp_broadcast_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        expect(result.unwrap().ptx.contains("Unknown intrinsic: gpu_warp_broadcast")).to_equal(false)

    it "does not emit Unknown intrinsic comment for gpu_warp_scan_add":
        val func = make_cuda_group_kernel("cuda_scan_no_unknown", 409, warp_scan_add_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        expect(result.unwrap().ptx.contains("Unknown intrinsic: gpu_warp_scan_add")).to_equal(false)

# ============================================================================
# Recognition and arity checks
# ============================================================================

describe "group algorithms — recognition and arity":

    it "recognizes gpu_warp_reduce_add":
        expect(recognize_gpu_intrinsic("gpu_warp_reduce_add").?).to_equal(true)

    it "recognizes gpu_warp_broadcast":
        expect(recognize_gpu_intrinsic("gpu_warp_broadcast").?).to_equal(true)

    it "recognizes gpu_warp_scan_add":
        expect(recognize_gpu_intrinsic("gpu_warp_scan_add").?).to_equal(true)

    it "all_gpu_intrinsic_names includes group algorithm intrinsics":
        val names = all_gpu_intrinsic_names()
        expect(names.contains("gpu_warp_reduce_add")).to_equal(true)
        expect(names.contains("gpu_warp_broadcast")).to_equal(true)
        expect(names.contains("gpu_warp_scan_add")).to_equal(true)

    it "group algorithm intrinsics are whitelisted by gpu_checker":
        expect(is_gpu_builtin_call("gpu_warp_reduce_add")).to_equal(true)
        expect(is_gpu_builtin_call("gpu_warp_broadcast")).to_equal(true)
        expect(is_gpu_builtin_call("gpu_warp_scan_add")).to_equal(true)
