# Unit coverage for the duplicate-check core scoring functions: tokenizer
# keyword classification, cosine-similarity scoring at the extremes, and the
# candidate-pruning detection path against the dup_pair/clean_pair fixtures
# (test/fixtures/duplication/). See doc/08_tracking/bug/ for defects found
# while building this coverage (seed u8 relational-comparison boxtag defect;
# duplicate-check CLI cannot scan under test/ without an exclude override).

use compiler.tools.duplicate_check.config.{default_config, apply_analysis_mode, DuplicationConfig}
use compiler.tools.duplicate_check.tokenizer.{tokenize, SimpleTokenKind}
use compiler.tools.duplicate_check.detector.{collect_files, find_duplicates, DuplicateGroup}
use compiler.tools.duplicate_check.features.{extract_token_frequencies, build_feature_vector, cosine_similarity}
use compiler.tools.duplicate_check.cache.{new_token_cache_manager}

fn dup_pair_dir() -> text:
    "test/fixtures/duplication/dup_pair"

fn clean_pair_dir() -> text:
    "test/fixtures/duplication/clean_pair"

fn token_mode_config() -> DuplicationConfig:
    var cfg = default_config()
    # The CLI's default exclude_patterns include "test/", which would make
    # collect_files silently return 0 files for any path under test/fixtures.
    # Direct unit calls bypass the CLI arg surface, so override it explicitly
    # (see duplicate_check_cli_cannot_scan_under_test_dir_2026-07-17.md).
    cfg.exclude_patterns = []
    cfg = apply_analysis_mode(cfg, "token")
    cfg.min_tokens = 10
    cfg.min_lines = 5
    cfg.min_impact = 10
    cfg

fn group_spans_both_files(groups: [DuplicateGroup]) -> bool:
    for g in groups:
        var has_a = false
        var has_b = false
        for block in g.blocks:
            if block.file.contains("/a.spl"):
                has_a = true
            if block.file.contains("/b.spl"):
                has_b = true
        if has_a and has_b:
            return true
    false

describe "duplicate-check tokenizer":
    it "classifies control-flow and binding keywords as Keyword tokens":
        var cfg = default_config()
        val source = "fn score(base: i64) -> i64:\n    var total = base\n    if total > 0:\n        return total\n    return 0\n"
        val tokens = tokenize(source, cfg)

        var keyword_count = 0
        for token in tokens:
            if token.kind == SimpleTokenKind.Keyword:
                keyword_count = keyword_count + 1

        # fn, var, if, return, return -> 5 keyword tokens
        expect(keyword_count).to_equal(5)

describe "duplicate-check similarity scoring":
    it "scores identical token-frequency vectors at (near-)maximum similarity":
        var freq_map = {}
        freq_map["SimpleTokenKind::Keyword:fn"] = 1
        freq_map["SimpleTokenKind::Identifier:IDENTIFIER"] = 3
        freq_map["SimpleTokenKind::Keyword:return"] = 2

        val vector_a = build_feature_vector(0, freq_map)
        val vector_b = build_feature_vector(1, freq_map)
        val similarity = cosine_similarity(vector_a, vector_b)

        expect(similarity).to_be_greater_than(0.99)

    it "scores disjoint token-frequency vectors at (near-)zero similarity":
        var freq_map_a = {}
        freq_map_a["SimpleTokenKind::Keyword:fn"] = 1
        freq_map_a["SimpleTokenKind::Identifier:IDENTIFIER"] = 3

        var freq_map_b = {}
        freq_map_b["SimpleTokenKind::Operator:+"] = 4
        freq_map_b["SimpleTokenKind::Literal:LITERAL"] = 2

        val vector_a = build_feature_vector(0, freq_map_a)
        val vector_b = build_feature_vector(1, freq_map_b)
        val similarity = cosine_similarity(vector_a, vector_b)

        expect(similarity).to_be_less_than(0.01)

describe "duplicate-check candidate-pruning detection path":
    it "detects the known duplicated function pair in dup_pair":
        val cfg = token_mode_config()
        val files = collect_files(dup_pair_dir(), cfg)
        expect(files.len()).to_equal(2)

        val cache_manager = new_token_cache_manager()
        val groups = find_duplicates(files, cfg, cache_manager)

        expect(groups.len()).to_be_greater_than(0)
        expect(group_spans_both_files(groups)).to_equal(true)

    it "reports no duplicate groups for the structurally distinct clean_pair":
        val cfg = token_mode_config()
        val files = collect_files(clean_pair_dir(), cfg)
        expect(files.len()).to_equal(2)

        val cache_manager = new_token_cache_manager()
        val groups = find_duplicates(files, cfg, cache_manager)

        expect(groups.len()).to_equal(0)
