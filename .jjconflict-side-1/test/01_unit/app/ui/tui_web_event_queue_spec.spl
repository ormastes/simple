# @cover src/app/ui.tui_web/backend.spl 80%
# @tag: unit, ui, tui-web, event-queue, perf

use std.spec.{describe, it, expect}
use app.ui.tui_web.backend.{TuiWebBackend}
use common.ui.widget.{UIEvent}

describe "TuiWebBackend event queue":

    it "keeps FIFO order across cursor compaction and clears after drain":
        val backend = TuiWebBackend.new()
        var i = 0
        while i < 80:
            backend.push_event(UIEvent.KeyPress(key: "k" + i.to_string()))
            i = i + 1

        val first = backend.poll_event(0)
        val second = backend.poll_event(0)
        expect(first != nil).to_equal(true)
        expect(second != nil).to_equal(true)

        var drained = 2
        while drained < 80:
            val event = backend.poll_event(0)
            expect(event != nil).to_equal(true)
            drained = drained + 1

        expect(backend.poll_event(0)).to_equal(nil)
        expect(backend.event_queue.len()).to_equal(0)
        expect(backend.event_head).to_equal(0)
