extern fn rt_file_read_text(path: text) -> text?

describe "ui cli socket count guard":
    it "guards malformed count values":
        val source = rt_file_read_text("src/app/ui.cli/socket_server.spl") ?? ""

        expect(source).to_contain("fn parse_socket_count_or_default(value: text, default_value: i32) -> i32")
        expect(source).to_contain("val count = parse_socket_count_or_default(count_str, 10)")
        expect(source.contains("count_str.to_int()")).to_equal(false)
