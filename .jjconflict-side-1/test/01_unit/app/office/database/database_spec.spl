"""Minimal Access-like database spec — table.spl + query.spl.

Ground truth is hand-computed against two small tables:

employees(id, name, dept, salary):
  1, Alice, Eng,   90000
  2, bob,   Sales, 60000
  3, Carol, Eng,   95000
  4, Dave,  Sales, 55000

departments(dept, manager):
  Eng,   Erin
  Sales, Sam
"""

use std.spec
use app.office.database.table.{Table, table_new, table_insert, table_row_count, table_get}
use app.office.database.query.{query_select_where, query_order_by, query_inner_join, query_group_count}

fn _employees() -> Table:
    var t = table_new("employees", ["id", "name", "dept", "salary"])
    t = table_insert(t, ["1", "Alice", "Eng", "90000"])
    t = table_insert(t, ["2", "bob", "Sales", "60000"])
    t = table_insert(t, ["3", "Carol", "Eng", "95000"])
    t = table_insert(t, ["4", "Dave", "Sales", "55000"])
    t

fn _departments() -> Table:
    var t = table_new("departments", ["dept", "manager"])
    t = table_insert(t, ["Eng", "Erin"])
    t = table_insert(t, ["Sales", "Sam"])
    t

describe "table_new / table_insert / table_row_count / table_get":
    it "builds a table and reports the correct row count":
        val t = _employees()
        expect(table_row_count(t)).to_equal(4)

    it "gets cells by row index and column name":
        val t = _employees()
        expect(table_get(t, 0, "name")).to_equal("Alice")
        expect(table_get(t, 2, "salary")).to_equal("95000")

describe "query_select_where":
    it "numeric compare selects rows with salary > 60000":
        val t = _employees()
        val r = query_select_where(t, "salary", ">", "60000")
        expect(table_row_count(r)).to_equal(2)
        expect(table_get(r, 0, "name")).to_equal("Alice")
        expect(table_get(r, 1, "name")).to_equal("Carol")

    it "case-insensitive text compare selects rows with dept = eng":
        val t = _employees()
        val r = query_select_where(t, "dept", "=", "eng")
        expect(table_row_count(r)).to_equal(2)
        expect(table_get(r, 0, "name")).to_equal("Alice")
        expect(table_get(r, 1, "name")).to_equal("Carol")

describe "query_order_by":
    it "sorts ascending by salary":
        val t = _employees()
        val r = query_order_by(t, "salary", false)
        expect(table_get(r, 0, "name")).to_equal("Dave")
        expect(table_get(r, 1, "name")).to_equal("bob")
        expect(table_get(r, 2, "name")).to_equal("Alice")
        expect(table_get(r, 3, "name")).to_equal("Carol")

    it "sorts descending by salary":
        val t = _employees()
        val r = query_order_by(t, "salary", true)
        expect(table_get(r, 0, "name")).to_equal("Carol")
        expect(table_get(r, 3, "name")).to_equal("Dave")

describe "query_inner_join":
    it "joins employees to departments on dept":
        val e = _employees()
        val d = _departments()
        val j = query_inner_join(e, d, "dept", "dept")
        expect(table_row_count(j)).to_equal(4)
        expect(table_get(j, 0, "manager")).to_equal("Erin")
        expect(table_get(j, 0, "name")).to_equal("Alice")

describe "query_group_count":
    it "groups employees by dept in first-seen order with counts":
        val t = _employees()
        val g = query_group_count(t, "dept")
        expect(table_row_count(g)).to_equal(2)
        expect(table_get(g, 0, "dept")).to_equal("Eng")
        expect(table_get(g, 0, "count")).to_equal("2")
        expect(table_get(g, 1, "dept")).to_equal("Sales")
        expect(table_get(g, 1, "count")).to_equal("2")

describe "tail execution probe":
    it "confirms the final describe block actually runs":
        expect(1 + 1).to_equal(2)
