"""Table relationships + referential integrity spec — relations.spl.

Ground truth is hand-computed against two small tables:

depts(dept_id, name):
  1, Eng
  2, Sales

employees(emp, dept_id):
  Alice, 1
  Bob,   2
  Carol, 9   <- orphan: no dept with dept_id=9
"""

use std.spec
use app.office.database.table.{Table, table_new, table_insert, table_row_count, table_get}
use app.office.database.relations.{Relationship, relationship_new, ref_integrity_check, can_insert_child, can_delete_parent, join_on_fk}

fn _depts() -> Table:
    var t = table_new("depts", ["dept_id", "name"])
    t = table_insert(t, ["1", "Eng"])
    t = table_insert(t, ["2", "Sales"])
    t

fn _employees() -> Table:
    var t = table_new("employees", ["emp", "dept_id"])
    t = table_insert(t, ["Alice", "1"])
    t = table_insert(t, ["Bob", "2"])
    t = table_insert(t, ["Carol", "9"])
    t

describe "relationship_new":
    it "carries all four declared fields":
        val r = relationship_new("employees", "dept_id", "depts", "dept_id")
        expect(r.child_table).to_equal("employees")
        expect(r.child_col).to_equal("dept_id")
        expect(r.parent_table).to_equal("depts")
        expect(r.parent_col).to_equal("dept_id")

describe "ref_integrity_check":
    it "flags Carol's dept_id=9 as the only orphan":
        val parent = _depts()
        val child = _employees()
        val violations = ref_integrity_check(parent, child, "dept_id", "dept_id")
        expect(violations.len()).to_equal(1)
        expect(violations[0]).to_equal("orphan: dept_id=9")

    it "is empty (referentially intact) when every FK resolves":
        val parent = _depts()
        var child = table_new("employees", ["emp", "dept_id"])
        child = table_insert(child, ["Alice", "1"])
        child = table_insert(child, ["Bob", "2"])
        val violations = ref_integrity_check(parent, child, "dept_id", "dept_id")
        expect(violations.len()).to_equal(0)

describe "can_insert_child":
    it "allows a new row whose FK resolves to an existing parent (dept_id=1)":
        val parent = _depts()
        val ok = can_insert_child(parent, ["Dave", "1"], 1, "dept_id")
        assert_true(ok)

    it "rejects a new row whose FK does not resolve (dept_id=9)":
        val parent = _depts()
        val ok = can_insert_child(parent, ["Eve", "9"], 1, "dept_id")
        assert_false(ok)

    it "allows an empty FK value (null FK)":
        val parent = _depts()
        val ok = can_insert_child(parent, ["Frank", ""], 1, "dept_id")
        assert_true(ok)

describe "can_delete_parent":
    it "restricts deleting dept 1 (Eng) because Alice depends on it":
        val parent = _depts()
        val child = _employees()
        val ok = can_delete_parent(parent, child, 0, "dept_id", "dept_id")
        assert_false(ok)

    it "allows deleting a dept with no dependent children":
        val parent = _depts()
        var no_children = table_new("employees", ["emp", "dept_id"])
        val ok = can_delete_parent(parent, no_children, 0, "dept_id", "dept_id")
        assert_true(ok)

describe "join_on_fk":
    it "joins employees to depts on dept_id, dropping Carol's orphan row":
        val parent = _depts()
        val child = _employees()
        val joined = join_on_fk(parent, child, "dept_id", "dept_id")
        expect(table_row_count(joined)).to_equal(2)

    it "row 0 joins Alice with Eng":
        val parent = _depts()
        val child = _employees()
        val joined = join_on_fk(parent, child, "dept_id", "dept_id")
        expect(table_get(joined, 0, "emp")).to_equal("Alice")
        expect(table_get(joined, 0, "name")).to_equal("Eng")

    describe "tail execution probe":
        it "confirms the final nested describe block actually runs":
            expect(1 + 1).to_equal(2)
