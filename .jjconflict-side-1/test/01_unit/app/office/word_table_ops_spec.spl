"""Word document table operations spec.

Verifies pure-function table operations: insert/delete rows/columns, set cell
values, and get table dimensions. All functions work over the RichDocument
model without mutating input. Tables are stored as markdown text within blocks."""

use std.spec
use app.office.word.table_ops.{table_insert_row, table_delete_row, table_insert_col, table_delete_col, table_set_cell, table_dims}
use common.rich_text.attributed_text.{RichDocument, DocBlock, BlockKind, TextSpan, InlineStyle}

# =========================================================================
# Helpers
# =========================================================================

fn _table_doc(table_text: text, title: text) -> RichDocument:
    """Build a document with a single table block."""
    var doc = RichDocument.new(title)
    val block = DocBlock(kind: BlockKind.Paragraph, spans: [
        TextSpan(text: table_text, style: InlineStyle.Normal, link_url: "", footnote_id: "", comment_id: "", revision_id: "")
    ])
    doc.blocks.push(block)
    doc

fn _get_table_text(doc: RichDocument, block_idx: i64) -> text:
    """Extract table markdown from document block."""
    if block_idx < 0 or block_idx >= doc.blocks.len().to_i64():
        return ""
    val block = doc.blocks.get(block_idx)
    if block.spans.len() == 0:
        return ""
    block.spans.get(0).text

# =========================================================================
# Test: table_dims
# =========================================================================

describe "table_dims: get table dimensions":
    """Returns [rows, cols] for body rows and columns."""

    it "returns [2, 2] for a 2x2 table":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val dims = table_dims(doc, 0)
        expect(dims.len()).to_equal(2)
        expect(dims.get(0)).to_equal(2)  # 2 body rows
        expect(dims.get(1)).to_equal(2)  # 2 cols

    it "returns [0, 0] for out-of-range block":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |"
        val doc = _table_doc(table_md, "test")
        val dims = table_dims(doc, 5)
        expect(dims.get(0)).to_equal(0)
        expect(dims.get(1)).to_equal(0)

    it "returns [0, 0] for empty block":
        val doc = RichDocument.new("test")
        val dims = table_dims(doc, 0)
        expect(dims.get(0)).to_equal(0)
        expect(dims.get(1)).to_equal(0)

# =========================================================================
# Test: table_insert_row
# =========================================================================

describe "table_insert_row: insert a row at given index":
    """Insert row in table body (after separator). Row index is 0-based."""

    it "inserts a row and dims increase to [3, 2]":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_row(doc, 0, 0, ["C1", "C2"])
        val dims = table_dims(new_doc, 0)
        expect(dims.get(0)).to_equal(3)
        expect(dims.get(1)).to_equal(2)

    it "inserts new row with correct content":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_row(doc, 0, 0, ["X", "Y"])
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| X | Y |")
        # Verify order: header, separator, X Y, A1 A2, B1 B2
        val lines = text.split("\n")
        expect(lines.len()).to_equal(5)
        expect(lines.get(2)).to_contain("X")

    it "inserts at end of table (row_index=2)":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_row(doc, 0, 2, ["Z1", "Z2"])
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| Z1 | Z2 |")
        val lines = text.split("\n")
        expect(lines.get(4)).to_contain("Z1")

    it "returns unchanged doc for out-of-range block":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_row(doc, 99, 0, ["X", "Y"])
        val dims = table_dims(new_doc, 0)
        expect(dims.get(0)).to_equal(1)  # Unchanged

# =========================================================================
# Test: table_delete_row
# =========================================================================

describe "table_delete_row: delete a row at given index":
    """Delete row from table body (after separator)."""

    it "deletes a row and dims decrease to [1, 2]":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_delete_row(doc, 0, 0)
        val dims = table_dims(new_doc, 0)
        expect(dims.get(0)).to_equal(1)
        expect(dims.get(1)).to_equal(2)

    it "deletes correct row (first row A1)":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_delete_row(doc, 0, 0)
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| B1 | B2 |")
        expect(text.contains("A1")).to_be(false)

    it "deletes last row":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_delete_row(doc, 0, 1)
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| A1 | A2 |")
        expect(text.contains("B1")).to_be(false)

    it "returns unchanged doc for out-of-range row":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_delete_row(doc, 0, 99)
        val dims = table_dims(new_doc, 0)
        expect(dims.get(0)).to_equal(1)  # Unchanged

# =========================================================================
# Test: table_insert_col
# =========================================================================

describe "table_insert_col: insert a column at given index":
    """Insert column with header and cells at col_index."""

    it "inserts a column and dims increase to [2, 3]":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_col(doc, 0, 1, "H_NEW", ["X", "Y"])
        val dims = table_dims(new_doc, 0)
        expect(dims.get(0)).to_equal(2)
        expect(dims.get(1)).to_equal(3)

    it "inserts column with correct header":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_col(doc, 0, 0, "NEW", ["V1", "V2"])
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| NEW | H1 |")

    it "inserts column with correct cells":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_col(doc, 0, 1, "MID", ["X", "Y"])
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| H1 | MID | H2 |")
        expect(text).to_contain("| A1 | X | A2 |")
        expect(text).to_contain("| B1 | Y | B2 |")

    it "inserts at end of row (col_index=2)":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_col(doc, 0, 2, "H3", ["A3", "B3"])
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| H1 | H2 | H3 |")
        expect(text).to_contain("| A1 | A2 | A3 |")

    it "returns unchanged doc for out-of-range col_index":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_insert_col(doc, 0, 99, "X", ["Y"])
        val dims = table_dims(new_doc, 0)
        expect(dims.get(1)).to_equal(2)  # Unchanged

# =========================================================================
# Test: table_delete_col
# =========================================================================

describe "table_delete_col: delete a column at given index":
    """Delete column from table."""

    it "deletes a column and dims decrease to [2, 1]":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_delete_col(doc, 0, 1)
        val dims = table_dims(new_doc, 0)
        expect(dims.get(0)).to_equal(2)
        expect(dims.get(1)).to_equal(1)

    it "deletes correct column (first column)":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_delete_col(doc, 0, 0)
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| H2 |")
        expect(text.contains("H1")).to_be(false)
        expect(text).to_contain("| A2 |")

    it "deletes last column":
        val table_md = "| H1 | H2 | H3 |\n|---|---|---|\n| A1 | A2 | A3 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_delete_col(doc, 0, 2)
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| H1 | H2 |")
        expect(text.contains("H3")).to_be(false)
        val dims = table_dims(new_doc, 0)
        expect(dims.get(1)).to_equal(2)

    it "returns unchanged doc for out-of-range col_index":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_delete_col(doc, 0, 99)
        val dims = table_dims(new_doc, 0)
        expect(dims.get(1)).to_equal(2)  # Unchanged

# =========================================================================
# Test: table_set_cell
# =========================================================================

describe "table_set_cell: set a cell value":
    """Set cell at (row_index, col_index) to a new value."""

    it "sets a cell to new value":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_set_cell(doc, 0, 0, 0, "CHANGED")
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| CHANGED | A2 |")

    it "sets different cell in same row":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_set_cell(doc, 0, 0, 1, "NEW_A2")
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| A1 | NEW_A2 |")

    it "sets cell in second row":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_set_cell(doc, 0, 1, 0, "B1_EDIT")
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| B1_EDIT | B2 |")
        # Verify first row unchanged
        expect(text).to_contain("| A1 | A2 |")

    it "returns unchanged doc for out-of-range cell":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |"
        val doc = _table_doc(table_md, "test")
        val new_doc = table_set_cell(doc, 0, 0, 99, "X")
        val text = _get_table_text(new_doc, 0)
        expect(text).to_contain("| A1 | A2 |")  # Unchanged

# =========================================================================
# Test: Combined Operations (Round-trip)
# =========================================================================

describe "combined operations: insert row, dims, delete row":
    """Test sequences of operations preserve document integrity."""

    it "insert row and verify dims, then delete returns to original dims":
        val table_md = "| H1 | H2 |\n|---|---|\n| A1 | A2 |\n| B1 | B2 |"
        val doc = _table_doc(table_md, "test")
        val original_dims = table_dims(doc, 0)
        expect(original_dims.get(0)).to_equal(2)

        val after_insert = table_insert_row(doc, 0, 1, ["X", "Y"])
        val insert_dims = table_dims(after_insert, 0)
        expect(insert_dims.get(0)).to_equal(3)

        val after_delete = table_delete_row(after_insert, 0, 1)
        val final_dims = table_dims(after_delete, 0)
        expect(final_dims.get(0)).to_equal(2)
