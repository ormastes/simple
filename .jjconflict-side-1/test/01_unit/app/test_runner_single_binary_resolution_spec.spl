use std.spec
use std.io_runtime.{file_read}

describe "single-file test runner binary resolution":
    it "does not execute its source entrypoint as the Simple binary":
        val source = file_read("src/app/test_runner_new/test_runner_single.spl")

        expect(source).to_contain("val configured = env_get(\"SIMPLE_BINARY\")")
        expect(source).to_contain("raw[0].ends_with(\"/simple\")")
        expect(source).to_contain("raw[0].ends_with(\"simple.exe\")")
        expect(source.contains("if raw.len() > 0 and rt_file_exists(raw[0]):")).to_equal(false)
