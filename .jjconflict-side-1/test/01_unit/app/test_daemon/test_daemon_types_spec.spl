# Test Daemon Types Specification
#
# Tests test-specific request kinds, response statuses,
# configuration, and conversion functions.
#
# **Feature IDs:** #TDMN-001 to #TDMN-010
# **Category:** Infrastructure

# ============================================================================
# Module-level constants and mock state
# ============================================================================

val TREQ_RUN_SINGLE: i64 = 1
val TREQ_RUN_ALL: i64 = 2
val TREQ_CLEAN_RUN: i64 = 3
val TREQ_STATUS: i64 = 4
val TREQ_STOP: i64 = 5

val TRESP_QUEUED: i64 = 0
val TRESP_RUNNING: i64 = 1
val TRESP_COMPLETED: i64 = 2
val TRESP_FAILED: i64 = 3
val TRESP_SKIPPED: i64 = 4
val TRESP_ERROR: i64 = 5
val TRESP_CACHED: i64 = 6

# Mock config
var tcfg_lock: text = ""
var tcfg_cache_path: text = ""
var tcfg_dep_path: text = ""
var tcfg_qemu_timeout: i64 = 0
var tcfg_max_qemu: i64 = 0

fn tcfg_reset():
    tcfg_lock = ".build/test_daemon/test_daemon.lock"
    tcfg_cache_path = ".build/test_daemon/test_cache.sdn"
    tcfg_dep_path = ".build/test_daemon/dep_graph.sdn"
    tcfg_qemu_timeout = 300000
    tcfg_max_qemu = 4

fn tcfg_get_lock() -> text:
    tcfg_lock
fn tcfg_get_cache() -> text:
    tcfg_cache_path
fn tcfg_get_dep() -> text:
    tcfg_dep_path
fn tcfg_get_qemu_timeout() -> i64:
    tcfg_qemu_timeout
fn tcfg_get_max_qemu() -> i64:
    tcfg_max_qemu

# Mock request conversion
var treq_kind: i64 = 0
var treq_path: text = ""
var treq_filter: text = ""
var treq_clean: bool = false

fn treq_reset():
    treq_kind = 0
    treq_path = ""
    treq_filter = ""
    treq_clean = false

fn treq_create(kind: i64, path: text, filter: text, clean: bool):
    treq_kind = kind
    treq_path = path
    treq_filter = filter
    treq_clean = clean

fn treq_to_daemon_fields() -> [(text, text)]:
    var fields: [(text, text)] = []
    if treq_path != "":
        fields = fields + [("test_path", treq_path)]
    if treq_filter != "":
        fields = fields + [("filter", treq_filter)]
    if treq_clean:
        fields = fields + [("clean", "true")]
    fields

fn treq_get_kind() -> i64:
    treq_kind
fn treq_get_path() -> text:
    treq_path

# Mock response conversion
var tresp_status: i64 = 0
var tresp_passed: i64 = 0
var tresp_failed: i64 = 0
var tresp_skipped: i64 = 0
var tresp_duration: i64 = 0
var tresp_cached: bool = false

fn tresp_reset():
    tresp_status = 0
    tresp_passed = 0
    tresp_failed = 0
    tresp_skipped = 0
    tresp_duration = 0
    tresp_cached = false

fn tresp_from_fields(status: i64, passed_s: text, failed_s: text, skipped_s: text, duration_s: text, cached_s: text):
    tresp_status = status
    tresp_passed = passed_s.to_i64() ?? 0
    tresp_failed = failed_s.to_i64() ?? 0
    tresp_skipped = skipped_s.to_i64() ?? 0
    tresp_duration = duration_s.to_i64() ?? 0
    tresp_cached = cached_s == "true"

fn tresp_get_status() -> i64:
    tresp_status
fn tresp_get_passed() -> i64:
    tresp_passed
fn tresp_get_failed() -> i64:
    tresp_failed
fn tresp_get_cached() -> bool:
    tresp_cached

# ============================================================================
# Tests
# ============================================================================

describe "TestDaemonConfig":
    it "has correct default lock path":
        tcfg_reset()
        expect(tcfg_get_lock()).to_equal(".build/test_daemon/test_daemon.lock")

    it "has correct default cache path":
        tcfg_reset()
        expect(tcfg_get_cache()).to_equal(".build/test_daemon/test_cache.sdn")

    it "has correct default QEMU timeout":
        tcfg_reset()
        expect(tcfg_get_qemu_timeout()).to_equal(300000)

    it "has correct default max QEMU sessions":
        tcfg_reset()
        expect(tcfg_get_max_qemu()).to_equal(4)

describe "TestRequestConversion":
    it "converts RUN_SINGLE with path":
        treq_reset()
        treq_create(TREQ_RUN_SINGLE, "test/foo_spec.spl", "", false)
        val fields = treq_to_daemon_fields()
        expect(fields.len()).to_equal(1)
        expect(fields[0][0]).to_equal("test_path")
        expect(fields[0][1]).to_equal("test/foo_spec.spl")

    it "converts CLEAN_RUN with clean flag":
        treq_reset()
        treq_create(TREQ_CLEAN_RUN, "test/bar_spec.spl", "", true)
        val fields = treq_to_daemon_fields()
        expect(fields.len()).to_equal(2)

    it "converts RUN_ALL with filter":
        treq_reset()
        treq_create(TREQ_RUN_ALL, "", "unit", false)
        val fields = treq_to_daemon_fields()
        expect(fields.len()).to_equal(1)
        expect(fields[0][0]).to_equal("filter")
        expect(fields[0][1]).to_equal("unit")

    it "preserves request kind":
        treq_reset()
        treq_create(TREQ_STATUS, "", "", false)
        expect(treq_get_kind()).to_equal(TREQ_STATUS)

describe "TestResponseConversion":
    it "parses completed result":
        tresp_reset()
        tresp_from_fields(TRESP_COMPLETED, "10", "0", "2", "450", "false")
        expect(tresp_get_status()).to_equal(TRESP_COMPLETED)
        expect(tresp_get_passed()).to_equal(10)
        expect(tresp_get_failed()).to_equal(0)
        expect(tresp_get_cached()).to_equal(false)

    it "parses cached result":
        tresp_reset()
        tresp_from_fields(TRESP_CACHED, "5", "0", "0", "0", "true")
        expect(tresp_get_status()).to_equal(TRESP_CACHED)
        expect(tresp_get_cached()).to_equal(true)

    it "parses failed result":
        tresp_reset()
        tresp_from_fields(TRESP_FAILED, "3", "2", "0", "800", "false")
        expect(tresp_get_status()).to_equal(TRESP_FAILED)
        expect(tresp_get_failed()).to_equal(2)

describe "RequestKindConstants":
    it "has distinct values":
        expect(TREQ_RUN_SINGLE != TREQ_RUN_ALL).to_equal(true)
        expect(TREQ_RUN_ALL != TREQ_CLEAN_RUN).to_equal(true)
        expect(TREQ_CLEAN_RUN != TREQ_STATUS).to_equal(true)
        expect(TREQ_STATUS != TREQ_STOP).to_equal(true)

describe "ResponseStatusConstants":
    it "has distinct values":
        expect(TRESP_QUEUED != TRESP_COMPLETED).to_equal(true)
        expect(TRESP_COMPLETED != TRESP_FAILED).to_equal(true)
        expect(TRESP_FAILED != TRESP_CACHED).to_equal(true)
        expect(TRESP_CACHED != TRESP_ERROR).to_equal(true)
