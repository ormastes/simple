# IDE capabilities hardening spec.
#
# Verifies that all registered capability entries have valid required fields,
# and that preview-bounds guards work correctly.

use std.spec
use app.ide.capabilities.{ide_capabilities, ide_capability_count, ide_capability_valid, ide_capability_valid_count, ide_preview_bounds_valid}

describe "capabilities: all registered entries have valid required fields":

    it "all capabilities pass ide_capability_valid":
        expect(ide_capability_valid_count()).to_equal(ide_capability_count())

    it "preview bounds with positive width and height are valid":
        expect(ide_preview_bounds_valid(800, 600)).to_equal(true)

    it "preview bounds with zero width are invalid":
        expect(ide_preview_bounds_valid(0, 600)).to_equal(false)

    it "preview bounds with zero height are invalid":
        expect(ide_preview_bounds_valid(800, 0)).to_equal(false)

    it "preview bounds with negative dimensions are invalid":
        expect(ide_preview_bounds_valid(-1, -1)).to_equal(false)

    it "capability count is positive":
        expect(ide_capability_count() > 0).to_equal(true)

    it "capability ids are all non-empty via ide_capability_valid":
        var all_ok = true
        for cap in ide_capabilities():
            if not ide_capability_valid(cap):
                all_ok = false
        expect(all_ok).to_equal(true)
