    k

# Nonce (12 bytes): 070000004041424344454647
fn _nonce() -> [u8]:
    var n: [u8] = []
    n.push(0x07)
    n.push(0x00)
    n.push(0x00)
    n.push(0x00)
    n.push(0x40)
    n.push(0x41)
    n.push(0x42)
    n.push(0x43)
    n.push(0x44)
    n.push(0x45)
    n.push(0x46)
    n.push(0x47)
    n

# AAD (12 bytes): 50515253c0c1c2c3c4c5c6c7
fn _aad() -> [u8]:
    var a: [u8] = []
    a.push(0x50)
    a.push(0x51)
