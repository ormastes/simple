# ChaCha20-Poly1305 AEAD Known-Answer Test — RFC 8439 §2.8.2
#
# Tests chacha20_poly1305_encrypt and chacha20_poly1305_decrypt against the
# canonical AEAD construction test vector from RFC 8439 Section 2.8.2.
#
# Encrypt returns ciphertext || 16-byte Poly1305 tag concatenated (130 bytes).
# Decrypt takes (key, nonce, ciphertext_only, aad, tag) and returns
# Chacha20Poly1305Result.Ok(data: plaintext) on success.
#
# NOTE: per memory/feedback_it_block_var_mutation.md, byte-array inputs are
# built in module-level fn helpers so loop pushes persist across calls.
# NOTE: per memory/feedback_compile_mode_false_greens.md this spec is
# verified in interpreter mode only.
# NOTE: hex literals have no u8 suffix (matches aes_modes_nist_spec.spl style).
#
# Source: RFC 8439 Section 2.8.2
# https://www.rfc-editor.org/rfc/rfc8439#section-2.8.2

use std.spec.*
use os.crypto.chacha20_poly1305.{
    chacha20_poly1305_encrypt,
    chacha20_poly1305_decrypt,
    Chacha20Poly1305Result
}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

# ============================================================================
# Slice helper
# ============================================================================

fn _slice(buf: [u8], start: i64, end_: i64) -> [u8]:
    var s: [u8] = []
    var i: i64 = start
    while i < end_:
        s.push(rt_bytes_u8_at(buf, i))
        i = i + 1
    s

# ============================================================================
# Result enum helpers
# ============================================================================

fn _decrypt_ok(r: Chacha20Poly1305Result) -> bool:
    match r:
        Chacha20Poly1305Result.Ok(_):  true
        Chacha20Poly1305Result.Err(_): false

fn _decrypt_payload(r: Chacha20Poly1305Result) -> [u8]:
    match r:
        Chacha20Poly1305Result.Ok(data): data
        Chacha20Poly1305Result.Err(_):   []

# ============================================================================
# RFC 8439 §2.8.2 test vectors
# ============================================================================

