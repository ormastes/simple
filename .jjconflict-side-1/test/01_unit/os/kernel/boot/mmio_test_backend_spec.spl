use std.spec.*
use os.kernel.boot.mmio.{
    mmio_reset_for_test,
    mmio_read8, mmio_write8,
    mmio_read16, mmio_write16,
    mmio_read32, mmio_write32,
    mmio_read64, mmio_write64
}

describe "MMIO test backend":

    it "reads the latest write without mutating typed array elements":
        mmio_reset_for_test()

        mmio_write8(0x1000, 7u8)
        mmio_write8(0x1000, 0u8)
        expect(mmio_read8(0x1000)).to_equal(0u8)

        mmio_write16(0x2000, 11u16)
        mmio_write16(0x2000, 13u16)
        expect(mmio_read16(0x2000)).to_equal(13u16)

        mmio_write32(0x3000, 17u32)
        mmio_write32(0x3000, 19u32)
        expect(mmio_read32(0x3000)).to_equal(19u32)

        mmio_write64(0x4000, 23u64)
        mmio_write64(0x4000, 29u64)
        expect(mmio_read64(0x4000)).to_equal(29u64)
