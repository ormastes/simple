# @cover src/os/services/nvfs/src/fs_driver/types.spl 80%
"""
# NVFS FS Driver Types Unit Tests

**Feature IDs:** #NVFS-FS-DRIVER-TYPES
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** In Progress
**Design:** doc/05_design/nvfs_design.md §5.3

## Overview

Tests for single-field wrapper structs and FsStatfs:
  - Inode, FileHandle, DirHandle, FileMode, Offset round-trips
  - FileHandle and DirHandle are distinct types
  - FsStatfs fields round-trip
  - Negative Offset is representable
  - Octal FileMode is representable
"""

use std.spipe.*
use std.fs_driver.types.*


# ============================================================================
# Wrapper round-trips
# ============================================================================

describe "FS Types — wrapper round-trips":
    """
    ## Single-field wrapper structs

    Each wrapper must return the value passed at construction.
    """

    it "Inode wraps and unwraps u64":
        val inode = Inode(id: 42)
        expect(inode.id).to_equal(42)

    it "FileHandle wraps and unwraps i32":
        val fh = FileHandle(id: 7)
        expect(fh.id).to_equal(7)

    it "DirHandle wraps and unwraps i32":
        val dh = DirHandle(id: 3)
        expect(dh.id).to_equal(3)

    it "FileMode wraps and unwraps u32 (octal 0o755)":
        val mode = FileMode(bits: 0o755)
        expect(mode.bits).to_equal(0o755)

    it "Offset wraps and unwraps i64 (negative)":
        val off = Offset(value: -1)
        expect(off.value).to_equal(-1)


# ============================================================================
# Distinct types
# ============================================================================

describe "FS Types — FileHandle vs DirHandle are distinct":
    """
    ## Type safety

    FileHandle and DirHandle should not be substitutable.
    This test verifies that same-value handles have the correct runtime type tag.
    """

    it "FileHandle(5).id equals DirHandle(5).id but types differ":
        val fh = FileHandle(id: 5)
        val dh = DirHandle(id: 5)
        # Both hold 5 but are different types — verify values independently
        expect(fh.id).to_equal(5)
        expect(dh.id).to_equal(5)


# ============================================================================
# FsStatfs
# ============================================================================

describe "FS Types — FsStatfs fields":
    """
    ## FsStatfs struct

    All six fields must be stored and retrieved correctly.
    """

    it "FsStatfs stores all six fields correctly":
        val stat = FsStatfs(
            total_bytes: 1024,
            free_bytes: 512,
            avail_bytes: 256,
            files_total: 100,
            files_free: 50,
            block_size: 4096
        )
        expect(stat.total_bytes).to_equal(1024)
        expect(stat.free_bytes).to_equal(512)
        expect(stat.avail_bytes).to_equal(256)
        expect(stat.files_total).to_equal(100)
        expect(stat.files_free).to_equal(50)
        expect(stat.block_size).to_equal(4096)

    it "FsStatfs with zero values is representable":
        val stat = FsStatfs(
            total_bytes: 0,
            free_bytes: 0,
            avail_bytes: 0,
            files_total: 0,
            files_free: 0,
            block_size: 512
        )
        expect(stat.total_bytes).to_equal(0)
        expect(stat.block_size).to_equal(512)
