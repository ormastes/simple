"""
Fork/Exec Structural Specification

Tests the kernel-level exec (syscall 59) dispatch path structurally.
These specs verify:
  - exec rejects invalid arguments (empty path)
  - exec resolves executable bytes from synthetic sources
  - The resolution pipeline returns correct bytes end-to-end

No actual processes are spawned — all tests exercise the structural
contract of the executable resolution path.

Run:
  bin/simple test test/os/kernel/loader/fork_exec_spec.spl
"""

use std.spec
use os.kernel.loader.executable_source.{
    resolve_executable_bytes,
    resolve_executable_bytes_from_path_bytes,
    _set_synthetic_initramfs_for_test,
    _clear_synthetic_initramfs_for_test,
    _clear_synthetic_vfs_for_test
}
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.app_registry.{app_registry_clear, app_registry_register}

extern fn rt_text_to_bytes(s: text) -> [u8]

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn _push_u16_le(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out.push((value & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out

fn _push_u32_le_r(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out.push((value & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out.push(((value >> 16) & 0xFF).to_u8())
    out.push(((value >> 24) & 0xFF).to_u8())
    out

fn _push_u64_le_r(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out = _push_u32_le_r(out, value & 0xFFFFFFFF)
    out = _push_u32_le_r(out, (value >> 32) & 0xFFFFFFFF)
    out

fn _elf_magic_payload() -> [u8]:
    """ELF magic + padding for resolution tests."""
    var buf: [u8] = []
    buf.push(0x7F.to_u8())
    buf.push(0x45.to_u8())
    buf.push(0x4C.to_u8())
    buf.push(0x46.to_u8())
    var i: i64 = 0
    while i < 13:
        buf.push(0.to_u8())
        i = i + 1
    buf

fn _minimal_elf64_x86_64() -> [u8]:
    """Minimal valid ELF64 x86_64: proven pattern from process_image_spec."""
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = _push_u16_le(bytes, 2)
    bytes = _push_u16_le(bytes, 62)
    bytes = _push_u32_le_r(bytes, 1)
    bytes = _push_u64_le_r(bytes, 0x400000)
    bytes = _push_u64_le_r(bytes, 64)
    bytes = _push_u64_le_r(bytes, 0)
    bytes = _push_u32_le_r(bytes, 0)
    bytes = _push_u16_le(bytes, 64)
    bytes = _push_u16_le(bytes, 56)
    bytes = _push_u16_le(bytes, 1)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u32_le_r(bytes, 1)
    bytes = _push_u32_le_r(bytes, 5)
    bytes = _push_u64_le_r(bytes, 0x1000)
    bytes = _push_u64_le_r(bytes, 0x400000)
    bytes = _push_u64_le_r(bytes, 0x400000)
    bytes = _push_u64_le_r(bytes, 4)
    bytes = _push_u64_le_r(bytes, 4)
    bytes = _push_u64_le_r(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes.push(0x90.to_u8())
    bytes.push(0x90.to_u8())
    bytes.push(0x90.to_u8())
    bytes

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "exec — argument validation":
    """Verify exec rejects invalid arguments at the structural level."""

    it "exec rejects empty path with EINVAL":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        val result = resolve_executable_bytes("", Architecture.X86_64)
        expect(result.is_err()).to_equal(true)
        expect(result.err().unwrap().starts_with("EINVAL")).to_equal(true)

    it "exec rejects nonexistent path with ENOENT":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        # Non-absolute path avoids VFS reader (interpreter limitation)
        val result = resolve_executable_bytes("no_such_binary", Architecture.X86_64)
        expect(result.is_err()).to_equal(true)
        expect(result.err().unwrap().starts_with("ENOENT")).to_equal(true)

describe "exec — image replacement structural":
    """Verify exec can load and parse a new image to replace the current one."""

    it "exec resolves synthetic bytes for a replacement image":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()

        val payload = _elf_magic_payload()
        _set_synthetic_initramfs_for_test("/sys/apps/new_image", payload)

        # Step 1: resolve bytes (what exec does internally)
        val bytes_result = resolve_executable_bytes("/sys/apps/new_image", Architecture.X86_64)
        expect(bytes_result.is_ok()).to_equal(true)
        val bytes = bytes_result.unwrap()
        expect(bytes[0]).to_equal(0x7F.to_u8())
        expect(bytes[1]).to_equal(0x45.to_u8())

        _clear_synthetic_initramfs_for_test()

    it "exec resolves path bytes via resolve_executable_bytes_from_path_bytes":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        app_registry_clear()
        app_registry_register("/sys/apps/path_bytes_test", "PBTST.SMF", false)

        val payload = _elf_magic_payload()
        _set_synthetic_initramfs_for_test("/sys/apps/path_bytes_test", payload)

        val path_bytes = rt_text_to_bytes("/sys/apps/path_bytes_test")
        val result = resolve_executable_bytes_from_path_bytes(path_bytes, Architecture.X86_64)
        expect(result.is_ok()).to_equal(true)
        val bytes = result.unwrap()
        expect(bytes[0]).to_equal(0x7F.to_u8())
        expect(bytes[1]).to_equal(0x45.to_u8())

        _clear_synthetic_initramfs_for_test()

describe "fork+exec lifecycle — structural":
    """Verify the complete fork+exec API surface compiles and the pipeline is coherent."""

    it "full lifecycle: resolve -> ELF bytes confirmed":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()

        val elf_data = _minimal_elf64_x86_64()
        _set_synthetic_initramfs_for_test("/sys/apps/lifecycle", elf_data)

        # Parent would fork() (syscall 57) — returns child PID in parent.
        # Child would exec() (syscall 59) — replaces its image.
        # We test the exec resolution part structurally.

        val bytes_result = resolve_executable_bytes("/sys/apps/lifecycle", Architecture.X86_64)
        expect(bytes_result.is_ok()).to_equal(true)
        val raw_bytes = bytes_result.unwrap()

        # Verify resolved bytes are ELF
        expect(raw_bytes[0]).to_equal(0x7F.to_u8())
        expect(raw_bytes[1]).to_equal(0x45.to_u8())
        expect(raw_bytes[2]).to_equal(0x4C.to_u8())
        expect(raw_bytes[3]).to_equal(0x46.to_u8())

        # Verify byte count matches
        expect(raw_bytes.len()).to_equal(elf_data.len())

        _clear_synthetic_initramfs_for_test()
