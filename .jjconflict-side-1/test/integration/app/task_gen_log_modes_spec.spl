use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_task_gen_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/doc/08_tracking/task && cat > " + FIXTURE_DIR + "/doc/08_tracking/task/task_db.sdn <<'EOF'\ntasks |\nTASK-001,core,Sample task,Do the thing,high,complete,true\nTASK-002,core,Next task,Do another thing,low,planned,true\nEOF"
    ])

fn _run_task_gen(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/task_gen/main.spl\" " + joined
    ])

describe "task-gen log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_task_gen(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_task_gen(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"task-gen\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain("\"tasks\":2")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_task_gen(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("Generated doc/08_tracking/task/task.md")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_task_gen(["--log-mode=noisy"])
        expect(code).to_equal(1)
