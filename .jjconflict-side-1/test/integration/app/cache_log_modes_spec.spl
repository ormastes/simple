use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_HOME = "/tmp/simple_cache_log_mode_home"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_HOME + " && mkdir -p " + FIXTURE_HOME + "/.simple/cache && touch " + FIXTURE_HOME + "/.simple/cache/alpha.spk"
    ])

fn _run_cache(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); HOME=" + FIXTURE_HOME + " SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/cache/main.spl\" " + joined
    ])

describe "cache log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_cache(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports info log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_cache(["info", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"info\"")
        expect(out).to_contain("\"exists\":true")
        expect(out).to_contain("\"count\":1")

    it "supports list log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_cache(["list", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"list\"")
        expect(out).to_contain("\"items\":[\"alpha.spk\"]")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_cache(["info", "--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Cache directory:")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_cache(["info", "--log-mode=noisy"])
        expect(code).to_equal(1)
