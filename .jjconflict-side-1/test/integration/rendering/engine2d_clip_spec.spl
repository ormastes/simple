# @tag: rendering, engine2d, clipping
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_cpu.spl 30%

use std.spec.{describe, context, it, expect}
use std.gpu.engine2d.engine.{Engine2D}
use std.gpu.engine2d.color.{rgb, color_r, color_g, color_b}

describe "Engine2D Clipping":

    context "cpu backend":

        it "set_clip restricts draw_rect_filled":
            var engine = Engine2D.create_with_backend(10, 10, "cpu")
            engine.clear(rgb(0, 0, 0))
            engine.set_clip(5, 5, 5, 5)
            engine.draw_rect_filled(0, 0, 10, 10, rgb(255, 0, 0))
            val pixels = engine.read_pixels()
            val outside = pixels[2 * 10 + 2]
            expect(color_r(outside)).to_equal(0)
            val inside = pixels[7 * 10 + 7]
            expect(color_r(inside)).to_equal(255)
            engine.shutdown()

        it "clear_clip restores full drawing area":
            var engine = Engine2D.create_with_backend(10, 10, "cpu")
            engine.clear(rgb(0, 0, 0))
            engine.set_clip(5, 5, 5, 5)
            engine.clear_clip()
            engine.draw_rect_filled(0, 0, 10, 10, rgb(0, 255, 0))
            val pixels = engine.read_pixels()
            val p = pixels[2 * 10 + 2]
            expect(color_g(p)).to_equal(255)
            engine.shutdown()

        it "clip does not affect clear":
            var engine = Engine2D.create_with_backend(10, 10, "cpu")
            engine.set_clip(5, 5, 5, 5)
            engine.clear(rgb(0, 0, 255))
            val pixels = engine.read_pixels()
            val p = pixels[2 * 10 + 2]
            expect(color_b(p)).to_equal(255)
            engine.shutdown()
