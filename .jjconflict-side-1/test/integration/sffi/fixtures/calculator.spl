# Canonical test library for SFFI round-trip testing
# Used by Direction A tests to verify Simple -> C/C++ interop

@export("C")
@repr("C")
class Calculator:
    accumulator: i64

    static fn create() -> Calculator:
        Calculator(accumulator: 0)

    fn get_accumulator() -> i64:
        self.accumulator

    me add(value: i64):
        self.accumulator = self.accumulator + value

    me multiply(value: i64):
        self.accumulator = self.accumulator * value

@export("C")
fn calculator_square(x: i64) -> i64:
    x * x

@export("C")
fn calculator_add(a: i64, b: i64) -> i64:
    a + b
