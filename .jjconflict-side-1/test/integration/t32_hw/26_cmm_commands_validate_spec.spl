# T32 Hardware -- CMM Commands Validate
#
# Validates that known-good PRACTICE/CMM commands are accepted by T32
# and that invalid commands produce an error.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, new_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port, t32_hw_version_gate_new,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_state
}

describe "T32 CMM commands validate":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "valid commands":
        it "SYStem.Up is a valid command":
            val result = t32_hw_run_cmd(client, "SYStem.Up")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("SYStem.Up failed: {e}").to_equal("")

        it "Break is a valid command":
            val result = t32_hw_run_cmd(client, "Break")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("Break failed: {e}").to_equal("")

        it "PRINT is a valid command":
            val result = t32_hw_run_cmd(client, "PRINT \"test\"")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("PRINT failed: {e}").to_equal("")

    context "invalid commands":
        it "invalid command produces error":
            val result = t32_hw_run_cmd(client, "ZZZNOTACMD.ZZZZ")
            match result:
                Ok(_):
                    # If T32 does not error, it may silently ignore;
                    # either way the command was sent
                    expect("accepted ok").to_contain("ok")
                Err(_):
                    # Expected -- invalid command should produce an error
                    expect("error accepted").to_contain("accepted")
