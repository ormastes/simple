# Should reject/execute correctly: calling a trait DEFAULT method that a struct
# inherits WITHOUT overriding it in its `impl Trait for Struct` block.
# Actually happens (deployed binary): SEGMENTATION FAULT (exit=139).
#
# Repro:
#   bin/release/x86_64-unknown-linux-gnu/simple run <this file> ; echo "exit=$?"
# Observed: prints the first line's output ("Yo") then SEGFAULTs computing the
# *second* call, which resolves to the inherited (non-overridden) default
# `greet_formal()` method.
trait Greetable:
    fn greet_formal() -> text:
        "Good day"
    fn greet_casual() -> text:
        "Hey"

struct Person:
    name: text

# Overrides ONLY greet_casual -- greet_formal is inherited from the trait
# default, unmodified.
impl Greetable for Person:
    fn greet_casual() -> text:
        "Yo"

fn main():
    val p = Person(name: "Alice")
    print(p.greet_casual())   # prints "Yo" fine
    print(p.greet_formal())   # SEGFAULT calling the inherited default
