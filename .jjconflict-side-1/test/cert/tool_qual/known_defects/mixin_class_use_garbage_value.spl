# Should happen: `class X: use SomeMixin` injects the mixin's field(s) and
# method(s) into X; calling the injected method / reading the injected field
# returns the constructed value.
# Actually happens (deployed binary): silently accepted (exit=0) but prints
# GARBAGE -- a raw heap-value tag for the method-call result, and 0.0 for the
# plain injected field read.
#
# Repro:
#   bin/release/x86_64-unknown-linux-gnu/simple run <this file> ; echo "exit=$?"
# Observed output (exit=0):
#   <value:0x49e4405ea06>
#   0.00000000000000000
# Expected (hand-computed): add_score(5) = score(10)+5 = 15; name = "Alice".
mixin Scorable:
    score: i64

    fn add_score(n: i64) -> i64:
        return self.score + n

class Player:
    use Scorable
    name: text

fn main():
    val p = Player(score: 10, name: "Alice")
    print(p.add_score(5))   # expected 15, ACTUAL: garbage heap-value tag
    print(p.name)            # expected Alice, ACTUAL: 0.0
