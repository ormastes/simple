# Should happen: a closure LEXICALLY NESTED inside another closure's body can
# READ a variable captured by the enclosing closure (language.md "Runtime
# Limitations: Nested closure capture - can READ outer vars").
# Actually happens (deployed binary): SILENT WRONG VALUE (exit=0), no error --
# the nested closure reads 0 for the outer-captured variable instead of its
# real value.
#
# Repro:
#   bin/release/x86_64-unknown-linux-gnu/simple run <this file> ; echo "exit=$?"
# Observed output (exit=0): 0
# Expected (hand-computed): step(y)=y+base; combo(x)=step(x)*mul =>
#   combo(2) = (2+10)*3 = 36.
fn main():
    val base = 10
    val mul = 3
    val combo = \x:
        val step = \y: y + base   # nested closure reading outer-of-outer `base`
        step(x) * mul
    print(combo(2))   # expected 36, ACTUAL: 0
