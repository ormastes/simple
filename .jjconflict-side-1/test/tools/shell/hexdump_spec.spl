# Test: hexdump tool
# Feature: TOOL-HEXDUMP - Display file in hex
# @cover tools/shell/hexdump/hexdump_tool.spl

describe "hexdump tool":
    context "hex formatting":
        it "converts byte to hex digits":
            val byte_val = 0xFF
            val hi = (byte_val >> 4) & 0xF
            val lo = byte_val & 0xF
            expect(hi).to_equal(15)
            expect(lo).to_equal(15)

        it "formats offset as 8 digits":
            val offset: u64 = 0
            # Offset 0 should produce "00000000"
            expect(offset).to_equal(0)

    context "ascii display":
        it "shows printable characters":
            val code = 65  # 'A'
            val is_printable = code >= 32 and code < 127
            expect(is_printable).to_equal(true)

        it "replaces non-printable with dot":
            val code = 0
            val is_printable = code >= 32 and code < 127
            expect(is_printable).to_equal(false)
