# @cover src/lib/nogc_sync_mut/database/sdn_table.spl 60%
"""
# Database SDN Table Import/Export

## Overview

Simple DB supports reading and writing table data as SDN named tables.
This spec uses a small local model to validate the parser-safe behavior of
importing and exporting SDN tables.

## SDN Format
```sdn
users |id, name, active|
    1, "Alice", true
    2, "Bob", false
```
"""

use std.spec

class SdnTable:
    name: text
    columns: [text]
    rows: [Dict<text, text>]

    static fn new(name: text, columns: [text]) -> SdnTable:
        SdnTable(name: name, columns: columns, rows: [])

    static fn empty_row() -> Dict<text, text>:
        {"__init__": ""}

    me add_row(row: Dict<text, text>):
        self.rows.push(row)

    fn quote_if_needed(value: text) -> text:
        if value.contains(","):
            '"' + value + '"'
        else:
            value

    fn row_value(row: Dict<text, text>, column: text) -> text:
        if row.has(column):
            row[column]
        else:
            ""

    fn to_sdn() -> text:
        var result = self.name + " |"
        result = result + self.columns.join(", ")
        result = result + "|\n"

        var ri: i64 = 0
        while ri < self.rows.len():
            var parts: [text] = []
            var ci: i64 = 0
            while ci < self.columns.len():
                val column = self.columns[ci]
                val raw = self.row_value(self.rows[ri], column)
                parts.push(self.quote_if_needed(raw))
                ci = ci + 1
            result = result + "    " + parts.join(", ") + "\n"
            ri = ri + 1

        result

fn strip_quotes(value: text) -> text:
    if value.len() >= 2 and value.starts_with('"') and value.ends_with('"'):
        value[1:(value.len() - 1)]
    else:
        value

fn split_sdn_row(line: text) -> [text]:
    var parts: [text] = []
    var current = ""
    var in_quotes = false
    var i: i64 = 0

    while i < line.len():
        val ch = line[i]
        if ch == '"':
            in_quotes = not in_quotes
            current = current + ch
        elif ch == ',' and not in_quotes:
            parts.push(current)
            current = ""
        else:
            current = current + ch
        i = i + 1

    if current != "" or parts.len() > 0:
        parts.push(current)

    parts

fn parse_sdn_table(content: text) -> SdnTable?:
    var lines = content.split("\n")
    if lines.len() == 0:
        return nil

    var header_idx: i64 = -1
    var name = ""
    var columns: [text] = []

    var i: i64 = 0
    while i < lines.len():
        val trimmed = lines[i].trim()
        if trimmed.contains("|") and not trimmed.starts_with("#"):
            val parts = trimmed.split("|")
            if parts.len() >= 3:
                name = parts[0].trim()
                columns = parts[1].split(",").map(\c: c.trim())
                header_idx = i
                i = lines.len()
            else:
                i = i + 1
        else:
            i = i + 1

    if header_idx < 0:
        return nil

    var table = SdnTable.new(name, columns)
    var row_idx = header_idx + 1
    while row_idx < lines.len():
        val line = lines[row_idx].trim()
        row_idx = row_idx + 1
        if line == "" or line.starts_with("#"):
            continue

        val parts = split_sdn_row(line)
        if parts.len() != columns.len():
            continue

        var row = SdnTable.empty_row()
        var j: i64 = 0
        while j < columns.len():
            row[columns[j]] = strip_quotes(parts[j].trim())
            j = j + 1
        table.add_row(row)

    Some(table)

fn same_texts(left: [text], right: [text]) -> bool:
    if left.len() != right.len():
        return false

    var i: i64 = 0
    while i < left.len():
        if left[i] != right[i]:
            return false
        i = i + 1

    true

describe "Database SDN table import/export":
    """Tests for SDN table import and export functionality."""

    it "exports users table to SDN":
        val table = SdnTable.new("users", ["id", "name", "active"])
        var row = SdnTable.empty_row()
        row["id"] = "1"
        row["name"] = "Alice"
        row["active"] = "true"
        table.add_row(row)

        val exported = table.to_sdn()
        expect(exported).to_contain("users |id, name, active|")
        expect(exported).to_contain("Alice")
        expect(exported).to_contain("true")

    it "imports users table from SDN":
        val content = "users |id, name, active|\n    1, \"Alice\", true\n    2, \"Bob\", false"
        val table = parse_sdn_table(content)
        match table:
            Some(resolved):
                expect(resolved.name).to_equal("users")
                expect(resolved.columns.len()).to_equal(3)
                expect(resolved.rows.len()).to_equal(2)
            nil:
                expect(false).to_equal(true)

    it "round-trips quoted values with commas":
        val table = SdnTable.new("notes", ["id", "description"])
        var row = SdnTable.empty_row()
        row["id"] = "1"
        row["description"] = "hello, world"
        table.add_row(row)

        val exported = table.to_sdn()
        expect(exported).to_contain('"hello, world"')

        val parsed = parse_sdn_table(exported)
        match parsed:
            Some(resolved):
                expect(resolved.rows.len()).to_equal(1)
            nil:
                expect(false).to_equal(true)
