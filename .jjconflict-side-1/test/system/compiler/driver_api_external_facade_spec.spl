# @cover src/compiler/80.driver/driver_api.spl 80%
# Driver API External Facade - End-to-End Tests
#
# Verifies the lightweight external `compiler.driver.driver_api` facade:
# - direct imports do not hang
# - single-file helper wrappers produce artifacts or success results
# - multi-source native helper fails fast instead of hanging

use std.spec

use compiler.driver.driver_api.{
    compile_to_smf, check_file, parse_sdn_file, aot_c_file,
    aot_llvm_file, aot_llvm_native_file, aot_native_file_with_backend,
    aot_cuda_file, aot_vhdl_file, aot_native_project_with_backend,
    compile_file
}

val NL = "\n"

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

fn write_file(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn delete_file(path: text) -> bool:
    rt_file_delete(path)

describe "Driver API External Facade":

    it "compile_to_smf writes an smf artifact for a direct external caller":
        val src_path = "/tmp/sml_driver_api_compile_to_smf.spl"
        val out_path = "/tmp/sml_driver_api_compile_to_smf.smf"
        delete_file(out_path)
        write_file(src_path, "fn main(): 7")

        val result = compile_to_smf(src_path, out_path)

        expect(result.is_ok()).to_equal(true)
        expect(rt_file_exists(out_path)).to_equal(true)

        delete_file(src_path)
        delete_file(out_path)

    it "check_file returns success for a valid source file":
        val src_path = "/tmp/sml_driver_api_check_ok.spl"
        write_file(src_path, "fn main(): 1 + 2")

        val result = check_file(src_path)

        expect(result.is_success()).to_equal(true)
        delete_file(src_path)

    it "parse_sdn_file returns success for a readable sdn file":
        val sdn_path = "/tmp/sml_driver_api_parse_ok.sdn"
        val content = "root:" + NL + "  name: \"driver-api\""
        write_file(sdn_path, content)

        val result = parse_sdn_file(sdn_path)

        expect(result.is_success()).to_equal(true)
        delete_file(sdn_path)

    it "aot_c_file writes an empty c backend artifact file for a direct external caller":
        val src_path = "/tmp/sml_driver_api_aot_c.spl"
        val out_path = "/tmp/sml_driver_api_aot_c.cpp"
        delete_file(out_path)
        write_file(src_path, "fn main(): 9")

        val result = aot_c_file(src_path, out_path)

        expect(result.is_success()).to_equal(true)
        expect(rt_file_exists(out_path)).to_equal(true)
        expect(rt_file_read_text(out_path)).to_equal("")

        delete_file(src_path)
        delete_file(out_path)

    it "aot_vhdl_file writes a VHDL artifact for a direct external caller":
        val src_path = "/tmp/sml_driver_api_aot_vhdl.spl"
        val out_path = "/tmp/sml_driver_api_aot_vhdl.vhd"
        delete_file(out_path)
        write_file(src_path, "fn add(a: i32, b: i32) -> i32:\n    a + b")

        val result = aot_vhdl_file(src_path, out_path)

        expect(result.is_success()).to_equal(true)
        expect(rt_file_exists(out_path)).to_equal(true)
        expect(rt_file_read_text(out_path)).to_contain("entity add is")

        delete_file(src_path)
        delete_file(out_path)

    it "aot_native_project_with_backend fails fast with a clear runtime error":
        val src_path = "/tmp/sml_driver_api_project_fail.spl"
        val out_path = "/tmp/sml_driver_api_project_fail.bin"
        write_file(src_path, "fn main(): 11")

        val result = aot_native_project_with_backend(["/tmp"], src_path, out_path, "llvm-lib", false)

        expect(result.is_success()).to_equal(false)
        expect(result.get_errors().join("\n")).to_contain("not supported")

        delete_file(src_path)
        delete_file(out_path)

    it "backend helper symbols import cleanly for a direct external caller":
        # Import-only coverage for lightweight facade symbols that should not hang.
        val _llvm_emit = aot_llvm_file
        val _llvm_native = aot_llvm_native_file
        val _native_backend = aot_native_file_with_backend
        val _cuda_emit = aot_cuda_file
        val _vhdl_emit = aot_vhdl_file
        expect(true).to_equal(true)

    it "grouped compile helper imports resolve cleanly for a direct external caller":
        val _compile_file = compile_file
        val _compile_to_smf = compile_to_smf
        val _check_file = check_file
        val _parse_sdn_file = parse_sdn_file
        val _aot_c_file = aot_c_file
        expect(true).to_equal(true)

    it "grouped backend helper imports resolve cleanly for a direct external caller":
        val _llvm_emit2 = aot_llvm_file
        val _llvm_native2 = aot_llvm_native_file
        val _native_backend2 = aot_native_file_with_backend
        val _cuda_emit2 = aot_cuda_file
        val _vhdl_emit2 = aot_vhdl_file
        expect(true).to_equal(true)
