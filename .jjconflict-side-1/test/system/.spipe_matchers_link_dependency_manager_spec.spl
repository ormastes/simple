# @cover src/compiler/70.backend/linker/link.spl 80%
# System tests for Link Dependency Manager
# Tests the check-links CLI command and link dependency resolution.
#
# NOTE: These tests validate the logic via helper functions.
# The actual `check-links` CLI command requires a rebuilt binary.

# ============================================================================
# Module-level helpers (replicate platform_defaults + merge logic)
# ============================================================================

fn helper_platform_libs(os: text) -> [text]:
    if os == "linux":
        return ["c", "pthread", "dl", "m"]
    elif os == "macos":
        return ["c", "pthread", "m", "System"]
    elif os == "freebsd":
        return ["c", "pthread", "m"]
    elif os == "windows":
        return ["kernel32", "user32"]
    []

fn helper_merge(defaults: [text], extras: [text]) -> [text]:
    var result: [text] = []
    for item in defaults:
        result.push(item)
    for item in extras:
        val trimmed = item.trim()
        if trimmed != "":
            result.push(trimmed)
    result

fn helper_resolve(os: text, no_default: bool, project_libs: [text], os_libs: [text], arch_libs: [text]) -> [text]:
    var libs: [text] = []
    if not no_default:
        libs = helper_platform_libs(os)
    libs = helper_merge(libs, project_libs)
    libs = helper_merge(libs, os_libs)
    libs = helper_merge(libs, arch_libs)
    libs

fn helper_format_check_line(lib: text, found: bool) -> text:
    if found:
        return "[OK]   {lib}"
    "[MISS] {lib}"

# ============================================================================
# Specs
# ============================================================================

describe "link_dependency_manager":

    describe "check-links output format":
        it "found_lib_shows_ok: found library shows OK":
            val line = helper_format_check_line("c", true)
            expect (line).starts_with("[OK]")
            expect (line).contains("c")

        it "missing_lib_shows_miss: missing library shows MISS":
            val line = helper_format_check_line("nonexistent", false)
            expect (line).starts_with("[MISS]")
            expect (line).contains("nonexistent")

    describe "full resolution pipeline":
        it "linux_no_overrides: Linux with no SDN gives 4 defaults":
            val libs = helper_resolve("linux", false, [], [], [])
            expect libs.len() == 4
            expect libs[0] == "c"

        it "linux_with_project_lib: project libs appended to defaults":
            val libs = helper_resolve("linux", false, ["ssl"], [], [])
            expect libs.len() == 5
            expect libs[4] == "ssl"

        it "linux_with_os_override: OS-specific libs appended":
            val libs = helper_resolve("linux", false, [], ["rt"], [])
            expect libs.len() == 5
            expect libs[4] == "rt"

        it "linux_riscv64_full_stack: all layers merge correctly":
            val libs = helper_resolve("linux", false, ["project_lib"], ["rt"], ["atomic"])
            expect libs.len() == 7
            expect libs[0] == "c"
            expect libs[4] == "project_lib"
            expect libs[5] == "rt"
            expect libs[6] == "atomic"

        it "no_default_libs_strips_defaults: no-default-libs gives only extras":
            val libs = helper_resolve("linux", true, ["custom"], [], [])
            expect libs.len() == 1
            expect libs[0] == "custom"

        it "windows_defaults: Windows gets kernel32 and user32":
            val libs = helper_resolve("windows", false, [], [], [])
            expect libs.len() == 2
            expect libs[0] == "kernel32"

        it "macos_defaults: macOS includes System library":
            val libs = helper_resolve("macos", false, [], [], [])
            expect libs.len() == 4
            expect libs[3] == "System"

    describe "missing library detection":
        it "all_found_returns_zero: all found means success":
            var all_found = true
            val libs = ["c", "pthread"]
            for lib in libs:
                val found = lib == "c" or lib == "pthread"
                if not found:
                    all_found = false
            expect all_found == true

        it "one_missing_returns_nonzero: any missing means failure":
            var all_found = true
            val libs = ["c", "nonexistent_lib"]
            for lib in libs:
                val found = lib == "c"
                if not found:
                    all_found = false
            expect all_found == false