use std.io_runtime
use std.spec
use std.nogc_sync_mut.engine.physics.graph.island_manager.{IslandManager}

# ---------------------------------------------------------------------------
# Helpers — all looping logic lives outside it blocks
# ---------------------------------------------------------------------------

fn make_manager() -> IslandManager:
    IslandManager.create(4, 0.01, 0.5)

fn sleep_body(mgr: IslandManager, idx: i64) -> IslandManager:
    var m = mgr
    m.update_sleep(idx, 0.001, 0.6)
    m

fn union_bodies(mgr: IslandManager, a: i64, b: i64) -> IslandManager:
    var m = mgr
    m.union(a, b)
    m

fn sleep_two(mgr: IslandManager, a: i64, b: i64) -> IslandManager:
    var m = mgr
    m.update_sleep(a, 0.001, 0.6)
    m.update_sleep(b, 0.001, 0.6)
    m

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "Physics2 IslandManager sleeping":
    it "bodies start awake":
        val m = make_manager()
        expect(m.is_island_sleeping(0)).to_equal(false)

    it "low KE puts island to sleep":
        var m = make_manager()
        m.update_sleep(0, 0.001, 0.6)
        expect(m.is_island_sleeping(0)).to_equal(true)

    it "high KE wakes island":
        var m = make_manager()
        m.update_sleep(0, 0.001, 0.6)
        m.update_sleep(0, 1.0, 0.1)
        expect(m.is_island_sleeping(0)).to_equal(false)

    it "union merges islands":
        var m = make_manager()
        m.union(0, 1)
        val r0 = m.find(0)
        val r1 = m.find(1)
        expect(r0).to_equal(r1)

    it "wake propagates to merged island":
        var m = make_manager()
        m.union(0, 1)
        m.update_sleep(0, 0.001, 0.6)
        m.update_sleep(1, 0.001, 0.6)
        m.wake_island(1)
        expect(m.is_island_sleeping(0)).to_equal(false)
