# ==========================================================================
# REQ-ENG-001: Scene Graph
# ==========================================================================

describe "REQ-ENG-001 Scene Graph":
    it "creates nodes and establishes parent-child hierarchy":
        var store = NodeStore.new()
        val root = store.create_node("root")
        val child = store.create_node("child")
        store.set_parent(child, root)
        val children = store.get_children(root)
        expect(children.len()).to_equal(1)

    it "computes world transform through parent chain":
        var store = NodeStore.new()
        val parent = store.create_node("parent")
        val child = store.create_node("child")
        store.set_parent(child, parent)
        store.set_position(parent, Vec2(x: 100.0, y: 50.0))
        store.set_position(child, Vec2(x: 10.0, y: 5.0))
        val world_tf = get_world_transform(store, child)
        val wx = world_tf.position.x * 10.0
        val wy = world_tf.position.y * 10.0
        expect(wx).to_be_greater_than(1099.0)
        expect(wx).to_be_less_than(1101.0)
        expect(wy).to_be_greater_than(549.0)
        expect(wy).to_be_less_than(551.0)

# ==========================================================================
# REQ-ENG-002: Component System
# ==========================================================================

describe "REQ-ENG-002 Component System":
    it "attaches and retrieves camera component":
        var store = NodeStore.new()
        val node = store.create_node("cam_node")
        var registry = ComponentRegistry.new()
        val cam = CameraData.create(800.0, 600.0)
        registry.attach_camera(node, cam)
        val retrieved = registry.get_camera(node)
        if val Some(c) = retrieved:
            val vw = c.viewport_width * 10.0
            expect(vw).to_be_greater_than(7999.0)
            expect(vw).to_be_less_than(8001.0)
        else:
            expect("camera not found").to_equal("found")

# ==========================================================================
# REQ-ENG-003: Software Renderer
# ==========================================================================

describe "REQ-ENG-003 Software Renderer":
    it "renders clear and rect commands to pixel buffer":
        var renderer = SoftwareRenderer.create(4, 3)
        var buf = RenderCommandBuffer.create()
        buf.push_clear(EngineColor.black())
        buf.push_rect(Rect2(x: 0.0, y: 0.0, width: 2.0, height: 2.0), EngineColor.red(), ZIndex(value: 0))
        renderer.render_frame(buf)
        val pixels = renderer.get_pixels()
        expect(pixels.len()).to_be_greater_than(0)

# ==========================================================================
# REQ-ENG-004: Physics (Pure Simple)
# ==========================================================================

describe "REQ-ENG-004 Pure Simple Physics":
    it "dynamic body falls under gravity after step":
        val config = default_physics_config()
        var world = PhysicsWorld2D.create(config)
        val node = NodeId(raw: RawHandle.new(0, 1))
        world.add_dynamic_body(node, 0.0, 10.0)
        world.add_circle_collider(node, 0.5)
        # Step for 100ms (should have several fixed steps)
        world.step(Seconds(value: 0.1))
        val pos = world.get_position(node)
        # Y should decrease (gravity is -9.81)
        expect(pos.y).to_be_less_than(10.0)
        world.destroy()

    it "circle-circle collision detection works":
        val contact = collide_circle_circle(
            Vec2(x: 0.0, y: 0.0), 1.0,
            Vec2(x: 1.5, y: 0.0), 1.0
        )
        if val Some(c) = contact:
            val pen = c.penetration * 100.0
            expect(pen).to_be_greater_than(49.0)
            expect(pen).to_be_less_than(51.0)
        else:
            expect("no contact").to_equal("contact found")

    it "non-overlapping circles return nil":
        val contact = collide_circle_circle(
            Vec2(x: 0.0, y: 0.0), 1.0,
            Vec2(x: 5.0, y: 0.0), 1.0
        )
        expect(contact).to_be_nil

    it "impulse changes dynamic body velocity":
        val config = default_physics_config()
        var world = PhysicsWorld2D.create(config)
        val node = NodeId(raw: RawHandle.new(0, 1))
        world.add_dynamic_body(node, 0.0, 0.0)
        world.apply_impulse(node, Vec2(x: 10.0, y: 0.0))
        val vel = world.get_velocity(node)
        expect(vel.x).to_be_greater_than(0.0)
        world.destroy()

# ==========================================================================
# REQ-ENG-005: Input System
# ==========================================================================

describe "REQ-ENG-005 Input System":
    it "input manager binds and queries actions without FFI":
        var mgr = InputManager.create(0)
        mgr.bind_key_action("jump", KeyCode(value: 32))
        # Without polling, action should not be pressed
        expect(mgr.is_action_pressed("jump")).to_equal(false)
        expect(mgr.get_action_strength("jump")).to_equal(0.0)
        mgr.destroy()

# ==========================================================================
# REQ-ENG-007: Resource Management
# ==========================================================================

describe "REQ-ENG-007 Resource Management":
    it "texture store adds and retrieves textures by handle":
        var ts = TextureStore.new()
        val tex = Texture.create(32, 32)
        val id = ts.add(tex)
        val retrieved = ts.get(id)
        if val Some(t) = retrieved:
            expect(t.width).to_equal(32)
            expect(t.height).to_equal(32)
        else:
            expect("texture not found").to_equal("found")

# ==========================================================================
# REQ-ENG-009: Signal/Event System
# ==========================================================================

describe "REQ-ENG-009 Signal System":
    it "signal emits and connections receive events":
        var sig = Signal(name: "test", connections: [], next_id: 0, enabled: true)
        var received = ""
        fn on_receive(data: text):
            received = data
        sig.connect(on_receive)
        sig.emit("hello")
        expect(received).to_equal("hello")

    it "event bus dispatches to named signals":
        var bus = EventBus(signals: {})
        bus.register("on_hit")
        var hit_data = ""
        fn on_hit(data: text):
            hit_data = data
        bus.connect("on_hit", on_hit)
        bus.emit("on_hit", "damage:10")
        expect(hit_data).to_equal("damage:10")

# ==========================================================================
# REQ-ENG-010: Texture Atlas
# ==========================================================================

describe "REQ-ENG-010 Texture Atlas":
    it "atlas packs regions and retrieves UV coordinates":
        var atlas = TextureAtlas.create(256, 256)
        val packed = atlas.pack("sprite_a", 32, 32)
        expect(packed).to_equal(true)
        val region = atlas.get_region("sprite_a")
        if val Some(r) = region:
            expect(r.pixel_width).to_equal(32)
            expect(r.pixel_height).to_equal(32)
        else:
            expect("region not found").to_equal("found")

# ==========================================================================
# REQ-ENG-011: Animated Sprites
# ==========================================================================

describe "REQ-ENG-011 Animated Sprites":
    it "sprite sheet calculates correct frame rects":
        val sheet = SpriteSheet.create(TextureStore.new().add(Texture.create(128, 128)), 32, 32)
        val rect = sheet.frame_rect(0)
        expect(rect.x).to_equal(0.0)
        expect(rect.y).to_equal(0.0)
        val rect1 = sheet.frame_rect(1)
        expect(rect1.x).to_equal(32.0)

# ==========================================================================
# REQ-ENG-012: TileMap
# ==========================================================================

describe "REQ-ENG-012 TileMap":
    it "tilemap set/get tile round-trips correctly":
        val tid = TextureStore.new().add(Texture.create(64, 64))
        var tm = TileMapData.create(tid, 16.0, 16.0, 4, 4)
        tm = tm.set_tile(0, 0, 5)
        val got = tm.get_tile(0, 0)
        expect(got).to_equal(5)

    it "world_to_tile converts coordinates":
        val tid = TextureStore.new().add(Texture.create(64, 64))
        val tm = TileMapData.create(tid, 16.0, 16.0, 10, 10)
        val tile = tm.world_to_tile(Vec2(x: 24.0, y: 8.0))
        expect(tile.tx).to_equal(1)
        expect(tile.ty).to_equal(0)

# ==========================================================================
# REQ-ENG-013: Camera2D
# ==========================================================================

describe "REQ-ENG-013 Camera2D":
    it "world_to_screen maps camera center to viewport center":
        val cam = CameraData.create(800.0, 600.0)
        val screen = cam.world_to_screen(Vec2(x: 50.0, y: 30.0), Vec2(x: 50.0, y: 30.0))
        val sx = screen.x * 10.0
        val sy = screen.y * 10.0
        expect(sx).to_be_greater_than(3999.0)
        expect(sx).to_be_less_than(4001.0)
        expect(sy).to_be_greater_than(2999.0)
        expect(sy).to_be_less_than(3001.0)

# ==========================================================================
# REQ-ENG-014: Vector Graphics
# ==========================================================================

describe "REQ-ENG-014 Vector Graphics":
    it "vector renderer emits render commands":
        val vr = VectorRenderer.create()
        var buf = RenderCommandBuffer.create()
        vr.fill_rect(buf, Rect2(x: 0.0, y: 0.0, width: 100.0, height: 50.0), EngineColor.blue(), ZIndex(value: 0))
        vr.fill_circle(buf, 50.0, 50.0, 25.0, EngineColor.red(), ZIndex(value: 1))
        expect(buf.len()).to_equal(2)

# ==========================================================================
# Integration: Full Pipeline (scene → physics → render)
# ==========================================================================

describe "Integration: Scene + Physics + Render Pipeline":
    it "creates scene with physics body and renders frame":
        # Scene
        var store = NodeStore.new()
        val player = store.create_node("player")
        store.set_position(player, Vec2(x: 100.0, y: 200.0))

        # Physics
        val config = default_physics_config()
        var world = PhysicsWorld2D.create(config)
        world.add_dynamic_body(player, 100.0, 200.0)
        world.add_box_collider(player, 0.5, 0.5)

        # Step physics
        world.step(Seconds(value: 0.016666))

        # Sync physics to scene
        val transforms = world.get_all_dynamic_transforms()
        expect(transforms.len()).to_equal(1)

        # Render
        var renderer = SoftwareRenderer.create(320, 240)
        var buf = RenderCommandBuffer.create()
        buf.push_clear(EngineColor.black())
        buf.push_rect(Rect2(x: 98.0, y: 198.0, width: 4.0, height: 4.0), EngineColor.green(), ZIndex(value: 1))
        renderer.render_frame(buf)
        val pixels = renderer.get_pixels()
        expect(pixels.len()).to_be_greater_than(0)

        world.destroy()

    it "clock produces frame timing for game loop":
        var clock = Clock.create(Seconds(value: 0.016666))
        val f1 = clock.tick(1000000000)
        val f2 = clock.tick(1050000000)
        val steps = clock.consume_fixed_steps()
        expect(steps).to_be_greater_than(0)
        val alpha = clock.get_interpolation_alpha()
        expect(alpha).to_be_greater_than(-0.01)
        expect(alpha).to_be_less_than(1.01)
