# IPC Port QEMU Tests — Port Creation and Connection
#
# @tag: os,qemu,ipc

use os.qemu_runner.{get_target, build_qemu_command}
use os.kernel.arch.arch_context.{Architecture}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 20000
val QEMU_CAPTURE_SECONDS: text = "5s"

var g_arm64_output: text = ""
var g_x86_64_output: text = ""
var g_x86_32_output: text = ""
var g_riscv32_output: text = ""
var g_riscv64_output: text = ""

fn _can_run(arch: Architecture) -> bool:
    val target = get_target(arch)
    val qemu_check = rt_process_run_timeout("which", [target.qemu_system], 5000)
    if qemu_check[2] != 0:
        print "SKIP: {target.qemu_system} not found"
        return false
    if not rt_file_exists(target.output):
        print "SKIP: Kernel not built: {target.output}"
        return false
    true

fn _run_qemu(arch: Architecture) -> text:
    val target = get_target(arch)
    val cmd_parts = build_qemu_command(target)
    val qemu_bin = cmd_parts[0]
    var args: [text] = []
    for i in 1..cmd_parts.len():
        args.push(cmd_parts[i])
    var timeout_args: [text] = [QEMU_CAPTURE_SECONDS, qemu_bin]
    for arg in args:
        timeout_args.push(arg)
    val result = rt_process_run_timeout("timeout", timeout_args, TIMEOUT_MS)
    result[0] + result[1]

fn _run_qemu_cached(arch: Architecture) -> text:
    if arch == Architecture.Arm64:
        if g_arm64_output == "":
            g_arm64_output = _run_qemu(arch)
        return g_arm64_output
    if arch == Architecture.X86_64:
        if g_x86_64_output == "":
            g_x86_64_output = _run_qemu(arch)
        return g_x86_64_output
    if arch == Architecture.X86:
        if g_x86_32_output == "":
            g_x86_32_output = _run_qemu(arch)
        return g_x86_32_output
    if arch == Architecture.Riscv32:
        if g_riscv32_output == "":
            g_riscv32_output = _run_qemu(arch)
        return g_riscv32_output
    if arch == Architecture.Riscv64:
        if g_riscv64_output == "":
            g_riscv64_output = _run_qemu(arch)
        return g_riscv64_output
    _run_qemu(arch)

describe "IPC Port ARM64":
    slow_it "IPC sender task created":
        if _can_run(Architecture.Arm64):
            val output = _run_qemu_cached(Architecture.Arm64)
            expect(output).to_contain("[TASK]")

    slow_it "IPC receiver task created":
        if _can_run(Architecture.Arm64):
            val output = _run_qemu_cached(Architecture.Arm64)
            expect(output).to_contain("ipc_receiver")

describe "IPC Port x86_64":
    slow_it "IPC sender task created":
        if _can_run(Architecture.X86_64):
            val output = _run_qemu_cached(Architecture.X86_64)
