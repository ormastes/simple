# @cover src/app/ui.browser/backend.spl 60%
# @cover src/app/ui.browser/app.spl 60%
# @gui: headless

# @tag:system
"""
# Browser Engine — Open & Snapshot System Spec

**Feature ID:** #UI-BROWSER-001
**Category:** UI / Browser
**Status:** In Progress

System-level test for the in-process Simple browser engine. Validates:

1. `BrowserApp.run_once(snapshot_path)` produces a P3 PPM file at the
   requested path with the expected 1280x720 header.
2. The framebuffer contains at least one non-background pixel after
   rendering a non-empty fixture (i.e., the paint pipeline actually wrote
   something).
3. Optional `--open` arm: when `SIMPLE_GUI_TEST=1` is set, the test will
   call `run_browser_gui` which (after Phase B lands) opens a real macOS
   window. In CI it stays headless.
"""

use std.spec.*

use app.ui.browser.app.{BrowserApp}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_env_get(name: text) -> text

val FIXTURE = "test/system/ui_browser/fixtures/hello.ui.sdn"
val SNAPSHOT = ".build/ui_browser/test_hello.ppm"

# ============================================================================
# Test Group 1: Headless snapshot — the gating CI assertion
# ============================================================================

describe "Browser Engine — Headless Snapshot":

    slow_it "produces a PPM snapshot for hello fixture":
        val result = BrowserApp.new(FIXTURE, 0, "software")
        match result:
            Ok(app) :
                val rc = app.run_once(SNAPSHOT)
                expect(rc).to_equal(0)
                expect(rt_file_exists(SNAPSHOT)).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

    slow_it "snapshot has P3 header with 1280x720":
        # run_once was called by the previous test; reuse the file.
        if rt_file_exists(SNAPSHOT):
            val content = rt_file_read_text(SNAPSHOT)
            # Header should start with "P3\n1280 720\n255\n"
            expect(content.starts_with("P3")).to_equal(true)
            expect(content.contains("1280 720")).to_equal(true)
            expect(content.contains("255")).to_equal(true)
        else:
            expect(false).to_equal(true)

    slow_it "snapshot body contains non-background pixels":
        # Background color is 0x1E1E1E => "30 30 30". A rendered fixture
        # must contain at least one pixel triple that is NOT "30 30 30"
        # somewhere in the body. We grep for a few known foreground triples
        # the painter emits (panel bg 0x2D2D2D => "45 45 45", inline text
        # 0xE0E0E0 => "224 224 224").
        if rt_file_exists(SNAPSHOT):
            val content = rt_file_read_text(SNAPSHOT)
            val has_panel_bg = content.contains("45 45 45")
            val has_text_fg = content.contains("224 224 224")
            expect(has_panel_bg or has_text_fg).to_equal(true)
        else:
            expect(false).to_equal(true)

# ============================================================================
# Test Group 2: Optional GUI window arm — guarded by env var
# ============================================================================

describe "Browser Engine — Open Window (guarded)":

    slow_it "opens window when SIMPLE_GUI_TEST=1":
        val flag = rt_env_get("SIMPLE_GUI_TEST")
        if flag == "1":
            # Phase B will route this through real winit + softbuffer.
            # Until then, run_once is the proxy that proves the same
            # render pipeline is exercised.
            val result = BrowserApp.new(FIXTURE, 0, "software")
            match result:
                Ok(app) :
                    val rc = app.run_once(SNAPSHOT)
                    expect(rc).to_equal(0)
                Err(e) :
                    expect(false).to_equal(true)
        else:
            # CI default: skip-by-pass.
            expect(true).to_equal(true)
