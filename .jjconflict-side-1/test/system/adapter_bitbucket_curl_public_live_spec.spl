use std.spec.{describe, it, expect}
use app.itf.adapter_bitbucket_curl.{BbCurlClient, bbc_get_pr, bbc_list_pr_comments, bbc_get_pr_statuses}

# Live smoke against atlassian/aui PR #1 (public, open as of 2026-04-26).
# Empty token -> adapter omits Authorization (per is_configured() relax).
# AUI chosen because response is ~6.8k (under the >~12k UTF-8 indexing OOB).

describe("adapter_bitbucket_curl — anon read against atlassian/aui PR #1", fn():
    it("get_pr returns PR (>=1kB JSON body)", fn():
        val client = BbCurlClient(
            base_url: "https://api.bitbucket.org/2.0",
            workspace: "atlassian",
            repo: "aui",
            token: "",
            curl_path: "curl"
        )
        val (ok, _pr, raw) = bbc_get_pr(client, "1")
        expect(ok).to_be(true)
        expect(raw.len() > 1000).to_be(true)
    )

    it("list_pr_comments returns successfully", fn():
        val client = BbCurlClient(
            base_url: "https://api.bitbucket.org/2.0",
            workspace: "atlassian",
            repo: "aui",
            token: "",
            curl_path: "curl"
        )
        val (ok, _comments, _raw) = bbc_list_pr_comments(client, "1")
        expect(ok).to_be(true)
    )

    it("get_pr_statuses returns successfully", fn():
        val client = BbCurlClient(
            base_url: "https://api.bitbucket.org/2.0",
            workspace: "atlassian",
            repo: "aui",
            token: "",
            curl_path: "curl"
        )
        val (ok, _statuses, _raw) = bbc_get_pr_statuses(client, "1")
        expect(ok).to_be(true)
    )
)
