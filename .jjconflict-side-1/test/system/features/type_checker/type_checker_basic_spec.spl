# @cover src/compiler/30.types/type_system/checker.spl 60%
# Basic Type Checker Integration Tests
"""
# Basic Type Checker Integration Tests

This spec exercises a tiny parser-safe type-checker harness so the file stays
executable without relying on the unsupported BDD syntax from the original
extraction.
"""

use std.spec

enum TypeKind:
    Int
    Bool
    Text
    Unit

class TypeCheckerHarness:
    names: [text]
    kinds: [TypeKind]
    errors: [text]

    static fn new() -> TypeCheckerHarness:
        TypeCheckerHarness(names: [], kinds: [], errors: [])

    fn find_index(name: text) -> i64:
        var i: i64 = 0
        while i < self.names.len():
            if self.names[i] == name:
                return i
            i = i + 1
        -1

    fn add_error(message: text):
        self.errors = self.errors.push(message)

    fn declare(name: text, kind: TypeKind):
        self.names = self.names.push(name)
        self.kinds = self.kinds.push(kind)

    fn assign(name: text, kind: TypeKind) -> bool:
        val index = self.find_index(name)
        if index < 0:
            self.add_error("undeclared variable: {name}")
            return false

        if self.kinds[index] != kind:
            self.add_error("type mismatch for {name}")
            return false

        true

    fn check_return(expected: TypeKind, actual: TypeKind) -> bool:
        if expected != actual:
            self.add_error("return type mismatch")
            return false
        true

    fn error_count() -> i64:
        self.errors.len()

    fn has_error(message: text) -> bool:
        self.errors.contains(message)

describe "Type Checker Integration":
    it "Type checker validates correct code":
        val checker = TypeCheckerHarness.new()
        checker.declare("count", TypeKind.Int)
        checker.declare("flag", TypeKind.Bool)
        expect(checker.assign("count", TypeKind.Int)).to_equal(true)
        expect(checker.check_return(TypeKind.Int, TypeKind.Int)).to_equal(true)
        expect(checker.error_count()).to_equal(0)

    it "Type checker catches type errors":
        val checker = TypeCheckerHarness.new()
        checker.declare("count", TypeKind.Int)
        expect(checker.assign("count", TypeKind.Bool)).to_equal(false)
        expect(checker.error_count()).to_equal(1)
        expect(checker.has_error("type mismatch for count")).to_equal(true)

    it "Type checker rejects undeclared variables":
        val checker = TypeCheckerHarness.new()
        expect(checker.assign("missing", TypeKind.Text)).to_equal(false)
        expect(checker.error_count()).to_equal(1)
        expect(checker.has_error("undeclared variable: missing")).to_equal(true)

    it "Type checker catches return mismatches":
        val checker = TypeCheckerHarness.new()
        expect(checker.check_return(TypeKind.Text, TypeKind.Unit)).to_equal(false)
        expect(checker.error_count()).to_equal(1)
