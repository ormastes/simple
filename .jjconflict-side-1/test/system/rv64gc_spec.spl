"""
# RV64GC Processor System Tests

**Feature IDs:** #RV64GC-SYS-001
**Category:** Hardware
**Difficulty:** 4/5
**Status:** In Progress

## Overview

Comprehensive BDD system tests for the RV64GC processor covering all extensions.
"""

# @cover src/hardware/rv64gc/top/rv64_soc.spl 60%
# @req REQ-RV64GC
# @feature rv64gc

# tag: only-compiled, vhdl, slow

import std.spec

use hardware.rv64gc.core.rv64_decode.*
use hardware.rv64gc.core.rv64_execute.{alu_execute, alu_execute_word}
use hardware.rv64gc.core.rv64_regfile.Rv64RegFile
use hardware.rv64gc.ext.rv64_muldiv.{muldiv_execute, muldiv_execute_word}
use hardware.rv64gc.ext.rv64_atomics.{amo_execute, AmoOp}
use hardware.rv64gc.pkg.rv64_types_pkg.*
use hardware.rv64gc.pkg.rv64_isa_pkg.*

# CSR addresses
val CSR_MSTATUS: i64 = 0x300
val CSR_MISA: i64 = 0x301
val CSR_MEDELEG: i64 = 0x302
val CSR_MIE: i64 = 0x304
val CSR_MTVEC: i64 = 0x305
val CSR_MSCRATCH: i64 = 0x340
val CSR_MEPC: i64 = 0x341
val CSR_MCAUSE: i64 = 0x342

# Privilege levels
val PRIV_U: i64 = 0
val PRIV_S: i64 = 1
val PRIV_M: i64 = 3

# PTE bits
val PTE_V: i64 = 1
val PTE_R: i64 = 2
val PTE_W: i64 = 4
val PTE_X: i64 = 8
val PTE_U: i64 = 16
val PTE_A: i64 = 64
val PTE_D: i64 = 128

# FP constants
val ONE_S: i64 = 0x3F800000
val TWO_S: i64 = 0x40000000
val THREE_S: i64 = 0x40400000
val ONE_D: i64 = 0x3FF0000000000000
val TWO_D: i64 = 0x4000000000000000
val THREE_D: i64 = 0x4008000000000000

# ===========================================================================
# Instruction Decode
# ===========================================================================

describe "RV64GC Processor":
    context "instruction decode":
        it "extracts opcode from ADDI":
            val instr = 0x00A00513
            expect(decode_opcode(instr)).to_equal(OP_OP_IMM)

        it "extracts rd correctly":
            val instr = 0x00A00513
            expect(decode_rd(instr)).to_equal(10)

        it "extracts rs1 correctly":
            val instr = 0x00A00513
            expect(decode_rs1(instr)).to_equal(0)

        it "decodes I-type positive immediate":
            val instr = 0x00A00513
            expect(decode_imm_i(instr)).to_equal(10)

        it "decodes I-type negative immediate":
            val instr = 0xFFB00513
            expect(decode_imm_i(instr)).to_equal(-5)

        it "decodes U-type immediate":
            val instr = 0x12345537
            expect(decode_imm_u(instr)).to_equal(0x12345000)

        it "identifies OP_OP_32 opcode for W-variants":
            val instr = 0x00C585BB
            expect(decode_opcode(instr)).to_equal(OP_OP_32)

        it "distinguishes ADD from SUB via funct7":
            val add_op = decode_alu_op(OP_OP, F3_ADD_SUB, F7_NORMAL)
            val sub_op = decode_alu_op(OP_OP, F3_ADD_SUB, F7_SUB_SRA)
            expect(add_op == AluOp.Add).to_equal(true)
            expect(sub_op == AluOp.Sub).to_equal(true)

    # ======================================================================
    # 64-bit ALU
    # ======================================================================

    context "64-bit ALU":
        it "ADD: basic":
            expect(alu_execute(AluOp.Add, 10, 20)).to_equal(30)

        it "ADD: 64-bit overflow wraps":
            expect(alu_execute(AluOp.Add, 0xFFFFFFFFFFFFFFFF, 1)).to_equal(0)

        it "SUB: basic":
            expect(alu_execute(AluOp.Sub, 50, 20)).to_equal(30)

        it "AND: upper bits":
            expect(alu_execute(AluOp.And, 0xFFFF000000000000, 0x00000000FFFFFFFF)).to_equal(0)

        it "SLL by 32 shifts to upper half":
            expect(alu_execute(AluOp.Sll, 1, 32)).to_equal(0x100000000)

        it "SRL by 32 from upper half":
            expect(alu_execute(AluOp.Srl, 0x100000000, 32)).to_equal(1)

        it "SRA preserves sign":
            expect(alu_execute(AluOp.Sra, 0x8000000000000000, 63)).to_equal(0xFFFFFFFFFFFFFFFF)

        it "SLT: negative < positive":
            expect(alu_execute(AluOp.Slt, 0x8000000000000000, 0)).to_equal(1)

        it "SLTU: unsigned comparison":
            expect(alu_execute(AluOp.Sltu, 0, 0x8000000000000000)).to_equal(1)

        it "SLL uses lower 6 bits only":
            expect(alu_execute(AluOp.Sll, 1, 64)).to_equal(1)

    # ======================================================================
    # W-variant ALU
    # ======================================================================

    context "W-variant ALU":
        it "ADDW: basic":
            expect(alu_execute_word(AluOp.Addw, 10, 20)).to_equal(30)

        it "ADDW: sign-extends negative 32-bit result":
            val result = alu_execute_word(AluOp.Addw, 0x7FFFFFFF, 1)
            expect(result).to_equal(0xFFFFFFFF80000000)

        it "ADDW: wraps at 32 bits":
            expect(alu_execute_word(AluOp.Addw, 0xFFFFFFFF, 1)).to_equal(0)

        it "SUBW: underflow sign-extends":
            val result = alu_execute_word(AluOp.Subw, 0, 1)
            expect(result).to_equal(0xFFFFFFFFFFFFFFFF)

        it "SLLW: shift into sign bit":
            val result = alu_execute_word(AluOp.Sllw, 1, 31)
            expect(result).to_equal(0xFFFFFFFF80000000)

        it "SRAW: fills with sign bit":
            val result = alu_execute_word(AluOp.Sraw, 0x80000000, 31)
            expect(result).to_equal(0xFFFFFFFFFFFFFFFF)

    # ======================================================================
    # Multiply/Divide
    # ======================================================================

    context "64-bit multiply/divide":
        it "MUL: 3 * 4 = 12":
            expect(muldiv_execute(MulDivOp.Mul, 3, 4)).to_equal(12)

        it "DIV: 20 / 4 = 5":
            expect(muldiv_execute(MulDivOp.Div, 20, 4)).to_equal(5)

        it "DIV: divide by zero returns -1":
            expect(muldiv_execute(MulDivOp.Div, 20, 0)).to_equal(-1)

        it "MULW: wraps at 32 bits":
            val result = muldiv_execute_word(MulDivOp.Mulw, 0x40000000, 2)
            expect(result).to_equal(0xFFFFFFFF80000000)

        it "REM: 20 % 3 = 2":
            expect(muldiv_execute(MulDivOp.Rem, 20, 3)).to_equal(2)

        it "DIVU: divide by zero returns MAX_U64":
            expect(muldiv_execute(MulDivOp.Divu, 42, 0)).to_equal(0xFFFFFFFFFFFFFFFF)

    # ======================================================================
    # Atomics
    # ======================================================================

    context "atomics":
        it "AMOADD: returns old and computes new":
            val r = amo_execute(AmoOp.Add, 100, 50)
            expect(r.old_value).to_equal(100)
            expect(r.new_value).to_equal(150)

        it "AMOSWAP: stores new value":
            val r = amo_execute(AmoOp.Swap, 100, 200)
            expect(r.new_value).to_equal(200)

        it "AMOAND: bitwise AND":
            val r = amo_execute(AmoOp.And, 0xFF, 0x0F)
            expect(r.new_value).to_equal(0x0F)

        it "AMOMAX: signed maximum":
            val r = amo_execute(AmoOp.Max, -10, 5)
            expect(r.new_value).to_equal(5)

    # ======================================================================
    # CSR Operations (inline model)
    # ======================================================================

    context "CSR operations":
        it "CSRRW: returns old, writes new":
            var scratch: i64 = 100
            val old = scratch
            scratch = 200
            expect(old).to_equal(100)
            expect(scratch).to_equal(200)

        it "CSRRS: sets bits":
            var mie: i64 = 0x0F
            mie = mie or 0xF0
            expect(mie).to_equal(0xFF)

        it "CSRRC: clears bits":
            var mie: i64 = 0xFF
            mie = mie and (0x0F xor 0xFFFFFFFFFFFFFFFF)
            expect(mie).to_equal(0xF0)

        it "mepc aligns to 2 bytes":
            var mepc: i64 = 0x80000003
            mepc = mepc and 0xFFFFFFFFFFFFFFFE
            expect(mepc).to_equal(0x80000002)

        it "misa reports RV64GC":
            val misa: i64 = 0x800000000014112D
            expect((misa >> 62) and 0x3).to_equal(2)
            expect((misa >> 8) and 1).to_equal(1)

        it "trap entry saves cause and pc":
            var mcause: i64 = 0
            var mepc: i64 = 0
            mcause = 11
            mepc = 0x80001000
            expect(mcause).to_equal(11)
            expect(mepc).to_equal(0x80001000)

    # ======================================================================
    # Pipeline
    # ======================================================================

    context "pipeline":
        it "load-use hazard detected":
            val ex_is_load = true
            val ex_rd = 10
            val id_rs1 = 10
            val hazard = ex_is_load and ex_rd == id_rs1 and ex_rd != 0
            expect(hazard).to_equal(true)

        it "no hazard when independent":
            val ex_is_load = true
            val ex_rd = 10
            val id_rs1 = 11
            val hazard = ex_is_load and ex_rd == id_rs1
            expect(hazard).to_equal(false)

        it "forwarding from EX stage":
            val id_rs1 = 10
            val ex_rd = 10
            val forward = id_rs1 == ex_rd and ex_rd != 0
            expect(forward).to_equal(true)

    # ======================================================================
    # Privilege Modes
    # ======================================================================

    context "privilege modes":
        it "CSR access: M-mode can access 0x3xx":
            val mode = PRIV_M
            val csr_addr = 0x300
            val required = (csr_addr >> 8) and 0x3
            expect(mode >= required).to_equal(true)

        it "CSR access: S-mode cannot access 0x3xx":
            val mode = PRIV_S
            val csr_addr = 0x300
            val required = (csr_addr >> 8) and 0x3
            expect(mode >= required).to_equal(false)

        it "trap delegation via medeleg":
            var medeleg: i64 = 1 << 8
            val delegated = (medeleg >> 8) and 1 == 1
            expect(delegated).to_equal(true)

        it "MPP field encoding":
            var mstatus: i64 = 1 << 11
            val mpp = (mstatus >> 11) and 0x3
            expect(mpp).to_equal(1)

    # ======================================================================
    # Sv39 MMU
    # ======================================================================

    context "Sv39 MMU":
        it "VPN extraction":
            val vaddr: i64 = 0x80000000
            expect((vaddr >> 30) and 0x1FF).to_equal(2)

        it "page fault on invalid PTE":
            val pte: i64 = 0
            expect(pte and PTE_V).to_equal(0)

        it "leaf PTE detection":
            val pte = (0x80 << 10) or PTE_V or PTE_R or PTE_W or PTE_A or PTE_D
            val is_leaf = (pte and (PTE_R or PTE_W or PTE_X)) != 0
            expect(is_leaf).to_equal(true)

        it "SATP Sv39 mode":
            val satp: i64 = 8 << 60
            val mode = (satp >> 60) and 0xF
            expect(mode).to_equal(8)

    # ======================================================================
    # Floating Point
    # ======================================================================

    context "single-precision float":
        it "sign injection: positive + positive = positive":
            val a = ONE_S
            val b = TWO_S
            val result = (a and 0x7FFFFFFF) or (b and 0x80000000)
            expect(result).to_equal(ONE_S)

        it "sign injection: positive + negative = negative":
            val a = ONE_S
            val b: i64 = 0xC0000000
            val result = (a and 0x7FFFFFFF) or (b and 0x80000000)
            expect(result).to_equal(0xBF800000)

        it "classify +0":
            val v = 0x00000000
            val is_pos_zero = v == 0
            expect(is_pos_zero).to_equal(true)

        it "NaN detection":
            val v: i64 = 0x7FC00000
            val exp = (v >> 23) and 0xFF
            val frac = v and 0x7FFFFF
            val is_nan = exp == 0xFF and frac != 0
            expect(is_nan).to_equal(true)

    context "double-precision float":
        it "sign injection double":
            val a = ONE_D
            val b = TWO_D
            val result = (a and 0x7FFFFFFFFFFFFFFF) or (b and 0x8000000000000000)
            expect(result).to_equal(ONE_D)

        it "NaN detection double":
            val v: i64 = 0x7FF8000000000000
            val exp = (v >> 52) and 0x7FF
            val frac = v and 0xFFFFFFFFFFFFF
            val is_nan = exp == 0x7FF and frac != 0
            expect(is_nan).to_equal(true)

        it "NaN-boxing check":
            val nan_boxed: i64 = 0xFFFFFFFF3F800000
            val upper = (nan_boxed >> 32) and 0xFFFFFFFF
            expect(upper).to_equal(0xFFFFFFFF)

        it "fcvt check: 1.0f and 1.0 have different encodings":
            expect(ONE_S != ONE_D).to_equal(true)

    context "FP CSR":
        it "fflags in lower 5 bits of fcsr":
            val fcsr: i64 = 0xFF
            expect(fcsr and 0x1F).to_equal(0x1F)

        it "frm in bits 7:5 of fcsr":
            val fcsr: i64 = 0xE0
            expect((fcsr >> 5) and 0x7).to_equal(0x7)

        it "exception flags accumulate":
            var flags: i64 = 0
            flags = flags or 0x01
            flags = flags or 0x10
            expect(flags).to_equal(0x11)

    # ======================================================================
    # SMP / Multi-hart
    # ======================================================================

    context "SMP":
        it "hart 0 and hart 1 have different IDs":
            val hart0: i64 = 0
            val hart1: i64 = 1
            expect(hart0 != hart1).to_equal(true)

        it "IPI via CLINT MSIP":
            var msip: [i64] = [0, 0]
            msip[1] = 1
            expect(msip[1]).to_equal(1)
            expect(msip[0]).to_equal(0)

        it "shared memory with atomic sync":
            var counter: i64 = 0
            val old0 = counter
            counter = counter + 1
            val old1 = counter
            counter = counter + 1
            expect(counter).to_equal(2)
