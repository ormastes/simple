# OS Shell Integration Test
#
# Tests: ShellApp command execution with VFS backing
# QEMU scenario: x64-nvme-fat32
# Exercises: ls, cat, echo, mkdir, pwd, cd, help, env
#
# Instead of injecting stdin (impossible in QEMU serial tests), this test
# creates a ShellApp.with_vfs() and calls execute() directly with command
# strings. Results are captured via shell.output_lines.
#
# This test runs as a baremetal OS entry point, not under the SSpec harness.

use os.kernel.boot.init_services.{init_services, services_storage_ready}
use os.services.vfs.vfs_init.{g_vfs, g_vfs_initialized}
use os.posix.mod.{posix_init}
use os.apps.shell.shell_app.{ShellApp}
use os.userlib.syscall_raw.{syscall}

extern fn serial_println(msg: text)
extern fn rt_exit(code: i32)

val ISA_DEBUG_EXIT_PORT: u64 = 0xf4

var _pass_count: u32 = 0
var _fail_count: u32 = 0

fn _assert(condition: bool, name: text):
    if condition:
        serial_println("[TEST PASS] {name}")
        _pass_count = _pass_count + 1
    else:
        serial_println("[TEST FAIL: {name}]")
        _fail_count = _fail_count + 1

fn _report():
    serial_println("")
    serial_println("Shell tests: {_pass_count} passed, {_fail_count} failed")
    if _fail_count == 0:
        serial_println("[ALL TESTS PASSED]")
    else:
        serial_println("[TESTS FAILED: {_fail_count}]")
    syscall(ISA_DEBUG_EXIT_PORT, 0, 0, 0, 0, 0)

fn os_shell_test():
    """Entry point for Shell + VFS integration tests."""
    serial_println("=== OS Shell Integration Test ===")
    serial_println("")

    # Initialize POSIX and boot services
    posix_init()
    init_services()

    if not g_vfs_initialized:
        serial_println("[SKIP] VFS not initialized -- cannot test shell")
        _assert(false, "VFS initialized for shell tests")
        _report()
        return

    # Create shell connected to VFS
    var shell = ShellApp.with_vfs(g_vfs)

    # ---- Test 1: Shell creation succeeds ----
    _assert(shell.running, "Shell is running after creation")

    # ---- Test 2: pwd returns root ----
    shell.output_lines = []
    shell.execute("pwd")
    val pwd_output = shell.output_lines
    serial_println("[INFO] pwd output: {pwd_output}")
    _assert(pwd_output.len() > 0, "pwd produces output")
    if pwd_output.len() > 0:
        _assert(pwd_output[0].contains("/"), "pwd shows root directory")

    # ---- Test 3: echo prints arguments ----
    shell.output_lines = []
    shell.execute("echo Hello World")
    val echo_output = shell.output_lines
    serial_println("[INFO] echo output: {echo_output}")
    _assert(echo_output.len() > 0, "echo produces output")
    if echo_output.len() > 0:
        _assert(echo_output[0].contains("Hello"), "echo prints arguments")

    # ---- Test 4: ls on root directory ----
    shell.output_lines = []
    shell.execute("ls /")
    val ls_output = shell.output_lines
    serial_println("[INFO] ls / output lines: {ls_output.len()}")
    _assert(ls_output.len() > 0, "ls / produces output")

    # ---- Test 5: ls shows hello.txt fixture ----
    var found_hello = false
    var li: u64 = 0
    while li < ls_output.len():
        if ls_output[li].contains("hello.txt"):
            found_hello = true
        li = li + 1
    _assert(found_hello, "ls / shows hello.txt fixture file")

    # ---- Test 6: cat reads file content ----
    shell.output_lines = []
    shell.execute("cat /hello.txt")
    val cat_output = shell.output_lines
    serial_println("[INFO] cat /hello.txt output: {cat_output}")
    _assert(cat_output.len() > 0, "cat /hello.txt produces output")
    if cat_output.len() > 0:
        _assert(cat_output[0].contains("Hello"), "cat shows file content")

    # ---- Test 7: mkdir creates directory ----
    shell.output_lines = []
    shell.execute("mkdir /shelltest")
    # Verify by listing
    shell.output_lines = []
    shell.execute("ls /")
    val ls2_output = shell.output_lines
    var found_dir = false
    var di: u64 = 0
    while di < ls2_output.len():
        if ls2_output[di].contains("shelltest"):
            found_dir = true
        di = di + 1
    _assert(found_dir, "mkdir /shelltest creates directory visible in ls")

    # ---- Test 8: cd changes directory ----
    shell.execute("cd /shelltest")
    shell.output_lines = []
    shell.execute("pwd")
    val cd_output = shell.output_lines
    serial_println("[INFO] pwd after cd: {cd_output}")
    if cd_output.len() > 0:
        _assert(cd_output[0].contains("shelltest"), "cd /shelltest changes cwd")
    else:
        _assert(false, "cd /shelltest changes cwd (no pwd output)")

    # ---- Test 9: help command lists commands ----
    shell.output_lines = []
    shell.execute("help")
    val help_output = shell.output_lines
    _assert(help_output.len() > 2, "help lists multiple commands (lines={help_output.len()})")

    # ---- Test 10: unknown command does not crash ----
    shell.output_lines = []
    shell.execute("nonexistent_command_xyz")
    _assert(true, "Unknown command does not crash shell")

    # ---- Test 11: exit sets running to false ----
    shell.execute("exit")
    _assert(not shell.running, "exit command stops shell")

    _report()
