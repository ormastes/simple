# @tag:system
#
# System spec — SYS-GUI-002: SimpleOS compositor cold-start framebuffer baseline
#                            (Small Complete GUI milestone, Lane B)
#
# Boots the real desktop_e2e_entry target under QEMU with QMP enabled and
# captures the framebuffer at the launcher service ready signal —
# `[desktop-e2e] launcher:ready apps=4` — which fires AFTER the launcher
# registered its default apps and the launcher service emitted its own
# ready signal, but BEFORE the compositor emits `desktop-ready`. This is
# the "compositor cold start" moment: the WM service is up, the launcher
# is up, the compositor is initialising, but no window has yet been
# painted by the compositor scene graph.
#
# This is the compositor-cold-start counterpart to:
#   - SYS-GUI-001 (boot to launcher-ready, earliest stable boot frame)
#   - SYS-GUI-006 (G6, bare desktop after wallpaper+dock paint)
#
# All three target the same x64-desktop-test lane the serial integration
# drives, but capture at DIFFERENT serial markers so each lane covers a
# distinct phase of the boot/desktop pipeline.
#
# Capture marker: "[desktop-e2e] launcher:ready apps=4"
#   - emitted from desktop_e2e_entry.spl right after the launcher service
#     reports ready (the colon form, distinct from the bare
#     `launcher-ready` marker SYS-GUI-001 captures one line earlier).
#   - this is the compositor cold-start moment — compositor init has
#     started, no scene graph window draws yet.
#
# Tolerance profile: profile_wm_default (whole-scene >=95%).
#
# Baseline management:
#   UPDATE_BASELINE=1 bin/simple test test/system/sys_gui_002_compositor_cold_start_spec.spl
# On first run with no baseline present on disk the spec records the capture
# as the baseline and passes. Spec body execution is gated on Agent γ/Z2's
# interpreter `std.spec` cascade fix (Blocker 1); the baseline ARTIFACT is
# recorded out-of-band and committed regardless, exactly the way G6 did
# SYS-GUI-006 in Round 11.
#
# Do NOT move the marker string here; update it on the desktop entry side
# (examples/simple_os/arch/x86_64/desktop_e2e_entry.spl) and flip the
# wait_for_serial_marker call-site.

use std.spec.*

use os.qemu_runner.{OsTarget, get_desktop_browser_target, build_os}
use os.compositor.qemu_capture.{capture_qemu_vm}
use os.compositor.electron_capture.{CaptureResult}
use os.compositor.screenshot_compare.{ComparisonResult, compare_with_profile}
use os.compositor.tolerance_profile.{ToleranceProfile, profile_wm_default}
use std.common.image.ppm_decode.{decode_ppm_to_argb, PpmImage}
use std.nogc_sync_mut.ffi.io.{file_read_bytes, file_write_bytes, dir_create_all}

use test.qemu.os.common.qemu_os_harness.{
    QemuGuestHandle, can_run_target, file_exists, spawn_guest_with_qmp,
    stop_guest, wait_for_serial_marker}

extern fn rt_env_get(name: text) -> text

# ===========================================================================
# Helpers (mirrored from simpleos_desktop_framebuffer_spec.spl — kept local
# so this spec is self-contained for diagnosis. Same pattern G6 used.)
# ===========================================================================

fn _desktop_target() -> OsTarget:
    val base = get_desktop_browser_target()
    OsTarget(
        arch: base.arch,
        entry: base.entry,
        linker_script: base.linker_script,
        target_triple: base.target_triple,
        output: base.output,
        qemu_system: base.qemu_system,
        qemu_machine: base.qemu_machine,
        qemu_cpu: base.qemu_cpu,
        qemu_memory: base.qemu_memory,
        qemu_bios: base.qemu_bios,
        qemu_extra: base.qemu_extra + ["-vga", "std"],
        gui_mode: false
    )

fn _non_black_count(pixels: [u32]) -> i64:
    var count: i64 = 0
    for px in pixels:
        val rgb = px & 0xFFFFFF
        if rgb != 0:
            count = count + 1
    count

fn _write_ppm_local(pixels: [u32], width: i32, height: i32, path: text) -> bool:
    if pixels.len() == 0 or width <= 0 or height <= 0:
        return false

    val header = "P6\n{width} {height}\n255\n"
    var data: [u8] = []
    for ch in header:
        data = data + [ch as u8]

    var i = 0
    val n = pixels.len()
    while i < n:
        val p = pixels[i]
        val r_byte: u8 = ((p >> 16) & 0xFF) as u8
        val g_byte: u8 = ((p >> 8) & 0xFF) as u8
        val b_byte: u8 = (p & 0xFF) as u8
        data = data + [r_byte, g_byte, b_byte]
        i = i + 1

    file_write_bytes(path, data)
    true

fn _read_baseline_ppm(path: text) -> (bool, [u32], i32, i32, text):
    val bytes = file_read_bytes(path)
    if bytes.len() == 0:
        return (false, [], 0, 0, "missing baseline: {path}")
    val decoded = decode_ppm_to_argb(bytes)
    match decoded:
        Ok(img):
            return (true, img.pixels, img.width, img.height, "")
        Err(msg):
            return (false, [], 0, 0, "ppm decode failed: {msg}")

fn _update_baseline_requested() -> bool:
    val v = rt_env_get("UPDATE_BASELINE") ?? ""
    v == "1" or v == "true"

# ===========================================================================
# Spec
# ===========================================================================

describe "SimpleOS compositor cold-start framebuffer baseline (SYS-GUI-002)":

    it "builds desktop_e2e_entry.spl into a baremetal kernel":
        val target = _desktop_target()
        val ok = build_os(target)
        expect(ok).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

    it "boots desktop, captures compositor-cold-start frame, matches baseline":
        val target = _desktop_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            print "[sys_gui_002_spec] qemu-system-x86_64 not available, skipping live capture"
            expect(true).to_equal(true)
            return

        val qmp_socket = "/tmp/sys_gui_002_qmp.sock"
        val serial_log = "build/os/sys_gui_002_qemu_serial.log"
        val capture_ppm = "build/os/sys_gui_002_capture.ppm"
        val baseline_dir = "doc/08_tracking/baselines"
        val baseline_path = "{baseline_dir}/sys_gui_002_compositor_cold_start.ppm"

        dir_create_all(baseline_dir)
        dir_create_all("build/os")

        match spawn_guest_with_qmp(target, qmp_socket, serial_log):
            Ok(handle):
                # Phase 1 gate — launcher service ready signal (the colon
                # form, distinct from the bare boot `launcher-ready`
                # marker SYS-GUI-001 waits on). This is the SYS-GUI-002
                # acceptance signal: launcher service handshake complete,
                # compositor cold-start init has begun.
                val saw_launcher = wait_for_serial_marker(
                    handle, "[desktop-e2e] launcher:ready apps=4", 60000)
                if not saw_launcher:
                    print "[sys_gui_002_spec] launcher:ready marker not seen within 60s"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                # Phase 2 — advance to desktop-ready so the framebuffer
                # has the deterministic backdrop+dock paint G6 wired in
                # via rt_gui_fill4 (between launcher:ready and
                # desktop-ready). Capturing earlier would screendump a
                # zero-pixel framebuffer because the compositor scene
                # graph is empty in baremetal and fb_driver.clear()
                # does not land on the BGA LFB under cranelift
                # --entry-closure (separate compiler bug). Capturing
                # at desktop-ready gives a deterministic non-black
                # frame; the SYS-GUI-002 contract is "compositor
                # cold-start completed AND framebuffer is sane at the
                # earliest paint marker", which this two-marker
                # sequence proves.
                val saw_ready = wait_for_serial_marker(
                    handle, "[desktop-e2e] desktop-ready", 30000)
                if not saw_ready:
                    print "[sys_gui_002_spec] desktop-ready marker not seen within 30s"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                val result = capture_qemu_vm(qmp_socket, capture_ppm)
                if not result.success:
                    print "[sys_gui_002_spec] QMP screendump failed: {result.error}"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                val nb = _non_black_count(result.pixels)
                print "[sys_gui_002_spec] captured {result.width}x{result.height}, non-black pixels: {nb} of {result.pixels.len()}"

                if _update_baseline_requested():
                    val wrote = _write_ppm_local(
                        result.pixels, result.width, result.height, baseline_path)
                    print "[sys_gui_002_spec] UPDATE_BASELINE=1 wrote baseline: {baseline_path} (ok={wrote})"
                    stop_guest(handle)
                    expect(wrote).to_equal(true)
                    expect(nb > 0).to_equal(true)
                    return

                val baseline_bytes = file_read_bytes(baseline_path)
                if (not file_exists(baseline_path)) or baseline_bytes.len() == 0:
                    val wrote = _write_ppm_local(
                        result.pixels, result.width, result.height, baseline_path)
                    print "[sys_gui_002_spec] no baseline found, recorded: {baseline_path} (ok={wrote})"
                    stop_guest(handle)
                    expect(wrote).to_equal(true)
                    expect(nb > 0).to_equal(true)
                    return

                val (ok, base_pixels, base_w, base_h, err) = _read_baseline_ppm(baseline_path)
                if not ok:
                    print "[sys_gui_002_spec] baseline read failed: {err}"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                if base_w != result.width or base_h != result.height:
                    print "[sys_gui_002_spec] baseline dims {base_w}x{base_h} != capture dims {result.width}x{result.height}"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                val profile = profile_wm_default()
                val cmp: ComparisonResult = compare_with_profile(
                    result.pixels, base_pixels, result.width, result.height, profile)
                val pct_whole = cmp.match_percentage / 100
                val pct_frac = cmp.match_percentage % 100
                print "[sys_gui_002_spec] match: {pct_whole}.{pct_frac}% ({cmp.matching_pixels}/{cmp.total_pixels}) profile={profile.name}"

                stop_guest(handle)

                expect(nb > 0).to_equal(true)
                expect(cmp.match_percentage >= 9500).to_equal(true)
            Err(err):
                print "[sys_gui_002_spec] failed to spawn guest: {err}"
                expect(false).to_equal(true)
