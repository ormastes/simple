"""
# WM Multi-App Taskbar Evidence Gate Contract

## Overview

Pins the contract of the multi-app taskbar capture gate
(`scripts/check/check-wm-multiapp-taskbar-evidence.shs` driving
`examples/06_io/ui/wm_multiapp_taskbar_gui.spl` and validated by
`scripts/check/measure_wm_multiapp_taskbar.spl`), which proves the Simple WM
(hosted compositor) can LAUNCH MULTIPLE GUI apps as internal windows through
Simple GUI, that a TASKBAR reflects them and WORKS (a taskbar click
focuses/restores its window), in a real on-screen GuiRenderer window, and
captures binding pixel evidence (per-window titlebar bands
differ from the desktop backdrop; the taskbar shows >= N colored segments).

This spec exercises TWO things deterministically, without paying for the live
capture pipeline:
  1. The pure compositor state machine that the demo drives — launching apps
     increments the window + taskbar count, a synthesized taskbar click focuses
     a background window, minimize hides a window while keeping its taskbar
     entry, and clicking that entry restores + focuses it. These assertions run
     on the REAL HostCompositor state (HeadlessHostCompositorBackend), the same
     objects the live demo mutates.
  2. The gate's fail-closed structural contract (markers it requires, pixel
     checks it enforces, and the taskbar-click handling wired into
     `host_compositor_left_button_at`).

## Syntax

```sh
SIMPLE_LIB=src bin/simple test test/03_system/check/wm_multiapp_taskbar_spec.spl --mode=interpreter --clean --fail-fast
```

## Acceptance

- Launching apps via `apply_bridge_request(COMP_CREATE_WINDOW)` grows the window
  list (and thus the taskbar item count), the newest window focused.
- `hit_taskbar` at a computed item x/y returns that window's id, and a
  synthesized press through `host_compositor_left_button_at` at that point
  focuses a background window (focused_window_id changes).
- `host_compositor_minimize_focused` minimizes the focused window (its taskbar
  entry persists), and a taskbar click on the minimized window's item restores
  and focuses it.
- The gate requires the launch/taskbar-focus/minimize/restore markers and fails
  closed on a missing capture, failed pixel calibration, window titlebars that
  do not differ from the backdrop, or fewer than N lit taskbar segments.

**Plan:** N/A
**Requirements:** N/A
**Design:** doc/00_llm_process/feature_expert/wm_gui_window_drawing/skill.md
"""

# @tag: system, gui, wm, compositor, taskbar, capture

use std.io_runtime.{file_read}
use std.spec.*
use common.window_protocol.geometry.{Size}
use os.compositor.host_compositor_entry.{HostCompositor, HeadlessHostCompositorBackend, host_compositor_left_button_at, host_compositor_focused_window_id, host_compositor_minimize_focused, host_taskbar_item_x, host_taskbar_item_width}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW}

val W: i32 = 512
val H: i32 = 384

fn _new_comp() -> HostCompositor:
    val backend = HeadlessHostCompositorBackend.new(W, H)
    HostCompositor.new(backend, Size.wh(W, H))

fn _index_of(comp: HostCompositor, id: i64) -> i32:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].id == id:
            return i
        i = i + 1
    -1

fn _launch(comp: HostCompositor, seq: i64, title: text, x: i32, y: i32, w: i32, h: i32, pid: i64, app_id: text):
    comp.apply_bridge_request(seq, 100 + seq, COMP_CREATE_WINDOW.to_i64(), 0, title, x, y, w, h, "x", pid, app_id)

fn _taskbar_click_x(comp: HostCompositor, id: i64) -> i32:
    val count = comp.windows.len().to_i32()
    val iw = host_taskbar_item_width(W, count)
    host_taskbar_item_x(W, count, _index_of(comp, id)) + iw / 2

describe "WM multi-app taskbar compositor state machine":

    it "grows the window + taskbar count as apps launch, newest focused":
        val comp = _new_comp()
        _launch(comp, 1, "Terminal", 24, 40, 180, 120, 901, "/sys/apps/terminal")
        expect(comp.windows.len()).to_equal(1)
        _launch(comp, 2, "Editor", 220, 55, 190, 130, 902, "/sys/apps/editor")
        _launch(comp, 3, "File Manager", 56, 195, 180, 115, 903, "/sys/apps/files")
        _launch(comp, 4, "Calculator", 290, 200, 160, 110, 904, "/sys/apps/calc")
        expect(comp.windows.len()).to_equal(4)
        # taskbar item count == window count; newest launched (Calculator, id 4)
        # is focused.
        expect(host_compositor_focused_window_id(comp)).to_equal(4)

    it "focuses a background window when its taskbar item is clicked":
        var comp = _new_comp()
        _launch(comp, 1, "Terminal", 24, 40, 180, 120, 901, "/sys/apps/terminal")
        _launch(comp, 2, "Editor", 220, 55, 190, 130, 902, "/sys/apps/editor")
        _launch(comp, 3, "File Manager", 56, 195, 180, 115, 903, "/sys/apps/files")
        _launch(comp, 4, "Calculator", 290, 200, 160, 110, 904, "/sys/apps/calc")
        # hit_taskbar at Terminal's item resolves to Terminal's id.
        val cy = H - 62 + 22
        val cx = _taskbar_click_x(comp, 1)
        expect(comp.hit_taskbar(cx, cy)).to_equal(1)
        expect(host_compositor_focused_window_id(comp)).to_equal(4)
        comp = host_compositor_left_button_at(comp, true, cx, cy)
        comp = host_compositor_left_button_at(comp, false, cx, cy)
        expect(host_compositor_focused_window_id(comp)).to_equal(1)

    it "minimizes the focused window and restores it via its taskbar item":
        var comp = _new_comp()
        _launch(comp, 1, "Terminal", 24, 40, 180, 120, 901, "/sys/apps/terminal")
        _launch(comp, 2, "Editor", 220, 55, 190, 130, 902, "/sys/apps/editor")
        _launch(comp, 3, "File Manager", 56, 195, 180, 115, 903, "/sys/apps/files")
        _launch(comp, 4, "Calculator", 290, 200, 160, 110, 904, "/sys/apps/calc")
        val cy = H - 62 + 22
        # Focus Terminal, then minimize it.
        val cxf = _taskbar_click_x(comp, 1)
        comp = host_compositor_left_button_at(comp, true, cxf, cy)
        comp = host_compositor_left_button_at(comp, false, cxf, cy)
        comp = host_compositor_minimize_focused(comp)
        expect(comp.windows[_index_of(comp, 1)].minimized).to_equal(true)
        # Taskbar entry persists for the minimized window (count unchanged).
        expect(comp.windows.len()).to_equal(4)
        # Click Terminal's taskbar item -> restore + focus.
        val cxr = _taskbar_click_x(comp, 1)
        comp = host_compositor_left_button_at(comp, true, cxr, cy)
        comp = host_compositor_left_button_at(comp, false, cxr, cy)
        expect(comp.windows[_index_of(comp, 1)].minimized).to_equal(false)
        expect(host_compositor_focused_window_id(comp)).to_equal(1)

describe "WM multi-app taskbar gate fail-closed contract":

    it "wires taskbar-click handling into host_compositor_left_button_at":
        val src = file_read("src/os/compositor/host_compositor_entry.spl")
        expect(src).to_contain("val tb_id = out.hit_taskbar(x, y)")
        expect(src).to_contain("out.focus_window(tb_id)")

    it "requires the launch / focus / minimize / restore markers":
        val gate = file_read("scripts/check/check-wm-multiapp-taskbar-evidence.shs")
        expect(gate).to_contain("[wm-multiapp] launched app=")
        expect(gate).to_contain("[wm-multiapp] taskbar_focus ")
        expect(gate).to_contain("[wm-multiapp] minimized id=")
        expect(gate).to_contain("[wm-multiapp] taskbar_restore ")
        expect(gate).to_contain("[wm-multiapp] final_state_ready")

    it "fails closed on missing capture, calibration, titlebars, or taskbar segments":
        val gate = file_read("scripts/check/check-wm-multiapp-taskbar-evidence.shs")
        expect(gate).to_contain("final-capture-missing")
        expect(gate).to_contain("pixel-calibration-failed")
        expect(gate).to_contain("window-titlebars-differ-from-bg-only")
        expect(gate).to_contain("taskbar-lit-segments")

    it "binds the validator's per-window titlebar and taskbar-segment checks":
        val val_src = file_read("scripts/check/measure_wm_multiapp_taskbar.spl")
        expect(val_src).to_contain("titlebar_ok")
        expect(val_src).to_contain("taskbar_lit_segments")
        expect(val_src).to_contain("windows_ok")

    it "uses the shared hosted GuiRenderer backend without exposing raw winit":
        val app = file_read("examples/06_io/ui/wm_multiapp_taskbar_gui.spl")
        expect(app).to_contain("GuiRenderer.create")
        expect(app).to_contain("HostedGuiRendererBackend.create")
        expect_not(app.contains("std.io.window_winit"))
        expect_not(app.contains("winit_window_new"))
        expect_not(app.contains("class WinitCompositorBackend"))
        expect(app).to_contain("fn apply_live_event")
        expect(app).to_contain("comp.handle_mouse_move")
        expect(app).to_contain("comp.handle_mouse_button")
        expect(app).to_contain("render_and_present(comp, state)")

        val backend = file_read("src/os/compositor/hosted_backend_gui_renderer.spl")
        expect(backend).to_contain("pixels: [u32]")
        expect(backend).to_contain("self.renderer.present_staged")
        expect_not(backend.contains("var runtime_pixels: [i64]"))
        expect_not(backend.contains("std.io.window_winit"))
        expect_not(backend.contains("rt_winit_window_new"))

    it "launches the live gate through self-hosted Simple plus the SFFI facade":
        val gate = file_read("scripts/check/check-wm-multiapp-taskbar-evidence.shs")
        expect(gate).to_contain("is_rust_seed_simple")
        expect(gate).to_contain("rust-seed-simple-bin-forbidden")
        expect(gate).to_contain("build/sffi/libspl_winit")
        expect(gate).to_contain("SIMPLE_SPL_WINIT_PATH")
        expect_not(gate.contains("target/gui/debug/simple"))
        expect_not(gate.contains("rt_winit_window_new"))

    it "documents that performance work must not reduce resolution or DPI":
        val design = file_read("doc/05_design/os/desktop/shared_wm_renderer_unification.md")
        expect(design).to_contain("8K-class desktops")
        expect(design).to_contain("300 DPI")
        expect(design).to_contain("not an acceptable optimization if it lowers logical size")
