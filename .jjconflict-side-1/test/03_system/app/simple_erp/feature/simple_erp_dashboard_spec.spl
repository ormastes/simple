# @platform: all

use std.io_runtime.{shell}

describe "simple erp dashboard":
    it "renders a self-contained HTML KPI dashboard for the suite lanes":
        val result = shell("bin/release/x86_64-unknown-linux-gnu/simple examples/12_business/simple_erp/src/dashboard_main.spl")
        expect(result.exit_code).to_equal(0)
        expect(result.stdout).to_contain("<!doctype html>")
        expect(result.stdout).to_contain("data-lane=\"restaurant\"")
        expect(result.stdout).to_contain("dashboard-ok lanes=5 revenue=33000")
