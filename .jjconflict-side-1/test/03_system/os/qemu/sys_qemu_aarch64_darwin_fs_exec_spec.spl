"""
QEMU System Test — aarch64-apple-darwin Hosted FS-Exec.

**Feature IDs:** #QEMU-SYSTEST-MULTIARCH-AC7
**Category:** OS system test — hosted native process

Runs the native aarch64-apple-darwin binary directly as a host process (NOT in QEMU)
and validates stdout marker output.

Binary: build/os/darwin-aarch64/simpleos_aarch64_darwin_fs_exec
App:    build/os/darwin-aarch64/hello_world.smf

This lane is different from the bare-metal lanes:
  - No QEMU, no kernel boot, no serial UART, no bare-metal EL0/EL1.
  - The binary is a native Mach-O process executed on an Apple Silicon Mac.
  - Output is captured from stdout, not a serial log.

A missing binary is a diagnosed RED failure (missing-media classification).
This is EXPECTED on Linux — no darwin SDK, so the binary is never built there.
Never uses skip(). On Linux this test is RED by design (honest missing-media).

The spec imports aarch64_darwin_* contract functions from qemu_systest_contract.
Those functions are added to qemu_systest_contract.spl by the orchestrator merge
(see doc/03_plan/os/multiarch_qemu_systest/aarch64_darwin_contract_snippet.md).
Until that merge, this spec cannot compile. The contract functions are in deliverable 4.
"""
use std.spec.*
use os.qemu_systest_contract.{
    run_qemu_systest,
    aarch64_darwin_binary_path,
    aarch64_darwin_app_path,
    aarch64_darwin_qemu_bin,
    aarch64_darwin_qemu_args,
    aarch64_darwin_markers,
    aarch64_darwin_timeout_ms,
    SYSTEST_PASS,
    SYSTEST_PREFIX_MISSING_MEDIA
}

extern fn rt_file_exists(path: text) -> bool

describe "systest — aarch64-apple-darwin hosted fs-exec":

    it "aarch64-darwin binary presence is diagnosed":
        val binary_present = rt_file_exists(aarch64_darwin_binary_path())
        val app_present = rt_file_exists(aarch64_darwin_app_path())
        if not binary_present:
            print "[sys_qemu_aarch64_darwin] MISSING BINARY (expected RED on Linux): " + aarch64_darwin_binary_path()
        if not app_present:
            print "[sys_qemu_aarch64_darwin] MISSING APP: " + aarch64_darwin_app_path()
        # On Linux this is expected to be false — RED is honest, not a bug.
        # On Apple Silicon Mac with darwin build, this goes green.
        expect(binary_present).to_equal(true)

    it "aarch64-darwin hosted process runs and all fs-exec acceptance markers appear":
        # run_qemu_systest is reused here: binary_path maps to kernel_path (missing-media
        # check), app_path maps to image_path (second missing-media check), qemu_bin is
        # the binary itself (executed directly, not via qemu), qemu_args is [] (no extra
        # args needed for the hosted entry program). The name "qemu_systest" is a misnomer
        # for this lane — it is a generic process-run-and-classify helper.
        val classification = run_qemu_systest(
            "aarch64-darwin",
            aarch64_darwin_binary_path(),
            aarch64_darwin_app_path(),
            aarch64_darwin_qemu_bin(),
            aarch64_darwin_qemu_args(),
            aarch64_darwin_markers(),
            aarch64_darwin_timeout_ms()
        )
        if classification != SYSTEST_PASS:
            print "[sys_qemu_aarch64_darwin] CLASSIFIED: " + classification
        expect(classification).to_equal(SYSTEST_PASS)
