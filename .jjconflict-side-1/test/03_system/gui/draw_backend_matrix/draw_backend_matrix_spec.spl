# @cover src/lib/gc_async_mut/gpu/engine2d/engine.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_directx.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl
# @tag: system, ui, engine2d, backend, drawing, matrix
"""
# Per-Backend Drawing Matrix — System-Specific Checkpoints

**Category:** Testing | **Status:** Implemented
**Requirements:** N/A
**Design:** N/A
**Research:** N/A
**Plan:** doc/03_plan/ui/testing/gpu_draw_event_intensive_tests.md

## Overview

One SHARED body — probe, create-success, draw-apply, readback-verify — run
against every 2D drawing backend key Engine2D exposes: `software` (the
absolute reference), `cpu`, `directx`, `vulkan`, and `metal`. Availability is
never silently skipped: a backend that cannot init on this host reports a
concrete `host-unavailable(reason)`, and asserting that classification IS the
system-specific checkpoint's pass condition (fail-closed, per the intensive
GPU/draw/event test plan).

Every readback assertion is an ABSOLUTE oracle — a known drawn pixel equals
the draw color, a known background pixel equals the clear color — never a
cross-backend diff alone. This avoids the false-green history documented in
`doc/07_guide/ui/engine2d_cpu_metal_bit_parity.md` (software-vs-itself
tautology, MATCH-only comparisons, memorized pixel tables).

## Key Concepts

| Concept | Description |
|---------|-------------|
| Probe | `Engine2D.probe_backend(w, h, key)` — native-only availability (no emulation fallback), so `metal` reports honestly `Unavailable` off macOS even though `directx-on-vulkan`/`metal-on-vulkan` emulation exists elsewhere |
| Create-success | `Engine2D.create_requested_backend` must resolve to the backend's own honest self-reported name (`directx` → `directx-software-emulation`), catching alias dishonesty |
| Draw-apply | one filled rect + one line drawn on a real framebuffer |
| Readback-verify | `read_pixels()` download; rect interior == rect color, line pixel == line color, far pixel == background — an absolute pixel oracle, fed through the shared `read_pixels_ppm` (P6) encoder |
| Vulkan device lane | `bin/simple test` runs specs in the classic interpreter, so real `vkCreateInstance`/`vkCmdDispatch` execute without any extra env var (see `doc/07_guide/ui/gpu_backends/vulkan_backed_rendering.md`) |

## Related Specifications

- `test/01_unit/lib/gc_async_mut/gpu/engine2d/engine2d_env_backend_select_spec.spl` — the `SIMPLE_2D_BACKEND` override model this spec's shared checkpoint follows
- `test/01_unit/lib/gc_async_mut/gpu/engine2d/backend_vulkan_drawing_spec.spl` — Vulkan lane hardening (structured error classification)
- `test/01_unit/lib/gc_async_mut/gpu/engine2d/vulkan_compute_oracle_spec.spl` — the honest device-count-zero gate this spec's Vulkan lane mirrors
- `test/02_integration/lib/gpu/cpu_sw_primitive_readback_spec.spl` — the shared per-primitive readback body this spec reuses

## Syntax

Steps are grouped `probe` → `create-success` → `draw-apply` → `readback-verify`
per backend `it`. `std.spec` matchers only; facades only (`std.io_runtime`
`env_set`), no raw `rt_*` externs.
"""

use std.spec.*
use std.io_runtime.{env_set}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgba}
use std.gc_async_mut.gpu.engine2d.backend_directx.{DirectXBackend}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}
use test.helpers.gpu_draw_event_shared.{assert_color_eq, read_pixels_ppm}

val CANVAS_W: i32 = 32
val CANVAS_H: i32 = 24
val BG: u32 = rgba(3, 5, 7, 255)
val RECT_COLOR: u32 = rgba(255, 0, 0, 255)
val LINE_COLOR: u32 = rgba(0, 255, 0, 255)

fn px_at(pixels: [u32], w: i32, x: i32, y: i32) -> u32:
    pixels[(y * w + x) as i64]

# ---------------------------------------------------------------------------
# Shared draw-apply + readback-verify body (steps 3-4), reused by every
# available backend lane below. Absolute oracle only.
# ---------------------------------------------------------------------------
fn draw_apply_and_verify(eng: Engine2D):
    step("draw-apply: clear + filled rect + line on a real framebuffer")
    eng.clear(BG)
    eng.draw_rect_filled(4, 4, 10, 6, RECT_COLOR)
    eng.draw_line(0, 18, 31, 18, LINE_COLOR, 1)
    eng.present()

    step("readback-verify: read_pixels() absolute oracle (rect/line/background)")
    val px = eng.read_pixels()
    expect(px.len()).to_equal(CANVAS_W * CANVAS_H)
    assert_color_eq(px_at(px, CANVAS_W, 8, 6), RECT_COLOR)
    assert_color_eq(px_at(px, CANVAS_W, 15, 18), LINE_COLOR)
    assert_color_eq(px_at(px, CANVAS_W, 1, 1), BG)

    step("the shared read_pixels_ppm oracle wrapper encodes a valid P6 header")
    val ppm = read_pixels_ppm(CANVAS_W, CANVAS_H, px)
    expect(ppm.len()).to_be_greater_than(CANVAS_W * CANVAS_H * 3)
    expect(ppm[0]).to_equal(80u8)
    expect(ppm[1]).to_equal(54u8)

    eng.shutdown()

# ---------------------------------------------------------------------------
# Extended-primitive parity body (DirectX/Vulkan drawing-op parity with the
# checked Metal surface): rounded_rect outline, gradient linear-H, radial
# gradient, shadow, and scaled/transform image. Coordinates are picked from
# the shared backend_emu.spl/backend_emu_adv.spl per-pixel algorithms so every
# assertion is an EXACT absolute oracle, not a "some pixel changed" proxy:
#   - gradient_rect_h: column 0 == left_color exactly, last column ==
#     right_color exactly (backend_emu.spl:585-590, lerp reaches the endpoint
#     exactly at col=0 and col=w-1).
#   - radial_gradient: center pixel (dist=0) == center_color exactly
#     (backend_emu.spl:613-621).
#   - shadow_rect with blur_r=0: a flat offset rect_filled, interior == color
#     exactly, and the un-offset corner stays background (backend_emu_adv.spl
#     emu_draw_shadow_rect).
#   - image_scaled / image_transform with a uniform source block: every
#     covered destination pixel == that source color exactly.
val EXT_W: i32 = 40
val EXT_H: i32 = 30
val EXT_BG: u32 = rgba(2, 2, 2, 255)
val EXT_A: u32 = rgba(200, 0, 0, 255)
val EXT_B: u32 = rgba(0, 0, 200, 255)
val EXT_C: u32 = rgba(0, 200, 0, 255)
val EXT_D: u32 = rgba(220, 220, 0, 255)
val EXT_E: u32 = rgba(0, 220, 220, 255)

fn assert_directx_extended_ops():
    var b = DirectXBackend.create()
    if not b.init(EXT_W, EXT_H):
        step("host-unavailable(directx): fail-closed checkpoint, not a silent skip")
        expect(b.last_error.len()).to_be_greater_than(0)
        return
    b.clear(EXT_BG)
    b.draw_rounded_rect_outline(2, 2, 10, 8, 2, EXT_A, 1)
    b.draw_gradient_rect_h(14, 2, 8, 6, EXT_A, EXT_B)
    b.draw_radial_gradient(28, 5, 4, EXT_C, EXT_B)
    b.draw_shadow_rect(2, 14, 6, 6, 1, 1, 0, EXT_D)
    b.draw_image_scaled(10, 14, 4, 4, 2, 2, [EXT_E, EXT_E, EXT_E, EXT_E])
    b.draw_image_transform(20, 14, 2, 2, 256, 0, 0, 256, 0, 0, [EXT_D, EXT_D, EXT_D, EXT_D])
    b.present()
    val px = b.read_pixels()
    assert_color_eq(px_at(px, EXT_W, 6, 2), EXT_A)            # rounded_rect_outline straight top edge
    assert_color_eq(px_at(px, EXT_W, 7, 6), EXT_BG)           # interior stays background (outline only)
    assert_color_eq(px_at(px, EXT_W, 14, 4), EXT_A)           # gradient_h left column == left_color exactly
    assert_color_eq(px_at(px, EXT_W, 21, 4), EXT_B)           # gradient_h right column == right_color exactly
    assert_color_eq(px_at(px, EXT_W, 28, 5), EXT_C)           # radial gradient center == center_color exactly
    assert_color_eq(px_at(px, EXT_W, 5, 17), EXT_D)           # shadow interior (offset by 1,1)
    assert_color_eq(px_at(px, EXT_W, 2, 14), EXT_BG)          # pre-offset corner stays background
    assert_color_eq(px_at(px, EXT_W, 11, 15), EXT_E)          # image_scaled uniform block
    assert_color_eq(px_at(px, EXT_W, 21, 15), EXT_D)          # image_transform identity-mapped pixel
    b.shutdown()

fn assert_vulkan_extended_ops():
    var b = VulkanBackend.create()
    if not b.init(EXT_W, EXT_H):
        step("host-unavailable(vulkan): fail-closed checkpoint, not a silent skip")
        expect(b.last_error.len()).to_be_greater_than(0)
        return
    b.clear(EXT_BG)
    b.draw_rounded_rect_outline(2, 2, 10, 8, 2, EXT_A, 1)
    b.draw_gradient_rect_h(14, 2, 8, 6, EXT_A, EXT_B)
    b.draw_radial_gradient(28, 5, 4, EXT_C, EXT_B)
    b.draw_shadow_rect(2, 14, 6, 6, 1, 1, 0, EXT_D)
    b.draw_image_scaled(10, 14, 4, 4, 2, 2, [EXT_E, EXT_E, EXT_E, EXT_E])
    b.draw_image_transform(20, 14, 2, 2, 256, 0, 0, 256, 0, 0, [EXT_D, EXT_D, EXT_D, EXT_D])
    b.present()
    val px = b.read_pixels()
    assert_color_eq(px_at(px, EXT_W, 6, 2), EXT_A)
    assert_color_eq(px_at(px, EXT_W, 7, 6), EXT_BG)
    assert_color_eq(px_at(px, EXT_W, 14, 4), EXT_A)
    assert_color_eq(px_at(px, EXT_W, 21, 4), EXT_B)
    assert_color_eq(px_at(px, EXT_W, 28, 5), EXT_C)
    assert_color_eq(px_at(px, EXT_W, 5, 17), EXT_D)
    assert_color_eq(px_at(px, EXT_W, 2, 14), EXT_BG)
    assert_color_eq(px_at(px, EXT_W, 11, 15), EXT_E)
    assert_color_eq(px_at(px, EXT_W, 21, 15), EXT_D)
    b.shutdown()

# ---------------------------------------------------------------------------
# Shared per-backend lane: probe -> (host-unavailable checkpoint) or
# (create-success -> draw-apply -> readback-verify). Never a silent skip().
# ---------------------------------------------------------------------------
fn run_backend_lane(key: text, expected_name: text):
    step("probe {key}")
    val probe = Engine2D.probe_backend(CANVAS_W, CANVAS_H, key)
    if not probe.is_ok():
        step("host-unavailable({key}): fail-closed checkpoint, not a silent skip")
        assert_false(probe.available)
        expect(probe.reason.len()).to_be_greater_than(0)
        return

    step("create-success: requested backend resolves to its own honest name")
    val created = Engine2D.create_requested_backend(CANVAS_W, CANVAS_H, key)
    assert_true(created.is_ok())
    var eng = created.unwrap()
    expect(eng.backend_name()).to_equal(expected_name)

    draw_apply_and_verify(eng)

describe "Draw backend matrix — per-combination system-specific checkpoints":

    it "software (baseline): always available, honest name, draw-apply, readback-verify":
        run_backend_lane("software", "software")

    it "cpu: always available, honest name, draw-apply, readback-verify":
        run_backend_lane("cpu", "cpu")

    it "directx: honest CPU software-emulation name, draw-apply, readback-verify (or host-unavailable)":
        # Never claims a native D3D11 driver: create_requested_backend stamps
        # the backend's own self-reported "directx-software-emulation" name,
        # not the requested "directx" key.
        run_backend_lane("directx", "directx-software-emulation")

    it "vulkan: real device draw-apply + readback-verify under the classic interpreter (or host-unavailable)":
        # bin/simple test runs in the classic interpreter, so real
        # vkCreateInstance/vkCmdDispatch execute here when a device is
        # present — no extra env var needed (see vulkan_backed_rendering.md).
        run_backend_lane("vulkan", "vulkan")

    it "metal: honest host-unavailable classification off macOS (or native draw-apply on macOS)":
        # Engine2D.probe_backend("metal", ...) tries ONLY native MetalBackend
        # (no metal-on-vulkan emulation fallback), so on this Linux host it
        # must report Unavailable with a concrete reason — the system-specific
        # checkpoint behavior the plan asks for. On macOS it would report
        # Initialized and the shared body runs the real GPU draw-apply path.
        run_backend_lane("metal", "metal")

    it "directx: extended drawing-op parity with checked Metal surface (rounded_rect outline, gradient linear/radial, shadow, scaled+transform image) — absolute pixel oracle (or host-unavailable)":
        # Confirms DirectXBackend forwards these extended ops to the same
        # honest internal SoftwareBackend that already rasterizes its base
        # RenderBackend ops, closing the delta against Metal's inherent-method
        # surface (see backend_directx.spl impl Engine2DExtended).
        assert_directx_extended_ops()

    it "vulkan: extended drawing-op parity with checked Metal surface (rounded_rect outline, gradient linear/radial, shadow, scaled+transform image) — absolute pixel oracle (or host-unavailable)":
        # Confirms VulkanBackend's existing emu-composed extended ops (already
        # present pre-change) produce the same exact pixels as the shared
        # backend_emu.spl/backend_emu_adv.spl algorithm DirectX/software use.
        assert_vulkan_extended_ops()

    it "SIMPLE_2D_BACKEND override selects software when it initializes (model: engine2d_env_backend_select_spec)":
        step("set SIMPLE_2D_BACKEND=software and confirm auto-detect honors it")
        env_set("SIMPLE_2D_BACKEND", "software")
        expect(Engine2D.detect_best_backend()).to_equal("software")
        step("clear the override so later runs auto-probe again")
        env_set("SIMPLE_2D_BACKEND", "")
