# @tag:system
# @tag:gui-entry-engine2d-wm-simple-web
#
# System spec — BGA WM + Simple Web + Engine2D check in QEMU.

"""
# GUI Entry Engine2D WM Simple Web QEMU Specification

## Overview

This scenario is the live x86_64 QEMU release gate for the SimpleOS Engine2D,
WM, Simple Web, and MDI demo. It builds the freestanding
`gui_entry_engine2d.spl` kernel, boots it with QMP enabled, waits for the guest
render-ready marker, and captures the visible QEMU framebuffer.

## Acceptance Criteria

- The kernel image builds and QEMU can launch it with `-vga std`.
- Serial output proves WM, Engine2D, Simple Web, top command lane, taskbar,
  HTML renderability through the Simple Web QEMU panel renderer contract, and
  the canonical five shared MDI surfaces.
- QMP `pmemsave 0xfd000000` captures the BGA framebuffer and converts it to a
  1024x768 PPM with more than 100000 non-black pixels and exact sampled colors
  for the red MMIO probe, browser header, web body bands, top command lane, and
  taskbar/background surface.
- QMP injects a deterministic host keyboard event with `input-send-event` and a second `pmemsave`
  proves the live framebuffer changed after guest input handling, so the
  scenario cannot pass from a static MDI screenshot alone.
- The canonical pinned-font pixel oracle is owned by
  `check-simpleos-wm-fullscreen-evidence.shs` and
  `native_gpu_font_readback_spec.spl`; this older WM/Web gate does not duplicate
  that release decision.
- A failed serial marker, failed QMP capture, blank framebuffer, or stale MDI
  surface count fails the scenario explicitly.

## Artifacts

Each run writes a unique artifact directory under
`build/tmp/gui_entry_engine2d_wm_simple_web_spec_<pid>_<micros>/` containing the
serial log, captured PPM, raw pmemsave bytes, and QMP result summary. The QMP
socket path also includes the same run id to avoid collisions between parallel
test runs.

## Examples

Run the live gate with:

```bash
timeout 420s bin/simple test \
  test/03_system/gui/gui_entry_engine2d_wm_simple_web_spec.spl \
  --mode=interpreter --clean --timeout 360 --sequential
```

A passing capture prints `capture_method=pmemsave`, `pmem_addr=0xfd000000`,
`ppm_dims=1024x768`,
`nonblack=<large count>`, and all checks as true:

```text
checks=[probe=True,header=True,bodyA=True,bodyB=True,top=True,taskbar=True]
```

If the serial markers are present but the QMP capture is blank, the failure is
in the framebuffer presentation path rather than the MDI service contract. If
`shared-mdi-ready surfaces=5` or `windows-ready count=5` is missing, the
canonical shared-MDI surface setup regressed before the bitmap gate.

## Failure Diagnostics

- Missing marker failures print the full guest serial log and QEMU stderr.
- Bitmap failures leave `capture.ppm` in the run artifact directory for manual
  sampling.
- The red probe at `(10,0)` proves basic framebuffer MMIO visibility.
- The browser, top-lane, and taskbar samples prove the WM/MDI scene is not a
  one-pixel or blank-frame false pass.

**Requirements:** N/A
**Plan:** .spipe/gui_hardening_current_plan/state.md
**Design:** doc/05_design/gui_color_image_pipeline_8k.md
**Research:** doc/01_research/local/gui_color_image_pipeline_8k.md
"""

use std.spec.*
use std.io_runtime.{getpid, time_now_unix_micros}

use os.qemu_runner.{OsTarget, build_os, get_wm_simple_web_check_target}
use std.nogc_sync_mut.io.dir_ops.{dir_create_all}
use app.io.mod.{cwd, file_delete, file_write, thread_sleep, process_run_timeout}

use test.system.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, spawn_guest_with_qmp, stop_guest,
    wait_for_serial_marker, read_serial_log, read_qemu_stderr_log}

fn _build_once(target: OsTarget) -> bool:
    val _removed_output = file_delete(target.output)
    val _removed_stamp = file_delete(target.output + ".build_stamp")
    build_os(target)

fn _pass_fail(ok: bool) -> text:
    if ok: "pass" else: "fail"

fn _run_id() -> text:
    getpid().to_text() + "_" + time_now_unix_micros().to_text()

fn _run_dir(run_id: text) -> text:
    "build/tmp/gui_entry_engine2d_wm_simple_web_spec_" + run_id

fn _qmp_socket(run_id: text) -> text:
    "/tmp/gui_entry_engine2d_wm_simple_web_qmp_" + run_id + ".sock"

fn _serial_log(run_id: text) -> text:
    _run_dir(run_id) + "/serial.log"

fn _capture_ppm(cwd: text, run_id: text) -> text:
    cwd + "/" + _run_dir(run_id) + "/capture.ppm"

fn _capture_before_input_ppm(cwd: text, run_id: text) -> text:
    cwd + "/" + _run_dir(run_id) + "/capture-before-input.ppm"

fn _capture_after_input_ppm(cwd: text, run_id: text) -> text:
    cwd + "/" + _run_dir(run_id) + "/capture-after-input.ppm"

fn _capture_hold_target(target: OsTarget) -> OsTarget:
    OsTarget(
        arch: target.arch,
        entry: target.entry,
        linker_script: target.linker_script,
        target_triple: target.target_triple,
        output: target.output,
        qemu_system: target.qemu_system,
        qemu_machine: target.qemu_machine,
        qemu_cpu: target.qemu_cpu,
        qemu_memory: target.qemu_memory,
        qemu_bios: target.qemu_bios,
        qemu_extra: ["-vga", "std"],
        gui_mode: target.gui_mode
    )

fn _capture_and_assert_web_ppm(qmp_socket: text, output_path: text) -> bool:
    val script = "import hashlib,json,os,socket,sys,time;" +
        "sock,out=sys.argv[1],sys.argv[2];raw=out+'.raw';" +
        "s=socket.socket(socket.AF_UNIX);s.settimeout(5);s.connect(sock);" +
        "f=s.makefile('rwb',buffering=0);" +
        "f.readline();\n" +
        "f.write(json.dumps(dict(execute='qmp_capabilities')).encode()+b'\\n');f.flush();f.readline();" +
        "f.write(json.dumps(dict(execute='human-monitor-command',arguments=dict([('command-line','pmemsave 0xfd000000 3145728 \"'+raw+'\"')]))).encode()+b'\\n');f.flush();" +
        "f.readline();\n" +
        "ok=any((time.sleep(0.1) or (os.path.exists(raw) and os.path.getsize(raw)>=3145728)) for _ in range(100));" +
        "mem=open(raw,'rb').read() if ok else b'';" +
        "w,h=(1024,768) if ok and len(mem)>=3145728 else (0,0);" +
        "pix=bytearray();" +
        "[pix.extend([mem[i+2],mem[i+1],mem[i]]) for i in range(0,w*h*4,4)];" +
        "ppm=(('P6\\n%d %d\\n255\\n' % (w,h)).encode()+bytes(pix)) if w and h else b'';" +
        "open(out,'wb').write(ppm) if ppm else None;" +
        "rgb=lambda x,y: pix[(y*w+x)*3:(y*w+x)*3+3];" +
        "near=lambda g,e,t: len(g)==3 and all(abs(g[i]-e[i])<=t for i in range(3));" +
        "non=sum(1 for i in range(0,len(pix),3) if pix[i:i+3] != b'\\x00\\x00\\x00');" +
        "probe=near(rgb(10,0),bytes([255,0,0]),8);" +
        "head=near(rgb(404,166),bytes([0x20,0x50,0xA0]),8);" +
        "bodya=near(rgb(404,200),bytes([0x18,0x22,0x30]),8);" +
        "bodyb=near(rgb(450,269),bytes([0x1F,0x29,0x37]),8);" +
        "top=near(rgb(64,20),bytes([0x20,0x50,0xA0]),8) and near(rgb(500,42),bytes([0x34,0x98,0xDB]),8) and near(rgb(900,20),bytes([0x1F,0x29,0x37]),8);" +
        "task=near(rgb(346,750),bytes([0x34,0x98,0xDB]),8) and near(rgb(500,740),bytes([0x17,0x20,0x2A]),8) and near(rgb(920,748),bytes([0x24,0x34,0x47]),8);" +
        "sha=hashlib.sha256(ppm).hexdigest() if ppm else '';" +
        "print('capture_method=pmemsave pmem_addr=0xfd000000 pmem_size=3145728 pmem_raw_bytes=%d ppm_dims=%dx%d nonblack=%d ppm_bytes=%d ppm_sha256=%s checks=[probe=%s,header=%s,bodyA=%s,bodyB=%s,top=%s,taskbar=%s]' % (len(mem),w,h,non,len(ppm),sha,probe,head,bodya,bodyb,top,task));" +
        "sys.exit(0 if ok and w==1024 and h==768 and non>100000 and probe and head and bodya and bodyb and top and task else 4)"
    val result = process_run_timeout("python3", ["-c", script, qmp_socket, output_path], 20000)
    if result[0] != "":
        print "[gui_entry_engine2d_wm_simple_web_spec] qmp ppm {result[0]}"
    if result[1] != "":
        print "[gui_entry_engine2d_wm_simple_web_spec] qmp ppm stderr: {result[1]}"
    result[2] == 0 and file_exists(output_path) and result[0].contains("capture_method=pmemsave") and result[0].contains("pmem_addr=0xfd000000") and result[0].contains("pmem_size=3145728") and result[0].contains("pmem_raw_bytes=3145728") and result[0].contains("ppm_dims=1024x768") and result[0].contains("ppm_bytes=2359312") and result[0].contains("ppm_sha256=") and result[0].contains("probe=True") and result[0].contains("header=True") and result[0].contains("bodyA=True") and result[0].contains("bodyB=True") and result[0].contains("top=True") and result[0].contains("taskbar=True")

fn _capture_and_assert_web_ppm_retry(qmp_socket: text, output_path: text, max_attempts: i64) -> bool:
    var attempt: i64 = 0
    while attempt < max_attempts:
        if _capture_and_assert_web_ppm(qmp_socket, output_path):
            return true
        thread_sleep(50)
        attempt = attempt + 1
    false

fn _qmp_input_and_assert_framebuffer_delta(qmp_socket: text, before_path: text, after_path: text) -> bool:
    val script = "import hashlib,json,os,socket,sys,time;" +
        "sock,before,after=sys.argv[1],sys.argv[2],sys.argv[3];" +
        "before_raw=before+'.raw';after_raw=after+'.raw';" +
        "s=socket.socket(socket.AF_UNIX);s.settimeout(5);s.connect(sock);" +
        "f=s.makefile('rwb',buffering=0);" +
        "f.readline();\n" +
        "def q(obj):\n f.write(json.dumps(obj).encode()+b'\\n');f.flush();return f.readline()\n" +
        "def hmp(cmd):\n return q(dict(execute='human-monitor-command',arguments=dict([('command-line',cmd)])))\n" +
        "def pmem(raw,ppm):\n hmp('pmemsave 0xfd000000 3145728 \"'+raw+'\"');ok=any((time.sleep(0.1) or (os.path.exists(raw) and os.path.getsize(raw)>=3145728)) for _ in range(100));mem=open(raw,'rb').read() if ok else b'';pix=bytearray();[pix.extend([mem[i+2],mem[i+1],mem[i]]) for i in range(0,1024*768*4,4)] if ok else None;open(ppm,'wb').write((b'P6\\n1024 768\\n255\\n'+bytes(pix)) if ok else b'');return mem\n" +
        "q(dict(execute='qmp_capabilities'));" +
        "\ndef key_a():\n q(dict(execute='input-send-event',arguments=dict(events=[dict(type='key',data=dict(down=True,key=dict(type='qcode',data='a'))),dict(type='key',data=dict(down=False,key=dict(type='qcode',data='a')))])));hmp('sendkey a')\n" +
        "mem0=pmem(before_raw,before);" +
        "key_a();time.sleep(1.25);" +
        "mem1=pmem(after_raw,after);" +
        "diff=sum(1 for a,b in zip(mem0,mem1) if a!=b) if len(mem0)==3145728 and len(mem1)==3145728 else 0;" +
        "sha0=hashlib.sha256(mem0).hexdigest() if mem0 else '';" +
        "sha1=hashlib.sha256(mem1).hexdigest() if mem1 else '';" +
        "print('qmp_keyboard_input before_raw_bytes=%d after_raw_bytes=%d framebuffer_changed_bytes=%d before_sha256_prefix=%s after_sha256_prefix=%s' % (len(mem0),len(mem1),diff,sha0[:12],sha1[:12]));" +
        "sys.exit(0 if len(mem0)==3145728 and len(mem1)==3145728 and diff>2048 and sha0!=sha1 else 5)"
    val result = process_run_timeout("python3", ["-c", script, qmp_socket, before_path, after_path], 25000)
    if result[0] != "":
        print "[gui_entry_engine2d_wm_simple_web_spec] qmp input {result[0]}"
    if result[1] != "":
        print "[gui_entry_engine2d_wm_simple_web_spec] qmp input stderr: {result[1]}"
    result[2] == 0 and file_exists(before_path) and file_exists(after_path) and result[0].contains("qmp_keyboard_input") and result[0].contains("framebuffer_changed_bytes=")

fn _qmp_capture_and_assert_web_ppm_with_input_delta(qmp_socket: text, capture_path: text, before_path: text, after_path: text) -> bool:
    val script = "import hashlib,json,os,socket,sys,time;" +
        "sock,capture,before,after=sys.argv[1],sys.argv[2],sys.argv[3],sys.argv[4];" +
        "cap_raw=capture+'.raw';before_raw=before+'.raw';after_raw=after+'.raw';" +
        "s=socket.socket(socket.AF_UNIX);s.settimeout(5);s.connect(sock);" +
        "f=s.makefile('rwb',buffering=0);" +
        "f.readline();\n" +
        "def q(obj):\n f.write(json.dumps(obj).encode()+b'\\n');f.flush();return f.readline()\n" +
        "def hmp(cmd):\n return q(dict(execute='human-monitor-command',arguments=dict([('command-line',cmd)])))\n" +
        "def pmem(raw,ppm):\n hmp('pmemsave 0xfd000000 3145728 \"'+raw+'\"');ok=any((time.sleep(0.1) or (os.path.exists(raw) and os.path.getsize(raw)>=3145728)) for _ in range(100));mem=open(raw,'rb').read() if ok else b'';pix=bytearray();[pix.extend([mem[i+2],mem[i+1],mem[i]]) for i in range(0,1024*768*4,4)] if ok else None;open(ppm,'wb').write((b'P6\\n1024 768\\n255\\n'+bytes(pix)) if ok else b'');return mem,pix\n" +
        "q(dict(execute='qmp_capabilities'));" +
        "cap_mem,cap_pix=pmem(cap_raw,capture);" +
        "rgb=lambda p,x,y: p[(y*1024+x)*3:(y*1024+x)*3+3];" +
        "near=lambda g,e,t: len(g)==3 and all(abs(g[i]-e[i])<=t for i in range(3));" +
        "non=sum(1 for i in range(0,len(cap_pix),3) if cap_pix[i:i+3] != b'\\x00\\x00\\x00');" +
        "probe=near(rgb(cap_pix,10,0),bytes([255,0,0]),8);" +
        "head=near(rgb(cap_pix,404,166),bytes([0x20,0x50,0xA0]),8);" +
        "bodya=near(rgb(cap_pix,404,200),bytes([0x18,0x22,0x30]),8);" +
        "bodyb=near(rgb(cap_pix,450,269),bytes([0x1F,0x29,0x37]),8);" +
        "top=near(rgb(cap_pix,64,20),bytes([0x20,0x50,0xA0]),8) and near(rgb(cap_pix,500,42),bytes([0x34,0x98,0xDB]),8) and near(rgb(cap_pix,900,20),bytes([0x1F,0x29,0x37]),8);" +
        "task=near(rgb(cap_pix,346,750),bytes([0x34,0x98,0xDB]),8) and near(rgb(cap_pix,500,740),bytes([0x17,0x20,0x2A]),8) and near(rgb(cap_pix,920,748),bytes([0x24,0x34,0x47]),8);" +
        "cap_sha=hashlib.sha256(open(capture,'rb').read()).hexdigest() if os.path.exists(capture) else '';" +
        "print('capture_method=pmemsave pmem_addr=0xfd000000 pmem_size=3145728 pmem_raw_bytes=%d ppm_dims=1024x768 nonblack=%d ppm_bytes=%d ppm_sha256=%s checks=[probe=%s,header=%s,bodyA=%s,bodyB=%s,top=%s,taskbar=%s]' % (len(cap_mem),non,os.path.getsize(capture) if os.path.exists(capture) else 0,cap_sha,probe,head,bodya,bodyb,top,task));" +
        "\ndef key_a():\n q(dict(execute='input-send-event',arguments=dict(events=[dict(type='key',data=dict(down=True,key=dict(type='qcode',data='a'))),dict(type='key',data=dict(down=False,key=dict(type='qcode',data='a')))])));hmp('sendkey a')\n" +
        "mem0,pix0=pmem(before_raw,before);" +
        "key_a();time.sleep(1.25);" +
        "mem1,pix1=pmem(after_raw,after);" +
        "diff=sum(1 for a,b in zip(mem0,mem1) if a!=b) if len(mem0)==3145728 and len(mem1)==3145728 else 0;" +
        "sha0=hashlib.sha256(mem0).hexdigest() if mem0 else '';" +
        "sha1=hashlib.sha256(mem1).hexdigest() if mem1 else '';" +
        "print('qmp_keyboard_input before_raw_bytes=%d after_raw_bytes=%d framebuffer_changed_bytes=%d before_sha256_prefix=%s after_sha256_prefix=%s' % (len(mem0),len(mem1),diff,sha0[:12],sha1[:12]));" +
        "anchor_ok=len(cap_mem)==3145728 and os.path.exists(capture) and os.path.getsize(capture)==2359312 and non>100000 and probe and head and bodya and bodyb and top and task;" +
        "input_ok=len(mem0)==3145728 and len(mem1)==3145728 and diff>2048 and sha0!=sha1 and os.path.exists(before) and os.path.exists(after);" +
        "sys.exit(0 if anchor_ok and input_ok else 6)"
    val result = process_run_timeout("python3", ["-c", script, qmp_socket, capture_path, before_path, after_path], 30000)
    if result[0] != "":
        print "[gui_entry_engine2d_wm_simple_web_spec] qmp capture/input {result[0]}"
    if result[1] != "":
        print "[gui_entry_engine2d_wm_simple_web_spec] qmp capture/input stderr: {result[1]}"
    file_write(capture_path + ".qmp_result.txt", "exit_code={result[2]}\nstdout:\n{result[0]}\nstderr:\n{result[1]}\n")
    result[2] == 0 and file_exists(capture_path) and file_exists(before_path) and file_exists(after_path) and result[0].contains("capture_method=pmemsave") and result[0].contains("qmp_keyboard_input")

fn _print_guest_diagnostics(prefix: text, serial: text, stderr: text):
    print "{prefix} serial_len={serial.len()} stderr_len={stderr.len()}"
    if serial != "":
        print "{prefix} serial:\n{serial}"
    if stderr != "":
        print "{prefix} qemu stderr:\n{stderr}"

describe "WM Simple Web Engine2D BGA QEMU check":
    it "builds, boots, reaches render markers, and captures Simple Web pixels":
        val target = get_wm_simple_web_check_target()
        expect(_pass_fail(_build_once(target))).to_equal("pass")
        expect(_pass_fail(file_exists(target.output))).to_equal("pass")
        val capture_target = _capture_hold_target(target)

        if not can_run_target(capture_target):
            print "[gui_entry_engine2d_wm_simple_web_spec] qemu-system-x86_64 not available, skipping live capture"
            expect(_pass_fail(file_exists(target.output))).to_equal("pass")
            return

        val run_id = _run_id()
        val artifact_dir = _run_dir(run_id)
        val qmp_socket = _qmp_socket(run_id)
        val serial_log = _serial_log(run_id)
        val cwd = cwd()
        val capture_ppm = _capture_ppm(cwd, run_id)
        val before_input_ppm = _capture_before_input_ppm(cwd, run_id)
        val after_input_ppm = _capture_after_input_ppm(cwd, run_id)

        dir_create_all(artifact_dir)
        val _deleted_qmp_socket = file_delete(qmp_socket)
        val _deleted_capture_ppm = file_delete(capture_ppm)
        val _deleted_before_input_ppm = file_delete(before_input_ppm)
        val _deleted_after_input_ppm = file_delete(after_input_ppm)

        match spawn_guest_with_qmp(capture_target, qmp_socket, serial_log):
            Ok(handle):
                val saw_ready = wait_for_serial_marker(handle, "[integrated-demo] render-ready", 60000)
                val serial = read_serial_log(handle)
                val saw_wm = serial.contains("[wm-demo] wm-service-ready")
                val saw_engine = serial.contains("[e2d-demo] engine-core-ready")
                val saw_web = serial.contains("[web-demo] pixels-ready")
                val saw_mdi = serial.contains("[mdi-demo] shared-mdi-ready surfaces=5") and serial.contains("[mdi-demo] windows-ready count=5")
                val saw_top = serial.contains("[mdi-demo] top-command-lane-ready")
                val saw_taskbar = serial.contains("[mdi-demo] taskbar-ready")
                val saw_web_contract = serial.contains("[web-demo] renderer=shared_mdi_framebuffer_scene") and serial.contains("html=about:engine2d-wm") and serial.contains("checksum=")
                val saw_html = serial.contains("[mdi-demo] html-renderable window=browser renderer=shared_mdi_framebuffer_scene") and serial.contains("checksum=")
                val saw_probe = serial.contains("[GUI] mmio-probe-painted")

                if not saw_probe or not saw_wm or not saw_engine or not saw_web or not saw_web_contract or not saw_mdi or not saw_top or not saw_taskbar or not saw_html or not saw_ready:
                    print "[gui_entry_engine2d_wm_simple_web_spec] missing marker probe={saw_probe} wm={saw_wm} e2d={saw_engine} web={saw_web} web_contract={saw_web_contract} mdi={saw_mdi} top={saw_top} taskbar={saw_taskbar} html={saw_html} ready={saw_ready}"
                    _print_guest_diagnostics("[gui_entry_engine2d_wm_simple_web_spec]", serial, read_qemu_stderr_log(handle))
                    stop_guest(handle)
                    expect(_pass_fail(saw_probe and saw_wm and saw_engine and saw_web and saw_web_contract and saw_mdi and saw_top and saw_taskbar and saw_html and saw_ready)).to_equal("pass")
                else:
                    step("Capture the WM/Web framebuffer and replay input")
                    val captured_input = _qmp_capture_and_assert_web_ppm_with_input_delta(qmp_socket, capture_ppm, before_input_ppm, after_input_ppm)
                    if not captured_input:
                        print "[gui_entry_engine2d_wm_simple_web_spec] QMP framebuffer capture or input replay assertion failed"
                        _print_guest_diagnostics("[gui_entry_engine2d_wm_simple_web_spec]", serial, read_qemu_stderr_log(handle))
                        stop_guest(handle)
                        expect(_pass_fail(captured_input)).to_equal("pass")
                    else:
                        stop_guest(handle)
                        expect(_pass_fail(file_exists(capture_ppm))).to_equal("pass")
                        expect(_pass_fail(file_exists(before_input_ppm))).to_equal("pass")
                        expect(_pass_fail(file_exists(after_input_ppm))).to_equal("pass")
            Err(err):
                print "[gui_entry_engine2d_wm_simple_web_spec] failed to spawn guest: {err}"
                expect(err).to_equal("")
