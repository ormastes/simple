    it "routes daily note template and attachment commands through the controller":
        val daily_root = "/tmp/simple_editor_controller_daily"
        expect(dir_create_all(daily_root)).to_equal(true)
        var session = EditSession.new()
        var ctrl: EditorController = EditorController.new(session)

        val daily = ctrl._execute_palette_command("daily-note-create", "2026-05-16|" + daily_root + "|# {{title}}\n")
        expect(daily.status_msg).to_equal("created daily note: " + daily_root + "/2026-05-16.md")
        expect(file_read_text(daily_root + "/2026-05-16.md")).to_equal("# 2026-05-16\n")
        val configured_daily = ctrl._execute_palette_command("daily-note-create", "2026-05-17|" + daily_root + "|# {{title}}\nDate: {{date}}\n|{{date}}-daily|markdown")
        expect(configured_daily.status_msg).to_equal("created daily note: " + daily_root + "/2026-05-17-daily.markdown")
        expect(file_read_text(daily_root + "/2026-05-17-daily.markdown")).to_equal("# 2026-05-17-daily\nDate: 2026-05-17\n")
        val daily_picker = ctrl._execute_palette_command("daily-note-picker", "2026-05-18|" + daily_root + "|# {{title}}\n|{{date}}-journal|md")
        expect(daily_picker.status_msg).to_equal("daily notes")
        expect(ctrl.wiki_panel.title).to_equal("Daily Notes")
        expect(ctrl.wiki_panel.rows.len()).to_equal(1)
        expect(ctrl.wiki_panel.rows[0].path).to_equal(daily_root + "/2026-05-18-journal.md")
        val picked_daily = ctrl._dispatch_wiki_panel_key("\n")
        expect(picked_daily.status_msg).to_equal("created daily note: " + daily_root + "/2026-05-18-journal.md")
        expect(file_read_text(daily_root + "/2026-05-18-journal.md")).to_equal("# 2026-05-18-journal\n")

        val tpl_path = "/tmp/simple_editor_controller_template.md"
        val target_path = "/tmp/simple_editor_controller_target.md"
        expect(file_write(tpl_path, "## {{title}}\nDate: {{date}}\n")).to_equal(true)
        expect(file_write(target_path, "# Target\n")).to_equal(true)
        val inserted = ctrl._execute_palette_command("template-insert", tpl_path + "|" + target_path + "|Planning|2026-05-16")
        expect(inserted.status_msg).to_equal("inserted template: " + tpl_path)
        expect(file_read_text(target_path)).to_equal("# Target\n## Planning\nDate: 2026-05-16\n")

        val tpl_root = "/tmp/simple_editor_controller_templates"
        val picker_target = "/tmp/simple_editor_controller_template_picker_target.md"
        expect(dir_create_all(tpl_root + "/nested")).to_equal(true)
        expect(file_write(tpl_root + "/Meeting.md", "## {{title}}\nDate: {{date}}\n")).to_equal(true)
        expect(file_write(tpl_root + "/nested/Note.markdown", "# {{title}}\n")).to_equal(true)
        expect(file_write(tpl_root + "/ignore.txt", "ignore")).to_equal(true)
        expect(file_write(picker_target, "# Picked\n")).to_equal(true)
        val templates = ctrl._execute_palette_command("template-picker", tpl_root + "|" + picker_target + "|Agenda|2026-05-16")
        expect(templates.status_msg).to_equal("templates: 2")
        expect(ctrl.session.dock_layout.active_right).to_equal("wiki-panel")
        expect(ctrl.wiki_panel.title).to_equal("Templates")
        expect(ctrl.wiki_panel.rows.len()).to_equal(2)
        expect(ctrl.wiki_panel.rows[0].icon).to_equal("template")
        expect(ctrl.wiki_panel.rows[0].detail.contains("|" + picker_target + "|Agenda|2026-05-16")).to_equal(true)
        val picked_template = ctrl._dispatch_wiki_panel_key("\n")
        expect(picked_template.status_msg.contains("inserted template: ")).to_equal(true)
        expect(file_read_text(picker_target).contains("Agenda")).to_equal(true)
        val filtered_templates = ctrl._execute_palette_command("template-picker", tpl_root + "|" + picker_target + "|Review|2026-05-17|meeting")
        expect(filtered_templates.status_msg).to_equal("templates: 1")
        expect(ctrl.wiki_template_query).to_equal("meeting")
        expect(ctrl.wiki_panel.rows[0].label).to_equal("Meeting.md")

        val embed_target = "/tmp/simple_editor_controller_embed_target.md"
        val embed_note = "/tmp/simple_editor_controller_embed_note.md"
        expect(file_write(embed_target, "# Embed Target\n\n")).to_equal(true)
        expect(file_write(embed_note, "# Embed Note\n")).to_equal(true)
        session.open_file(embed_target)
        var embed_buffer = session.active_buffer()
        embed_buffer.move_cursor(1, 0)
        session.update_active_buffer(embed_buffer)
        ctrl.session = session
        val embedded = ctrl._execute_palette_command("wiki-embed-insert", embed_target + "|" + embed_note + "|Embedded")
        expect(embedded.status_msg).to_equal("inserted embed: simple_editor_controller_embed_note")
        expect(ctrl.session.active_buffer().to_text()).to_equal("# Embed Target\n![[simple_editor_controller_embed_note|Embedded]]\n\n")

        val attachment_target = "/tmp/simple_editor_controller_attachment.md"
        expect(file_write(attachment_target, "# Attach\n")).to_equal(true)
        val attached = ctrl._execute_palette_command("attachment-insert", attachment_target + "|assets/screenshot.png|Screenshot")
        expect(attached.status_msg).to_equal("inserted attachment: assets/screenshot.png")
        expect(file_read_text(attachment_target)).to_equal("# Attach\n![Screenshot](assets/screenshot.png)\n")

        val stored_root = "/tmp/simple_editor_controller_attachment_store"
        expect(dir_create_all(stored_root + "/inbox")).to_equal(true)
        file_delete(stored_root + "/assets/photo.png")
        file_delete(stored_root + "/assets/photo-1.png")
        file_delete(stored_root + "/assets/photo-copy.png")
        val stored_target = stored_root + "/Note.md"
        val stored_source = stored_root + "/inbox/photo.png"
        expect(file_write(stored_target, "# Stored\n")).to_equal(true)
        expect(file_write(stored_source, "png-bytes")).to_equal(true)
        val stored = ctrl._execute_palette_command("attachment-insert", stored_target + "|" + stored_source + "|Photo|assets")
        expect(stored.status_msg.contains("inserted attachment: assets/photo")).to_equal(true)
        expect(file_read_text(stored_target).contains("# Stored\n![Photo](assets/photo")).to_equal(true)
        expect(file_write(stored_root + "/inbox/photo-copy.png", "png-copy")).to_equal(true)
        val stored_conflict = ctrl._execute_palette_command("attachment-insert", stored_target + "|" + stored_root + "/inbox/photo-copy.png|Copy|assets")
        expect(stored_conflict.status_msg).to_equal("inserted attachment: assets/photo-copy.png")
        expect(file_exists(stored_root + "/assets/photo-copy.png")).to_equal(true)
        expect(file_write(stored_root + "/inbox/photo.png", "png-new")).to_equal(true)
        val stored_renamed = ctrl._execute_palette_command("attachment-insert", stored_target + "|" + stored_root + "/inbox/photo.png|Photo 2|assets")
        expect(stored_renamed.status_msg.contains("inserted attachment: assets/photo-")).to_equal(true)

        val attachment_root = "/tmp/simple_editor_controller_attachments"
        expect(dir_create_all(attachment_root + "/assets")).to_equal(true)
        expect(file_write(attachment_root + "/assets/screenshot.png", "png")).to_equal(true)
        expect(file_write(attachment_root + "/assets/readme.txt", "txt")).to_equal(true)
        val picked = ctrl._execute_palette_command("attachment-picker", attachment_root + "|screen")
        expect(picked.status_msg).to_equal("attachments: 1")
        expect(ctrl.wiki_attachment_query).to_equal("screen")
        expect(ctrl.session.dock_layout.active_right).to_equal("wiki-panel")
        expect(ctrl.wiki_panel.title).to_equal("Attachment Picker")
        expect(ctrl.wiki_panel.rows.len()).to_equal(1)
        expect(ctrl.wiki_panel.rows[0].icon).to_equal("attachment")
        expect(ctrl.wiki_panel.rows[0].label).to_equal("screenshot.png")
        expect(ctrl.wiki_panel.rows[0].path).to_equal(attachment_root + "/assets/screenshot.png")

        val picker_insert_target = "/tmp/simple_editor_controller_attachment_picker_insert.md"
        expect(file_write(picker_insert_target, "# Picker Insert\n")).to_equal(true)
        val picker_insert = ctrl._execute_palette_command("attachment-picker", attachment_root + "|screen|" + picker_insert_target)
        expect(picker_insert.status_msg).to_equal("attachments: 1")
        expect(ctrl.wiki_panel.rows[0].detail).to_equal(picker_insert_target + "|" + attachment_root + "/assets/screenshot.png|screenshot.png|")
        val inserted_attachment = ctrl._dispatch_wiki_panel_key("\n")
        expect(inserted_attachment.status_msg).to_equal("inserted attachment: " + attachment_root + "/assets/screenshot.png")
        expect(file_read_text(picker_insert_target)).to_equal("# Picker Insert\n![screenshot.png](" + attachment_root + "/assets/screenshot.png)\n")

    it "navigates markdown table cells from controller commands":
        val table_path = "/tmp/simple_editor_controller_table_nav.md"
        expect(file_write(table_path, "| A | B |\n| --- | --- |\n| 1 | 2 |\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(table_path)
        var buffer = session.active_buffer()
        buffer.move_cursor(0, 3)
        session.update_active_buffer(buffer)
        var ctrl: EditorController = EditorController.new(session)

        val next = ctrl._execute_palette_command("markdown-table-cell-next", "")
        expect(next.status_msg).to_equal("table cell next")
        expect(ctrl.session.active_buffer().cursor_row).to_equal(0)
        expect(ctrl.session.active_buffer().cursor_col).to_equal(6)

        val next_row = ctrl._execute_palette_command("markdown-table-cell-next", "")
        expect(next_row.status_msg).to_equal("table cell next")
        expect(ctrl.session.active_buffer().cursor_row).to_equal(2)
        expect(ctrl.session.active_buffer().cursor_col).to_equal(2)

        val prev = ctrl._execute_palette_command("markdown-table-cell-prev", "")
        expect(prev.status_msg).to_equal("table cell previous")
        expect(ctrl.session.active_buffer().cursor_row).to_equal(0)
        expect(ctrl.session.active_buffer().cursor_col).to_equal(6)
        val focused_line = tui_render_editor_line_at_theme(ctrl.session.active_buffer(), 0, ctrl.session.active_buffer().line_at(0), 0, "dark", table_path)
        expect(focused_line.contains("\x1b[7mB\x1b[0m")).to_equal(true)

        var edit_buffer = ctrl.session.active_buffer()
        edit_buffer.move_cursor(2, 2)
        ctrl.session.update_active_buffer(edit_buffer)
        val inserted_row = ctrl._execute_palette_command("markdown-table-row-insert", "")
        expect(inserted_row.status_msg).to_equal("table row inserted")
        val table_after_row_insert = ctrl.session.active_buffer().to_text()
        expect(table_after_row_insert.contains("|  |  |")).to_equal(true)
        val inserted_col = ctrl._execute_palette_command("markdown-table-column-insert", "")
        expect(inserted_col.status_msg).to_equal("table column inserted")
        expect(ctrl.session.active_buffer().line_at(0)).to_equal("| A |  | B |")
        expect(ctrl.session.active_buffer().line_at(1)).to_equal("| --- | --- | --- |")

