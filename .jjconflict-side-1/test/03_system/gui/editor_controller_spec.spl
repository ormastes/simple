        expect(file_write(worker_path, "fn main():\n    print(\"worker\")\n")).to_equal(true)
        val launch_json = "{\"version\":\"0.2.0\",\"configurations\":[{\"name\":\"API\",\"type\":\"simple\",\"request\":\"launch\",\"program\":\"" + api_path + "\",\"cwd\":\"" + root + "\"},{\"name\":\"Worker\",\"type\":\"simple\",\"request\":\"launch\",\"program\":\"" + worker_path + "\",\"cwd\":\"" + root + "\"}],\"compounds\":[{\"name\":\"All\",\"configurations\":[\"API\",\"Worker\"],\"preLaunchTask\":\"build all\"}]}"
