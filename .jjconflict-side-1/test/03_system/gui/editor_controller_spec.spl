    it "notifies active LSP clients about watched files and workspace folders":
        val root = "/tmp/simple_editor_lsp_watch_dir"
        expect(dir_create_all(root)).to_equal(true)
        val path = root + "/main.spl"
        expect(file_write(path, "fn main():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        ctrl._activate_active_language()
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(3)
        expect(ctrl.file_watcher.watched_count()).to_equal(1)
        expect(ctrl.file_watcher.watched_directory_count()).to_equal(1)

        val changed = ctrl._notify_lsp_file_changed(path, 2)
        expect(changed.status_msg).to_equal("lsp file change notified")
        val folder = ctrl._notify_lsp_workspace_folder(root, "simple_editor_lsp_watch_dir", true)
        expect(folder.status_msg).to_equal("lsp workspace folder notified")
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(5)

        expect(file_write(path, "fn main():\n    val changed = true\n")).to_equal(true)
        val polled = ctrl._poll_file_watcher()
        expect(polled.status_msg).to_equal("file changes notified: 1")
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(6)
        val active_buffer = ctrl.session.active_buffer()
        expect(md_buffer_content(active_buffer).contains("changed = true")).to_equal(true)
        val created_path = root + "/created.spl"
        expect(file_write(created_path, "fn created():\n    return\n")).to_equal(true)
        val created = ctrl._poll_file_watcher()
        expect(created.status_msg).to_equal("file changes notified: 1")
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(7)
        expect(file_delete(created_path)).to_equal(true)
        val deleted = ctrl._poll_file_watcher()
        expect(deleted.status_msg).to_equal("file changes notified: 1")
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(8)
        expect(dir_create_all(root + "/node_modules/pkg")).to_equal(true)
        expect(file_write(root + "/node_modules/pkg/ignored.spl", "fn ignored():\n    return\n")).to_equal(true)
        val ignored = ctrl._poll_file_watcher()
        expect(ignored.status_msg).to_equal("file changes notified: 1")
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(8)

        val policy = ctrl._configure_file_watcher_policy(500, ["*.tmp", "ignored_dir"])
        expect(policy.status_msg).to_equal("file watcher policy updated")
        expect(ctrl.file_watcher.poll_interval_ms).to_equal(500)
        expect(file_write(root + "/ignored.tmp", "ignored")).to_equal(true)
        expect(dir_create_all(root + "/ignored_dir")).to_equal(true)
        expect(file_write(root + "/ignored_dir/ignored.spl", "fn ignored_dir():\n    return\n")).to_equal(true)
        val ignored_custom = ctrl._poll_file_watcher()
        expect(ignored_custom.redraw).to_equal(false)
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(8)

        expect(file_write(path, "fn main():\n    val debounced = true\n")).to_equal(true)
        val debounced = ctrl._poll_file_watcher_after(100)
        expect(debounced.redraw).to_equal(false)
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(8)
        val flushed = ctrl._poll_file_watcher_after(400)
        expect(flushed.status_msg).to_equal("file changes notified: 1")
        expect(stdio_transport_pending_count(ctrl.simple_lsp_state.client.transport)).to_equal(9)

    it "requests rename from command UI and applies async WorkspaceEdit responses":
        val path = "/tmp/simple_editor_rename_ui.spl"
        expect(file_write(path, "fn main():\n    val answer = 1\n    answer\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        var buffer = ctrl.session.active_buffer()
        buffer.move_cursor(1, 8)
        ctrl.session.update_active_buffer(buffer)

        val requested = ctrl._execute_palette_command("rename", "renamed_answer")
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("rename requested: renamed_answer")

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val edit_json = "{\"changes\":{\"file://" + path + "\":[{\"range\":{\"start\":{\"line\":1,\"character\":8},\"end\":{\"line\":1,\"character\":14}},\"newText\":\"renamed_answer\"}]}}"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + edit_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.session.active_buffer().line_at(1)).to_equal("    val renamed_answer = 1")
        expect(ctrl.status_msg).to_equal("applied: rename")

    it "previews async rename WorkspaceEdit responses before confirmation":
        val path = "/tmp/simple_editor_rename_preview_ui.spl"
        expect(file_write(path, "fn main():\n    val answer = 1\n    answer\n")).to_equal(true)
