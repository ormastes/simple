        expect(editor_debug_session_count(ctrl.debug_registry)).to_equal(2)
        expect(ctrl.debug_dap_clients.len()).to_equal(2)
        expect(editor_debug_first_session(ctrl.debug_registry).config.program).to_equal(first_path)

        val listed = ctrl._execute_palette_command("debug-sessions", "")
        expect(listed.status_msg).to_equal("debug sessions: 2")
        expect(ctrl.wiki_panel.title).to_equal("Debug Sessions")
        expect(ctrl.wiki_panel.rows.len()).to_equal(2)
