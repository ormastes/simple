        expect(ctrl.debug_dap_client.send_buffer[1].contains("\"preLaunchTask\":\"build main.spl\"")).to_equal(true)
        expect(ctrl.debug_dap_client.send_buffer[1].contains("\"env\":{\"SIMPLE_LIB\":\"" + root + "/src\"}")).to_equal(true)

