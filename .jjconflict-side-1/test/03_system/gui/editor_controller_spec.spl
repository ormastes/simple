        expect(requested.status_msg).to_equal("rename preview requested: preview_answer")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)
        expect(ctrl.lsp_result_panel.title).to_equal("Rename Preview")

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val edit_json = "{\"changes\":{\"file://" + path + "\":[{\"range\":{\"start\":{\"line\":1,\"character\":8},\"end\":{\"line\":1,\"character\":14}},\"newText\":\"preview_answer\"}]}}"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + edit_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
