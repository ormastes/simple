    it "hydrates async LSP document links into the result panel":
        val path = "/tmp/simple_editor_document_links_ui.md"
        val target_path = "/tmp/simple_editor_document_links_target.md"
        expect(file_write(path, "[Target](file://" + target_path + ")\n")).to_equal(true)
        expect(file_write(target_path, "# Target\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        val requested = ctrl._execute_palette_command("document-links", "")
        val request_id = ctrl.md_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("document-links results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.md_lsp_state.client
        var transport = client.transport
        val result_json = "[{\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":0,\"character\":30}},\"target\":\"file://" + target_path + "\"}]"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var md_state = ctrl.md_lsp_state
        md_state.client = client
        ctrl.md_lsp_state = md_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Document Links")
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("link")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal(target_path)
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("line 1:1")
        expect(lsp_result_panel_target_path(ctrl.lsp_result_panel)).to_equal(target_path)

