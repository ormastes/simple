    it "opens selects and jumps from the diagnostics problems panel":
        val first_path = "/tmp/simple_editor_problem_first.spl"
        val second_path = "/tmp/simple_editor_problem_second.spl"
        expect(file_write(first_path, "fn first():\n    return\n")).to_equal(true)
        expect(file_write(second_path, "fn second():\n    val bad = 1\n    bad\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(first_path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl.diagnostic_store.set_diagnostics(first_path, [
            EditorDiagnostic(path: first_path, line: 0, col: 3, end_line: 0, end_col: 8, severity: "warning", message: "first warning", source: "test")
        ])
        ctrl.diagnostic_store.set_diagnostics(second_path, [
            EditorDiagnostic(path: second_path, line: 2, col: 4, end_line: 2, end_col: 7, severity: "error", message: "second error", source: "test")
        ])

        val shown = ctrl._execute_palette_command("problems", "")
        expect(shown.status_msg).to_equal("problems: 2")
        expect(ctrl.session.dock_layout.active_right).to_equal("problems")
        expect(ctrl.diagnostics_panel.rows.len()).to_equal(2)
        expect(ctrl.diagnostics_panel.rows[0].label).to_equal("first warning")

        val rects: [SplitRect] = []
        val down = ctrl.handle_key("j", rects)
        expect(down.status_msg).to_equal("problem selected")
        val opened = ctrl.handle_key("\r", rects)
        expect(opened.status_msg).to_equal("problem jump: " + second_path + ":3")
        expect(ctrl.session.active_document().path()).to_equal(second_path)

    it "filters diagnostics problems by severity and source":
        val first_path = "/tmp/simple_editor_problem_filter_first.spl"
        val second_path = "/tmp/simple_editor_problem_filter_second.spl"
        expect(file_write(first_path, "fn first():\n    return\n")).to_equal(true)
        expect(file_write(second_path, "fn second():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(first_path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl.diagnostic_store.set_diagnostics(first_path, [
            EditorDiagnostic(path: first_path, line: 0, col: 3, end_line: 0, end_col: 8, severity: "warning", message: "lint warning", source: "lint"),
            EditorDiagnostic(path: first_path, line: 1, col: 4, end_line: 1, end_col: 8, severity: "error", message: "simple error", source: "simple")
        ])
        ctrl.diagnostic_store.set_diagnostics(second_path, [
            EditorDiagnostic(path: second_path, line: 1, col: 2, end_line: 1, end_col: 5, severity: "error", message: "lint error", source: "lint")
        ])

        val errors = ctrl._execute_palette_command("diagnostics-filter", "error|")
        expect(errors.status_msg).to_equal("problems: 2")
        expect(ctrl.diagnostics_panel.title).to_equal("Problems (error)")
        expect(ctrl.diagnostics_panel.rows.len()).to_equal(2)
        expect(ctrl.diagnostics_panel.rows[0].label).to_equal("simple error")
        expect(ctrl.diagnostics_panel.rows[1].label).to_equal("lint error")

        val lint = ctrl._execute_palette_command("diagnostics-filter", "|lint")
        expect(lint.status_msg).to_equal("problems: 2")
        expect(ctrl.diagnostics_panel.title).to_equal("Problems (lint)")
        expect(ctrl.diagnostics_panel.rows[0].label).to_equal("lint warning")
        expect(ctrl.diagnostics_panel.rows[1].label).to_equal("lint error")

        val lint_errors = ctrl._execute_palette_command("diagnostics-filter", "error|lint")
        expect(lint_errors.status_msg).to_equal("problems: 1")
        expect(ctrl.diagnostics_panel.title).to_equal("Problems (error lint)")
        expect(ctrl.diagnostics_panel.rows[0].label).to_equal("lint error")

        val no_match = ctrl._execute_palette_command("diagnostics-filter", "hint|lint")
        expect(no_match.status_msg).to_equal("problems: 0")
        expect(ctrl.diagnostics_panel.rows[0].label).to_equal("No problems")

