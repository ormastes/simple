        expect(ctrl.debug_dap_clients[1].send_buffer[1].contains("\"program\":\"" + worker_path + "\"")).to_equal(true)
        expect(ctrl.debug_dap_client.send_buffer.len()).to_equal(4)
        expect(ctrl.debug_dap_client.send_buffer[1].contains("\"program\":\"" + api_path + "\"")).to_equal(true)
        expect(ctrl.debug_dap_client.send_buffer[3].contains("\"program\":\"" + worker_path + "\"")).to_equal(true)

