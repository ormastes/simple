    it "hydrates async LSP signature help into the result panel":
        val path = "/tmp/simple_editor_signature_help_ui.spl"
        expect(file_write(path, "fn add(value: i64) -> i64:\n    value\nfn main():\n    add(1)\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        var buffer = ctrl.session.active_buffer()
        buffer.move_cursor(3, 8)
        ctrl.session.update_active_buffer(buffer)

        val requested = ctrl._execute_palette_command("signature-help", "")
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("signature-help results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val result_json = "{\"signatures\":[{\"label\":\"add(value: i64) -> i64\",\"documentation\":\"Returns the value\"},{\"label\":\"add(value: text, fallback: text) -> text\",\"documentation\":\"Returns text\"}],\"activeSignature\":1,\"activeParameter\":1}"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Signature Help")
        expect(ctrl.lsp_result_panel.rows.len()).to_equal(2)
        expect(ctrl.lsp_result_panel.selected).to_equal(1)
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("signature")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("add(value: i64) -> i64")
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("Returns the value")
        expect(ctrl.lsp_result_panel.rows[0].command_payload).to_equal("value: i64")
        expect(ctrl.lsp_result_panel.rows[1].label).to_equal("add(value: text, fallback: text) -> text")
        expect(ctrl.lsp_result_panel.rows[1].detail).to_equal("Returns text")
        expect(ctrl.lsp_result_panel.rows[1].command_payload).to_equal("fallback: text")
        expect(ctrl.lsp_signature_popup.visible).to_equal(true)
        expect(ctrl.lsp_signature_popup.label).to_equal("add(value: text, fallback: text) -> text")
        expect(ctrl.lsp_signature_popup.detail).to_equal("Returns text")
        expect(ctrl.lsp_signature_popup.active_parameter).to_equal("fallback: text")
        val signature_tui = tui_render_lsp_signature_popup_lines(ctrl.lsp_signature_popup, 42)
        expect(signature_tui.len()).to_equal(3)
        expect(signature_tui[0].contains("Signature")).to_equal(true)
        expect(signature_tui[1].contains("add(")).to_equal(true)
        expect(signature_tui[1].contains("\x1b[1;38;5;81mfallback: text")).to_equal(true)
        expect(signature_tui[1].contains("\x1b[48;5;236m")).to_equal(true)
        expect(signature_tui[2].contains("Returns text")).to_equal(true)
        expect(tui_render_lsp_signature_popup_lines(lsp_signature_popup_hidden(), 42).len()).to_equal(0)

        val previous_signature = ctrl._execute_palette_command("signature-prev", "")
        expect(previous_signature.status_msg).to_equal("signature overload 1/2")
        expect(ctrl.lsp_result_panel.selected).to_equal(0)
        expect(ctrl.lsp_signature_popup.label).to_equal("add(value: i64) -> i64")
        expect(ctrl.lsp_signature_popup.active_parameter).to_equal("value: i64")

        val next_signature = ctrl._execute_palette_command("signature-next", "")
        expect(next_signature.status_msg).to_equal("signature overload 2/2")
        expect(ctrl.lsp_result_panel.selected).to_equal(1)
        expect(ctrl.lsp_signature_popup.label).to_equal("add(value: text, fallback: text) -> text")

        val dismissed = ctrl._execute_palette_command("signature-dismiss", "")
        expect(dismissed.status_msg).to_equal("signature dismissed")
        expect(ctrl.lsp_signature_popup.visible).to_equal(false)

        ctrl.lsp_signature_popup = LspSignaturePopup(visible: true, label: "again()", detail: "doc", active_parameter: "", line: 0, col: 3)
        val esc_dismissed = ctrl.handle_key("\x1b", [])
        expect(esc_dismissed.status_msg).to_equal("signature dismissed")
        expect(ctrl.lsp_signature_popup.visible).to_equal(false)

