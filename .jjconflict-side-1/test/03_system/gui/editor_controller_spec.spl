    it "hydrates async LSP call hierarchy incoming and outgoing calls into result panels":
        val path = "/tmp/simple_editor_call_hierarchy_expand_ui.spl"
        expect(file_write(path, "fn target():\n    return\nfn caller():\n    target()\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        val item_json = "{\"name\":\"target\",\"kind\":12,\"uri\":\"file://" + path + "\",\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":1,\"character\":10}},\"selectionRange\":{\"start\":{\"line\":0,\"character\":3},\"end\":{\"line\":0,\"character\":9}}}"

        val roots = ctrl._execute_palette_command("call-hierarchy", "")
        val roots_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(roots.status_msg).to_equal("call-hierarchy results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val root_result = "[{\"name\":\"target\",\"kind\":12,\"uri\":\"file://" + path + "\",\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":1,\"character\":10}},\"selectionRange\":{\"start\":{\"line\":0,\"character\":3},\"end\":{\"line\":0,\"character\":9}}}]"
        var response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + roots_id.to_text() + ", \"result\": " + root_result + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state
        ctrl._refresh_lsp_results()
        expect(ctrl.lsp_result_panel.title).to_equal("Call Hierarchy")
        expect(ctrl.lsp_result_panel.rows[0].expanded).to_equal(false)

        val incoming = ctrl._dispatch_lsp_result_key(" ")
        val incoming_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(incoming.status_msg).to_equal("call-hierarchy-incoming results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        client = ctrl.simple_lsp_state.client
        transport = client.transport
        val incoming_result = "[{\"from\":{\"name\":\"caller\",\"kind\":12,\"uri\":\"file://" + path + "\",\"range\":{\"start\":{\"line\":2,\"character\":0},\"end\":{\"line\":3,\"character\":12}},\"selectionRange\":{\"start\":{\"line\":2,\"character\":3},\"end\":{\"line\":2,\"character\":9}}},\"fromRanges\":[]}]"
        response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + incoming_id.to_text() + ", \"result\": " + incoming_result + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Call Hierarchy")
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("call")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("target")
        expect(ctrl.lsp_result_panel.rows[0].expanded).to_equal(true)
        expect(ctrl.lsp_result_panel.rows[1].label).to_equal("caller")
        expect(ctrl.lsp_result_panel.rows[1].detail).to_equal("incoming from " + path + ":3")
        expect(ctrl.lsp_result_panel.rows[1].depth).to_equal(1)
        expect(ctrl.lsp_result_panel.rows[1].expanded).to_equal(true)
        expect(lsp_result_panel_render(ctrl.lsp_result_panel, 2)[1].contains("  call caller")).to_equal(true)
        ctrl.lsp_result_panel = lsp_result_panel_select(ctrl.lsp_result_panel, 1)
        val mixed_outgoing = ctrl._dispatch_lsp_result_key("o")
        val mixed_outgoing_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(mixed_outgoing.status_msg).to_equal("call-hierarchy-outgoing results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)
        client = ctrl.simple_lsp_state.client
        transport = client.transport
        val mixed_outgoing_result = "[{\"to\":{\"name\":\"nested_callee\",\"kind\":12,\"uri\":\"file://" + path + "\",\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":1,\"character\":10}},\"selectionRange\":{\"start\":{\"line\":0,\"character\":3},\"end\":{\"line\":0,\"character\":16}}},\"fromRanges\":[]}]"
        response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + mixed_outgoing_id.to_text() + ", \"result\": " + mixed_outgoing_result + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state
        ctrl._refresh_lsp_results()
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("target")
        expect(ctrl.lsp_result_panel.rows[0].depth).to_equal(0)
        expect(ctrl.lsp_result_panel.rows[1].label).to_equal("caller")
        expect(ctrl.lsp_result_panel.rows[1].depth).to_equal(1)
        expect(ctrl.lsp_result_panel.rows[2].label).to_equal("nested_callee")
        expect(ctrl.lsp_result_panel.rows[2].detail).to_equal("outgoing to " + path + ":1")
        expect(ctrl.lsp_result_panel.rows[2].depth).to_equal(2)
        expect(lsp_result_panel_render(ctrl.lsp_result_panel, 3)[2].contains("    call nested_callee")).to_equal(true)
        ctrl.lsp_result_panel = lsp_result_panel_select(ctrl.lsp_result_panel, 0)
        val collapsed = ctrl._dispatch_lsp_result_key(" ")
        expect(collapsed.status_msg).to_equal("lsp result collapsed")
        expect(ctrl.lsp_result_panel.rows[0].expanded).to_equal(false)
        expect(lsp_result_panel_render(ctrl.lsp_result_panel, 2).len()).to_equal(1)
        expect(lsp_result_panel_render(ctrl.lsp_result_panel, 1)[0].contains("> call target")).to_equal(true)
        val refreshed_incoming = ctrl._execute_palette_command("call-hierarchy-incoming", item_json)
        val refreshed_incoming_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(refreshed_incoming.status_msg).to_equal("call-hierarchy-incoming results")
        client = ctrl.simple_lsp_state.client
        transport = client.transport
        response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + refreshed_incoming_id.to_text() + ", \"result\": " + incoming_result + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state
        ctrl._refresh_lsp_results()
        expect(ctrl.lsp_result_panel.title).to_equal("Incoming Calls")
        expect(ctrl.lsp_result_panel.rows[0].expanded).to_equal(true)

        val incoming_collapsed = ctrl._dispatch_lsp_result_key(" ")
        expect(incoming_collapsed.status_msg).to_equal("lsp result collapsed")
        val incoming_refreshed = ctrl._execute_palette_command("call-hierarchy-incoming", item_json)
        val incoming_refreshed_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(incoming_refreshed.status_msg).to_equal("call-hierarchy-incoming results")
        client = ctrl.simple_lsp_state.client
        transport = client.transport
        response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + incoming_refreshed_id.to_text() + ", \"result\": " + incoming_result + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state
        ctrl._refresh_lsp_results()
        expect(ctrl.lsp_result_panel.rows[0].expanded).to_equal(false)

        val outgoing = ctrl._execute_palette_command("call-hierarchy-outgoing", item_json)
        val outgoing_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(outgoing.status_msg).to_equal("call-hierarchy-outgoing results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        client = ctrl.simple_lsp_state.client
        transport = client.transport
        val outgoing_result = "[{\"to\":{\"name\":\"callee\",\"kind\":12,\"uri\":\"file://" + path + "\",\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":1,\"character\":10}},\"selectionRange\":{\"start\":{\"line\":0,\"character\":3},\"end\":{\"line\":0,\"character\":9}}},\"fromRanges\":[]}]"
        response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + outgoing_id.to_text() + ", \"result\": " + outgoing_result + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Outgoing Calls")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("callee")
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("outgoing to " + path + ":1")
        expect(ctrl.lsp_result_panel.rows[0].depth).to_equal(1)

    it "hides call hierarchy descendants below collapsed result rows":
        val panel = LspResultPanel(title: "Call Hierarchy", rows: [
            LspResultRow(icon: "call", label: "root", detail: "root.spl:1", path: "/tmp/root.spl", line: 0, col: 0, command_name: "", command_payload: "", depth: 0, expanded: false),
            LspResultRow(icon: "call", label: "child", detail: "child.spl:2", path: "/tmp/child.spl", line: 1, col: 0, command_name: "", command_payload: "", depth: 1, expanded: true),
            LspResultRow(icon: "call", label: "sibling", detail: "sibling.spl:3", path: "/tmp/sibling.spl", line: 2, col: 0, command_name: "", command_payload: "", depth: 0, expanded: true)
        ], selected: 0, scroll_offset: 0, pending: false, request_id: 0)

        val rendered = lsp_result_panel_render(panel, 5)

        expect(rendered.len()).to_equal(2)
        expect(rendered[0].contains("root")).to_equal(true)
        expect(rendered[0].contains("> call")).to_equal(true)
        expect(rendered[1].contains("sibling")).to_equal(true)
        expect(rendered[1].contains("child")).to_equal(false)

    it "hydrates async LSP semantic tokens into the result panel":
        val path = "/tmp/simple_editor_semantic_tokens_ui.spl"
        expect(file_write(path, "fn main():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        val requested = ctrl._execute_palette_command("semantic-tokens", "")
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("semantic-tokens results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val result_json = "{\"legend\":{\"tokenTypes\":[\"namespace\",\"function\",\"keyword\"],\"tokenModifiers\":[\"declaration\",\"readonly\"]},\"data\":[0,3,4,1,1,1,4,6,2,2]}"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Semantic Tokens")
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("semantic")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("Token 1")
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("line 1:4 len 4 type function mods declaration")
        expect(ctrl.lsp_result_panel.rows[1].detail).to_equal("line 2:5 len 6 type keyword mods readonly")
        val semantic_buffer = ctrl.session.active_buffer()
        expect(semantic_buffer.semantic_tokens.len()).to_equal(2)
        expect(semantic_buffer.semantic_token_type_at(0, 3)).to_equal(1)
        expect(semantic_buffer.semantic_token_type_at(1, 4)).to_equal(2)
        val semantic_html = gui_render_editor_area(semantic_buffer, "simple", semantic_buffer.viewport)
        expect(semantic_html.contains("semantic-token-2")).to_equal(true)
        val semantic_tui = tui_render_line_with_semantic_tokens(semantic_buffer, 1, semantic_buffer.line_at(1))
        expect(semantic_tui.contains("\x1b[35mreturn\x1b[0m")).to_equal(true)
        val semantic_tui_scrolled = tui_render_line_with_semantic_tokens_at(semantic_buffer, 0, "main", 3)
        expect(semantic_tui_scrolled).to_equal("\x1b[36mmain\x1b[0m")
        val semantic_tui_light = tui_render_line_with_semantic_tokens_theme(semantic_buffer, 0, semantic_buffer.line_at(0), "light")
        expect(semantic_tui_light.contains("\x1b[34mmain\x1b[0m")).to_equal(true)
        val semantic_tui_solarized = tui_render_line_with_semantic_tokens_theme(semantic_buffer, 1, semantic_buffer.line_at(1), "solarized")
        expect(semantic_tui_solarized.contains("\x1b[33mreturn\x1b[0m")).to_equal(true)

        ctrl._notify_active_lsp_changed()
        expect(ctrl.session.active_buffer().semantic_tokens.len()).to_equal(0)

    it "hydrates async LSP inlay hints into the result panel":
        val path = "/tmp/simple_editor_inlay_hints_ui.spl"
        expect(file_write(path, "fn main():\n    val answer = 1\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        val requested = ctrl._execute_palette_command("inlay-hints", "")
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("inlay-hints results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val result_json = "[{\"position\":{\"line\":1,\"character\":14},\"label\":\": i64\",\"kind\":1}]"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Inlay Hints")
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("hint")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal(": i64")
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("line 2:15")
        val hinted_buffer = ctrl.session.active_buffer()
        expect(hinted_buffer.inlay_hints.len()).to_equal(1)
        expect(hinted_buffer.line_with_inlay_hints(1)).to_equal("    val answer: i64 = 1")
        val hinted_html = gui_render_editor_area(hinted_buffer, "simple", hinted_buffer.viewport)
        expect(hinted_html.contains("class=\"inlay-hint\"")).to_equal(true)
        expect(hinted_html.contains("data-event=\"inlay-hint-click\"")).to_equal(true)
        expect(hinted_html.contains("data-value=\"1,14\"")).to_equal(true)

        ctrl._notify_active_lsp_changed()
        expect(ctrl.session.active_buffer().inlay_hints.len()).to_equal(0)
        expect(ctrl.lsp_result_panel.title).to_equal("Inlay Hints")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)
        expect(ctrl.pending_inlay_hint_refresh).to_equal(true)
        val pending_request_id = ctrl.simple_lsp_state.client.next_id
        val debounce_wait = ctrl._poll_inlay_hint_refresh_after(100)
        expect(debounce_wait.redraw).to_equal(false)
        expect(ctrl.simple_lsp_state.client.next_id).to_equal(pending_request_id)
        ctrl._notify_active_lsp_changed()
        expect(ctrl.inlay_hint_refresh_elapsed_ms).to_equal(0)
        val debounce_flush = ctrl._poll_inlay_hint_refresh_after(300)
        expect(debounce_flush.status_msg).to_equal("inlay hints refreshed")
        expect(ctrl.pending_inlay_hint_refresh).to_equal(false)
        expect(ctrl.simple_lsp_state.client.next_id).to_equal(pending_request_id + 1)

    it "hydrates async LSP code lens entries into the result panel":
        val path = "/tmp/simple_editor_code_lens_ui.spl"
        expect(file_write(path, "fn main():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        val requested = ctrl._execute_palette_command("code-lens", "")
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("code-lens results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val result_json = "[{\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":0,\"character\":9}},\"command\":{\"title\":\"Run main\",\"command\":\"debug-start\",\"arguments\":[\"simple\"]}}]"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Code Lens")
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("lens")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("Run main")
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("debug-start line 1:1 args simple")
        expect(lsp_result_panel_target_command(ctrl.lsp_result_panel)).to_equal("debug-start")
        expect(lsp_result_panel_target_command_payload(ctrl.lsp_result_panel)).to_equal("simple")
        val multi_args_response = LspResponse(id: 1, ok: true, result_json: "[{\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":0,\"character\":9}},\"command\":{\"title\":\"Open note\",\"command\":\"wiki-quick-switch\",\"arguments\":[\"daily\",\"2026\"]}}]", error_text: "")
        val multi_args_panel = lsp_result_panel_from_response("code-lens", multi_args_response)
        expect(lsp_result_panel_target_command(multi_args_panel)).to_equal("wiki-quick-switch")
        expect(lsp_result_panel_target_command_payload(multi_args_panel)).to_equal("daily|2026")
        expect(multi_args_panel.rows[0].detail).to_equal("wiki-quick-switch line 1:1 args daily, 2026")
        val object_args_response = LspResponse(id: 2, ok: true, result_json: "[{\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":0,\"character\":9}},\"command\":{\"title\":\"Open structured\",\"command\":\"wiki-property-set\",\"arguments\":[{\"key\":\"status\",\"value\":\"done\"},\"local\"]}}]", error_text: "")
        val object_args_panel = lsp_result_panel_from_response("code-lens", object_args_response)
        expect(lsp_result_panel_target_command(object_args_panel)).to_equal("wiki-property-set")
        expect(lsp_result_panel_target_command_payload(object_args_panel)).to_equal("{\"key\":\"status\",\"value\":\"done\"}|local")
        expect(object_args_panel.rows[0].detail).to_equal("wiki-property-set line 1:1 args {\"key\":\"status\",\"value\":\"done\"}, local")
        val lens_buffer = ctrl.session.active_buffer()
        expect(lens_buffer.code_lenses.len()).to_equal(1)
        expect(lens_buffer.code_lenses[0].label).to_equal("Run main")
        expect(lens_buffer.line_with_code_lenses(0)).to_equal("fn main():  [Run main]")
        val lens_html = gui_render_editor_area(lens_buffer, "simple", lens_buffer.viewport)
        expect(lens_html.contains("class=\"code-lens-inline\"")).to_equal(true)
        expect(lens_html.contains("data-command=\"debug-start\"")).to_equal(true)
        expect(lens_html.contains("data-args=\"simple\"")).to_equal(true)

        val ran = ctrl._execute_palette_command("code-lens-run", "")
        expect(ran.status_msg).to_equal("debug adapter: Launch Simple")
        expect(ctrl.debug_status).to_equal("starting")

        ctrl._notify_active_lsp_changed()
        expect(ctrl.session.active_buffer().code_lenses.len()).to_equal(0)

    it "hydrates async LSP resolved code lens entries into the result panel":
        val path = "/tmp/simple_editor_code_lens_resolve_ui.spl"
        expect(file_write(path, "fn main():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        val item_json = "{\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":0,\"character\":9}},\"data\":{\"id\":1}}"

        val requested = ctrl._execute_palette_command("code-lens-resolve", item_json)
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("code-lens-resolve results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val result_json = "{\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":0,\"character\":9}},\"command\":{\"title\":\"Debug main\",\"command\":\"debug-start\",\"arguments\":[\"simple\"]}}"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Resolved Code Lens")
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("lens")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("Debug main")
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("debug-start line 1:1 args simple")
        expect(lsp_result_panel_target_command(ctrl.lsp_result_panel)).to_equal("debug-start")

    it "hydrates async LSP hover content into the result panel":
        val path = "/tmp/simple_editor_hover_ui.spl"
        expect(file_write(path, "fn main():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        var buffer = ctrl.session.active_buffer()
        buffer.move_cursor(0, 3)
        ctrl.session.update_active_buffer(buffer)

        val requested = ctrl._execute_palette_command("hover", "")
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("hover results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val result_json = "{\"contents\":{\"kind\":\"markdown\",\"value\":\"fn main() -> void\"},\"range\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":0,\"character\":7}}}"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Hover")
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("hover")
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("fn main() -> void")
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("line 1:1")
        expect(ctrl.lsp_hover_popup.visible).to_equal(true)
        expect(ctrl.lsp_hover_popup.content).to_equal("fn main() -> void")
        expect(ctrl.lsp_hover_popup.line).to_equal(0)
        expect(ctrl.lsp_hover_popup.col).to_equal(3)
        val hover_tui = tui_render_lsp_hover_popup_lines(ctrl.lsp_hover_popup, 40)
        expect(hover_tui.len()).to_equal(3)
        expect(hover_tui[0].contains("Hover")).to_equal(true)
        expect(hover_tui[1].contains("fn main() -> void")).to_equal(true)
        expect(hover_tui[1].contains("\x1b[48;5;236m")).to_equal(true)
        expect(tui_render_lsp_hover_popup_lines(lsp_hover_popup_hidden(), 40).len()).to_equal(0)

        val dismissed = ctrl._execute_palette_command("hover-dismiss", "")
        expect(dismissed.status_msg).to_equal("hover dismissed")
        expect(ctrl.lsp_hover_popup.visible).to_equal(false)

        ctrl.lsp_hover_popup = LspHoverPopup(visible: true, content: "again", detail: "line 1:4", line: 0, col: 3)
        val esc_dismissed = ctrl.handle_key("\x1b", [])
        expect(esc_dismissed.status_msg).to_equal("hover dismissed")
        expect(ctrl.lsp_hover_popup.visible).to_equal(false)

    it "clears stale diagnostics for the active file when text changes":
        val active_path = "/tmp/simple_editor_diagnostics_stale_active.spl"
        val other_path = "/tmp/simple_editor_diagnostics_stale_other.spl"
        expect(file_write(active_path, "fn main():\n    return\n")).to_equal(true)
        expect(file_write(other_path, "fn other():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(active_path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl.diagnostic_store.set_diagnostics(active_path, [
            EditorDiagnostic(path: active_path, line: 0, col: 3, end_line: 0, end_col: 7, severity: "error", message: "stale active", source: "test")
        ])
        ctrl.diagnostic_store.set_diagnostics(other_path, [
            EditorDiagnostic(path: other_path, line: 0, col: 3, end_line: 0, end_col: 7, severity: "warning", message: "keep other", source: "test")
        ])
        ctrl._execute_palette_command("problems", "")
        expect(ctrl.diagnostics_panel.rows.len()).to_equal(2)

        ctrl._notify_active_lsp_changed()

        expect(ctrl.diagnostic_store.diagnostics_for(active_path).len()).to_equal(0)
        expect(ctrl.diagnostic_store.diagnostics_for(other_path).len()).to_equal(1)
        expect(ctrl.diagnostics_panel.rows.len()).to_equal(1)
        expect(ctrl.diagnostics_panel.rows[0].path).to_equal(other_path)

    it "replaces diagnostics from LSP publish notifications and clears empty publishes":
        val active_path = "/tmp/simple_editor_diagnostics_publish_active.spl"
        val other_path = "/tmp/simple_editor_diagnostics_publish_other.spl"
        expect(file_write(active_path, "fn main():\n    return\n")).to_equal(true)
        expect(file_write(other_path, "fn other():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(active_path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl._activate_active_language()
        ctrl.diagnostic_store.set_diagnostics(active_path, [
            EditorDiagnostic(path: active_path, line: 9, col: 1, end_line: 9, end_col: 2, severity: "warning", message: "stale active", source: "test")
        ])
        ctrl.diagnostic_store.set_diagnostics(other_path, [
            EditorDiagnostic(path: other_path, line: 3, col: 1, end_line: 3, end_col: 2, severity: "error", message: "keep other", source: "test")
        ])
        val filtered = ctrl._execute_palette_command("diagnostics-filter", "error|")
        expect(filtered.status_msg).to_equal("problems: 1")
        expect(ctrl.diagnostics_panel.title).to_equal("Problems (error)")
        expect(ctrl.diagnostics_panel.rows[0].label).to_equal("keep other")

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val publish = "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/publishDiagnostics\",\"params\":{\"uri\":\"file://" + active_path + "\",\"diagnostics\":[{\"range\":{\"start\":{\"line\":1,\"character\":4},\"end\":{\"line\":1,\"character\":8}},\"severity\":1,\"source\":\"simple\",\"message\":\"fresh\"}]}}"
        transport.recv_buffer.push(publish)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._poll_lsp_diagnostics()

        expect(ctrl.diagnostic_store.diagnostics_for(active_path).len()).to_equal(1)
        expect(ctrl.diagnostic_store.diagnostics_for(active_path)[0].message).to_equal("fresh")
        expect(ctrl.diagnostic_store.diagnostics_for(other_path).len()).to_equal(1)
        expect(ctrl.diagnostics_panel.rows.len()).to_equal(2)
        expect(ctrl.diagnostics_panel.title).to_equal("Problems (error)")
        expect(ctrl.diagnostics_panel.rows[0].label).to_equal("keep other")
        expect(ctrl.diagnostics_panel.rows[1].label).to_equal("fresh")

        client = ctrl.simple_lsp_state.client
        transport = client.transport
        val clear_publish = "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/publishDiagnostics\",\"params\":{\"uri\":\"file://" + active_path + "\",\"diagnostics\":[]}}"
        transport.recv_buffer.push(clear_publish)
        client.transport = transport
        simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._poll_lsp_diagnostics()

        expect(ctrl.diagnostic_store.diagnostics_for(active_path).len()).to_equal(0)
        expect(ctrl.diagnostic_store.diagnostics_for(other_path).len()).to_equal(1)
        expect(ctrl.diagnostics_panel.rows.len()).to_equal(1)
        expect(ctrl.diagnostics_panel.title).to_equal("Problems (error)")
        expect(ctrl.diagnostics_panel.rows[0].label).to_equal("keep other")

    it "exposes extended LSP parity requests through editor MCP tools":
        val path = "/tmp/simple_editor_lsp_mcp_extended.spl"
        expect(file_write(path, "fn main():\n    val answer = 1\n    answer\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)

        expect(editor_mcp_dispatch(session, "editor.lsp_references", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_selection_ranges", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_document_symbols", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_prepare_rename", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_formatting", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_range_formatting", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_signature_help", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_document_links", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_folding_ranges", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_workspace_symbols", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_workspace_symbols", ["main"]).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_semantic_tokens", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_inlay_hints", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_code_lens", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_code_lens_resolve", ["{}"]).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_call_hierarchy", []).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_call_hierarchy_incoming", ["{}"]).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_call_hierarchy_outgoing", ["{}"]).ok).to_equal(true)
        expect(editor_mcp_dispatch(session, "editor.lsp_rename", ["renamed_answer"]).ok).to_equal(true)
