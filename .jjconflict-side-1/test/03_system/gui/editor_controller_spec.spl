        expect(ctrl.debug_dap_client.send_buffer[1].contains("\"program\":\"" + first_path + "\"")).to_equal(true)

    it "hydrates DAP stack scope and variable responses into the debug panel":
        val path = "/tmp/simple_editor_debug_dap_response.spl"
        expect(file_write(path, "fn main():\n    val answer = 42\n    answer\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl._start_debug_adapter("simple")

        val stack_json = "{\"seq\":1005,\"type\":\"response\",\"request_seq\":5,\"success\":true,\"command\":\"stackTrace\",\"body\":{\"stackFrames\":[{\"id\":1,\"name\":\"main\",\"line\":2,\"column\":4,\"source\":{\"name\":\"main.spl\",\"path\":\"" + path + "\"}}],\"totalFrames\":1}}"
        val stack = ctrl._debug_hydrate_dap_response(stack_json)
        expect(stack.status_msg).to_equal("debug stack")
        expect(ctrl.wiki_panel.rows[1].icon).to_equal("stack")
        expect(ctrl.wiki_panel.rows[1].label).to_equal("main")
        expect(ctrl.wiki_panel.rows[1].path).to_equal(path)
        expect(ctrl.wiki_panel.rows[1].detail).to_equal(path + ":2:4")

        val scopes_json = "{\"seq\":1006,\"type\":\"response\",\"request_seq\":6,\"success\":true,\"command\":\"scopes\",\"body\":{\"scopes\":[{\"name\":\"Locals\",\"variablesReference\":10,\"expensive\":false}]}}"
        val scopes = ctrl._debug_hydrate_dap_response(scopes_json)
        expect(scopes.status_msg).to_equal("debug scopes")
        expect(ctrl.wiki_panel.rows[2].icon).to_equal("scope")
        expect(ctrl.wiki_panel.rows[2].label).to_equal("Locals")
        expect(ctrl.wiki_panel.rows[2].detail).to_equal("ref 10")

        val variables_json = "{\"seq\":1007,\"type\":\"response\",\"request_seq\":7,\"success\":true,\"command\":\"variables\",\"body\":{\"variables\":[{\"name\":\"answer\",\"value\":\"42\",\"type\":\"i64\",\"variablesReference\":0}]}}"
        val variables = ctrl._debug_hydrate_dap_response(variables_json)
        expect(variables.status_msg).to_equal("debug variables: Locals")
        expect(ctrl.wiki_panel.rows[3].icon).to_equal("variable")
        expect(ctrl.wiki_panel.rows[3].label).to_equal("answer")
        expect(ctrl.wiki_panel.rows[3].detail).to_equal("42 : i64")

        val evaluate_json = "{\"seq\":1008,\"type\":\"response\",\"request_seq\":8,\"success\":true,\"command\":\"evaluate\",\"body\":{\"result\":\"42\",\"variablesReference\":0}}"
        val evaluated = ctrl._debug_hydrate_dap_response(evaluate_json)
        expect(evaluated.status_msg).to_equal("debug evaluate result")
        expect(ctrl.wiki_panel.rows[4].icon).to_equal("console")
        expect(ctrl.wiki_panel.rows[4].label).to_equal("evaluate-result")
        expect(ctrl.wiki_panel.rows[4].detail).to_equal("42")

        val failed_json = "{\"seq\":1008,\"type\":\"response\",\"request_seq\":8,\"success\":false,\"command\":\"stackTrace\",\"message\":\"failed\"}"
        expect(ctrl._debug_hydrate_dap_response(failed_json).status_msg).to_equal("debug response failed: stackTrace")

    it "queues editor debug controls through the DAP client and polls responses":
        val path = "/tmp/simple_editor_debug_dap_client.spl"
        expect(file_write(path, "fn main():\n    val answer = 42\n    answer\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        val started = ctrl._start_debug_adapter("simple")
        expect(started.status_msg).to_equal("debug adapter: Launch Simple")
        expect(ctrl.debug_dap_client.running).to_equal(true)
        expect(ctrl.debug_dap_client.send_buffer.len()).to_equal(2)
        expect(ctrl.debug_dap_client.send_buffer[0].contains("\"command\":\"initialize\"")).to_equal(true)
        expect(ctrl.debug_dap_client.send_buffer[1].contains("\"command\":\"launch\"")).to_equal(true)

        ctrl._debug_add_breakpoint(path, 2, "answer > 0", "hit answer", "3")
        expect(ctrl.debug_dap_client.send_buffer[2].contains("\"command\":\"setBreakpoints\"")).to_equal(true)
        expect(ctrl.debug_dap_client.send_buffer[2].contains("\"condition\":\"answer > 0\"")).to_equal(true)
        ctrl._debug_continue()
        expect(ctrl.debug_dap_client.send_buffer[3].contains("\"command\":\"continue\"")).to_equal(true)
        ctrl._debug_pause()
        expect(ctrl.debug_dap_client.send_buffer[4].contains("\"command\":\"pause\"")).to_equal(true)
        ctrl._debug_step("stepOut")
        expect(ctrl.debug_dap_client.send_buffer[5].contains("\"command\":\"stepOut\"")).to_equal(true)
        ctrl._execute_palette_command("debug-stack", "")
        expect(ctrl.debug_dap_client.send_buffer[6].contains("\"command\":\"stackTrace\"")).to_equal(true)
        ctrl._execute_palette_command("debug-scopes", "1")
        expect(ctrl.debug_dap_client.send_buffer[7].contains("\"command\":\"scopes\"")).to_equal(true)
        ctrl._execute_palette_command("debug-variables", "10")
        expect(ctrl.debug_dap_client.send_buffer[8].contains("\"command\":\"variables\"")).to_equal(true)
        ctrl._execute_palette_command("debug-exceptions", "caught, uncaught")
        expect(ctrl.debug_dap_client.send_buffer[9].contains("\"command\":\"setExceptionBreakpoints\"")).to_equal(true)
        ctrl._execute_palette_command("debug-evaluate", "answer")
        expect(ctrl.debug_dap_client.send_buffer[10].contains("\"command\":\"evaluate\"")).to_equal(true)
        ctrl._execute_palette_command("debug-watch", "answer")
        expect(ctrl.debug_dap_client.send_buffer[11].contains("\"command\":\"evaluate\"")).to_equal(true)
        expect(ctrl.debug_pending_watch_expressions.len()).to_equal(1)
        ctrl._debug_hydrate_dap_response("{\"seq\":1008,\"type\":\"response\",\"request_seq\":11,\"success\":true,\"command\":\"evaluate\",\"body\":{\"result\":\"42\",\"variablesReference\":0}}")
        expect(ctrl.debug_pending_watch_expressions.len()).to_equal(0)

        var dap = ctrl.debug_dap_client
        dap = editor_debug_dap_client_inject_message(dap, "{\"seq\":1007,\"type\":\"response\",\"request_seq\":7,\"success\":true,\"command\":\"stackTrace\",\"body\":{\"stackFrames\":[{\"id\":1,\"name\":\"main\",\"line\":2,\"column\":4,\"source\":{\"name\":\"main.spl\",\"path\":\"" + path + "\"}}],\"totalFrames\":1}}")
        dap = editor_debug_dap_client_inject_message(dap, "{\"seq\":2002,\"type\":\"event\",\"event\":\"stopped\",\"body\":{\"reason\":\"breakpoint\",\"threadId\":1}}")
        ctrl.debug_dap_client = dap
        val polled = ctrl._execute_palette_command("debug-poll", "")
        expect(polled.status_msg).to_equal("debug stopped: breakpoint")
        expect(ctrl.debug_pending_watch_expressions.len()).to_equal(1)
        expect(ctrl.debug_dap_client.send_buffer[12].contains("\"command\":\"evaluate\"")).to_equal(true)
        expect(ctrl.debug_status).to_equal("paused")
        expect(editor_debug_first_session(ctrl.debug_registry).stack_frames[0].path).to_equal(path)

        val terminated = ctrl._debug_terminate_first()
        expect(terminated.status_msg).to_equal("debug terminated")
        expect(ctrl.debug_dap_client.running).to_equal(false)

    it "starts debugging from the nearest VSCode launch.json configuration":
        val root = "/tmp/simple_editor_debug_launch"
        expect(dir_create_all(root + "/.vscode")).to_equal(true)
        expect(dir_create_all(root + "/src")).to_equal(true)
        val path = root + "/src/main.spl"
        expect(file_write(path, "fn main():\n    print(\"launch\")\n")).to_equal(true)
        val launch_json = "{\"version\":\"0.2.0\",\"configurations\":[{\"name\":\"Configured Simple\",\"type\":\"simple\",\"request\":\"launch\",\"program\":\"" + path + "\",\"cwd\":\"" + root + "\",\"args\":[\"--mode\",\"interpreter\"]}]}"
        expect(file_write(root + "/.vscode/launch.json", launch_json)).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        val started = ctrl._start_debug_adapter("simple")
        val debug_session = editor_debug_first_session(ctrl.debug_registry)

        expect(started.status_msg).to_equal("debug adapter: Configured Simple")
        expect(debug_session.config.name).to_equal("Configured Simple")
        expect(debug_session.config.cwd).to_equal(root)
        expect(debug_session.config.args.len()).to_equal(2)

