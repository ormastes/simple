        expect(dir_create_all(root)).to_equal(true)
        expect(file_write(active_path, "fn active_entry():\n    return\n")).to_equal(true)
        expect(file_write(sibling_path, "fn indexed_target():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(active_path)
        var ctrl: EditorController = EditorController.new(session)
        val indexed = ctrl._rebuild_workspace_symbol_index(root)
        expect(indexed.status_msg).to_equal("workspace symbols indexed: 2")

        val requested = ctrl._execute_palette_command("workspace-symbols", "indexed")

        expect(requested.status_msg).to_equal("workspace-symbols results")
        expect(ctrl.lsp_result_panel.title).to_equal("Workspace Symbols")
        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.rows.len()).to_equal(1)
        expect(ctrl.lsp_result_panel.rows[0].label).to_equal("indexed_target")
        expect(ctrl.lsp_result_panel.rows[0].path).to_equal(sibling_path)
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal(sibling_path + ":1")
        val workspace_symbol_request = ctrl.simple_lsp_state.client.transport.send_buffer[ctrl.simple_lsp_state.client.transport.send_buffer.len() - 1]
        expect(workspace_symbol_request.contains("\"query\": \"indexed\"")).to_equal(true)

    it "hydrates pending LSP result panels from async server responses":
        val path = "/tmp/simple_editor_lsp_hydrate.spl"
        val target_path = "/tmp/simple_editor_lsp_hydrate_target.spl"
        expect(file_write(path, "fn main():\n    val answer = 1\n    answer\n")).to_equal(true)
        expect(file_write(target_path, "fn target():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        val refs = ctrl._execute_palette_command("references", "")
        val request_id = ctrl.lsp_result_panel.request_id
        expect(refs.status_msg).to_equal("references results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val result_json = "[{\"uri\":\"file://" + target_path + "\",\"range\":{\"start\":{\"line\":1,\"character\":4},\"end\":{\"line\":1,\"character\":10}}}]"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        expect(lsp_response_from_json(response_json).result_json).to_equal(result_json)
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        val hydrated = ctrl._poll_lsp_results()
        expect(hydrated.status_msg).to_equal("lsp results updated")
        expect(ctrl.lsp_result_panel.request_id).to_equal(request_id)

