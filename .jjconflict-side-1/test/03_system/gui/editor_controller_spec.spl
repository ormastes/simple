    it "hydrates async LSP selection ranges into the result panel":
        val path = "/tmp/simple_editor_selection_ranges_ui.spl"
        expect(file_write(path, "fn main():\n    val answer = 1\n    answer\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        var buffer = ctrl.session.active_buffer()
        buffer.move_cursor(2, 8)
        ctrl.session.update_active_buffer(buffer)

        val requested = ctrl._execute_palette_command("selection-ranges", "")
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("selection-ranges results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)

        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        val result_json = "[{\"range\":{\"start\":{\"line\":2,\"character\":4},\"end\":{\"line\":2,\"character\":10}},\"parent\":{\"range\":{\"start\":{\"line\":2,\"character\":0},\"end\":{\"line\":2,\"character\":10}}}}]"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.lsp_result_panel.pending).to_equal(false)
        expect(ctrl.lsp_result_panel.title).to_equal("Selection Ranges")
        expect(ctrl.lsp_result_panel.rows.len()).to_equal(2)
        expect(ctrl.lsp_result_panel.rows[0].icon).to_equal("selection")
        expect(ctrl.lsp_result_panel.rows[0].detail).to_equal("line 3:5-3:11")
        expect(ctrl.lsp_result_panel.rows[1].depth).to_equal(1)

        val applied = ctrl._execute_palette_command("selection-expand", "")
        val selected_buffer = ctrl.session.active_buffer()
        expect(applied.status_msg).to_equal("selection range: 3:5-3:11")
        expect(selected_buffer.selection_range.active).to_equal(true)
        expect(selected_buffer.selection_range.start_row).to_equal(2)
        expect(selected_buffer.selection_range.start_col).to_equal(4)
        expect(selected_buffer.selection_range.end_row).to_equal(2)
        expect(selected_buffer.selection_range.end_col).to_equal(10)
        val selected_html = gui_render_editor_area(selected_buffer, "simple", selected_buffer.viewport)
        expect(selected_html.contains("class=\"selection-range\"")).to_equal(true)
        expect(selected_html.contains("data-start=\"4\" data-end=\"10\"")).to_equal(true)
        val selected_tui = tui_render_line_with_semantic_tokens(selected_buffer, 2, selected_buffer.line_at(2))
        expect(selected_tui.contains("\x1b[7manswer\x1b[0m")).to_equal(true)
        val expanded = ctrl.handle_key("Shift+Alt+Right", [])
        val expanded_buffer = ctrl.session.active_buffer()
        expect(expanded.status_msg).to_equal("selection range: 3:1-3:11")
        expect(expanded_buffer.selection_range.start_col).to_equal(0)
        expect(expanded_buffer.selection_range.end_col).to_equal(10)
        expect(ctrl.lsp_result_panel.selected).to_equal(1)

        val shrunk = ctrl.handle_key("Shift+Alt+Left", [])
        val shrunk_buffer = ctrl.session.active_buffer()
        expect(shrunk.status_msg).to_equal("selection range: 3:5-3:11")
        expect(shrunk_buffer.selection_range.start_col).to_equal(4)
        expect(shrunk_buffer.selection_range.end_col).to_equal(10)
        expect(ctrl.lsp_result_panel.selected).to_equal(0)

        shrunk_buffer.add_selection_range(1, 4, 1, 7)
        ctrl.session.update_active_buffer(shrunk_buffer)
        val reapplied = ctrl._dispatch_lsp_result_key("\r")
        val multi_buffer = ctrl.session.active_buffer()
        expect(reapplied.status_msg).to_equal("selection range: 3:5-3:11")
        expect(multi_buffer.selection_range_count()).to_equal(2)
        expect(multi_buffer.position_selected(2, 5)).to_equal(true)
        expect(multi_buffer.position_selected(1, 5)).to_equal(true)
        val preserved_html = gui_render_editor_area(multi_buffer, "simple", multi_buffer.viewport)
        expect(preserved_html.contains("data-start=\"4\" data-end=\"10\"")).to_equal(true)
        expect(preserved_html.contains("data-start=\"4\" data-end=\"7\"")).to_equal(true)

        val all_applied = ctrl._execute_palette_command("selection-apply-all", "")
        val all_buffer = ctrl.session.active_buffer()
        expect(all_applied.status_msg).to_equal("selection ranges applied: 2")
        expect(all_buffer.selection_range_count()).to_equal(2)
        expect(all_buffer.line_has_selection(2)).to_equal(true)
        val multi_html = gui_render_editor_area(all_buffer, "simple", all_buffer.viewport)
        expect(multi_html.contains("data-start=\"0\" data-end=\"10\"")).to_equal(true)
        val multi_tui = tui_render_line_with_semantic_tokens(all_buffer, 2, all_buffer.line_at(2))
        expect(multi_tui.contains("\x1b[7m")).to_equal(true)

    it "hydrates async LSP folding ranges into the result panel":
        val path = "/tmp/simple_editor_folding_ranges_ui.spl"
