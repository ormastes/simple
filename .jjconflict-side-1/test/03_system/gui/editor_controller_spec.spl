    it "opens Markdown links and wiki links under the cursor":
        val home_path = "/tmp/simple_editor_open_link_home.md"
        val target_path = "/tmp/simple editor open link target.md"
        val relative_path = "/tmp/simple_editor_open_link_relative.md"
        var missing_idx = 0
        var missing_title = "SimpleEditorCreatedNotePropertiesPanel20260513"
        var missing_path = "/tmp/" + missing_title + ".md"
        while file_exists(missing_path):
            missing_idx = missing_idx + 1
            missing_title = "SimpleEditorCreatedNote" + missing_idx.to_text()
            missing_path = "/tmp/" + missing_title + ".md"
        expect(file_write(home_path, "See [[simple editor open link target]] and [Relative](simple_editor_open_link_relative.md) and [[" + missing_title + "]]\n")).to_equal(true)
        expect(file_write(target_path, "# Target\n")).to_equal(true)
        expect(file_write(relative_path, "# Relative\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(home_path)
        session.open_file(target_path)
        session.open_file(home_path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl.vault_search_index = md_vault_search_index_new("/tmp", [md_wiki_document(home_path, file_read_text(home_path) ?? ""), md_wiki_document(target_path, file_read_text(target_path) ?? "")])
        var buffer = ctrl.session.active_buffer()
        buffer.move_cursor(0, 8)
        ctrl.session.update_active_buffer(buffer)

        val wiki_opened = ctrl._execute_palette_command("open-link", "")
        expect(wiki_opened.status_msg).to_equal("opened link: " + target_path)
        expect(ctrl.session.active_document().path()).to_equal(target_path)

        ctrl.session.open_file(home_path)
        ctrl._focus_lsp_target_path(home_path)
        buffer = ctrl.session.active_buffer()
        val relative_line = buffer.line_at(0)
        val relative_col = relative_line.index_of("Relative")
        buffer.move_cursor(0, relative_col)
        ctrl.session.update_active_buffer(buffer)

        ctrl.handle_key("g", [])
        val gx_opened = ctrl.handle_key("x", [])
        expect(gx_opened.status_msg).to_equal("opened link: " + relative_path)

        ctrl.session.open_file(home_path)
        ctrl._focus_lsp_target_path(home_path)
        buffer = ctrl.session.active_buffer()
        val missing_line = buffer.line_at(0)
        val missing_col = missing_line.index_of(missing_title)
        buffer.move_cursor(0, missing_col)
        ctrl.session.update_active_buffer(buffer)

        val created = ctrl._execute_palette_command("open-link", "")
        val missing_note_opened = created.status_msg == "created note: " + missing_path or created.status_msg == "opened link: " + missing_path
        expect(missing_note_opened).to_equal(true)
        expect(file_read_text(missing_path)).to_equal("# " + missing_title + "\n\n")
        expect(ctrl.session.active_document().path()).to_equal(missing_path)
        expect(md_vault_search_index_search(ctrl.vault_search_index, missing_title).len()).to_equal(1)

    it "hands external Markdown links to a configured browser command":
        expect(env_set("SIMPLE_EDITOR_BROWSER_COMMAND", "true")).to_equal(true)
        val path = "/tmp/simple_editor_external_link.md"
        expect(file_write(path, "[Docs](https://example.com/docs)\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        var buffer = ctrl.session.active_buffer()
        buffer.move_cursor(0, 2)
        ctrl.session.update_active_buffer(buffer)

        val opened = ctrl._execute_palette_command("open-link", "")
        expect(opened.status_msg).to_equal("opened external link: https://example.com/docs")
        expect(env_set("SIMPLE_EDITOR_BROWSER_COMMAND", "")).to_equal(true)

