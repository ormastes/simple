    it "folds and unfolds active Markdown sections from editor commands":
        val path = "/tmp/simple_editor_fold_controls.md"
        expect(file_write(path, "# One\nbody\n## Child\nchild body\n# Two\nnext\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        var active = ctrl.session.active_buffer()
        active.move_cursor(1, 0)
        ctrl.session.update_active_buffer(active)

        val folded = ctrl._execute_palette_command("fold-toggle", "")
        expect(folded.status_msg).to_equal("folded section")
        var buffer = ctrl.session.active_buffer()
        expect(buffer.has_fold_range(0, 3)).to_equal(true)
        expect(buffer.cursor_row).to_equal(0)
        expect(buffer.visible_line_at(1)).to_equal(4)

        val unfolded = ctrl._execute_palette_command("fold-toggle", "")
        expect(unfolded.status_msg).to_equal("unfolded section")
        buffer = ctrl.session.active_buffer()
        expect(buffer.folded_ranges.len()).to_equal(0)

        active = ctrl.session.active_buffer()
        active.move_cursor(1, 0)
        ctrl.session.update_active_buffer(active)
        val z_prefix = ctrl.handle_key("z", [])
        expect(z_prefix.status_msg).to_equal("z ...")
        val z_fold = ctrl.handle_key("a", [])
        expect(z_fold.status_msg).to_equal("folded section")
        buffer = ctrl.session.active_buffer()
        expect(buffer.has_fold_range(0, 3)).to_equal(true)
        expect(buffer.line_with_fold_marker(0).contains("| za]")).to_equal(true)
        val z_unfold_prefix = ctrl.handle_key("z", [])
        expect(z_unfold_prefix.status_msg).to_equal("z ...")
        val z_unfold = ctrl.handle_key("a", [])
        expect(z_unfold.status_msg).to_equal("unfolded section")
        buffer = ctrl.session.active_buffer()
        expect(buffer.folded_ranges.len()).to_equal(0)

        val fold_all = ctrl._execute_palette_command("markdown.foldAll", "")
        expect(fold_all.status_msg).to_start_with("folded ")
        buffer = ctrl.session.active_buffer()
        expect(buffer.folded_ranges.len()).to_be_greater_than(0)

        val unfold_all = ctrl._execute_palette_command("markdown.unfoldAll", "")
        expect(unfold_all.status_msg).to_equal("unfolded all")
        buffer = ctrl.session.active_buffer()
        expect(buffer.folded_ranges.len()).to_equal(0)

    it "toggles active Obsidian callout fold markers from editor commands":
        val path = "/tmp/simple_editor_callout_fold_controls.md"
        expect(file_write(path, "> [!TIP] Tip\n> Body\n")).to_equal(true)
