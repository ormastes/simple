    it "tracks VSCode-style debug breakpoints watches and termination in controller state":
        val path = "/tmp/simple_editor_debug_state.spl"
        expect(file_write(path, "fn main():\n    val answer = 1\n    answer\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        expect(ctrl._debug_add_breakpoint(path, 2, "answer > 0", "", "").status_msg).to_equal("no debug session")

        ctrl._start_debug_adapter("simple")
        val bp = ctrl._debug_add_breakpoint(path, 2, "answer > 0", "log answer", "3")
        expect(bp.status_msg).to_equal("breakpoint set: " + path + ":2")
        val watch = ctrl._execute_palette_command("debug-watch", "answer")
        expect(watch.status_msg).to_equal("watch added: answer")
        expect(ctrl.session.dock_layout.active_right).to_equal("wiki-panel")
        expect(ctrl.wiki_panel.title).to_equal("Debug Session")
        expect(ctrl.wiki_panel.rows[2].label).to_equal("answer")
        expect(ctrl.wiki_panel.rows[2].detail).to_equal("pending")
        expect(ctrl.debug_pending_watch_expressions.len()).to_equal(1)
        expect(ctrl.debug_dap_client.send_buffer[3].contains("\"command\":\"evaluate\"")).to_equal(true)
        val watch_eval_json = "{\"seq\":1001,\"type\":\"response\",\"request_seq\":4,\"success\":true,\"command\":\"evaluate\",\"body\":{\"result\":\"42\",\"variablesReference\":0}}"
        val watch_eval = ctrl._debug_hydrate_dap_response(watch_eval_json)
        expect(watch_eval.status_msg).to_equal("watch refreshed: answer")
        expect(ctrl.debug_pending_watch_expressions.len()).to_equal(0)
        expect(ctrl.wiki_panel.rows[2].detail).to_equal("42")
        val evaluated = ctrl._execute_palette_command("debug-evaluate", "answer + 1")
        expect(evaluated.status_msg).to_equal("debug evaluate: answer + 1")
        val watch_result = ctrl._debug_update_watch_result("answer", "1", "ok")
        expect(watch_result.status_msg).to_equal("watch: answer")
        expect(ctrl.wiki_panel.rows[2].detail).to_equal("1")
        val evaluate_result = ctrl._debug_record_evaluate_result("answer + 1", "2", "ok")
        expect(evaluate_result.status_msg).to_equal("debug result: answer + 1")
        val stack = ctrl._debug_update_stack_frames([
            EditorDebugStackFrame(id: 1, name: "main", path: path, line: 2, col: 4)
        ])
        expect(stack.status_msg).to_equal("debug stack")
        expect(ctrl.wiki_panel.rows[1].icon).to_equal("stack")
        expect(ctrl.wiki_panel.rows[1].label).to_equal("main")
        expect(ctrl.wiki_panel.rows[1].path).to_equal(path)
        val scopes = ctrl._debug_update_scopes([
            EditorDebugScope(name: "Locals", variables_reference: 10, variables: [])
        ])
        expect(scopes.status_msg).to_equal("debug scopes")
        expect(ctrl.wiki_panel.rows[2].icon).to_equal("scope")
        expect(ctrl.wiki_panel.rows[2].label).to_equal("Locals")
        val variables = ctrl._debug_update_scope_variables("Locals", [
            EditorDebugVariable(name: "answer", value: "1", debug_type: "i64", variables_reference: 0)
        ])
        expect(variables.status_msg).to_equal("debug variables: Locals")
        expect(ctrl.wiki_panel.rows[3].icon).to_equal("variable")
        expect(ctrl.wiki_panel.rows[3].label).to_equal("answer")
        expect(ctrl.wiki_panel.rows[3].detail).to_equal("1 : i64")
        val shown = ctrl._execute_palette_command("debug-console", "")
        expect(shown.status_msg).to_equal("debug session")
        expect(ctrl.wiki_panel.title).to_equal("Debug Session")
        val exceptions = ctrl._debug_set_exception_filters(["caught", "uncaught"])
        expect(exceptions.status_msg).to_equal("exception breakpoints set")
        expect(ctrl.wiki_panel.rows[4].icon).to_equal("exception")
        expect(ctrl.wiki_panel.rows[4].label).to_equal("caught")
        expect(ctrl.wiki_panel.rows[5].label).to_equal("uncaught")

        val debug_session = editor_debug_first_session(ctrl.debug_registry)
        expect(debug_session.breakpoints.len()).to_equal(1)
        expect(debug_session.breakpoints[0].condition).to_equal("answer > 0")
        expect(debug_session.breakpoints[0].log_message).to_equal("log answer")
        expect(debug_session.breakpoints[0].hit_condition).to_equal("3")
        expect(debug_session.watches.len()).to_equal(1)
        expect(debug_session.watches[0].expression).to_equal("answer")
        expect(debug_session.watches[0].last_value).to_equal("1")
        expect(debug_session.stack_frames[0].name).to_equal("main")
        expect(debug_session.scopes[0].variables[0].value).to_equal("1")
        expect(debug_session.console.len()).to_equal(4)
        expect(debug_session.exception_filters.len()).to_equal(2)
        expect(debug_session.exception_filters[0]).to_equal("caught")

        expect(ctrl._debug_continue().status_msg).to_equal("debug continue")
        expect(ctrl.debug_status).to_equal("running")
        expect(ctrl._debug_pause().status_msg).to_equal("debug pause")
        expect(ctrl.debug_status).to_equal("paused")
        expect(ctrl._debug_step("stepOver").status_msg).to_equal("debug stepOver")
        expect(ctrl.debug_status).to_equal("stepping")

        val terminated = ctrl._debug_terminate_first()
        expect(terminated.status_msg).to_equal("debug terminated")
        expect(ctrl.debug_status).to_equal("terminated")
        expect(editor_debug_first_session(ctrl.debug_registry).status).to_equal("terminated")
        var last_dap_index = ctrl.debug_dap_client.send_buffer.len() - 1
        expect(ctrl.debug_dap_client.send_buffer[last_dap_index].contains("\"command\":\"disconnect\"")).to_equal(true)
        val restarted = ctrl._debug_restart_first()
        expect(restarted.status_msg).to_equal("debug restart")
        expect(ctrl.debug_status).to_equal("restarting")
        expect(editor_debug_first_session(ctrl.debug_registry).status).to_equal("restarting")
        last_dap_index = ctrl.debug_dap_client.send_buffer.len() - 3
        expect(ctrl.debug_dap_client.send_buffer[last_dap_index].contains("\"command\":\"restart\"")).to_equal(true)
        expect(ctrl.debug_dap_client.send_buffer[last_dap_index + 1].contains("\"command\":\"initialize\"")).to_equal(true)
        expect(ctrl.debug_dap_client.send_buffer[last_dap_index + 2].contains("\"command\":\"launch\"")).to_equal(true)
        expect(ctrl._execute_palette_command("debug-restart", "").status_msg).to_equal("debug restart")
        expect(ctrl._execute_palette_command("debug-continue", "").status_msg).to_equal("debug continue")
        expect(ctrl.debug_status).to_equal("running")
        expect(ctrl._execute_palette_command("debug-pause", "").status_msg).to_equal("debug pause")
        expect(ctrl.debug_status).to_equal("paused")
        expect(ctrl._execute_palette_command("debug-step", "stepIn").status_msg).to_equal("debug stepIn")
        expect(ctrl.debug_status).to_equal("stepping")
        expect(ctrl._execute_palette_command("debug-exceptions", "caught, uncaught").status_msg).to_equal("exception breakpoints set")
        expect(editor_debug_first_session(ctrl.debug_registry).exception_filters[1]).to_equal("uncaught")
        expect(ctrl._execute_palette_command("debug-terminate", "").status_msg).to_equal("debug terminated")

    it "hydrates DAP lifecycle events into active debug status":
        val path = "/tmp/simple_editor_debug_dap_events.spl"
        expect(file_write(path, "fn main():\n    val answer = 42\n    answer\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl._start_debug_adapter("simple")

        val stopped = ctrl._debug_hydrate_dap_event("{\"seq\":2002,\"type\":\"event\",\"event\":\"stopped\",\"body\":{\"reason\":\"breakpoint\",\"threadId\":1}}")
        expect(stopped.status_msg).to_equal("debug stopped: breakpoint")
        expect(ctrl.debug_status).to_equal("paused")
        expect(editor_debug_first_session(ctrl.debug_registry).status).to_equal("paused")
        expect(ctrl.wiki_panel.title).to_equal("Debug Session")

        val continued = ctrl._debug_hydrate_dap_event("{\"seq\":2003,\"type\":\"event\",\"event\":\"continued\",\"body\":{\"threadId\":1}}")
        expect(continued.status_msg).to_equal("debug continued")
        expect(ctrl.debug_status).to_equal("running")
        expect(editor_debug_first_session(ctrl.debug_registry).status).to_equal("running")

        val terminated = ctrl._debug_hydrate_dap_event("{\"seq\":2004,\"type\":\"event\",\"event\":\"terminated\"}")
        expect(terminated.status_msg).to_equal("debug terminated")
        expect(ctrl.debug_status).to_equal("terminated")
        expect(editor_debug_first_session(ctrl.debug_registry).status).to_equal("terminated")

    it "shows and switches multiple debug sessions from the debug sessions panel":
        val first_path = "/tmp/simple_editor_debug_session_one.spl"
        val second_path = "/tmp/simple_editor_debug_session_two.spl"
        expect(file_write(first_path, "fn main():\n    1\n")).to_equal(true)
        expect(file_write(second_path, "fn main():\n    2\n")).to_equal(true)
