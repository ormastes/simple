    it "syncs multi-file LSP WorkspaceEdit quick fixes into open sibling buffers":
        val active_path = "/tmp/simple_editor_workspace_edit_open_active.md"
        val other_path = "/tmp/simple_editor_workspace_edit_open_other.md"
        expect(file_write(active_path, "Rename old here\n")).to_equal(true)
        expect(file_write(other_path, "Rename old there\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(active_path)
        session.open_file(other_path)
        session.open_file(active_path)
        var ctrl: EditorController = EditorController.new(session)

        val edit_json = "{\"changes\":{\"file://" + active_path + "\":[{\"range\":{\"start\":{\"line\":0,\"character\":7},\"end\":{\"line\":0,\"character\":10}},\"newText\":\"new\"}],\"file://" + other_path + "\":[{\"range\":{\"start\":{\"line\":0,\"character\":7},\"end\":{\"line\":0,\"character\":10}},\"newText\":\"new\"}]}}"
        ctrl.code_actions = [EditorCodeAction(title: "Apply LSP open multi edit", kind: "quickfix", edit_json: edit_json, command: "")]
        val applied = ctrl._execute_palette_command("quickfix-apply", "")

        var open_other_text = ""
        var open_other_dirty = false
        for doc in ctrl.session.documents:
            if doc.path() == other_path:
                open_other_text = doc.buffer.line_at(0)
                open_other_dirty = doc.buffer.dirty

        expect(applied.status_msg).to_equal("applied: Apply LSP open multi edit (1 file edits)")
        expect(ctrl.session.active_buffer().line_at(0)).to_equal("Rename new here")
        expect(open_other_text).to_equal("Rename new there")
        expect(open_other_dirty).to_equal(true)
        expect(file_read_text(other_path)).to_equal("Rename old there\n")

    it "executes command-only LSP code actions through workspace executeCommand":
        val path = "/tmp/simple_editor_code_action_command.spl"
        expect(file_write(path, "fn main():\n    return\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl._activate_active_language()

        val command_json = "{\"title\":\"Organize Imports\",\"command\":\"simple.organizeImports\",\"arguments\":[{\"uri\":\"file://" + path + "\"}]}"
        ctrl.code_actions = [EditorCodeAction(title: "Organize Imports", kind: "source.organizeImports", edit_json: "", command: command_json)]
        val applied = ctrl._execute_palette_command("quickfix-apply", "")

        expect(applied.status_msg).to_equal("command requested: simple.organizeImports")
        expect(ctrl.code_actions.len()).to_equal(0)
        val sent = ctrl.simple_lsp_state.client.transport.send_buffer[ctrl.simple_lsp_state.client.transport.send_buffer.len() - 1]
        expect(sent.contains("\"method\": \"workspace/executeCommand\"")).to_equal(true)
        expect(sent.contains("\"command\":\"simple.organizeImports\"")).to_equal(true)
        expect(sent.contains("\"arguments\":[{\"uri\":\"file://")).to_equal(true)

    it "applies edit-and-command LSP code actions before executeCommand":
        val path = "/tmp/simple_editor_code_action_edit_command.spl"
        expect(file_write(path, "Rename old now\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)
        ctrl._activate_active_language()

        val edit_json = "{\"changes\":{\"file://" + path + "\":[{\"range\":{\"start\":{\"line\":0,\"character\":7},\"end\":{\"line\":0,\"character\":10}},\"newText\":\"new\"}]}}"
        val command_json = "{\"command\":\"simple.postEdit\",\"arguments\":[\"done\"]}"
        ctrl.code_actions = [EditorCodeAction(title: "Apply and Notify", kind: "quickfix", edit_json: edit_json, command: command_json)]
        val applied = ctrl._execute_palette_command("quickfix-apply", "")

        expect(applied.status_msg).to_equal("applied: Apply and Notify; command requested: simple.postEdit")
        expect(ctrl.session.active_buffer().line_at(0)).to_equal("Rename new now")
        val sent = ctrl.simple_lsp_state.client.transport.send_buffer[ctrl.simple_lsp_state.client.transport.send_buffer.len() - 1]
        expect(sent.contains("\"method\": \"workspace/executeCommand\"")).to_equal(true)
        expect(sent.contains("\"command\":\"simple.postEdit\"")).to_equal(true)

    it "hydrates async LSP code actions into a selectable apply panel":
        val path = "/tmp/simple_editor_code_action_picker.spl"
        expect(file_write(path, "Rename old now\n")).to_equal(true)
        var session = EditSession.new()
        session.open_file(path)
        var ctrl: EditorController = EditorController.new(session)

        val requested = ctrl._execute_palette_command("code-action", "")
        val request_id = ctrl.simple_lsp_state.client.next_id - 1
        expect(requested.status_msg).to_equal("code-action results")
        expect(ctrl.lsp_result_panel.pending).to_equal(true)
        expect(ctrl.lsp_result_panel.title).to_equal("Code Actions")

        val first_edit = "{\"line\":0,\"newText\":\"Rename first now\"}"
        val second_edit = "{\"line\":0,\"newText\":\"Rename second now\"}"
        val result_json = "[{\"title\":\"First fix\",\"kind\":\"quickfix\",\"edit\":" + first_edit + "},{\"title\":\"Second fix\",\"kind\":\"quickfix\",\"edit\":" + second_edit + "}]"
        val response_json = "{\"jsonrpc\": \"2.0\", \"id\": " + request_id.to_text() + ", \"result\": " + result_json + "}"
        var client = ctrl.simple_lsp_state.client
        var transport = client.transport
        transport.recv_buffer.push(response_json)
        client.transport = transport
        var simple_state = ctrl.simple_lsp_state
        simple_state.client = client
        ctrl.simple_lsp_state = simple_state

        ctrl._refresh_lsp_results()

        expect(ctrl.code_actions.len()).to_equal(2)
        expect(ctrl.code_actions[1].edit_json.contains("second")).to_equal(true)
        val preview_apply = _editor_apply_code_action_content(ctrl.session.active_buffer(), path, ctrl.code_actions[1].edit_json)
        expect(preview_apply.content.trim()).to_equal("Rename second now")
        expect(ctrl.lsp_result_panel.title).to_equal("Code Actions")
        expect(ctrl.lsp_result_panel.rows[1].label).to_equal("Second fix")
        ctrl.lsp_result_panel = lsp_result_panel_select(ctrl.lsp_result_panel, 1)
        val applied = ctrl._dispatch_lsp_result_key("\r")

        expect(applied.status_msg).to_equal("applied: Second fix")
        expect(ctrl.session.active_buffer().line_at(0).trim()).to_equal("Rename second now")

