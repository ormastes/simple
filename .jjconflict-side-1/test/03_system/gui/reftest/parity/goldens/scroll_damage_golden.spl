# Golden fixture: scroll_damage — 2 DrawRects at different y offsets

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_red, sk_color_blue}

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    # First rect: top strip at y=0
    val rect1 = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 80.0)
    val paint1 = sk_paint_fill(sk_color_red())
    val op1 = sk_picture_op_draw_rect(rect1, paint1)
    # Second rect: offset lower strip at y=128 (simulating scroll offset)
    val rect2 = SkRect(left: 0.0, top: 128.0, right: 256.0, bottom: 208.0)
    val paint2 = sk_paint_fill(sk_color_blue())
    val op2 = sk_picture_op_draw_rect(rect2, paint2)
    val ops = [op1, op2]
    val picture = SkPicture(cull_rect: cull, op_count: 2, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
