# Golden fixture: dashed_strokes — 3 stroked horizontal lines at widths 1.0, 2.0, 4.0

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, sk_picture_op_draw_path}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.paint.{SkPaint, sk_paint_stroke}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_black}
use std.skia.entity.enums.{SkPathFillType}

fn _hline_path(y: f64) -> SkPath:
    val base = sk_path_new()
    val p1 = base.move_to(16.0, y)
    p1.line_to(240.0, y)

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    val black = sk_color_black()
    val path1 = _hline_path(64.0)
    val paint1 = sk_paint_stroke(black, 1.0)
    val op1 = sk_picture_op_draw_path(path1, paint1)
    val path2 = _hline_path(128.0)
    val paint2 = sk_paint_stroke(black, 2.0)
    val op2 = sk_picture_op_draw_path(path2, paint2)
    val path3 = _hline_path(192.0)
    val paint3 = sk_paint_stroke(black, 4.0)
    val op3 = sk_picture_op_draw_path(path3, paint3)
    val ops = [op1, op2, op3]
    val picture = SkPicture(cull_rect: cull, op_count: 3, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
