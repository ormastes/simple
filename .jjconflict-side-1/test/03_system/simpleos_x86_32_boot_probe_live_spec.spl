# @tag:system
#
# Opt-in live QEMU validation for the SimpleOS x86_32 boot/probe lane.

use std.spec

extern fn rt_env_get(name: text) -> text?
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

val SIMPLE_BIN: text = "src/compiler_rust/target/bootstrap/simple"
val LINKER_SCRIPT: text = "examples/simple_os/arch/x86_32/linker.ld"
val BUILD_SOURCES: text = "--source examples/simple_os/arch/x86_32"
val BUILD_PREFIX: text =
    "SIMPLE_BOOTSTRAP=1 SIMPLE_LIB=\"$(pwd)/src\" PATH=\"/usr/bin:$PATH\" {SIMPLE_BIN} native-build"
val QEMU_BASE: text =
    "qemu-system-i386 -machine pc -cpu qemu32 -serial stdio -display none -no-reboot"
val DEBUG_EXIT: text = "-device isa-debug-exit,iobase=0xf4,iosize=0x04"
val PROBE_MARKER: text = "[probe browser-x86] spl_start"
val INT80_MARKER: text = "[int80 probe] brk ok"
val INT80_SYSCALL_MARKER: text = "[int80 syscall] brk ok"
val PROCESS_CREATE_MARKER: text = "[x86_32 process] create ok"
val PROCESS_BRK_MARKER: text = "[x86_32 process] brk ok"
val PROCESS_REBOOT_MARKER: text = "[x86_32 process] reboot ok"
val PROCESS_DIAGNOSTICS_MARKER: text = "[x86_32 process] diagnostics ok"
val SHELL_SMOKE_MARKER: text = "[x86_32 shell] smoke ok"
val PROCESS_SHELL_MARKER: text = "[x86_32 process] shell-smoke ok"
val FS_INITRD_MARKER: text = "[x86_32 fs] initrd fat32 ok"
val FS_HELLO_MARKER: text = "[x86_32 fs] hello_world smf ok"
val FS_BROWSER_MARKER: text = "[x86_32 fs] browser smf ok"
val FS_ARCH_MARKER: text = "[x86_32 fs] x86_32 payload ok"
val FS_EXEC_MARKER: text = "[x86_32 fs] app execution ok"

fn _enabled() -> bool:
    (rt_env_get("SIMPLEOS_QEMU_X86_32_BOOT_LIVE") ?? "") == "1"

fn _run_shell(command: text) -> (text, text, i64):
    rt_process_run("/bin/sh", ["-c", command])

fn _qemu_available() -> bool:
    val result = _run_shell("command -v qemu-system-i386 >/dev/null 2>&1")
    result[2] == 0

fn _build_probe(output: text) -> (bool, text):
    val command = "{BUILD_PREFIX} {BUILD_SOURCES} --backend llvm --entry-closure --entry examples/simple_os/arch/x86_32/browser_probe_entry.spl --target i686-unknown-none -o {output} --linker-script {LINKER_SCRIPT}"
    val result = _run_shell(command)
    val log = result[0] + result[1]
    if result[2] != 0:
        print "[simpleos_x86_32_boot_probe_live_spec] build failed exit={result[2]}"
        print log
        return (false, log)
    if not rt_file_exists(output):
        print "[simpleos_x86_32_boot_probe_live_spec] build output missing: {output}"
        return (false, log)
    (true, log)

fn _build_int80_probe(output: text) -> (bool, text):
    val command = "{BUILD_PREFIX} {BUILD_SOURCES} --backend llvm --entry-closure --entry examples/simple_os/arch/x86_32/int80_probe_entry.spl --target i686-unknown-none -o {output} --linker-script {LINKER_SCRIPT}"
    val result = _run_shell(command)
    val log = result[0] + result[1]
    if result[2] != 0:
        print "[simpleos_x86_32_boot_probe_live_spec] int80 build failed exit={result[2]}"
        print log
        return (false, log)
    if not rt_file_exists(output):
        print "[simpleos_x86_32_boot_probe_live_spec] int80 build output missing: {output}"
        return (false, log)
    (true, log)

fn _build_int80_syscall_probe(output: text) -> (bool, text):
    val command = "{BUILD_PREFIX} {BUILD_SOURCES} --backend llvm --entry-closure --entry examples/simple_os/arch/x86_32/int80_syscall_probe_entry.spl --target i686-unknown-none -o {output} --linker-script {LINKER_SCRIPT}"
    val result = _run_shell(command)
    val log = result[0] + result[1]
    if result[2] != 0:
        print "[simpleos_x86_32_boot_probe_live_spec] int80 syscall build failed exit={result[2]}"
        print log
        return (false, log)
    if not rt_file_exists(output):
        print "[simpleos_x86_32_boot_probe_live_spec] int80 syscall build output missing: {output}"
        return (false, log)
    (true, log)

fn _build_int80_process_shell_probe(output: text) -> (bool, text):
    val command = "{BUILD_PREFIX} {BUILD_SOURCES} --backend llvm --entry-closure --entry examples/simple_os/arch/x86_32/int80_process_shell_probe_entry.spl --target i686-unknown-none -o {output} --linker-script {LINKER_SCRIPT}"
    val result = _run_shell(command)
    val log = result[0] + result[1]
    if result[2] != 0:
        print "[simpleos_x86_32_boot_probe_live_spec] int80 process shell build failed exit={result[2]}"
        print log
        return (false, log)
    if not rt_file_exists(output):
        print "[simpleos_x86_32_boot_probe_live_spec] int80 process shell build output missing: {output}"
        return (false, log)
    (true, log)

fn _build_initrd_fs_exec_probe(output: text) -> (bool, text):
    val command = "{BUILD_PREFIX} {BUILD_SOURCES} --backend llvm --entry-closure --entry examples/simple_os/arch/x86_32/initrd_fs_exec_probe_entry.spl --target i686-unknown-none -o {output} --linker-script {LINKER_SCRIPT}"
    val result = _run_shell(command)
    val log = result[0] + result[1]
    if result[2] != 0:
        print "[simpleos_x86_32_boot_probe_live_spec] initrd fs-exec build failed exit={result[2]}"
        print log
        return (false, log)
    if not rt_file_exists(output):
        print "[simpleos_x86_32_boot_probe_live_spec] initrd fs-exec build output missing: {output}"
        return (false, log)
    (true, log)

fn _ensure_x86_32_fs_exec_image(img_path: text) -> (bool, text):
    val command = "sh scripts/os/make_os_disk.shs 64 {img_path} \"\" x86_32"
    val result = _run_shell(command)
    val log = result[0] + result[1]
    if result[2] != 0:
        print "[simpleos_x86_32_boot_probe_live_spec] fs image build failed exit={result[2]}"
        print log
        return (false, log)
    if not rt_file_exists(img_path):
        print "[simpleos_x86_32_boot_probe_live_spec] fs image missing: {img_path}"
        return (false, log)
    (true, log)

fn _build_prerequisite_missing(log: text) -> bool:
    log.contains("LLVM backend requested but 'llvm' feature not enabled") or
        log.contains("native backend 'llvm' is not available in this build") or
        log.contains("Support for this target has not been implemented yet")

fn _run_probe(kernel: text) -> (text, i64):
    val command = "timeout 10s {QEMU_BASE} -m 128M -kernel {kernel} {DEBUG_EXIT} 2>&1 | tr -d '\\000'"
    val result = _run_shell(command)
    (result[0] + result[1], result[2])

fn _run_probe_with_initrd(kernel: text, initrd: text) -> (text, i64):
    val command = "timeout 10s {QEMU_BASE} -m 128M -kernel {kernel} -initrd {initrd} {DEBUG_EXIT} 2>&1 | tr -d '\\000'"
    val result = _run_shell(command)
    (result[0] + result[1], result[2])

describe "SimpleOS x86_32 boot-probe live QEMU lane":
    """Live x86_32 validation, disabled unless SIMPLEOS_QEMU_X86_32_BOOT_LIVE=1."""

    it "boots the x86_32 browser probe to spl_start":
        """When enabled, QEMU serial output must show the x86_32 probe marker."""
        if not _enabled():
            expect(_enabled()).to_equal(false)
        elif not _qemu_available():
            expect(_qemu_available()).to_equal(false)
        else:
            val output_path = "build/os/simpleos_x86_32_browser_probe.elf"
            val build = _build_probe(output_path)
            if not build[0]:
                expect(_build_prerequisite_missing(build[1])).to_equal(true)
            else:
                val result = _run_probe(output_path)
                val serial = result[0]
                if not serial.contains(PROBE_MARKER):
                    print "[simpleos_x86_32_boot_probe_live_spec] qemu exit={result[1]}"
                    print serial
                expect(serial.contains(PROBE_MARKER)).to_equal(true)

    it "routes a live int 0x80 trap through the i386 IDT gate":
        """When enabled, QEMU serial output must show the int80 probe marker."""
        if not _enabled():
            expect(_enabled()).to_equal(false)
        elif not _qemu_available():
            expect(_qemu_available()).to_equal(false)
        else:
            val output_path = "build/os/simpleos_x86_32_int80_probe.elf"
            val build = _build_int80_probe(output_path)
            if not build[0]:
                expect(_build_prerequisite_missing(build[1])).to_equal(true)
            else:
                val result = _run_probe(output_path)
                val serial = result[0]
                if not serial.contains(INT80_MARKER):
                    print "[simpleos_x86_32_boot_probe_live_spec] int80 qemu exit={result[1]}"
                    print serial
                expect(serial.contains(INT80_MARKER)).to_equal(true)

    it "routes live int 0x80 through the installed Simple syscall runtime":
        """When enabled, the real x86_32 syscall runtime must handle brk."""
        if not _enabled():
            expect(_enabled()).to_equal(false)
        elif not _qemu_available():
            expect(_qemu_available()).to_equal(false)
        else:
            val output_path = "build/os/simpleos_x86_32_int80_syscall_probe.elf"
            val build = _build_int80_syscall_probe(output_path)
            if not build[0]:
                expect(_build_prerequisite_missing(build[1])).to_equal(true)
            else:
                val result = _run_probe(output_path)
                val serial = result[0]
                if not serial.contains(INT80_SYSCALL_MARKER):
                    print "[simpleos_x86_32_boot_probe_live_spec] int80 syscall qemu exit={result[1]}"
                    print serial
                expect(serial.contains(INT80_SYSCALL_MARKER)).to_equal(true)

    it "routes live x86_32 process and shell smoke through the installed runtime":
        """When enabled, i386 process, brk, reboot, diagnostics, and shell markers must pass."""
        if not _enabled():
            expect(_enabled()).to_equal(false)
        elif not _qemu_available():
            expect(_qemu_available()).to_equal(false)
        else:
            val output_path = "build/os/simpleos_x86_32_int80_process_shell_probe.elf"
            val build = _build_int80_process_shell_probe(output_path)
            if not build[0]:
                expect(_build_prerequisite_missing(build[1])).to_equal(true)
            else:
                val result = _run_probe(output_path)
                val serial = result[0]
                if not serial.contains(PROCESS_SHELL_MARKER):
                    print "[simpleos_x86_32_boot_probe_live_spec] int80 process shell qemu exit={result[1]}"
                    print serial
                expect(serial.contains(PROCESS_CREATE_MARKER)).to_equal(true)
                expect(serial.contains(PROCESS_BRK_MARKER)).to_equal(true)
                expect(serial.contains(PROCESS_REBOOT_MARKER)).to_equal(true)
                expect(serial.contains(PROCESS_DIAGNOSTICS_MARKER)).to_equal(true)
                expect(serial.contains(SHELL_SMOKE_MARKER)).to_equal(true)
                expect(serial.contains(PROCESS_SHELL_MARKER)).to_equal(true)

    it "executes x86_32 filesystem-backed app payloads from a FAT32 initrd image":
        """When enabled, the i386 lane must find staged app payloads in a live QEMU filesystem image."""
        if not _enabled():
            expect(_enabled()).to_equal(false)
        elif not _qemu_available():
            expect(_qemu_available()).to_equal(false)
        else:
            val output_path = "build/os/simpleos_x86_32_initrd_fs_exec_probe.elf"
            val image_path = "build/os/simpleos_x86_32_fs_exec.img"
            val image = _ensure_x86_32_fs_exec_image(image_path)
            val build = _build_initrd_fs_exec_probe(output_path)
            if not image[0]:
                expect(false).to_equal(true)
            elif not build[0]:
                expect(_build_prerequisite_missing(build[1])).to_equal(true)
            else:
                val result = _run_probe_with_initrd(output_path, image_path)
                val serial = result[0]
                if not serial.contains(FS_EXEC_MARKER):
                    print "[simpleos_x86_32_boot_probe_live_spec] initrd fs-exec qemu exit={result[1]}"
                    print serial
                expect(serial.contains(FS_INITRD_MARKER)).to_equal(true)
                expect(serial.contains(FS_HELLO_MARKER)).to_equal(true)
                expect(serial.contains(FS_BROWSER_MARKER)).to_equal(true)
                expect(serial.contains(FS_ARCH_MARKER)).to_equal(true)
                expect(serial.contains(FS_EXEC_MARKER)).to_equal(true)
