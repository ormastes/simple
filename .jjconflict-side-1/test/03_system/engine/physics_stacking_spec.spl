# Physics2 Stacking Tower — System Test
#
# Verifies: AABB-AABB collision, gravity, position correction,
# settling behavior, BVH with many bodies.

use std.io_runtime
use std.spec.{describe, it, expect}
use std.common.math.{math_sqrt, math_abs}
use std.common.engine.ids.{NodeId, RawHandle}
use std.common.engine.math2d.{Vec2}
use std.nogc_sync_mut.engine.physics.config.{default_physics_config_2d}
use std.nogc_sync_mut.engine.physics.world2d.{PhysicsWorld2D}

fn make_node(idx: i64) -> NodeId:
    NodeId(raw: RawHandle.new(idx, 1))

fn make_stack_world(num_crates: i64) -> PhysicsWorld2D:
    var config = default_physics_config_2d()
    config.restitution = 0.1
    config.friction = 0.5
    var world = PhysicsWorld2D.create(config)
    # Floor
    world.add_static_body(make_node(100), 0.0, 0.0)
    world.add_box_collider(make_node(100), 10.0, 0.5)
    # Stack crates vertically
    var i = 0
    while i < num_crates:
        val nid = i + 1
        val y = 1.5 + i.to_f64() * 1.2
        world.add_dynamic_body(make_node(nid), 0.0, y, 1.0)
        world.add_box_collider(make_node(nid), 0.5, 0.5)
        i = i + 1
    world

fn step_n(world: PhysicsWorld2D, n: i64):
    var i = 0
    while i < n:
        world.step(0.016)
        i = i + 1

fn all_above_floor(world: PhysicsWorld2D, num_crates: i64) -> bool:
    var i = 0
    while i < num_crates:
        val pos = world.get_position(make_node(i + 1))
        if pos.y < -0.5:
            return false
        i = i + 1
    true

fn max_height(world: PhysicsWorld2D, num_crates: i64) -> f64:
    var max_y = 0.0
    var i = 0
    while i < num_crates:
        val pos = world.get_position(make_node(i + 1))
        if pos.y > max_y:
            max_y = pos.y
        i = i + 1
    max_y

describe "Physics2 Stacking System":
    it "crates settle above floor":
        var world = make_stack_world(3)
        step_n(world, 100)
        expect(all_above_floor(world, 3)).to_equal(true)
        world.destroy()

    it "stack height bounded":
        var world = make_stack_world(3)
        step_n(world, 100)
        val h = max_height(world, 3)
        expect(h < 10.0).to_equal(true)
        expect(h > 0.5).to_equal(true)
        world.destroy()

    it "gravity pulls crates down":
        var world = make_stack_world(1)
        val before = world.get_position(make_node(1))
        step_n(world, 20)
        val after = world.get_position(make_node(1))
        expect(after.y < before.y).to_equal(true)
        world.destroy()

    it "floor stops falling crate":
        var world = make_stack_world(1)
        step_n(world, 150)
        val pos = world.get_position(make_node(1))
        expect(pos.y > 0.0).to_equal(true)
        expect(pos.y < 3.0).to_equal(true)
        world.destroy()
