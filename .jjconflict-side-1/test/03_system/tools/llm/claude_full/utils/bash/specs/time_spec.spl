"""
# Claude Full bash time spec

Pure Simple coverage for time command metadata.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.bash.specs.time.*

describe "Claude full bash time command spec":
    it "exposes time command metadata":
        step("Check command metadata")
        val spec = timeCommandSpec()
        expect(spec.name).to_equal("time")
        expect(spec.description).to_equal("Time a command")

    it "exposes command args":
        step("Check arg metadata")
        val spec = timeCommandSpec()
        if val args = spec.args:
            expect(args.name).to_equal("command")
            expect(args.description).to_equal("Command to time")
            expect(args.isOptional).to_be_nil()
            expect(args.isVariadic).to_be_nil()
            expect(args.isCommand).to_equal(Some(true))
        else:
            expect(false).to_equal(true)
