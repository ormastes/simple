"""
# Claude Full Dialog Memory Message Components

Modern SSpec coverage for dialog, memory, reconnect, and message helper parity models.
"""

use std.spec.*
use app.llm_caret.claude_full.components.MCPServerDesktopImportDialog.*
use app.llm_caret.claude_full.components.MCPServerDialogCopy.*
use app.llm_caret.claude_full.components.MCPServerMultiselectDialog.*
use app.llm_caret.claude_full.components.MemoryUsageIndicator.*
use app.llm_caret.claude_full.components.MessageModel.*
use app.llm_caret.claude_full.components.MessageResponse.*
use app.llm_caret.claude_full.components.memory.MemoryUpdateNotification.*
use app.llm_caret.claude_full.components.memory.MemoryFileSelector.*
use app.llm_caret.claude_full.components.mcp.utils.reconnectHelpers.*
use app.llm_caret.claude_full.components.messageActions.*

describe "Claude full dialog memory and message parity":
    it "should model MCP dialog copy and reconnect helpers":
        step("Render MCP copy")
        expect(mcpServerDialogCopyText()).to_contain("All tool calls require approval")
        expect(mcpServerDialogCopyLink()).to_equal("https://code.claude.com/docs/en/mcp")

        step("Handle reconnect result states")
        val connected = handleReconnectResult(ReconnectAttemptResult.new("connected", 1, 0, 0), "github")
        expect(connected.success).to_equal(true)
        expect(connected.message).to_equal("Reconnected to github.")
        expect(handleReconnectResult(ReconnectAttemptResult.new("needs-auth", 0, 0, 0), "github").message).to_contain("Authenticate")
        expect(handleReconnectError("network", "github")).to_equal("Error reconnecting to github: network")
        expect(reconnectResultHasPayload(ReconnectAttemptResult.new("connected", 0, 1, 0))).to_equal(true)

    it "should model desktop import and multiselect flows":
        step("Plan desktop imports with collisions")
        val servers = [MCPDesktopImportServer.new("github", "http"), MCPDesktopImportServer.new("fs", "stdio")]
        val model = mcpDesktopImportDialogModel(servers, ["github"])
        expect(model.warning).to_contain("numbered suffix")
        expect(model.options[0].has_collision).to_equal(true)
        expect(model.defaults[0]).to_equal("fs")
        val plan = mcpDesktopImportPlan(servers, ["github", "fs"], ["github"])
        expect(plan[0].final_name).to_equal("github_1")
        expect(mcpDesktopImportSummary(servers, ["fs"], [], "project")).to_contain("Successfully imported 1")

        step("Apply multiselect choices")
        val settings = MCPServerMultiselectSettings.new([], [])
        val update = mcpMultiselectApplySubmit(["github", "fs"], ["github"], settings)
        expect(update.approved_count).to_equal(1)
        expect(update.rejected_count).to_equal(1)
        expect(update.settings.enabled_mcpjson_servers[0]).to_equal("github")
        expect(update.settings.disabled_mcpjson_servers[0]).to_equal("fs")
        expect(mcpMultiselectDialogSummary(["github", "fs"], ["github"], settings)).to_contain("approved=1")

    it "should model memory notification and usage indicators":
        step("Choose the shortest memory path")
        expect(getRelativeMemoryPath("/home/me/project/CLAUDE.md", "/home/me", "/home/me/project")).to_equal("./CLAUDE.md")
        expect(memoryUpdateNotification("/home/me/.claude/CLAUDE.md", "/home/me", "/work").message).to_contain("~/.claude/CLAUDE.md")

        step("Render high memory indicator")
        expect(memoryUsageIndicator(MemoryUsageSnapshot.new(100, "normal"), "100 B", true).visible).to_equal(false)
        val high = memoryUsageIndicator(MemoryUsageSnapshot.new(100, "critical"), "100 MB", true)
        expect(high.visible).to_equal(true)
        expect(high.color).to_equal("error")
        expect(memoryUsageIndicator(MemoryUsageSnapshot.new(100, "warning"), "100 MB", false).visible).to_equal(false)

    it "should model memory file selector options and toggles":
        step("Build file and folder options")
        val state = MemoryFileSelectorState.new(true, true, true, false, 0, -1, "/repo/docs/CLAUDE.md")
        expect(memoryFileSelectorAutoDreamRow(state)).to_equal("Auto-dream: on - never - /dream to run")
        expect(memoryFileSelectorSelectionAction(memoryFileSelectorFolderValue("/team"))).to_equal("open-folder:/team")

        step("Navigate selector toggles")
        expect(memoryFileSelectorConfirmAction(0)).to_equal("toggle-auto-memory")
        expect(memoryFileSelectorNextFocusedToggle(0, 1)).to_equal(1)
        expect(memoryFileSelectorPreviousFocusedToggle(1)).to_equal(0)

    it "should model message model and response wrapper":
        step("Show assistant model only in transcript text messages")
        val msg = MessageModelMessage.new("assistant", "claude-opus", [MessageContentBlock.new("text")])
        val render = messageModelRender(msg, true)
        expect(render.visible).to_equal(true)
        expect(render.minWidth).to_equal("claude-opus".len() + 8)
        expect(messageModelRender(msg, false).visible).to_equal(false)

        step("Wrap top-level message responses")
        val response = MessageResponse("hello", -1, false)
        expect(response.mode).to_equal("framed")
        expect(response.ratchetLock).to_equal("offscreen")
        expect(MessageResponse("hello", 4, true).mode).to_equal("nested")

    it "should model message action navigation and copy":
        step("Detect navigable messages and primary tool input")
        val bash = MessageActionsMessage.assistant("a1", MessageActionsBlock.toolUse("Bash", [MessageActionsField.new("command", "ls")]))
        expect(messageActionsIsNavigableMessage(bash)).to_equal(true)
        expect(messageActionsCopyTextOf(bash)).to_equal("ls")
        expect(messageActionsPrimaryInputLabel("WebSearch")).to_equal("query")

        step("Dispatch copy and edit actions")
        val cursor = MessageActionsState.new("u1", "user", false, "")
        val user = MessageActionsMessage.user("u1", MessageActionsBlock.textBlock("<system-reminder>x</system-reminder>hello"), false, false)
        expect(messageActionsBarLabels(cursor)[0]).to_equal("enter edit")
        expect(messageActionsDispatch("messageActions:enter", Some(cursor), Some(user)).kind).to_equal("edit")
        expect(messageActionsDispatch("messageActions:c", Some(cursor), Some(user)).copy_text).to_equal("hello")

    it "should check modeled TypeScript source floors":
        step("Read line helpers")
        expect(mcpServerDesktopImportDialogSourceLinesModeled()).to_equal(202)
        expect(mcpServerDialogCopySourceLinesModeled()).to_equal(14)
        expect(mcpServerMultiselectDialogSourceLinesModeled()).to_equal(132)
        expect(memoryUsageIndicatorSourceLinesModeled()).to_equal(36)
        expect(memoryUpdateNotificationSourceLinesModeled()).to_equal(44)
        expect(memoryFileSelectorSourceLinesModeled()).to_equal(437)
        expect(messageModelSourceLinesModeled()).to_equal(42)
        expect(messageResponseSourceLinesModeled()).to_equal(77)
        expect(messageActionsSourceLinesModeled()).to_equal(449)
        expect(reconnectHelpersSourceLinesModeled()).to_equal(48)
