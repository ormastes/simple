# A source body wins over an ordinary same-named runtime SFFI import, while a
# compiler-generated collection intrinsic stays runtime-owned.
fn rt_array_len_safe<T>(array: [T]) -> i64:
    array.len()

fn rt_array_len(value: i64) -> i64:
    value + 2

fn rt_array_get(array: i64, index: i64) -> i64:
    -99

fn rt_array_set(array: i64, index: i64, value: i64) -> i64:
    -98

fn main() -> i64:
    var items = [10, 20, 30, 40]
    print(rt_array_len_safe(items))
    print(items[1])
    items[1] = 25
    print(items[1])
    0
