## mod_unit_param.spl — MINIMAL REPRO for the P1 bug
## Demonstrates: parameter or variable named "unit" -> expression parsed as Identifier("Unit")
## -> lookup fails in both JIT/HIR path and interpreter path.
##
## Expected output: ops/sec 42
## Actual (both JIT and interpreter): error "Unknown variable: Unit" / "variable Unit not found"
##
## Root cause: expressions/primary/identifiers.rs:74
##   TokenKind::Unit => self.parse_keyword_identifier("Unit")   <-- capital "Unit"
## But expect_identifier (for param declarations):
##   TokenKind::Unit => "unit".to_string()                       <-- lowercase "unit"
## Mismatch: parameter stored as "unit", looked up as "Unit" in body expression.

struct MyResult:
    val_field: text

fn make_result(unit: text) -> MyResult:
    MyResult(
        val_field: unit,
    )

fn main():
    val r = make_result("ops/sec")
    print(r.val_field)
