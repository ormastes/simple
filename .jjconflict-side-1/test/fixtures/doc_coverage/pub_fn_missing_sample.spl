# Fixture for fmt/doc-coverage sanity check (Worker R, 2026-07-17).
# One documented pub fn + one undocumented pub fn for the wired
# `simple doc-coverage` grep-based scanner (app.stats.doc_coverage_dynamic).

# This function has a preceding comment and counts as documented.
pub fn documented_thing(x: i64) -> i64:
    x + 1

pub fn orphan_fn(x: i64) -> i64:
    x - 1
