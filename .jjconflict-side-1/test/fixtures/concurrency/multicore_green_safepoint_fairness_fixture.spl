use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism, multicore_green_parallelism, multicore_green_safepoint, multicore_green_submitted_count, multicore_green_completed_count, multicore_green_pending_count, multicore_green_busy_count}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_thread_sleep(ms: i64)
extern fn rt_exit(code: i32)

fn spin_for_us_with_safepoint(target_us: i64, value: i64) -> i64:
    val start = rt_time_now_unix_micros()
    var last_poll = start
    while rt_time_now_unix_micros() - start < target_us:
        _ = 1 + 1
        val now = rt_time_now_unix_micros()
        if now - last_poll >= 1000:
            multicore_green_safepoint()
            last_poll = now
    return value

fn main() -> i64:
    multicore_green_set_parallelism(1)
    println("parallelism_before={multicore_green_parallelism()}")
    val submitted_before = multicore_green_submitted_count()
    println("submitted_before={submitted_before}")
    val h0 = multicore_green_spawn(\: spin_for_us_with_safepoint(120000, 2))
    rt_thread_sleep(10)
    val h1 = multicore_green_spawn(\: 7)
    val h2 = multicore_green_spawn(\: 11)
    rt_thread_sleep(20)
    val quick_a_done_during_spin = h1.is_done()
    val quick_b_done_during_spin = h2.is_done()
    println("quick_a_done_during_spin={quick_a_done_during_spin}")
    println("quick_b_done_during_spin={quick_b_done_during_spin}")
    println("submitted_during_spin={multicore_green_submitted_count()}")
    println("completed_during_spin={multicore_green_completed_count()}")
    println("pending_during_spin={multicore_green_pending_count()}")
    println("busy_during_spin={multicore_green_busy_count()}")
    val slow = h0.join()
    val quick_a = h1.join()
    val quick_b = h2.join()
    val total = slow + quick_a + quick_b
    val submitted_after_join = multicore_green_submitted_count()
    val completed_after_join = multicore_green_completed_count()
    val pending_after_join = multicore_green_pending_count()
    val busy_after_join = multicore_green_busy_count()
    println("slow={slow}")
    println("quick_a={quick_a}")
    println("quick_b={quick_b}")
    println("submitted_after_join={submitted_after_join}")
    println("completed_after_join={completed_after_join}")
    println("pending_after_join={pending_after_join}")
    println("busy_after_join={busy_after_join}")
    println("total={total}")
    if total != 20:
        rt_exit(71)
    if !quick_a_done_during_spin:
        rt_exit(72)
    if !quick_b_done_during_spin:
        rt_exit(73)
    if submitted_after_join - submitted_before < 3:
        rt_exit(74)
    if completed_after_join < 3:
        rt_exit(75)
    if pending_after_join != 0:
        rt_exit(76)
    if busy_after_join != 0:
        rt_exit(77)
    0
