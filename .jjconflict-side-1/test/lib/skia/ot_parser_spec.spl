describe "parse_cff_charstring":
    it "returns Some empty path for endchar-only charstring":
        # Build font with CFF table containing just an endchar opcode (14)
        # CFF tag = 0x43464620 = 1128678944
        # hdrSize = 4, so charstring scanning starts at base+4
        val buf: [u8] = [
            0, 1, 0, 0,
            0, 1,
            0, 16,
            0, 0,
            0, 1,
            # table record for CFF:
            67, 70, 70, 32,
            0, 0, 0, 0,
            0, 0, 0, 28,
            0, 0, 0, 5,
            # CFF data: header major=1 minor=0 hdrSize=4 offSize=1, then endchar
            1, 0, 4, 1,
            14                 # endchar opcode
        ]
        val font_opt = parse_offset_table(buf)
        val font = font_opt.unwrap()
        val result = parse_cff_charstring(font, 0)
        expect(result == None).to_equal(false)
        val path = result.unwrap()
        expect(path.is_empty()).to_equal(true)

