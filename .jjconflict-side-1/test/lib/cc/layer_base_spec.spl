# Tests for cc::Layer base (layer_base.spl) — Chromium-mirroring compositor
# input layer type. Covers default construction, tree-index initialization,
# root detection, opacity clamping, bounds mutation, and child list ops.

use std.sspec.*
use std.lib.cc.entity.layer_base.{
    Layer, LayerId, LayerType, layer_new, layer_id_new
}
use std.skia.entity.geometry.{SkRect, SkPoint, sk_rect, sk_point}
use std.skia.entity.color.{SkColor4f, sk_color4f}

fn _make_layer(idv: i64) -> Layer:
    layer_new(layer_id_new(idv), sk_rect(0.0, 0.0, 100.0, 50.0), LayerType.Content)

describe "cc::Layer base":
    it "layer_new: default opacity 1.0, is_drawable true, contents_opaque false":
        val l = _make_layer(1)
        expect(l.opacity).to_equal(1.0)
        expect(l.is_drawable).to_equal(true)
        expect(l.contents_opaque).to_equal(false)

    it "layer_new: all tree indices are -1":
        val l = _make_layer(2)
        expect(l.transform_tree_index).to_equal(-1)
        expect(l.clip_tree_index).to_equal(-1)
        expect(l.effect_tree_index).to_equal(-1)
        expect(l.scroll_tree_index).to_equal(-1)

    it "is_root: parent_id -1 returns true":
        val l = _make_layer(3)
        expect(l.is_root()).to_equal(true)

    it "set_opacity: clamped to [0, 1]":
        val l = _make_layer(4)
        l.set_opacity(2.5)
        expect(l.opacity).to_equal(1.0)
        l.set_opacity(-0.3)
        expect(l.opacity).to_equal(0.0)
        l.set_opacity(0.5)
        expect(l.opacity).to_equal(0.5)

    it "set_bounds: updates bounds field":
        val l = _make_layer(5)
        l.set_bounds(sk_rect(10.0, 20.0, 110.0, 120.0))
        expect(l.bounds.left).to_equal(10.0)
        expect(l.bounds.top).to_equal(20.0)
        expect(l.bounds.right).to_equal(110.0)
        expect(l.bounds.bottom).to_equal(120.0)

    it "add_child: appends to children_ids":
        val l = _make_layer(6)
        l.add_child(100)
        l.add_child(101)
        expect(l.child_count()).to_equal(2)
        expect(l.children_ids[0]).to_equal(100)
        expect(l.children_ids[1]).to_equal(101)

    it "remove_child: removes existing child, returns true":
        val l = _make_layer(7)
        l.add_child(200)
        l.add_child(201)
        l.add_child(202)
        val ok = l.remove_child(201)
        expect(ok).to_equal(true)
        expect(l.child_count()).to_equal(2)
        expect(l.children_ids[0]).to_equal(200)
        expect(l.children_ids[1]).to_equal(202)

    it "remove_child: missing child returns false":
        val l = _make_layer(8)
        l.add_child(300)
        val ok = l.remove_child(999)
        expect(ok).to_equal(false)
        expect(l.child_count()).to_equal(1)
