# RenderWidgetHostView unit tests

use std.spipe.*
use std.skia.entity.geometry.{SkRect}
use std.viz.entity.surface_id.{SurfaceId, FrameSinkId, LocalSurfaceId}
use std.viz.entity.compositor_frame.{CompositorFrame}
use std.viz.feature.display_compositor.{DisplayCompositor}
use std.content.feature.render_widget_host_view.{RenderWidgetHostView, InputEvent, InputEventKind}

fn _rect() -> SkRect:
    SkRect(left: 0.0, top: 0.0, right: 1024.0, bottom: 768.0)

fn _surface_id() -> SurfaceId:
    val fsi = FrameSinkId(client_id: 1, sink_id: 1)
    val lsi = LocalSurfaceId(parent_sequence_number: 1, child_sequence_number: 1)
    SurfaceId(frame_sink_id: fsi, local_surface_id: lsi)

fn _dc() -> DisplayCompositor:
    DisplayCompositor.new(_rect())

describe "RenderWidgetHostView.new":
    it "new RWHV has 0 pending inputs":
        val rwhv = RenderWidgetHostView.new(_surface_id(), _rect(), _dc())
        expect rwhv.pending_input_count() to_equal 0

    it "bounds round-trip":
        val bounds = SkRect(left: 10.0, top: 20.0, right: 500.0, bottom: 400.0)
        val rwhv = RenderWidgetHostView.new(_surface_id(), bounds, _dc())
        expect rwhv.bounds.left to_equal 10.0

describe "RenderWidgetHostView input":
    it "dispatch_input bumps pending count":
        var rwhv = RenderWidgetHostView.new(_surface_id(), _rect(), _dc())
        val ev = InputEvent(kind: InputEventKind.MouseDown, x: 100, y: 200, data: 0)
        rwhv.dispatch_input(ev)
        expect rwhv.pending_input_count() to_equal 1

    it "submit_compositor_frame returns without error":
        var rwhv = RenderWidgetHostView.new(_surface_id(), _rect(), _dc())
        val frame = CompositorFrame.empty()
        rwhv.submit_compositor_frame(frame)
        expect rwhv.pending_input_count() to_equal 0
