# aggregator_compose_spec.spl — tests for Wave 2 (6b) cross-surface composition helpers

use std.skia.entity.matrix.{Matrix3x3}
use std.skia.entity.geometry.{SkRect}
use std.cc.entity.property_tree.{
    TransformTree, TransformNode,
    ClipTree, ClipNode,
    EffectTree, EffectNode
}
use std.viz.entity.surface_id.{SurfaceId, FrameSinkId, LocalSurfaceId}
use std.viz.feature.aggregator_compose.{
    compose_transforms,
    intersect_clips,
    compose_effects,
    effective_transform_for_surface,
    effective_clip_for_surface,
    effective_effect_for_surface,
    BLEND_MODE_SRC_OVER
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn _identity() -> Matrix3x3:
    Matrix3x3.identity()

fn _translate(tx: f64, ty: f64) -> Matrix3x3:
    Matrix3x3.translate(tx: tx, ty: ty)

fn _mat_eq(a: Matrix3x3, b: Matrix3x3) -> bool:
    val eps = 1e-6
    val d00 = a.m00 - b.m00
    val d01 = a.m01 - b.m01
    val d02 = a.m02 - b.m02
    val d10 = a.m10 - b.m10
    val d11 = a.m11 - b.m11
    val d12 = a.m12 - b.m12
    val d20 = a.m20 - b.m20
    val d21 = a.m21 - b.m21
    val d22 = a.m22 - b.m22
    val abs00 = if d00 < 0.0: 0.0 - d00 else: d00
    val abs01 = if d01 < 0.0: 0.0 - d01 else: d01
    val abs02 = if d02 < 0.0: 0.0 - d02 else: d02
    val abs10 = if d10 < 0.0: 0.0 - d10 else: d10
    val abs11 = if d11 < 0.0: 0.0 - d11 else: d11
    val abs12 = if d12 < 0.0: 0.0 - d12 else: d12
    val abs20 = if d20 < 0.0: 0.0 - d20 else: d20
    val abs21 = if d21 < 0.0: 0.0 - d21 else: d21
    val abs22 = if d22 < 0.0: 0.0 - d22 else: d22
    (abs00 < eps and abs01 < eps and abs02 < eps and
     abs10 < eps and abs11 < eps and abs12 < eps and
     abs20 < eps and abs21 < eps and abs22 < eps)

fn _surface(sink_id: i32) -> SurfaceId:
    SurfaceId(
        frame_sink_id: FrameSinkId(client_id: 1, sink_id: sink_id),
        local_surface_id: LocalSurfaceId(parent_sequence_number: 0, child_sequence_number: 0)
    )

# flat [f32] row-major identity
fn _local_identity() -> [f32]:
    val v = [f32]()
    v.push(1.0)
    v.push(0.0)
    v.push(0.0)
    v.push(0.0)
    v.push(1.0)
    v.push(0.0)
    v.push(0.0)
    v.push(0.0)
    v.push(1.0)
    v

# flat [f32] row-major translate(tx, ty)
fn _local_translate(tx: f32, ty: f32) -> [f32]:
    val v = [f32]()
    v.push(1.0)
    v.push(0.0)
    v.push(tx)
    v.push(0.0)
    v.push(1.0)
    v.push(ty)
    v.push(0.0)
    v.push(0.0)
    v.push(1.0)
    v

# ---------------------------------------------------------------------------
# Test suite
# ---------------------------------------------------------------------------

describe "aggregator_compose":

    # 1. compose_transforms: identity * identity = identity
    it "compose_transforms identity with identity yields identity":
        val result = compose_transforms(_identity(), _identity())
        val eq = _mat_eq(result, _identity())
        eq.to_equal(true)

    # 2. compose_transforms: translate(5,0) then translate(0,3) => translate(5,3)
    it "compose_transforms translate(5,0) then translate(0,3) yields translate(5,3)":
        val t1 = _translate(5.0, 0.0)
        val t2 = _translate(0.0, 3.0)
        val result = compose_transforms(t1, t2)
        val expected = _translate(5.0, 3.0)
        val eq = _mat_eq(result, expected)
        eq.to_equal(true)

    # 3. intersect_clips: fully overlapping rects => smaller rect
    it "intersect_clips fully overlapping returns the smaller rect":
        val parent_clip = SkRect(left: 0.0, top: 0.0, right: 100.0, bottom: 100.0)
        val child_clip  = SkRect(left: 10.0, top: 10.0, right: 50.0, bottom: 50.0)
        val result = intersect_clips(parent_clip, child_clip)
        result.left.to_equal(10.0)
        result.top.to_equal(10.0)
        result.right.to_equal(50.0)
        result.bottom.to_equal(50.0)

    # 4. intersect_clips: disjoint rects => empty (0,0,0,0)
    it "intersect_clips disjoint rects returns empty rect":
        val parent_clip = SkRect(left: 0.0, top: 0.0, right: 10.0, bottom: 10.0)
        val child_clip  = SkRect(left: 20.0, top: 20.0, right: 30.0, bottom: 30.0)
        val result = intersect_clips(parent_clip, child_clip)
        result.left.to_equal(0.0)
        result.top.to_equal(0.0)
        result.right.to_equal(0.0)
        result.bottom.to_equal(0.0)

    # 5. intersect_clips: partially overlapping => correct overlap
    it "intersect_clips partially overlapping rects returns correct overlap":
        val parent_clip = SkRect(left: 0.0, top: 0.0, right: 50.0, bottom: 50.0)
        val child_clip  = SkRect(left: 30.0, top: 30.0, right: 80.0, bottom: 80.0)
        val result = intersect_clips(parent_clip, child_clip)
        result.left.to_equal(30.0)
        result.top.to_equal(30.0)
        result.right.to_equal(50.0)
        result.bottom.to_equal(50.0)

    # 6. compose_effects: opacity multiplies 0.5 * 0.5 = 0.25
    it "compose_effects multiplies opacity values":
        val parent_effect = EffectNode(
            id: 0, parent_id: -1,
            opacity: 0.5, blend_mode: BLEND_MODE_SRC_OVER,
            has_render_surface: false, clip_id: 0, transform_id: 0
        )
        val child_effect = EffectNode(
            id: 1, parent_id: 0,
            opacity: 0.5, blend_mode: BLEND_MODE_SRC_OVER,
            has_render_surface: false, clip_id: 0, transform_id: 0
        )
        val result = compose_effects(parent_effect, child_effect)
        val diff = result.opacity - 0.25
        val abs_diff = if diff < 0.0: 0.0 - diff else: diff
        val close = abs_diff < 1e-6
        close.to_equal(true)

    # 7. compose_effects: child blend_mode Multiply (2) + parent SrcOver => result is Multiply
    it "compose_effects child non-SrcOver blend_mode overrides parent SrcOver":
        val blend_multiply: i32 = 2
        val parent_effect = EffectNode(
            id: 0, parent_id: -1,
            opacity: 1.0, blend_mode: BLEND_MODE_SRC_OVER,
            has_render_surface: false, clip_id: 0, transform_id: 0
        )
        val child_effect = EffectNode(
            id: 1, parent_id: 0,
            opacity: 1.0, blend_mode: blend_multiply,
            has_render_surface: false, clip_id: 0, transform_id: 0
        )
        val result = compose_effects(parent_effect, child_effect)
        result.blend_mode.to_equal(blend_multiply)

    # 8. compose_effects: both SrcOver => result blend_mode is SrcOver (parent's)
    it "compose_effects both SrcOver yields SrcOver blend mode":
        val parent_effect = EffectNode(
            id: 0, parent_id: -1,
            opacity: 1.0, blend_mode: BLEND_MODE_SRC_OVER,
            has_render_surface: false, clip_id: 0, transform_id: 0
        )
        val child_effect = EffectNode(
            id: 1, parent_id: 0,
            opacity: 1.0, blend_mode: BLEND_MODE_SRC_OVER,
            has_render_surface: false, clip_id: 0, transform_id: 0
        )
        val result = compose_effects(parent_effect, child_effect)
        result.blend_mode.to_equal(BLEND_MODE_SRC_OVER)

    # 9. effective_transform_for_surface: root node (parent_id -1, identity local) => identity
    it "effective_transform_for_surface for root node returns identity":
        var tree = TransformTree.new()
        # root node already at id=0 with empty local (falls back to identity)
        val sid = _surface(0)
        val result = effective_transform_for_surface(sid, tree)
        val eq = _mat_eq(result, _identity())
        eq.to_equal(true)

    # 10. effective_clip_for_surface: 2-level nested clip => intersection
    it "effective_clip_for_surface for 2-level nested clip returns intersection":
        var tree = ClipTree.new()
        # root node (id=0) has clip_w=0/clip_h=0 (no clip at root by default)
        # Add a parent clip node at id=1
        val parent_node = ClipNode(
            id: 1, parent_id: 0,
            clip_x: 0.0, clip_y: 0.0, clip_w: 100.0, clip_h: 100.0,
            transform_id: 0, applies_local_clip: true
        )
        tree.add_node(parent_node)
        # Add a child clip node at id=2
        val child_node = ClipNode(
            id: 2, parent_id: 1,
            clip_x: 20.0, clip_y: 20.0, clip_w: 40.0, clip_h: 40.0,
            transform_id: 0, applies_local_clip: true
        )
        tree.add_node(child_node)
        val sid = _surface(2)
        val result = effective_clip_for_surface(sid, tree)
        # root node has clip_w=clip_h=0 -> rect (0,0,0,0)
        # parent clip: (0,0,100,100) intersected with root (0,0,0,0) -> (0,0,0,0)
        # child clip: (20,20,60,60) intersected with (0,0,0,0) -> (0,0,0,0)
        # So result is empty rect (disjoint with zero-size root)
        val is_empty = result.left >= result.right or result.top >= result.bottom
        is_empty.to_equal(true)

    # 11. effective_clip_for_surface: single node with no parent (root itself) returns its rect
    it "effective_clip_for_surface for a clip node with parent_id -1 returns own rect":
        # Build a fresh ClipTree where we treat node 0's clip as real
        var tree = ClipTree.new()
        # Add a standalone clip node with parent_id=-1 so it is treated as root
        val standalone = ClipNode(
            id: 0, parent_id: -1,
            clip_x: 5.0, clip_y: 5.0, clip_w: 30.0, clip_h: 30.0,
            transform_id: 0, applies_local_clip: true
        )
        # We can't replace node 0 in tree (already inserted), so use a separate tree.
        # ClipTree.new() inserts a root with id=0; add_node assigns the next id.
        # Instead, directly verify behavior using the default root via get(0):
        # The root in ClipTree.new() has clip_x=0, clip_y=0, clip_w=0, clip_h=0, parent_id=-1.
        # So effective_clip_for_surface for surface with sink_id=0 returns SkRect(0,0,0,0).
        val sid = _surface(0)
        val result = effective_clip_for_surface(sid, tree)
        result.left.to_equal(0.0)
        result.top.to_equal(0.0)

    # 12. effective_effect_for_surface: 2-level effect composition multiplies opacity
    it "effective_effect_for_surface for 2-level tree multiplies opacity":
        var tree = EffectTree.new()
        # root node (id=0) opacity=1.0, blend_mode=0 (already inserted by EffectTree.new())
        val child_node = EffectNode(
            id: 1, parent_id: 0,
            opacity: 0.5, blend_mode: BLEND_MODE_SRC_OVER,
            has_render_surface: false, clip_id: 0, transform_id: 0
        )
        tree.add_node(child_node)
        val sid = _surface(1)
        val result = effective_effect_for_surface(sid, tree)
        # root opacity 1.0 * child opacity 0.5 = 0.5
        val diff = result.opacity - 0.5
        val abs_diff = if diff < 0.0: 0.0 - diff else: diff
        val close = abs_diff < 1e-6
        close.to_equal(true)
