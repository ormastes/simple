# @cover src/lib/blink/dom/document.spl 80%
"""
# Blink Document Specification

**Category:** Browser / Blink
**Status:** Stub

## Overview

Tests for the Blink-style Document stub — the root DOM container that
owns a DomTree, tracks the document URL, title, and HTML5 ready-state
lifecycle (Loading -> Interactive -> Complete).
"""

use std.spipe.*
use std.lib.blink.dom.document.{
    Document, ReadyState, document_new
}

describe "document_new":
    it "ready_state is Loading, character_set is UTF-8":
        val doc = document_new("http://example.com/")
        val is_loading = doc.ready_state == ReadyState.Loading
        expect is_loading == true
        expect doc.character_set == "UTF-8"
        expect doc.content_type == "text/html"

    it "url is parsed from input string":
        val doc = document_new("https://www.example.com/path?q=1")
        expect doc.url.scheme == "https"
        expect doc.url.host == "www.example.com"
        expect doc.url.is_valid == true

describe "set_title":
    it "updates title field":
        val doc = document_new("http://example.com/")
        doc.set_title("Hello World")
        expect doc.title == "Hello World"

describe "set_ready_state":
    it "updates state":
        val doc = document_new("http://example.com/")
        doc.set_ready_state(ReadyState.Interactive)
        val is_interactive = doc.ready_state == ReadyState.Interactive
        expect is_interactive == true

describe "create_element":
    it "returns new node id":
        val doc = document_new("http://example.com/")
        val div_id = doc.create_element("div")
        expect div_id > 0

describe "is_loading":
    it "returns true initially, false after set_ready_state(Complete)":
        val doc = document_new("http://example.com/")
        expect doc.is_loading() == true
        doc.set_ready_state(ReadyState.Complete)
        expect doc.is_loading() == false

describe "is_complete":
    it "returns true only when ready_state is Complete":
        val doc = document_new("http://example.com/")
        expect doc.is_complete() == false
        doc.set_ready_state(ReadyState.Interactive)
        expect doc.is_complete() == false
        doc.set_ready_state(ReadyState.Complete)
        expect doc.is_complete() == true