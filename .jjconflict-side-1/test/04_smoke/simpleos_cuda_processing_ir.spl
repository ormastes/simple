use std.common.processing.processing_ir.{processing_ir_fill_u32, processing_ir_cpu_execute, processing_ir_outputs_equal}
use std.gc_async_mut.processing.cuda_fill_u32.{processing_ir_execute_cuda}

fn main() -> i64:
    val ir = processing_ir_fill_u32(256, 7u32)
    val expected = processing_ir_cpu_execute(ir)
    val result = processing_ir_execute_cuda(ir)
    if not result.completed or result.backend_handle <= 0 or result.device_identity <= 0 or not processing_ir_outputs_equal(result.values, expected):
        print("SIMPLEOS_CUDA_PROCESSING_IR_FAIL reason={result.reason}\n")
        return 1
    var checksum: i64 = 0
    for value in result.values:
        checksum = checksum + value.to_i64()
    if checksum != 1792:
        print("SIMPLEOS_CUDA_PROCESSING_IR_FAIL checksum={checksum}\n")
        return 1
    print("SIMPLEOS_CUDA_PROCESSING_IR_PASS handle={result.backend_handle} checksum={checksum}\n")
    0
