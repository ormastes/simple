# @cover src/os/sosix/process.spl 80%
"""
# SOSIX Process Specification

SOSIX is the native async process surface. POSIX process APIs are wrappers over
this module.
"""

use std.spec
use os.posix.errno.{EINVAL, EIO}
use os.sosix.process.{
    SOSIX_PROCESS_MAX_REQUESTS,
    sosix_process_init,
    sosix_process_spawn,
    sosix_process_execve,
    sosix_process_signal,
    sosix_process_is_complete,
    sosix_process_result,
    sosix_process_free_request,
    sosix_process_wait_request
}

describe "SOSIX process request lifecycle":
    it "completes invalid spawn paths without entering the syscall backend":
        sosix_process_init()
        val req = sosix_process_spawn("", [], 2)

        expect(req).to_be_less_than(SOSIX_PROCESS_MAX_REQUESTS)
        expect(sosix_process_is_complete(req)).to_equal(true)
        expect(sosix_process_result(req)).to_equal(0 - EINVAL as i64)

        sosix_process_free_request(req)

    it "completes invalid exec paths without entering the syscall backend":
        sosix_process_init()
        val req = sosix_process_execve("", [], [])

        expect(req).to_be_less_than(SOSIX_PROCESS_MAX_REQUESTS)
        expect(sosix_process_is_complete(req)).to_equal(true)
        expect(sosix_process_result(req)).to_equal(0 - EINVAL as i64)

        sosix_process_free_request(req)

    it "completes invalid signal requests without entering the syscall backend":
        sosix_process_init()
        val req = sosix_process_signal(42u64, -1)

        expect(req).to_be_less_than(SOSIX_PROCESS_MAX_REQUESTS)
        expect(sosix_process_is_complete(req)).to_equal(true)
        expect(sosix_process_result(req)).to_equal(0 - EINVAL as i64)

        sosix_process_free_request(req)

    it "reports EIO for invalid request handles":
        expect(sosix_process_is_complete(SOSIX_PROCESS_MAX_REQUESTS)).to_equal(true)
        expect(sosix_process_result(SOSIX_PROCESS_MAX_REQUESTS)).to_equal(0 - EIO as i64)
        expect(sosix_process_wait_request(SOSIX_PROCESS_MAX_REQUESTS)).to_equal(0 - EIO as i64)
