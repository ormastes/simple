"""
# IPC Privilege Control Specification (G11)

**Feature IDs:** #OS-G11
**Category:** Runtime
**Difficulty:** 3/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Tests for G11 privilege tables: PrivilegeMask storage, PRIVCTL ops,
and the SystemPrivilege capability gate.
"""

use std.spec.{describe, it, expect}
use os.kernel.types.capability_types.{PrivilegeMask, PRIVCTL_SET_MASK, PRIVCTL_GET_MASK, PRIVCTL_ADD_PEER, PRIVCTL_REMOVE_PEER, priv_allows_kernel_call, priv_allows_send_to}
use os.kernel.ipc.capability.{PrivilegeTable}


# ============================================================================
# Test Group 1: PrivilegeMask helpers
# ============================================================================

describe "priv_allows_kernel_call":
    """Tests for the kernel-call bitmap check helper."""
    it "returns false when kernel_calls bitmap is 0":
        """Zero bitmap denies all calls."""
        val mask = PrivilegeMask(
            kernel_calls: 0,
            irqs: 0,
            io_port_base: 0,
            io_port_len: 0,
            allowed_peers: []
        )
        expect(priv_allows_kernel_call(mask, 0)).to_equal(false)
        expect(priv_allows_kernel_call(mask, 1)).to_equal(false)

    it "returns true for bit 0 when kernel_calls has bit 0 set":
        """Bit 0 set means call_id=0 is permitted."""
        val mask = PrivilegeMask(
            kernel_calls: 1,
            irqs: 0,
            io_port_base: 0,
            io_port_len: 0,
            allowed_peers: []
        )
        expect(priv_allows_kernel_call(mask, 0)).to_equal(true)
        expect(priv_allows_kernel_call(mask, 1)).to_equal(false)

    it "returns false for call_id >= 64":
        """Out-of-range call IDs are always denied."""
        val mask = PrivilegeMask(
            kernel_calls: 0xFFFFFFFFFFFFFFFF,
            irqs: 0,
            io_port_base: 0,
            io_port_len: 0,
            allowed_peers: []
        )
        expect(priv_allows_kernel_call(mask, 64)).to_equal(false)


describe "priv_allows_send_to":
    """Tests for the IPC peer allowlist check helper."""
    it "returns false when allowed_peers is empty":
        """Empty peer list denies all sends."""
        val mask = PrivilegeMask(
            kernel_calls: 0,
            irqs: 0,
            io_port_base: 0,
            io_port_len: 0,
            allowed_peers: []
        )
        expect(priv_allows_send_to(mask, 42)).to_equal(false)

    it "returns true when peer is in the allowed list":
        """Peer present in list is permitted."""
        val mask = PrivilegeMask(
            kernel_calls: 0,
            irqs: 0,
            io_port_base: 0,
            io_port_len: 0,
            allowed_peers: [10, 20, 42]
        )
        expect(priv_allows_send_to(mask, 42)).to_equal(true)
        expect(priv_allows_send_to(mask, 10)).to_equal(true)
        expect(priv_allows_send_to(mask, 99)).to_equal(false)


# ============================================================================
# Test Group 2: PrivilegeTable set/get
# ============================================================================

describe "PrivilegeTable set and get":
    """Tests for per-task privilege mask storage."""
    it "get returns nil for unknown task":
        """No record exists before set() is called."""
        val tbl = PrivilegeTable.new()
        val result = tbl.get(999)
        expect(result).to_be_nil()

    it "set then get returns the stored mask":
        """After set, the stored mask fields are retrievable."""
        var tbl = PrivilegeTable.new()
        val mask = PrivilegeMask(
            kernel_calls: 7,
            irqs: 3,
            io_port_base: 0x3F8,
            io_port_len: 8,
            allowed_peers: []
        )
        tbl.set(1, mask)
        val found = tbl.get(1)
        val m = found
        expect(m.kernel_calls).to_equal(7)
        expect(m.io_port_base).to_equal(0x3F8)

    it "set replaces existing mask for same task":
        """Second set() overwrites the previous mask."""
        var tbl = PrivilegeTable.new()
        val mask1 = PrivilegeMask(kernel_calls: 1, irqs: 0, io_port_base: 0, io_port_len: 0, allowed_peers: [])
        val mask2 = PrivilegeMask(kernel_calls: 255, irqs: 0, io_port_base: 0, io_port_len: 0, allowed_peers: [])
        tbl.set(5, mask1)
        tbl.set(5, mask2)
        val found = tbl.get(5)
        val m = found
        expect(m.kernel_calls).to_equal(255)


# ============================================================================
# Test Group 3: PrivilegeTable peer management
# ============================================================================

describe "PrivilegeTable add_peer and remove_peer":
    """Tests for add/remove peer on the privilege table."""
    it "add_peer creates record if none exists and peer is queryable":
        """add_peer auto-creates a record when none exists."""
        var tbl = PrivilegeTable.new()
        tbl.add_peer(7, 42)
        val found = tbl.get(7)
        val m = found
        expect(priv_allows_send_to(m, 42)).to_equal(true)

    it "add_peer is idempotent — duplicate does not double-add":
        """Calling add_peer twice for the same peer keeps list size at 1."""
        var tbl = PrivilegeTable.new()
        tbl.add_peer(3, 10)
        tbl.add_peer(3, 10)
        val found = tbl.get(3)
        val m = found
        expect(priv_allows_send_to(m, 10)).to_equal(true)
        expect(m.allowed_peers.len()).to_equal(1)

    it "remove_peer removes the given peer":
        """After remove_peer the removed peer is denied and others allowed."""
        var tbl = PrivilegeTable.new()
        tbl.add_peer(2, 100)
        tbl.add_peer(2, 200)
        tbl.remove_peer(2, 100)
        val found = tbl.get(2)
        val m = found
        expect(priv_allows_send_to(m, 100)).to_equal(false)
        expect(priv_allows_send_to(m, 200)).to_equal(true)

    it "remove_peer on missing task is a no-op":
        """remove_peer for unknown task leaves table empty for that id."""
        var tbl = PrivilegeTable.new()
        tbl.remove_peer(999, 42)
        val result = tbl.get(999)
        expect(result).to_be_nil()
