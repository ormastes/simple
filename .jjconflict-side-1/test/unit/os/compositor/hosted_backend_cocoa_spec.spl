# Hosted Cocoa Backend — winit-alias coverage spec
#
# `HostedCocoaBackend` is intentionally documented as a selector-facing
# macOS alias over the shared winit pixel buffer implementation. These tests
# avoid host SFFI calls and assert the alias boundary explicitly.

use std.spec.{describe, it, expect}
use os.compositor.hosted_backend_cocoa.{HostedCocoaBackend}

describe "HostedCocoaBackend alias boundary":

    it "names the implementation as a winit alias":
        expect(HostedCocoaBackend.implementation_name()).to_equal("cocoa-winit-alias")

    it "documents that native Cocoa symbols are not bound by this class":
        expect(HostedCocoaBackend.uses_native_cocoa_symbols()).to_equal(false)

    it "instantiates through the test seam without touching SFFI":
        val be = HostedCocoaBackend.new(11, 22, 320, 240)
        expect(be.window_id).to_equal(11)
        expect(be.buffer_id).to_equal(22)
        expect(be.w).to_equal(320)
        expect(be.h).to_equal(240)

    it "keeps CompositorBackend method signatures aligned with u32/i32 contract":
        val be = HostedCocoaBackend.new(0, 0, 128, 128)
        if false:
            be.clear(0xFF000000)
            be.fill_rect(0, 0, 10, 10, 0xFFFFFFFF)
            be.draw_text(0, 0, "x", 0xFFFFFFFF, 0xFF000000)
            val ch: u8 = 65
            be.draw_char_8x16(0, 0, ch, 0xFFFFFFFF, 0xFF000000)
            be.put_pixel(0, 0, 0xFF0000FF)
            be.present()
            be.present_rect(0, 0, 64, 64)
        expect(be.w).to_equal(128)

    it "keeps glass method signatures aligned with u32/i32 contract":
        val be = HostedCocoaBackend.new(0, 0, 128, 128)
        if false:
            val alpha: u8 = 128
            be.blend_rect(0, 0, 64, 64, 0x80FFFFFF, alpha)
            val radius: u32 = 4
            be.blur_region(0, 0, 64, 64, radius)
            be.gradient_v(0, 0, 64, 64, 0xFF000000, 0xFFFFFFFF)
            val _px = be.read_pixel(0, 0)
        expect(be.h).to_equal(128)

    it "keeps lifecycle signatures deterministic":
        val be = HostedCocoaBackend.new(0, 0, 64, 64)
        if false:
            val _created = HostedCocoaBackend.try_create(1, 64, 64, 0xFF000000)
            val _ok = be.resize(128, 128)
            be.free()
        expect(be.w + be.h).to_equal(128)
