# @cover src/os/compositor/screenshot_compare.spl 80%
# @tag: rendering, pixel, comparison, profile
#
# Screenshot Compare — Profile Extension Specification
#
# Verifies the new compare_with_profile() function added to the existing
# screenshot_compare module. This bridges the tolerance_profile system
# into the core comparison pipeline.

use std.spec.{describe, context, it, expect}
use os.compositor.screenshot_compare.{
    ComparisonResult, compare_with_profile, compare_pixel_buffers}
use os.compositor.tolerance_profile.{
    profile_strict, profile_text_tolerant, profile_glass_blur,
    profile_wm_default}

# ============================================================================
# Constants
# ============================================================================

val W: i32 = 4
val H: i32 = 4
val BLACK: u32   = 0xFF000000
val WHITE: u32   = 0xFFFFFFFF
val GRAY_128: u32 = 0xFF808080
val GRAY_192: u32 = 0xFFC0C0C0

# ============================================================================
# Test Group 1: Basic Profile Comparison (AC-4)
# ============================================================================

describe "ScreenshotCompare — compare_with_profile":

    context "identical buffers":

        it "AC-4: identical buffers with strict profile return 100% match":
            val a = [BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK]
            val b = [BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK]
            val profile = profile_strict()
            val result = compare_with_profile(a, b, W, H, profile)
            expect(result.match_percentage).to_equal(10000)

        it "AC-4: identical buffers with wm_default profile return 100% match":
            val a = [WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE]
            val b = [WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE]
            val profile = profile_wm_default()
            val result = compare_with_profile(a, b, W, H, profile)
            expect(result.match_percentage).to_equal(10000)

        it "AC-4: exact comparison treats alpha differences as mismatches":
            val a = [0x00000000, 0x00000000, 0x00000000, 0x00000000,
                     0x00000000, 0x00000000, 0x00000000, 0x00000000,
                     0x00000000, 0x00000000, 0x00000000, 0x00000000,
                     0x00000000, 0x00000000, 0x00000000, 0x00000000]
            val b = [0xFF000000, 0xFF000000, 0xFF000000, 0xFF000000,
                     0xFF000000, 0xFF000000, 0xFF000000, 0xFF000000,
                     0xFF000000, 0xFF000000, 0xFF000000, 0xFF000000,
                     0xFF000000, 0xFF000000, 0xFF000000, 0xFF000000]
            val result = compare_pixel_buffers(a, b, W, H, 0)
            expect(result.match_percentage).to_be_less_than(10000)

    context "slightly different buffers":

        it "AC-4: strict profile detects small differences":
            val a = [GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128]
            val b = [GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192]
            val profile = profile_strict()
            val result = compare_with_profile(a, b, W, H, profile)
            expect(result.match_percentage).to_be_less_than(10000)

        it "AC-4: text_tolerant profile is more lenient than strict for same diff":
            val a = [GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128]
            val b = [GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192]
            val strict_result = compare_with_profile(a, b, W, H, profile_strict())
            val tolerant_result = compare_with_profile(a, b, W, H, profile_text_tolerant())
            val more_lenient = tolerant_result.match_percentage >= strict_result.match_percentage
            expect(more_lenient).to_equal(true)

        it "AC-4: glass_blur profile is more lenient than strict for same diff":
            val a = [GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128]
            val b = [GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192]
            val strict_result = compare_with_profile(a, b, W, H, profile_strict())
            val glass_result = compare_with_profile(a, b, W, H, profile_glass_blur())
            val more_lenient = glass_result.match_percentage >= strict_result.match_percentage
            expect(more_lenient).to_equal(true)

    context "completely different buffers":

        it "AC-4: black vs white with any profile reports low match":
            val a = [BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK]
            val b = [WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE]
            val profile = profile_wm_default()
            val result = compare_with_profile(a, b, W, H, profile)
            expect(result.match_percentage).to_be_less_than(5000)

# ============================================================================
# Test Group 2: Result Structure (AC-4)
# ============================================================================

describe "ScreenshotCompare — compare_with_profile result":

    context "ComparisonResult fields":

        it "AC-4: result has max_channel_diff field":
            val a = [BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK]
            val b = [WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE]
            val profile = profile_strict()
            val result = compare_with_profile(a, b, W, H, profile)
            expect(result.max_channel_diff).to_be_greater_than(0)

        it "AC-4: result has total_channel_diff field":
            val a = [BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK]
            val b = [GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128]
            val profile = profile_strict()
            val result = compare_with_profile(a, b, W, H, profile)
            expect(result.total_channel_diff).to_be_greater_than(0)
