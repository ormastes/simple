"""
# coreutils/run argument parsing
**Feature IDs:** #WAVE5-G9
**Category:** Userland coreutils
"""
use std.spec.*
use os.apps.coreutils.run.{main_run}

describe "run argument parsing":
    """Argument handling paths."""

    it "zero args returns 1 (usage error)":
        """run with no operands must complain."""
        val rc = main_run([])
        expect rc.to_equal(1i32)

    it "--help returns 0":
        """Help is a no-op successful exit."""
        val rc = main_run(["--help"])
        expect rc.to_equal(0i32)

    it "one arg returns an i32":
        """A command path should type-check and produce a status."""
        val rc = main_run(["/sys/apps/hello_world"])
        val is_int: bool = rc == 0i32 or rc != 0i32
        expect is_int.to_equal(true)

