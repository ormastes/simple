use std.spec
use os.game.steam.steam_2048_demo.{
    steam_2048_demo_marker,
    steam_2048_demo_run,
    steam_2048_merge_left,
    steam_2048_port_guest_marker_ready,
    steam_2048_port_manifest,
    steam_2048_port_marker,
    steam_2048_row_text,
    steam_2048_simpleos_guest_marker_ready
}

describe "SimpleOS Steam 2048 smoke game":
    it "keeps the deterministic 2048 merge rule executable":
        val merged = steam_2048_merge_left([2, 2, 0, 0])
        expect steam_2048_row_text(merged) == "4,0,0,0"

    it "binds the open source 2048 game to the Steam facade":
        val run = steam_2048_demo_run()
        expect run.source_game == "2048"
        expect run.upstream_url == "https://github.com/gabrielecirulli/2048"
        expect run.license == "MIT"
        expect run.steam.state.achievement_unlocked == true
        expect run.steam.state.drm_ticket == "simple-drm-ticket"
        expect run.port_profile.profile_version == "steamos-rebuild-v1"
        expect run.port_profile.rebuild_target == "simpleos-native"

    it "emits a guest-checkable marker":
        val marker = steam_2048_demo_marker()
        expect (marker).contains("[steam-2048-demo]")
        expect (marker).contains("runtime=SteamLinuxRuntime/soldier")
        expect (marker).contains("network=true")
        expect steam_2048_simpleos_guest_marker_ready(marker) == true

    it "emits a rebuild-porting manifest and marker":
        val manifest = steam_2048_port_manifest()
        val marker = steam_2048_port_marker()
        expect (manifest).contains("port_profile=steamos-rebuild-v1")
        expect (manifest).contains("source=2048")
        expect (manifest).contains("rebuild_target=simpleos-native")
        expect (marker).contains("steam_facade=simple-steam-sffi-v1")
        expect steam_2048_port_guest_marker_ready(marker) == true

    it "rejects incomplete guest serial evidence":
        expect steam_2048_simpleos_guest_marker_ready("[steam-2048-demo] source=2048") == false
        expect steam_2048_port_guest_marker_ready("[game-port] profile=steamos-rebuild-v1 source=2048") == false