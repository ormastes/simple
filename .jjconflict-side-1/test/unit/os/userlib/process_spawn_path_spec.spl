# Userspace spawn_path() API specification.
#
# Covers marshaling layout, error paths, argv defaults, and API signatures.
# Tests run in interpreter mode — syscalls are not executed against a real
# kernel, so we verify marshaling shape, error short-circuits, and
# compile-time signatures only.

use std.spec
use std.io_runtime
use os.sosix.process.{
    sosix_marshal_string_vector,
    sosix_marshal_string_vector_size
}
use os.userlib.process.{spawn_path}

# ============================================================================
# Module-level helpers — avoid var mutation issues in interpreter it-blocks
# ============================================================================

fn _make_single_string_buf() -> [u8]:
    """Marshal a single-element vector ["hello"] and return the buffer."""
    val strings: [text] = ["hello"]
    sosix_marshal_string_vector(strings)

fn _make_two_string_buf() -> [u8]:
    """Marshal ["ab", "cde"] and return the buffer."""
    val strings: [text] = ["ab", "cde"]
    sosix_marshal_string_vector(strings)

fn _make_empty_buf() -> [u8]:
    """Marshal an empty vector and return the buffer."""
    val strings: [text] = []
    sosix_marshal_string_vector(strings)

fn _expected_size(count: u64, total_bytes: u64) -> u64:
    """Compute expected buffer size for validation."""
    sosix_marshal_string_vector_size(count, total_bytes)

# ============================================================================
# Marshaling layout tests
# ============================================================================

describe "spawn_path marshaling":
    """Verify sosix_marshal_string_vector produces correct byte layouts."""

    it "returns empty buffer for empty input":
        val buf = _make_empty_buf()
        expect buf.len() == 0

    it "marshals single string with correct total size":
        val buf = _make_single_string_buf()
        # "hello" = 5 bytes + 1 NUL + 1 offset (8 bytes) + NULL terminator (8 bytes)
        # = 6 + 16 = 22
        val expected = _expected_size(1, 5)
        expect expected == 22
        expect buf.len().to_u64() == expected

    it "places NUL terminator after string bytes":
        val buf = _make_single_string_buf()
        # buf[0..4] = "hello", buf[5] = 0x00
        expect buf[0] == 0x68u8  # 'h'
        expect buf[1] == 0x65u8  # 'e'
        expect buf[2] == 0x6Cu8  # 'l'
        expect buf[3] == 0x6Cu8  # 'l'
        expect buf[4] == 0x6Fu8  # 'o'
        expect buf[5] == 0x00u8  # NUL

    it "encodes offset 0 for first string in pointer table":
        val buf = _make_single_string_buf()
        # Offset table starts at byte 6 (after "hello\0")
        # First offset = 0, little-endian u64
        expect buf[6] == 0x00u8
        expect buf[7] == 0x00u8
        expect buf[8] == 0x00u8
        expect buf[9] == 0x00u8
        expect buf[10] == 0x00u8
        expect buf[11] == 0x00u8
        expect buf[12] == 0x00u8
        expect buf[13] == 0x00u8

    it "ends with 8-byte NULL terminator pointer":
        val buf = _make_single_string_buf()
        val n = buf.len()
        # Last 8 bytes should all be zero
        expect buf[n - 1] == 0x00u8
        expect buf[n - 2] == 0x00u8
        expect buf[n - 3] == 0x00u8
        expect buf[n - 4] == 0x00u8
        expect buf[n - 5] == 0x00u8
        expect buf[n - 6] == 0x00u8
        expect buf[n - 7] == 0x00u8
        expect buf[n - 8] == 0x00u8

    it "marshals two strings with correct total size":
        val buf = _make_two_string_buf()
        # "ab" (2+1) + "cde" (3+1) = 7 string bytes
        # + 2 offsets (16) + NULL ptr (8) = 31
        val expected = _expected_size(2, 5)
        expect expected == 31
        expect buf.len().to_u64() == expected

    it "encodes second string offset correctly":
        val buf = _make_two_string_buf()
        # String data: "ab\0cde\0" = 7 bytes
        # Offset table starts at byte 7
        # offset[0] = 0  (bytes 7..14)
        # offset[1] = 3  (bytes 15..22) — "ab\0" is 3 bytes
        expect buf[15] == 0x03u8  # offset = 3, low byte
        expect buf[16] == 0x00u8

    it "preserves string content for two-element vector":
        val buf = _make_two_string_buf()
        # "ab" at offset 0
        expect buf[0] == 0x61u8  # 'a'
        expect buf[1] == 0x62u8  # 'b'
        expect buf[2] == 0x00u8  # NUL
        # "cde" at offset 3
        expect buf[3] == 0x63u8  # 'c'
        expect buf[4] == 0x64u8  # 'd'
        expect buf[5] == 0x65u8  # 'e'
        expect buf[6] == 0x00u8  # NUL

# ============================================================================
# spawn_path error and signature tests
# ============================================================================

describe "spawn_path API":
    """Verify spawn_path error handling, argv defaults, and type signatures."""

    it "returns Err(EINVAL) for empty path":
        val result = spawn_path("", [], [])
        expect result.is_err() == true
        expect result.unwrap_err() == 22

    it "returns Err(EINVAL) for empty path with argv":
        val result = spawn_path("", ["arg0"], ["HOME=/home"])
        expect result.is_err() == true
        expect result.unwrap_err() == 22

    # TODO(kernel-abi): spawn_path with a valid path requires a live kernel
    # to exercise syscall 13. These cases cannot be tested in interpreter mode.
    # When a kernel test harness is available, add:
    #   - spawn_path with valid path returns Ok(pid)
    #   - argv defaults to [path] when empty (verify kernel receives argv[0])

    it "sosix_marshal_string_vector accepts [text] and returns [u8]":
        val input: [text] = ["test"]
        val result: [u8] = sosix_marshal_string_vector(input)
        expect result.len() > 0

    it "sosix_marshal_string_vector_size returns u64":
        val size: u64 = sosix_marshal_string_vector_size(2, 10)
        # total_bytes(10) + count(2) + (count+1)*8 = 10 + 2 + 24 = 36
        expect size == 36
