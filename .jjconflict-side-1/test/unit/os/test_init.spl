fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn before(a: i64, b: i64) -> bool:
    a < b

fn dep_ok(svc: i64, dep: i64) -> bool:
    dep < svc

fn main():
    print "=== Init ==="
    check("order", before(0, 1))
    check("self", not before(1, 1))
    check("dep_ok", dep_ok(5, 2))
    check("dep_fail", not dep_ok(2, 5))
    check("dep_self", not dep_ok(3, 3))
    print "=== DONE ==="
