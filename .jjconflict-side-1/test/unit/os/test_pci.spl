fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"
fn shr(x: i64, n: i64) -> i64:
    x / (1 << n)
fn pci_bdf(bus: i64, dev: i64, f: i64) -> i64:
    (1 << 31) | (bus << 16) | (dev << 11) | (f << 8) | (0x10 & 0xFC)
fn main():
    print "=== PCI ==="
    check("enable", shr(pci_bdf(1, 2, 3), 31) == 1)
    check("bus=1", (shr(pci_bdf(1, 2, 3), 16) & 0xFF) == 1)
    check("dev=2", (shr(pci_bdf(1, 2, 3), 11) & 0x1F) == 2)
    check("fn=3", (shr(pci_bdf(1, 2, 3), 8) & 7) == 3)
    check("off", (pci_bdf(1, 2, 3) & 0xFC) == 0x10)
    print "=== DONE ==="
