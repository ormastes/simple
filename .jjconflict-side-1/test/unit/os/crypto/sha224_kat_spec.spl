# SHA-224 NIST FIPS 180-4 Known-Answer Test Vectors
#
# Tests the pure-Simple SHA-224 implementation in src/os/crypto/sha224.spl
# against FIPS 180-4 Appendix C canonical vectors.
#
#   SHA-224("")    -> d14a028c2a3a2bc9476102bb288234c415a2b01f828ea62ac5b3e42f
#   SHA-224("abc") -> 23097d223405d8228642a477bda255b32aadbce4bda0b3f7e36c9da7
#
# Source: NIST FIPS 180-4 Appendix C (also reproduced in NIST CSRC examples).
#
# NOTE: per .claude/memory/feedback_compile_mode_false_greens.md this spec is
# verified in interpreter mode. The pure-Simple SHA-256 core that SHA-224
# reuses inherits the Cranelift selective `>> 3` miscompilation noted in
# sha256.spl; compile-mode SHA-224 may regress until that lands fixed.

use std.spipe.*
use os.crypto.sha224.{sha224}

# ============================================================================
# Helpers — build inputs in module-level fns so it-block var mutation
# (feedback_it_block_var_mutation.md) doesn't drop list pushes.
# ============================================================================

fn _empty_bytes() -> [u8]:
    var out: [u8] = []
    out

fn _abc_bytes() -> [u8]:
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

# ============================================================================
# SHA-224 — FIPS 180-4 Appendix C KAT
# ============================================================================

describe "SHA-224 — FIPS 180-4 known-answer vectors":

    it "SHA-224(\"\") = d14a028c...":
        expect(_bytes_hex(sha224(_empty_bytes()))).to_equal(
            "d14a028c2a3a2bc9476102bb288234c415a2b01f828ea62ac5b3e42f"
        )

    it "SHA-224(\"abc\") = 23097d22...":
        expect(_bytes_hex(sha224(_abc_bytes()))).to_equal(
            "23097d223405d8228642a477bda255b32aadbce4bda0b3f7e36c9da7"
        )

    it "SHA-224 output length is 28 bytes":
        expect(sha224(_abc_bytes()).len()).to_equal(28)
