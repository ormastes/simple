# Feature: Event Queue for Headless UI Testing
# Category: UI Components
# Status: Implemented
#
# Tests EventQueue indirectly through NoneBackend since the bootstrap
# interpreter loses class type info on direct cross-module construction.

use std.spec.*

use app.ui.none.backend.{NoneBackend}
use common.ui.widget.{UIEvent}


# ============================================================================
# Test Group 1: Queue via NoneBackend
# ============================================================================

describe "EventQueue via NoneBackend":

    it "starts with no events":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                val event = backend.poll_event(0)
                expect(event == nil).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "injects and polls a single event":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                backend.inject_event(UIEvent.Quit)
                val event = backend.poll_event(0)
                expect(event != nil).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "injects multiple events and polls in FIFO order":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                val events = [UIEvent.KeyPress(key: "a"), UIEvent.KeyPress(key: "b"), UIEvent.Quit]
                backend.inject_events(events)

                val e1 = backend.poll_event(0)
                val e2 = backend.poll_event(0)
                val e3 = backend.poll_event(0)
                val e4 = backend.poll_event(0)

                expect(e1 != nil).to_equal(true)
                expect(e2 != nil).to_equal(true)
                expect(e3 != nil).to_equal(true)
                expect(e4 == nil).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)
