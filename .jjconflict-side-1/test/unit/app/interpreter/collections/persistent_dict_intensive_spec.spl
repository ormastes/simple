# Persistent Dictionary - Local Harness
#
# Parser-safe coverage for persistent dictionary behavior without depending on
# the runtime interpreter implementation.

use spipe.*

fn find_text_index(items: [text], target: text) -> i64:
    var i = 0
    while i < items.len():
        if items[i] == target:
            return i
        i = i + 1
    -1

fn text_array_update(items: [text], index: i64, value: text) -> [text]:
    var result: [text] = []
    var i = 0
    while i < items.len():
        if i == index:
            result = result + [value]
        else:
            result = result + [items[i]]
        i = i + 1
    result

fn text_array_remove(items: [text], index: i64) -> [text]:
    var result: [text] = []
    var i = 0
    while i < items.len():
        if i != index:
            result = result + [items[i]]
        i = i + 1
    result

fn array_insert(items: [i64], index: i64, value: i64) -> [i64]:
    var result: [i64] = []
    var i = 0
    while i < items.len():
        if i == index:
            result = result + [value]
        result = result + [items[i]]
        i = i + 1
    if index >= items.len():
        result = result + [value]
    result

fn array_update(items: [i64], index: i64, value: i64) -> [i64]:
    var result: [i64] = []
    var i = 0
    while i < items.len():
        if i == index:
            result = result + [value]
        else:
            result = result + [items[i]]
        i = i + 1
    result

fn array_remove(items: [i64], index: i64) -> [i64]:
    var result: [i64] = []
    var i = 0
    while i < items.len():
        if i != index:
            result = result + [items[i]]
        i = i + 1
    result

class PersistentDict:
    keys_: [text]
    values_: [i64]

    static fn new() -> PersistentDict:
        PersistentDict(keys_: [], values_: [])

    static fn from_entries(entries) -> PersistentDict:
        var dict = PersistentDict.new()
        for entry in entries:
            dict = dict.set(entry.0, entry.1)
        dict

    fn len() -> i64:
        self.keys_.len()

    fn is_empty() -> bool:
        self.len() == 0

    fn get(key: text):
        val idx = find_text_index(self.keys_, key)
        if idx >= 0:
            Some(self.values_[idx])
        else:
            None

    fn set(key: text, value: i64) -> PersistentDict:
        val idx = find_text_index(self.keys_, key)
        if idx >= 0:
            PersistentDict(
                keys_: text_array_update(self.keys_, idx, key),
                values_: array_update(self.values_, idx, value)
            )
        else:
            PersistentDict(
                keys_: self.keys_ + [key],
                values_: self.values_ + [value]
            )

    fn remove(key: text) -> PersistentDict:
        val idx = find_text_index(self.keys_, key)
        if idx >= 0:
            PersistentDict(
                keys_: text_array_remove(self.keys_, idx),
                values_: array_remove(self.values_, idx)
            )
        else:
            self

    fn merge(other: PersistentDict) -> PersistentDict:
        var merged = self
        var i = 0
        while i < other.len():
            merged = merged.set(other.keys_[i], other.values_[i])
            i = i + 1
        merged

    fn filter(pred) -> PersistentDict:
        var filtered = PersistentDict.new()
        var i = 0
        while i < self.len():
            if pred(self.keys_[i], self.values_[i]):
                filtered = filtered.set(self.keys_[i], self.values_[i])
            i = i + 1
        filtered

    fn map_values(mapper) -> PersistentDict:
        var mapped = PersistentDict.new()
        var i = 0
        while i < self.len():
            mapped = mapped.set(self.keys_[i], mapper(self.values_[i]))
            i = i + 1
        mapped

    fn entries():
        var result: [(text, i64)] = []
        var i = 0
        while i < self.len():
            result = result + [(self.keys_[i], self.values_[i])]
            i = i + 1
        result

    fn keys() -> [text]:
        var result: [text] = []
        var i = 0
        while i < self.len():
            result = result + [self.keys_[i]]
            i = i + 1
        result

    fn values() -> [i64]:
        var result: [i64] = []
        var i = 0
        while i < self.len():
            result = result + [self.values_[i]]
            i = i + 1
        result

fn entries_has(entries, key: text, value: i64) -> bool:
    for entry in entries:
        if entry.0 == key and entry.1 == value:
            return true
    false

describe "PersistentDict":
    describe "Core operations":
        it "creates an empty dict":
            val dict = PersistentDict.new()
            assert dict.len() == 0
            assert dict.is_empty()

        it "inserts and retrieves a value":
            val dict = PersistentDict.new().set("key", 42)
            assert dict.len() == 1
            assert dict.get("key") == Some(42)

        it "updates an existing key":
            val dict1 = PersistentDict.new().set("key", 1)
            val dict2 = dict1.set("key", 2)
            assert dict1.get("key") == Some(1)
            assert dict2.get("key") == Some(2)

        it "removes a key":
            val dict1 = PersistentDict.new().set("a", 1).set("b", 2)
            val dict2 = dict1.remove("a")
            assert dict1.len() == 2
            assert dict2.len() == 1
            assert dict2.get("a") == None
            assert dict2.get("b") == Some(2)

    describe "Immutability":
        it "keeps earlier versions unchanged":
            val base = PersistentDict.new().set("a", 1)
            val next = base.set("b", 2)
            val final = next.remove("a")
            assert base.get("b") == None
            assert next.get("a") == Some(1)
            assert final.get("a") == None

        it "supports a small version chain":
            var versions: [PersistentDict] = []
            var dict = PersistentDict.new()
            for i in 0..25:
                versions = versions + [dict]
                dict = dict.set("key_{i}", i)

            assert versions[0].len() == 0
            assert versions[10].len() == 10
            assert dict.len() == 25

    describe "Bulk operations":
        it "merge combines dicts":
            val dict1 = PersistentDict.new().set("a", 1).set("b", 2)
            val dict2 = PersistentDict.new().set("b", 20).set("c", 3)
            val merged = dict1.merge(dict2)
            assert merged.len() == 3
            assert merged.get("a") == Some(1)
            assert merged.get("b") == Some(20)
            assert merged.get("c") == Some(3)

        it "filter keeps matching entries":
            var dict = PersistentDict.new()
            for i in 0..12:
                dict = dict.set("key_{i}", i)

            val evens = dict.filter(\k, v: v % 2 == 0)
            assert evens.len() == 6
            assert evens.get("key_0") == Some(0)
            assert evens.get("key_1") == None
            assert evens.get("key_10") == Some(10)

        it "map_values transforms values":
            val doubled = PersistentDict.new()
                .set("a", 1)
                .set("b", 2)
                .map_values(\v: v * 2)
            assert doubled.get("a") == Some(2)
            assert doubled.get("b") == Some(4)

    describe "Conversion":
        it "round-trips through entries":
            val dict = PersistentDict.from_entries([
                ("a", 1),
                ("b", 2),
                ("c", 3)
            ])
            val entries = dict.entries()
            assert dict.len() == 3
            assert entries.len() == 3
            assert entries_has(entries, "a", 1)
            assert entries_has(entries, "b", 2)
            assert entries_has(entries, "c", 3)

        it "returns keys and values":
            val dict = PersistentDict.from_entries([
                ("a", 1),
                ("b", 2)
            ])
            val keys = dict.keys()
            val values = dict.values()
            assert keys.len() == 2
            assert values.len() == 2
            assert keys.contains("a")
            assert keys.contains("b")
            assert values.contains(1)
            assert values.contains(2)

    describe "Edge cases":
        it "handles empty string keys":
            val dict = PersistentDict.new().set("", 42)
            assert dict.get("") == Some(42)

        it "handles unicode keys":
            val dict = PersistentDict.new()
                .set("héllo", 1)
                .set("世界", 2)
                .set("🚀", 3)
            assert dict.get("héllo") == Some(1)
            assert dict.get("世界") == Some(2)
            assert dict.get("🚀") == Some(3)

    describe "Array helpers":
        it "inserts, updates, and removes at the expected position":
            val arr = [1, 2, 3]
            assert array_insert(arr, 1, 99) == [1, 99, 2, 3]
            assert array_update(arr, 1, 99) == [1, 99, 3]
            assert array_remove(arr, 1) == [1, 3]

        it "leaves the original array unchanged":
            val arr = [1, 2, 3]
            val _ = array_insert(arr, 1, 99)
            val _ = array_update(arr, 1, 99)
            val _ = array_remove(arr, 1)
            assert arr == [1, 2, 3]
