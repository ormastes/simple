use std.io_runtime.{file_read}
use app.cli.bootstrap_main.{native_build_single_spl_positional}

describe "native-build CLI arg source regressions":
    it "routes omitted --backend through the default Simple LLVM backend":
        val source = file_read("src/app/cli/_CliMain/main_and_help.spl")
        expect(source).to_contain("not saw_backend")

    it "matches only --entry and --entry=value for native-build entry parsing":
        val source = file_read("src/app/io/_CliCompile/compile_targets.spl")
        expect(source).to_contain("arg == \"--entry\" or arg.starts_with(\"--entry=\")")
        expect(source.contains("elif a.starts_with(\"--entry\")")).to_equal(false)

    it "selects the pure-Simple lane only for an isolated bare source file":
        val args = ["simple", "native-build", "probe.spl", "-o", "probe"]
        expect(native_build_single_spl_positional(args)).to_equal("probe.spl")

    it "preserves explicit and positional source inputs for the full native builder":
        val flagged = ["simple", "native-build", "--source", "generated", "probe.spl"]
        val positional = ["simple", "native-build", "generated", "probe.spl"]
        expect(native_build_single_spl_positional(flagged)).to_equal("")
        expect(native_build_single_spl_positional(positional)).to_equal("")
