# @cover src/app/cli/theme_sync.spl 70%
"""
# Theme Sync CLI list Specification

**Feature IDs:** #THEME-SYNC-003
**Category:** Tooling
**Difficulty:** 1/5
**Status:** Implemented

## Overview

Verifies the helper functions used by the theme-sync CLI: argument parsing,
the `_read_sdn_value` helper, and stub subcommand behavior.

These tests are self-contained (no filesystem access) and verify the
pure logic components of the CLI.

## Behavior
- _flag_value extracts --flag=value from args list
- _has_flag detects boolean flags
- render-wm stub returns 0 and prints deferred message
- render-app stub returns 0 and prints deferred message
- dump-local defaults to obsidian theme when --theme not provided
- diff requires --local and --remote flags
"""

# ============================================================================
# Test helpers (inline the pure functions from theme_sync.spl for unit testing)
# ============================================================================

fn _test_flag_value(args: [text], prefix: text) -> text:
    """Inline copy of _flag_value for unit testing."""
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with(prefix):
            return arg[prefix.len():]
        i = i + 1
    ""

fn _test_has_flag(args: [text], flag: text) -> bool:
    """Inline copy of _has_flag for unit testing."""
    var i = 0
    while i < args.len():
        if args[i] == flag:
            return true
        i = i + 1
    false

fn _test_read_sdn_value(content: text, key: text) -> text:
    """Inline copy of _read_sdn_value for unit testing."""
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        val prefix = "{key}: "
        if line.starts_with(prefix):
            val raw = line[prefix.len():]
            if raw.starts_with("\"") and raw.ends_with("\"") and raw.len() >= 2:
                return raw[1:raw.len() - 1]
            return raw
        i = i + 1
    ""

# ============================================================================
# Test Group 1: Argument parsing helpers
# ============================================================================

describe "theme_sync _flag_value":
    it "extracts --theme=obsidian":
        val args = ["dump-local", "--theme=obsidian", "--out=out.sdn"]
        expect(_test_flag_value(args, "--theme=")).to_equal("obsidian")

    it "extracts --out=path":
        val args = ["dump-local", "--theme=glass", "--out=/tmp/out.sdn"]
        expect(_test_flag_value(args, "--out=")).to_equal("/tmp/out.sdn")

    it "returns empty string when flag not found":
        val args = ["dump-local", "--out=/tmp/out.sdn"]
        expect(_test_flag_value(args, "--theme=")).to_equal("")

    it "extracts --local= path":
        val args = ["diff", "--local=local.sdn", "--remote=remote.sdn"]
        expect(_test_flag_value(args, "--local=")).to_equal("local.sdn")

    it "extracts --remote= path":
        val args = ["diff", "--local=local.sdn", "--remote=remote.sdn"]
        expect(_test_flag_value(args, "--remote=")).to_equal("remote.sdn")

    it "handles empty args list":
        val args: [text] = []
        expect(_test_flag_value(args, "--theme=")).to_equal("")

describe "theme_sync _has_flag":
    it "detects --no-color flag":
        val args = ["diff", "--local=a.sdn", "--remote=b.sdn", "--no-color"]
        expect(_test_has_flag(args, "--no-color")).to_equal(true)

    it "returns false when flag absent":
        val args = ["diff", "--local=a.sdn", "--remote=b.sdn"]
        expect(_test_has_flag(args, "--no-color")).to_equal(false)

    it "handles empty args list":
        val args: [text] = []
        expect(_test_has_flag(args, "--no-color")).to_equal(false)

# ============================================================================
# Test Group 2: _read_sdn_value helper
# ============================================================================

describe "theme_sync _read_sdn_value":
    it "extracts quoted value":
        val content = "mode: \"reconcile\"\nset_at: \"2026-04-12\"\n"
        expect(_test_read_sdn_value(content, "mode")).to_equal("reconcile")

    it "extracts unquoted value":
        val content = "mode: reconcile\n"
        expect(_test_read_sdn_value(content, "mode")).to_equal("reconcile")

    it "extracts pulled_at":
        val content = "display_name: \"SimpleOS Obsidian\"\npulled_at: \"2026-04-12\"\n"
        expect(_test_read_sdn_value(content, "pulled_at")).to_equal("2026-04-12")

    it "returns empty string when key not found":
        val content = "display_name: \"SimpleOS Obsidian\"\npulled_at: \"2026-04-12\"\n"
        expect(_test_read_sdn_value(content, "nonexistent_key")).to_equal("")

    it "handles multiline content (stops at first match)":
        val content = "key: \"first\"\nkey: \"second\"\n"
        expect(_test_read_sdn_value(content, "key")).to_equal("first")

    it "handles empty content":
        val content = ""
        expect(_test_read_sdn_value(content, "mode")).to_equal("")

# ============================================================================
# Test Group 3: SDN round-trip for sync_mode.sdn format
# ============================================================================

describe "read sync_mode.sdn format":
    it "reads mode field from sync_mode.sdn content":
        val sync_mode_content = "mode: reconcile\nreason: |\n    Initial reconciliation\nset_at: \"2026-04-12\"\n"
        expect(_test_read_sdn_value(sync_mode_content, "mode")).to_equal("reconcile")

    it "reads set_at field from sync_mode.sdn content":
        val sync_mode_content = "mode: push_only\nset_at: \"2026-04-12\"\n"
        expect(_test_read_sdn_value(sync_mode_content, "set_at")).to_equal("2026-04-12")

# ============================================================================
# Test Group 4: Valid theme names for dump-local
# ============================================================================

use common.ui.glass.tokens.{StitchDesignSystem}

describe "theme_sync valid theme detection":
    it "obsidian is a valid theme name":
        val ds = StitchDesignSystem.obsidian()
        expect(ds.metadata.display_name).to_equal("SimpleOS Obsidian")

    it "glass is a valid theme name":
        val ds = StitchDesignSystem.glass()
        expect(ds.metadata.display_name).to_equal("SimpleOS Glass")

    it "obsidian theme has color_mode DARK":
        val ds = StitchDesignSystem.obsidian()
        expect(ds.metadata.color_mode).to_equal("DARK")

    it "glass theme has color_mode DARK":
        val ds = StitchDesignSystem.glass()
        expect(ds.metadata.color_mode).to_equal("DARK")
