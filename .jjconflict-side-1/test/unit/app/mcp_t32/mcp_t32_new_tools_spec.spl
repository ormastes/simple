# MCP T32 New Tools spec — tests CLI-MCP gap closure (F3) and CMM validator (F4)
# Covers: t32_session_info, t32_action_list, t32_status_snapshot, t32_cmm_validate

# --- Inlined helper classes (no imports) ---

class T32SessionInfo:
    session_id: text
    host: text
    port: i64
    architecture: text
    connected: bool
    core_count: i64
    current_core_id: i64

class T32ActionEntry:
    key: text
    label: text
    action_type: text

class T32StatusSnapshot:
    run_state: text
    system_state: text
    session_id: text
    core_id: i64
    message_line: text
    connected: bool

class T32CmmFinding:
    line: i64
    command: text
    severity: text
    message: text
    suggestion: text

class T32CmmValidateResult:
    classification: text
    findings: [T32CmmFinding]

# --- Inlined session info lookup ---

fn make_test_sessions() -> [T32SessionInfo]:
    var sessions: [T32SessionInfo] = []
    sessions.push(T32SessionInfo(
        session_id: "sess_001",
        host: "localhost",
        port: 20000,
        architecture: "ARM",
        connected: true,
        core_count: 4,
        current_core_id: 0
    ))
    sessions.push(T32SessionInfo(
        session_id: "sess_002",
        host: "192.168.1.100",
        port: 20001,
        architecture: "RISCV",
        connected: true,
        core_count: 2,
        current_core_id: 1
    ))
    sessions.push(T32SessionInfo(
        session_id: "sess_disconnected",
        host: "10.0.0.5",
        port: 20002,
        architecture: "TriCore",
        connected: false,
        core_count: 0,
        current_core_id: -1
    ))
    sessions

fn session_info_lookup(session_id: text) -> T32SessionInfo:
    val sessions = make_test_sessions()
    for s in sessions:
        if s.session_id == session_id:
            return s
    T32SessionInfo(
        session_id: "",
        host: "",
        port: 0,
        architecture: "",
        connected: false,
        core_count: 0,
        current_core_id: -1
    )

fn session_info_error(session_id: text) -> text:
    val info = session_info_lookup(session_id)
    if info.session_id == "":
        return "T4200: Unknown session '{session_id}' — use t32_sessions_list to discover sessions."
    ""

# --- Inlined action list logic ---

class T32WindowActions:
    window_key: text
    actions: [T32ActionEntry]

fn make_test_window_actions() -> [T32WindowActions]:
    var windows: [T32WindowActions] = []

    var reg_actions: [T32ActionEntry] = []
    reg_actions.push(T32ActionEntry(key: "reg.copy", label: "Copy Register Value", action_type: "read"))
    reg_actions.push(T32ActionEntry(key: "reg.set", label: "Set Register Value", action_type: "write"))
    reg_actions.push(T32ActionEntry(key: "reg.format", label: "Change Format", action_type: "view"))
    windows.push(T32WindowActions(window_key: "register", actions: reg_actions))

    var src_actions: [T32ActionEntry] = []
    src_actions.push(T32ActionEntry(key: "src.goto", label: "Go to Line", action_type: "navigate"))
    src_actions.push(T32ActionEntry(key: "src.bp", label: "Set Breakpoint", action_type: "write"))
    src_actions.push(T32ActionEntry(key: "src.find", label: "Find Text", action_type: "read"))
    src_actions.push(T32ActionEntry(key: "src.copy", label: "Copy Selection", action_type: "read"))
    windows.push(T32WindowActions(window_key: "source", actions: src_actions))

    var empty_actions: [T32ActionEntry] = []
    windows.push(T32WindowActions(window_key: "area", actions: empty_actions))

    windows

fn action_list_lookup(window_key: text) -> [T32ActionEntry]:
    val windows = make_test_window_actions()
    for w in windows:
        if w.window_key == window_key:
            return w.actions
    var sentinel: [T32ActionEntry] = []
    sentinel.push(T32ActionEntry(key: "__error__", label: "", action_type: ""))
    sentinel

fn action_list_is_error(actions: [T32ActionEntry]) -> bool:
    if actions.len() == 1:
        if actions[0].key == "__error__":
            return true
    false

fn action_list_error(window_key: text) -> text:
    "T4201: Unknown window '{window_key}' — use t32_window_list to discover windows."

fn action_list_filter_by_type(actions: [T32ActionEntry], action_type: text) -> [T32ActionEntry]:
    var filtered: [T32ActionEntry] = []
    for a in actions:
        if a.action_type == action_type:
            filtered.push(a)
    filtered

# --- Inlined status snapshot logic ---

fn make_test_status(run_state: text, system_state: text, session_id: text, core_id: i64, message_line: text, connected: bool) -> T32StatusSnapshot:
    T32StatusSnapshot(
        run_state: run_state,
        system_state: system_state,
        session_id: session_id,
        core_id: core_id,
        message_line: message_line,
        connected: connected
    )

# --- Inlined CMM blocking detection (reuses session_tools.spl patterns) ---

fn cmm_find_char(s: text, ch: text) -> i64:
    var i = 0
    for c in s:
        if c == ch:
            return i
        i = i + 1
    -1

fn cmm_to_upper(s: text) -> text:
    s.upper()

fn cmm_trim(s: text) -> text:
    s.trim()

fn cmm_detect_blocking_pattern(line: text) -> T32CmmFinding:
    val upper = cmm_to_upper(cmm_trim(line))

    if upper.starts_with("DIALOG.OK"):
        return T32CmmFinding(
            line: 0, command: "DIALOG.OK", severity: "BLOCK",
            message: "GUI dialog blocks in headless mode",
            suggestion: ""
        )
    if upper.starts_with("DIALOG.YESNO"):
        return T32CmmFinding(
            line: 0, command: "DIALOG.YESNO", severity: "BLOCK",
            message: "GUI dialog blocks waiting for user input",
            suggestion: "ENTRY &confirm\nIF \"&confirm\"==\"YES\""
        )
    if upper.starts_with("DIALOG.FILE"):
        return T32CmmFinding(
            line: 0, command: "DIALOG.FILE", severity: "BLOCK",
            message: "File dialog blocks waiting for user selection",
            suggestion: "Pass file path as tool argument instead"
        )
    if upper == "INKEY" or upper.starts_with("INKEY "):
        return T32CmmFinding(
            line: 0, command: "INKEY", severity: "BLOCK",
            message: "INKEY blocks waiting for keyboard input",
            suggestion: "ENTRY &var\n; Pass value via tool parameter"
        )
    if upper == "ENTER" or upper.starts_with("ENTER "):
        return T32CmmFinding(
            line: 0, command: "ENTER", severity: "BLOCK",
            message: "ENTER blocks waiting for user input in AREA window",
            suggestion: "ENTRY &var\n; Pass value via tool parameter"
        )
    if upper == "PAUSE" or upper.starts_with("PAUSE "):
        return T32CmmFinding(
            line: 0, command: "PAUSE", severity: "BLOCK",
            message: "PAUSE halts script until user resumes",
            suggestion: "PRINT \"checkpoint: <description>\"\n; Remove PAUSE for automation"
        )
    if upper == "STOP" or upper.starts_with("STOP "):
        return T32CmmFinding(
            line: 0, command: "STOP", severity: "BLOCK",
            message: "STOP halts PRACTICE script execution",
            suggestion: ""
        )
    if upper.starts_with("SCREEN.WAIT"):
        return T32CmmFinding(
            line: 0, command: "SCREEN.WAIT", severity: "WARN",
            message: "SCREEN.WAIT may stall without display",
            suggestion: ""
        )
    if upper.starts_with("WAIT "):
        val has_timeout = upper.contains("S") or upper.contains("MS")
        if has_timeout == false:
            return T32CmmFinding(
                line: 0, command: "WAIT", severity: "WARN",
                message: "Unbounded WAIT may block indefinitely",
                suggestion: "WAIT 5.s\n; Add explicit timeout"
            )
    # No blocking pattern found
    T32CmmFinding(line: 0, command: "", severity: "", message: "", suggestion: "")

fn cmm_is_empty_finding(f: T32CmmFinding) -> bool:
    f.command == ""

fn cmm_split_lines(source: text) -> [text]:
    source.split("\n")

fn cmm_validate(source: text, mode: text) -> T32CmmValidateResult:
    val lines = cmm_split_lines(source)
    var findings: [T32CmmFinding] = []
    var line_num = 1
    for line in lines:
        val trimmed = cmm_trim(line)
        if trimmed.len() > 0:
            val finding = cmm_detect_blocking_pattern(trimmed)
            if cmm_is_empty_finding(finding) == false:
                val with_line = T32CmmFinding(
                    line: line_num,
                    command: finding.command,
                    severity: finding.severity,
                    message: finding.message,
                    suggestion: finding.suggestion
                )
                findings.push(with_line)
        line_num = line_num + 1

    if findings.len() == 0:
        return T32CmmValidateResult(classification: "safe", findings: findings)

    var has_block = false
    for f in findings:
        if f.severity == "BLOCK":
            has_block = true
    if has_block:
        return T32CmmValidateResult(classification: "needs_manual_rewrite", findings: findings)

    T32CmmValidateResult(classification: "has_warnings", findings: findings)

# --- Tests ---

describe "T32 MCP New Tools — CLI-MCP Gap Closure":

    # =========================================================================
    # Test Group 1: t32_session_info (REQ-F3-001, AC-F3-01)
    # =========================================================================
    context "t32_session_info":

        it "returns session details for valid id":
            val info = session_info_lookup("sess_001")
            expect(info.session_id).to_equal("sess_001")
            expect(info.host).to_equal("localhost")

        it "returns error for unknown session id":
            val err = session_info_error("nonexistent_session")
            expect(err).to_start_with("T4200")
            expect(err).to_contain("nonexistent_session")
            expect(err).to_contain("t32_sessions_list")

        it "includes host and port fields":
            val info = session_info_lookup("sess_001")
            expect(info.host).to_equal("localhost")
            expect(info.port).to_equal(20000)

        it "includes architecture field":
            val info = session_info_lookup("sess_002")
            expect(info.architecture).to_equal("RISCV")

        it "includes connection state":
            val info = session_info_lookup("sess_disconnected")
            expect(info.connected).to_equal(false)
            val info_ok = session_info_lookup("sess_001")
            expect(info_ok.connected).to_equal(true)

        it "includes core count":
            val info = session_info_lookup("sess_001")
            expect(info.core_count).to_equal(4)
            val info2 = session_info_lookup("sess_002")
            expect(info2.core_count).to_equal(2)

        it "includes current core id":
            val info = session_info_lookup("sess_001")
            expect(info.current_core_id).to_equal(0)
            val info2 = session_info_lookup("sess_002")
            expect(info2.current_core_id).to_equal(1)

        it "disconnected session has zero core count":
            val info = session_info_lookup("sess_disconnected")
            expect(info.core_count).to_equal(0)
            expect(info.current_core_id).to_equal(-1)

    # =========================================================================
    # Test Group 2: t32_action_list (REQ-F3-002, AC-F3-02)
    # =========================================================================
    context "t32_action_list":

        it "lists all actions for register window":
            val actions = action_list_lookup("register")
            expect(actions.len()).to_equal(3)

        it "lists all actions for source window":
            val actions = action_list_lookup("source")
            expect(actions.len()).to_equal(4)

        it "returns empty list for window with no actions":
            val actions = action_list_lookup("area")
            expect(actions.len()).to_equal(0)

        it "returns error for unknown window":
            val actions = action_list_lookup("nonexistent_window")
            expect(action_list_is_error(actions)).to_equal(true)
            val err = action_list_error("nonexistent_window")
            expect(err).to_start_with("T4201")
            expect(err).to_contain("nonexistent_window")

        it "action entries have key, label, type fields":
            val actions = action_list_lookup("register")
            val first = actions[0]
            expect(first.key).to_equal("reg.copy")
            expect(first.label).to_equal("Copy Register Value")
            expect(first.action_type).to_equal("read")

        it "filters by action type read":
            val actions = action_list_lookup("source")
            val read_actions = action_list_filter_by_type(actions, "read")
            expect(read_actions.len()).to_equal(2)
            expect(read_actions[0].key).to_equal("src.find")

        it "filters by action type write":
            val actions = action_list_lookup("source")
            val write_actions = action_list_filter_by_type(actions, "write")
            expect(write_actions.len()).to_equal(1)
            expect(write_actions[0].key).to_equal("src.bp")

        it "returns all actions when no filter applied":
            val actions = action_list_lookup("register")
            val all_types = action_list_filter_by_type(actions, "")
            # Empty filter returns nothing — use unfiltered list for "all"
            expect(all_types.len()).to_equal(0)
            expect(actions.len()).to_equal(3)

    # =========================================================================
    # Test Group 3: t32_status_snapshot (REQ-F3-004, AC-F3-04)
    # =========================================================================
    context "t32_status_snapshot":

        it "returns run_state running":
            val snap = make_test_status("running", "system up", "sess_001", 0, "", true)
            expect(snap.run_state).to_equal("running")

        it "returns run_state stopped":
            val snap = make_test_status("stopped", "break at main", "sess_001", 0, "Break at 0x08001234", true)
            expect(snap.run_state).to_equal("stopped")

        it "returns system state text":
            val snap = make_test_status("stopped", "power debug ready", "sess_001", 0, "", true)
            expect(snap.system_state).to_equal("power debug ready")

        it "returns session context with id and core":
            val snap = make_test_status("running", "up", "sess_002", 1, "", true)
            expect(snap.session_id).to_equal("sess_002")
            expect(snap.core_id).to_equal(1)

        it "returns message line if available":
            val snap = make_test_status("stopped", "break", "sess_001", 0, "Break at main+0x10", true)
            expect(snap.message_line).to_equal("Break at main+0x10")

        it "returns connected=false when disconnected":
            val snap = make_test_status("unknown", "disconnected", "sess_003", -1, "", false)
            expect(snap.connected).to_equal(false)
            expect(snap.run_state).to_equal("unknown")

    # =========================================================================
    # Test Group 4: t32_cmm_validate mode=check (REQ-F4-001, REQ-F4-002, AC-F4-01)
    # =========================================================================
    context "t32_cmm_validate mode=check":

        it "detects DIALOG.OK as BLOCK":
            val result = cmm_validate("DIALOG.OK \"Flash done\"", "check")
            expect(result.classification).to_equal("needs_manual_rewrite")
            expect(result.findings.len()).to_equal(1)
            expect(result.findings[0].command).to_equal("DIALOG.OK")
            expect(result.findings[0].severity).to_equal("BLOCK")

        it "detects DIALOG.YESNO as BLOCK":
            val result = cmm_validate("DIALOG.YESNO \"Erase flash?\"", "check")
            expect(result.classification).to_equal("needs_manual_rewrite")
            expect(result.findings[0].command).to_equal("DIALOG.YESNO")
            expect(result.findings[0].severity).to_equal("BLOCK")

        it "detects DIALOG.FILE as BLOCK":
            val result = cmm_validate("DIALOG.FILE \"*.elf\"", "check")
            expect(result.findings[0].command).to_equal("DIALOG.FILE")
            expect(result.findings[0].severity).to_equal("BLOCK")

        it "detects INKEY as BLOCK":
            val result = cmm_validate("INKEY &pressed", "check")
            expect(result.findings[0].command).to_equal("INKEY")
            expect(result.findings[0].severity).to_equal("BLOCK")

        it "detects ENTER as BLOCK":
            val result = cmm_validate("ENTER &value", "check")
            expect(result.findings[0].command).to_equal("ENTER")
            expect(result.findings[0].severity).to_equal("BLOCK")

        it "detects PAUSE as BLOCK":
            val result = cmm_validate("PAUSE", "check")
            expect(result.findings[0].command).to_equal("PAUSE")
            expect(result.findings[0].severity).to_equal("BLOCK")

        it "detects STOP as BLOCK":
            val result = cmm_validate("STOP", "check")
            expect(result.findings[0].command).to_equal("STOP")
            expect(result.findings[0].severity).to_equal("BLOCK")

        it "detects SCREEN.WAIT as WARN":
            val result = cmm_validate("SCREEN.WAIT", "check")
            expect(result.classification).to_equal("has_warnings")
            expect(result.findings[0].command).to_equal("SCREEN.WAIT")
            expect(result.findings[0].severity).to_equal("WARN")

        it "safe script returns classification=safe":
            val result = cmm_validate("ENTRY &addr\nData.dump &addr\nENDDO", "check")
            expect(result.classification).to_equal("safe")
            expect(result.findings.len()).to_equal(0)

    # =========================================================================
    # Test Group 5: t32_cmm_validate mode=report (REQ-F4-003, AC-F4-02)
    # =========================================================================
    context "t32_cmm_validate mode=report":

        it "report includes line numbers":
            val result = cmm_validate("ENTRY &addr\nDIALOG.OK \"Done\"\nENDDO", "report")
            expect(result.findings.len()).to_equal(1)
            expect(result.findings[0].line).to_equal(2)

        it "report classifies severity BLOCK":
            val result = cmm_validate("DIALOG.YESNO \"Sure?\"", "report")
            expect(result.findings[0].severity).to_equal("BLOCK")

        it "report classifies severity WARN":
            val result = cmm_validate("SCREEN.WAIT", "report")
            expect(result.findings[0].severity).to_equal("WARN")

        it "multiple findings in one script":
            val source = "DIALOG.OK \"Start\"\nENTRY &addr\nPAUSE\nDIALOG.YESNO \"Continue?\"\nENDDO"
            val result = cmm_validate(source, "report")
            expect(result.findings.len()).to_equal(3)
            expect(result.findings[0].command).to_equal("DIALOG.OK")
            expect(result.findings[1].command).to_equal("PAUSE")
            expect(result.findings[2].command).to_equal("DIALOG.YESNO")

        it "nested patterns detected — DIALOG inside IF context":
            val source = "IF TRUE()\n(\n  DIALOG.OK \"inside if\"\n)\nENDDO"
            val result = cmm_validate(source, "report")
            expect(result.findings.len()).to_equal(1)
            expect(result.findings[0].command).to_equal("DIALOG.OK")
            expect(result.findings[0].line).to_equal(3)

        it "empty script returns safe":
            val result = cmm_validate("", "report")
            expect(result.classification).to_equal("safe")
            expect(result.findings.len()).to_equal(0)

        it "report includes command name":
            val result = cmm_validate("STOP", "report")
            expect(result.findings[0].command).to_equal("STOP")
            expect(result.findings[0].message).to_contain("PRACTICE")

    # =========================================================================
    # Test Group 6: t32_cmm_validate mode=suggest (REQ-F4-004, AC-F4-03)
    # =========================================================================
    context "t32_cmm_validate mode=suggest":

        it "DIALOG.YESNO suggests ENTRY &confirm pattern":
            val result = cmm_validate("DIALOG.YESNO \"Erase?\"", "suggest")
            expect(result.findings[0].suggestion).to_contain("ENTRY")
            expect(result.findings[0].suggestion).to_contain("confirm")

        it "DIALOG.FILE suggests tool argument path":
            val result = cmm_validate("DIALOG.FILE \"*.elf\"", "suggest")
            expect(result.findings[0].suggestion).to_contain("tool argument")

        it "ENTER suggests ENTRY &var pattern":
            val result = cmm_validate("ENTER &value", "suggest")
            expect(result.findings[0].suggestion).to_contain("ENTRY")
            expect(result.findings[0].suggestion).to_contain("var")

        it "PAUSE suggests PRINT checkpoint pattern":
            val result = cmm_validate("PAUSE", "suggest")
            expect(result.findings[0].suggestion).to_contain("PRINT")
            expect(result.findings[0].suggestion).to_contain("checkpoint")

        it "unbounded WAIT suggests timeout pattern":
            val result = cmm_validate("WAIT !STATE.RUN()", "suggest")
            expect(result.findings.len()).to_equal(1)
            expect(result.findings[0].severity).to_equal("WARN")
            expect(result.findings[0].suggestion).to_contain("timeout")

        it "safe script has no suggestions":
            val result = cmm_validate("ENTRY &addr\nData.dump &addr", "suggest")
            expect(result.findings.len()).to_equal(0)
