# Feature IDs Extended Tests
# Tests the 3 new FeatureId variants: PracticeScript, OpenocdMonitor, SemihostRead.

# --- Local copy of FeatureId with new variants ---

enum FeatureId:
    Halt
    Resume
    SingleStep
    StepOver
    Reset
    ReadMemory
    WriteMemory
    ReadRegister
    WriteRegister
    ReadAllRegisters
    SetBreakpoint
    ClearBreakpoint
    SetWatchpoint
    FlashProgram
    SystemReset
    TraceCapture
    CoverageCollect
    PracticeScript
    OpenocdMonitor
    SemihostRead

    fn to_string() -> text:
        match self:
            Halt: "Halt"
            Resume: "Resume"
            SingleStep: "SingleStep"
            StepOver: "StepOver"
            Reset: "Reset"
            ReadMemory: "ReadMemory"
            WriteMemory: "WriteMemory"
            ReadRegister: "ReadRegister"
            WriteRegister: "WriteRegister"
            ReadAllRegisters: "ReadAllRegisters"
            SetBreakpoint: "SetBreakpoint"
            ClearBreakpoint: "ClearBreakpoint"
            SetWatchpoint: "SetWatchpoint"
            FlashProgram: "FlashProgram"
            SystemReset: "SystemReset"
            TraceCapture: "TraceCapture"
            CoverageCollect: "CoverageCollect"
            PracticeScript: "PracticeScript"
            OpenocdMonitor: "OpenocdMonitor"
            SemihostRead: "SemihostRead"

    fn eq(other: FeatureId) -> bool:
        self.to_string() == other.to_string()

# --- Tests ---

describe "FeatureId new variants to_string":
    it "PracticeScript has correct to_string":
        val f = FeatureId.PracticeScript
        expect(f.to_string()).to_equal("PracticeScript")

    it "OpenocdMonitor has correct to_string":
        val f = FeatureId.OpenocdMonitor
        expect(f.to_string()).to_equal("OpenocdMonitor")

    it "SemihostRead has correct to_string":
        val f = FeatureId.SemihostRead
        expect(f.to_string()).to_equal("SemihostRead")

describe "FeatureId new variants distinctness":
    it "PracticeScript is not OpenocdMonitor":
        val a = FeatureId.PracticeScript
        val b = FeatureId.OpenocdMonitor
        expect(a.eq(b)).to_equal(false)

    it "OpenocdMonitor is not SemihostRead":
        val a = FeatureId.OpenocdMonitor
        val b = FeatureId.SemihostRead
        expect(a.eq(b)).to_equal(false)

    it "PracticeScript equals itself":
        val a = FeatureId.PracticeScript
        val b = FeatureId.PracticeScript
        expect(a.eq(b)).to_equal(true)

    it "new variants are distinct from existing":
        val a = FeatureId.PracticeScript
        val b = FeatureId.FlashProgram
        expect(a.eq(b)).to_equal(false)

    it "OpenocdMonitor is distinct from SystemReset":
        val a = FeatureId.OpenocdMonitor
        val b = FeatureId.SystemReset
        expect(a.eq(b)).to_equal(false)
