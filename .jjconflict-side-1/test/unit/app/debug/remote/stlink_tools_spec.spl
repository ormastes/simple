# ST-Link Tools Protocol Tests
# Mock simulation tests for StLinkToolsClient operations.

# --- Local simulation of ST-Link tools ---

class StLinkProbeInfo:
    serial: text
    chip_id: i64
    flash_size: i64
    sram_size: i64
    description: text

class MockStLinkClient:
    serial: text
    connected: bool
    last_command: text

impl MockStLinkClient:
    static fn for_stm32h7() -> MockStLinkClient:
        MockStLinkClient(
            serial: "002600213137510833333639",
            connected: true,
            last_command: ""
        )

    static fn for_stm32wb() -> MockStLinkClient:
        MockStLinkClient(
            serial: "0671FF555755846687041216",
            connected: true,
            last_command: ""
        )

    fn probe_info() -> Result<StLinkProbeInfo, text>:
        if not self.connected:
            return Err("not connected")
        Ok(StLinkProbeInfo(
            serial: self.serial,
            chip_id: 0x480,
            flash_size: 2097152,
            sram_size: 131072,
            description: "STM32H7xx"
        ))

    fn chip_id() -> Result<i64, text>:
        if not self.connected:
            return Err("not connected")
        if self.serial == "002600213137510833333639":
            Ok(0x480)
        else:
            Ok(0x495)

    fn flash_size() -> Result<i64, text>:
        if not self.connected:
            return Err("not connected")
        if self.serial == "002600213137510833333639":
            Ok(2097152)
        else:
            Ok(1048576)

    fn sram_size() -> Result<i64, text>:
        if not self.connected:
            return Err("not connected")
        if self.serial == "002600213137510833333639":
            Ok(131072)
        else:
            Ok(262144)

    me flash_write(binary_path: text, addr: i64) -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        self.last_command = "st-flash write {binary_path} 0x{addr}"
        Ok("Flash written successfully")

    me flash_erase() -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        self.last_command = "st-flash erase"
        Ok("Flash erased")

    me reset() -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        self.last_command = "st-flash reset"
        Ok("Target reset")

    fn read_memory(addr: i64, size: i32) -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        Ok("00000000")

    me disconnect():
        self.connected = false

# --- Tests ---

describe "StLinkToolsClient STM32H7 probe":
    it "probe info returns correct serial":
        val client = MockStLinkClient.for_stm32h7()
        val info = client.probe_info()
        expect(info != nil).to_equal(true)

    it "chip_id returns 0x480 for STM32H7":
        val client = MockStLinkClient.for_stm32h7()
        val chip = client.chip_id()
        expect(chip != nil).to_equal(true)

    it "flash_size returns 2MB for STM32H7":
        val client = MockStLinkClient.for_stm32h7()
        val size = client.flash_size()
        expect(size != nil).to_equal(true)

    it "sram_size returns 128KB for STM32H7":
        val client = MockStLinkClient.for_stm32h7()
        val size = client.sram_size()
        expect(size != nil).to_equal(true)

    it "serial is correct":
        val client = MockStLinkClient.for_stm32h7()
        expect(client.serial).to_equal("002600213137510833333639")

describe "StLinkToolsClient STM32WB probe":
    it "chip_id returns 0x495 for STM32WB":
        val client = MockStLinkClient.for_stm32wb()
        val chip = client.chip_id()
        expect(chip != nil).to_equal(true)

    it "flash_size returns 1MB for STM32WB":
        val client = MockStLinkClient.for_stm32wb()
        val size = client.flash_size()
        expect(size != nil).to_equal(true)

    it "sram_size returns 256KB for STM32WB":
        val client = MockStLinkClient.for_stm32wb()
        val size = client.sram_size()
        expect(size != nil).to_equal(true)

    it "serial is correct":
        val client = MockStLinkClient.for_stm32wb()
        expect(client.serial).to_equal("0671FF555755846687041216")

describe "StLinkToolsClient flash operations":
    it "flash_write sets last command":
        var client = MockStLinkClient.for_stm32h7()
        client.flash_write("app.bin", 0x08000000)
        expect(client.last_command).to_contain("st-flash write")

    it "flash_erase sets last command":
        var client = MockStLinkClient.for_stm32h7()
        client.flash_erase()
        expect(client.last_command).to_contain("st-flash erase")

    it "reset sets last command":
        var client = MockStLinkClient.for_stm32h7()
        client.reset()
        expect(client.last_command).to_contain("st-flash reset")

    it "read_memory returns data":
        val client = MockStLinkClient.for_stm32h7()
        val mem = client.read_memory(0x08000000, 4)
        expect(mem != nil).to_equal(true)

describe "StLinkToolsClient disconnect":
    it "disconnect sets connected to false":
        var client = MockStLinkClient.for_stm32h7()
        expect(client.connected).to_equal(true)
        client.disconnect()
        expect(client.connected).to_equal(false)

    it "operations after disconnect fail":
        var client = MockStLinkClient.for_stm32h7()
        client.disconnect()
        val result = client.chip_id()
        expect(client.connected).to_equal(false)
