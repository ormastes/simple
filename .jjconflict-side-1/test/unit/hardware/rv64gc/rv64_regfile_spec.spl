"""
# RV64 Register File Unit Tests

**Feature IDs:** #RV64-REGFILE-001
**Category:** Hardware
**Difficulty:** 1/5
**Status:** Draft

## Overview

Unit tests for the 32×64-bit integer register file.
x0 is hardwired to zero; x1-x31 are read/write 64-bit registers.
"""

import std.spec

use hardware.rv64gc.core.rv64_regfile.Rv64RegFile

describe "Rv64RegFile Initialization":
    """
    ## Initial State

    All registers should be zero after creation.
    """

    it "all registers initialized to zero":
        val rf = Rv64RegFile.create()
        expect(rf.read(0)).to_equal(0)
        expect(rf.read(1)).to_equal(0)
        expect(rf.read(31)).to_equal(0)

describe "Rv64RegFile x0 Hardwired Zero":
    """
    ## x0 Constraint

    Writes to x0 must be silently discarded; reads always return 0.
    """

    it "x0 always returns 0 after write":
        var rf = Rv64RegFile.create()
        rf.write(0, 0xDEADBEEFCAFEBABE)
        expect(rf.read(0)).to_equal(0)

describe "Rv64RegFile Read/Write":
    """
    ## General Purpose Register Access
    """

    it "write and read x1":
        var rf = Rv64RegFile.create()
        rf.write(1, 42)
        expect(rf.read(1)).to_equal(42)

    it "write and read x31":
        var rf = Rv64RegFile.create()
        rf.write(31, 0x7FFFFFFFFFFFFFFF)
        expect(rf.read(31)).to_equal(0x7FFFFFFFFFFFFFFF)

    it "overwrite preserves latest value":
        var rf = Rv64RegFile.create()
        rf.write(10, 100)
        rf.write(10, 200)
        expect(rf.read(10)).to_equal(200)

    it "full 64-bit value preserved":
        var rf = Rv64RegFile.create()
        rf.write(5, 0xFFFFFFFFFFFFFFFF)
        expect(rf.read(5)).to_equal(0xFFFFFFFFFFFFFFFF)

    it "upper 32 bits stored correctly":
        var rf = Rv64RegFile.create()
        rf.write(7, 0x100000000)
        expect(rf.read(7)).to_equal(0x100000000)

    it "independent registers do not interfere":
        var rf = Rv64RegFile.create()
        rf.write(1, 111)
        rf.write(2, 222)
        expect(rf.read(1)).to_equal(111)
        expect(rf.read(2)).to_equal(222)
