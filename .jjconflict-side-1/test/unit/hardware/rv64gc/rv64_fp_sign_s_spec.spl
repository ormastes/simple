"""
# RV64 Single-Precision FP Sign Manipulation Tests

**Feature IDs:** #RV64-FP-SIGN-S-001
**Category:** Hardware
**Difficulty:** 2/5
**Status:** Draft

## Overview

Unit tests for fsgnj.s, fsgnjn.s, fsgnjx.s.
"""

# tag: only-compiled

import std.spec

use hardware.rv64gc.ext.rv64_float.{fp_sgnj_s, fp_sgnjn_s, fp_sgnjx_s}

val ONE_S: i64 = 0x3F800000
val NEG_ONE_S: i64 = 0xBF800000
val TWO_S: i64 = 0x40000000
val NEG_TWO_S: i64 = 0xC0000000

describe "FSGNJ.S (copy sign from rs2)":
    it "positive + positive = positive":
        expect(fp_sgnj_s(ONE_S, TWO_S)).to_equal(ONE_S)

    it "positive + negative = negative":
        expect(fp_sgnj_s(ONE_S, NEG_TWO_S)).to_equal(NEG_ONE_S)

    it "negative + positive = positive":
        expect(fp_sgnj_s(NEG_ONE_S, TWO_S)).to_equal(ONE_S)

describe "FSGNJN.S (copy negated sign from rs2)":
    it "positive + positive = negative":
        expect(fp_sgnjn_s(ONE_S, TWO_S)).to_equal(NEG_ONE_S)

    it "positive + negative = positive":
        expect(fp_sgnjn_s(ONE_S, NEG_TWO_S)).to_equal(ONE_S)

    it "negative + positive = negative":
        expect(fp_sgnjn_s(NEG_ONE_S, TWO_S)).to_equal(NEG_ONE_S)

describe "FSGNJX.S (XOR signs)":
    it "positive XOR positive = positive":
        expect(fp_sgnjx_s(ONE_S, TWO_S)).to_equal(ONE_S)

    it "positive XOR negative = negative":
        expect(fp_sgnjx_s(ONE_S, NEG_TWO_S)).to_equal(NEG_ONE_S)

    it "negative XOR negative = positive":
        expect(fp_sgnjx_s(NEG_ONE_S, NEG_TWO_S)).to_equal(ONE_S)
