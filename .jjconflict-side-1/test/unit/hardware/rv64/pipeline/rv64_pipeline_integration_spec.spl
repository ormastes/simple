"""
RV64 Pipeline Integration Specification

End-to-end test: load a short RV64I program into memory, step through all
five pipeline stages, verify final register/memory state.

**Feature IDs:** #HW-RV64-PIPE-INT
**Category:** Testing
**Status:** Implemented
"""

use std.spec.{describe, it, expect}

use std.hardware.rv64.pipeline.types.{
    Rv64RegisterFile, create_rv64_register_file,
    Rv64Memory, create_rv64_memory,
    Rv64IfIdLatch, Rv64IdExLatch, Rv64ExMemLatch, Rv64MemWbLatch
}
use std.hardware.rv64.pipeline.if_stage.{Rv64IfStage, create_rv64_if_stage}
use std.hardware.rv64.pipeline.id_stage.{Rv64IdStage, create_rv64_id_stage}
use std.hardware.rv64.pipeline.ex_stage.{Rv64ExStage, create_rv64_ex_stage}
use std.hardware.rv64.pipeline.mem_stage.{Rv64MemStage, create_rv64_mem_stage}
use std.hardware.rv64.pipeline.wb_stage.{Rv64WbStage, create_rv64_wb_stage}
use std.hardware.rv64.pipeline.decoder.{
    encode_addi, encode_add, encode_sub, encode_lui,
    encode_sw, encode_lw, encode_sd, encode_ld,
    encode_addw, encode_addiw
}

# ============================================================================
# Helper: run one instruction through all 5 stages in sequence
# ============================================================================

fn run_single_instruction(
    mem: Rv64Memory,
    rf: Rv64RegisterFile,
    ifs: Rv64IfStage
):
    """Step one instruction through IF->ID->EX->MEM->WB (non-pipelined)."""
    var ids = create_rv64_id_stage()
    var exs = create_rv64_ex_stage()
    var mems = create_rv64_mem_stage()
    var wbs = create_rv64_wb_stage()

    val if_id = ifs.tick(mem, false, 0)
    val id_ex = ids.tick(if_id, rf)
    val ex_mem = exs.tick(id_ex)
    mems.tick_store(ex_mem, mem)
    val mem_wb = mems.tick(ex_mem, mem)
    wbs.tick(mem_wb, rf)

    # Handle branches/jumps
    if ex_mem.branch_taken:
        ifs.set_pc(ex_mem.branch_target)

# ============================================================================
# Integration Tests
# ============================================================================

describe "RV64 Pipeline Integration":
    it "executes ADDI x1, x0, 42 and writes 42 to x1":
        var mem = create_rv64_memory(1024)
        var rf = create_rv64_register_file()
        var ifs = create_rv64_if_stage(0)

        mem.store_instruction(0, encode_addi(1, 0, 42))
        run_single_instruction(mem, rf, ifs)

        expect(rf.read(1)).to_equal(42)

    it "executes ADD x3, x1, x2 after loading x1=10 and x2=20":
        var mem = create_rv64_memory(1024)
        var rf = create_rv64_register_file()
        var ifs = create_rv64_if_stage(0)

        mem.store_instruction(0, encode_addi(1, 0, 10))
        mem.store_instruction(4, encode_addi(2, 0, 20))
        mem.store_instruction(8, encode_add(3, 1, 2))

        run_single_instruction(mem, rf, ifs)
        run_single_instruction(mem, rf, ifs)
        run_single_instruction(mem, rf, ifs)

        expect(rf.read(1)).to_equal(10)
        expect(rf.read(2)).to_equal(20)
        expect(rf.read(3)).to_equal(30)

    it "executes SUB x3, x1, x2":
        var mem = create_rv64_memory(1024)
        var rf = create_rv64_register_file()
        var ifs = create_rv64_if_stage(0)

        mem.store_instruction(0, encode_addi(1, 0, 50))
        mem.store_instruction(4, encode_addi(2, 0, 8))
        mem.store_instruction(8, encode_sub(3, 1, 2))

        run_single_instruction(mem, rf, ifs)
        run_single_instruction(mem, rf, ifs)
        run_single_instruction(mem, rf, ifs)

        expect(rf.read(3)).to_equal(42)

    it "executes LUI x1, 0x12345000":
        var mem = create_rv64_memory(1024)
        var rf = create_rv64_register_file()
        var ifs = create_rv64_if_stage(0)

        mem.store_instruction(0, encode_lui(1, 0x12345000))
        run_single_instruction(mem, rf, ifs)

        expect(rf.read(1)).to_equal(0x12345000)

    it "executes SW then LW round-trip":
        var mem = create_rv64_memory(1024)
        var rf = create_rv64_register_file()
        var ifs = create_rv64_if_stage(0)

        # x1 = 256 (base address for data)
        mem.store_instruction(0, encode_addi(1, 0, 256))
        # x2 = 0xBEEF
        mem.store_instruction(4, encode_addi(2, 0, 0xBEEF - 0x10000))
        # NOTE: ADDI sign-extends, so use two-step load for 0xBEEF
        # Actually, just use a small value for simplicity
        mem.store_instruction(4, encode_addi(2, 0, 99))
        # SW x2, 0(x1)
        mem.store_instruction(8, encode_sw(2, 1, 0))
        # LW x3, 0(x1)
        mem.store_instruction(12, encode_lw(3, 1, 0))

        run_single_instruction(mem, rf, ifs)  # addi x1
        run_single_instruction(mem, rf, ifs)  # addi x2
        run_single_instruction(mem, rf, ifs)  # sw
        run_single_instruction(mem, rf, ifs)  # lw

        expect(rf.read(3)).to_equal(99)

    it "executes ADDW (RV64I W-suffix) with 32-bit truncation":
        var mem = create_rv64_memory(1024)
        var rf = create_rv64_register_file()
        var ifs = create_rv64_if_stage(0)

        mem.store_instruction(0, encode_addi(1, 0, 10))
        mem.store_instruction(4, encode_addi(2, 0, 20))
        mem.store_instruction(8, encode_addw(3, 1, 2))

        run_single_instruction(mem, rf, ifs)
        run_single_instruction(mem, rf, ifs)
        run_single_instruction(mem, rf, ifs)

        expect(rf.read(3)).to_equal(30)

    it "executes ADDIW (RV64I W-suffix immediate)":
        var mem = create_rv64_memory(1024)
        var rf = create_rv64_register_file()
        var ifs = create_rv64_if_stage(0)

        mem.store_instruction(0, encode_addi(1, 0, 100))
        mem.store_instruction(4, encode_addiw(2, 1, 5))

        run_single_instruction(mem, rf, ifs)
        run_single_instruction(mem, rf, ifs)

        expect(rf.read(2)).to_equal(105)

    it "x0 stays zero through pipeline":
        var mem = create_rv64_memory(1024)
        var rf = create_rv64_register_file()
        var ifs = create_rv64_if_stage(0)

        # Try to write to x0
        mem.store_instruction(0, encode_addi(0, 0, 42))
        run_single_instruction(mem, rf, ifs)

        expect(rf.read(0)).to_equal(0)
