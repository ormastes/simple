"""
Feature: CallRecorder Mock Class
Category: Mocking Framework
Status: Complete
"""

# Parser-safe local harness for the call recorder construction shape.
# The production `spec.CallRecorder` import is not required for this coverage path.

use spec.{describe, it, expect}

class CallRecorder:
    calls: [text]

    static fn new() -> CallRecorder:
        CallRecorder(calls: [])

    fn record(name: text):
        self.calls = self.calls + [name]

describe "CallRecorder Static Method":
    """
    Tests the lightweight call recorder shape used by the original spec.
    """
    it "can call static fn new":
        val recorder = CallRecorder.new()
        expect(recorder.calls.len() == 0)

    it "records a call on the local harness":
        val recorder = CallRecorder.new()
        recorder.record("ping")
        expect(recorder.calls.len() == 1)
        expect(recorder.calls[0] == "ping")
