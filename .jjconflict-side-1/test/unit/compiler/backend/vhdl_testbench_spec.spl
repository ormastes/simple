"""
# VHDL Testbench Generator Unit Tests

**Feature IDs:** #VHDL-EMU-001
**Category:** Tooling
**Difficulty:** 2/5
**Status:** In Progress

## Overview

Unit tests for VhdlTestbenchGenerator verifying correct VHDL output structure.
"""

import std.spec

use compiler.backend.vhdl.vhdl_testbench.{VhdlTestbenchGenerator, VhdlStimulus}

describe "VhdlTestbenchGenerator":
    """
    ## Unit Tests

    Validates testbench VHDL output structure and content.
    """

    context "with default configuration":
        """Default 10ns clock, active-high reset, 50ns reset duration."""

        it "generates library header":
            """
            **Then:** Output starts with IEEE library declarations
            """
            val gen = VhdlTestbenchGenerator.create()
            val tb = gen.generate_basic("test_entity", [("clk", "in", "std_logic")])
            expect(tb).to_start_with("library ieee;")

        it "generates entity with _tb suffix":
            """
            **Then:** Testbench entity name has _tb suffix
            """
            val gen = VhdlTestbenchGenerator.create()
            val tb = gen.generate_basic("my_design", [("clk", "in", "std_logic")])
            expect(tb).to_contain("entity my_design_tb is")

        it "generates clock process":
            """
            **Then:** Clock generation process is included
            """
            val gen = VhdlTestbenchGenerator.create()
            val ports = [("clk", "in", "std_logic"), ("rst", "in", "std_logic")]
            val tb = gen.generate_basic("dut", ports)
            expect(tb).to_contain("clk_gen: process")
            expect(tb).to_contain("CLK_PERIOD")

    context "with custom configuration":
        """Custom clock period and reset polarity."""

        it "respects active-low reset":
            """
            **Given:** reset_active_high = false
            **Then:** Reset initial value is '1' (inactive)
            """
            val gen = VhdlTestbenchGenerator.with_config(20, false, 100)
            val ports = [("clk", "in", "std_logic"), ("rst", "in", "std_logic")]
            val tb = gen.generate_basic("dut", ports)
            expect(tb).to_contain("'1'")
