# # MIR Optimization - Copy Propagation Tests
#
# **Feature ID:** #COMPILER-MIROPT-004
# **Category:** Compiler | MIR Optimization
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Simple Copy Propagation":
    it "propagate val copy":
        val x = 42
        val y = x
        check(y == 42)

    it "propagate through multiple copies":
        val a = 42
        val b = a
        val c = b
        val d = c
        check(d == 42)

    it "propagate function result":
        fn compute() -> i64:
            42
        val result = compute()
        val copy = result
        check(copy == 42)

    it "propagate array element":
        val arr = [10, 20, 30]
        val elem = arr[1]
        val copy = elem
        check(copy == 20)

describe "Copy Propagation in Branches":
    it "propagate in if branch":
        val x = 42
        var result = 0
        if true:
            val y = x
            result = y
        check(result == 42)

    it "propagate in else branch":
        val x = 42
        var result = 0
        if false:
            result = 0
        else:
            val y = x
            result = y
        check(result == 42)

    it "propagate across branches":
        val x = 42
        var result = 0
        if x > 0:
            result = x
        else:
            result = -x
        check(result == 42)

describe "Copy Propagation in Loops":
    it "propagate loop invariant":
        val factor = 10
        var sum = 0
        for i in 0..3:
            val scaled = i * factor
            sum = sum + scaled
        check(sum == 30)

    it "propagate into loop body":
        val offset = 100
        var result = 0
        for i in 0..3:
            result = offset + i
        check(result == 102)

describe "Copy Propagation with Functions":
    it "propagate argument":
        fn use_value(x: i64) -> i64:
            val y = x
            y + 1
        check(use_value(41) == 42)

    it "propagate return value":
        fn get() -> i64:
            val x = 42
            val y = x
            y
        check(get() == 42)

    it "propagate through nested calls":
        fn inner(x: i64) -> i64:
            x
        fn outer(x: i64) -> i64:
            val y = inner(x)
            y
        check(outer(42) == 42)
