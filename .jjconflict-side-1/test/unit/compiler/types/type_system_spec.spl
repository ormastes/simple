# # Type System Unit Tests
#
# **Feature ID:** #COMPILER-TYPES-002
# **Category:** Compiler | Types
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Primitive Types":
    it "i64 type":
        val x: i64 = 42
        check(x == 42)

    it "f64 type":
        val x: f64 = 3.14
        check(x > 3.0)

    it "bool type":
        val x: bool = true
        check(x)

    it "text type":
        val x: text = "hello"
        check(x == "hello")

    it "unit type":
        val x = ()
        check(true)

describe "Composite Types":
    it "array type":
        val arr: [i64] = [1, 2, 3]
        check(arr.len() == 3)

    it "optional type":
        val x: Option<i64> = Some(42)
        check(x.?)

    it "tuple type":
        val pair = (1, "hello")
        check(true)

    it "map type":
        val m = {"key": "value"}
        check(m.len() == 1)

describe "Type Conversions":
    it "i64 to f64":
        val x: i64 = 42
        val y = x.to_f64()
        check(y > 41.0 and y < 43.0)

    it "f64 to i64":
        val x: f64 = 42.7
        val y = x.to_i64()
        check(y == 42)

    it "i64 to text":
        val x: i64 = 42
        val s = "{x}"
        check(s == "42")

    it "bool to text":
        val x = true
        val s = "{x}"
        check(s == "true")

describe "Type Aliases":
    it "type alias basic":
        type Number = i64
        val x: Number = 42
        check(x == 42)

describe "Type Checking Errors":
    it "type mismatch is error":
        val error = "type_mismatch"
        check(error == "type_mismatch")

    it "undeclared type is error":
        val error = "undeclared_type"
        check(error == "undeclared_type")

    it "incompatible return type is error":
        val error = "incompatible_return"
        check(error == "incompatible_return")

    it "argument count mismatch is error":
        val error = "arg_count_mismatch"
        check(error == "arg_count_mismatch")

describe "Subtyping":
    it "nil is subtype of Option":
        val x: Option<i64> = nil
        check(x.?() == false)

    it "Some is subtype of Option":
        val x: Option<i64> = Some(42)
        check(x.?)

describe "Type Constraints":
    it "numeric constraint":
        val x = 42
        val y = x + 1
        check(y == 43)

    it "equality constraint":
        val x = 42
        val y = 42
        check(x == y)

    it "ordering constraint":
        val x = 3
        val y = 5
        check(x < y)

    it "string constraint":
        val x = "hello"
        check(x.len() == 5)
