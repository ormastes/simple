# # Type Inference Unit Tests
#
# **Feature ID:** #COMPILER-TYPES-001
# **Category:** Compiler | Types
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Integer Type Inference":
    it "infer i64 from integer literal":
        val x = 42
        check(x == 42)

    it "infer i64 from negative literal":
        val x = -5
        check(x == -5)

    it "infer i64 from zero":
        val x = 0
        check(x == 0)

    it "infer i64 from large number":
        val x = 1000000
        check(x == 1000000)

    it "infer from arithmetic expression":
        val x = 3 + 4
        check(x == 7)

describe "Float Type Inference":
    it "infer f64 from float literal":
        val x = 3.14
        check(x > 3.0)

    it "infer f64 from negative float":
        val x = -2.5
        check(x < 0.0)

    it "infer f64 from float arithmetic":
        val x = 1.5 + 2.5
        check(x > 3.9 and x < 4.1)

describe "Boolean Type Inference":
    it "infer bool from true":
        val x = true
        check(x)

    it "infer bool from false":
        val x = false
        check(not x)

    it "infer bool from comparison":
        val x = 5 > 3
        check(x)

    it "infer bool from logical":
        val x = true and false
        check(not x)

describe "String Type Inference":
    it "infer text from string literal":
        val x = "hello"
        check(x == "hello")

    it "infer text from interpolation":
        val name = "world"
        val x = "hello {name}"
        check(x.contains("world"))

    it "infer text from concatenation":
        val x = "a" + "b"
        check(x == "ab")

describe "Array Type Inference":
    it "infer array of i64":
        val arr = [1, 2, 3]
        check(arr.len() == 3)

    it "infer array of text":
        val arr = ["a", "b", "c"]
        check(arr.len() == 3)

    it "infer empty array":
        val arr: [i64] = []
        check(arr.len() == 0)

    it "infer nested array":
        val arr = [[1, 2], [3, 4]]
        check(arr.len() == 2)

describe "Option Type Inference":
    it "infer Some variant":
        val x = Some(42)
        check(x.? == true)

    it "infer nil":
        val x = nil
        check(x.?() == false)

    it "infer from optional chaining":
        val x = Some(42)
        val y = x ?? 0
        check(y == 42)

    it "nil coalescing with default":
        val x = nil
        val y = x ?? 99
        check(y == 99)

describe "Function Return Type Inference":
    it "infer return type from body":
        fn double(x: i64) -> i64:
            x * 2
        check(double(21) == 42)

    it "infer return type from if-else":
        fn sign(x: i64) -> i64:
            if x > 0:
                1
            elif x < 0:
                -1
            else:
                0
        check(sign(5) == 1)
        check(sign(-3) == -1)
        check(sign(0) == 0)

    it "infer return type from match":
        fn describe_num(x: i64) -> text:
            match x:
                0: "zero"
                1: "one"
                _: "other"
        check(describe_num(0) == "zero")
        check(describe_num(1) == "one")
        check(describe_num(99) == "other")

describe "Generic Type Inference":
    it "infer generic from usage":
        fn first(arr: [i64]) -> i64:
            arr[0]
        check(first([10, 20]) == 10)

    it "infer generic map result":
        val arr = [1, 2, 3]
        val doubled = arr.map(\x: x * 2)
        check(doubled[0] == 2)
        check(doubled[1] == 4)

    it "infer generic filter result":
        val arr = [1, 2, 3, 4, 5]
        val evens = arr.filter(\x: x % 2 == 0)
        check(evens.len() == 2)
