# Regression spec: rt_bdd_expect_eq_rv must use semantic equality on
# heap-allocated text — not raw pointer compare.
#
# Surface bug: pre-fix, `expect "ok" == "ok"` false-failed under
# `--mode=smf` with messages like
# "Expected 126243115335105 to equal 126243115335153" because each
# rt_string_new call returns a fresh heap pointer.
#
# Acceptance under `--mode=smf --force-rebuild`:
#   - "equal text operands compare equal"   PASSES
#   - "equal int operands compare equal"    PASSES
#   - "unequal text operands deliberate-fail RED" FAILS, with a message
#     containing the rendered text ("ok" / "ko") — not raw pointer ints.

describe "rt_bdd_expect_eq_rv uses semantic compare for text":
    it "equal text operands compare equal":
        expect "ok" == "ok"

    it "equal int operands compare equal":
        expect 1 == 1

    it "unequal text operands deliberate-fail RED":
        expect "ok" == "ko"
