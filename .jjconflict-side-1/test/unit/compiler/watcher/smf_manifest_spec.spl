# SMF Manifest Specification
#
# Tests manifest creation, SDN serialization round-trip,
# entry CRUD, and lookup operations.
#
# **Feature IDs:** #WATCH-MAN-001 to #WATCH-MAN-010
# **Category:** Infrastructure

# ============================================================================
# Mock types (self-contained for interpreter mode)
# ============================================================================

struct MockManifestEntry:
    source_path: text
    smf_path: text
    source_hash: i64
    compiled_at: i64
    backend: text

struct MockManifest:
    version: i64
    entries: Dict<text, MockManifestEntry>
    updated_at: i64

fn mock_entry(source: text, smf: text, hash: i64, backend: text) -> MockManifestEntry:
    MockManifestEntry(
        source_path: source,
        smf_path: smf,
        source_hash: hash,
        compiled_at: 1000000,
        backend: backend
    )

fn mock_manifest() -> MockManifest:
    MockManifest(version: 1, entries: {}, updated_at: 0)

fn mock_manifest_update(m: MockManifest, e: MockManifestEntry) -> MockManifest:
    var entries = m.entries
    entries[e.source_path] = e
    MockManifest(version: m.version, entries: entries, updated_at: m.updated_at + 1)

fn mock_manifest_remove(m: MockManifest, source_path: text) -> MockManifest:
    var entries = m.entries
    if entries.contains_key(source_path):
        entries.remove(source_path)
    MockManifest(version: m.version, entries: entries, updated_at: m.updated_at + 1)

fn mock_manifest_find(m: MockManifest, source_path: text) -> MockManifestEntry?:
    if m.entries.contains_key(source_path):
        return Some(m.entries[source_path])
    nil

# ============================================================================
# SDN serialization helpers (mirror production logic)
# ============================================================================

fn mock_to_sdn(m: MockManifest) -> text:
    var lines: [text] = [
        "smf_manifest:",
        "  version: {m.version}",
        "  updated_at: {m.updated_at}",
        ""
    ]
    if m.entries.len() > 0:
        lines = lines + ["entries |source_path, smf_path, source_hash, compiled_at, backend|"]
        for key in m.entries.keys():
            val e = m.entries[key]
            lines = lines + ["    \"{e.source_path}\", \"{e.smf_path}\", {e.source_hash}, {e.compiled_at}, \"{e.backend}\""]
    lines.join("\n")

fn mock_parse_entry_line(line: text) -> MockManifestEntry?:
    val parts = line.split(", ")
    if parts.len() < 5:
        return nil
    val source_path = parts[0].trim().replace("\"", "")
    val smf_path = parts[1].trim().replace("\"", "")
    val source_hash = parts[2].trim().to_i64() ?? 0
    val compiled_at = parts[3].trim().to_i64() ?? 0
    val backend = parts[4].trim().replace("\"", "")
    Some(MockManifestEntry(
        source_path: source_path, smf_path: smf_path,
        source_hash: source_hash, compiled_at: compiled_at, backend: backend
    ))

fn mock_from_sdn(content: text) -> MockManifest:
    var version: i64 = 1
    var updated_at: i64 = 0
    var entries: Dict<text, MockManifestEntry> = {}
    var in_entries = false
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            continue
        if trimmed.starts_with("version:"):
            val val_str = trimmed.replace("version:", "").trim()
            version = val_str.to_i64() ?? 1
        else if trimmed.starts_with("updated_at:"):
            val val_str = trimmed.replace("updated_at:", "").trim()
            updated_at = val_str.to_i64() ?? 0
        else if trimmed.starts_with("entries "):
            in_entries = true
        else if in_entries and trimmed.starts_with("\""):
            val entry = mock_parse_entry_line(trimmed)
            if entry.?:
                val e = entry.unwrap()
                entries[e.source_path] = e
    MockManifest(version: version, entries: entries, updated_at: updated_at)

# ============================================================================
# Tests
# ============================================================================

describe "SmfManifest creation":
    it "creates empty manifest with version 1":
        val m = mock_manifest()
        expect(m.version).to_equal(1)
        expect(m.entries.len()).to_equal(0)

    it "creates entry with all fields":
        val e = mock_entry("src/main.spl", "build/smf/src_main.smf", 12345, "cranelift")
        expect(e.source_path).to_equal("src/main.spl")
        expect(e.smf_path).to_equal("build/smf/src_main.smf")
        expect(e.source_hash).to_equal(12345)
        expect(e.backend).to_equal("cranelift")

describe "SmfManifest operations":
    it "adds entry via update":
        var m = mock_manifest()
        val e = mock_entry("src/main.spl", "build/smf/src_main.smf", 100, "cranelift")
        m = mock_manifest_update(m, e)
        expect(m.entries.len()).to_equal(1)
        expect(m.entries.contains_key("src/main.spl")).to_equal(true)

    it "overwrites entry with same source_path":
        var m = mock_manifest()
        val e1 = mock_entry("src/main.spl", "build/smf/src_main.smf", 100, "cranelift")
        val e2 = mock_entry("src/main.spl", "build/smf/src_main.smf", 200, "llvm")
        m = mock_manifest_update(m, e1)
        m = mock_manifest_update(m, e2)
        expect(m.entries.len()).to_equal(1)
        expect(m.entries["src/main.spl"].source_hash).to_equal(200)
        expect(m.entries["src/main.spl"].backend).to_equal("llvm")

    it "adds multiple entries":
        var m = mock_manifest()
        val e1 = mock_entry("src/a.spl", "build/smf/a.smf", 10, "cranelift")
        val e2 = mock_entry("src/b.spl", "build/smf/b.smf", 20, "cranelift")
        m = mock_manifest_update(m, e1)
        m = mock_manifest_update(m, e2)
        expect(m.entries.len()).to_equal(2)

    it "removes entry":
        var m = mock_manifest()
        val e = mock_entry("src/main.spl", "build/smf/src_main.smf", 100, "cranelift")
        m = mock_manifest_update(m, e)
        m = mock_manifest_remove(m, "src/main.spl")
        expect(m.entries.len()).to_equal(0)

    it "remove of nonexistent key is no-op":
        var m = mock_manifest()
        m = mock_manifest_remove(m, "src/nonexistent.spl")
        expect(m.entries.len()).to_equal(0)

describe "SmfManifest find":
    it "finds existing entry":
        var m = mock_manifest()
        val e = mock_entry("src/main.spl", "build/smf/src_main.smf", 42, "cranelift")
        m = mock_manifest_update(m, e)
        val found = mock_manifest_find(m, "src/main.spl")
        expect(found.?).to_equal(true)
        expect(found.unwrap().source_hash).to_equal(42)

    it "returns nil for missing entry":
        val m = mock_manifest()
        val found = mock_manifest_find(m, "src/missing.spl")
        expect(found.?).to_equal(false)

describe "SmfManifest SDN serialization":
    it "serializes empty manifest":
        val m = mock_manifest()
        val sdn = mock_to_sdn(m)
        expect(sdn).to_contain("smf_manifest:")
        expect(sdn).to_contain("version: 1")

    it "serializes manifest with entries":
        var m = mock_manifest()
        val e = mock_entry("src/main.spl", "build/smf/src_main.smf", 999, "cranelift")
        m = mock_manifest_update(m, e)
        val sdn = mock_to_sdn(m)
        expect(sdn).to_contain("entries |source_path, smf_path, source_hash, compiled_at, backend|")
        expect(sdn).to_contain("src/main.spl")
        expect(sdn).to_contain("build/smf/src_main.smf")
        expect(sdn).to_contain("999")
        expect(sdn).to_contain("cranelift")

    it "round-trips empty manifest":
        val m = mock_manifest()
        val sdn = mock_to_sdn(m)
        val parsed = mock_from_sdn(sdn)
        expect(parsed.version).to_equal(1)
        expect(parsed.entries.len()).to_equal(0)

    it "round-trips manifest with single entry":
        var m = mock_manifest()
        val e = mock_entry("src/app/cli/main.spl", "build/smf/src_app_cli_main.smf", 12345, "cranelift")
        m = mock_manifest_update(m, e)
        val sdn = mock_to_sdn(m)
        val parsed = mock_from_sdn(sdn)
        expect(parsed.entries.len()).to_equal(1)
        val pe = parsed.entries["src/app/cli/main.spl"]
        expect(pe.smf_path).to_equal("build/smf/src_app_cli_main.smf")
        expect(pe.source_hash).to_equal(12345)
        expect(pe.backend).to_equal("cranelift")

    it "round-trips manifest with multiple entries":
        var m = mock_manifest()
        val e1 = mock_entry("src/a.spl", "build/smf/a.smf", 100, "cranelift")
        val e2 = mock_entry("src/b.spl", "build/smf/b.smf", 200, "llvm")
        m = mock_manifest_update(m, e1)
        m = mock_manifest_update(m, e2)
        val sdn = mock_to_sdn(m)
        val parsed = mock_from_sdn(sdn)
        expect(parsed.entries.len()).to_equal(2)
        expect(parsed.entries["src/a.spl"].source_hash).to_equal(100)
        expect(parsed.entries["src/b.spl"].source_hash).to_equal(200)
        expect(parsed.entries["src/b.spl"].backend).to_equal("llvm")

    it "parses entry line correctly":
        val line = "\"src/main.spl\", \"build/smf/main.smf\", 42, 1000, \"cranelift\""
        val entry = mock_parse_entry_line(line)
        expect(entry.?).to_equal(true)
        val e = entry.unwrap()
        expect(e.source_path).to_equal("src/main.spl")
        expect(e.smf_path).to_equal("build/smf/main.smf")
        expect(e.source_hash).to_equal(42)
        expect(e.compiled_at).to_equal(1000)
        expect(e.backend).to_equal("cranelift")

    it "returns nil for malformed entry line":
        val entry = mock_parse_entry_line("bad data")
        expect(entry.?).to_equal(false)
