# @cover src/compiler/35.semantics/lint/lint_cache.spl
"""
# Lint Cache Specification

**Feature IDs:** #REQC-AC5, #REQC-AC6
**Category:** Compiler | Semantics | Lint | Cache
**Difficulty:** 3/5
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
**Artifacts:** N/A

## Overview

Tests the incremental hash-based lint cache used by the required_comment lint
rule. The cache avoids re-running lint on an AST scope whose hash has not
changed. It also supports symbol-reference invalidation: if a symbol depended
on by a cached result changes, the cached entry is invalidated even if the
enclosing scope hash is unchanged.

## Key Concepts

| Concept | Description |
|---------|-------------|
| scope_hash | FNV-1a hash of the serialized AST of an enclosing function scope |
| cache key | "file_path::scope_name" text key |
| cache hit | scope_hash matches stored hash -> return cached warnings |
| cache miss | scope_hash differs or key absent -> re-run lint, store result |
| symbol_deps | List of symbol names referenced inside a dangerous keyword call |
| symbol_index | Reverse map: symbol_name -> [cache_key] |
| invalidate_symbol | Removes all cache entries that depended on a given symbol |
| invalidate_file | Recomputes per-decl hashes and invalidates changed entries + their deps |
"""

use std.common.hash_utils.{hash_string_fnv, hash_combine}

# ============================================================================
# Helpers — self-contained cache implementation for testing
# ============================================================================

class LintCacheEntryTest:
    scope_hash: i64
    warnings: [text]          # simplified: store warning codes as text
    symbol_deps: [text]

class LintCacheTest:
    entries: Dict<text, LintCacheEntryTest>
    symbol_index: Dict<text, [text]>

fn make_empty_cache() -> LintCacheTest:
    LintCacheTest(
        entries: {},
        symbol_index: {}
    )

fn cache_store_test(
    cache: LintCacheTest,
    key: text,
    scope_hash: i64,
    warnings: [text],
    deps: [text]
):
    val entry = LintCacheEntryTest(
        scope_hash: scope_hash,
        warnings: warnings,
        symbol_deps: deps
    )
    cache.entries[key] = entry
    for dep in deps:
        var existing: [text] = []
        if cache.symbol_index.contains_key(dep):
            existing = cache.symbol_index[dep]
        existing.push(key)
        cache.symbol_index[dep] = existing

fn cache_lookup_test(
    cache: LintCacheTest,
    key: text,
    current_hash: i64
) -> Option<[text]>:
    if not cache.entries.contains_key(key):
        return nil
    val entry = cache.entries[key]
    if entry.scope_hash != current_hash:
        return nil
    Some(entry.warnings)

fn cache_invalidate_symbol_test(cache: LintCacheTest, symbol_name: text):
    if not cache.symbol_index.contains_key(symbol_name):
        return pass_dn("no entries reference this symbol")
    val keys_to_remove = cache.symbol_index[symbol_name]
    for k in keys_to_remove:
        cache.entries.remove(k)
    cache.symbol_index.remove(symbol_name)

fn cache_invalidate_file_test(
    cache: LintCacheTest,
    file_path: text,
    new_decl_hashes: Dict<text, i64>
):
    # For each entry whose key starts with file_path, recheck hash
    var to_remove: [text] = []
    for key in cache.entries.keys():
        if key.starts_with(file_path):
            val entry = cache.entries[key]
            # Extract scope_name after "::"
            val sep_idx = key.find("::")
            if sep_idx >= 0:
                val scope_name = key[(sep_idx + 2):]
                if new_decl_hashes.contains_key(scope_name):
                    val new_hash = new_decl_hashes[scope_name]
                    if new_hash != entry.scope_hash:
                        to_remove.push(key)
                        # Invalidate symbol deps too
                        for dep in entry.symbol_deps:
                            cache_invalidate_symbol_test(cache, dep)
    for k in to_remove:
        cache.entries.remove(k)

fn make_scope_hash(content: text) -> i64:
    hash_string_fnv(content)


# ============================================================================
# Test Group 1: Basic cache store and lookup — AC-5
# ============================================================================

describe "lint cache — store and lookup":
    """
    ## Cache Store and Lookup

    lint_cache_store persists a result keyed by scope hash.
    lint_cache_lookup returns the cached warnings when the hash matches.
    """

    context "when a result is stored and the hash is unchanged":
        it "cache lookup returns the stored warnings (cache hit)":
            var cache = make_empty_cache()
            val key = "src/foo.spl::my_fn"
            val h = make_scope_hash("pass_todo body content")
            cache_store_test(cache, key, h, ["REQC001"], [])
            val result = cache_lookup_test(cache, key, h)
            expect(result.?).to_equal(true)

        it "cache hit returns the exact stored warning codes":
            var cache = make_empty_cache()
            val key = "src/foo.spl::check_fn"
            val h = make_scope_hash("pass_do_nothing no comment")
            cache_store_test(cache, key, h, ["REQC001"], [])
            val result = cache_lookup_test(cache, key, h)
            match result:
                Some(ws): expect(ws.len()).to_equal(1)
                nil: expect(false).to_equal(true)

        it "cache hit can return an empty warning list (clean scope)":
            var cache = make_empty_cache()
            val key = "src/bar.spl::clean_fn"
            val h = make_scope_hash("pass_todo(\"reason\") with comment")
            cache_store_test(cache, key, h, [], [])
            val result = cache_lookup_test(cache, key, h)
            match result:
                Some(ws): expect(ws.len()).to_equal(0)
                nil: expect(false).to_equal(true)

    context "when the cache is empty":
        it "lookup returns nil for an unknown key":
            var cache = make_empty_cache()
            val result = cache_lookup_test(cache, "src/unknown.spl::fn", 12345)
            expect(result.?).to_equal(false)


# ============================================================================
# Test Group 2: Cache miss when hash changes — AC-5
# ============================================================================

describe "lint cache — cache miss on hash change":
    """
    ## Cache Miss

    When the current scope hash differs from the stored hash the cached result
    is stale and lint_cache_lookup returns nil (cache miss).
    """

    context "when the scope hash has changed":
        it "cache lookup returns nil (cache miss)":
            var cache = make_empty_cache()
            val key = "src/mod.spl::changed_fn"
            val old_hash = make_scope_hash("old body")
            val new_hash = make_scope_hash("new body with extra statement")
            cache_store_test(cache, key, old_hash, ["REQC001"], [])
            val result = cache_lookup_test(cache, key, new_hash)
            expect(result.?).to_equal(false)

        it "after a miss the caller re-runs lint and can store a fresh result":
            var cache = make_empty_cache()
            val key = "src/mod.spl::evolving_fn"
            val old_hash = make_scope_hash("original")
            val new_hash = make_scope_hash("modified")
            cache_store_test(cache, key, old_hash, ["REQC001"], [])
            val miss = cache_lookup_test(cache, key, new_hash)
            expect(miss.?).to_equal(false)
            # Caller re-runs lint, gets empty result, stores fresh
            cache_store_test(cache, key, new_hash, [], [])
            val hit = cache_lookup_test(cache, key, new_hash)
            expect(hit.?).to_equal(true)


# ============================================================================
# Test Group 3: Symbol dependency tracking — AC-6
# ============================================================================

describe "lint cache — symbol dependency tracking":
    """
    ## Symbol Dependencies

    When a cache entry is stored with symbol_deps, the symbol_index maps each
    dep name to that cache key so the entry can be invalidated when the symbol
    changes.
    """

    context "when an entry is stored with symbol deps":
        it "symbol_index maps each dep to the cache key":
            var cache = make_empty_cache()
            val key = "src/ml.spl::train"
            val h = make_scope_hash("loss() body")
            cache_store_test(cache, key, h, ["REQC002"], ["Optimizer", "LossConfig"])
            expect(cache.symbol_index.contains_key("Optimizer")).to_equal(true)
            expect(cache.symbol_index.contains_key("LossConfig")).to_equal(true)

        it "symbol_index entry contains the cache key":
            var cache = make_empty_cache()
            val key = "src/ml.spl::backward"
            val h = make_scope_hash("dangerous call")
            cache_store_test(cache, key, h, ["REQC002"], ["GradScaler"])
            val deps_for_grad = cache.symbol_index["GradScaler"]
            expect(_contains_text(deps_for_grad, key)).to_equal(true)

    context "when multiple scopes depend on the same symbol":
        it "symbol_index lists all dependent cache keys":
            var cache = make_empty_cache()
            val key_a = "src/a.spl::fn_a"
            val key_b = "src/b.spl::fn_b"
            val ha = make_scope_hash("body a")
            val hb = make_scope_hash("body b")
            cache_store_test(cache, key_a, ha, [], ["SharedSymbol"])
            cache_store_test(cache, key_b, hb, [], ["SharedSymbol"])
            val deps = cache.symbol_index["SharedSymbol"]
            expect(deps.len()).to_equal(2)


# ============================================================================
# Test Group 4: Symbol reference invalidation — AC-6
# ============================================================================

describe "lint cache — symbol reference invalidation":
    """
    ## Symbol Invalidation

    cache_invalidate_symbol removes all cache entries that listed the symbol as
    a dependency, even if those entries' scope hashes have not changed.
    """

    context "when a depended-on symbol changes":
        it "invalidates the cache entry for the dependent scope":
            var cache = make_empty_cache()
            val key = "src/risk.spl::risky"
            val h = make_scope_hash("stable body")
            cache_store_test(cache, key, h, ["REQC002"], ["DangerousHelper"])
            # Simulate symbol change
            cache_invalidate_symbol_test(cache, "DangerousHelper")
            val result = cache_lookup_test(cache, key, h)
            expect(result.?).to_equal(false)

        it "symbol_index entry is removed after invalidation":
            var cache = make_empty_cache()
            val key = "src/risk.spl::risky"
            val h = make_scope_hash("body")
            cache_store_test(cache, key, h, [], ["TargetSymbol"])
            cache_invalidate_symbol_test(cache, "TargetSymbol")
            expect(cache.symbol_index.contains_key("TargetSymbol")).to_equal(false)

        it "unrelated entries are NOT removed":
            var cache = make_empty_cache()
            val key_a = "src/a.spl::fn_a"
            val key_b = "src/b.spl::fn_b"
            val ha = make_scope_hash("body a")
            val hb = make_scope_hash("body b")
            cache_store_test(cache, key_a, ha, [], ["SymA"])
            cache_store_test(cache, key_b, hb, [], ["SymB"])
            cache_invalidate_symbol_test(cache, "SymA")
            val result_b = cache_lookup_test(cache, key_b, hb)
            expect(result_b.?).to_equal(true)

    context "when invalidating a symbol not in the index":
        it "does not crash and cache is unchanged":
            var cache = make_empty_cache()
            val key = "src/stable.spl::fn"
            val h = make_scope_hash("unchanged")
            cache_store_test(cache, key, h, [], [])
            # This must not crash
            cache_invalidate_symbol_test(cache, "NonExistentSymbol")
            val result = cache_lookup_test(cache, key, h)
            expect(result.?).to_equal(true)


# ============================================================================
# Test Group 5: File-level invalidation — AC-5, AC-6
# ============================================================================

describe "lint cache — file-level invalidation":
    """
    ## File Invalidation

    cache_invalidate_file recomputes per-declaration hashes and removes entries
    whose hashes have changed, plus cascades to symbol dependents.
    """

    context "when a file is re-parsed with one changed declaration":
        it "removes the cache entry for the changed declaration":
            var cache = make_empty_cache()
            val file = "src/changed.spl"
            val key = "src/changed.spl::modified_fn"
            val old_hash = make_scope_hash("old")
            cache_store_test(cache, key, old_hash, ["REQC001"], [])
            var new_hashes: Dict<text, i64> = {}
            new_hashes["modified_fn"] = make_scope_hash("new")
            cache_invalidate_file_test(cache, file, new_hashes)
            val result = cache_lookup_test(cache, key, make_scope_hash("new"))
            expect(result.?).to_equal(false)

        it "leaves unchanged declarations in the cache":
            var cache = make_empty_cache()
            val file = "src/partial.spl"
            val key_changed = "src/partial.spl::changed_fn"
            val key_stable = "src/partial.spl::stable_fn"
            val old_hash = make_scope_hash("old")
            val stable_hash = make_scope_hash("stable body forever")
            cache_store_test(cache, key_changed, old_hash, [], [])
            cache_store_test(cache, key_stable, stable_hash, [], [])
            var new_hashes: Dict<text, i64> = {}
            new_hashes["changed_fn"] = make_scope_hash("new body")
            new_hashes["stable_fn"] = stable_hash
            cache_invalidate_file_test(cache, file, new_hashes)
            val result = cache_lookup_test(cache, key_stable, stable_hash)
            expect(result.?).to_equal(true)

    context "when a changed declaration has symbol deps":
        it "cascades to invalidate symbol-dependent entries in other files":
            var cache = make_empty_cache()
            val file_a = "src/a.spl"
            val key_a = "src/a.spl::fn_a"
            val old_hash_a = make_scope_hash("a old")
            cache_store_test(cache, key_a, old_hash_a, [], ["SharedDep"])
            # Another file's entry depends on SharedDep
            val key_b = "src/b.spl::fn_b"
            val hash_b = make_scope_hash("b stable")
            cache_store_test(cache, key_b, hash_b, [], ["SharedDep"])
            # a.spl re-parses with changed fn_a
            var new_hashes_a: Dict<text, i64> = {}
            new_hashes_a["fn_a"] = make_scope_hash("a new")
            cache_invalidate_file_test(cache, file_a, new_hashes_a)
            # fn_b should also be invalidated via symbol cascade
            val result_b = cache_lookup_test(cache, key_b, hash_b)
            expect(result_b.?).to_equal(false)


# ============================================================================
# Test Group 6: Scope hash computation — AC-5
# ============================================================================

describe "lint cache — scope hash properties":
    """
    ## Scope Hash

    hash_ast_scope produces a deterministic i64 hash of an AST scope.
    Same content -> same hash. Different content -> different hash.
    """

    it "same content produces the same hash":
        val h1 = make_scope_hash("fn body: pass_todo no comment")
        val h2 = make_scope_hash("fn body: pass_todo no comment")
        expect(h1).to_equal(h2)

    it "different content produces different hashes":
        val h1 = make_scope_hash("original body")
        val h2 = make_scope_hash("modified body with extra statement")
        expect(h1 == h2).to_equal(false)

    it "empty content has a stable hash":
        val h1 = make_scope_hash("")
        val h2 = make_scope_hash("")
        expect(h1).to_equal(h2)

    it "hash combine produces different results for different orderings":
        val ha = hash_string_fnv("alpha")
        val hb = hash_string_fnv("beta")
        val combined_ab = hash_combine(ha, hb)
        val combined_ba = hash_combine(hb, ha)
        expect(combined_ab == combined_ba).to_equal(false)


# ============================================================================
# Helpers
# ============================================================================

fn _contains_text(lst: [text], item: text) -> bool:
    for x in lst:
        if x == item:
            return true
    false
