# @cover src/os/compositor/display_backend.spl 0%
# @tag: ui, fill_rect, contract, doctest
#
# D1 — fill_rect Edge Semantics Doc-Test
#
# Locks the cross-backend contract: fill_rect(x, y, w, h, color) paints
# columns [x, x+w) and rows [y, y+h). Right/bottom edges are EXCLUSIVE.
# Zero w or h is a no-op. Negative w/h is undefined.
#
# This spec exercises BrowserCompositorBackend (pure Simple, no FFI) as
# the in-process pin for the contract. Other backends carry the same
# contract via trait docstrings — see
# doc/03_plan/sys_gui/d1_fill_rect_contract_doctest.md.

use std.spec.{describe, context, it, expect}
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}

# ============================================================================
# Constants — 8x8 canvas + fixed ARGB palette
# ============================================================================

val W: i32 = 8
val H: i32 = 8
val CLEAR: u32  = 0xFF000000
val RED: u32    = 0xFFFF0000
val BLUE: u32   = 0xFF0000FF
val GREEN: u32  = 0xFF00FF00
val YELLOW: u32 = 0xFFFFFF00
val CYAN: u32   = 0xFF00FFFF

fn _fresh() -> BrowserCompositorBackend:
    BrowserCompositorBackend.with_color(W, H, CLEAR)

# ============================================================================
# BrowserCompositorBackend fill_rect edges
# ============================================================================

describe "BrowserCompositorBackend fill_rect edges":

    context "painted region is half-open [x,x+w) x [y,y+h)":

        it "paints interior pixel (4, 4) when rect is (2,2,3,3)":
            val backend = _fresh()
            backend.fill_rect(2, 2, 3, 3, RED)
            expect(cap_read_pixel(backend, 4, 4)).to_equal(RED)

        it "paints top-left corner (2, 2) when rect is (2,2,3,3)":
            val backend = _fresh()
            backend.fill_rect(2, 2, 3, 3, RED)
            expect(cap_read_pixel(backend, 2, 2)).to_equal(RED)

        it "leaves right/bottom edge (5, 5) untouched (EXCLUSIVE)":
            val backend = _fresh()
            backend.fill_rect(2, 2, 3, 3, RED)
            expect(cap_read_pixel(backend, 5, 5)).to_equal(CLEAR)

        it "leaves outside-top-left (1, 1) untouched":
            val backend = _fresh()
            backend.fill_rect(2, 2, 3, 3, RED)
            expect(cap_read_pixel(backend, 1, 1)).to_equal(CLEAR)

    context "degenerate and full-canvas cases":

        it "no-ops on zero width/height":
            val backend = _fresh()
            backend.fill_rect(0, 0, 0, 0, BLUE)
            var any_painted = false
            var y: i32 = 0
            while y < H:
                var x: i32 = 0
                while x < W:
                    if cap_read_pixel(backend, x, y) != CLEAR:
                        any_painted = true
                    x = x + 1
                y = y + 1
            expect(any_painted).to_equal(false)

        it "fills every pixel when rect matches canvas":
            val backend = _fresh()
            backend.fill_rect(0, 0, W, H, GREEN)
            var all_green = true
            var y: i32 = 0
            while y < H:
                var x: i32 = 0
                while x < W:
                    if cap_read_pixel(backend, x, y) != GREEN:
                        all_green = false
                    x = x + 1
                y = y + 1
            expect(all_green).to_equal(true)

    context "edge-overlap write order":
        # Paint a horizontal YELLOW strip across row 0, then a CYAN column
        # down column 0. Where they overlap at (0,0), CYAN (later) wins.

        it "later write wins at overlap (0,0) -> CYAN":
            val backend = _fresh()
            backend.fill_rect(0, 0, W, 1, YELLOW)
            backend.fill_rect(0, 0, 1, H, CYAN)
            expect(cap_read_pixel(backend, 0, 0)).to_equal(CYAN)

        it "non-overlap strip pixel (1, 0) stays YELLOW":
            val backend = _fresh()
            backend.fill_rect(0, 0, W, 1, YELLOW)
            backend.fill_rect(0, 0, 1, H, CYAN)
            expect(cap_read_pixel(backend, 1, 0)).to_equal(YELLOW)

        it "non-overlap column pixel (0, 1) stays CYAN":
            val backend = _fresh()
            backend.fill_rect(0, 0, W, 1, YELLOW)
            backend.fill_rect(0, 0, 1, H, CYAN)
            expect(cap_read_pixel(backend, 0, 1)).to_equal(CYAN)
