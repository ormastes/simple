# Test: expr tool
# Feature: TOOL-EXPR - Evaluate arithmetic expressions
# @cover tools/shell/expr/expr_tool.spl

describe "expr tool":
    context "arithmetic":
        it "adds integers":
            expect(3 + 4).to_equal(7)

        it "subtracts integers":
            expect(10 - 3).to_equal(7)

        it "multiplies integers":
            expect(6 * 7).to_equal(42)

        it "divides integers":
            expect(15 / 3).to_equal(5)

        it "computes modulo":
            expect(17 % 5).to_equal(2)

    context "comparison":
        it "equal returns 1 for match":
            val result = if 5 == 5: 1 else: 0
            expect(result).to_equal(1)

        it "not-equal returns 1 for mismatch":
            val result = if 5 != 3: 1 else: 0
            expect(result).to_equal(1)
