# Test: dirname tool
# Feature: TOOL-DIRNAME - Strip filename from path
# @cover tools/shell/dirname/dirname_tool.spl

describe "dirname tool":
    context "path extraction":
        it "extracts parent directory":
            val path = "/usr/local/bin/simple"
            var last_slash = -1
            var i = 0
            for ch in path:
                if ch == "/":
                    last_slash = i
                i = i + 1
            val dir = path.slice(0, last_slash)
            expect(dir).to_equal("/usr/local/bin")

        it "returns / for root-level files":
            val path = "/file.txt"
            var last_slash = 0
            expect(path.slice(0, 1)).to_equal("/")

        it "returns . for bare filename":
            val path = "file.txt"
            var has_slash = false
            for ch in path:
                if ch == "/":
                    has_slash = true
            val result = if has_slash: "error" else: "."
            expect(result).to_equal(".")
