# Test: find tool
# Feature: TOOL-FIND - Search for files in directory hierarchy
#
# Local reimplementation of find helper functions to avoid interpreter-mode issues
# (importing app.tools.find.main fails with "method `len` not found on type `symbol`")

fn parse_size_filter(spec: text) -> (text, i64):
    """Parse size spec like +1M, -100k. Returns (comparison, bytes)."""
    if spec.len() == 0:
        return ("", 0)

    # Split into individual characters to avoid substring corruption bug
    var chars: [text] = []
    val raw_chars = spec.split("")
    for ch in raw_chars:
        if ch.len() > 0:
            chars.push(ch)

    var cmp = ""
    var start_idx = 0
    if chars[0] == "+":
        cmp = "+"
        start_idx = 1
    elif chars[0] == "-":
        cmp = "-"
        start_idx = 1

    var multiplier = 1
    val last_ch = chars[chars.len() - 1]
    var end_idx = chars.len()
    if last_ch == "k" or last_ch == "K":
        multiplier = 1024
        end_idx = chars.len() - 1
    elif last_ch == "M" or last_ch == "m":
        multiplier = 1024 * 1024
        end_idx = chars.len() - 1
    elif last_ch == "G" or last_ch == "g":
        multiplier = 1024 * 1024 * 1024
        end_idx = chars.len() - 1

    # Build number string from chars[start_idx..end_idx]
    var num_str = ""
    var i = start_idx
    while i < end_idx:
        num_str = num_str + chars[i]
        i = i + 1

    val num = int(num_str)
    (cmp, num * multiplier)

fn matches_size(actual_size: i64, cmp: text, target: i64) -> bool:
    """Check if file size matches the filter."""
    if cmp == "+":
        actual_size > target
    elif cmp == "-":
        actual_size < target
    else:
        actual_size == target

fn count_depth(path: text, base: text) -> i64:
    """Count directory depth relative to base path."""
    val relative = if path.starts_with(base): path.substring(base.len()) else: path
    # Count "/" characters using split instead of substring iteration
    val parts = relative.split("/")
    # Number of slashes = parts.len() - 1
    parts.len() - 1

describe "find tool":
    context "size filter parsing":
        it "parses plus prefix":
            val result = parse_size_filter("+100")
            expect(result.0).to_equal("+")
            expect(result.1).to_equal(100)

        it "parses minus prefix":
            val result = parse_size_filter("-50")
            expect(result.0).to_equal("-")
            expect(result.1).to_equal(50)

        it "parses kilobyte suffix":
            val result = parse_size_filter("+1k")
            expect(result.0).to_equal("+")
            expect(result.1).to_equal(1024)

        it "parses megabyte suffix":
            val result = parse_size_filter("+1M")
            expect(result.0).to_equal("+")
            expect(result.1).to_equal(1048576)

    context "size matching":
        it "matches greater than":
            expect(matches_size(200, "+", 100)).to_equal(true)

        it "rejects not greater than":
            expect(matches_size(50, "+", 100)).to_equal(false)

        it "matches less than":
            expect(matches_size(50, "-", 100)).to_equal(true)

        it "matches exact size":
            expect(matches_size(100, "", 100)).to_equal(true)

    context "depth counting":
        it "counts zero depth for base path":
            val depth = count_depth("src", "src")
            expect(depth).to_equal(0)

        it "counts nested depth":
            val depth = count_depth("src/app/tools", "src")
            expect(depth).to_equal(2)
