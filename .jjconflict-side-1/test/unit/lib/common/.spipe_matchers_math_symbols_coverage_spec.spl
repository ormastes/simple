# @covers src/lib/common/unicode_math.spl 80%
"""
# Unicode Math Symbols & Operators Coverage Specification

**Feature IDs:** #LIB-MATH-COV
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Branch coverage tests for `std.unicode_math` symbol/operator lookup functions
and box-drawing/bracket pieces. Split from math_coverage_spec.spl for memory.

## Key Concepts

| Concept | Description |
|---------|-------------|
| math_sym | Symbol lookup: calculus, roots, constants, quantifiers, logic, sets, misc |
| math_op | Operator lookup: comparison, arithmetic, arrows |
| brackets | Box-drawing pieces for matrices |
"""

use std.unicode_math.{math_sym, math_op, hline}
use std.unicode_math.{bracket_left_top, bracket_left_mid, bracket_left_bot}
use std.unicode_math.{bracket_right_top, bracket_right_mid, bracket_right_bot}
use std.unicode_math.{paren_left_top, paren_left_mid, paren_left_bot}
use std.unicode_math.{paren_right_top, paren_right_mid, paren_right_bot}
use std.unicode_math.{brace_left_top, brace_left_mid, brace_left_bot}
use std.unicode_math.{brace_right_top, brace_right_mid, brace_right_bot}
use std.unicode_math.{brace_ext}

# ============================================================================
# 1. unicode_math — Math Symbols
# ============================================================================

describe "unicode_math math_sym":
    """
    ## Math Symbol Lookup

    Tests symbol lookup for calculus, roots, constants, quantifiers,
    logic, sets, number sets, and miscellaneous symbols.
    """

    context "calculus symbols":
        it "returns sum":
            expect math_sym("sum") == "\u2211"

        it "returns product":
            expect math_sym("product") == "\u220F"

        it "returns coproduct":
            expect math_sym("coproduct") == "\u2210"

        it "returns integral":
            expect math_sym("integral") == "\u222B"

        it "returns double_integral":
            expect math_sym("double_integral") == "\u222C"

        it "returns triple_integral":
            expect math_sym("triple_integral") == "\u222D"

        it "returns contour_integral":
            expect math_sym("contour_integral") == "\u222E"

        it "returns surface_integral":
            expect math_sym("surface_integral") == "\u222F"

        it "returns volume_integral":
            expect math_sym("volume_integral") == "\u2230"

    context "root symbols":
        it "returns sqrt":
            expect math_sym("sqrt") == "\u221A"

        it "returns cbrt":
            expect math_sym("cbrt") == "\u221B"

        it "returns fourthrt":
            expect math_sym("fourthrt") == "\u221C"

    context "constants":
        it "returns infinity":
            expect math_sym("infinity") == "\u221E"

        it "returns pi_sym":
            expect math_sym("pi_sym") == "\u03C0"

        it "returns euler":
            expect math_sym("euler") == "\u212F"

        it "returns imaginary":
            expect math_sym("imaginary") == "\u2111"

        it "returns real_part":
            expect math_sym("real_part") == "\u211C"

        it "returns planck":
            expect math_sym("planck") == "\u210F"

        it "returns aleph":
            expect math_sym("aleph") == "\u2135"

    context "quantifiers":
        it "returns forall":
            expect math_sym("forall") == "\u2200"

        it "returns exists":
            expect math_sym("exists") == "\u2203"

        it "returns nexists":
            expect math_sym("nexists") == "\u2204"

    context "logic symbols":
        it "returns and":
            expect math_sym("and") == "\u2227"

        it "returns or":
            expect math_sym("or") == "\u2228"

        it "returns not":
            expect math_sym("not") == "\u00AC"

        it "returns top":
            expect math_sym("top") == "\u22A4"

        it "returns bot":
            expect math_sym("bot") == "\u22A5"

        it "returns proves":
            expect math_sym("proves") == "\u22A2"

        it "returns models":
            expect math_sym("models") == "\u22A8"

        it "returns therefore":
            expect math_sym("therefore") == "\u2234"

        it "returns because":
            expect math_sym("because") == "\u2235"

    context "set symbols":
        it "returns in":
            expect math_sym("in") == "\u2208"

        it "returns notin":
            expect math_sym("notin") == "\u2209"

        it "returns subset":
            expect math_sym("subset") == "\u2282"

        it "returns superset":
            expect math_sym("superset") == "\u2283"

        it "returns subseteq":
            expect math_sym("subseteq") == "\u2286"

        it "returns supseteq":
            expect math_sym("supseteq") == "\u2287"

        it "returns union":
            expect math_sym("union") == "\u222A"

        it "returns intersection":
            expect math_sym("intersection") == "\u2229"

        it "returns emptyset":
            expect math_sym("emptyset") == "\u2205"

        it "returns setminus":
            expect math_sym("setminus") == "\u2216"

    context "number set symbols":
        it "returns naturals":
            expect math_sym("naturals") == "\u2115"

        it "returns integers":
            expect math_sym("integers") == "\u2124"

        it "returns rationals":
            expect math_sym("rationals") == "\u211A"

        it "returns reals":
            expect math_sym("reals") == "\u211D"

        it "returns complex":
            expect math_sym("complex") == "\u2102"

        it "returns primes":
            expect math_sym("primes") == "\u2119"

    context "miscellaneous symbols":
        it "returns degree":
            expect math_sym("degree") == "\u00B0"

        it "returns prime":
            expect math_sym("prime") == "\u2032"

        it "returns double_prime":
            expect math_sym("double_prime") == "\u2033"

        it "returns triple_prime":
            expect math_sym("triple_prime") == "\u2034"

        it "returns ellipsis":
            expect math_sym("ellipsis") == "\u2026"

        it "returns vellipsis":
            expect math_sym("vellipsis") == "\u22EE"

        it "returns hellipsis":
            expect math_sym("hellipsis") == "\u22EF"

        it "returns dellipsis":
            expect math_sym("dellipsis") == "\u22F1"

        it "returns compose":
            expect math_sym("compose") == "\u2218"

        it "returns tensor":
            expect math_sym("tensor") == "\u2297"

        it "returns direct_sum":
            expect math_sym("direct_sum") == "\u2295"

        it "returns dot_product":
            expect math_sym("dot_product") == "\u2299"

    context "fallback for unknown symbols":
        it "returns unknown name unchanged":
            expect math_sym("unknown_sym") == "unknown_sym"


# ============================================================================
# 2. unicode_math — Math Operators
# ============================================================================

describe "unicode_math math_op":
    """
    ## Math Operator Lookup

    Tests operator lookup for comparison, arithmetic, and arrow symbols.
    """

    context "comparison operators":
        it "returns leq":
            expect math_op("leq") == "\u2264"

        it "returns geq":
            expect math_op("geq") == "\u2265"

        it "returns neq":
            expect math_op("neq") == "\u2260"

        it "returns approx":
            expect math_op("approx") == "\u2248"

        it "returns equiv":
            expect math_op("equiv") == "\u2261"

        it "returns nequiv":
            expect math_op("nequiv") == "\u2262"

        it "returns cong":
            expect math_op("cong") == "\u2245"

        it "returns sim":
            expect math_op("sim") == "\u223C"

        it "returns ll":
            expect math_op("ll") == "\u226A"

        it "returns gg":
            expect math_op("gg") == "\u226B"

        it "returns propto":
            expect math_op("propto") == "\u221D"

        it "returns defeq":
            expect math_op("defeq") == "\u2254"

    context "arithmetic operators":
        it "returns pm":
            expect math_op("pm") == "\u00B1"

        it "returns mp":
            expect math_op("mp") == "\u2213"

        it "returns times":
            expect math_op("times") == "\u00D7"

        it "returns div":
            expect math_op("div") == "\u00F7"

        it "returns cdot":
            expect math_op("cdot") == "\u00B7"

        it "returns star":
            expect math_op("star") == "\u2217"

    context "arrow operators":
        it "returns to":
            expect math_op("to") == "\u2192"

        it "returns from":
            expect math_op("from") == "\u2190"

        it "returns lr":
            expect math_op("lr") == "\u2194"

        it "returns implies":
            expect math_op("implies") == "\u21D2"

        it "returns implied_by":
            expect math_op("implied_by") == "\u21D0"

        it "returns iff":
            expect math_op("iff") == "\u21D4"

        it "returns mapsto":
            expect math_op("mapsto") == "\u21A6"

        it "returns long_to":
            expect math_op("long_to") == "\u27F6"

        it "returns long_implies":
            expect math_op("long_implies") == "\u27F9"

        it "returns long_iff":
            expect math_op("long_iff") == "\u27FA"

        it "returns surjection":
            expect math_op("surjection") == "\u21A0"

        it "returns injection":
            expect math_op("injection") == "\u21A3"

    context "fallback for unknown operators":
        it "returns unknown name unchanged":
            expect math_op("unknown_op") == "unknown_op"


# ============================================================================
# 3. unicode_math — Box Drawing / Brackets
# ============================================================================

describe "unicode_math brackets and lines":
    """
    ## Box Drawing and Bracket Pieces

    Tests hline generation and all bracket/paren/brace piece functions.
    """

    context "hline":
        it "creates line of width 3":
            val line = hline(3)
            expect line.len() > 0

        it "creates line of width 0":
            expect hline(0) == ""

    context "square bracket pieces":
        it "returns left top bracket":
            expect bracket_left_top() == "\u23A1"

        it "returns left mid bracket":
            expect bracket_left_mid() == "\u23A2"

        it "returns left bot bracket":
            expect bracket_left_bot() == "\u23A3"

        it "returns right top bracket":
            expect bracket_right_top() == "\u23A4"

        it "returns right mid bracket":
            expect bracket_right_mid() == "\u23A5"

        it "returns right bot bracket":
            expect bracket_right_bot() == "\u23A6"

    context "parenthesis pieces":
        it "returns left top paren":
            expect paren_left_top() == "\u239B"

        it "returns left mid paren":
            expect paren_left_mid() == "\u239C"

        it "returns left bot paren":
            expect paren_left_bot() == "\u239D"

        it "returns right top paren":
            expect paren_right_top() == "\u239E"

        it "returns right mid paren":
            expect paren_right_mid() == "\u239F"

        it "returns right bot paren":
            expect paren_right_bot() == "\u23A0"

    context "brace pieces":
        it "returns left top brace":
            expect brace_left_top() == "\u23A7"

        it "returns left mid brace":
            expect brace_left_mid() == "\u23A8"

        it "returns left bot brace":
            expect brace_left_bot() == "\u23A9"

        it "returns right top brace":
            expect brace_right_top() == "\u23AB"

        it "returns right mid brace":
            expect brace_right_mid() == "\u23AC"

        it "returns right bot brace":
            expect brace_right_bot() == "\u23AD"

        it "returns brace extension":
            expect brace_ext() == "\u23AA"