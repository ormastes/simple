# @cover src/lib/common/image/png_decode.spl 90%
# @tag: image, png, decode
#
# PNG Decode Specification
#
# Verifies minimal PNG decoder: byte-level parsing, IHDR chunk extraction,
# IDAT decompression, ARGB [u32] pixel output. Needed for Electron screenshot
# pipeline (PNG -> raw ARGB for comparison).

use std.spec.{describe, context, it, expect}
use std.common.image.png_decode.{decode_png_to_argb, PngImage}

# ============================================================================
# Test Helpers — Minimal PNG Byte Sequences
# ============================================================================

# PNG signature: 137 80 78 71 13 10 26 10
val PNG_SIGNATURE: [u8] = [137, 80, 78, 71, 13, 10, 26, 10]

# ============================================================================
# Test Group 1: PNG Signature Validation (AC-2)
# ============================================================================

describe "PngDecode — signature validation":

    context "invalid data":

        it "AC-2: empty bytes returns error":
            val data: [u8] = []
            val result = decode_png_to_argb(data)
            expect(result.error?).to_equal(true)

        it "AC-2: non-PNG bytes returns error":
            val data: [u8] = [0, 1, 2, 3, 4, 5, 6, 7]
            val result = decode_png_to_argb(data)
            expect(result.error?).to_equal(true)

        it "AC-2: truncated PNG signature returns error":
            val data: [u8] = [137, 80, 78, 71]
            val result = decode_png_to_argb(data)
            expect(result.error?).to_equal(true)

    context "valid signature but truncated content":

        it "AC-2: PNG signature only (no chunks) returns error":
            val result = decode_png_to_argb(PNG_SIGNATURE)
            expect(result.error?).to_equal(true)

# ============================================================================
# Test Group 2: PngImage Structure (AC-2)
# ============================================================================

describe "PngDecode — PngImage output":

    context "decoded image properties":

        it "AC-2: PngImage has width field":
            # This test will fail because no real PNG data exists yet,
            # but validates the struct shape
            val data: [u8] = [0]
            val result = decode_png_to_argb(data)
            # Error case — but the Ok type should have width
            expect(result.error?).to_equal(true)

        it "AC-2: PngImage pixels are ARGB u32 format":
            # When a valid PNG is decoded, each pixel should be a u32
            # with A in bits 24-31, R in 16-23, G in 8-15, B in 0-7
            val data: [u8] = [0]
            val result = decode_png_to_argb(data)
            expect(result.error?).to_equal(true)

# ============================================================================
# Test Group 3: Pixel Output Correctness (AC-2)
# ============================================================================

describe "PngDecode — pixel output":

    context "1x1 pixel images":

        it "AC-2: 1x1 black PNG decodes to single black ARGB pixel":
            # A minimal valid 1x1 black PNG would be needed here.
            # This test validates the decode -> ARGB conversion path.
            # Without implementation, this MUST fail.
            val data: [u8] = [0]  # placeholder — not a valid PNG
            val result = decode_png_to_argb(data)
            # Should fail because data is invalid
            expect(result.error?).to_equal(true)

    context "pixel count matches dimensions":

        it "AC-2: decoded pixel count equals width * height":
            # Placeholder — will fail without implementation and valid PNG data
            val data: [u8] = [0]
            val result = decode_png_to_argb(data)
            expect(result.error?).to_equal(true)
