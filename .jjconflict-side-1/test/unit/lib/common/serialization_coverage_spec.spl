# ============================================================================
# Test Group 20: Byte Array Utilities (utilities.spl)
# ============================================================================

describe "write_bytes":
    """
    ## Byte Array Writing
    """

    it "prepends length as varint":
        val result = write_bytes([10, 20, 30])
        expect(result[0]).to_equal(3)
        expect(result.len()).to_equal(4)

    it "writes empty byte array":
        val result = write_bytes([])
        expect(result[0]).to_equal(0)
        expect(result.len()).to_equal(1)

describe "read_bytes":
    """
    ## Byte Array Reading

    Tests normal read, read beyond bounds, and empty read.
    """

    it "reads specified number of bytes":
        val data = [10, 20, 30, 40, 50]
        val result = read_bytes(data, 1, 3)
        val bytes = result.0
        expect(bytes.len()).to_equal(3)
        expect(bytes[0]).to_equal(20)
        expect(bytes[1]).to_equal(30)
        expect(bytes[2]).to_equal(40)

    it "handles read beyond array bounds":
        val data = [10, 20]
        val result = read_bytes(data, 0, 5)
        val bytes = result.0
        expect(bytes.len()).to_equal(2)

    it "reads zero bytes":
        val result = read_bytes([1, 2, 3], 0, 0)
        val bytes = result.0
        expect(bytes.len()).to_equal(0)

describe "read_bytes_with_length":
    """
    ## Length-Prefixed Byte Reading

    Roundtrip test with write_bytes.
    """

    it "roundtrips with write_bytes":
        val original = [65, 66, 67]
        val written = write_bytes(original)
        val result = read_bytes_with_length(written, 0)
        val data = result.0
        val consumed = result.1
        expect(data.len()).to_equal(3)
        expect(data[0]).to_equal(65)
        expect(data[1]).to_equal(66)
        expect(data[2]).to_equal(67)

# ============================================================================
# Test Group 21: Hex Conversion (utilities.spl)
# ============================================================================

describe "int_to_hex":
    """
    ## Integer to Hex Conversion
    """

    it "converts zero":
        expect(int_to_hex(0)).to_equal("00")

    it "converts single digit":
        expect(int_to_hex(10)).to_equal("0a")

    it "converts 255":
        expect(int_to_hex(255)).to_equal("ff")

    it "converts mid-range value":
        expect(int_to_hex(171)).to_equal("ab")

describe "bytes_to_hex":
    """
    ## Byte Array to Hex String
    """

    it "converts empty byte array":
        expect(bytes_to_hex([])).to_equal("")

    it "converts single byte":
        expect(bytes_to_hex([255])).to_equal("ff")

    it "converts multiple bytes":
        expect(bytes_to_hex([0, 171, 255])).to_equal("00abff")

describe "hex_to_bytes":
    """
    ## Hex String to Byte Array

    Tests even-length, odd-length (trailing nibble), and empty.
    """

    it "converts empty hex string":
        val result = hex_to_bytes("")
        expect(result.len()).to_equal(0)

    it "converts valid hex pairs":
        val result = hex_to_bytes("00abff")
        expect(result.len()).to_equal(3)
        expect(result[0]).to_equal(0)
        expect(result[1]).to_equal(171)
        expect(result[2]).to_equal(255)

    it "handles uppercase hex":
        val result = hex_to_bytes("AB")
        expect(result.len()).to_equal(1)
        expect(result[0]).to_equal(171)

    it "handles odd-length hex string by skipping trailing nibble":
        val result = hex_to_bytes("abc")
        expect(result.len()).to_equal(1)
        expect(result[0]).to_equal(171)

    it "roundtrips with bytes_to_hex":
        val original = [0, 42, 255, 128]
        val roundtripped = hex_to_bytes(bytes_to_hex(original))
        expect(deep_equal_list_int(original, roundtripped)).to_equal(true)

# ============================================================================
# Test Group 22: Roundtrip Integration Tests
# ============================================================================

describe "Serialization Roundtrips":
    """
    ## End-to-End Roundtrip Tests

    Verify that serialize -> deserialize / encode -> decode paths produce
    consistent results.
    """

    context "varint roundtrips":
        it "roundtrips various values":
            val values = [0, 1, 127, 128, 256, 1000, -1, -128, -1000]
            var i = 0
            while i < values.len():
                val encoded = write_varint(values[i])
                val decoded = read_varint(encoded, 0)
                expect(decoded.0).to_equal(values[i])
                i = i + 1

    context "string escape roundtrips":
        it "roundtrips strings with all special characters":
            val inputs = ["", "hello", "say \"hi\"", "a\\b", "line1\nline2", "col1\tcol2", "cr\rhere"]
            var i = 0
            while i < inputs.len():
                val roundtripped = unescape_string(escape_string(inputs[i]))
                expect(roundtripped).to_equal(inputs[i])
                i = i + 1

    context "quote/unquote roundtrips":
        it "roundtrips text through quote and unquote":
            val inputs = ["", "simple", "with \"quotes\"", "with\nnewline"]
            var i = 0
            while i < inputs.len():
                val roundtripped = unquote_string(quote_string(inputs[i]))
                expect(roundtripped).to_equal(inputs[i])
                i = i + 1

    context "hex roundtrips":
        it "roundtrips byte arrays through hex conversion":
            val inputs = [[], [0], [255], [0, 127, 255], [16, 32, 48]]
            var i = 0
            while i < inputs.len():
                val roundtripped = hex_to_bytes(bytes_to_hex(inputs[i]))
                expect(deep_equal_list_int(inputs[i], roundtripped)).to_equal(true)
                i = i + 1

    context "version roundtrips":
        it "roundtrips versioned data":
            val data = "[1, 2, 3]"
            val versioned = add_version(data, 42)
            expect(get_version(versioned)).to_equal(42)
            expect(strip_version(versioned)).to_equal(data)

    context "type tag roundtrips":
        it "roundtrips tagged data":
            val data = "inner content"
            val tagged = tag_type(data, "CustomType")
            expect(get_type_tag(tagged)).to_equal("CustomType")
            expect(strip_type_tag(tagged)).to_equal(data)

