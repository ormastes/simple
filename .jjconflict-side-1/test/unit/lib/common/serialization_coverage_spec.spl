# @covers src/lib/common/serialization/formats.spl 70%
"""
# Serialization Module Coverage Specification

**Feature IDs:** #SERIAL-COV
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Comprehensive branch-coverage tests for `src/lib/common/serialization/`.
Covers all exported functions from serialize.spl, formats.spl, types.spl,
utilities.spl, and deserialize.spl aiming for 90%+ branch coverage.

## Key Concepts

| Concept | Description |
|---------|-------------|
| Text Serialization | Convert primitives/collections to human-readable text |
| Binary Serialization | Convert primitives/collections to byte arrays |
| SDN | Simple Data Notation format detection and validation |
| Varint | Variable-length integer encoding for compact binary |
| Type Tags | Runtime type markers for serialized objects |
| Pretty Print | Indented formatting for nested structures |

## Related Specifications

- [DB Serializer](test/unit/tools/db_serializer_spec.spl) - SDN serialization tests

## Implementation Notes

Each function is tested with both "happy path" and edge/boundary inputs
to exercise true AND false branches in every conditional.
"""

use serialization.*

# ============================================================================
# Test Group 1: Type Constants (types.spl)
# ============================================================================

describe "Type Constants":
    """
    ## Type Tag Values

    Verify each type constant returns the expected integer tag.
    """

    it "returns correct values for all type tags":
        expect(type_nil()).to_equal(0)
        expect(type_bool()).to_equal(1)
        expect(type_int()).to_equal(2)
        expect(type_float()).to_equal(3)
        expect(type_text()).to_equal(4)
        expect(type_list()).to_equal(5)
        expect(type_tuple()).to_equal(6)
        expect(type_dict()).to_equal(7)
        expect(type_custom()).to_equal(8)

# ============================================================================
# Test Group 2: Character Code Functions (serialize.spl)
# ============================================================================

describe "char_code_safe":
    """
    ## ASCII Code Lookup

    Tests char_code_safe for all character classes to hit every branch.
    """

    context "printable symbols":
        it "returns correct code for space":
            expect(char_code_safe(" ")).to_equal(32)

        it "returns correct code for exclamation":
            expect(char_code_safe("!")).to_equal(33)

        it "returns correct code for double quote":
            expect(char_code_safe("\"")).to_equal(34)

        it "returns correct code for hash":
            expect(char_code_safe("#")).to_equal(35)

        it "returns correct code for various symbols":
            expect(char_code_safe("$")).to_equal(36)
            expect(char_code_safe("%")).to_equal(37)
            expect(char_code_safe("&")).to_equal(38)
            expect(char_code_safe("'")).to_equal(39)
            expect(char_code_safe("(")).to_equal(40)
            expect(char_code_safe(")")).to_equal(41)
            expect(char_code_safe("*")).to_equal(42)
            expect(char_code_safe("+")).to_equal(43)
            expect(char_code_safe(",")).to_equal(44)
            expect(char_code_safe("-")).to_equal(45)
            expect(char_code_safe(".")).to_equal(46)
            expect(char_code_safe("/")).to_equal(47)

    context "digits":
        it "returns correct codes for all digits":
            expect(char_code_safe("0")).to_equal(48)
            expect(char_code_safe("1")).to_equal(49)
            expect(char_code_safe("2")).to_equal(50)
            expect(char_code_safe("3")).to_equal(51)
            expect(char_code_safe("4")).to_equal(52)
            expect(char_code_safe("5")).to_equal(53)
            expect(char_code_safe("6")).to_equal(54)
            expect(char_code_safe("7")).to_equal(55)
            expect(char_code_safe("8")).to_equal(56)
            expect(char_code_safe("9")).to_equal(57)

    context "punctuation after digits":
        it "returns correct codes for colon through at-sign":
            expect(char_code_safe(":")).to_equal(58)
            expect(char_code_safe(";")).to_equal(59)
            expect(char_code_safe("<")).to_equal(60)
            expect(char_code_safe("=")).to_equal(61)
            expect(char_code_safe(">")).to_equal(62)
            expect(char_code_safe("@")).to_equal(64)

    context "uppercase letters":
        it "returns correct codes for A-Z range":
            expect(char_code_safe("A")).to_equal(65)
            expect(char_code_safe("M")).to_equal(77)
            expect(char_code_safe("Z")).to_equal(90)

    context "lowercase letters":
        it "returns correct codes for a-z range":
            expect(char_code_safe("a")).to_equal(97)
            expect(char_code_safe("m")).to_equal(109)
            expect(char_code_safe("z")).to_equal(122)

    context "bracket and brace characters":
        it "returns correct codes for brackets and braces":
            expect(char_code_safe("[")).to_equal(91)
            expect(char_code_safe("\\")).to_equal(92)
            expect(char_code_safe("]")).to_equal(93)
            expect(char_code_safe("^")).to_equal(94)
            expect(char_code_safe("_")).to_equal(95)
            expect(char_code_safe("`")).to_equal(96)
            expect(char_code_safe("{")).to_equal(123)
            expect(char_code_safe("|")).to_equal(124)
            expect(char_code_safe("}")).to_equal(125)
            expect(char_code_safe("~")).to_equal(126)

    context "whitespace characters":
        it "returns correct codes for newline tab and carriage return":
            expect(char_code_safe("\n")).to_equal(10)
            expect(char_code_safe("\t")).to_equal(9)
            expect(char_code_safe("\r")).to_equal(13)

    context "fallback for unknown characters":
        it "returns 0 for unrecognized input":
            # Empty string or non-ASCII falls through to default 0
            expect(char_code_safe("")).to_equal(0)

# ============================================================================
# Test Group 3: Varint Encoding (serialize.spl)
# ============================================================================

describe "write_varint":
    """
    ## Variable-Length Integer Encoding

    Tests zero, positive, negative, and multi-byte varint encoding.
    """

    context "when value is zero":
        it "returns single byte zero":
            val result = write_varint(0)
            expect(result.len()).to_equal(1)
            expect(result[0]).to_equal(0)

    context "when value is positive and small":
        it "encodes small positive as single byte":
            val result = write_varint(42)
            expect(result.len()).to_equal(1)
            expect(result[0]).to_equal(42)

    context "when value is positive and large":
        it "encodes values above 127 as multi-byte":
            val result = write_varint(300)
            expect(result.len()).to_be_greater_than(1)

    context "when value is negative":
        it "prepends 255 sign marker":
            val result = write_varint(-42)
            expect(result[0]).to_equal(255)
            expect(result.len()).to_be_greater_than(1)

describe "read_varint":
    """
    ## Variable-Length Integer Decoding

    Tests roundtrip decoding for zero, positive, negative, and multi-byte values.
    """

    context "roundtrip with zero":
        it "decodes zero correctly":
            val encoded = write_varint(0)
            val result = read_varint(encoded, 0)
            expect(result.0).to_equal(0)

    context "roundtrip with positive":
        it "decodes positive correctly":
            val encoded = write_varint(42)
            val result = read_varint(encoded, 0)
            expect(result.0).to_equal(42)

    context "roundtrip with large positive":
        it "decodes multi-byte positive correctly":
            val encoded = write_varint(300)
            val result = read_varint(encoded, 0)
            expect(result.0).to_equal(300)

    context "roundtrip with negative":
        it "decodes negative correctly":
            val encoded = write_varint(-42)
            val result = read_varint(encoded, 0)
            expect(result.0).to_equal(-42)

    context "consumed bytes count":
        it "reports correct number of consumed bytes":
            val encoded = write_varint(42)
            val result = read_varint(encoded, 0)
            expect(result.1).to_equal(encoded.len())

# ============================================================================
# Test Group 4: Binary Serialization - Primitives (serialize.spl)
# ============================================================================

describe "serialize_int_bytes":
    """
    ## Integer Binary Serialization

    Tests type tag presence and varint encoding of integers.
    """

    it "starts with int type tag":
        val result = serialize_int_bytes(0)
        expect(result[0]).to_equal(type_int())

    it "serializes zero":
        val result = serialize_int_bytes(0)
        expect(result.len()).to_be_greater_than(1)

    it "serializes positive integer":
        val result = serialize_int_bytes(100)
        expect(result[0]).to_equal(type_int())
        expect(result.len()).to_be_greater_than(1)

    it "serializes negative integer":
        val result = serialize_int_bytes(-50)
        expect(result[0]).to_equal(type_int())

describe "serialize_bool_bytes":
    """
    ## Boolean Binary Serialization

    Tests both true and false branches.
    """

    it "serializes true with type tag and 1":
        val result = serialize_bool_bytes(true)
        expect(result[0]).to_equal(type_bool())
        expect(result[1]).to_equal(1)

    it "serializes false with type tag and 0":
        val result = serialize_bool_bytes(false)
        expect(result[0]).to_equal(type_bool())
        expect(result[1]).to_equal(0)

describe "serialize_nil_bytes":
    """
    ## Nil Binary Serialization
    """

    it "returns single byte with nil type tag":
        val result = serialize_nil_bytes()
        expect(result.len()).to_equal(1)
        expect(result[0]).to_equal(type_nil())

describe "serialize_text_bytes":
    """
    ## Text Binary Serialization

    Tests empty and non-empty strings.
    """

    it "serializes empty string":
        val result = serialize_text_bytes("")
        expect(result[0]).to_equal(type_text())

    it "serializes non-empty string with correct length":
        val result = serialize_text_bytes("abc")
        expect(result[0]).to_equal(type_text())
        expect(result.len()).to_be_greater_than(1)

    it "serializes string with special characters":
        val result = serialize_text_bytes("a\nb")
        expect(result[0]).to_equal(type_text())

# ============================================================================
# Test Group 5: Text Serialization - String Escaping (serialize.spl)
# ============================================================================

describe "escape_string":
    """
    ## String Escaping

    Tests every escape branch: quote, backslash, newline, tab, carriage return, normal.
    """

    it "escapes double quotes":
        val result = escape_string("say \"hi\"")
        expect(result).to_contain("\\\"")

    it "escapes backslashes":
        val result = escape_string("path\\to")
        expect(result).to_contain("\\\\")

    it "escapes newlines":
        val result = escape_string("a\nb")
        expect(result).to_contain("\\n")

    it "escapes tabs":
        val result = escape_string("a\tb")
        expect(result).to_contain("\\t")

    it "escapes carriage returns":
        val result = escape_string("a\rb")
        expect(result).to_contain("\\r")

    it "passes through normal characters unchanged":
        val result = escape_string("hello")
        expect(result).to_equal("hello")

    it "handles empty string":
        val result = escape_string("")
        expect(result).to_equal("")

describe "unescape_string":
    """
    ## String Unescaping

    Tests every unescape branch and roundtrip with escape_string.
    """

    it "unescapes backslash-quote to quote":
        val result = unescape_string("say \\\"hi\\\"")
        expect(result).to_contain("\"")

    it "unescapes backslash-backslash":
        val result = unescape_string("path\\\\to")
        expect(result).to_contain("\\")

    it "unescapes backslash-n to newline":
        val result = unescape_string("a\\nb")
        expect(result).to_contain("\n")

    it "unescapes backslash-t to tab":
        val result = unescape_string("a\\tb")
        expect(result).to_contain("\t")

    it "unescapes backslash-r to carriage return":
        val result = unescape_string("a\\rb")
        expect(result).to_contain("\r")

    it "handles unknown escape sequence":
        val result = unescape_string("a\\xb")
        expect(result).to_equal("a\\xb")

    it "handles trailing backslash at end of string":
        val result = unescape_string("abc\\")
        expect(result).to_equal("abc\\")

    it "handles empty string":
        val result = unescape_string("")
        expect(result).to_equal("")

    it "roundtrips with escape_string":
        val original = "say \"hi\"\npath\\to\ttab\rreturn"
        val roundtripped = unescape_string(escape_string(original))
        expect(roundtripped).to_equal(original)

describe "quote_string":
    """
    ## String Quoting
    """

    it "wraps string in double quotes":
        val result = quote_string("hello")
        expect(result).to_start_with("\"")
        expect(result).to_end_with("\"")

    it "escapes inner content":
        val result = quote_string("say \"hi\"")
        expect(result).to_start_with("\"")
        expect(result).to_end_with("\"")
        expect(result).to_contain("\\\"")

describe "unquote_string":
    """
    ## String Unquoting

    Tests quoted, unquoted, short, and non-quoted inputs.
    """

    it "removes quotes and unescapes":
        val result = unquote_string("\"hello\"")
        expect(result).to_equal("hello")

    it "returns input unchanged for short strings":
        val result = unquote_string("x")
        expect(result).to_equal("x")

    it "returns input unchanged when not quoted":
        val result = unquote_string("hello")
        expect(result).to_equal("hello")

    it "returns empty input unchanged":
        val result = unquote_string("")
        expect(result).to_equal("")

    it "roundtrips with quote_string":
        val original = "hello world"
        val roundtripped = unquote_string(quote_string(original))
        expect(roundtripped).to_equal(original)

