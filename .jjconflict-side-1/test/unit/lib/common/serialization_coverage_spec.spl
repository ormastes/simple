describe "to_sdn_int":
    """
    ## SDN Integer Conversion
    """

    it "converts positive integer":
        expect(to_sdn_int(42)).to_equal("42")

    it "converts zero":
        expect(to_sdn_int(0)).to_equal("0")

    it "converts negative integer":
        expect(to_sdn_int(-5)).to_equal("-5")

describe "to_sdn_bool":
    """
    ## SDN Boolean Conversion

    Both true and false branches.
    """

    it "converts true":
        expect(to_sdn_bool(true)).to_equal("true")

    it "converts false":
        expect(to_sdn_bool(false)).to_equal("false")

describe "to_sdn_nil":
    """
    ## SDN Nil Conversion
    """

    it "converts nil value":
        expect(to_sdn_nil()).to_equal("nil")

describe "to_sdn_text":
    """
    ## SDN Text Conversion
    """

    it "quotes text":
        val result = to_sdn_text("hello")
        expect(result).to_equal("\"hello\"")

describe "to_sdn_list":
    """
    ## SDN List Conversion
    """

    it "converts empty list":
        expect(to_sdn_list([])).to_equal("[]")

    it "converts non-empty list":
        expect(to_sdn_list(["1", "2"])).to_equal("[1, 2]")

describe "to_sdn_tuple":
    """
    ## SDN Tuple Conversion
    """

    it "converts empty tuple":
        expect(to_sdn_tuple([])).to_equal("()")

    it "converts non-empty tuple":
        expect(to_sdn_tuple(["a", "b"])).to_equal("(a, b)")

describe "to_sdn_dict":
    """
    ## SDN Dict Conversion
    """

    it "converts empty dict":
        expect(to_sdn_dict([])).to_equal("{}")

    it "converts non-empty dict":
        expect(to_sdn_dict([("k", "v")])).to_equal("{k: v}")

# ============================================================================
# Test Group 11: Format Detection (formats.spl)
# ============================================================================

describe "is_numeric_text":
    """
    ## Numeric Text Detection

    Tests all branches: empty, negative sign only, valid digits, non-digit chars, negative numbers.
    """

    it "returns false for empty string":
        expect(is_numeric_text("")).to_equal(false)

    it "returns false for minus sign only":
        expect(is_numeric_text("-")).to_equal(false)

    it "returns true for single digit":
        expect(is_numeric_text("5")).to_equal(true)

    it "returns true for multi-digit number":
        expect(is_numeric_text("12345")).to_equal(true)

    it "returns true for negative number":
        expect(is_numeric_text("-42")).to_equal(true)

    it "returns false for alphabetic text":
        expect(is_numeric_text("abc")).to_equal(false)

    it "returns false for mixed text":
        expect(is_numeric_text("12a")).to_equal(false)

    it "returns true for zero":
        expect(is_numeric_text("0")).to_equal(true)

describe "detect_format":
    """
    ## Format Detection

    Tests all branches: empty, tagged (@), dict/list ({/[), quoted string,
    boolean keywords, numeric, and unknown fallback.
    """

    it "returns unknown for empty string":
        expect(detect_format("")).to_equal("unknown")

    it "detects tagged format":
        expect(detect_format("@MyType\{payload\}")).to_equal("tagged")

    it "detects sdn for dict starting with brace":
        expect(detect_format("{key: val}")).to_equal("sdn")

    it "detects sdn for list starting with bracket":
        expect(detect_format("[1, 2, 3]")).to_equal("sdn")

    it "detects sdn for quoted string":
        expect(detect_format("\"hello\"")).to_equal("sdn")

    it "detects sdn for true":
        expect(detect_format("true")).to_equal("sdn")

    it "detects sdn for false":
        expect(detect_format("false")).to_equal("sdn")

    it "detects sdn for nil":
        expect(detect_format("nil")).to_equal("sdn")

    it "detects sdn for numeric string":
        expect(detect_format("42")).to_equal("sdn")

    it "returns unknown for unrecognized format":
        expect(detect_format("random_text")).to_equal("unknown")

describe "is_valid_sdn":
    """
    ## SDN Validity Check

    Tests valid sdn, valid tagged, and invalid inputs.
    """

    it "returns true for valid sdn list":
        expect(is_valid_sdn("[1, 2]")).to_equal(true)

    it "returns true for tagged format":
        expect(is_valid_sdn("@Type\{payload\}")).to_equal(true)

    it "returns true for sdn boolean":
        expect(is_valid_sdn("true")).to_equal(true)

    it "returns false for invalid input":
        expect(is_valid_sdn("")).to_equal(false)

    it "returns false for unknown format":
        expect(is_valid_sdn("random_text")).to_equal(false)

# ============================================================================
# Test Group 12: Pretty Printing (utilities.spl)
# ============================================================================

describe "pretty_print_indent":
    """
    ## Indentation

    Tests zero and non-zero indent levels.
    """

    it "adds no indent at level 0":
        val result = pretty_print_indent("hello", 0)
        expect(result).to_equal("hello")

    it "adds two spaces per indent level":
        val result = pretty_print_indent("hello", 2)
        expect(result).to_start_with("    ")
        expect(result).to_end_with("hello")

    it "adds single level indent":
        val result = pretty_print_indent("x", 1)
        expect(result).to_equal("  x")

describe "pretty_list":
    """
    ## Pretty List Printing

    Tests empty list branch and non-empty with comma logic.
    """

    it "returns bracket pair for empty list":
        val result = pretty_list([], 0)
        expect(result).to_equal("[]")

    it "formats single item list":
        val result = pretty_list(["a"], 0)
        expect(result).to_start_with("[\n")
        expect(result).to_contain("a")

    it "formats multi-item list with commas":
        val result = pretty_list(["a", "b"], 0)
        expect(result).to_contain(",")

    it "does not add comma after last item":
        val result = pretty_list(["a"], 0)
        expect(result).to_contain("a\n")

describe "pretty_tuple":
    """
    ## Pretty Tuple Printing

    Tests empty tuple branch and non-empty.
    """

    it "returns parens for empty tuple":
        val result = pretty_tuple([], 0)
        expect(result).to_equal("()")

    it "formats single value tuple":
        val result = pretty_tuple(["x"], 0)
        expect(result).to_start_with("(\n")
        expect(result).to_contain("x")

    it "formats multi-value tuple with commas":
        val result = pretty_tuple(["x", "y"], 0)
        expect(result).to_contain(",")

describe "pretty_dict":
    """
    ## Pretty Dict Printing

    Tests empty dict branch and non-empty.
    """

    it "returns braces for empty dict":
        val result = pretty_dict([], 0)
        expect(result).to_equal("{}")

    it "formats single entry dict":
        val result = pretty_dict([("k", "v")], 0)
        expect(result).to_start_with("{\n")
        expect(result).to_contain("k: v")

    it "formats multi-entry dict with commas":
        val result = pretty_dict([("a", "1"), ("b", "2")], 0)
        expect(result).to_contain(",")

