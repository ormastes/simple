# Tests for common.window_protocol.input_translator
# Covers: key_char_to_wm_key_event — nil key, lowercase, uppercase, window_id passthrough

use common.window_protocol.input_translator.{key_char_to_wm_key_event}
use common.window_protocol.window_protocol.{WM_EVENT_KEY_PRESS}

describe "key_char_to_wm_key_event":
    context "when key_char is nil":
        it "produces key_code 0 and WM_EVENT_KEY_PRESS with correct window_id":
            var evt = key_char_to_wm_key_event(42, nil)
            expect(evt.key_code).to_equal(0)
            expect(evt.event_type).to_equal(WM_EVENT_KEY_PRESS)
            expect(evt.window_id).to_equal(42)

    context "when key_char is a lowercase letter":
        it "maps 'a' to key_code 97 and passes window_id through":
            var evt = key_char_to_wm_key_event(7, "a")
            expect(evt.key_code).to_equal(97)
            expect(evt.window_id).to_equal(7)
            expect(evt.event_type).to_equal(WM_EVENT_KEY_PRESS)

    context "when key_char is an uppercase letter":
        it "maps 'A' to key_code 65":
            var evt = key_char_to_wm_key_event(0, "A")
            expect(evt.key_code).to_equal(65)
            expect(evt.event_type).to_equal(WM_EVENT_KEY_PRESS)
            expect(evt.window_id).to_equal(0)

    context "mouse_pos defaults":
        it "mouse_x and mouse_y are 0 for key events":
            var evt = key_char_to_wm_key_event(1, "z")
            expect(evt.mouse_x).to_equal(0)
            expect(evt.mouse_y).to_equal(0)
