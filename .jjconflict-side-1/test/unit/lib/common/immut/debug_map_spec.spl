# Debug dict helpers

fn dict_has_keys(d) -> bool:
    for k in d:
        return true
    false

describe "Debug dict helpers":
    it "empty dict has no keys":
        var d = {}
        expect(dict_has_keys(d)).to_equal(false)

    it "non-empty dict has keys":
        var d = {}
        d["a"] = 1
        expect(dict_has_keys(d)).to_equal(true)
