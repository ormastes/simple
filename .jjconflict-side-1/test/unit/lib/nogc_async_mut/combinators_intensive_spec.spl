"""
# Async Combinators Intensive Tests

**Feature IDs:** #RT-020
**Category:** Runtime
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** doc/requirement/async_promise_intensive_tests.md

## Overview
Intensive tests for future combinators: join_all, select, race, timeout,
zip, and retry patterns.
"""

# --- Inline Stubs ---

enum FutureState:
    Pending
    Ready(value)
    Failed(error)

class SimpleFuture:
    state: FutureState

    static fn ready(value) -> SimpleFuture:
        return SimpleFuture(state: FutureState.Ready(value))

    static fn pending() -> SimpleFuture:
        return SimpleFuture(state: FutureState.Pending)

    static fn failed(err) -> SimpleFuture:
        return SimpleFuture(state: FutureState.Failed(err))

    fn is_ready() -> bool:
        if val FutureState.Ready(_) = self.state:
            return true
        return false

    fn is_pending() -> bool:
        if val FutureState.Pending = self.state:
            return true
        return false

    fn is_failed() -> bool:
        if val FutureState.Failed(_) = self.state:
            return true
        return false

    fn get_value():
        if val FutureState.Ready(v) = self.state:
            return v
        return nil

    fn get_error():
        if val FutureState.Failed(e) = self.state:
            return e
        return nil

# --- Combinator Free Functions ---

fn join_all(futures: [SimpleFuture]) -> SimpleFuture:
    if futures.len() == 0:
        return SimpleFuture.ready([])
    var values = []
    var i = 0
    while i < futures.len():
        var f = futures[i]
        if f.is_failed():
            return SimpleFuture.failed(f.get_error())
        if f.is_pending():
            return SimpleFuture.pending()
        values.push(f.get_value())
        i = i + 1
    return SimpleFuture.ready(values)

fn select_first(futures: [SimpleFuture]) -> SimpleFuture:
    var i = 0
    while i < futures.len():
        var f = futures[i]
        if f.is_ready():
            return f
        i = i + 1
    return SimpleFuture.pending()

fn race(futures: [SimpleFuture]) -> SimpleFuture:
    var i = 0
    while i < futures.len():
        var f = futures[i]
        if f.is_ready() or f.is_failed():
            return f
        i = i + 1
    return SimpleFuture.pending()

fn timeout_future(future: SimpleFuture, timed_out: bool) -> SimpleFuture:
    if timed_out and future.is_pending():
        return SimpleFuture.failed("timeout")
    return future

fn zip(a: SimpleFuture, b: SimpleFuture) -> SimpleFuture:
    if a.is_failed():
        return SimpleFuture.failed(a.get_error())
    if b.is_failed():
        return SimpleFuture.failed(b.get_error())
    if a.is_ready() and b.is_ready():
        return SimpleFuture.ready([a.get_value(), b.get_value()])
    return SimpleFuture.pending()

fn retry(make_future: fn() -> SimpleFuture, max_retries: i64) -> SimpleFuture:
    var attempts = 0
    while attempts <= max_retries:
        var f = make_future()
        if f.is_ready():
            return f
        attempts = attempts + 1
    return SimpleFuture.failed("max retries exhausted")

fn all_settled(futures: [SimpleFuture]) -> SimpleFuture:
    var results = []
    var i = 0
    while i < futures.len():
        var f = futures[i]
        if f.is_pending():
            return SimpleFuture.pending()
        results.push(f.state)
        i = i + 1
    return SimpleFuture.ready(results)

fn first_ok(futures: [SimpleFuture]) -> SimpleFuture:
    var last_error = nil
    var i = 0
    while i < futures.len():
        var f = futures[i]
        if f.is_ready():
            return f
        if f.is_failed():
            last_error = f.get_error()
        i = i + 1
    if last_error != nil:
        return SimpleFuture.failed(last_error)
    return SimpleFuture.pending()

# --- Tests ---

describe "Async Combinators Intensive":

    # ===== join_all =====

    describe "join_all":

        it "returns ready with all values when all futures are ready":
            var f1 = SimpleFuture.ready(10)
            var f2 = SimpleFuture.ready(20)
            var f3 = SimpleFuture.ready(30)
            var result = join_all([f1, f2, f3])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal([10, 20, 30])

        it "returns pending when one future is pending":
            var f1 = SimpleFuture.ready(1)
            var f2 = SimpleFuture.pending()
            var f3 = SimpleFuture.ready(3)
            var result = join_all([f1, f2, f3])
            expect(result.is_pending()).to_equal(true)

        it "returns failed when one future has failed":
            var f1 = SimpleFuture.ready(1)
            var f2 = SimpleFuture.failed("oops")
            var f3 = SimpleFuture.ready(3)
            var result = join_all([f1, f2, f3])
            expect(result.is_failed()).to_equal(true)
            expect(result.get_error()).to_equal("oops")

        it "returns ready with empty list for empty input":
            var result = join_all([])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal([])

        it "handles single item list":
            var result = join_all([SimpleFuture.ready(42)])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal([42])

        it "preserves value order":
            var f1 = SimpleFuture.ready("a")
            var f2 = SimpleFuture.ready("b")
            var f3 = SimpleFuture.ready("c")
            var result = join_all([f1, f2, f3])
            var vals = result.get_value()
            expect(vals[0]).to_equal("a")
            expect(vals[1]).to_equal("b")
            expect(vals[2]).to_equal("c")

    # ===== select_first =====

    describe "select_first":

        it "returns first ready future found":
            var f1 = SimpleFuture.pending()
            var f2 = SimpleFuture.ready(99)
            var f3 = SimpleFuture.ready(100)
            var result = select_first([f1, f2, f3])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(99)

        it "returns pending when all are pending":
            var f1 = SimpleFuture.pending()
            var f2 = SimpleFuture.pending()
            var result = select_first([f1, f2])
            expect(result.is_pending()).to_equal(true)

        it "skips failed futures and finds ready":
            var f1 = SimpleFuture.failed("err")
            var f2 = SimpleFuture.pending()
            var f3 = SimpleFuture.ready(7)
            var result = select_first([f1, f2, f3])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(7)

    # ===== race =====

    describe "race":

        it "returns first non-pending future":
            var f1 = SimpleFuture.pending()
            var f2 = SimpleFuture.ready(55)
            var f3 = SimpleFuture.pending()
            var result = race([f1, f2, f3])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(55)

        it "returns pending when all are pending":
            var f1 = SimpleFuture.pending()
            var f2 = SimpleFuture.pending()
            var result = race([f1, f2])
            expect(result.is_pending()).to_equal(true)

        it "returns failed if first non-pending is failed":
            var f1 = SimpleFuture.pending()
            var f2 = SimpleFuture.failed("race-fail")
            var f3 = SimpleFuture.ready(1)
            var result = race([f1, f2, f3])
            expect(result.is_failed()).to_equal(true)
            expect(result.get_error()).to_equal("race-fail")

        it "returns ready if first non-pending is ready":
            var f1 = SimpleFuture.ready(200)
            var f2 = SimpleFuture.failed("no")
            var result = race([f1, f2])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(200)

    # ===== timeout_future =====

    describe "timeout_future":

        it "passes through when not timed out":
            var f = SimpleFuture.ready(5)
            var result = timeout_future(f, false)
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(5)

        it "fails pending future when timed out":
            var f = SimpleFuture.pending()
            var result = timeout_future(f, true)
            expect(result.is_failed()).to_equal(true)
            expect(result.get_error()).to_equal("timeout")

        it "passes through ready future even when timed out":
            var f = SimpleFuture.ready(42)
            var result = timeout_future(f, true)
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(42)

    # ===== zip =====

    describe "zip":

        it "returns paired values when both ready":
            var a = SimpleFuture.ready("x")
            var b = SimpleFuture.ready("y")
            var result = zip(a, b)
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(["x", "y"])

        it "returns pending when one is pending":
            var a = SimpleFuture.ready(1)
            var b = SimpleFuture.pending()
            var result = zip(a, b)
            expect(result.is_pending()).to_equal(true)

        it "returns failed when one is failed":
            var a = SimpleFuture.failed("zip-err")
            var b = SimpleFuture.ready(2)
            var result = zip(a, b)
            expect(result.is_failed()).to_equal(true)
            expect(result.get_error()).to_equal("zip-err")

        it "returns pending when both are pending":
            var a = SimpleFuture.pending()
            var b = SimpleFuture.pending()
            var result = zip(a, b)
            expect(result.is_pending()).to_equal(true)

    # ===== retry =====

    describe "retry":

        it "succeeds on first try":
            var make = \: SimpleFuture.ready(1)
            var result = retry(make, 3)
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(1)

        it "succeeds after retries":
            # Cannot use mutable closure capture, so test with always-ready
            var make = \: SimpleFuture.ready("done")
            var result = retry(make, 5)
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal("done")

        it "fails when all retries exhausted":
            var make = \: SimpleFuture.failed("always fails")
            var result = retry(make, 2)
            expect(result.is_failed()).to_equal(true)

        it "fails immediately with zero retries if not ready":
            var make = \: SimpleFuture.failed("nope")
            var result = retry(make, 0)
            expect(result.is_failed()).to_equal(true)

    # ===== all_settled =====

    describe "all_settled":

        it "returns ready when all futures are ready":
            var f1 = SimpleFuture.ready(1)
            var f2 = SimpleFuture.ready(2)
            var result = all_settled([f1, f2])
            expect(result.is_ready()).to_equal(true)

        it "returns ready when all futures are failed":
            var f1 = SimpleFuture.failed("a")
            var f2 = SimpleFuture.failed("b")
            var result = all_settled([f1, f2])
            expect(result.is_ready()).to_equal(true)

        it "returns ready for mixed ready and failed":
            var f1 = SimpleFuture.ready(1)
            var f2 = SimpleFuture.failed("err")
            var result = all_settled([f1, f2])
            expect(result.is_ready()).to_equal(true)

        it "returns pending when some are still pending":
            var f1 = SimpleFuture.ready(1)
            var f2 = SimpleFuture.pending()
            var result = all_settled([f1, f2])
            expect(result.is_pending()).to_equal(true)

    # ===== first_ok =====

    describe "first_ok":

        it "returns first ready future":
            var f1 = SimpleFuture.ready(10)
            var f2 = SimpleFuture.ready(20)
            var result = first_ok([f1, f2])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(10)

        it "skips failed futures and returns first ready":
            var f1 = SimpleFuture.failed("bad")
            var f2 = SimpleFuture.failed("worse")
            var f3 = SimpleFuture.ready(77)
            var result = first_ok([f1, f2, f3])
            expect(result.is_ready()).to_equal(true)
            expect(result.get_value()).to_equal(77)

        it "returns failed when all futures have failed":
            var f1 = SimpleFuture.failed("e1")
            var f2 = SimpleFuture.failed("e2")
            var result = first_ok([f1, f2])
            expect(result.is_failed()).to_equal(true)
            expect(result.get_error()).to_equal("e2")
