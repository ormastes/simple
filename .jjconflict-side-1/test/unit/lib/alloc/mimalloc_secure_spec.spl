# ## Overview
#
# BDD specs for the secure-mode and aligned-metadata extensions to the
# pure-Simple mimalloc port (M3 milestone).
#
# Covers:
#   - MiAbandonedList push/collect lifecycle
#   - MiAllocMeta alignment computation and verification
#   - mi_malloc_secure (zeroed on alloc) and mi_free_secure (zeroed on free)
#   - mi_collect force/non-force drain semantics
#
# In interpreter mode the runner only verifies file loading (imports + syntax).
# In compiled mode each `it` body executes for real.

use std.nogc_sync_mut.mimalloc.{
    MiSegment,
    MiHeap,
    MiPage,
    mimalloc_init,
    mi_malloc,
    mi_collect,
    mi_heap_collect,
    mi_heap_new,
}
use std.nogc_sync_mut.mimalloc_secure.{
    MiAbandonedSegment,
    MiAbandonedList,
    MiAllocMeta,
    abandoned_list_new,
    abandoned_push,
    abandoned_collect,
    abandoned_count,
    alloc_meta_new,
    alloc_meta_verify,
    mi_malloc_secure,
    mi_free_secure,
    mi_malloc_raw_aligned,
}

# ============================================================================
# Test Group 1: MiAbandonedList
# ============================================================================

describe "MiAbandonedList":
    """
    ## MiAbandonedList — cross-thread abandoned segment queue

    Validates that abandoned segments can be pushed, counted, and drained
    atomically via abandoned_collect.
    """

    it "abandoned_list_new creates empty list with count 0":
        val list = abandoned_list_new()
        expect(abandoned_count(list)).to_equal(0)

    it "abandoned_push increases count by one":
        val seg = MiSegment(slice_count: 0, thread_id: 1, pages: [])
        val abandoned = MiAbandonedSegment(segment: seg, remaining_pages: 0)
        val list = abandoned_list_new()
        val list2 = abandoned_push(list, abandoned)
        expect(abandoned_count(list2)).to_equal(1)

    it "abandoned_push twice gives count 2":
        val seg = MiSegment(slice_count: 0, thread_id: 1, pages: [])
        val a = MiAbandonedSegment(segment: seg, remaining_pages: 0)
        val list = abandoned_push(abandoned_push(abandoned_list_new(), a), a)
        expect(abandoned_count(list)).to_equal(2)

    it "abandoned_collect drains all segments and leaves list empty":
        val seg = MiSegment(slice_count: 1, thread_id: 2, pages: [])
        val a = MiAbandonedSegment(segment: seg, remaining_pages: 3)
        val list = abandoned_push(abandoned_push(abandoned_list_new(), a), a)
        val result = abandoned_collect(list)
        val empty_list = result[0]
        val drained = result[1]
        expect(abandoned_count(empty_list)).to_equal(0)
        expect(drained.len() as i64).to_equal(2)

    it "abandoned_collect on empty list returns empty drained array":
        val list = abandoned_list_new()
        val result = abandoned_collect(list)
        val empty_list = result[0]
        val drained = result[1]
        expect(abandoned_count(empty_list)).to_equal(0)
        expect(drained.len() as i64).to_equal(0)

# ============================================================================
# Test Group 2: MiAllocMeta — alignment metadata
# ============================================================================

describe "MiAllocMeta":
    """
    ## MiAllocMeta — allocation alignment metadata

    Validates alloc_meta_new computes is_aligned correctly and alloc_meta_verify
    rejects zero-size and misaligned records.
    """

    it "alloc_meta_new computes is_aligned true for aligned address":
        # address 64 aligned to 8: 64 % 8 == 0
        val meta = alloc_meta_new(64, 32, 8)
        expect(meta.is_aligned).to_equal(true)

    it "alloc_meta_new computes is_aligned false for misaligned address":
        # address 65 aligned to 8: 65 % 8 != 0
        val meta = alloc_meta_new(65, 32, 8)
        expect(meta.is_aligned).to_equal(false)

    it "alloc_meta_new with alignment 1 is always aligned":
        val meta = alloc_meta_new(13, 16, 1)
        expect(meta.is_aligned).to_equal(true)

    it "alloc_meta_new with alignment 0 is always aligned":
        val meta = alloc_meta_new(7, 16, 0)
        expect(meta.is_aligned).to_equal(true)

    it "alloc_meta_verify returns true for valid aligned meta":
        val meta = alloc_meta_new(64, 32, 8)
        expect(alloc_meta_verify(meta)).to_equal(true)

    it "alloc_meta_verify returns false for zero size":
        val meta = alloc_meta_new(64, 0, 8)
        expect(alloc_meta_verify(meta)).to_equal(false)

    it "alloc_meta_verify returns false for misaligned meta":
        val meta = alloc_meta_new(65, 32, 8)
        expect(alloc_meta_verify(meta)).to_equal(false)

# ============================================================================
# Test Group 3: Secure alloc/free
# ============================================================================

describe "secure alloc and free":
    """
    ## mi_malloc_secure / mi_free_secure

    Validates that mi_malloc_secure returns zeroed memory and that
    mi_free_secure zeroes the buffer before returning it to the pool.
    """

    it "mi_malloc_secure returns zeroed memory":
        val heap = mi_heap_new()
        mimalloc_init(heap)
        val ptr_opt = mi_malloc_secure(32)
        val ptr = ptr_opt.unwrap()
        var zero_count: i64 = 0
        for byte in ptr:
            if byte == 0u8:
                zero_count = zero_count + 1
        expect(zero_count).to_equal(ptr.len() as i64)

    it "mi_malloc_secure returns nil for size 0":
        val heap = mi_heap_new()
        mimalloc_init(heap)
        val ptr_opt = mi_malloc_secure(0)
        expect(ptr_opt.?).to_equal(false)

    it "mi_free_secure zeroes memory before freeing":
        val heap = mi_heap_new()
        mimalloc_init(heap)
        val ptr_opt = mi_malloc_secure(16)
        val ptr = ptr_opt.unwrap()
        # Write non-zero sentinel bytes
        ptr[0] = 0xAAu8
        ptr[1] = 0xBBu8
        # Free securely — this must zero all bytes first
        mi_free_secure(ptr, 16)
        # After zeroing, all bytes should be 0
        var zero_count: i64 = 0
        for byte in ptr:
            if byte == 0u8:
                zero_count = zero_count + 1
        expect(zero_count).to_equal(ptr.len() as i64)

# ============================================================================
# Test Group 4: mi_collect drain semantics
# ============================================================================

describe "mi_collect":
    """
    ## mi_collect — delayed free drain

    Validates that mi_collect(true) drains any pending delayed free entries
    without crashing, and that mi_collect(false) is safe to call at any time.
    """

    it "mi_collect(false) is safe to call on empty delayed list":
        val heap = mi_heap_new()
        mimalloc_init(heap)
        mi_collect(false)
        expect(true).to_equal(true)

    it "mi_collect(true) drains delayed free list without crash":
        val heap = mi_heap_new()
        mimalloc_init(heap)
        # Allocate to populate accounting, then force collect
        val ptr_opt = mi_malloc(32)
        expect(ptr_opt.?).to_equal(true)
        mi_collect(true)
        expect(true).to_equal(true)

    it "mi_collect(true) called repeatedly is safe":
        val heap = mi_heap_new()
        mimalloc_init(heap)
        mi_collect(true)
        mi_collect(true)
        mi_collect(true)
        expect(true).to_equal(true)

    it "mi_heap_collect delegates to mi_collect safely":
        val heap = mi_heap_new()
        mimalloc_init(heap)
        mi_heap_collect(heap, true)
        mi_heap_collect(heap, false)
        expect(true).to_equal(true)
