# @cover src/lib/nogc_sync_mut/mimalloc_tls.spl
# # Mimalloc TLS (Thread-Local Heap) Specification
#
# **Feature IDs:** #alloc-002
# **Category:** Infrastructure | Stdlib
# **Difficulty:** 3/5
# **Status:** Draft
# **Requirements:** N/A
# **Plan:** N/A
# **Design:** N/A
# **Research:** N/A
# **Artifacts:** N/A
#
# ## Overview
#
# BDD specs for the thread-local heap layer in mimalloc_tls.spl.
# Covers MiThreadHeap initialisation, TLS lookup, heap independence,
# resource teardown, and mi_heap_new_thread isolation.
#
# ## Key Concepts
#
# | Concept              | Description                                          |
# |----------------------|------------------------------------------------------|
# | MiThreadHeap         | Per-thread heap record (heap + thread_id)            |
# | MiTlsRegistry        | Module-level registry of all thread heaps + handle   |
# | mimalloc_thread_init | Creates and registers a new per-thread heap          |
# | mimalloc_thread_heap | Returns the calling thread's heap via TLS lookup     |
# | mi_heap_new_thread   | Returns an independent heap (not the global one)     |

use std.nogc_sync_mut.mimalloc.{MiHeap, MiPage, MiBlock, mi_heap_new, mimalloc_init}
use std.nogc_sync_mut.mimalloc_tls.{
    MiThreadHeap,
    MiTlsRegistry,
    mimalloc_thread_init,
    mimalloc_thread_heap,
    mimalloc_thread_destroy,
    mi_heap_new_thread,
}
use std.spec.{describe, it, expect}

# ============================================================================
# Test Group 1: mi_heap_new_thread — independent heap creation
# ============================================================================

describe "mi_heap_new_thread":
    """
    ## mi_heap_new_thread — per-thread independent heap factory

    Verifies that each call returns a fresh MiHeap value with its own
    pages_by_class slots, independent from any global state.
    """

    it "returns a heap with non-empty pages_by_class slots":
        val heap = mi_heap_new_thread()
        # A fresh independent heap should have pre-allocated class slots
        expect(heap.pages_by_class.len()).to_be_greater_than(0)

    it "returned heap size_classes is empty (slots built internally)":
        val heap = mi_heap_new_thread()
        expect(heap.size_classes.len()).to_equal(0)

    it "two calls return independent heap values":
        val heap_a = mi_heap_new_thread()
        val heap_b = mi_heap_new_thread()
        # Both should have the same slot count (same table)
        expect(heap_a.pages_by_class.len()).to_equal(heap_b.pages_by_class.len())

# ============================================================================
# Test Group 2: mimalloc_thread_init — registration
# ============================================================================

describe "mimalloc_thread_init":
    """
    ## mimalloc_thread_init — create and register a per-thread heap

    Verifies that init returns a valid MiThreadHeap with an assigned
    thread_id and a properly initialised heap.
    """

    it "returns a MiThreadHeap with a non-empty heap":
        val record = mimalloc_thread_init()
        expect(record.heap.pages_by_class.len()).to_be_greater_than(0)

    it "thread_id is a valid slot index (heap list is non-empty after init)":
        val record = mimalloc_thread_init()
        # usize is always >= 0; verify the heap was actually registered
        expect(record.heap.pages_by_class.len()).to_be_greater_than(0)

    it "successive inits return different thread_ids":
        val r1 = mimalloc_thread_init()
        val r2 = mimalloc_thread_init()
        expect(r1.thread_id == r2.thread_id).to_equal(false)

# ============================================================================
# Test Group 3: mimalloc_thread_heap — TLS lookup
# ============================================================================

describe "mimalloc_thread_heap":
    """
    ## mimalloc_thread_heap — retrieve the calling thread's heap

    Verifies that after init the heap is retrievable and matches the
    record returned by mimalloc_thread_init.
    """

    it "returns a heap after thread_init":
        val _record = mimalloc_thread_init()
        val heap = mimalloc_thread_heap()
        # Should return a heap with at least as many slots as the TLS table
        expect(heap.pages_by_class.len()).to_be_greater_than(0)

    it "heap returned is not a zero-slot placeholder":
        val _record = mimalloc_thread_init()
        val heap = mimalloc_thread_heap()
        expect(heap.pages_by_class.len()).to_be_greater_than(0)

# ============================================================================
# Test Group 4: heap independence
# ============================================================================

describe "Thread heap independence":
    """
    ## Heap independence

    Verifies that separate MiHeap values returned by mi_heap_new_thread
    do not share pages_by_class state.
    """

    it "heaps start with all-empty page lists":
        val heap = mi_heap_new_thread()
        var all_empty = true
        for class_pages in heap.pages_by_class:
            if class_pages.len() != 0:
                all_empty = false
        expect(all_empty).to_equal(true)

    it "mi_heap_new_thread differs from a zero-page-slot heap":
        val independent = mi_heap_new_thread()
        val bare = MiHeap(size_classes: [], pages_by_class: [])
        # Independent heap has slots; bare struct has none
        expect(independent.pages_by_class.len()).to_be_greater_than(bare.pages_by_class.len())

# ============================================================================
# Test Group 5: mimalloc_thread_destroy — teardown
# ============================================================================

describe "mimalloc_thread_destroy":
    """
    ## mimalloc_thread_destroy — per-thread resource cleanup

    Verifies that destroy runs without error and that a subsequent
    mimalloc_thread_heap call returns a fallback (zero-slot) heap.
    """

    it "destroy completes without error":
        val _record = mimalloc_thread_init()
        mimalloc_thread_destroy()
        # If we reach here the call succeeded
        expect(true).to_equal(true)

    it "heap after destroy returns fallback with pre-built slots":
        val _record = mimalloc_thread_init()
        mimalloc_thread_destroy()
        val heap = mimalloc_thread_heap()
        # After destroy the TLS slot is reset to sentinel (-1); the lookup
        # falls back to mi_heap_new() which always returns a heap with slots.
        expect(heap.pages_by_class.len()).to_be_greater_than(0)
