# --- TC4: same key/IV as TC3, 60-byte PT (first 60 of TC3), 20-byte AAD ---
# Key:   feffe9928665731c6d6a8f9467308308
# Nonce: cafebabefacedbaddecaf888
# PT:    d9313225f88406e5a55909c5aff5269a
#        86a7a9531534f7da2e4c303d8a318a72
#        1c3c0c95956809532fcf0e2449a6b525
#        b16aedf5aa0de657ba637b391aafd2    (60 bytes — drop last 4 of TC3)
# AAD:   feedfacedeadbeeffeedfacedeadbeefabaddad2
# CT:    42831ec2217774244b7221b784d0d49c
#        e3aa212f2c02a4e035c17e2329aca12e
#        21d514b25466931c7d8f6a5aac84aa05
#        1ba30b396a0aac973d58e091           (60 bytes)
# Tag:   5bc94fbc3221a5db94fae95ae7121a47

fn _tc4_key() -> [u8]:
    [0xfeu8, 0xffu8, 0xe9u8, 0x92u8, 0x86u8, 0x65u8, 0x73u8, 0x1cu8,
     0x6du8, 0x6au8, 0x8fu8, 0x94u8, 0x67u8, 0x30u8, 0x83u8, 0x08u8]

fn _tc4_nonce() -> [u8]:
    [0xcau8, 0xfeu8, 0xbau8, 0xbeu8, 0xfau8, 0xceu8,
     0xdbu8, 0xadu8, 0xdeu8, 0xcau8, 0xf8u8, 0x88u8]

fn _tc4_plaintext() -> [u8]:
    [0xd9u8, 0x31u8, 0x32u8, 0x25u8, 0xf8u8, 0x84u8, 0x06u8, 0xe5u8,
     0xa5u8, 0x59u8, 0x09u8, 0xc5u8, 0xafu8, 0xf5u8, 0x26u8, 0x9au8,
     0x86u8, 0xa7u8, 0xa9u8, 0x53u8, 0x15u8, 0x34u8, 0xf7u8, 0xdau8,
     0x2eu8, 0x4cu8, 0x30u8, 0x3du8, 0x8au8, 0x31u8, 0x8au8, 0x72u8,
     0x1cu8, 0x3cu8, 0x0cu8, 0x95u8, 0x95u8, 0x68u8, 0x09u8, 0x53u8,
     0x2fu8, 0xcfu8, 0x0eu8, 0x24u8, 0x49u8, 0xa6u8, 0xb5u8, 0x25u8,
     0xb1u8, 0x6au8, 0xedu8, 0xf5u8, 0xaau8, 0x0du8, 0xe6u8, 0x57u8,
     0xbau8, 0x63u8, 0x7bu8, 0x39u8]

fn _tc4_aad() -> [u8]:
    [0xfeu8, 0xedu8, 0xfau8, 0xceu8, 0xdeu8, 0xadu8, 0xbeu8, 0xefu8,
     0xfeu8, 0xedu8, 0xfau8, 0xceu8, 0xdeu8, 0xadu8, 0xbeu8, 0xefu8,
     0xabu8, 0xadu8, 0xdau8, 0xd2u8]

fn _tc4_expected_ct() -> [u8]:
    [0x42u8, 0x83u8, 0x1eu8, 0xc2u8, 0x21u8, 0x77u8, 0x74u8, 0x24u8,
     0x4bu8, 0x72u8, 0x21u8, 0xb7u8, 0x84u8, 0xd0u8, 0xd4u8, 0x9cu8,
     0xe3u8, 0xaau8, 0x21u8, 0x2fu8, 0x2cu8, 0x02u8, 0xa4u8, 0xe0u8,
     0x35u8, 0xc1u8, 0x7eu8, 0x23u8, 0x29u8, 0xacu8, 0xa1u8, 0x2eu8,
