# AES-128-GCM NIST SP 800-38D Appendix B Test Vectors
#
# Tests aes128_gcm_encrypt / aes128_gcm_decrypt against the four mandatory
# test cases from NIST SP 800-38D Appendix B (TC1–TC4).
#
# TC1: all-zero 16-byte key, all-zero 12-byte IV, empty PT, empty AAD
# TC2: all-zero 16-byte key, all-zero 12-byte IV, 16-byte zero PT, empty AAD
# TC3: non-trivial key/IV, 64-byte PT, empty AAD
# TC4: same key/IV as TC3, 60-byte PT, 20-byte AAD
#
# Source: NIST SP 800-38D (Nov 2007), Appendix B

use os.crypto.aes128_gcm.{aes128_gcm_encrypt, aes128_gcm_decrypt, Aes128GcmResult}

# ============================================================================
# Vector helpers — built at module level to avoid it-block var-mutation footgun
# (see memory: feedback_it_block_var_mutation.md)
# ============================================================================

# --- TC1: all-zero key, all-zero IV, empty PT, empty AAD ---
# Key:   00000000000000000000000000000000
# Nonce: 000000000000000000000000
# PT:    (empty)
# AAD:   (empty)
# CT:    (empty)
# Tag:   58e2fccefa7e3061367f1d57a4e7455a

fn _tc1_key() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn _tc1_nonce() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn _tc1_expected_tag() -> [u8]:
    [0x58u8, 0xe2u8, 0xfcu8, 0xceu8, 0xfau8, 0x7eu8, 0x30u8, 0x61u8,
     0x36u8, 0x7fu8, 0x1du8, 0x57u8, 0xa4u8, 0xe7u8, 0x45u8, 0x5au8]

# --- TC2: all-zero key, all-zero IV, 16-byte zero PT, empty AAD ---
# Key:   00000000000000000000000000000000
# Nonce: 000000000000000000000000
# PT:    00000000000000000000000000000000
# AAD:   (empty)
# CT:    0388dace60b6a392f328c2b971b2fe78
# Tag:   ab6e47d42cec13bdf53a67b21257bddf

fn _tc2_key() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn _tc2_nonce() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn _tc2_plaintext() -> [u8]:
