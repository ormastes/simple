    #  statements in IETF sessions, as well as written and electronic
    #  communications made at any time or place, which are addressed to"
    # 375 bytes (ASCII) — from RFC 8439 §A.3 Test Vector #2
    # offsets 000-063: "Any submission to the IETF intended by the Contr"
    [0x41u8, 0x6eu8, 0x79u8, 0x20u8, 0x73u8, 0x75u8, 0x62u8, 0x6du8,
     0x69u8, 0x73u8, 0x73u8, 0x69u8, 0x6fu8, 0x6eu8, 0x20u8, 0x74u8,
     0x6fu8, 0x20u8, 0x74u8, 0x68u8, 0x65u8, 0x20u8, 0x49u8, 0x45u8,
     0x54u8, 0x46u8, 0x20u8, 0x69u8, 0x6eu8, 0x74u8, 0x65u8, 0x6eu8,
     0x64u8, 0x65u8, 0x64u8, 0x20u8, 0x62u8, 0x79u8, 0x20u8, 0x74u8,
     0x68u8, 0x65u8, 0x20u8, 0x43u8, 0x6fu8, 0x6eu8, 0x74u8, 0x72u8,
     # offsets 048-111: "ibutor for publi cation as all or  part of an IETF  Internet-Draft "
     0x69u8, 0x62u8, 0x75u8, 0x74u8, 0x6fu8, 0x72u8, 0x20u8, 0x66u8,
     0x6fu8, 0x72u8, 0x20u8, 0x70u8, 0x75u8, 0x62u8, 0x6cu8, 0x69u8,
     0x63u8, 0x61u8, 0x74u8, 0x69u8, 0x6fu8, 0x6eu8, 0x20u8, 0x61u8,
     0x73u8, 0x20u8, 0x61u8, 0x6cu8, 0x6cu8, 0x20u8, 0x6fu8, 0x72u8,
     0x20u8, 0x70u8, 0x61u8, 0x72u8, 0x74u8, 0x20u8, 0x6fu8, 0x66u8,
     0x20u8, 0x61u8, 0x6eu8, 0x20u8, 0x49u8, 0x45u8, 0x54u8, 0x46u8,
     0x20u8, 0x49u8, 0x6eu8, 0x74u8, 0x65u8, 0x72u8, 0x6eu8, 0x65u8,
     0x74u8, 0x2du8, 0x44u8, 0x72u8, 0x61u8, 0x66u8, 0x74u8, 0x20u8,
     # offsets 112-175: "or RFC and any s tatement made wi thin the context  of an IETF acti"
     0x6fu8, 0x72u8, 0x20u8, 0x52u8, 0x46u8, 0x43u8, 0x20u8, 0x61u8,
     0x6eu8, 0x64u8, 0x20u8, 0x61u8, 0x6eu8, 0x79u8, 0x20u8, 0x73u8,
