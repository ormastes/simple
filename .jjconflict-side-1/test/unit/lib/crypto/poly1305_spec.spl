# ============================================================================
# Specs
# ============================================================================

describe "Poly1305 RFC 8439 §2.5.2 — canonical test vector":

    it "MAC of 'Cryptographic Forum Research Group' matches RFC 8439 §2.5.2":
        val tag = poly1305_mac(_key_252(), _msg_252())
        expect(_bytes_eq(tag, _expected_tag_252())).to_equal(true)

    it "tag is exactly 16 bytes":
        val tag = poly1305_mac(_key_252(), _msg_252())
        expect(tag.len()).to_equal(16u64)

describe "Poly1305 RFC 8439 §2.6.2 — key generation via ChaCha20":

    it "poly1305_key_gen produces the RFC 8439 §2.6.2 expected one-time key":
        val otk = poly1305_key_gen(_key_gen_key(), _key_gen_nonce())
        expect(_bytes_eq(otk, _key_gen_expected_otk())).to_equal(true)

    it "poly1305_key_gen always returns exactly 32 bytes":
        val otk = poly1305_key_gen(_key_gen_key(), _key_gen_nonce())
        expect(otk.len()).to_equal(32u64)

describe "Poly1305 RFC 8439 §A.3 — additional test vectors":

    it "Test #1: zero key + 64-byte zero message → zero tag":
        val tag = poly1305_mac(_key_a3_1(), _msg_a3_1())
        expect(_bytes_eq(tag, _expected_tag_a3_1())).to_equal(true)

    it "Test #2: r=0, s=36e5..., tag equals s regardless of message":
        val tag = poly1305_mac(_key_a3_2(), _msg_a3_2())
        expect(_bytes_eq(tag, _expected_tag_a3_2())).to_equal(true)

    it "Test #4: Jabberwocky 127 bytes (partial last block) → 4541669a...":
        val tag = poly1305_mac(_key_a3_4(), _msg_a3_4())
        expect(_bytes_eq(tag, _expected_tag_a3_4())).to_equal(true)

describe "Poly1305 edge cases":

    it "zero-length message → tag is 16 bytes":
        val empty: [u8] = []
        val tag = poly1305_mac(_key_252(), empty)
        expect(tag.len()).to_equal(16u64)

    it "zero-length message with zero key → zero tag":
        val empty: [u8] = []
        val tag = poly1305_mac(_key_a3_1(), empty)
        expect(_bytes_eq(tag, _expected_tag_a3_1())).to_equal(true)
