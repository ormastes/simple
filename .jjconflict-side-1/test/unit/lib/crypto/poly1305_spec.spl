     0x45u8, 0x54u8, 0x46u8, 0x20u8, 0x43u8, 0x6fu8, 0x6eu8, 0x74u8,
     0x72u8, 0x69u8, 0x62u8, 0x75u8, 0x74u8, 0x69u8, 0x6fu8, 0x6eu8,
     0x22u8, 0x2eu8, 0x20u8, 0x53u8, 0x75u8, 0x63u8, 0x68u8, 0x20u8,
     0x73u8, 0x74u8, 0x61u8, 0x74u8, 0x65u8, 0x6du8, 0x65u8, 0x6eu8,
     0x74u8, 0x73u8, 0x20u8, 0x69u8, 0x6eu8, 0x63u8, 0x6cu8, 0x75u8,
     # offsets 240-303: "de oral statemen ts in IETF sessi ons, as well as  written and elec"
     0x64u8, 0x65u8, 0x20u8, 0x6fu8, 0x72u8, 0x61u8, 0x6cu8, 0x20u8,
     0x73u8, 0x74u8, 0x61u8, 0x74u8, 0x65u8, 0x6du8, 0x65u8, 0x6eu8,
