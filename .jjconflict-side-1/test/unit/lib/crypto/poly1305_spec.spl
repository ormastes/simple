     0x20u8, 0x6fu8, 0x66u8, 0x20u8, 0x61u8, 0x6eu8, 0x20u8, 0x49u8,
     0x45u8, 0x54u8, 0x46u8, 0x20u8, 0x61u8, 0x63u8, 0x74u8, 0x69u8,
     # offsets 176-239: "vity is consider ed an "IETF Cont ribution". Such  statements inclu"
     0x76u8, 0x69u8, 0x74u8, 0x79u8, 0x20u8, 0x69u8, 0x73u8, 0x20u8,
     0x63u8, 0x6fu8, 0x6eu8, 0x73u8, 0x69u8, 0x64u8, 0x65u8, 0x72u8,
