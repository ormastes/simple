# Poly1305 RFC 8439 known-answer tests — std.crypto.poly1305
#
# Tests cover:
#   §2.5.2  Canonical MAC test vector: "Cryptographic Forum Research Group"
#   §2.6.2  Poly1305 key generation via ChaCha20 (counter=0)
#   A.3 #1  Zero key + zero message → zero tag
#   A.3 #2  Non-zero key, message with 0x01-padded block boundary
#   A.3 #4  Carroll "Jabberwocky" quote, 127 bytes
#   Tag length invariant (always 16 bytes)
#   Key-gen output length (always 32 bytes)
#   Zero-length message
#
# Execution note: it-block bodies are verified in compiled mode.  Structure and
# imports are validated by the interpreter on every test run.
#
# All RFC vectors must match byte-exact — no "close enough".

use std.spipe.*
use std.crypto.poly1305.{poly1305_mac, poly1305_key_gen}

# ============================================================================
# Helpers
# ============================================================================

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    """Return true iff two byte arrays are identical."""
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1u64
    true

# ============================================================================
# RFC 8439 §2.5.2 — Canonical test vector
#
# key (r): 85 d6 be 78 57 55 6d 33 7f 44 52 fe 42 d5 06 a8
# key (s): 01 03 80 8a fb 0d b2 fd 4a bf f6 af 41 49 f5 1b
# msg:     "Cryptographic Forum Research Group" (34 bytes)
# tag:     a8 06 1d c1 30 51 36 c6 c2 2b 8b af 0c 01 27 a9
# ============================================================================

fn _key_252() -> [u8]:
    [0x85u8, 0xd6u8, 0xbeu8, 0x78u8, 0x57u8, 0x55u8, 0x6du8, 0x33u8,
     0x7fu8, 0x44u8, 0x52u8, 0xfeu8, 0x42u8, 0xd5u8, 0x06u8, 0xa8u8,
     0x01u8, 0x03u8, 0x80u8, 0x8au8, 0xfbu8, 0x0du8, 0xb2u8, 0xfdu8,
     0x4au8, 0xbfu8, 0xf6u8, 0xafu8, 0x41u8, 0x49u8, 0xf5u8, 0x1bu8]

fn _msg_252() -> [u8]:
    # "Cryptographic Forum Research Group" — 34 bytes ASCII
    [0x43u8, 0x72u8, 0x79u8, 0x70u8, 0x74u8, 0x6fu8, 0x67u8, 0x72u8,
     0x61u8, 0x70u8, 0x68u8, 0x69u8, 0x63u8, 0x20u8, 0x46u8, 0x6fu8,
     0x72u8, 0x75u8, 0x6du8, 0x20u8, 0x52u8, 0x65u8, 0x73u8, 0x65u8,
     0x61u8, 0x72u8, 0x63u8, 0x68u8, 0x20u8, 0x47u8, 0x72u8, 0x6fu8,
     0x75u8, 0x70u8]

fn _expected_tag_252() -> [u8]:
    [0xa8u8, 0x06u8, 0x1du8, 0xc1u8, 0x30u8, 0x51u8, 0x36u8, 0xc6u8,
     0xc2u8, 0x2bu8, 0x8bu8, 0xafu8, 0x0cu8, 0x01u8, 0x27u8, 0xa9u8]

# ============================================================================
# RFC 8439 §2.6.2 — Poly1305 key generation test vector
#
# ChaCha20 key: 80 81 82 83 84 85 86 87 88 89 8a 8b 8c 8d 8e 8f
#               90 91 92 93 94 95 96 97 98 99 9a 9b 9c 9d 9e 9f
# Nonce:        00 00 00 00 00 01 02 03 04 05 06 07
# Expected OTK: 8a d5 a0 8b 90 5f 81 cc 81 50 40 27 4a b2 96 36
#               50 83 2d cd 26 98 e9 7a 29 35 1f 44 4b 77 73 5e
# ============================================================================

fn _key_gen_key() -> [u8]:
    [0x80u8, 0x81u8, 0x82u8, 0x83u8, 0x84u8, 0x85u8, 0x86u8, 0x87u8,
     0x88u8, 0x89u8, 0x8au8, 0x8bu8, 0x8cu8, 0x8du8, 0x8eu8, 0x8fu8,
     0x90u8, 0x91u8, 0x92u8, 0x93u8, 0x94u8, 0x95u8, 0x96u8, 0x97u8,
     0x98u8, 0x99u8, 0x9au8, 0x9bu8, 0x9cu8, 0x9du8, 0x9eu8, 0x9fu8]

fn _key_gen_nonce() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x01u8, 0x02u8, 0x03u8,
     0x04u8, 0x05u8, 0x06u8, 0x07u8]

fn _key_gen_expected_otk() -> [u8]:
    # RFC 8439 §2.6.2 exact output bytes (from ChaCha20 state after 20 rounds,
    # first 32 bytes serialized little-endian):
    # 8ba0d58a cc815f90 27405081 7194b24a  → 8a d5 a0 8b 90 5f 81 cc 81 50 40 27 4a b2 94 71
    # 37b633a8 a50dfde3 e2b8db08 46a6d1fd  → a8 33 b6 37 e3 fd 0d a5 08 db b8 e2 fd d1 a6 46
    [0x8au8, 0xd5u8, 0xa0u8, 0x8bu8, 0x90u8, 0x5fu8, 0x81u8, 0xccu8,
     0x81u8, 0x50u8, 0x40u8, 0x27u8, 0x4au8, 0xb2u8, 0x94u8, 0x71u8,
     0xa8u8, 0x33u8, 0xb6u8, 0x37u8, 0xe3u8, 0xfdu8, 0x0du8, 0xa5u8,
     0x08u8, 0xdbu8, 0xb8u8, 0xe2u8, 0xfdu8, 0xd1u8, 0xa6u8, 0x46u8]

# ============================================================================
# RFC 8439 §A.3 Test #1 — zero key + zero message → zero tag
#
# key:  32 × 0x00
# msg:  64 × 0x00
# tag:  16 × 0x00
# ============================================================================

fn _key_a3_1() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn _msg_a3_1() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn _expected_tag_a3_1() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

# ============================================================================
# RFC 8439 §A.3 Test #2
#
# r = 0 (first 16 bytes), s = 36 e5 f6 b5 ... (last 16 bytes).
# When r=0, h*r=0 after every block, so accumulator stays 0.
# Final tag = (0 + s) mod 2^128 = s.
# The message content does not affect the tag for this weak-key case.
#
# key:  00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00  ← r (clamped to 0)
#       36 e5 f6 b5 c5 e0 60 70 f0 ef ca 96 22 7a 86 3e  ← s
# msg:  "Any submission to the IETF intended by the Contributor for
#        publication as all or part of an IETF Internet-Draft or RFC
#        and any statement made within the context of an IETF activity
#        is considered an "IETF Contribution". Such statements include
#        oral statements in IETF sessions, as well as written and
#        electronic communications made at any time or place, which
#        are addressed to"  (375 bytes per RFC 8439 §A.3 TV#2)
# tag:  36 e5 f6 b5 c5 e0 60 70 f0 ef ca 96 22 7a 86 3e  (= s, since r=0)
# ============================================================================

fn _key_a3_2() -> [u8]:
    # r = 00...00 (first 16 bytes), s = 36 e5 f6 b5 ... (last 16 bytes)
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x36u8, 0xe5u8, 0xf6u8, 0xb5u8, 0xc5u8, 0xe0u8, 0x60u8, 0x70u8,
     0xf0u8, 0xefu8, 0xcau8, 0x96u8, 0x22u8, 0x7au8, 0x86u8, 0x3eu8]

