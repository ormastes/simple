# # FFI Basics Unit Tests
#
# **Feature ID:** #LIB-FFI-001
# **Category:** Lib | FFI
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "FFI Type Mapping":
    it "i64 maps to int64_t":
        val type_name = "int64_t"
        check(type_name == "int64_t")

    it "f64 maps to double":
        val type_name = "double"
        check(type_name == "double")

    it "bool maps to bool":
        val type_name = "bool"
        check(type_name == "bool")

    it "text maps to char*":
        val type_name = "char*"
        check(type_name == "char*")

    it "void maps to void":
        val type_name = "void"
        check(type_name == "void")

describe "FFI Calling Convention":
    it "c calling convention":
        val conv = "c"
        check(conv == "c")

    it "stdcall convention":
        val conv = "stdcall"
        check(conv == "stdcall")

    it "fastcall convention":
        val conv = "fastcall"
        check(conv == "fastcall")

describe "FFI Safety":
    it "extern functions are unsafe":
        val is_unsafe = true
        check(is_unsafe)

    it "null pointer check":
        val ptr = nil
        check(ptr.?() == false)

    it "buffer size validation":
        val buffer_size = 1024
        check(buffer_size > 0)

    it "string encoding is UTF-8":
        val encoding = "utf-8"
        check(encoding == "utf-8")

describe "FFI Data Layout":
    it "struct alignment":
        val alignment = 8
        check(alignment == 8 or alignment == 4)

    it "field offset calculation":
        val offset = 0
        check(offset >= 0)

    it "struct padding":
        val has_padding = true
        check(true)

    it "packed struct":
        val packed = true
        check(packed)

describe "Runtime FFI Functions":
    it "rt_file_read_text signature":
        val name = "rt_file_read_text"
        check(name.starts_with("rt_"))

    it "rt_file_write_text signature":
        val name = "rt_file_write_text"
        check(name.starts_with("rt_"))

    it "rt_time_now_ms signature":
        val name = "rt_time_now_ms"
        check(name.starts_with("rt_"))

    it "rt_env_get signature":
        val name = "rt_env_get"
        check(name.starts_with("rt_"))
