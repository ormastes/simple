# Specification for src/lib/nogc_sync_mut/http/accept_encoding.spl
#
# Covers RFC 7231 §5.3.4 Accept-Encoding parsing and codec negotiation.

use std.spipe.*
use std.nogc_sync_mut.http.accept_encoding.{
    AcceptEncodingEntry,
    parse_accept_encoding,
    negotiate_encoding,
}

describe "Accept-Encoding parser":

    it "returns empty list for empty header":
        val entries = parse_accept_encoding("")
        expect entries.len() == 0

    it "returns empty list for whitespace-only header":
        val entries = parse_accept_encoding("   ")
        expect entries.len() == 0

    it "parses a single token with default q=1.0":
        val entries = parse_accept_encoding("gzip")
        expect entries.len() == 1
        expect entries[0].coding == "gzip"
        expect entries[0].q == 1000

    it "parses multiple tokens preserving order":
        val entries = parse_accept_encoding("gzip, deflate, br")
        expect entries.len() == 3
        expect entries[0].coding == "gzip"
        expect entries[1].coding == "deflate"
        expect entries[2].coding == "br"

    it "lowercases tokens":
        val entries = parse_accept_encoding("GZIP, BR, ZsTd")
        expect entries[0].coding == "gzip"
        expect entries[1].coding == "br"
        expect entries[2].coding == "zstd"

    it "parses q=0.5 to 500":
        val entries = parse_accept_encoding("gzip;q=0.5")
        expect entries.len() == 1
        expect entries[0].q == 500

    it "parses q=1.0 and q=0":
        val entries = parse_accept_encoding("gzip;q=1.0, br;q=0")
        expect entries[0].q == 1000
        expect entries[1].q == 0

    it "parses three-digit fractional q-values":
        val entries = parse_accept_encoding("br;q=0.123")
        expect entries[0].q == 123

    it "tolerates whitespace around tokens, commas, and equals":
        val entries = parse_accept_encoding("  gzip ;  q = 0.8 , br  ")
        expect entries.len() == 2
        expect entries[0].coding == "gzip"
        expect entries[0].q == 800
        expect entries[1].coding == "br"
        expect entries[1].q == 1000

    it "handles the wildcard token":
        val entries = parse_accept_encoding("*")
        expect entries.len() == 1
        expect entries[0].coding == "*"
        expect entries[0].q == 1000

    it "ignores empty list slots from trailing commas":
        val entries = parse_accept_encoding("gzip,, br")
        expect entries.len() == 2
        expect entries[0].coding == "gzip"
        expect entries[1].coding == "br"

    it "clamps malformed q-values to 0":
        val entries = parse_accept_encoding("gzip;q=oops")
        expect entries[0].q == 0

    it "clamps q>1 to 1000":
        val entries = parse_accept_encoding("gzip;q=2.5")
        expect entries[0].q == 1000

describe "Accept-Encoding negotiation":

    it "returns empty for empty header (caller decides identity vs default)":
        expect negotiate_encoding("", ["gzip", "br"]) == ""

    it "picks the only listed codec when supported":
        expect negotiate_encoding("gzip", ["gzip", "br"]) == "gzip"

    it "picks the highest-q codec":
        val out = negotiate_encoding("gzip;q=0.5, br;q=0.9", ["gzip", "br"])
        expect out == "br"

    it "ignores codecs the server does not support":
        val out = negotiate_encoding("xz, gzip;q=0.5", ["gzip", "br"])
        expect out == "gzip"

    it "rejects q=0 even if it is the only listed codec":
        expect negotiate_encoding("gzip;q=0", ["gzip"]) == ""

    it "honours wildcard q for un-listed codecs":
        # "*;q=0.7": all server codecs become q=0.7. First in supported wins.
        val out = negotiate_encoding("*;q=0.7", ["zstd", "gzip"])
        expect out == "zstd"

    it "explicit q beats wildcard q":
        val out = negotiate_encoding("*;q=0.5, gzip;q=0.9", ["zstd", "gzip"])
        expect out == "gzip"

    it "wildcard q=0 forbids un-listed codecs":
        # br is not in the explicit list and falls back to *;q=0; only gzip wins.
        val out = negotiate_encoding("gzip;q=0.8, *;q=0", ["br", "gzip"])
        expect out == "gzip"

    it "matches exact tokens (case-insensitive)":
        val out = negotiate_encoding("GZIP;q=0.9", ["gzip"])
        expect out == "gzip"