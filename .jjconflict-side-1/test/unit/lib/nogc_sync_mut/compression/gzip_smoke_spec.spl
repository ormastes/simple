# gzip_smoke_spec.spl — round-trip smoke tests for the gzip module.
#
# Levels 1-9 use fixed-Huffman DEFLATE blocks (RFC 1951 §3.2.6).
# Level 0 uses stored (uncompressed) blocks.
# Dynamic-Huffman blocks (BTYPE=10) are not yet supported; returns Err.
# See doc/08_tracking/bug/gzip_module_crc32_unresolved_2026-05-01.md § Resolution.

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.gzip.{gzip_compress, gzip_decompress}

fn _make_small_payload() -> [u8]:
    return [
        0x61u8, 0x62u8, 0x63u8, 0x64u8,
        0x65u8, 0x66u8, 0x67u8, 0x68u8,
        0x69u8, 0x6Au8, 0x6Bu8, 0x6Cu8,
        0x6Du8, 0x6Eu8, 0x6Fu8, 0x70u8
    ]

fn _make_200_byte_payload() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 200:
        out.push((i % 251).to_u8())
        i = i + 1
    out

fn _make_aaa256() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 256:
        out.push(0x41u8)
        i = i + 1
    out

fn _make_zeros_1000() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 1000:
        out.push(0x00u8)
        i = i + 1
    out

fn _make_alpha_text_1k() -> [u8]:
    # "abcdefghijklmnopqrstuvwxyz " x 40 = 1080 bytes
    var out: [u8] = []
    var rep = 0
    while rep < 40:
        var c: i64 = 97
        while c < 123:
            out.push(c.to_u8())
            c = c + 1
        out.push(0x20u8)
        rep = rep + 1
    out

fn _make_random_64() -> [u8]:
    return [
        0x7cu8, 0x3au8, 0xf1u8, 0x09u8, 0xb4u8, 0x62u8, 0xd8u8, 0x55u8,
        0x1eu8, 0x97u8, 0x40u8, 0xc3u8, 0x2bu8, 0x8eu8, 0x73u8, 0xaau8,
        0x05u8, 0xd6u8, 0x91u8, 0x4fu8, 0xe2u8, 0xb7u8, 0x38u8, 0x6cu8,
        0x20u8, 0xdcu8, 0x59u8, 0x84u8, 0x17u8, 0xf0u8, 0x43u8, 0xc8u8,
        0x9bu8, 0x26u8, 0x71u8, 0xe5u8, 0x0au8, 0xbcu8, 0x6fu8, 0x34u8,
        0xd1u8, 0x8au8, 0x57u8, 0x2eu8, 0x93u8, 0x48u8, 0xc5u8, 0x7bu8,
        0x16u8, 0xe8u8, 0x3du8, 0xa2u8, 0x5fu8, 0x0bu8, 0xd4u8, 0x69u8,
        0x82u8, 0x25u8, 0xfbu8, 0x50u8, 0xc7u8, 0x3eu8, 0x9au8, 0x61u8
    ]

describe("gzip round-trip"):
    it("round-trips an empty payload"):
        val empty: [u8] = []
        val compressed = gzip_compress(empty, 6)
        val decoded = gzip_decompress(compressed)
        expect(decoded == nil).to_equal(false)
        val out = decoded ?? []
        expect(out.len()).to_equal(0)

    it("round-trips a small 16-byte payload"):
        val payload = _make_small_payload()
        val compressed = gzip_compress(payload, 6)
        val decoded = gzip_decompress(compressed)
        expect(decoded == nil).to_equal(false)
        val out = decoded ?? []
        expect(out.len()).to_equal(16)
        var i = 0
        var all_match = true
        while i < 16:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect(all_match).to_equal(true)

    it("round-trips a 200-byte payload"):
        val payload = _make_200_byte_payload()
        val compressed = gzip_compress(payload, 6)
        val decoded = gzip_decompress(compressed)
        expect(decoded == nil).to_equal(false)
        val out = decoded ?? []
        expect(out.len()).to_equal(200)
        var i = 0
        var all_match = true
        while i < 200:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect(all_match).to_equal(true)

    it("compressed output is larger than empty input (header+footer overhead)"):
        val empty: [u8] = []
        val compressed = gzip_compress(empty, 0)
        # minimum gzip frame: 10-byte header + 5-byte stored block + 8-byte footer = 23 bytes
        expect(compressed.len() >= 18).to_equal(true)

    it("compressed output is larger than small input (overhead dominates)"):
        val payload = _make_small_payload()
        val compressed = gzip_compress(payload, 1)
        # gzip stored block adds ~18 bytes of overhead
        expect(compressed.len() > payload.len()).to_equal(true)

    # --- fixed-Huffman (levels 1-9) tests ---

    it("fixed-Huffman: 256xA compresses to <50% and round-trips"):
        val payload = _make_aaa256()
        val compressed = gzip_compress(payload, 6)
        # 256 bytes → should be well under 128 bytes
        expect(compressed.len() < 128).to_equal(true)
        val decoded = gzip_decompress(compressed)
        expect(decoded == nil).to_equal(false)
        val out = decoded ?? []
        expect(out.len()).to_equal(256)
        var i = 0
        var all_match = true
        while i < 256:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect(all_match).to_equal(true)

    it("fixed-Huffman: 1080-byte alpha text compresses to <80% and round-trips"):
        val payload = _make_alpha_text_1k()
        val compressed = gzip_compress(payload, 6)
        # compressed must be < 80% of original
        val limit = (payload.len() * 80) / 100
        expect(compressed.len() < limit).to_equal(true)
        val decoded = gzip_decompress(compressed)
        expect(decoded == nil).to_equal(false)
        val out = decoded ?? []
        expect(out.len()).to_equal(payload.len())
        var i = 0
        var all_match = true
        while i < payload.len():
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect(all_match).to_equal(true)

    it("fixed-Huffman: 64-byte random payload round-trips"):
        val payload = _make_random_64()
        val compressed = gzip_compress(payload, 6)
        val decoded = gzip_decompress(compressed)
        expect(decoded == nil).to_equal(false)
        val out = decoded ?? []
        expect(out.len()).to_equal(64)
        var i = 0
        var all_match = true
        while i < 64:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect(all_match).to_equal(true)

    it("fixed-Huffman: empty payload round-trips at level 6"):
        val empty: [u8] = []
        val compressed = gzip_compress(empty, 6)
        val decoded = gzip_decompress(compressed)
        expect(decoded == nil).to_equal(false)
        val out = decoded ?? []
        expect(out.len()).to_equal(0)

    it("fixed-Huffman: 1000 zeros compress aggressively and round-trip"):
        val payload = _make_zeros_1000()
        val compressed = gzip_compress(payload, 6)
        # 1000 zeros should compress to well under 100 bytes
        expect(compressed.len() < 100).to_equal(true)
        val decoded = gzip_decompress(compressed)
        expect(decoded == nil).to_equal(false)
        val out = decoded ?? []
        expect(out.len()).to_equal(1000)
        var i = 0
        var all_match = true
        while i < 1000:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect(all_match).to_equal(true)

    it("level 0 stored blocks produce output larger than input"):
        val payload = _make_aaa256()
        val compressed = gzip_compress(payload, 0)
        # stored block: 10 header + 5 block header + 256 data + 8 footer = 279 bytes
        expect(compressed.len() > payload.len()).to_equal(true)
