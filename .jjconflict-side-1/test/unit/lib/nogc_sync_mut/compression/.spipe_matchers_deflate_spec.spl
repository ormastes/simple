# deflate_spec.spl — round-trip tests for raw deflate (RFC 1951) entry point.
#
# Verifies that deflate_compress / deflate_decompress produce proper frameless
# deflate streams: no gzip magic 0x1F 0x8B at offset 0, and gzip data is not
# accepted transparently as a raw deflate stream.

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.deflate.{deflate_compress, deflate_decompress}
use std.nogc_sync_mut.compression.gzip.{gzip_compress}

# ---------------------------------------------------------------------------
# Module-scope payload builders (it-block var mutation may not persist in
# interpreter mode — all non-trivial payloads must come from module-scope fns)
# ---------------------------------------------------------------------------

fn _make_16_bytes() -> [u8]:
    return [
        0x61u8, 0x62u8, 0x63u8, 0x64u8,
        0x65u8, 0x66u8, 0x67u8, 0x68u8,
        0x69u8, 0x6Au8, 0x6Bu8, 0x6Cu8,
        0x6Du8, 0x6Eu8, 0x6Fu8, 0x70u8
    ]

fn _make_aaa256() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 256:
        out.push(0x41u8)
        i = i + 1
    out

fn _make_small_gzip() -> [u8]:
    # A minimal gzip stream (level 6, small payload) — starts with 0x1F 0x8B
    val payload = _make_16_bytes()
    return gzip_compress(payload, 6)

# ---------------------------------------------------------------------------

describe("raw deflate (RFC 1951) round-trip"):

    it("round-trips an empty payload"):
        val empty: [u8] = []
        val compressed = deflate_compress(empty, 6)
        expect compressed.len() > 0 == true
        val decoded = deflate_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 0

    it("round-trips 16 bytes at level 6 (fixed Huffman)"):
        val payload = _make_16_bytes()
        val compressed = deflate_compress(payload, 6)
        val decoded = deflate_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 16
        var i = 0
        var all_match = true
        while i < 16:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("256xA at level 6 compresses to well under 50% of input"):
        val payload = _make_aaa256()
        val compressed = deflate_compress(payload, 6)
        # raw deflate has no 18-byte gzip wrapper; 256 bytes of 'A' → ~8-12 bytes
        val limit = (payload.len() * 50) / 100
        expect compressed.len() < limit == true

    it("256xA at level 6 round-trips correctly"):
        val payload = _make_aaa256()
        val compressed = deflate_compress(payload, 6)
        val decoded = deflate_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 256
        var i = 0
        var all_match = true
        while i < 256:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("level 0 (stored) output is slightly larger than input"):
        val payload = _make_aaa256()
        val compressed = deflate_compress(payload, 0)
        # stored block: 1 (hdr) + 2 (LEN) + 2 (NLEN) + 256 (data) = 261
        expect compressed.len() > payload.len() == true

    it("level 0 (stored) round-trips correctly"):
        val payload = _make_16_bytes()
        val compressed = deflate_compress(payload, 0)
        val decoded = deflate_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 16
        var i = 0
        var all_match = true
        while i < 16:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("raw deflate output does NOT start with gzip magic 0x1F 0x8B"):
        val payload = _make_16_bytes()
        val compressed = deflate_compress(payload, 6)
        # A deflate block first byte encodes BFINAL+BTYPE+code-bits — never 0x1F
        expect compressed[0] == 0x1Fu8 == false

    it("gzip stream is not transparently decoded as raw deflate"):
        # gzip starts with 0x1F 0x8B; inflate() sees BTYPE=3 (reserved) and falls
        # through without matching the original payload, so the output length differs.
        val payload = _make_16_bytes()
        val gzip_data = _make_small_gzip()
        val decoded = deflate_decompress(gzip_data)
        # Either nil (error path) or a byte slice that doesn't match the payload length
        val out = decoded ?? []
        expect out.len() == payload.len() == false