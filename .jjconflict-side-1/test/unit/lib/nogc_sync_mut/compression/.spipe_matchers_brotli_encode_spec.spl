# brotli_encode_spec.spl — RFC 7932 brotli encoder smoke tests
#
# Tests the uncompressed-meta-block encoder in encoder.spl.
# All round-trip tests go through the in-repo brotli_decode.
#
# WBITS=16 stream framing: first bit is 0 (WBITS=16).
# Empty stream canonical form: [0x06] (bits: WBITS=0, ISLAST=1, ISLASTEMPTY=1,
# then zero-padded to byte = 0b00000110 = 0x06).

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.brotli.encoder.{brotli_compress}
use std.nogc_sync_mut.compression.brotli.decoder.{brotli_decode}

# ---- payload helpers (module-scope — avoids interpreter it-block mutation footgun) ----

fn _make_empty() -> [u8]:
    []

fn _make_single_a() -> [u8]:
    [0x41u8]

fn _make_200_ascii() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 200:
        out.push((0x20 + (i % 95)).to_u8())
        i = i + 1
    out

# 1000-byte payload — stays well within interpreter time budget.
fn _make_1000_bytes() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 1000:
        out.push((i % 251).to_u8())
        i = i + 1
    out

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

describe("brotli_compress"):
    it("empty input produces canonical 1-byte stream [0x06]"):
        val encoded = brotli_compress(_make_empty())
        expect encoded.len() == 1
        expect encoded[0].to_i64() == 0x06

    it("empty input round-trips through brotli_decode to empty"):
        val encoded = brotli_compress(_make_empty())
        val decoded = brotli_decode(encoded)
        expect decoded.is_ok() == true
        expect decoded.unwrap().len() == 0

    it("single byte 'A' round-trips through brotli_decode"):
        val input = _make_single_a()
        val encoded = brotli_compress(input)
        val decoded = brotli_decode(encoded)
        expect decoded.is_ok() == true
        val out = decoded.unwrap()
        expect out.len() == 1
        expect out[0].to_i64() == 0x41

    it("200 ASCII bytes round-trip through brotli_decode unchanged"):
        val input = _make_200_ascii()
        val encoded = brotli_compress(input)
        val decoded = brotli_decode(encoded)
        expect decoded.is_ok() == true
        expect _bytes_equal(decoded.unwrap(), input) == true

    it("1000 bytes round-trip through brotli_decode unchanged"):
        val input = _make_1000_bytes()
        val encoded = brotli_compress(input)
        val decoded = brotli_decode(encoded)
        expect decoded.is_ok() == true
        expect _bytes_equal(decoded.unwrap(), input) == true

    it("output starts with WBITS=16 marker (first byte bit0=0)"):
        # WBITS=16 encodes as a single 0 bit; with ISLAST=0 next, the first
        # byte has bit0=0 for a non-empty stream.
        val encoded = brotli_compress(_make_single_a())
        expect (encoded[0].to_i64() & 1) == 0

    it("output is byte-aligned (no trailing partial bytes)"):
        # Encoder always flushes; output length must be a whole number of bytes.
        val encoded = brotli_compress(_make_200_ascii())
        # Spot-check: decoded length matches input (validates alignment correctness)
        val decoded = brotli_decode(encoded)
        expect decoded.is_ok() == true
        expect decoded.unwrap().len() == 200

    it("4-nibble MLEN boundary: MLEN-1=0xFFFF encodes with code=0 (4 nibbles)"):
        # The encoder uses 4-nibble encoding for MLEN-1 <= 0xFFFF.
        # A 200-byte payload has MLEN-1=199=0xC7, well within 4-nibble range.
        # Verify by checking byte 1 (MLEN-1 bits 4-11) of the stream.
        # Stream bit layout: bit0=WBITS(0), bit1=ISLAST(0), bit2-3=MNIBBLES_code(00=0),
        #   bits4-7=MLEN-1[0..3], byte1=MLEN-1[4..11], byte2=MLEN-1[12..15]+ISUNCOMP+pad
        # MLEN-1=199=0xC7: bits0-3=7, bits4-7=0xC, bits8-15=0
        # byte0 = (0 | 0<<1 | 0<<2 | 0<<3 | 7<<4) = 0x70
        # byte1 = (0xC) = 0x0C
        # byte2 = (0 | 1<<4) = 0x10  (ISUNCOMPRESSED=1, rest pad)
        val encoded = brotli_compress(_make_200_ascii())
        expect encoded[0].to_i64() == 0x70
        expect encoded[1].to_i64() == 0x0C
        expect encoded[2].to_i64() == 0x10

    it("encoded output is larger than input by a small framing overhead"):
        # Sanity check: uncompressed encoder never shrinks data.
        val input = _make_200_ascii()
        val encoded = brotli_compress(input)
        expect encoded.len() > input.len() == true