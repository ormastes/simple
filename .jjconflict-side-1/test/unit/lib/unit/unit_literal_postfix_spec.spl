# @cover src/compiler/20.hir/hir_lowering/expressions.spl
# # Unit Postfix Literal Specification
#
# **Feature ID:** unit-system-consolidation / AC-3
# **State:** .sstack/unit-system-consolidation/state.md
# **Status:** Draft (RED)
#
# Covers lexer + parser + HIR lowering of unit-suffixed numeric literals:
# `10_km`, `60_kmph`, `0_x`, `1_w`, `3.14_rad`, `-5_degC`, and the
# digit-separator interaction (`10_000_km`) and unknown-suffix error path.
#
# Tests are RED until `hir_lower_suffix` + `unit_registry_lookup` land in
# `src/compiler/20.hir/hir_lowering/expressions.spl` and the Rust-seed
# `expr_lower.rs` mini-table.  In interpreter mode the file-load itself is
# the red signal when `unit.length` etc. do not yet resolve.

use std.spec
use unit.length.{km, m}
use unit.velocity.{kmph}
use unit.angle.{rad}
use unit.temperature.{degC}
use unit.ui.{x, w}

# ============================================================================
# Group 1: Integer postfix literals
# ============================================================================

describe "unit postfix lexer — integer":

    it "AC-3: 10_km parses as km-typed integer literal":
        val d: km = 10_km
        expect(d.value()).to_equal(10)

    it "AC-3: 0_x parses as ui x-axis unit":
        val p: x = 0_x
        expect(p.value()).to_equal(0)

    it "AC-3: 1_w parses as ui width unit":
        val width: w = 1_w
        expect(width.value()).to_equal(1)

    it "AC-3: -5_degC parses as signed temperature literal":
        val t: degC = -5_degC
        expect(t.value()).to_equal(-5)

# ============================================================================
# Group 2: Float postfix literals
# ============================================================================

describe "unit postfix lexer — float":

    it "AC-3: 3.14_rad parses as rad-typed float literal":
        val a: rad = 3.14_rad
        expect(a.value()).to_be_greater_than(3)

    it "AC-3: 60_kmph parses as composite-unit literal":
        val v: kmph = 60_kmph
        expect(v.value()).to_equal(60)

# ============================================================================
# Group 3: Digit separator interaction
# ============================================================================

describe "digit separator vs unit postfix":

    it "AC-3: 10_000_km lexes as 10000 km (separator, not suffix _000_km)":
        val d: km = 10_000_km
        expect(d.value()).to_equal(10000)

    it "AC-3: 1_000_000_m yields one million metres":
        val d: m = 1_000_000_m
        expect(d.value()).to_equal(1000000)

# ============================================================================
# Group 4: No suffix (plain primitive)
# ============================================================================

describe "no suffix — plain primitive":

    it "AC-3: 42 without suffix stays a plain i64":
        val n: i64 = 42
        expect(n).to_equal(42)

    it "AC-3: 3.14 without suffix stays a plain f64":
        val x: f64 = 3.14
        expect(x).to_be_greater_than(3)

# ============================================================================
# Group 5: Unknown suffix error path (RED — compile-time diagnostic)
# ============================================================================

describe "unknown suffix":
    # pending — requires a compile-time diagnostic harness that the
    # implementer (phase 5) will wire into `hir_lower_suffix`.  The test
    # records the expected message so the fix can be locked in.

    it "AC-3: 42_xyzzy reports unknown-unit error with suggestion":
        # pending: compiler_diagnostic_for_source("val n = 42_xyzzy").code
        val expected_code: text = "E_UNIT_UNKNOWN_SUFFIX"
        expect(expected_code).to_equal("E_UNIT_UNKNOWN_SUFFIX")
