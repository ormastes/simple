# Minimal CUDA kernel test — verifies the dlopen pipeline works

extern fn rt_cuda_init() -> i64
extern fn rt_cuda_device_get(id: i64) -> i64
extern fn rt_cuda_ctx_create(device: i64) -> i64
extern fn rt_cuda_ctx_destroy(ctx: i64) -> i64
extern fn rt_cuda_mem_alloc(size: i64) -> i64
extern fn rt_cuda_mem_free(ptr: i64) -> i64
extern fn rt_cuda_memset(ptr: i64, value: i64, size: i64) -> i64
extern fn rt_cuda_memcpy_dtoh(dst: i64, src: i64, size: i64) -> i64
extern fn rt_cuda_module_load_data(ptx: text) -> i64
extern fn rt_cuda_module_unload(module: i64) -> i64
extern fn rt_cuda_launch_kernel(module: i64, func_name: text, grid_x: i64, grid_y: i64, grid_z: i64, block_x: i64, block_y: i64, block_z: i64, args_ptr: i64) -> i64
extern fn rt_cuda_sync() -> i64
extern fn rt_alloc(size: i64) -> i64
extern fn rt_ptr_write_i64(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_read_i64(ptr: i64, offset: i64) -> i64

fn main():
    val SIMPLE_PTX = ".version 7.0\n.target sm_50\n.address_size 64\n\n.visible .entry noop()\n{\n    ret;\n}\n"
    print("=== Minimal CUDA Pipeline Test ===")

    var err = rt_cuda_init()
    print("init: " + err.to_string())

    var dev = rt_cuda_device_get(0)
    print("device: " + dev.to_string())

    print("device selected; runtime-owned default context will be used")

    print("PTX length: " + SIMPLE_PTX.len().to_string())
    var module = rt_cuda_module_load_data(SIMPLE_PTX)
    print("module: " + module.to_string())
    if module <= 0:
        print("FAIL: module_load_data error=" + module.to_string())
        return

    val kernel_name = "noop"
    var launch = rt_cuda_launch_kernel(module, kernel_name, 1, 1, 1, 1, 1, 1, 0)
    print("launch: " + launch.to_string())

    var d_out = rt_cuda_mem_alloc(8)
    print("d_out: " + d_out.to_string())
    rt_cuda_memset(d_out, 42, 8)

    var sync_r = rt_cuda_sync()
    print("sync: " + sync_r.to_string())

    var h_buf = rt_alloc(8)
    rt_cuda_memcpy_dtoh(h_buf, d_out, 8)
    var result = rt_ptr_read_i64(h_buf, 0)
    print("result: " + result.to_string())
    if launch == 0 and result != 0:
        print("PASS: CUDA module launch and device readback executed correctly")
    else:
        print("FAIL: expected successful launch and nonzero readback, got launch=" + launch.to_string() + " result=" + result.to_string())

    rt_cuda_mem_free(d_out)
    rt_cuda_module_unload(module)
