struct FileBuf:
    data: [u8]
    pos: i64
    mode: text

fn fbuf_open(initial: [u8], mode: text) -> FileBuf:
    FileBuf(data: initial, pos: 0i64, mode: mode)

fn fbuf_write(f: FileBuf, bytes: [u8]) -> FileBuf:
    var new_data = f.data
    var i = 0i64
    while i < bytes.len():
        new_data.push(bytes[i])
        i = i + 1i64
    FileBuf(data: new_data, pos: f.pos, mode: f.mode)

fn fbuf_read(f: FileBuf, n: i64) -> [u8]:
    var result = []
    var i = 0i64
    while i < n:
        if (f.pos + i) < f.data.len():
            result.push(f.data[f.pos + i])
            i = i + 1i64
    result

fn fbuf_read_advance(f: FileBuf, n: i64) -> FileBuf:
    val new_pos = f.pos + n
    FileBuf(data: f.data, pos: new_pos, mode: f.mode)

fn fbuf_gets(f: FileBuf) -> [u8]:
    var result = []
    var i = f.pos
    while i < f.data.len():
        val byte = f.data[i]
        result.push(byte)
        if byte == 10i64:
            break
        i = i + 1i64
    result

fn fbuf_eof(f: FileBuf) -> bool:
    f.pos >= f.data.len()

fn fbuf_len(f: FileBuf) -> i64:
    f.data.len()

fn fbuf_flush(f: FileBuf) -> [u8]:
    f.data
