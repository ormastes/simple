# Framebuffer Driver — Pixel Rendering on Limine Framebuffer
#
# MDSOC: feature dimension, drivers layer
# Input: BootOutputPort.framebuffer (address, width, height, pitch, bpp)
# Provides: fill_rect, draw_char, blit, swap_buffers
#
# Uses double buffering: draw to back buffer, swap to front on vsync.

use os.kernel.boot.ports.{FramebufferInfo, framebuffer_info_phys_addr}
use os.kernel.boot.mmio.{mmio_write32, mmio_read32}
use std.gpu.engine2d.framebuffer_surface.{FramebufferSurface}
use os.drivers.framebuffer.fb_font.{get_glyph_8x16}
use common.gpu.simpleos_host_gpu_protocol.{simpleos_host_gpu_readback_checksum_step, simpleos_host_gpu_readback_checksum_finalize}

# Direct-LFB horizontal span fill (boot-stub C, raw-int args, no allocation).
# Writes `count` ARGB8888 pixels at row `y` starting at column `x`, straight
# into the hardware linear framebuffer registered at boot via rt_gui_set_fb.
# Used only on the too-large-for-back-buffer path below (see put_pixel).
extern fn rt_gui_hline(y: i64, x: i64, count: i64, color: i64)

# Direct-LFB rectangle fill (boot-stub C, packed-int args, no allocation).
# Fills the whole (x, y, w, h) rect in a single C-side row loop instead of
# one Simple-side extern call per row -- see `clear`/`fill_rect` below: a
# 2160-call-per-frame row loop for a 4K clear was slow enough, under the
# taskbar-clock fault-recovery retry storm (each retry re-renders the
# frame from scratch), to blow the per-attempt work budget and drive extra
# retries before the render pipeline gave up -- each extra retry's other
# allocations (offscreen surfaces, composition scratch) compounded on the
# never-frees-anything bump heap into a heap-exhaustion panic that a plain
# HEAD build (fast, bounds-checked-but-silently-truncated back-buffer
# writes) never hit. One `rt_gui_fill4` call replaces 2160.
extern fn rt_gui_fill4(xy: i64, wh: i64, color: i64, unused: i64)

# ============================================================================
# Color
# ============================================================================

struct Color:
    """32-bit ARGB color."""
    r: u8
    g: u8
    b: u8
    a: u8

impl Color:
    fn to_u32() -> u32:
        """Convert to 32-bit ARGB pixel value."""
        ((self.a.to_u32() << 24) | (self.r.to_u32() << 16) | (self.g.to_u32() << 8) | self.b.to_u32())

    static fn rgb(r: u8, g: u8, b: u8) -> Color:
        Color(r: r, g: g, b: b, a: 255)

    static fn black() -> Color: Color.rgb(0, 0, 0)
    static fn white() -> Color: Color.rgb(255, 255, 255)
    static fn red() -> Color: Color.rgb(255, 0, 0)
    static fn green() -> Color: Color.rgb(0, 255, 0)
    static fn blue() -> Color: Color.rgb(0, 0, 255)
    static fn gray() -> Color: Color.rgb(128, 128, 128)
    static fn dark_gray() -> Color: Color.rgb(64, 64, 64)
    static fn light_gray() -> Color: Color.rgb(192, 192, 192)

struct DamageRect:
    """Exclusive-end framebuffer damage rectangle."""
    x1: u32
    y1: u32
    x2: u32
    y2: u32
    valid: bool

impl DamageRect:
    fn width() -> u32:
        if not self.valid or self.x2 <= self.x1:
            return 0
        self.x2 - self.x1

    fn height() -> u32:
        if not self.valid or self.y2 <= self.y1:
            return 0
        self.y2 - self.y1

struct FramebufferCapabilities:
    """Display backend capability summary for compositor selection."""
    backend_kind: text
    width: u32
    height: u32
    bpp: u32
    flush_mode: text
    cache_policy: text

# ============================================================================
# Framebuffer Driver
# ============================================================================

fn _zero_u32_buffer(count: u32) -> [u32]:
    """Build a zero-filled `[u32]` of `count` entries."""
    # Single O(n) allocation. The previous `buf = buf + [0u32]` loop CONCATENATED
    # a fresh array every iteration, so under the freestanding bump allocator
    # (no free) it allocated arrays of size 1,2,3,...,count = O(count^2) memory.
    # For a 4K back buffer (3840*2160 = 8.29M entries) that exhausts the kernel
    # heap after ~16K iterations regardless of heap size — the SimpleOS WM 4K
    # heap-exhaustion regression. `[0u32; n]` allocates the buffer once.
    #
    # Oversized modes get NO staging buffer at all: the freestanding array
    # runtime clamps capacity (rt_array_new / rt_array_repeat cap at 0x100000
    # entries), so a request beyond that silently yields a SHORT array whose
    # bounds-checked writes all drop — the root cause of the all-black 4K
    # SimpleOS desktop (2026-07-16). Returning [] makes the driver's
    # "staging buffer present" checks (length() > 0) route every draw to the
    # direct-LFB span path instead.
    if count.to_i64() > 0x100000:
        return []
    [0u32; count.to_i64()]

class FramebufferDriver:
    """Double-buffered framebuffer driver.

    Three modes:
    - Direct MMIO (`from_boot_info`/`from_scanout_raw`): draw ops (`put_pixel`,
      `fill_rect`, `clear`, `blend_pixel`, and the text/glyph helpers built on
      top of them) write into the software `back_buffer`. `swap_buffers()`
      copies the tracked dirty rect from `back_buffer` into hardware MMIO at
      `front_addr`, so a caller that forgets to swap never tears the visible
      framebuffer mid-draw. `host_buffer` is empty in this mode.
    - Empty stub (`empty`): no-op for hosted mode where the hardware FB is
      unused.
    - Host-backed headless (`from_buffer`): writes go directly to the
      in-process `host_buffer: [u32]` ARGB array (no back-buffer indirection)
      — this mode has no real display to tear, and existing wm_compare
      backend-parity callers read `host_pixels()` immediately after drawing.
      See the wm_compare backend parity specs.
    """
    front_addr: u64         # Hardware framebuffer address (from Limine), 0 in headless mode
    back_buffer: [u32]      # Software back buffer for MMIO mode (ARGB8888, len = w*h)
    host_buffer: [u32]      # Host-backed headless buffer (ARGB8888, len = w*h)
    width: u32
    height: u32
    pitch: u32              # Bytes per scanline
    bpp: u32                # Bits per pixel
    dirty: bool             # Buffer has changes
    dirty_x1: u32
    dirty_y1: u32
    dirty_x2: u32
    dirty_y2: u32

impl FramebufferDriver:

    static fn empty() -> FramebufferDriver:
        """Create a dummy driver (for hosted mode where hardware FB is unused)."""
        FramebufferDriver(
            front_addr: 0,
            back_buffer: [],
            host_buffer: [],
            width: 0,
            height: 0,
            pitch: 0,
            bpp: 0,
            dirty: false,
            dirty_x1: 0,
            dirty_y1: 0,
            dirty_x2: 0,
            dirty_y2: 0
        )

    static fn from_boot_info(fb: FramebufferInfo) -> FramebufferDriver:
        """Create driver from Limine framebuffer info.

        Direct-MMIO mode: draw ops target `front_addr` directly, so this path
        does not allocate a redundant full-frame software back buffer.
        """
        FramebufferDriver(
            front_addr: framebuffer_info_phys_addr(fb),
            back_buffer: [],
            host_buffer: [],
            width: fb.width,
            height: fb.height,
            pitch: fb.pitch,
            bpp: fb.bpp,
            dirty: false,
            dirty_x1: 0,
            dirty_y1: 0,
            dirty_x2: 0,
            dirty_y2: 0
        )

    static fn from_scanout_raw(front_addr: u64, width: u32, height: u32, pitch: u32, bpp: u32) -> FramebufferDriver:
        """Create a direct framebuffer without a struct-by-value ABI boundary.

        Direct-MMIO mode: draw ops target `front_addr` directly, so this path
        does not allocate a redundant full-frame software back buffer.
        """
        FramebufferDriver(
            front_addr: front_addr,
            back_buffer: [],
            host_buffer: [],
            width: width,
            height: height,
            pitch: pitch,
            bpp: bpp,
            dirty: false,
            dirty_x1: 0,
            dirty_y1: 0,
            dirty_x2: 0,
            dirty_y2: 0
        )

    static fn from_buffer(width: u32, height: u32) -> FramebufferDriver:
        """Create a host-backed headless framebuffer driver.

        The driver wraps an in-process `[u32]` ARGB8888 buffer of
        `width * height` pixels. All draw/read methods route through
        the buffer instead of MMIO. Used by the wm_compare backend parity
        harness so `fb_backend` can be exercised without booting QEMU.

        See the wm_compare backend parity specs.
        """
        FramebufferDriver(
            front_addr: 0,
            back_buffer: [],
            host_buffer: _zero_u32_buffer(width * height),
            width: width,
            height: height,
            pitch: width * 4,
            bpp: 32,
            dirty: false,
            dirty_x1: 0,
            dirty_y1: 0,
            dirty_x2: 0,
            dirty_y2: 0
        )

    fn is_host_backed() -> bool:
        """True if this driver is wrapping an in-process pixel buffer."""
        self.front_addr == 0 and self.width > 0 and self.height > 0

    fn has_staging_buffer() -> bool:
        """True when the MMIO-mode staging `back_buffer` exists.

        `_zero_u32_buffer` allocates the staging buffer full-size or not at
        all (oversized modes get `[]`), so a plain emptiness check decides
        between the classic double-buffered path (all current arm64/riscv64
        modes, <= 1M px) and the direct-LFB span path (4K x86_64).
        """
        self.back_buffer.length() > 0

    fn host_pixels() -> [u32]:
        """Snapshot of the host-backed pixel buffer (ARGB8888, row-major).

        Returns an empty array on non-host-backed drivers. Callers that
        want a stable snapshot should treat the result as read-only —
        the array is the live buffer reference, not a copy.
        """
        self.host_buffer

    me mark_dirty_rect(x: u32, y: u32, w: u32, h: u32):
        """Record framebuffer damage using exclusive-end coordinates."""
        if w == 0 or h == 0 or self.width == 0 or self.height == 0:
            return
        if x >= self.width or y >= self.height:
            return
        var x2_u = x.to_u64() + w.to_u64()
        var y2_u = y.to_u64() + h.to_u64()
        if x2_u > self.width.to_u64():
            x2_u = self.width.to_u64()
        if y2_u > self.height.to_u64():
            y2_u = self.height.to_u64()
        val x2 = x2_u.to_u32()
        val y2 = y2_u.to_u32()
        if x2 <= x or y2 <= y:
            return
        if not self.dirty:
            self.dirty_x1 = x
            self.dirty_y1 = y
            self.dirty_x2 = x2
            self.dirty_y2 = y2
        else:
            if x < self.dirty_x1:
                self.dirty_x1 = x
            if y < self.dirty_y1:
                self.dirty_y1 = y
            if x2 > self.dirty_x2:
                self.dirty_x2 = x2
            if y2 > self.dirty_y2:
                self.dirty_y2 = y2
        self.dirty = true

    fn dirty_rect() -> DamageRect:
        DamageRect(
            x1: self.dirty_x1,
            y1: self.dirty_y1,
            x2: self.dirty_x2,
            y2: self.dirty_y2,
            valid: self.dirty
        )

    me clear_dirty():
        self.dirty = false
        self.dirty_x1 = 0
        self.dirty_y1 = 0
        self.dirty_x2 = 0
        self.dirty_y2 = 0

    fn capabilities() -> FramebufferCapabilities:
        val backend = if self.front_addr == 0: "host-buffer" else: "framebuffer-mmio"
        FramebufferCapabilities(
            backend_kind: backend,
            width: self.width,
            height: self.height,
            bpp: self.bpp,
            flush_mode: "dirty-rect",
            cache_policy: if self.front_addr == 0: "coherent" else: "uncached"
        )

    me present_argb32_from_mmio(source_addr: u64, source_width: u32, source_height: u32, source_bytes: i64, expected_checksum: i64) -> bool:
        """Validate and present one complete ARGB32 MMIO readback without allocating."""
        if source_addr == 0u64 or source_addr % 4u64 != 0u64 or source_width == 0u32 or source_height == 0u32:
            return false
        if self.bpp != 32u32 or source_width != self.width or source_height != self.height or expected_checksum <= 0:
            return false
        val max_u64 = 0xFFFFFFFFFFFFFFFFu64
        val pixel_count = source_width.to_u64() * source_height.to_u64()
        if pixel_count == 0u64 or pixel_count > max_u64 / 4u64:
            return false
        val exact_bytes = pixel_count * 4u64
        if source_bytes <= 0 or source_bytes.to_u64() != exact_bytes or source_addr > max_u64 - exact_bytes:
            return false
        val row_bytes = source_width.to_u64() * 4u64
        if self.pitch.to_u64() < row_bytes or self.pitch % 4u32 != 0u32:
            return false
        val last_row_offset = (source_height.to_u64() - 1u64) * self.pitch.to_u64()
        if last_row_offset > max_u64 - row_bytes:
            return false
        val destination_span = last_row_offset + row_bytes
        val host_backed = self.front_addr == 0u64
        if host_backed:
            if destination_span / 4u64 > self.host_buffer.len().to_u64():
                return false
        else:
            if self.front_addr % 4u64 != 0u64 or self.front_addr > max_u64 - destination_span:
                return false
            val source_end = source_addr + exact_bytes
            val destination_end = self.front_addr + destination_span
            if source_addr < destination_end and self.front_addr < source_end:
                return false

        var checksum: i64 = 0
        var index: u64 = 0u64
        while index < pixel_count:
            checksum = simpleos_host_gpu_readback_checksum_step(checksum, mmio_read32(source_addr + index * 4u64))
            index = index + 1u64
        if simpleos_host_gpu_readback_checksum_finalize(checksum) != expected_checksum:
            return false

        var row: u64 = 0u64
        while row < source_height.to_u64():
            var col: u64 = 0u64
            while col < source_width.to_u64():
                val pixel = mmio_read32(source_addr + (row * source_width.to_u64() + col) * 4u64)
                val destination_offset = row * self.pitch.to_u64() + col * 4u64
                if host_backed:
                    self.host_buffer[(destination_offset / 4u64).to_i64()] = pixel
                else:
                    mmio_write32(self.front_addr + destination_offset, pixel)
                col = col + 1u64
            row = row + 1u64
        # This path already wrote the authoritative surface (front MMIO or
        # host_buffer) directly, bypassing back_buffer — clear the damage
        # tracking without triggering swap_buffers()'s back->front copy,
        # which would otherwise stomp what was just written with stale
        # back_buffer content.
        self.mark_dirty_rect(0u32, 0u32, self.width, self.height)
        self.clear_dirty()
        true

    me put_pixel(x: u32, y: u32, color: Color):
        """Set a single pixel on the active surface (front MMIO or host buffer).

        MMIO mode writes straight through to the hardware LFB (same
        direct-MMIO contract as `present_argb32_from_mmio`/`read_pixel` below)
        instead of staging into `back_buffer`. The `[0u32; w*h]` back-buffer
        allocation is unreliable at 4K sizes on the freestanding
        entry-closure native-build path — `back_buffer.length()` reads back
        far smaller than `w*h` post-construction, so every bounds-checked
        write into it was silently dropped (0 pixels ever landed in the
        hardware LFB despite `swap_buffers()` running and reporting a
        correct dirty rect). Direct-MMIO writes have no such indirection
        and are proven to reach the display (used already by the host-gpu
        readback-presentation path).
        """
        if x >= self.width or y >= self.height:
            return
        val pixel = color.to_u32()
        if self.front_addr != 0:
            val idx = (y * self.width + x).to_i64()
            if idx < self.back_buffer.length().to_i64():
                self.back_buffer[idx] = pixel
            else:
                # No staging buffer (oversized mode): write the LFB directly.
                # Per-pixel Simple-side MMIO (u64 address math) allocates a
                # boxed temporary per write on the freestanding path and
                # exhausted the 192MB kernel heap within one 4K frame — the
                # span helper does the volatile store loop in C with raw
                # integer args (no allocation).
                rt_gui_hline(y.to_i64(), x.to_i64(), 1, pixel.to_i64())
        else:
            val idx = (y * self.width + x).to_i64()
            if idx < self.host_buffer.length().to_i64():
                self.host_buffer[idx] = pixel
        self.mark_dirty_rect(x, y, 1, 1)

    me fill_rect(x: u32, y: u32, w: u32, h: u32, color: Color):
        """Fill a rectangle on the active surface (front MMIO or host buffer).

        See `put_pixel` for why oversized modes bypass `back_buffer` and
        write the hardware LFB directly (row spans via `rt_gui_hline`).
        """
        val pixel = color.to_u32()
        val host_backed = self.front_addr == 0
        # Explicit branches (no `and`): the entry-closure freestanding codegen
        # drops the left operand of mixed boolean `and` expressions.
        var direct = false
        if host_backed == false:
            if self.back_buffer.length() == 0:
                direct = true
        if direct:
            # Single C-side rect fill instead of a per-row `rt_gui_hline`
            # loop -- see `rt_gui_fill4`'s doc comment above: a per-row
            # extern-call loop here is slow enough under the fault-recovery
            # retry storm to blow the per-attempt work budget.
            var in_bounds = false
            if x < self.width:
                if y < self.height:
                    in_bounds = true
            if in_bounds:
                var clamped_w = w
                if x + clamped_w > self.width:
                    clamped_w = self.width - x
                var clamped_h = h
                if y + clamped_h > self.height:
                    clamped_h = self.height - y
                val xy = (x.to_i64() << 32) | y.to_i64()
                val wh = (clamped_w.to_i64() << 32) | clamped_h.to_i64()
                rt_gui_fill4(xy, wh, pixel.to_i64(), 0)
            self.mark_dirty_rect(x, y, w, h)
            return
        var row: u32 = 0
        while row < h:
            val py = y + row
            if py >= self.height:
                row = h
            else:
                var col: u32 = 0
                while col < w:
                    val px = x + col
                    if px < self.width:
                        val idx = (py * self.width + px).to_i64()
                        if host_backed:
                            if idx < self.host_buffer.length().to_i64():
                                self.host_buffer[idx] = pixel
                        else:
                            self.back_buffer[idx] = pixel
                    col = col + 1
                row = row + 1
        self.mark_dirty_rect(x, y, w, h)

    me draw_char_8x16(x: u32, y: u32, ch: u8, fg: Color, bg: Color):
        """Draw a single character using built-in 8x16 bitmap font.

        Each character is 8 pixels wide, 16 pixels tall.
        Font data from VGA ROM bitmap (PSF format).
        """
        val glyph = get_glyph_8x16(ch)
        var row: u32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: u32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask) != 0: fg else: bg
                val px = x + col
                val py = y + row
                self.put_pixel(px, py, color)
                col = col + 1
            row = row + 1

    me draw_text(x: u32, y: u32, text_str: text, fg: Color, bg: Color):
        """Draw a text string using 8x16 font."""
        var cx = x
        for ch in text_str:
            val ch_byte = ch.to_u8()
            self.draw_char_8x16(cx, y, ch_byte, fg, bg)
            cx = cx + 8

    me swap_buffers():
        """Present the back buffer: copy the tracked dirty rect to hardware MMIO.

        Only runs the back->front copy when `back_buffer` really covers the
        mode (see `back_buffer_covers_mode`). Oversized modes wrote the LFB
        directly in `put_pixel`/`fill_rect`/`clear`, so copying the (short,
        zero-filled) back buffer here would smear black over the frame just
        painted — those modes only clear the damage bookkeeping, matching
        `present_argb32_from_mmio`'s "already wrote the authoritative
        surface directly" contract. Host-backed mode has no back buffer
        either (writes already landed in `host_buffer`).
        """
        if self.front_addr != 0 and self.dirty:
            if self.has_staging_buffer():
                val cap = self.back_buffer.length().to_i64()
                var row: u32 = self.dirty_y1
                while row < self.dirty_y2:
                    var col: u32 = self.dirty_x1
                    while col < self.dirty_x2:
                        val idx = (row * self.width + col).to_i64()
                        if idx < cap:
                            val offset = ((row * self.width + col) * 4).to_u64()
                            mmio_write32(self.front_addr + offset, self.back_buffer[idx])
                        col = col + 1
                    row = row + 1
        self.clear_dirty()

    me present_rect(x: u32, y: u32, w: u32, h: u32):
        """Present a bounded region when the backend supports partial flush."""
        self.mark_dirty_rect(x, y, w, h)
        self.swap_buffers()

    me flush_dirty_rects():
        """Flush tracked damage and clear the damage state.

        Direct-MMIO and host-backed framebuffer modes write pixels eagerly, so
        this currently clears bookkeeping. GPU backends consume the same
        DamageRect contract before issuing transfer/flush commands.
        """
        self.clear_dirty()

    me clear(color: Color):
        """Clear entire framebuffer (back buffer, direct LFB, or host buffer).

        See `put_pixel` for why oversized modes bypass `back_buffer` and
        write the hardware LFB directly (row spans via `rt_gui_hline`).
        """
        val pixel = color.to_u32()
        val total = self.width * self.height
        val tot_i = total.to_i64()
        if self.front_addr != 0:
            if self.has_staging_buffer():
                val cap = self.back_buffer.length().to_i64()
                var i: i64 = 0
                while i < tot_i and i < cap:
                    self.back_buffer[i] = pixel
                    i = i + 1
            else:
                val xy = (0i64 << 32) | 0i64
                val wh = (self.width.to_i64() << 32) | self.height.to_i64()
                rt_gui_fill4(xy, wh, pixel.to_i64(), 0)
        else:
            val cap = self.host_buffer.length().to_i64()
            var j: i64 = 0
            while j < tot_i and j < cap:
                self.host_buffer[j] = pixel
                j = j + 1
        self.mark_dirty_rect(0, 0, self.width, self.height)

    fn pixel_count() -> u32:
        self.width * self.height

    me blend_pixel(x: u32, y: u32, color: Color, alpha: u8):
        """Alpha-blend a pixel on the active surface (back buffer or host buffer).

        MMIO mode blends into `back_buffer`; call `swap_buffers()` to present.
        """
        if x >= self.width or y >= self.height:
            return
        val inv = 255 - alpha.to_u32()
        val sr = color.r.to_u32()
        val sg = color.g.to_u32()
        val sb = color.b.to_u32()
        val idx = (y * self.width + x).to_i64()
        var buffered = false
        if self.front_addr != 0:
            buffered = self.has_staging_buffer()
        var dst: u32 = 0
        if self.front_addr != 0:
            if buffered:
                dst = self.back_buffer[idx]
            else:
                # Oversized mode: the LFB is the authoritative surface.
                dst = self.read_pixel(x, y)
        else:
            if idx >= self.host_buffer.length().to_i64():
                return
            dst = self.host_buffer[idx]
        val dr = (dst >> 16) & 0xFF
        val dg = (dst >> 8) & 0xFF
        val db = dst & 0xFF
        val rr = (sr * alpha.to_u32() + dr * inv + 128) >> 8
        val rg = (sg * alpha.to_u32() + dg * inv + 128) >> 8
        val rb = (sb * alpha.to_u32() + db * inv + 128) >> 8
        val out = 0xFF000000 | (rr << 16) | (rg << 8) | rb
        if self.front_addr != 0:
            if buffered:
                self.back_buffer[idx] = out
            else:
                rt_gui_hline(y.to_i64(), x.to_i64(), 1, out.to_i64())
        else:
            self.host_buffer[idx] = out
        self.mark_dirty_rect(x, y, 1, 1)

    me blend_rect(x: u32, y: u32, w: u32, h: u32, color: Color, alpha: u8):
        """Alpha-blend a filled rectangle directly on the hardware framebuffer."""
        var row: u32 = 0
        while row < h:
            var col: u32 = 0
            while col < w:
                self.blend_pixel(x + col, y + row, color, alpha)
                col = col + 1
            row = row + 1

    fn read_pixel(x: u32, y: u32) -> u32:
        """Read a pixel from the active surface (MMIO or host buffer)."""
        if x >= self.width or y >= self.height:
            return 0
        if self.front_addr != 0:
            val offset = ((y * self.width + x) * 4).to_u64()
            return mmio_read32(self.front_addr + offset)
        val idx = (y * self.width + x).to_i64()
        if idx >= self.host_buffer.length().to_i64():
            return 0
        self.host_buffer[idx]

fn framebuffer_argb_to_color(argb: u32) -> Color:
    Color(
        r: ((argb >> 16) & 0xFF).to_u8(),
        g: ((argb >> 8) & 0xFF).to_u8(),
        b: (argb & 0xFF).to_u8(),
        a: ((argb >> 24) & 0xFF).to_u8()
    )

impl FramebufferSurface for FramebufferDriver:
    fn framebuffer_width() -> u32:
        self.width

    fn framebuffer_height() -> u32:
        self.height

    me framebuffer_clear_argb(color: u32):
        if self.front_addr != 0u64:
            self.framebuffer_fill_rect_argb(0u32, 0u32, self.width, self.height, color)
        else:
            self.clear(framebuffer_argb_to_color(color))

    me framebuffer_fill_rect_argb(x: u32, y: u32, w: u32, h: u32, color: u32):
        # The freestanding trait receiver is value-copied, so mutations to its
        # software back_buffer/dirty fields are detached from the later present
        # call. MMIO surfaces therefore render straight to the authoritative
        # front buffer; host-backed surfaces retain the buffered hosted path.
        if self.front_addr != 0u64:
            var row: u32 = 0u32
            while row < h and y + row < self.height:
                var col: u32 = 0u32
                while col < w and x + col < self.width:
                    val offset = (y + row).to_u64() * self.pitch.to_u64() + (x + col).to_u64() * 4u64
                    mmio_write32(self.front_addr + offset, color)
                    col = col + 1u32
                row = row + 1u32
        else:
            self.fill_rect(x, y, w, h, framebuffer_argb_to_color(color))

    me framebuffer_put_pixel_argb(x: u32, y: u32, color: u32):
        if x >= self.width or y >= self.height:
            return
        if self.front_addr != 0u64:
            val offset = y.to_u64() * self.pitch.to_u64() + x.to_u64() * 4u64
            mmio_write32(self.front_addr + offset, color)
        else:
            self.put_pixel(x, y, framebuffer_argb_to_color(color))

    fn framebuffer_read_pixel_argb(x: u32, y: u32) -> u32:
        self.read_pixel(x, y)

    me framebuffer_present():
        if self.front_addr == 0u64:
            self.swap_buffers()
