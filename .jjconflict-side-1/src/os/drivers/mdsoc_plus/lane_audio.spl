# Audio lane MDSOC+ platform contract helpers.

fn audio_lane_controller() -> text:
    "intel-hda"

fn audio_lane_primary_codec() -> text:
    "realtek-hda"

fn audio_lane_secondary_codec() -> text:
    "cirrus-logic-hda"

fn audio_lane_dma_required() -> bool:
    true

fn audio_lane_period_required() -> bool:
    true

fn audio_lane_codec_supported(codec: text) -> bool:
    codec == "realtek-hda" or codec == "cirrus-logic-hda"

fn audio_lane_probe_label(controller: bool, codec: bool, dma: bool, period: bool, mixer: text) -> text:
    if controller and codec and dma and period and mixer != "none":
        return "audio-lane:ready"
    if not controller:
        return "audio-lane:missing-controller"
    if not codec:
        return "audio-lane:missing-codec"
    if not dma:
        return "audio-lane:missing-dma"
    if not period:
        return "audio-lane:missing-period"
    "audio-lane:missing-mixer"

fn audio_lane_cpu_accel_required() -> bool:
    true

fn audio_lane_dma_without_period_invalid(dma: bool, period: bool) -> bool:
    dma and not period
