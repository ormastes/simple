# Display DMA — AC-6 capability naming, AC-7 dirty-rect flushing, AC-8 VirtIO-GPU shared DMA.

# ── AC-6  DisplayCapability ───────────────────────────────────────────────────

struct DisplayCapability:
    backend: text
    is_dma_capable: bool
    is_accelerated: bool
    width: i32
    height: i32
    bpp: i32

fn display_capability_framebuffer(w: i32, h: i32, bpp: i32) -> DisplayCapability:
    DisplayCapability(
        backend: "framebuffer_mmio",
        is_dma_capable: false,
        is_accelerated: false,
        width: w,
        height: h,
        bpp: bpp
    )

fn display_capability_bga(w: i32, h: i32, bpp: i32) -> DisplayCapability:
    DisplayCapability(
        backend: "bga_write_combining",
        is_dma_capable: false,
        is_accelerated: false,
        width: w,
        height: h,
        bpp: bpp
    )

fn display_capability_virtio_gpu(w: i32, h: i32, bpp: i32) -> DisplayCapability:
    DisplayCapability(
        backend: "virtio_gpu_dma",
        is_dma_capable: true,
        is_accelerated: false,
        width: w,
        height: h,
        bpp: bpp
    )

fn display_capability_is_legacy(cap: DisplayCapability) -> bool:
    cap.backend == "framebuffer_mmio" or cap.backend == "bga_write_combining"

fn display_capability_supports_dirty_rect(cap: DisplayCapability) -> bool:
    cap.backend == "bga_write_combining" or cap.backend == "virtio_gpu_dma"

fn _bool_text(v: bool) -> text:
    if v:
        "true"
    else:
        "false"

fn display_capability_summary(cap: DisplayCapability) -> text:
    "[display-cap] backend=" + cap.backend +
        " dma=" + _bool_text(cap.is_dma_capable) +
        " accel=" + _bool_text(cap.is_accelerated) +
        " res=" + cap.width.to_text() + "x" + cap.height.to_text() +
        " bpp=" + cap.bpp.to_text()

# ── AC-7  DirtyRect ───────────────────────────────────────────────────────────

struct DirtyRect:
    x: i32
    y: i32
    w: i32
    h: i32
    is_full_frame: bool

fn dirty_rect_region(x: i32, y: i32, w: i32, h: i32) -> DirtyRect:
    DirtyRect(x: x, y: y, w: w, h: h, is_full_frame: false)

fn dirty_rect_full_frame(screen_w: i32, screen_h: i32) -> DirtyRect:
    DirtyRect(x: 0, y: 0, w: screen_w, h: screen_h, is_full_frame: true)

fn dirty_rect_pixel_count(r: DirtyRect) -> i32:
    r.w * r.h

fn dirty_rect_is_bounded(r: DirtyRect) -> bool:
    r.is_full_frame == false

# ── AC-7  DirtyRectQueue — flat 8-slot queue ──────────────────────────────────

struct DirtyRectQueue:
    count: i32
    r0_x: i32
    r0_y: i32
    r0_w: i32
    r0_h: i32
    r1_x: i32
    r1_y: i32
    r1_w: i32
    r1_h: i32
    r2_x: i32
    r2_y: i32
    r2_w: i32
    r2_h: i32
    r3_x: i32
    r3_y: i32
    r3_w: i32
    r3_h: i32
    r4_x: i32
    r4_y: i32
    r4_w: i32
    r4_h: i32
    r5_x: i32
    r5_y: i32
    r5_w: i32
    r5_h: i32
    r6_x: i32
    r6_y: i32
    r6_w: i32
    r6_h: i32
    r7_x: i32
    r7_y: i32
    r7_w: i32
    r7_h: i32

fn dirty_rect_queue_create() -> DirtyRectQueue:
    DirtyRectQueue(
        count: 0,
        r0_x: 0, r0_y: 0, r0_w: 0, r0_h: 0,
        r1_x: 0, r1_y: 0, r1_w: 0, r1_h: 0,
        r2_x: 0, r2_y: 0, r2_w: 0, r2_h: 0,
        r3_x: 0, r3_y: 0, r3_w: 0, r3_h: 0,
        r4_x: 0, r4_y: 0, r4_w: 0, r4_h: 0,
        r5_x: 0, r5_y: 0, r5_w: 0, r5_h: 0,
        r6_x: 0, r6_y: 0, r6_w: 0, r6_h: 0,
        r7_x: 0, r7_y: 0, r7_w: 0, r7_h: 0
    )

fn dirty_rect_queue_add(q: DirtyRectQueue, r: DirtyRect) -> DirtyRectQueue:
    if q.count >= 8:
        q
    else:
        var slot = q.count
        if slot == 0:
            DirtyRectQueue(count: 1,
                r0_x: r.x, r0_y: r.y, r0_w: r.w, r0_h: r.h,
                r1_x: q.r1_x, r1_y: q.r1_y, r1_w: q.r1_w, r1_h: q.r1_h,
                r2_x: q.r2_x, r2_y: q.r2_y, r2_w: q.r2_w, r2_h: q.r2_h,
                r3_x: q.r3_x, r3_y: q.r3_y, r3_w: q.r3_w, r3_h: q.r3_h,
                r4_x: q.r4_x, r4_y: q.r4_y, r4_w: q.r4_w, r4_h: q.r4_h,
                r5_x: q.r5_x, r5_y: q.r5_y, r5_w: q.r5_w, r5_h: q.r5_h,
                r6_x: q.r6_x, r6_y: q.r6_y, r6_w: q.r6_w, r6_h: q.r6_h,
                r7_x: q.r7_x, r7_y: q.r7_y, r7_w: q.r7_w, r7_h: q.r7_h)
        else:
            if slot == 1:
                DirtyRectQueue(count: 2,
                    r0_x: q.r0_x, r0_y: q.r0_y, r0_w: q.r0_w, r0_h: q.r0_h,
                    r1_x: r.x, r1_y: r.y, r1_w: r.w, r1_h: r.h,
                    r2_x: q.r2_x, r2_y: q.r2_y, r2_w: q.r2_w, r2_h: q.r2_h,
                    r3_x: q.r3_x, r3_y: q.r3_y, r3_w: q.r3_w, r3_h: q.r3_h,
                    r4_x: q.r4_x, r4_y: q.r4_y, r4_w: q.r4_w, r4_h: q.r4_h,
                    r5_x: q.r5_x, r5_y: q.r5_y, r5_w: q.r5_w, r5_h: q.r5_h,
                    r6_x: q.r6_x, r6_y: q.r6_y, r6_w: q.r6_w, r6_h: q.r6_h,
                    r7_x: q.r7_x, r7_y: q.r7_y, r7_w: q.r7_w, r7_h: q.r7_h)
            else:
                if slot == 2:
                    DirtyRectQueue(count: 3,
                        r0_x: q.r0_x, r0_y: q.r0_y, r0_w: q.r0_w, r0_h: q.r0_h,
                        r1_x: q.r1_x, r1_y: q.r1_y, r1_w: q.r1_w, r1_h: q.r1_h,
                        r2_x: r.x, r2_y: r.y, r2_w: r.w, r2_h: r.h,
                        r3_x: q.r3_x, r3_y: q.r3_y, r3_w: q.r3_w, r3_h: q.r3_h,
                        r4_x: q.r4_x, r4_y: q.r4_y, r4_w: q.r4_w, r4_h: q.r4_h,
                        r5_x: q.r5_x, r5_y: q.r5_y, r5_w: q.r5_w, r5_h: q.r5_h,
                        r6_x: q.r6_x, r6_y: q.r6_y, r6_w: q.r6_w, r6_h: q.r6_h,
                        r7_x: q.r7_x, r7_y: q.r7_y, r7_w: q.r7_w, r7_h: q.r7_h)
                else:
                    if slot == 3:
                        DirtyRectQueue(count: 4,
                            r0_x: q.r0_x, r0_y: q.r0_y, r0_w: q.r0_w, r0_h: q.r0_h,
                            r1_x: q.r1_x, r1_y: q.r1_y, r1_w: q.r1_w, r1_h: q.r1_h,
                            r2_x: q.r2_x, r2_y: q.r2_y, r2_w: q.r2_w, r2_h: q.r2_h,
                            r3_x: r.x, r3_y: r.y, r3_w: r.w, r3_h: r.h,
                            r4_x: q.r4_x, r4_y: q.r4_y, r4_w: q.r4_w, r4_h: q.r4_h,
                            r5_x: q.r5_x, r5_y: q.r5_y, r5_w: q.r5_w, r5_h: q.r5_h,
                            r6_x: q.r6_x, r6_y: q.r6_y, r6_w: q.r6_w, r6_h: q.r6_h,
                            r7_x: q.r7_x, r7_y: q.r7_y, r7_w: q.r7_w, r7_h: q.r7_h)
                    else:
                        if slot == 4:
                            DirtyRectQueue(count: 5,
                                r0_x: q.r0_x, r0_y: q.r0_y, r0_w: q.r0_w, r0_h: q.r0_h,
                                r1_x: q.r1_x, r1_y: q.r1_y, r1_w: q.r1_w, r1_h: q.r1_h,
                                r2_x: q.r2_x, r2_y: q.r2_y, r2_w: q.r2_w, r2_h: q.r2_h,
                                r3_x: q.r3_x, r3_y: q.r3_y, r3_w: q.r3_w, r3_h: q.r3_h,
                                r4_x: r.x, r4_y: r.y, r4_w: r.w, r4_h: r.h,
                                r5_x: q.r5_x, r5_y: q.r5_y, r5_w: q.r5_w, r5_h: q.r5_h,
                                r6_x: q.r6_x, r6_y: q.r6_y, r6_w: q.r6_w, r6_h: q.r6_h,
                                r7_x: q.r7_x, r7_y: q.r7_y, r7_w: q.r7_w, r7_h: q.r7_h)
                        else:
                            if slot == 5:
                                DirtyRectQueue(count: 6,
                                    r0_x: q.r0_x, r0_y: q.r0_y, r0_w: q.r0_w, r0_h: q.r0_h,
                                    r1_x: q.r1_x, r1_y: q.r1_y, r1_w: q.r1_w, r1_h: q.r1_h,
                                    r2_x: q.r2_x, r2_y: q.r2_y, r2_w: q.r2_w, r2_h: q.r2_h,
                                    r3_x: q.r3_x, r3_y: q.r3_y, r3_w: q.r3_w, r3_h: q.r3_h,
                                    r4_x: q.r4_x, r4_y: q.r4_y, r4_w: q.r4_w, r4_h: q.r4_h,
                                    r5_x: r.x, r5_y: r.y, r5_w: r.w, r5_h: r.h,
                                    r6_x: q.r6_x, r6_y: q.r6_y, r6_w: q.r6_w, r6_h: q.r6_h,
                                    r7_x: q.r7_x, r7_y: q.r7_y, r7_w: q.r7_w, r7_h: q.r7_h)
                            else:
                                if slot == 6:
                                    DirtyRectQueue(count: 7,
                                        r0_x: q.r0_x, r0_y: q.r0_y, r0_w: q.r0_w, r0_h: q.r0_h,
                                        r1_x: q.r1_x, r1_y: q.r1_y, r1_w: q.r1_w, r1_h: q.r1_h,
                                        r2_x: q.r2_x, r2_y: q.r2_y, r2_w: q.r2_w, r2_h: q.r2_h,
                                        r3_x: q.r3_x, r3_y: q.r3_y, r3_w: q.r3_w, r3_h: q.r3_h,
                                        r4_x: q.r4_x, r4_y: q.r4_y, r4_w: q.r4_w, r4_h: q.r4_h,
                                        r5_x: q.r5_x, r5_y: q.r5_y, r5_w: q.r5_w, r5_h: q.r5_h,
                                        r6_x: r.x, r6_y: r.y, r6_w: r.w, r6_h: r.h,
                                        r7_x: q.r7_x, r7_y: q.r7_y, r7_w: q.r7_w, r7_h: q.r7_h)
                                else:
                                    DirtyRectQueue(count: 8,
                                        r0_x: q.r0_x, r0_y: q.r0_y, r0_w: q.r0_w, r0_h: q.r0_h,
                                        r1_x: q.r1_x, r1_y: q.r1_y, r1_w: q.r1_w, r1_h: q.r1_h,
                                        r2_x: q.r2_x, r2_y: q.r2_y, r2_w: q.r2_w, r2_h: q.r2_h,
                                        r3_x: q.r3_x, r3_y: q.r3_y, r3_w: q.r3_w, r3_h: q.r3_h,
                                        r4_x: q.r4_x, r4_y: q.r4_y, r4_w: q.r4_w, r4_h: q.r4_h,
                                        r5_x: q.r5_x, r5_y: q.r5_y, r5_w: q.r5_w, r5_h: q.r5_h,
                                        r6_x: q.r6_x, r6_y: q.r6_y, r6_w: q.r6_w, r6_h: q.r6_h,
                                        r7_x: r.x, r7_y: r.y, r7_w: r.w, r7_h: r.h)

fn dirty_rect_queue_add_ok(q: DirtyRectQueue, r: DirtyRect) -> bool:
    q.count < 8

fn dirty_rect_queue_flush_all(q: DirtyRectQueue) -> i32:
    q.count

fn dirty_rect_queue_after_flush(q: DirtyRectQueue) -> DirtyRectQueue:
    DirtyRectQueue(count: 0,
        r0_x: 0, r0_y: 0, r0_w: 0, r0_h: 0,
        r1_x: 0, r1_y: 0, r1_w: 0, r1_h: 0,
        r2_x: 0, r2_y: 0, r2_w: 0, r2_h: 0,
        r3_x: 0, r3_y: 0, r3_w: 0, r3_h: 0,
        r4_x: 0, r4_y: 0, r4_w: 0, r4_h: 0,
        r5_x: 0, r5_y: 0, r5_w: 0, r5_h: 0,
        r6_x: 0, r6_y: 0, r6_w: 0, r6_h: 0,
        r7_x: 0, r7_y: 0, r7_w: 0, r7_h: 0)

fn dirty_rect_queue_total_pixels(q: DirtyRectQueue) -> i32:
    (q.r0_w * q.r0_h) + (q.r1_w * q.r1_h) + (q.r2_w * q.r2_h) +
    (q.r3_w * q.r3_h) + (q.r4_w * q.r4_h) + (q.r5_w * q.r5_h) +
    (q.r6_w * q.r6_h) + (q.r7_w * q.r7_h)

fn dirty_rect_queue_should_full_frame(q: DirtyRectQueue, screen_pixels: i32) -> bool:
    dirty_rect_queue_total_pixels(q) > screen_pixels / 2

# ── AC-8  VirtioGpuDmaTransfer ────────────────────────────────────────────────

struct VirtioGpuDmaTransfer:
    resource_id: i32
    dma_paddr: i64
    byte_length: i64
    transfer_type: text
    owner_task: i32

fn virtio_gpu_dma_attach(resource_id: i32, dma_paddr: i64, byte_length: i64, owner_task: i32) -> VirtioGpuDmaTransfer:
    VirtioGpuDmaTransfer(
        resource_id: resource_id,
        dma_paddr: dma_paddr,
        byte_length: byte_length,
        transfer_type: "attach",
        owner_task: owner_task
    )

fn virtio_gpu_dma_transfer(resource_id: i32, dma_paddr: i64, byte_length: i64, owner_task: i32) -> VirtioGpuDmaTransfer:
    VirtioGpuDmaTransfer(
        resource_id: resource_id,
        dma_paddr: dma_paddr,
        byte_length: byte_length,
        transfer_type: "transfer_to_host",
        owner_task: owner_task
    )

fn virtio_gpu_dma_flush(resource_id: i32, owner_task: i32) -> VirtioGpuDmaTransfer:
    VirtioGpuDmaTransfer(
        resource_id: resource_id,
        dma_paddr: 0,
        byte_length: 0,
        transfer_type: "flush",
        owner_task: owner_task
    )

fn virtio_gpu_dma_uses_shared_dma(t: VirtioGpuDmaTransfer) -> bool:
    t.transfer_type == "attach" or t.transfer_type == "transfer_to_host"

fn virtio_gpu_dma_summary(t: VirtioGpuDmaTransfer) -> text:
    "[virtio-gpu-dma] type=" + t.transfer_type +
        " resource=" + t.resource_id.to_text() +
        " paddr=" + t.dma_paddr.to_text() +
        " bytes=" + t.byte_length.to_text() +
        " task=" + t.owner_task.to_text()

# ── DisplayDmaManager ─────────────────────────────────────────────────────────

struct DisplayDmaManager:
    capability: text
    is_dma_enabled: bool
    fallback_active: bool

fn display_dma_manager_with_dma(cap: text) -> DisplayDmaManager:
    DisplayDmaManager(capability: cap, is_dma_enabled: true, fallback_active: false)

fn display_dma_manager_framebuffer_fallback() -> DisplayDmaManager:
    DisplayDmaManager(capability: "framebuffer_mmio", is_dma_enabled: false, fallback_active: true)

fn display_dma_manager_activate_fallback(m: DisplayDmaManager) -> DisplayDmaManager:
    DisplayDmaManager(capability: m.capability, is_dma_enabled: false, fallback_active: true)

fn display_dma_manager_activate_fallback_status(m: DisplayDmaManager) -> text:
    "fallback:active capability=" + m.capability

fn display_dma_manager_current_mode(m: DisplayDmaManager) -> text:
    if m.fallback_active:
        "fallback"
    else:
        "dma"

fn display_dma_manager_summary(m: DisplayDmaManager) -> text:
    "[display-dma-mgr] capability=" + m.capability +
        " dma=" + _bool_text(m.is_dma_enabled) +
        " fallback=" + _bool_text(m.fallback_active) +
        " mode=" + display_dma_manager_current_mode(m)
