//! Target: `library/std/src/sys/pal/simpleos/mod.rs`
//!
//! Platform abstraction layer for the `simpleos` target family.
//! Seeded from `sys/pal/unsupported/mod.rs`, with real libstd primitives
//! backed by `libsimpleos_c` where SimpleOS supports them. Subsystems that
//! SimpleOS does not yet model re-use the `unsupported` shims verbatim.

#![allow(dead_code)]
#![allow(missing_docs, nonstandard_style)]
#![deny(unsafe_op_in_unsafe_fn)]

