pub use self::common::{abort_internal, decode_error_kind, hashmap_random_keys, is_interrupted};

/// Runtime entry hook invoked from SimpleOS `_start`. `(argc, argv)` is
/// stashed for `std::env::args`; no other libstd init is currently required.
///
/// # Safety
/// Called exactly once from the runtime entry point before any libstd call
/// that observes command-line arguments.
pub unsafe fn init(argc: isize, argv: *const *const u8, _sigpipe: u8) {
    unsafe { env::init(argc, argv) }
}

/// Runtime teardown hook. No-op on SimpleOS — `_exit` flushes for us.
pub unsafe fn cleanup() {}
