//! Target: `library/std/src/sys/pal/simpleos/time.rs`
//!
//! `Instant` on `CLOCK_MONOTONIC`, `SystemTime` on `CLOCK_REALTIME`. Both
//! flow through `clock_gettime(2)` as exposed by libsimpleos_c.

use crate::time::Duration;

const CLOCK_REALTIME:  i32 = 0;
const CLOCK_MONOTONIC: i32 = 1;
const NSEC_PER_SEC: u64 = 1_000_000_000;

#[repr(C)]
#[derive(Copy, Clone, Default)]
struct Timespec { tv_sec: i64, tv_nsec: i64 }

unsafe extern "C" {
    fn clock_gettime(clk_id: i32, tp: *mut Timespec) -> i32;
}

fn now(clk: i32) -> Timespec {
    let mut t = Timespec::default();
    // Best-effort — if the clock call fails we hand back the zero value.
    let _ = unsafe { clock_gettime(clk, &mut t) };
    t
}

fn ts_to_dur(t: Timespec) -> Duration {
    Duration::new(t.tv_sec as u64, t.tv_nsec as u32)
}

#[derive(Copy, Clone, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct Instant(Duration);

impl Instant {
    pub fn now() -> Instant { Instant(ts_to_dur(now(CLOCK_MONOTONIC))) }

    pub fn checked_sub_instant(&self, other: &Instant) -> Option<Duration> {
        self.0.checked_sub(other.0)
    }

    pub fn checked_add_duration(&self, d: &Duration) -> Option<Instant> {
        Some(Instant(self.0.checked_add(*d)?))
    }

    pub fn checked_sub_duration(&self, d: &Duration) -> Option<Instant> {
        Some(Instant(self.0.checked_sub(*d)?))
    }
}

#[derive(Copy, Clone, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct SystemTime(Duration);

impl SystemTime {
    pub const UNIX_EPOCH: SystemTime = SystemTime(Duration::from_secs(0));

    pub fn now() -> SystemTime { SystemTime(ts_to_dur(now(CLOCK_REALTIME))) }

    /// Construct a `SystemTime` from raw seconds since the Unix epoch.
    /// Used by `fs::FileAttr::modified()`.
    pub fn from_secs(secs: i64) -> SystemTime {
        SystemTime(Duration::new(secs.max(0) as u64, 0))
    }

    pub fn sub_time(&self, other: &SystemTime) -> Result<Duration, Duration> {
        self.0.checked_sub(other.0).ok_or_else(|| other.0 - self.0)
    }

    pub fn checked_add_duration(&self, d: &Duration) -> Option<SystemTime> {
        Some(SystemTime(self.0.checked_add(*d)?))
    }

    pub fn checked_sub_duration(&self, d: &Duration) -> Option<SystemTime> {
        Some(SystemTime(self.0.checked_sub(*d)?))
    }
}

// Silence dead-code when `NSEC_PER_SEC` is only used by future helpers.
#[allow(dead_code)]
const _: u64 = NSEC_PER_SEC;
