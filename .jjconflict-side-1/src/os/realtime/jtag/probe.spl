# JtagProbe trait — abstract JTAG probe interface.
# Host-side only (not baremetal). Implemented by OpenOCD and TRACE32 backends.

trait JtagProbe:
    """Abstract JTAG debug probe interface for state capture/restore."""
    fn halt() -> bool
    fn resume() -> bool
    fn read_region(addr: u64, len: i32) -> [u8]
    fn write_region(addr: u64, data: [u8]) -> bool
    fn read_register(name: text) -> u64
    fn write_register(name: text, value: u64) -> bool
    fn read_all_registers() -> [u64]
    fn write_all_registers(regs: [u64]) -> bool
    fn is_halted() -> bool
    fn reset() -> bool

val PROBE_TYPE_OPENOCD: i32 = 0
val PROBE_TYPE_TRACE32: i32 = 1

class ProbeConfig:
    """Configuration for connecting to a JTAG probe."""
    probe_type: i32
    host: text
    port: i32
    target_arch: text

    static fn openocd(host: text, port: i32, arch: text) -> ProbeConfig:
        ProbeConfig(
            probe_type: PROBE_TYPE_OPENOCD,
            host: host,
            port: port,
            target_arch: arch
        )

    static fn trace32(host: text, port: i32, arch: text) -> ProbeConfig:
        ProbeConfig(
            probe_type: PROBE_TYPE_TRACE32,
            host: host,
            port: port,
            target_arch: arch
        )
