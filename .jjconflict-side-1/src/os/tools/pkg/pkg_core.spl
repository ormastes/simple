# Package Core — Shared Package Operations (CLI + GUI + OS)
# MDSOC: feature dimension, apps layer
#
# Provides structured, non-printing package operations used by:
# - CLI (pkg_cli.spl, pkg_manager.spl) — formats results as text
# - GUI (package_manager.spl, installer_gui.spl) — binds to widgets
# - OS installer (usb_installer.spl) — drives install flow
#
# All functions return data structures, never print directly.
# This eliminates duplication between CLI and GUI code paths.

use os.tools.pkg.pkg_manifest.{PackageManifest, PackageVersion, parse_manifest, serialize_manifest}
use os.tools.pkg.pkg_format.{
    ExtendedManifest, PackageType, PkgArch, InstallHooks,
    parse_extended_manifest, serialize_extended_manifest,
    package_type_to_text, pkg_arch_to_text, pkg_arch_from_text
}
use os.tools.pkg.pkg_repository.{Repository, PackageIndex, load_repositories, fetch_index, search, load_local_index}
use os.tools.pkg.pkg_resolver.{resolve, ResolvedSet}
use os.userlib.fs.{read_text, write_text, stat, readdir, mkdir}

# === Shared Data Structures ===

enum PkgStatus:
    Installed
    Available
    Updatable

struct PackageInfo:
    """Unified package view for both CLI and GUI."""
    name: text
    version: text
    installed_version: text
    description: text
    category: text
    size: text
    arch: text
    pkg_type: text
    status: PkgStatus
    dependencies: [text]
    files: [text]
    license: text
    maintainer: text
    checksum: text

struct PkgOperationResult:
    success: bool
    message: text
    packages_affected: [text]

struct PkgProgress:
    """Progress callback data for GUI progress bars."""
    current: i32
    total: i32
    current_name: text
    phase: text         # "resolving", "downloading", "installing", "configuring"
    percent: i32        # 0-100

# === Package Core Service ===

val INSTALLED_DB = "/pkg/installed"
val REPO_DIR = "/pkg/repo"

class PkgCore:
    """Shared package service — stateless operations returning structured data."""
    installed_cache: [PackageInfo]
    available_cache: [PackageInfo]
    repos: [Repository]
    initialized: bool

impl PkgCore:
    static fn new() -> PkgCore:
        PkgCore(
            installed_cache: [],
            available_cache: [],
            repos: [],
            initialized: false
        )

    me init() -> Result<bool, text>:
        """Load installed packages and repository list."""
        # Load repos
        val repo_result = load_repositories()
        if val Ok(repos) = repo_result:
            self.repos = repos

        # Load installed packages
        self.installed_cache = _load_installed_packages()

        # Load available packages from repos
        self.available_cache = _load_available_packages(self.repos)

        self.initialized = true
        return Result.Ok(true)

    # === Query Operations (read-only, return data) ===

    fn list_installed() -> [PackageInfo]:
        """List all installed packages."""
        self.installed_cache

    fn list_available() -> [PackageInfo]:
        """List all available (not installed) packages."""
        var result: [PackageInfo] = []
        for pkg in self.available_cache:
            if _is_in_list(pkg.name, self.installed_cache) == false:
                result.push(pkg)
        return result

    fn list_updatable() -> [PackageInfo]:
        """List packages with updates available."""
        var result: [PackageInfo] = []
        for avail in self.available_cache:
            for inst in self.installed_cache:
                if avail.name == inst.name and avail.version != inst.installed_version:
                    var info = avail
                    info.installed_version = inst.installed_version
                    info.status = PkgStatus.Updatable
                    result.push(info)
        return result

    fn list_all() -> [PackageInfo]:
        """List all packages (installed + available), deduped, with status."""
        var result: [PackageInfo] = []
        # Add installed
        for pkg in self.installed_cache:
            result.push(pkg)
        # Add available (not installed)
        for pkg in self.available_cache:
            if _is_in_list(pkg.name, self.installed_cache) == false:
                result.push(pkg)
        # Check for updates
        var i = 0
        while i < result.len():
            if result[i].status == PkgStatus.Installed:
                for avail in self.available_cache:
                    if avail.name == result[i].name and avail.version != result[i].version:
                        result[i].status = PkgStatus.Updatable
                        break
            i = i + 1
        return result

    fn search_packages(query: text) -> [PackageInfo]:
        """Search all packages (installed + available) by name or description."""
        val all = self.list_all()
        var result: [PackageInfo] = []
        val lower_q = query.lower()
        for pkg in all:
            if pkg.name.lower().contains(lower_q) or pkg.description.lower().contains(lower_q):
                result.push(pkg)
        return result

    fn get_info(name: text) -> PackageInfo?:
        """Get detailed info for a package by name."""
        for pkg in self.installed_cache:
            if pkg.name == name:
                return pkg
        for pkg in self.available_cache:
            if pkg.name == name:
                return pkg
        return nil

    fn get_dependencies(name: text) -> [text]:
        """Get dependency list for a package."""
        val info = self.get_info(name)
        if val Some(pkg) = info:
            return pkg.dependencies
        return []

    fn count_by_status() -> (i32, i32, i32):
        """Return (installed, available, updatable) counts."""
        val all = self.list_all()
        var inst = 0
        var avail = 0
        var upd = 0
        for pkg in all:
            match pkg.status:
                PkgStatus.Installed: inst = inst + 1
                PkgStatus.Available: avail = avail + 1
                PkgStatus.Updatable: upd = upd + 1
        return (inst, avail, upd)

    # === Mutating Operations (return results, never print) ===

    me install(name: text) -> PkgOperationResult:
        """Install a package and its dependencies."""
        if _is_in_list(name, self.installed_cache):
            return PkgOperationResult(success: false, message: "Already installed: {name}", packages_affected: [])

        # Resolve dependencies
        var available_manifests: [PackageManifest] = []
        for repo in self.repos:
            val idx_result = fetch_index(repo)
            if val Ok(idx) = idx_result:
                for pkg in idx.packages:
                    available_manifests.push(pkg)

        var installed_manifests: [PackageManifest] = []
        for pkg in self.installed_cache:
            installed_manifests.push(_info_to_manifest(pkg))

        val resolve_result = resolve(name, available_manifests, installed_manifests)
        if val Err(e) = resolve_result:
            return PkgOperationResult(success: false, message: "Dependency resolution failed: {e}", packages_affected: [])
        val resolved = resolve_result.unwrap()

        # Install each package
        var installed: [text] = []
        for pkg_name in resolved.install_order:
            if _is_in_list(pkg_name, self.installed_cache):
                pass_dn
            else:
                val install_result = _do_install_single(pkg_name, resolved.packages)
                if val Err(e) = install_result:
                    return PkgOperationResult(success: false, message: "Failed to install {pkg_name}: {e}", packages_affected: installed)
                val manifest = install_result.unwrap()
                self.installed_cache.push(_manifest_to_info(manifest, PkgStatus.Installed))
                installed.push(pkg_name)

        return PkgOperationResult(success: true, message: "Installed {name} ({installed.len()} packages)", packages_affected: installed)

    me remove(name: text) -> PkgOperationResult:
        """Remove a package (if no reverse dependencies)."""
        if _is_in_list(name, self.installed_cache) == false:
            return PkgOperationResult(success: false, message: "Not installed: {name}", packages_affected: [])

        # Check reverse dependencies
        for pkg in self.installed_cache:
            if pkg.name != name:
                for dep in pkg.dependencies:
                    val dep_name = dep.split(">=")[0]
                    if dep_name == name:
                        return PkgOperationResult(success: false, message: "Cannot remove {name}: required by {pkg.name}", packages_affected: [])

        # Find and remove
        var target: PackageInfo? = nil
        var new_list: [PackageInfo] = []
        for pkg in self.installed_cache:
            if pkg.name == name:
                target = pkg
            else:
                new_list.push(pkg)

        if val Some(pkg) = target:
            # Remove files
            for f in pkg.files:
                os.userlib.fs.remove(f)
            # Remove manifest
            os.userlib.fs.remove("{INSTALLED_DB}/{name}.sdn")
            self.installed_cache = new_list

        return PkgOperationResult(success: true, message: "Removed {name}", packages_affected: [name])

    me update(name: text) -> PkgOperationResult:
        """Update a single package to latest version."""
        val rm_result = self.remove(name)
        if rm_result.success == false:
            return PkgOperationResult(success: false, message: "Cannot update {name}: {rm_result.message}", packages_affected: [])
        return self.install(name)

    me update_all() -> PkgOperationResult:
        """Update all updatable packages."""
        val updatable = self.list_updatable()
        var updated: [text] = []
        for pkg in updatable:
            val result = self.update(pkg.name)
            if result.success:
                updated.push(pkg.name)
        return PkgOperationResult(success: true, message: "Updated {updated.len()} packages", packages_affected: updated)

# === Internal Helpers ===

fn _load_installed_packages() -> [PackageInfo]:
    """Load installed package manifests from /pkg/installed/."""
    var packages: [PackageInfo] = []
    val entries = readdir(INSTALLED_DB)
    for entry in entries:
        if entry.ends_with(".sdn"):
            val content = read_text("{INSTALLED_DB}/{entry}")
            val result = parse_manifest(content)
            if val Ok(manifest) = result:
                packages.push(_manifest_to_info(manifest, PkgStatus.Installed))
    return packages

fn _load_available_packages(repos: [Repository]) -> [PackageInfo]:
    """Load available packages from all repositories."""
    var packages: [PackageInfo] = []
    for repo in repos:
        val idx_result = fetch_index(repo)
        if val Ok(idx) = idx_result:
            for manifest in idx.packages:
                packages.push(_manifest_to_info(manifest, PkgStatus.Available))
    return packages

fn _manifest_to_info(m: PackageManifest, status: PkgStatus) -> PackageInfo:
    PackageInfo(
        name: m.name,
        version: m.version.to_text(),
        installed_version: if status == PkgStatus.Installed: m.version.to_text() else: "",
        description: m.description,
        category: _guess_category(m.name),
        size: "{m.files.len()} files",
        arch: "any",
        pkg_type: "app",
        status: status,
        dependencies: m.dependencies,
        files: m.files,
        license: "",
        maintainer: "",
        checksum: m.checksum
    )

fn _info_to_manifest(info: PackageInfo) -> PackageManifest:
    val ver_result = PackageVersion.parse(info.version)
    val version = if val Ok(v) = ver_result: v else: PackageVersion(major: 0, minor: 0, patch: 0)
    PackageManifest(
        name: info.name,
        version: version,
        description: info.description,
        dependencies: info.dependencies,
        files: info.files,
        checksum: info.checksum
    )

fn _is_in_list(name: text, packages: [PackageInfo]) -> bool:
    for pkg in packages:
        if pkg.name == name:
            return true
    return false

fn _guess_category(name: text) -> text:
    """Guess category from package name prefix."""
    if name.starts_with("simpleos-kernel") or name.starts_with("simpleos-core") or name.starts_with("simple-init") or name.starts_with("simple-drivers"):
        return "System"
    else if name.starts_with("simple-compiler") or name.starts_with("simple-lsp") or name.starts_with("simple-debug") or name.starts_with("simple-build") or name.starts_with("simple-test"):
        return "Development"
    else if name.starts_with("simple-browser") or name.starts_with("simple-ssh") or name.starts_with("simple-curl") or name.starts_with("simple-dns") or name.starts_with("simple-ftp"):
        return "Network"
    else if name.starts_with("simple-snake") or name.starts_with("simple-mine") or name.starts_with("simple-tetris") or name.starts_with("simple-chess") or name.starts_with("simple-2048"):
        return "Games"
    return "Utilities"

fn _do_install_single(name: text, resolved: [PackageManifest]) -> Result<PackageManifest, text>:
    """Install a single package from resolved set."""
    for pkg in resolved:
        if pkg.name == name:
            for file_path in pkg.files:
                val src = "{REPO_DIR}/{name}/{file_path}"
                val content = read_text(src)
                write_text(file_path, content)
            # Register
            mkdir(INSTALLED_DB)
            val manifest_content = serialize_manifest(pkg)
            write_text("{INSTALLED_DB}/{name}.sdn", manifest_content)
            return Result.Ok(pkg)
    return Result.Err("Package not found in resolved set: {name}")
