# yes — Repeatedly output a string
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.tools.shell.shell_helpers.{write_line}

fn tool_yes(args: [text], terminal: Terminal) -> i32:
    """Repeatedly output a string (default: 'y'). Outputs 1000 lines max."""
    val msg = if args.len() > 0: args[0] else: "y"
    var count = 0
    while count < 1000:
        write_line(terminal, msg)
        count = count + 1
    return 0
