# mktemp — Create temporary file or directory
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{write_line, write_error}

extern fn clock_ms() -> i64

fn tool_mktemp(vfs: VfsManager?, args: [text], terminal: Terminal) -> i32:
    """Create a temporary file or directory and print its path.

    Flags: -d (create directory instead of file)
    """
    if vfs == nil:
        write_error(terminal, "mktemp: no filesystem mounted")
        return 1

    var make_dir = false
    for arg in args:
        if arg == "-d":
            make_dir = true

    # Generate unique name using clock
    val ts = clock_ms()
    val name = "tmp.{ts}"
    val path = "/tmp/{name}"

    if make_dir:
        val result = vfs.mkdir(path)
        if result.is_err():
            write_error(terminal, "mktemp: {result.unwrap_err()}")
            return 1
    else:
        val result = vfs.write_text(path, "")
        if result.is_err():
            write_error(terminal, "mktemp: {result.unwrap_err()}")
            return 1

    write_line(terminal, path)
    return 0
