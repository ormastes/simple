# POSIX-over-NVFS shim capability set.
#
# Exposes POSIX-visible features only. COW / Snapshot / Dedup / Checksum /
# Reflink are deliberately withheld because the shim emulates in-place
# semantics over arenas; callers that want those features must speak to
# NvfsDriver (append-only) directly.
#
# Phase 9 B2 — doc/05_design/nvfs_posix_wrapper.md §6.

use std.fs_driver.capability.{Capability, CapabilitySet}

fn nvfs_posix_capabilities() -> CapabilitySet:
    """Return the POSIX-shim capability set.

    Present: PosixCompat, CaseSensitive, Hardlinks, SparseFiles, LargeFiles,
    UnicodeNames, AsyncIo.

    Absent (by design): COW, Snapshot, Clone, Dedup, Checksum, SelfHeal,
    SendReceive, Compress, Encrypt, Quota, Reflink, Atime, Xattr, Acl,
    CaseFold.
    """
    var s = CapabilitySet.empty()
    s = s.with(Capability.PosixCompat)
    s = s.with(Capability.CaseSensitive)
    s = s.with(Capability.Hardlinks)
    s = s.with(Capability.SparseFiles)
    s = s.with(Capability.LargeFiles)
    s = s.with(Capability.UnicodeNames)
    s = s.with(Capability.AsyncIo)
    s
