# FAT32 Filesystem Trait Implementation
#
# MDSOC: feature dimension, vfs layer
# Implements the Filesystem trait methods for Fat32Driver and provides
# the PathParts helper used by both the trait implementation and fat32.spl.
# Extracted from fat32.spl to keep file sizes under 800 lines.

use os.services.vfs.vfs.{Filesystem, SeekWhence}
use os.kernel.types.fs_types.{FileFlags, FsNode, FsNodeKind, DirEntry}
use os.services.fat32.fat32.{Fat32Driver, Fat32DirEntry, Fat32OpenFile, FAT32_ATTR_DIRECTORY, FAT32_ATTR_LFN, FAT32_EOC, _fat32_unwrap_err}
use os.services.fat32.fat32_write.{Fat32WriteContext, DIR_ENTRY_SIZE}
use os.services.fat32.fat32_write_helpers.{format_8_3_name}
use common.string_core.{str_char_at}

# ============================================================================
# Path Helper — Split path into parent directory and basename
# ============================================================================

struct PathParts:
    """Result of splitting a path into parent directory and filename."""
    parent: text
    name: text

fn _split_path_parent(path: text) -> PathParts:
    """Split "/foo/bar/baz.txt" into parent="/foo/bar" and name="baz.txt".

    For paths with no directory component (e.g., "file.txt"), parent is "/".
    """
    var last_slash: i32 = -1
    var ci = 0
    while ci < path.len():
        val ch = str_char_at(path, ci)
        if ch == "/":
            last_slash = ci.to_i32()
        ci = ci + 1

    if last_slash < 0:
        return PathParts(parent: "/", name: path)
    if last_slash == 0:
        var name_part = ""
        var j = 0
        while j < path.len():
            val ch = str_char_at(path, j)
            if j > 0:
                name_part = name_part + ch
            j = j + 1
        return PathParts(parent: "/", name: name_part)

    var parent = ""
    var name = ""
    var k = 0
    while k < path.len():
        val ch = str_char_at(path, k)
        if k < last_slash:
            parent = parent + ch
        else:
            if k > last_slash:
                name = name + ch
        k = k + 1
    PathParts(parent: parent, name: name)

fn _mark_entry_deleted(ctx: Fat32WriteContext, dir_cluster: u32, name: text) -> Result<bool, text>:
    """Mark a directory entry as deleted (0xE5) without freeing its clusters.

    Used by rename to remove the old entry while preserving the cluster chain.
    """
    var write_ctx: Fat32WriteContext = ctx
    val upper_name = name.upper()
    var current = dir_cluster
    var max_iter: u32 = 100000
    while current >= 2 and max_iter > 0:
        val data_result = write_ctx.read_cluster(current)
        if data_result.is_err():
            return Err(_fat32_unwrap_err(data_result))
        var data = data_result.unwrap()

        val entries_per_cluster = (write_ctx.sectors_per_cluster * write_ctx.bytes_per_sector) / 32
        var idx: u32 = 0
        while idx < entries_per_cluster:
            val off = (idx * 32).to_i32()
            val first_byte = data[off]
            if first_byte == 0x00:
                return Err("entry not found: {name}")
            if first_byte == 0xE5 or data[off + 11] == FAT32_ATTR_LFN:
                idx = idx + 1
                continue
            var entry_name = ""
            var ni = 0
            while ni < 8:
                val ch = data[off + ni]
                if ch != 0x20 and ch != 0x00:
                    entry_name = entry_name + ch.chr()
                ni = ni + 1
            var ext_name = ""
            ni = 0
            while ni < 3:
                val ch = data[off + 8 + ni]
                if ch != 0x20 and ch != 0x00:
                    ext_name = ext_name + ch.chr()
                ni = ni + 1
            if ext_name.len() > 0:
                entry_name = entry_name + "." + ext_name
            if entry_name.upper() == upper_name:
                data[off] = 0xE5
                return write_ctx.write_cluster_data(current, data)
            idx = idx + 1

        val fat_offset = current * 4
        val fat_sector = write_ctx.reserved_sectors.to_u64() + (fat_offset / write_ctx.bytes_per_sector).to_u64()
        val entry_offset = (fat_offset % write_ctx.bytes_per_sector).to_i32()
        val fat_result = write_ctx.device.read_sector(fat_sector)
        if fat_result.is_err():
            return Err("failed to read FAT sector")
        val fat_buf = fat_result.unwrap()
        val next = (((fat_buf[entry_offset + 3].to_u32() << 24) |
                     (fat_buf[entry_offset + 2].to_u32() << 16) |
                     (fat_buf[entry_offset + 1].to_u32() << 8) |
                     fat_buf[entry_offset].to_u32()) & 0x0FFFFFFF)
        if next >= FAT32_EOC or next < 2:
            break
        current = next
        max_iter = max_iter - 1

    Err("entry not found: {name}")

# ============================================================================
# Filesystem trait implementation for Fat32Driver
# ============================================================================

impl Filesystem for Fat32Driver:
    fn fs_name() -> text: "fat32"

    me fn mount(device: text, options: text) -> Result<bool, text>:
        val bpb_result = self.read_bpb()
        if bpb_result.is_err():
            return Err(_fat32_unwrap_err(bpb_result))

        val bpb = bpb_result.unwrap()
        self.bytes_per_sector = bpb.bytes_per_sector.to_u32()
        self.sectors_per_cluster = bpb.sectors_per_cluster.to_u32()
        self.reserved_sectors = bpb.reserved_sectors.to_u32()
        self.num_fats = bpb.num_fats.to_u32()
        self.fat_size = bpb.fat_size_32
        self.root_cluster = bpb.root_cluster

        if self.bytes_per_sector == 0:
            return Err("invalid BPB: bytes_per_sector=0")
        if self.sectors_per_cluster == 0:
            return Err("invalid BPB: sectors_per_cluster=0")
        if self.num_fats == 0:
            return Err("invalid BPB: num_fats=0")
        if self.fat_size == 0:
            return Err("invalid BPB: fat_size=0")

        self.data_start_sector = self.reserved_sectors + (self.num_fats * self.fat_size)

        val total_sectors = bpb.total_sectors_32
        if total_sectors <= self.data_start_sector:
            return Err("invalid BPB: total_sectors <= data_start_sector")
        val data_sectors = total_sectors - self.data_start_sector
        self.total_clusters = data_sectors / self.sectors_per_cluster

        self.mounted = true
        Ok(true)

    me fn unmount() -> Result<bool, text>:
        self.open_files = []
        self.mounted = false
        Ok(true)

    me fn open(path: text, flags: FileFlags) -> Result<u64, text>:
        """Open a file by traversing directory tree.

        If the file does not exist and flags.create is set, creates
        a new file at the given path using Fat32WriteContext.
        """
        if not self.mounted:
            return Err("filesystem not mounted")
        val result = self.resolve_path(path)
        if result.is_err():
            return Err(_fat32_unwrap_err(result))
        val entry_opt = result.unwrap()
        if not entry_opt.?:
            if flags.create:
                val parent_and_name = _split_path_parent(path)
                val parent_path = parent_and_name.parent
                val file_name = parent_and_name.name
                val parent_result = self.resolve_path(parent_path)
                if parent_result.is_err():
                    return Err(_fat32_unwrap_err(parent_result))
                val parent_opt = parent_result.unwrap()
                if not parent_opt.?:
                    return Err("parent directory not found: {parent_path}")
                val parent_entry = parent_opt
                val parent_cluster = self.entry_first_cluster(parent_entry)
                var ctx = Fat32WriteContext.new(self)
                val create_result = ctx.create_file(parent_cluster, file_name, false)
                if create_result.is_err():
                    return Err(_fat32_unwrap_err(create_result))
                val new_cluster = create_result.unwrap()
                self.device = ctx.device
                val handle = self.next_handle
                self.next_handle = self.next_handle + 1
                val open_file = Fat32OpenFile(
                    handle: handle,
                    first_cluster: new_cluster,
                    current_cluster: new_cluster,
                    current_offset: 0,
                    file_size: 0,
                    dir_cluster: parent_cluster,
                    name: file_name,
                    flags: flags
                )
                self.open_files.push(open_file)
                return Ok(handle)
            return Err("file not found: {path}")
        val entry = entry_opt
        val parent_and_name = _split_path_parent(path)
        val parent_result = self.resolve_path(parent_and_name.parent)
        if parent_result.is_err():
            return Err(_fat32_unwrap_err(parent_result))
        val parent_opt = parent_result.unwrap()
        if not parent_opt.?:
            return Err("parent directory not found: {parent_and_name.parent}")
        val parent_cluster = self.entry_first_cluster(parent_opt)
        val cluster = self.entry_first_cluster(entry)
        val handle = self.next_handle
        self.next_handle = self.next_handle + 1
        val open_file = Fat32OpenFile(
            handle: handle,
            first_cluster: cluster,
            current_cluster: cluster,
            current_offset: 0,
            file_size: entry.file_size.to_u64(),
            dir_cluster: parent_cluster,
            name: parent_and_name.name,
            flags: flags
        )
        self.open_files.push(open_file)
        Ok(handle)

    me fn read(handle: u64, size: u64) -> Result<[u8], text>:
        """Read data from open file following cluster chain."""
        var open_idx = -1
        var scan = 0
        while scan < self.open_files.len():
            if self.open_files[scan].handle == handle:
                open_idx = scan
                break
            scan = scan + 1

        if open_idx < 0:
            return Err("invalid file handle")
        val f = self.open_files[open_idx]
        val remaining = f.file_size - f.current_offset
        val read_size = if size < remaining: size else: remaining
        if read_size == 0:
            return Ok([])

        var result_buf: [u8] = []
        var bytes_read: u64 = 0
        var current_cluster = f.current_cluster
        val cluster_size = (self.sectors_per_cluster * self.bytes_per_sector).to_u64()
        var offset_in_cluster = f.current_offset % cluster_size

        while bytes_read < read_size and not self.is_eoc(current_cluster):
            val data_result = self.read_cluster(current_cluster)
            if data_result.is_err():
                return Err(_fat32_unwrap_err(data_result))
            val data = data_result.unwrap()

            var i = offset_in_cluster
            while i < cluster_size and bytes_read < read_size:
                result_buf.push(data[i.to_i32()])
                bytes_read = bytes_read + 1
                i = i + 1

            val next_result = self.read_fat_entry(current_cluster)
            if next_result.is_err():
                break
            current_cluster = next_result.unwrap()
            offset_in_cluster = 0

        if open_idx >= 0:
            val old = self.open_files[open_idx]
            self.open_files[open_idx] = Fat32OpenFile(
                handle: old.handle,
                first_cluster: old.first_cluster,
                current_cluster: current_cluster,
                current_offset: old.current_offset + bytes_read,
                file_size: old.file_size,
                dir_cluster: old.dir_cluster,
                name: old.name,
                flags: old.flags
            )
        Ok(result_buf)

    me fn write(handle: u64, data: [u8]) -> Result<u64, text>:
        """Write data to an open file at the current offset."""
        var open_idx = -1
        var scan = 0
        while scan < self.open_files.len():
            if self.open_files[scan].handle == handle:
                open_idx = scan
                break
            scan = scan + 1
        if open_idx < 0:
            return Err("invalid file handle")
        val f = self.open_files[open_idx]
        if not f.flags.write:
            return Err("file not opened for writing")

        var ctx = Fat32WriteContext.new(self)

        val write_result = ctx.write_file_data(f.first_cluster, f.current_offset, data)
        if write_result.is_err():
            return Err(_fat32_unwrap_err(write_result))
        val bytes_written = write_result.unwrap()
        self.device = ctx.device

        val new_offset = f.current_offset + bytes_written
        val new_size = if new_offset > f.file_size: new_offset else: f.file_size

        var i = 0
        while i < self.open_files.len():
            if self.open_files[i].handle == handle:
                self.open_files[i] = Fat32OpenFile(
                    handle: handle,
                    first_cluster: f.first_cluster,
                    current_cluster: f.current_cluster,
                    current_offset: new_offset,
                    file_size: new_size,
                    dir_cluster: f.dir_cluster,
                    name: f.name,
                    flags: f.flags
                )
                break
            i = i + 1

        Ok(bytes_written)

    me fn close(handle: u64) -> Result<bool, text>:
        """Close an open file handle."""
        var i = 0
        while i < self.open_files.len():
            if self.open_files[i].handle == handle:
                val file = self.open_files[i]
                if file.flags.write:
                    var ctx = Fat32WriteContext.new(self)
                    val update_result = ctx.update_file_size(file.dir_cluster, file.name, file.file_size.to_u32())
                    if update_result.is_err():
                        return Err(_fat32_unwrap_err(update_result))
                    self.device = ctx.device
                self.open_files.remove(i)
                return Ok(true)
            i = i + 1
        Err("invalid file handle")

    me fn seek(handle: u64, offset: i64, whence: SeekWhence) -> Result<u64, text>:
        """Seek to position in file."""
        var open_idx = -1
        var scan = 0
        while scan < self.open_files.len():
            if self.open_files[scan].handle == handle:
                open_idx = scan
                break
            scan = scan + 1
        if open_idx < 0:
            return Err("invalid file handle")
        val f = self.open_files[open_idx]
        val new_offset = match whence:
            case SeekWhence.Set: offset.to_u64()
            case SeekWhence.Cur: (f.current_offset.to_i64() + offset).to_u64()
            case SeekWhence.End: (f.file_size.to_i64() + offset).to_u64()
        if new_offset > f.file_size:
            return Err("seek beyond end of file")
        if new_offset > 0 and self.sectors_per_cluster == 0:
            return Err("invalid filesystem geometry")
        var cluster = f.first_cluster
        if new_offset > 0:
            val cluster_size = (self.sectors_per_cluster * self.bytes_per_sector).to_u64()
            var clusters_to_skip = new_offset / cluster_size
            if new_offset % cluster_size == 0:
                clusters_to_skip = clusters_to_skip - 1
            while clusters_to_skip > 0:
                val next_result = self.read_fat_entry(cluster)
                if next_result.is_err():
                    return Err(_fat32_unwrap_err(next_result))
                val next = next_result.unwrap()
                if next >= FAT32_EOC:
                    return Err("seek beyond cluster chain")
                cluster = next
                clusters_to_skip = clusters_to_skip - 1
        self.open_files[open_idx] = Fat32OpenFile(
            handle: f.handle,
            first_cluster: f.first_cluster,
            current_cluster: cluster,
            current_offset: new_offset,
            file_size: f.file_size,
            dir_cluster: f.dir_cluster,
            name: f.name,
            flags: f.flags
        )
        Ok(new_offset)

    fn stat(path: text) -> Result<FsNode, text>:
        """Get file metadata by path."""
        if not self.mounted:
            return Err("filesystem not mounted")
        val result = self.resolve_path(path)
        if result.is_err():
            return Err(_fat32_unwrap_err(result))
        val entry_opt = result.unwrap()
        if not entry_opt.?:
            return Err("not found: {path}")
        val entry = entry_opt
        Ok(self.entry_to_fs_node(entry, path))

    fn chmod(path: text, mode: u16) -> Result<bool, text>:
        Err("chmod: FAT32 only supports read-only attribute, not full POSIX permissions")

    fn symlink(target: text, link_path: text) -> Result<bool, text>:
        Err("symlinks not supported on FAT32")

    me fn mkdir(path: text) -> Result<bool, text>:
        """Create a directory with . and .. entries."""
        if not self.mounted:
            return Err("filesystem not mounted")

        val existing = self.resolve_path(path)
        if existing.is_ok():
            val ex = existing.unwrap()
            if ex.?:
                return Err("path already exists: {path}")

        val parent_and_name = _split_path_parent(path)
        val parent_path = parent_and_name.parent
        val dir_name = parent_and_name.name

        val parent_result = self.resolve_path(parent_path)
        if parent_result.is_err():
            return Err(_fat32_unwrap_err(parent_result))
        val parent_opt = parent_result.unwrap()
        if not parent_opt.?:
            return Err("parent directory not found: {parent_path}")
        val parent_entry = parent_opt
        if (parent_entry.attr & FAT32_ATTR_DIRECTORY) == 0:
            return Err("parent is not a directory: {parent_path}")
        val parent_cluster = self.entry_first_cluster(parent_entry)

        var ctx = Fat32WriteContext.new(self)
        val create_result = ctx.create_directory(parent_cluster, dir_name)
        if create_result.is_err():
            return Err(_fat32_unwrap_err(create_result))
        self.device = ctx.device
        Ok(true)

    me fn rmdir(path: text) -> Result<bool, text>:
        """Remove an empty directory."""
        if not self.mounted:
            return Err("filesystem not mounted")

        val dir_result = self.resolve_path(path)
        if dir_result.is_err():
            return Err(_fat32_unwrap_err(dir_result))
        val dir_opt = dir_result.unwrap()
        if not dir_opt.?:
            return Err("directory not found: {path}")
        val dir_entry = dir_opt
        if (dir_entry.attr & FAT32_ATTR_DIRECTORY) == 0:
            return Err("not a directory: {path}")

        val contents = self.readdir(path)
        if contents.is_err():
            return Err(_fat32_unwrap_err(contents))
        if contents.unwrap().len() > 0:
            return Err("directory not empty: {path}")

        val parent_and_name = _split_path_parent(path)
        val parent_path = parent_and_name.parent
        val dir_name = parent_and_name.name

        val parent_result = self.resolve_path(parent_path)
        if parent_result.is_err():
            return Err(_fat32_unwrap_err(parent_result))
        val parent_opt = parent_result.unwrap()
        if not parent_opt.?:
            return Err("parent not found: {parent_path}")
        val parent_cluster = self.entry_first_cluster(parent_opt)

        var ctx = Fat32WriteContext.new(self)
        val delete_result = ctx.delete_file(parent_cluster, dir_name)
        if delete_result.is_err():
            return Err(_fat32_unwrap_err(delete_result))
        self.device = ctx.device
        delete_result

    fn readdir(path: text) -> Result<[DirEntry], text>:
        """List directory contents."""
        if not self.mounted:
            return Err("filesystem not mounted")
        val result = self.resolve_path(path)
        if result.is_err():
            return Err(_fat32_unwrap_err(result))
        val entry_opt = result.unwrap()
        if not entry_opt.?:
            return Err("directory not found: {path}")
        val entry = entry_opt
        if (entry.attr & FAT32_ATTR_DIRECTORY) == 0:
            return Err("not a directory: {path}")

        val dir_cluster = self.entry_first_cluster(entry)
        val chain_result = self.follow_cluster_chain(dir_cluster)
        if chain_result.is_err():
            return Err(_fat32_unwrap_err(chain_result))
        val chain = chain_result.unwrap()

        var entries: [DirEntry] = []
        for cluster in chain:
            val data_result = self.read_cluster(cluster)
            if data_result.is_err():
                return Err(_fat32_unwrap_err(data_result))
            val data = data_result.unwrap()

            val entries_per_cluster = (self.sectors_per_cluster * self.bytes_per_sector) / 32
            var idx: u32 = 0
            var pending_lfn = ""
            while idx < entries_per_cluster:
                val off = (idx * 32).to_i32()
                val first_byte = data[off]
                if first_byte == 0x00:
                    return Ok(entries)
                if first_byte == 0xE5:
                    pending_lfn = ""
                    idx = idx + 1
                    continue
                if data[off + 11] == FAT32_ATTR_LFN:
                    pending_lfn = self.parse_lfn_name_part(data, off) + pending_lfn
                    idx = idx + 1
                    continue
                val short_name = self.parse_8_3_name(data, off)
                if short_name == "." or short_name == "..":
                    pending_lfn = ""
                    idx = idx + 1
                    continue
                val name = if pending_lfn.len() > 0: pending_lfn else: short_name

                val dir_entry = Fat32DirEntry(
                    name: [data[off], data[off+1], data[off+2], data[off+3],
                           data[off+4], data[off+5], data[off+6], data[off+7],
                           data[off+8], data[off+9], data[off+10]],
                    attr: data[off + 11],
                    nt_reserved: 0, create_time_tenth: 0,
                    create_time: 0, create_date: 0, access_date: 0,
                    cluster_high: (data[off+21].to_u16() << 8) | data[off+20].to_u16(),
                    modify_time: 0, modify_date: 0,
                    cluster_low: (data[off+27].to_u16() << 8) | data[off+26].to_u16(),
                    file_size: ((data[off+31].to_u32() << 24) | (data[off+30].to_u32() << 16) | (data[off+29].to_u32() << 8) | data[off+28].to_u32())
                )
                val node = self.entry_to_fs_node(dir_entry, name)
                entries.push(DirEntry(name: name, node: node))
                pending_lfn = ""
                idx = idx + 1
        Ok(entries)

    me fn unlink(path: text) -> Result<bool, text>:
        """Delete a file."""
        if not self.mounted:
            return Err("filesystem not mounted")

        val file_result = self.resolve_path(path)
        if file_result.is_err():
            return Err(_fat32_unwrap_err(file_result))
        val file_opt = file_result.unwrap()
        if not file_opt.?:
            return Err("file not found: {path}")
        val file_entry = file_opt
        if (file_entry.attr & FAT32_ATTR_DIRECTORY) != 0:
            return Err("cannot unlink directory (use rmdir): {path}")

        val parent_and_name = _split_path_parent(path)
        val parent_path = parent_and_name.parent
        val file_name = parent_and_name.name

        val parent_result = self.resolve_path(parent_path)
        if parent_result.is_err():
            return Err(_fat32_unwrap_err(parent_result))
        val parent_opt = parent_result.unwrap()
        if not parent_opt.?:
            return Err("parent not found: {parent_path}")
        val parent_cluster = self.entry_first_cluster(parent_opt)

        var ctx = Fat32WriteContext.new(self)
        val delete_result = ctx.delete_file(parent_cluster, file_name)
        if delete_result.is_err():
            return Err(_fat32_unwrap_err(delete_result))
        self.device = ctx.device
        delete_result

    me fn rename(old_path: text, new_path: text) -> Result<bool, text>:
        """Rename or move a file/directory."""
        if not self.mounted:
            return Err("filesystem not mounted")

        val src_result = self.resolve_path(old_path)
        if src_result.is_err():
            return Err(_fat32_unwrap_err(src_result))
        val src_opt = src_result.unwrap()
        if not src_opt.?:
            return Err("source not found: {old_path}")
        val src_entry = src_opt

        val dst_check = self.resolve_path(new_path)
        if dst_check.is_ok():
            val dc = dst_check.unwrap()
            if dc.?:
                return Err("destination already exists: {new_path}")

        val old_parent_and_name = _split_path_parent(old_path)
        val new_parent_and_name = _split_path_parent(new_path)

        val old_parent_result = self.resolve_path(old_parent_and_name.parent)
        if old_parent_result.is_err():
            return Err(_fat32_unwrap_err(old_parent_result))
        val old_parent_opt = old_parent_result.unwrap()
        if not old_parent_opt.?:
            return Err("source parent not found")
        val old_parent_cluster = self.entry_first_cluster(old_parent_opt)

        val new_parent_result = self.resolve_path(new_parent_and_name.parent)
        if new_parent_result.is_err():
            return Err(_fat32_unwrap_err(new_parent_result))
        val new_parent_opt = new_parent_result.unwrap()
        if not new_parent_opt.?:
            return Err("destination parent not found")
        val new_parent_cluster = self.entry_first_cluster(new_parent_opt)

        var ctx = Fat32WriteContext.new(self)

        val new_name_bytes = format_8_3_name(new_parent_and_name.name)
        val slot_result = ctx.find_free_dir_slot(new_parent_cluster)
        if slot_result.is_err():
            return Err(_fat32_unwrap_err(slot_result))
        val slot = slot_result.unwrap()

        val new_entry = Fat32DirEntry(
            name: new_name_bytes,
            attr: src_entry.attr,
            nt_reserved: src_entry.nt_reserved,
            create_time_tenth: src_entry.create_time_tenth,
            create_time: src_entry.create_time,
            create_date: src_entry.create_date,
            access_date: src_entry.access_date,
            cluster_high: src_entry.cluster_high,
            modify_time: src_entry.modify_time,
            modify_date: src_entry.modify_date,
            cluster_low: src_entry.cluster_low,
            file_size: src_entry.file_size
        )
        val write_result = ctx.write_dir_entry(slot, new_entry)
        if write_result.is_err():
            return Err(_fat32_unwrap_err(write_result))

        val del_result = _mark_entry_deleted(ctx, old_parent_cluster, old_parent_and_name.name)
        if del_result.is_err():
            return Err(_fat32_unwrap_err(del_result))

        Ok(true)
