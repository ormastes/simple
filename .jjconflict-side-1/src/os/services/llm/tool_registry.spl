# MCP Tool Registry — OS Tool Definitions
#
# Registers all SimpleOS MCP tools with their schemas.
# Uses the same JSON builder pattern as the existing MCP SDK
# (std.nogc_async_mut.mcp.helpers_compat).
#
# Tools are grouped by category:
#   File:    file_read, file_write, file_list, file_search
#   Process: process_list, process_spawn, process_kill
#   Window:  window_create, window_close, window_list, window_focus
#   Widget:  widget_set, widget_read, widget_action
#   UIAccess: ui_access_snapshot, ui_access_surface, ui_access_find, ui_access_act, ui_access_history, ui_access_observe, ui_access_state, ui_access_query, ui_access_ensure, ui_access_value, ui_access_adapter_snapshot, ui_access_visual_probe
#   Screen:  screenshot, screen_read_text
#   System:  system_info, system_exec

use std.nogc_async_mut.mcp.core.{ToolHandler, create_tool_handler}
use std.nogc_async_mut.mcp.handler_registry.{register_tool_handler}
use os.services.llm.tool_schemas_file_proc.{schema_file_read, schema_file_write, schema_file_list, schema_file_search, schema_process_list, schema_process_spawn, schema_process_kill}
use os.services.llm.tool_schemas_window_widget.{schema_window_create, schema_window_close, schema_window_list, schema_window_focus, schema_widget_set, schema_widget_read, schema_widget_action}
use os.services.llm.tool_schemas_ui_access.{schema_ui_access_snapshot, schema_ui_access_surface, schema_ui_access_find, schema_ui_access_act, schema_ui_access_history, schema_ui_access_observe, schema_ui_access_state, schema_ui_access_query, schema_ui_access_ensure, schema_ui_access_value, schema_ui_access_adapter_snapshot, schema_ui_access_visual_probe}
use os.services.llm.tool_schemas_screen_system.{schema_screenshot, schema_screen_read_text, schema_system_info, schema_system_exec}

# =========================================================================
# JSON Helpers (inlined for isolation, same pattern as api_tools.spl)
# =========================================================================

fn _js(s: text) -> text:
    "\"" + s + "\""

fn _jp(key: text, value: text) -> text:
    "\"" + key + "\":" + value

fn _jo1(p1: text) -> text:
    "{" + p1 + "}"

fn _jo2(p1: text, p2: text) -> text:
    "{" + p1 + "," + p2 + "}"

fn _jo3(p1: text, p2: text, p3: text) -> text:
    "{" + p1 + "," + p2 + "," + p3 + "}"

fn _jo4(p1: text, p2: text, p3: text, p4: text) -> text:
    "{" + p1 + "," + p2 + "," + p3 + "," + p4 + "}"

# =========================================================================
# Registration Entry Point
# =========================================================================

fn register_os_tools():
    """Register all OS MCP tools with the handler registry.

    Called during init service startup (service #5: LLM MCP server)."""
    # File tools
    register_tool_handler(create_tool_handler(
        "file_read", "Read file contents from the OS filesystem",
        schema_file_read(), "os.services.llm.mcp_os_server", "tool_file_read"
    ))
    register_tool_handler(create_tool_handler(
        "file_write", "Write content to a file on the OS filesystem",
        schema_file_write(), "os.services.llm.mcp_os_server", "tool_file_write"
    ))
    register_tool_handler(create_tool_handler(
        "file_list", "List directory contents",
        schema_file_list(), "os.services.llm.mcp_os_server", "tool_file_list"
    ))
    register_tool_handler(create_tool_handler(
        "file_search", "Search files by name pattern",
        schema_file_search(), "os.services.llm.mcp_os_server", "tool_file_search"
    ))

    # Process tools
    register_tool_handler(create_tool_handler(
        "process_list", "List running processes with PID, name, state, and CPU%",
        schema_process_list(), "os.services.llm.mcp_os_server", "tool_process_list"
    ))
    register_tool_handler(create_tool_handler(
        "process_spawn", "Spawn a new process from a binary path",
        schema_process_spawn(), "os.services.llm.mcp_os_server", "tool_process_spawn"
    ))
    register_tool_handler(create_tool_handler(
        "process_kill", "Kill a running process by PID",
        schema_process_kill(), "os.services.llm.mcp_os_server", "tool_process_kill"
    ))

    # Window tools
    register_tool_handler(create_tool_handler(
        "window_create", "Create a new window with title and dimensions",
        schema_window_create(), "os.services.llm.mcp_os_server", "tool_window_create"
    ))
    register_tool_handler(create_tool_handler(
        "window_close", "Close a window by ID",
        schema_window_close(), "os.services.llm.mcp_os_server", "tool_window_close"
    ))
    register_tool_handler(create_tool_handler(
        "window_list", "List all open windows with ID, title, size, and focus state",
        schema_window_list(), "os.services.llm.mcp_os_server", "tool_window_list"
    ))
    register_tool_handler(create_tool_handler(
        "window_focus", "Focus a window by ID",
        schema_window_focus(), "os.services.llm.mcp_os_server", "tool_window_focus"
    ))

    # Widget tools (LLM-friendly GUI)
    register_tool_handler(create_tool_handler(
        "widget_set", "Set window contents using widget DSL. Renders to both GUI and CLI.",
        schema_widget_set(), "os.services.llm.mcp_os_server", "tool_widget_set"
    ))
    register_tool_handler(create_tool_handler(
        "widget_read", "Read current widget tree as text description. LLM can inspect UI state.",
        schema_widget_read(), "os.services.llm.mcp_os_server", "tool_widget_read"
    ))
    register_tool_handler(create_tool_handler(
        "widget_action", "Trigger a UI action (button click, menu select) on a window",
        schema_widget_action(), "os.services.llm.mcp_os_server", "tool_widget_action"
    ))

    # Canonical UI access tools
    register_tool_handler(create_tool_handler(
        "ui_access_snapshot", "Read the canonical UI access snapshot across all surfaces",
        schema_ui_access_snapshot(), "os.services.llm.mcp_os_server", "tool_ui_access_snapshot"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_surface", "Read one UI surface and its nodes from the canonical access model",
        schema_ui_access_surface(), "os.services.llm.mcp_os_server", "tool_ui_access_surface"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_find", "Find canonical UI nodes by surface, kind, text, or focus state",
        schema_ui_access_find(), "os.services.llm.mcp_os_server", "tool_ui_access_find"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_act", "Dispatch an action against a canonical UI node reference",
        schema_ui_access_act(), "os.services.llm.mcp_os_server", "tool_ui_access_act"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_history", "Read recent canonical UI access events for all surfaces or one surface",
        schema_ui_access_history(), "os.services.llm.mcp_os_server", "tool_ui_access_history"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_observe", "Declaratively observe the current UI access state for a node, surface, or filtered query",
        schema_ui_access_observe(), "os.services.llm.mcp_os_server", "tool_ui_access_observe"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_state", "Read or set declarative UI state for a surface or canonical node",
        schema_ui_access_state(), "os.services.llm.mcp_os_server", "tool_ui_access_state"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_query", "Query canonical UI nodes with structured JSON results",
        schema_ui_access_query(), "os.services.llm.mcp_os_server", "tool_ui_access_query"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_ensure", "Ensure canonical UI state satisfies a bounded declarative expectation",
        schema_ui_access_ensure(), "os.services.llm.mcp_os_server", "tool_ui_access_ensure"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_value", "Read or set typed values on value-bearing canonical UI nodes",
        schema_ui_access_value(), "os.services.llm.mcp_os_server", "tool_ui_access_value"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_adapter_snapshot", "Read an additive adapter-backed snapshot envelope for a UI surface",
        schema_ui_access_adapter_snapshot(), "os.services.llm.mcp_os_server", "tool_ui_access_adapter_snapshot"
    ))
    register_tool_handler(create_tool_handler(
        "ui_access_visual_probe", "Read a vision-sidecar probe for a UI surface",
        schema_ui_access_visual_probe(), "os.services.llm.mcp_os_server", "tool_ui_access_visual_probe"
    ))

    # Screen tools
    register_tool_handler(create_tool_handler(
        "screenshot", "Get text description of entire screen: windows, positions, widget summaries",
        schema_screenshot(), "os.services.llm.mcp_os_server", "tool_screenshot"
    ))
    register_tool_handler(create_tool_handler(
        "screen_read_text", "Extract all visible text from screen (accessibility)",
        schema_screen_read_text(), "os.services.llm.mcp_os_server", "tool_screen_read_text"
    ))

    # System tools
    register_tool_handler(create_tool_handler(
        "system_info", "Get system information: memory, CPU, uptime, hostname",
        schema_system_info(), "os.services.llm.mcp_os_server", "tool_system_info"
    ))
    register_tool_handler(create_tool_handler(
        "system_exec", "Execute a shell command and return output",
        schema_system_exec(), "os.services.llm.mcp_os_server", "tool_system_exec"
    ))
