# UI Access Resolver
#
# Shared read-side resolver for internal snapshots, adapter envelopes, and
# vision-sidecar probes.

use common.ui.session.{UISession}
use common.ui.access.{UiAccessSnapshot, UiAccessSurface}
use common.ui.access_source.{UiAccessSourceMeta, UiAccessAdapterTarget, UiAccessSnapshotEnvelope, ui_access_source_meta, ui_access_adapter_target_for_snapshot, ui_access_adapter_target, ui_access_snapshot_envelope}
use common.ui.access_adapter.{UiAccessAdapterRegistry}
use common.ui.access_vision.{UiAccessVisionCaptureResult, ui_access_visual_probe_from_snapshot}

fn ui_access_resolve_internal(session: UISession, surface_id: text) -> UiAccessSnapshotEnvelope:
    val snapshot = session.access_snapshot()
    val resolved_surface_id = _resolve_surface_id(snapshot, surface_id)
    val surface = _find_surface(snapshot, resolved_surface_id)
    val source = _source_from_snapshot(snapshot, resolved_surface_id, surface)
    val target = ui_access_adapter_target_for_snapshot(source, snapshot.mode, resolved_surface_id)
    return ui_access_snapshot_envelope(source, target, snapshot, [])

fn ui_access_resolve_adapter(session: UISession, registry: UiAccessAdapterRegistry, surface_id: text) -> Result<UiAccessSnapshotEnvelope, text>:
    val snapshot = session.access_snapshot()
    val resolved_surface_id = _resolve_surface_id(snapshot, surface_id)
    if resolved_surface_id == "":
        return Err("missing surface_id")
    val surface = _find_surface(snapshot, resolved_surface_id)
    if surface == nil:
        return Err("surface {resolved_surface_id} not found")
    val source = _source_from_snapshot(snapshot, resolved_surface_id, surface)
    val target = ui_access_adapter_target(
        source,
        "snapshot",
        snapshot.mode,
        snapshot.active_surface,
        resolved_surface_id,
        surface.window_id,
        surface.app_id,
        surface.title,
        false,
        0
    )
    return Ok(registry.adapt(target))

fn ui_access_resolve_visual_probe(session: UISession, surface_id: text) -> UiAccessVisionCaptureResult:
    val snapshot = session.access_snapshot()
    val resolved_surface_id = _resolve_surface_id(snapshot, surface_id)
    return ui_access_visual_probe_from_snapshot(snapshot, resolved_surface_id)

fn _resolve_surface_id(snapshot: UiAccessSnapshot, surface_id: text) -> text:
    if surface_id != "":
        return surface_id
    return snapshot.active_surface

fn _find_surface(snapshot: UiAccessSnapshot, surface_id: text) -> UiAccessSurface?:
    for surface in snapshot.surfaces:
        if surface.surface_id == surface_id:
            return surface
    return nil

fn _source_from_snapshot(snapshot: UiAccessSnapshot, surface_id: text, surface: UiAccessSurface?) -> UiAccessSourceMeta:
    if surface != nil:
        return ui_access_source_meta(
            "session",
            surface_id,
            if surface.title != "": surface.title else: surface_id,
            "session://{surface_id}",
            "{snapshot.protocol_version}"
        )
    return ui_access_source_meta("session", surface_id, surface_id, "session://{surface_id}", "{snapshot.protocol_version}")
