# Theme Service — Dynamic Theme Management for SimpleOS
#
# Manages the active design system theme and notifies subscribers
# (Compositor, GUI apps) when the theme changes.
# Supports loading tokens from SDN snapshots.

use common.ui.glass.tokens.{GlassDesignTokens}
use common.ui.theme_package.{default_theme_id, load_theme_package, theme_design_tokens}

extern fn rt_file_read_text(path: text) -> text

# IPC Protocol for Theme Service
# Message types:
# 1: Get Current Theme (returns theme name + tokens)
# 2: Set Theme (updates system-wide theme)
# 3: Subscribe (adds caller port to notification list)

class ThemeService:
    active_theme_name: text
    current_tokens: GlassDesignTokens
    subscribers: [u64] # List of IPC ports to notify

    static fn new() -> ThemeService:
        val pkg = load_theme_package(default_theme_id())
        ThemeService(
            active_theme_name: pkg.id,
            current_tokens: pkg.tokens,
            subscribers: []
        )

    me set_theme(name: text):
        """Update the active theme and notify all subscribers."""
        self.active_theme_name = name
        self.current_tokens = theme_design_tokens(name)
        
        self._notify_all()

    me load_theme_file(path: text):
        """Load the default folder-based theme package.

        The path argument is accepted for compatibility; config/themes/theme.sdn
        is now the source of truth.
        """
        val pkg = load_theme_package(default_theme_id())
        self.active_theme_name = pkg.id
        self.current_tokens = pkg.tokens
        self._notify_all()

    me load_theme(name: text):
        """Load a theme id or compatibility alias from config/themes/theme.sdn."""
        val pkg = load_theme_package(name)
        self.active_theme_name = pkg.id
        self.current_tokens = pkg.tokens
        self._notify_all()

    me subscribe(port: u64):
        """Register an IPC port to receive theme change notifications."""
        self.subscribers = self.subscribers.push(port)

    me _notify_all():
        """Send notification to all subscribed IPC ports."""
        for port in self.subscribers:
            # syscall(SYS_IPC_SEND, port, ...)
            # For now, this is a placeholder for the actual IPC delivery
            pass_dn

    me get_tokens() -> GlassDesignTokens:
        return self.current_tokens

# Global instance for the kernel/compositor process
var g_theme_service: ThemeService? = nil

fn get_theme_service() -> ThemeService:
    if g_theme_service == nil:
        g_theme_service = ThemeService.new()
    return g_theme_service
