# P-384 Jacobian Point Operations
#
# Provides JacP384 (Jacobian coordinate point), curve generator constants,
# Jacobian arithmetic (double, add_mixed, add_jac), constant-time select,
# scalar multiplication, affine projection, and point validation.
#
# References:
#   * FIPS 186-4 / SEC2 v2.0 §2.5.1 (P-384 parameters)
#   * RFC 5903 §4.1 (ECDH with P-384)

use os.crypto.p384_field.{MASK32, Fe384, fe_zero, fe_one, _fe_get, _fe_from_arr, fe_from_bytes, fe_to_bytes, fe_add, _fe_cond_sub_p, _fe_cond_select, fe_sub, _fe_add_p, fe_mul, fe_sq, _fe_mul_wide, _fe_reduce_wide, _reduce_one_round, fe_inv, fe_eq}

# ============================================================================
# Jacobian point type
# ============================================================================

struct JacP384:
    x: Fe384
    y: Fe384
    z: Fe384
    inf: bool

fn _jac_inf() -> JacP384:
    JacP384(x: fe_zero(), y: fe_one(), z: fe_zero(), inf: true)

fn _jac_from_affine(ax: Fe384, ay: Fe384) -> JacP384:
    JacP384(x: ax, y: ay, z: fe_one(), inf: false)

# ============================================================================
# Curve generator G
# ============================================================================

fn _gx() -> Fe384:
