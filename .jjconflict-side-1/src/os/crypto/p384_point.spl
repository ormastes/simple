    b.push(0xF3)
    b.push(0x20)
    b.push(0xAD)
    b.push(0x74)
    b.push(0x6E)
    b.push(0x1D)
    b.push(0x3B)
    b.push(0x62)
    b.push(0x8B)
    b.push(0xA7)
    b.push(0x9B)
    b.push(0x98)
    b.push(0x59)
    b.push(0xF7)
    b.push(0x41)
    b.push(0xE0)
    b.push(0x82)
    b.push(0x54)
    b.push(0x2A)
    b.push(0x38)
    b.push(0x55)
    b.push(0x02)
    b.push(0xF2)
    b.push(0x5D)
    b.push(0xBF)
    b.push(0x55)
    b.push(0x29)
    b.push(0x6C)
    b.push(0x3A)
    b.push(0x54)
    b.push(0x5E)
    b.push(0x38)
    b.push(0x72)
    b.push(0x76)
    b.push(0x0A)
    b.push(0xB7)
    fe_from_bytes(b)

