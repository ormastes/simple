fn _small_ed_point_table_16(base: SmallEdPoint, two_d_small: [u64]) -> [SmallEdPoint]:
    var table: [SmallEdPoint] = []
    table.push(_small_ed_point_identity())
    var current = base
    table.push(current)
    var idx: u64 = 2
    while idx < 16:
        current = _ed_point_add_small_with_2d_small(p1: current, p2: base, two_d_small: two_d_small)
        table.push(current)
        idx = idx + 1
    table

fn _small_ed_cached_table_16(base: SmallEdPoint, two_d_small: [u64]) -> [SmallEdCached]:
    val points = _small_ed_point_table_16(base, two_d_small)
    var out: [SmallEdCached] = []
    var idx: u64 = 0
    while idx < points.len():
        out.push(_small_ed_point_to_cached(points[idx], two_d_small))
        idx = idx + 1
    out

fn _ed25519_base_point_small() -> SmallEdPoint:
    _ed_point_to_small(_ed25519_base_point())

fn _ed25519_base_point_cached_table_16(two_d_small: [u64]) -> [SmallEdCached]:
    _small_ed_cached_table_16(_ed25519_base_point_small(), two_d_small)

fn ed_scalar_mul(scalar: [u8], p: EdPoint) -> EdPoint:
    """Constant-time scalar multiplication: scalar * P (4-bit fixed window).

    scalar: 32-byte little-endian scalar.

    Processes the scalar from most-significant nibble to least-significant
    nibble using a constant-time select over a 16-entry table of multiples
    `[0*P .. 15*P]`. Each nibble step does four doublings and one addition.
    The selected multiple is chosen with XOR-mask cselect, so there is no
    data-dependent branch on secret scalar digits.

    Fixes `doc/08_tracking/bug/ed25519_scalar_mul_not_constant_time_2026-05-01.md`.
    """
    var result = ed_point_identity()
    var base = p
    var seen_nonzero = false
    var bit_idx: u64 = 0
    while bit_idx < 256:
        if _ed_scalar_bit(scalar, bit_idx) == 1:
            if seen_nonzero:
                result = ed_point_add(result, base)
            else:
                result = base
                seen_nonzero = true
        base = ed_point_double(base)
        bit_idx = bit_idx + 1
    result

fn _ed_scalar_mul_basepoint_cached(scalar: [u8]) -> EdPoint:
    var result = _small_ed_point_identity()
    val two_d_small = _fe_to_smalllimb(_ed25519_2d())
    val point_table = _small_ed_point_table_16(_ed25519_base_point_small(), two_d_small)
    val table = _small_ed_cached_table_16(_ed25519_base_point_small(), two_d_small)
    var seen_nonzero = false

    var byte_idx: i64 = 31
    while byte_idx >= 0:
        val logical_byte = (31 - byte_idx).to_u64()
        if logical_byte == 8:
            serial_println("[ed25519-scalar] byte8")
        if logical_byte == 10:
            serial_println("[ed25519-scalar] byte10")
        val byte_val = _ed_u8_at(scalar, byte_idx.to_u64()).to_u64()
        if byte_idx == 0:
            serial_println("[ed25519-scalar] base byte0 val={byte_val}")
        val hi = (byte_val >> 4) & 0xFu64
        val lo = byte_val & 0xFu64

        result = _small_ed_point_double4(result)
        val pair = _small_ed_cached_select_16_pair(table, hi, lo)
        val hi_point = pair.first
        if hi != 0:
            if seen_nonzero:
                result = _ed_point_add_small_cached(result, hi_point)
            else:
                result = _small_ed_point_select_16_direct(point_table, hi)
                seen_nonzero = true
        result = _small_ed_point_double4(result)
        val lo_point = pair.second
        if lo != 0:
            if seen_nonzero:
                result = _ed_point_add_small_cached(result, lo_point)
            else:
                result = _small_ed_point_select_16_direct(point_table, lo)
                seen_nonzero = true
        if logical_byte == 8:
            serial_println("[ed25519-scalar] byte8 lo add done")
        byte_idx = byte_idx - 1

    _small_ed_point_to_ed(result)

fn _ed_scalar_bit(scalar: [u8], bit_idx: u64) -> u64:
    val byte_idx = bit_idx / 8
    val bit_in_byte = bit_idx - byte_idx * 8
    (_ed_u8_at(scalar, byte_idx).to_u64() >> bit_in_byte) & 1

fn ed_scalar_mul_basepoint_simple(scalar: [u8]) -> EdPoint:
    var result = ed_point_identity()
    var base = _ed25519_base_point()
    var seen_nonzero = false
    var bit_idx: u64 = 0
    while bit_idx < 256:
        if _ed_scalar_bit(scalar, bit_idx) == 1:
            if seen_nonzero:
                result = ed_point_add(result, base)
            else:
                result = base
                seen_nonzero = true
        base = ed_point_double(base)
        bit_idx = bit_idx + 1
    result

fn ed_scalar_mul_basepoint(scalar: [u8]) -> EdPoint:
    ed_scalar_mul_basepoint_simple(scalar)

# ============================================================================
# Point Encoding / Decoding (RFC 8032 section 5.1.2)
# ============================================================================

fn ed_point_encode(p: EdPoint) -> [u8]:
    """Encode a point to 32 bytes.

    Encoding: y-coordinate in little-endian, with top bit of last byte
    set to the sign (low bit) of the x-coordinate.
    """
    val z_inv = fe_invert(p.z)
    val x = fe_mul(p.x, z_inv)
    val y = fe_mul(p.y, z_inv)

    var encoded = fe_to_bytes(y)

    # Set top bit of last byte to the sign of x
    if fe_is_negative(x):
        encoded[31] = encoded[31] | 0x80

    encoded

fn ed_point_decode(bytes: [u8]) -> EdPoint:
    """Decode a 32-byte encoding to a point on the curve.

    Extracts y from the low 255 bits, recovers x from the curve equation,
    and uses the top bit to select the sign of x.

    Returns the decoded point. If the encoding is invalid (not on curve),
    the result is unspecified.
    """
    # Extract sign bit of x from top bit of last byte
    val x_sign: u64 = (bytes[31].to_u64() >> 7) & 1

    # Clear top bit to get y
    var y_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        y_bytes.push(bytes[i])
        i = i + 1
    y_bytes[31] = y_bytes[31] & 0x7F

    val y = fe_from_bytes(y_bytes)

    # Recover x from curve equation: -x^2 + y^2 = 1 + d*x^2*y^2
    # x^2 = (y^2 - 1) / (d*y^2 + 1)
    val y_sq = fe_sq(y)
    val d = _ed25519_d()

    val u = fe_sub(y_sq, fe_one())         # u = y^2 - 1
    val v = fe_add(fe_mul(d, y_sq), fe_one())  # v = d*y^2 + 1

    # x = sqrt(u/v) = u * v^3 * (u * v^7)^((p-5)/8)
    # Or equivalently: x^2 = u * v^(-1), then x = sqrt(u * v^(-1))
    # We use: x = u * v^3 * (u * v^7)^((p-5)/8)
    # Since (p-5)/8 = 2^252 - 3
    val v_sq = fe_sq(v)
    val v_cubed = fe_mul(v_sq, v)
    val v4 = fe_sq(v_sq)
    val v7 = fe_mul(v4, v_cubed)
    val uv7 = fe_mul(u, v7)

    # (u * v^7)^(2^252 - 3)
    val uv7_pow = fe_pow2252m3(uv7)

    # x = u * v^3 * (u * v^7)^(2^252 - 3)
    var x = fe_mul(fe_mul(u, v_cubed), uv7_pow)

    # Verify: v * x^2 == u?
    val vx2 = fe_mul(v, fe_sq(x))
    val check = fe_reduce(fe_sub(vx2, u))

    if check.l0 != 0:
        # Try v * x^2 == -u (need to multiply x by sqrt(-1))
        val sqrt_m1 = _fe_sqrt_m1()
        x = fe_mul(x, sqrt_m1)
    else:
        if check.l1 != 0:
            val sqrt_m1 = _fe_sqrt_m1()
            x = fe_mul(x, sqrt_m1)
        else:
            if check.l2 != 0:
                val sqrt_m1 = _fe_sqrt_m1()
                x = fe_mul(x, sqrt_m1)
            else:
                if check.l3 != 0:
                    val sqrt_m1 = _fe_sqrt_m1()
                    x = fe_mul(x, sqrt_m1)
                else:
                    if check.l4 != 0:
                        val sqrt_m1 = _fe_sqrt_m1()
                        x = fe_mul(x, sqrt_m1)

    # Adjust sign of x to match the encoded sign bit
    if fe_is_negative(x) != (x_sign == 1):
        x = fe_neg(x)

    val t = fe_mul(x, y)
    EdPoint(x: x, y: y, z: fe_one(), t: t)

fn ed25519_probe_basepoint_encode() -> [u8]:
    ed_point_encode(_ed25519_base_point())

fn ed25519_probe_scalar_one_encode() -> [u8]:
    var one: [u8] = []
    var i: u64 = 0
    while i < 32:
        if i == 0:
            one.push(1)
        else:
            one.push(0)
        i = i + 1
    ed_point_encode(ed_scalar_mul_basepoint(one))

fn ed25519_probe_scalar_one_simple_encode() -> [u8]:
    var one: [u8] = []
    var i: u64 = 0
    while i < 32:
        if i == 0:
            one.push(1)
        else:
            one.push(0)
        i = i + 1
    ed_point_encode(ed_scalar_mul_basepoint_simple(one))

fn ed25519_probe_point_table_one_encode() -> [u8]:
    val two_d_small = _fe_to_smalllimb(_ed25519_2d())
    val points = _small_ed_point_table_16(_ed25519_base_point_small(), two_d_small)
    ed_point_encode(_small_ed_point_to_ed(points[1]))

fn ed25519_probe_cached_identity_add_one_encode() -> [u8]:
    val two_d_small = _fe_to_smalllimb(_ed25519_2d())
    val table = _ed25519_base_point_cached_table_16(two_d_small)
    val result = _ed_point_add_small_cached(_small_ed_point_identity(), table[1])
    ed_point_encode(_small_ed_point_to_ed(result))
