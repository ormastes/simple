# Ed25519 Extended Point Operations (RFC 8032)
#
# Provides the EdPoint struct, field helpers (fe_neg, fe_sqrt, etc.),
# curve constants (d, 2d, base point B), and extended-coordinate point
# operations (add, double, cselect, scalar_mul, encode, decode).
#
# Imported by ed25519.spl (hub) and ed25519_scalar.spl does NOT import here.
#
# References:
#   RFC 8032 — Edwards-Curve Digital Signature Algorithm
#   HWCD08   — Twisted Edwards Curves Revisited

use os.crypto.curve25519.{Fe25519, _fe_to_smalllimb, _smalllimb_to_fe, fe_zero, fe_one, fe_add, fe_sub, fe_mul, fe_sq, fe_invert, fe_reduce, fe_from_bytes, fe_to_bytes}
use os.crypto.curve25519_smalllimb.{_x25519_fe_add, _x25519_fe_add_raw, _x25519_fe_sub, _x25519_fe_sub_raw, _x25519_fe_neg, _x25519_fe_mul, _x25519_fe_sq}
extern fn serial_println(msg: text)
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _ed_u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# Extended Point on Ed25519
# ============================================================================

struct EdPoint:
    """Point on the Ed25519 Edwards curve in extended coordinates (X, Y, Z, T).

    Represents the affine point (X/Z, Y/Z) with T = X*Y/Z.
    """
    x: Fe25519
    y: Fe25519
    z: Fe25519
    t: Fe25519

struct SmallEdPoint:
    x: [u64]
    y: [u64]
    z: [u64]
    t: [u64]

struct SmallEdCached:
    yplusx: [u64]
    yminusx: [u64]
    z2: [u64]
    t2d: [u64]

struct SmallEdCachedPair:
    first: SmallEdCached
    second: SmallEdCached

# ============================================================================
# Field Helpers (supplementing curve25519.spl)
# ============================================================================

fn fe_neg(a: Fe25519) -> Fe25519:
    """Negate a field element: -a mod p."""
    fe_sub(a: fe_zero(), b: a)

fn fe_is_negative(a: Fe25519) -> bool:
    """Check if the field element is "negative" (low bit of canonical form is 1)."""
    val bytes = fe_to_bytes(a)
    (bytes[0] & 1) == 1

fn fe_pow2252m3(u: Fe25519) -> Fe25519:
    """Compute u^(2^252 - 3) mod p.

    This is u^((p+3)/8 - 1) which is useful for square root computation.
    (p+3)/8 = 2^252 - 2, so u^((p+3)/8) = u * u^(2^252-3).
    Uses the same addition-chain structure as fe_invert.
    """
    # z^2
    var z2 = fe_sq(u)

    # z^(2^2) = z^4
    var t = fe_sq(z2)
    # z^(2^3) = z^8
    t = fe_sq(t)

    # z^9 = z^8 * z
    var z9 = fe_mul(t, u)
    # z^11 = z^9 * z^2
    var z11 = fe_mul(z9, z2)

    # z^22
    t = fe_sq(z11)
    # z^31 = z^22 * z^9
    var z_2_5_0 = fe_mul(t, z9)

    # z^(2^10 - 1)
    t = fe_sq(z_2_5_0)
    var i: u64 = 1
    while i < 5:
        t = fe_sq(t)
        i = i + 1
    var z_2_10_0 = fe_mul(t, z_2_5_0)

    # z^(2^20 - 1)
    t = fe_sq(z_2_10_0)
    i = 1
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_20_0 = fe_mul(t, z_2_10_0)

    # z^(2^40 - 1)
    t = fe_sq(z_2_20_0)
    i = 1
    while i < 20:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_20_0)

    # z^(2^50 - 1)
    i = 0
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_50_0 = fe_mul(t, z_2_10_0)

    # z^(2^100 - 1)
    t = fe_sq(z_2_50_0)
    i = 1
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    var z_2_100_0 = fe_mul(t, z_2_50_0)

    # z^(2^200 - 1)
    t = fe_sq(z_2_100_0)
    i = 1
    while i < 100:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_100_0)

    # z^(2^250 - 1)
    i = 0
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_50_0)

    # z^(2^252 - 4)
    t = fe_sq(t)
    t = fe_sq(t)

    # z^(2^252 - 3) = z^(2^252 - 4) * z
    fe_mul(t, u)

fn fe_sqrt(u: Fe25519) -> Fe25519:
    """Compute the square root of u mod p, if it exists.

    Uses u^((p+3)/8) with adjustment by sqrt(-1) if needed.
    For p = 2^255 - 19, (p+3)/8 = 2^252 - 2.

    Returns a root r such that r^2 = u. If u is not a quadratic residue,
    the result is unspecified (caller should verify r^2 == u).
    """
    # r = u^((p+3)/8) = u * u^(2^252 - 3)
    val r_base = fe_mul(u, fe_pow2252m3(u))

    # Check: r^2 == u?
    val r_sq = fe_sq(r_base)
    val check = fe_sub(r_sq, u)
    val check_reduced = fe_reduce(check)

    # If r^2 == u, we're done
    if check_reduced.l0 == 0:
        if check_reduced.l1 == 0:
            if check_reduced.l2 == 0:
                if check_reduced.l3 == 0:
                    if check_reduced.l4 == 0:
                        return r_base

    # Otherwise try r * sqrt(-1)
    # sqrt(-1) = 2^((p-1)/4) mod p
    # We compute sqrt(-1) via the pow chain
    val sqrt_m1 = _fe_sqrt_m1()
    val r_adj = fe_mul(r_base, sqrt_m1)

    r_adj

fn _fe_sqrt_m1() -> Fe25519:
    """Compute sqrt(-1) mod p = 2^((p-1)/4) mod p.

    p-1 = 2^255 - 20, so (p-1)/4 = 2^253 - 5.
    We compute 2^(2^253 - 5) mod p.

    sqrt(-1) = 0x2b8324804fc1df0b2b4d00993dfbd7a72f431806ad2fe478c4ee1b274a0ea0b0
    """
    # Precomputed sqrt(-1) as bytes (little-endian)
    var bytes: [u8] = [
        0xb0, 0xa0, 0x0e, 0x4a, 0x27, 0x1b, 0xee, 0xc4,
        0x78, 0xe4, 0x2f, 0xad, 0x06, 0x18, 0x43, 0x2f,
        0xa7, 0xd7, 0xfb, 0x3d, 0x99, 0x00, 0x4d, 0x2b,
        0x0b, 0xdf, 0xc1, 0x4f, 0x80, 0x24, 0x83, 0x2b
    ]
    fe_from_bytes(bytes)

# ============================================================================
# Curve Constant d
# ============================================================================

fn _ed25519_d() -> Fe25519:
    """Compute d = -121665/121666 mod p = -121665 * inv(121666) mod p.

    d = 0x52036cee2b6ffe738cc740797779e89800700a4d4141d8ab75eb4dca135978a3
    """
    Fe25519(
        l0: 929955233495203,
        l1: 466365720129213,
        l2: 1662059464998953,
        l3: 2033849074728123,
        l4: 1442794654840575
    )

fn _ed25519_2d() -> Fe25519:
    """Compute 2*d mod p. Used in point addition formulas."""
    val d = _ed25519_d()
    fe_add(d, d)

# ============================================================================
# Ed25519 Base Point B
# ============================================================================

fn _ed25519_base_point() -> EdPoint:
    """Return the Ed25519 base point B.

    B has y = 4/5 mod p, and x is the positive (even) square root.

    By = 0x6666666666666666666666666666666666666666666666666666666666666658
    Bx = 0x216936d3cd6e53fec0a4e231fdd6dc5c692cc7609525a7b2c9562d608f25d51a
    """
    val bx = Fe25519(
        l0: 1738742601995546,
        l1: 1146398526822698,
        l2: 2070867633025821,
        l3: 562264141797630,
        l4: 587772402128613
    )
    val by = Fe25519(
        l0: 1801439850948184,
        l1: 1351079888211148,
        l2: 450359962737049,
        l3: 900719925474099,
        l4: 1801439850948198
    )
    EdPoint(
        x: bx,
        y: by,
        z: fe_one(),
        t: fe_mul(bx, by)
    )

# ============================================================================
# Extended Coordinate Point Operations (HWCD08)
# ============================================================================

fn ed_point_identity() -> EdPoint:
    """Return the neutral element (identity point): (0, 1, 1, 0)."""
    EdPoint(x: fe_zero(), y: fe_one(), z: fe_one(), t: fe_zero())

fn _small_ed_point_identity() -> SmallEdPoint:
    SmallEdPoint(
        x: _fe_to_smalllimb(fe_zero()),
        y: _fe_to_smalllimb(fe_one()),
        z: _fe_to_smalllimb(fe_one()),
        t: _fe_to_smalllimb(fe_zero())
    )

fn _ed_point_to_small(p: EdPoint) -> SmallEdPoint:
    SmallEdPoint(
        x: _fe_to_smalllimb(p.x),
        y: _fe_to_smalllimb(p.y),
        z: _fe_to_smalllimb(p.z),
        t: _fe_to_smalllimb(p.t)
    )

fn _small_ed_point_to_ed(p: SmallEdPoint) -> EdPoint:
    EdPoint(
        x: _smalllimb_to_fe(p.x),
        y: _smalllimb_to_fe(p.y),
        z: _smalllimb_to_fe(p.z),
        t: _smalllimb_to_fe(p.t)
    )

fn _small_ed_point_to_cached(p: SmallEdPoint, two_d_small: [u64]) -> SmallEdCached:
    SmallEdCached(
        yplusx: _x25519_fe_add(p.y, p.x),
        yminusx: _x25519_fe_sub(p.y, p.x),
        z2: _x25519_fe_add(p.z, p.z),
        t2d: _x25519_fe_mul(p.t, two_d_small)
    )

fn _ed_point_add_small_with_2d_small(p1: SmallEdPoint, p2: SmallEdPoint, two_d_small: [u64]) -> SmallEdPoint:
    """Add two points in extended coordinates.

    Uses unified addition formula from HWCD08 for twisted Edwards curve
    -x^2 + y^2 = 1 + d*x^2*y^2 (a = -1).

    A = (Y1-X1)*(Y2-X2), B = (Y1+X1)*(Y2+X2)
    C = 2*d*T1*T2, D = 2*Z1*Z2
    E = B - A, F = D - C, G = D + C, H = B + A
    X3 = E*F, Y3 = G*H, T3 = E*H, Z3 = F*G
    """
    val x1 = p1.x
    val y1 = p1.y
    val z1 = p1.z
    val t1 = p1.t
    val x2 = p2.x
    val y2 = p2.y
    val z2 = p2.z
    val t2 = p2.t
    val a = _x25519_fe_mul(_x25519_fe_sub(y1, x1), _x25519_fe_sub(y2, x2))
    val b = _x25519_fe_mul(_x25519_fe_add(y1, x1), _x25519_fe_add(y2, x2))
    val c = _x25519_fe_mul(_x25519_fe_mul(t1, t2), two_d_small)
    val z_prod = _x25519_fe_mul(z1, z2)
    val dd = _x25519_fe_add(z_prod, z_prod)

    val e = _x25519_fe_sub(b, a)
    val f = _x25519_fe_sub(dd, c)
    val g = _x25519_fe_add(dd, c)
    val h = _x25519_fe_add(b, a)

    SmallEdPoint(
        x: _x25519_fe_mul(e, f),
        y: _x25519_fe_mul(g, h),
        z: _x25519_fe_mul(f, g),
        t: _x25519_fe_mul(e, h)
    )

fn _ed_point_add_small_cached(p1: SmallEdPoint, p2: SmallEdCached) -> SmallEdPoint:
    val tr_x = _x25519_fe_add_raw(p1.y, p1.x)
    val tr_y = _x25519_fe_sub_raw(p1.y, p1.x)
    val tr_z = _x25519_fe_mul(tr_x, p2.yplusx)
    val tr_y2 = _x25519_fe_mul(tr_y, p2.yminusx)
    val tr_t = _x25519_fe_mul(p2.t2d, p1.t)
    val dd = _x25519_fe_mul(p1.z, p2.z2)

    val x = _x25519_fe_sub_raw(tr_z, tr_y2)
    val y = _x25519_fe_add_raw(tr_z, tr_y2)
    val z = _x25519_fe_add_raw(dd, tr_t)
    val t = _x25519_fe_sub_raw(dd, tr_t)

    SmallEdPoint(
        x: _x25519_fe_mul(x, t),
        y: _x25519_fe_mul(y, z),
        z: _x25519_fe_mul(t, z),
        t: _x25519_fe_mul(x, y)
    )

fn _ed_point_add_with_2d_small(p1: EdPoint, p2: EdPoint, two_d_small: [u64]) -> EdPoint:
    _small_ed_point_to_ed(_ed_point_add_small_with_2d_small(_ed_point_to_small(p1), _ed_point_to_small(p2), two_d_small))

fn _ed_point_add_with_2d(p1: EdPoint, p2: EdPoint, two_d: Fe25519) -> EdPoint:
    _ed_point_add_with_2d_small(p1, p2, _fe_to_smalllimb(two_d))

fn ed_point_add(p1: EdPoint, p2: EdPoint) -> EdPoint:
    _ed_point_add_with_2d(p1, p2, _ed25519_2d())

fn ed_point_double(p1: EdPoint) -> EdPoint:
    """Double a point in extended coordinates.

    Uses dedicated doubling formula from HWCD08 for a = -1:
    A = X1^2, B = Y1^2, C = 2*Z1^2
    D = -A (since a = -1), E = (X1+Y1)^2 - A - B
    G = D + B, F = G - C, H = D - B
    X3 = E*F, Y3 = G*H, T3 = E*H, Z3 = F*G
    """
    return ed_point_add(p1, p1)

fn ed_point_double_formula_probe(p1: EdPoint) -> EdPoint:
    val x = _fe_to_smalllimb(p1.x)
    val y = _fe_to_smalllimb(p1.y)
    val z = _fe_to_smalllimb(p1.z)

    val a = _x25519_fe_sq(x)
    val b = _x25519_fe_sq(y)
    val z_sq = _x25519_fe_sq(z)
    val c = _x25519_fe_add(z_sq, z_sq)

    val d = _x25519_fe_neg(a)
    val x_plus_y = _x25519_fe_add(x, y)
    val e = _x25519_fe_sub(_x25519_fe_sub(_x25519_fe_sq(x_plus_y), a), b)

    val g = _x25519_fe_add(d, b)
    val f = _x25519_fe_sub(g, c)
    val h = _x25519_fe_sub(b, d)

    EdPoint(
        x: _smalllimb_to_fe(_x25519_fe_mul(e, f)),
        y: _smalllimb_to_fe(_x25519_fe_mul(g, h)),
        z: _smalllimb_to_fe(_x25519_fe_mul(f, g)),
        t: _smalllimb_to_fe(_x25519_fe_mul(e, h))
    )

fn _ed_point_double_small(p1: SmallEdPoint) -> SmallEdPoint:
    val x = p1.x
    val y = p1.y
    val z = p1.z

    val a = _x25519_fe_sq(x)
    val b = _x25519_fe_sq(y)
    val z_sq = _x25519_fe_sq(z)
    val c = _x25519_fe_add_raw(z_sq, z_sq)

    val d = _x25519_fe_neg(a)
    val x_plus_y = _x25519_fe_add_raw(x, y)
    val e = _x25519_fe_sub_raw(_x25519_fe_sub_raw(_x25519_fe_sq(x_plus_y), a), b)

    val g = _x25519_fe_add_raw(d, b)
    val f = _x25519_fe_sub_raw(g, c)
    val h = _x25519_fe_sub_raw(b, d)

    SmallEdPoint(
        x: _x25519_fe_mul(e, f),
        y: _x25519_fe_mul(g, h),
        z: _x25519_fe_mul(f, g),
        t: _x25519_fe_mul(e, h)
    )

fn ed_point_cselect(p0: EdPoint, p1: EdPoint, choose_p1: u64) -> EdPoint:
    """Constant-time point select: returns p1 if choose_p1=1, else p0.

    Uses the XOR-mask pattern from `fe_cswap` (curve25519.spl):
        out = a ^ (mask & (a ^ b))
    where mask = 0 - choose_p1 (all-ones if 1, all-zeros if 0).

    No branches on `choose_p1`; the same field operations execute regardless of
    the bit value. Matches the constant-time discipline used by the Curve25519
    Montgomery ladder. Compiler must NOT branch-fold these XOR/AND ops — they
    are arithmetic, not compares (per the B6 memory note on CT compares).
    """
    val mask: u64 = 0 - choose_p1
    EdPoint(
        x: Fe25519(
            l0: p0.x.l0 ^ (mask & (p0.x.l0 ^ p1.x.l0)),
            l1: p0.x.l1 ^ (mask & (p0.x.l1 ^ p1.x.l1)),
            l2: p0.x.l2 ^ (mask & (p0.x.l2 ^ p1.x.l2)),
            l3: p0.x.l3 ^ (mask & (p0.x.l3 ^ p1.x.l3)),
            l4: p0.x.l4 ^ (mask & (p0.x.l4 ^ p1.x.l4))
        ),
        y: Fe25519(
            l0: p0.y.l0 ^ (mask & (p0.y.l0 ^ p1.y.l0)),
            l1: p0.y.l1 ^ (mask & (p0.y.l1 ^ p1.y.l1)),
            l2: p0.y.l2 ^ (mask & (p0.y.l2 ^ p1.y.l2)),
            l3: p0.y.l3 ^ (mask & (p0.y.l3 ^ p1.y.l3)),
            l4: p0.y.l4 ^ (mask & (p0.y.l4 ^ p1.y.l4))
        ),
        z: Fe25519(
            l0: p0.z.l0 ^ (mask & (p0.z.l0 ^ p1.z.l0)),
            l1: p0.z.l1 ^ (mask & (p0.z.l1 ^ p1.z.l1)),
            l2: p0.z.l2 ^ (mask & (p0.z.l2 ^ p1.z.l2)),
            l3: p0.z.l3 ^ (mask & (p0.z.l3 ^ p1.z.l3)),
            l4: p0.z.l4 ^ (mask & (p0.z.l4 ^ p1.z.l4))
        ),
        t: Fe25519(
            l0: p0.t.l0 ^ (mask & (p0.t.l0 ^ p1.t.l0)),
            l1: p0.t.l1 ^ (mask & (p0.t.l1 ^ p1.t.l1)),
            l2: p0.t.l2 ^ (mask & (p0.t.l2 ^ p1.t.l2)),
            l3: p0.t.l3 ^ (mask & (p0.t.l3 ^ p1.t.l3)),
            l4: p0.t.l4 ^ (mask & (p0.t.l4 ^ p1.t.l4))
        )
    )

fn _small_ed_point_cselect(p0: SmallEdPoint, p1: SmallEdPoint, choose_p1: u64) -> SmallEdPoint:
    val mask: u64 = 0 - choose_p1
    SmallEdPoint(
        x: [
            p0.x[0] ^ (mask & (p0.x[0] ^ p1.x[0])),
            p0.x[1] ^ (mask & (p0.x[1] ^ p1.x[1])),
            p0.x[2] ^ (mask & (p0.x[2] ^ p1.x[2])),
            p0.x[3] ^ (mask & (p0.x[3] ^ p1.x[3])),
            p0.x[4] ^ (mask & (p0.x[4] ^ p1.x[4])),
            p0.x[5] ^ (mask & (p0.x[5] ^ p1.x[5])),
            p0.x[6] ^ (mask & (p0.x[6] ^ p1.x[6])),
            p0.x[7] ^ (mask & (p0.x[7] ^ p1.x[7])),
            p0.x[8] ^ (mask & (p0.x[8] ^ p1.x[8])),
            p0.x[9] ^ (mask & (p0.x[9] ^ p1.x[9]))
        ],
        y: [
            p0.y[0] ^ (mask & (p0.y[0] ^ p1.y[0])),
            p0.y[1] ^ (mask & (p0.y[1] ^ p1.y[1])),
            p0.y[2] ^ (mask & (p0.y[2] ^ p1.y[2])),
            p0.y[3] ^ (mask & (p0.y[3] ^ p1.y[3])),
            p0.y[4] ^ (mask & (p0.y[4] ^ p1.y[4])),
            p0.y[5] ^ (mask & (p0.y[5] ^ p1.y[5])),
            p0.y[6] ^ (mask & (p0.y[6] ^ p1.y[6])),
            p0.y[7] ^ (mask & (p0.y[7] ^ p1.y[7])),
            p0.y[8] ^ (mask & (p0.y[8] ^ p1.y[8])),
            p0.y[9] ^ (mask & (p0.y[9] ^ p1.y[9]))
        ],
        z: [
            p0.z[0] ^ (mask & (p0.z[0] ^ p1.z[0])),
            p0.z[1] ^ (mask & (p0.z[1] ^ p1.z[1])),
            p0.z[2] ^ (mask & (p0.z[2] ^ p1.z[2])),
            p0.z[3] ^ (mask & (p0.z[3] ^ p1.z[3])),
            p0.z[4] ^ (mask & (p0.z[4] ^ p1.z[4])),
            p0.z[5] ^ (mask & (p0.z[5] ^ p1.z[5])),
            p0.z[6] ^ (mask & (p0.z[6] ^ p1.z[6])),
            p0.z[7] ^ (mask & (p0.z[7] ^ p1.z[7])),
            p0.z[8] ^ (mask & (p0.z[8] ^ p1.z[8])),
            p0.z[9] ^ (mask & (p0.z[9] ^ p1.z[9]))
        ],
        t: [
            p0.t[0] ^ (mask & (p0.t[0] ^ p1.t[0])),
            p0.t[1] ^ (mask & (p0.t[1] ^ p1.t[1])),
            p0.t[2] ^ (mask & (p0.t[2] ^ p1.t[2])),
            p0.t[3] ^ (mask & (p0.t[3] ^ p1.t[3])),
            p0.t[4] ^ (mask & (p0.t[4] ^ p1.t[4])),
            p0.t[5] ^ (mask & (p0.t[5] ^ p1.t[5])),
            p0.t[6] ^ (mask & (p0.t[6] ^ p1.t[6])),
            p0.t[7] ^ (mask & (p0.t[7] ^ p1.t[7])),
            p0.t[8] ^ (mask & (p0.t[8] ^ p1.t[8])),
            p0.t[9] ^ (mask & (p0.t[9] ^ p1.t[9]))
        ]
    )

fn _small_ed_point_double4(p: SmallEdPoint) -> SmallEdPoint:
    var out = _ed_point_double_small(p)
    out = _ed_point_double_small(out)
    out = _ed_point_double_small(out)
    _ed_point_double_small(out)

fn _ct_eq_u64_small(a: u64, b: u64) -> u64:
    val diff = a ^ b
    ((diff - 1u64) >> 63) & 1u64

fn _small_ed_point_select_16(table: [SmallEdPoint], digit: u64) -> SmallEdPoint:
    var selected_x = table[0].x
    var selected_y = table[0].y
    var selected_z = table[0].z
    var selected_t = table[0].t
    var idx: u64 = 1
    while idx < 16:
        val mask: u64 = 0u64 - _ct_eq_u64_small(digit, idx)
        val point = table[idx]
        selected_x = [
            selected_x[0] ^ (mask & (selected_x[0] ^ point.x[0])),
            selected_x[1] ^ (mask & (selected_x[1] ^ point.x[1])),
            selected_x[2] ^ (mask & (selected_x[2] ^ point.x[2])),
            selected_x[3] ^ (mask & (selected_x[3] ^ point.x[3])),
            selected_x[4] ^ (mask & (selected_x[4] ^ point.x[4])),
            selected_x[5] ^ (mask & (selected_x[5] ^ point.x[5])),
            selected_x[6] ^ (mask & (selected_x[6] ^ point.x[6])),
            selected_x[7] ^ (mask & (selected_x[7] ^ point.x[7])),
            selected_x[8] ^ (mask & (selected_x[8] ^ point.x[8])),
            selected_x[9] ^ (mask & (selected_x[9] ^ point.x[9]))
        ]
        selected_y = [
            selected_y[0] ^ (mask & (selected_y[0] ^ point.y[0])),
            selected_y[1] ^ (mask & (selected_y[1] ^ point.y[1])),
            selected_y[2] ^ (mask & (selected_y[2] ^ point.y[2])),
            selected_y[3] ^ (mask & (selected_y[3] ^ point.y[3])),
            selected_y[4] ^ (mask & (selected_y[4] ^ point.y[4])),
            selected_y[5] ^ (mask & (selected_y[5] ^ point.y[5])),
            selected_y[6] ^ (mask & (selected_y[6] ^ point.y[6])),
            selected_y[7] ^ (mask & (selected_y[7] ^ point.y[7])),
            selected_y[8] ^ (mask & (selected_y[8] ^ point.y[8])),
            selected_y[9] ^ (mask & (selected_y[9] ^ point.y[9]))
        ]
        selected_z = [
            selected_z[0] ^ (mask & (selected_z[0] ^ point.z[0])),
            selected_z[1] ^ (mask & (selected_z[1] ^ point.z[1])),
            selected_z[2] ^ (mask & (selected_z[2] ^ point.z[2])),
            selected_z[3] ^ (mask & (selected_z[3] ^ point.z[3])),
            selected_z[4] ^ (mask & (selected_z[4] ^ point.z[4])),
            selected_z[5] ^ (mask & (selected_z[5] ^ point.z[5])),
            selected_z[6] ^ (mask & (selected_z[6] ^ point.z[6])),
            selected_z[7] ^ (mask & (selected_z[7] ^ point.z[7])),
            selected_z[8] ^ (mask & (selected_z[8] ^ point.z[8])),
            selected_z[9] ^ (mask & (selected_z[9] ^ point.z[9]))
        ]
        selected_t = [
            selected_t[0] ^ (mask & (selected_t[0] ^ point.t[0])),
            selected_t[1] ^ (mask & (selected_t[1] ^ point.t[1])),
            selected_t[2] ^ (mask & (selected_t[2] ^ point.t[2])),
            selected_t[3] ^ (mask & (selected_t[3] ^ point.t[3])),
            selected_t[4] ^ (mask & (selected_t[4] ^ point.t[4])),
            selected_t[5] ^ (mask & (selected_t[5] ^ point.t[5])),
            selected_t[6] ^ (mask & (selected_t[6] ^ point.t[6])),
            selected_t[7] ^ (mask & (selected_t[7] ^ point.t[7])),
            selected_t[8] ^ (mask & (selected_t[8] ^ point.t[8])),
            selected_t[9] ^ (mask & (selected_t[9] ^ point.t[9]))
        ]
        idx = idx + 1
    SmallEdPoint(x: selected_x, y: selected_y, z: selected_z, t: selected_t)

