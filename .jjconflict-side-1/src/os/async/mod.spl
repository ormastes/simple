# SimpleOS async facade.
#
# This package is intentionally small: kernel services use it as a no-host,
# polling-based boundary for device and VFS futures.

use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}
use os.async.os_future.{OsFuture, ReadyFuture}
use os.async.os_executor.{OsExecutor}
