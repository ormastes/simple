# OS Poll — Async poll result for OS-level futures
#
# Equivalent to Rust's Poll<T>, but designed for baremetal OS use.
# Used by OsFuture.poll() to indicate whether a future has completed.

enum OsPoll<T>:
    """Result of polling an OS future.

    Ready(value) means the future has completed with the given value.
    Pending means the future is not yet ready and the waker has been registered.
    """
    Ready(value: T)
    Pending
