# Rendering Shapes — Gradients, Blur, Rounded Rectangles, Circle, Ring, Line
#
# Companion to render.spl. Depends on px_read/px_write/alpha_blend/lerp_color
# and the global framebuffer state (g_width, g_height, g_ready) from render.spl.

use os.gui.render.{px_read, px_write, alpha_blend, lerp_color, _lerp_channel, render_width, render_height}

extern fn rt_alloc(size: u64) -> u64
extern fn rt_mmio_read_u32(addr: u64) -> u32
extern fn rt_mmio_write_u32(addr: u64, value: u32)

# ============================================================================
# Gradients
# ============================================================================

fn gradient_v(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    """Vertical gradient from c1 (top) to c2 (bottom).

    Colors are 0x00RRGGBB. Output pixels are fully opaque.
    """
    if h == 0 or w == 0:
        return
    val gw = render_width()
    val gh = render_height()
    val max = if h > 1: h - 1 else: 1
    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= gh:
            return
        val color = lerp_color(c1, c2, row, max)
        var col: u64 = 0
        while col < w:
            val px = x + col
            if px < gw:
                px_write(px, py, color)
            col = col + 1
        row = row + 1

fn gradient_h(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    """Horizontal gradient from c1 (left) to c2 (right).

    Colors are 0x00RRGGBB. Output pixels are fully opaque.
    """
    if h == 0 or w == 0:
        return
    val gw = render_width()
    val gh = render_height()
    val max = if w > 1: w - 1 else: 1
    var col: u64 = 0
    while col < w:
        val px = x + col
        if px >= gw:
            col = col + 1
            continue
        val color = lerp_color(c1, c2, col, max)
        var row: u64 = 0
        while row < h:
            val py = y + row
            if py < gh:
                px_write(px, py, color)
            row = row + 1
        col = col + 1

fn gradient_blend_v(x: u64, y: u64, w: u64, h: u64, c1: u64, a1: u64, c2: u64, a2: u64):
    """Vertical gradient with varying alpha.

    Blends gradient color onto existing framebuffer content.
    c1/c2 are 0x00RRGGBB, a1/a2 are alpha values (0-255).
    """
    if h == 0 or w == 0:
        return
    val gw = render_width()
    val gh = render_height()
    val max = if h > 1: h - 1 else: 1
    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= gh:
            return
        val color = lerp_color(c1, c2, row, max)
        val alpha = _lerp_channel(a1, a2, row, max)
        var col: u64 = 0
        while col < w:
            val px = x + col
            if px < gw:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            col = col + 1
        row = row + 1

# ============================================================================
# Box Blur (3-pass or 5-pass approximation of Gaussian)
# ============================================================================

fn box_blur(x: u64, y: u64, w: u64, h: u64, radius: u64):
    """Multi-pass box blur approximating Gaussian blur.

    Uses 5 passes (H-V-H-V-H) matching glass_render.c for quality.
    Radius is clamped to 30 to prevent artifacts.
    """
    if w == 0 or h == 0:
        return
    var r = radius
    if r > 30:
        r = 30
    if r == 0:
        return
    val gw = render_width()
    val gh = render_height()
    # Clamp region to screen bounds
    var bw = w
    var bh = h
    if x + bw > gw:
        bw = gw - x
    if y + bh > gh:
        bh = gh - y
    # 5-pass: H -> V -> H -> V -> H
    _blur_h(x, y, bw, bh, r)
    _blur_v(x, y, bw, bh, r)
    _blur_h(x, y, bw, bh, r)
    _blur_v(x, y, bw, bh, r)
    _blur_h(x, y, bw, bh, r)

fn _blur_h(x0: u64, y0: u64, w: u64, h: u64, r: u64):
    """Horizontal blur pass using sliding window accumulator."""
    if r == 0 or w == 0:
        return
    val gw = render_width()
    val gh = render_height()
    val d = 2 * r + 1
    var row: u64 = 0
    while row < h:
        val py = y0 + row
        if py >= gh:
            row = row + 1
            continue
        var acc_r: u64 = 0
        var acc_g: u64 = 0
        var acc_b: u64 = 0
        var i: u64 = 0
        while i < d and i < w:
            var sx = x0 + i
            if i < r:
                sx = x0
            else:
                sx = x0 + i - r
            if sx >= gw:
                sx = gw - 1
            val c = px_read(sx, py)
            acc_r = acc_r + ((c >> 16) & 0xFF)
            acc_g = acc_g + ((c >> 8) & 0xFF)
            acc_b = acc_b + (c & 0xFF)
            i = i + 1

        val tmp_buf = rt_alloc(w * 4)

        var col: u64 = 0
        while col < w:
            val avg_r = acc_r / d
            val avg_g = acc_g / d
            val avg_b = acc_b / d
            val blurred = 0xFF000000 | (avg_r << 16) | (avg_g << 8) | avg_b
            if tmp_buf != 0:
                rt_mmio_write_u32(tmp_buf + col * 4, (blurred & 0xFFFFFFFF).to_u32())
            else:
                val px_out = x0 + col
                if px_out < gw:
                    px_write(px_out, py, blurred)

            var rm_x = x0 + col
            if col >= r:
                rm_x = x0 + col - r
            else:
                rm_x = x0
            if rm_x >= gw:
                rm_x = gw - 1
            val rm_c = px_read(rm_x, py)
            acc_r = acc_r - ((rm_c >> 16) & 0xFF)
            acc_g = acc_g - ((rm_c >> 8) & 0xFF)
            acc_b = acc_b - (rm_c & 0xFF)

            var add_x = x0 + col + r + 1
            if add_x >= x0 + w:
                add_x = x0 + w - 1
            if add_x >= gw:
                add_x = gw - 1
            val add_c = px_read(add_x, py)
            acc_r = acc_r + ((add_c >> 16) & 0xFF)
            acc_g = acc_g + ((add_c >> 8) & 0xFF)
            acc_b = acc_b + (add_c & 0xFF)

            col = col + 1

        if tmp_buf != 0:
            var c2: u64 = 0
            while c2 < w:
                val px_out = x0 + c2
                if px_out < gw:
                    val v = rt_mmio_read_u32(tmp_buf + c2 * 4).to_u64()
                    px_write(px_out, py, v)
                c2 = c2 + 1

        row = row + 1

fn _blur_v(x0: u64, y0: u64, w: u64, h: u64, r: u64):
    """Vertical blur pass using sliding window accumulator."""
    if r == 0 or h == 0:
        return
    val gw = render_width()
    val gh = render_height()
    val d = 2 * r + 1
    var col: u64 = 0
    while col < w:
        val px = x0 + col
        if px >= gw:
            col = col + 1
            continue
        var acc_r: u64 = 0
        var acc_g: u64 = 0
        var acc_b: u64 = 0
        var i: u64 = 0
        while i < d and i < h:
            var sy = y0 + i
            if i < r:
                sy = y0
            else:
                sy = y0 + i - r
            if sy >= gh:
                sy = gh - 1
            val c = px_read(px, sy)
            acc_r = acc_r + ((c >> 16) & 0xFF)
            acc_g = acc_g + ((c >> 8) & 0xFF)
            acc_b = acc_b + (c & 0xFF)
            i = i + 1

        val tmp_buf = rt_alloc(h * 4)

        var row: u64 = 0
        while row < h:
            val avg_r = acc_r / d
            val avg_g = acc_g / d
            val avg_b = acc_b / d
            val blurred = 0xFF000000 | (avg_r << 16) | (avg_g << 8) | avg_b
            if tmp_buf != 0:
                rt_mmio_write_u32(tmp_buf + row * 4, (blurred & 0xFFFFFFFF).to_u32())
            else:
                val py = y0 + row
                if py < gh:
                    px_write(px, py, blurred)

            var rm_y = y0 + row
            if row >= r:
                rm_y = y0 + row - r
            else:
                rm_y = y0
            if rm_y >= gh:
                rm_y = gh - 1
            val rm_c = px_read(px, rm_y)
            acc_r = acc_r - ((rm_c >> 16) & 0xFF)
            acc_g = acc_g - ((rm_c >> 8) & 0xFF)
            acc_b = acc_b - (rm_c & 0xFF)

            var add_y = y0 + row + r + 1
            if add_y >= y0 + h:
                add_y = y0 + h - 1
            if add_y >= gh:
                add_y = gh - 1
            val add_c = px_read(px, add_y)
            acc_r = acc_r + ((add_c >> 16) & 0xFF)
            acc_g = acc_g + ((add_c >> 8) & 0xFF)
            acc_b = acc_b + (add_c & 0xFF)

            row = row + 1

        if tmp_buf != 0:
            var r2: u64 = 0
            while r2 < h:
                val py = y0 + r2
                if py < gh:
                    val v = rt_mmio_read_u32(tmp_buf + r2 * 4).to_u64()
                    px_write(px, py, v)
                r2 = r2 + 1

        col = col + 1

# ============================================================================
# Rounded Rectangle with Anti-Aliasing
# ============================================================================

fn rounded_rect_aa(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    """Draw a rounded rectangle (squircle) with anti-aliased corners."""
    if w == 0 or h == 0:
        return
    val gw = render_width()
    val gh = render_height()
    var r = radius
    if r > w / 2:
        r = w / 2
    if r > h / 2:
        r = h / 2
    val r2 = r * r

    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= gh:
            return

        var x_start: u64 = 0
        var x_end: u64 = w

        var in_corner = 0
        var dy: u64 = 0
        if row < r:
            in_corner = 1
            dy = r - row
        if row >= h - r:
            in_corner = 1
            dy = row - (h - 1 - r)

        if in_corner == 1:
            var dx: u64 = 0
            while (dx + 1) * (dx + 1) + dy * dy <= r2:
                dx = dx + 1
            x_start = r - dx
            x_end = w - (r - dx)

            if x_start > 0:
                val edge_px = x + x_start - 1
                if edge_px < gw:
                    val dist2 = (x_start) * (x_start) + dy * dy
                    var coverage = alpha
                    if dist2 > r2:
                        coverage = 0
                    else:
                        coverage = alpha * (r2 - dist2) / r2
                    if coverage > 0:
                        val dst = px_read(edge_px, py)
                        px_write(edge_px, py, alpha_blend(dst, color, coverage))

            if x_end < w:
                val edge_px = x + x_end
                if edge_px < gw:
                    val dist2 = (x_start) * (x_start) + dy * dy
                    var coverage = alpha
                    if dist2 > r2:
                        coverage = 0
                    else:
                        coverage = alpha * (r2 - dist2) / r2
                    if coverage > 0:
                        val dst = px_read(edge_px, py)
                        px_write(edge_px, py, alpha_blend(dst, color, coverage))

        var col = x_start
        while col < x_end:
            val px = x + col
            if px >= gw:
                col = col + 1
                continue
            if alpha >= 255:
                px_write(px, py, 0xFF000000 | (color & 0x00FFFFFF))
            else:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            col = col + 1
        row = row + 1

fn rounded_rect_top(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    """Rounded rectangle with only top corners rounded (for title bars)."""
    if w == 0 or h == 0:
        return
    val gw = render_width()
    val gh = render_height()
    var r = radius
    if r > w / 2:
        r = w / 2
    if r > h:
        r = h
    val r2 = r * r

    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= gh:
            return

        var x_start: u64 = 0
        var x_end: u64 = w

        if row < r:
            val dy = r - row
            var dx: u64 = 0
            while (dx + 1) * (dx + 1) + dy * dy <= r2:
                dx = dx + 1
            x_start = r - dx
            x_end = w - (r - dx)

        var col = x_start
        while col < x_end:
            val px = x + col
            if px >= gw:
                col = col + 1
                continue
            if alpha >= 255:
                px_write(px, py, 0xFF000000 | (color & 0x00FFFFFF))
            else:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            col = col + 1
        row = row + 1

# ============================================================================
# Circle
# ============================================================================

fn filled_circle(cx: u64, cy: u64, diameter: u64, color: u64, alpha: u64):
    """Draw a filled circle using scanline rasterization.

    (cx, cy) is the top-left of the bounding box, not the center.
    """
    if diameter == 0:
        return
    val gw = render_width()
    val gh = render_height()
    val r = diameter / 2
    val ox = cx + r
    val oy = cy + r
    val r2 = r * r

    var row: u64 = 0
    while row < diameter:
        val py = cy + row
        if py >= gh:
            row = row + 1
            continue

        var dy_abs: u64 = 0
        if row >= r:
            dy_abs = row - r
        else:
            dy_abs = r - row
        val dy2 = dy_abs * dy_abs
        if dy2 > r2:
            row = row + 1
            continue

        var dx: u64 = 0
        while (dx + 1) * (dx + 1) <= r2 - dy2:
            dx = dx + 1

        var x_left: u64 = 0
        if ox > dx:
            x_left = ox - dx
        var x_right = ox + dx
        if x_right >= gw:
            x_right = gw - 1

        var px = x_left
        while px <= x_right:
            if alpha >= 255:
                px_write(px, py, 0xFF000000 | (color & 0x00FFFFFF))
            else:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            px = px + 1
        row = row + 1

# ============================================================================
# Ring (Hollow Circle)
# ============================================================================

fn ring(cx: u64, cy: u64, outer_diameter: u64, thickness: u64, color: u64, alpha: u64):
    """Draw a ring (hollow circle). (cx, cy) is top-left of bounding box."""
    if outer_diameter == 0 or thickness == 0:
        return
    val gw = render_width()
    val gh = render_height()
    val outer_r = outer_diameter / 2
    val inner_r = if outer_r > thickness: outer_r - thickness else: 0
    val outer_r2 = outer_r * outer_r
    val inner_r2 = inner_r * inner_r
    val center_x = cx + outer_r
    val center_y = cy + outer_r

    var row: u64 = 0
    while row < outer_diameter:
        val py = cy + row
        if py >= gh:
            row = row + 1
            continue

        var dy_abs: u64 = 0
        if row >= outer_r:
            dy_abs = row - outer_r
        else:
            dy_abs = outer_r - row
        val dy2 = dy_abs * dy_abs
        if dy2 > outer_r2:
            row = row + 1
            continue

        var outer_dx: u64 = 0
        while (outer_dx + 1) * (outer_dx + 1) <= outer_r2 - dy2:
            outer_dx = outer_dx + 1

        var inner_dx: u64 = 0
        if dy2 < inner_r2:
            while (inner_dx + 1) * (inner_dx + 1) <= inner_r2 - dy2:
                inner_dx = inner_dx + 1

        var lx = center_x - outer_dx
        val lx_end = if dy2 < inner_r2: center_x - inner_dx else: center_x + 1
        while lx < lx_end:
            if lx < gw:
                if alpha >= 255:
                    px_write(lx, py, 0xFF000000 | (color & 0x00FFFFFF))
                else:
                    val dst = px_read(lx, py)
                    px_write(lx, py, alpha_blend(dst, color, alpha))
            lx = lx + 1

        var rx = if dy2 < inner_r2: center_x + inner_dx else: center_x
        val rx_end = center_x + outer_dx + 1
        while rx < rx_end:
            if rx < gw:
                if alpha >= 255:
                    px_write(rx, py, 0xFF000000 | (color & 0x00FFFFFF))
                else:
                    val dst = px_read(rx, py)
                    px_write(rx, py, alpha_blend(dst, color, alpha))
            rx = rx + 1

        row = row + 1

# ============================================================================
# Line (Bresenham)
# ============================================================================

fn line(x0: u64, y0: u64, x1: u64, y1: u64, color: u64, alpha: u64):
    """Draw a line using Bresenham's algorithm. Handles all octants."""
    val gw = render_width()
    val gh = render_height()
    var dx: u64 = 0
    var dy: u64 = 0
    var sx: u64 = 1
    var sy: u64 = 1
    var x_neg: u64 = 0
    var y_neg: u64 = 0

    if x1 >= x0:
        dx = x1 - x0
    else:
        dx = x0 - x1
        x_neg = 1

    if y1 >= y0:
        dy = y1 - y0
    else:
        dy = y0 - y1
        y_neg = 1

    var cx = x0
    var cy = y0

    if dx >= dy:
        var err: u64 = dx / 2
        var steps: u64 = 0
        while steps <= dx:
            if cx < gw and cy < gh:
                if alpha >= 255:
                    px_write(cx, cy, 0xFF000000 | (color & 0x00FFFFFF))
                else:
                    val dst = px_read(cx, cy)
                    px_write(cx, cy, alpha_blend(dst, color, alpha))

            if x_neg == 1:
                if cx == 0:
                    return
                cx = cx - 1
            else:
                cx = cx + 1

            if dy > err:
                err = err + dx - dy
                if y_neg == 1:
                    if cy == 0:
                        return
                    cy = cy - 1
                else:
                    cy = cy + 1
            else:
                err = err - dy

            steps = steps + 1
    else:
        var err: u64 = dy / 2
        var steps: u64 = 0
        while steps <= dy:
            if cx < gw and cy < gh:
                if alpha >= 255:
                    px_write(cx, cy, 0xFF000000 | (color & 0x00FFFFFF))
                else:
                    val dst = px_read(cx, cy)
                    px_write(cx, cy, alpha_blend(dst, color, alpha))

            if y_neg == 1:
                if cy == 0:
                    return
                cy = cy - 1
            else:
                cy = cy + 1

            if dx > err:
                err = err + dy - dx
                if x_neg == 1:
                    if cx == 0:
                        return
                    cx = cx - 1
                else:
                    cx = cx + 1
            else:
                err = err - dx

            steps = steps + 1
