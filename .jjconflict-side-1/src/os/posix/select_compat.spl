# Select/Poll Compatibility via Notification Multiplexing
#
# Emulates POSIX select()/poll() using SimpleOS's notification system.
# Each FD type has an associated notification ID:
#   - Pipes: data_ready / space_available notifications
#   - Sockets: IPC-based (poll via notification on netstack port)
#   - Serial: always ready (polling returns immediately)
#
# The key primitive is kernel syscall 29 (WaitAny), which blocks until
# any of a set of notifications fires.

use os.posix.errno.{EBADF, EINVAL, EIO}
use os.posix.fd_table.{fd_is_valid, fd_poll_ready, fd_poll_notification, POLLIN, POLLOUT, POLLERR, POLLHUP, POLLNVAL, MAX_FDS}
use os.userlib.syscall_raw.{syscall}

# Syscall numbers
val _SYS_NOTIF_POLL: u64 = 27
val _SYS_NOTIF_WAIT_ANY: u64 = 29
val _SYS_NOTIF_REGISTER_MULTI: u64 = 30

# Maximum FDs we can poll at once
val MAX_POLL_FDS: u64 = 64

# ============================================================================
# PollFd — per-fd poll request/result
# ============================================================================

struct PollFd:
    """A single file descriptor to poll, with requested and returned events."""
    fd: i32
    events: i16     # Requested events (POLLIN, POLLOUT)
    revents: i16    # Returned events (filled by posix_poll)

# ============================================================================
# posix_poll — poll multiple FDs for readiness
# ============================================================================

fn posix_poll(fds: [PollFd], timeout_ms: i64) -> i64:
    """Poll multiple file descriptors for I/O readiness.

    Args:
      fds:        array of PollFd structs with fd and requested events
      timeout_ms: -1 = block indefinitely, 0 = non-blocking, >0 = timeout in ms

    Returns:
      > 0: number of fds with events (revents filled in)
      = 0: timeout expired, no events
      < 0: -errno on error
    """
    if fds.len() == 0:
        return 0
    if fds.len() > MAX_POLL_FDS:
        return 0 - EINVAL as i64

    # Phase 1: Quick non-blocking check of all fds
    var ready_count: i64 = 0
    var fi: u64 = 0
    while fi < fds.len():
        fds[fi] = PollFd(fd: fds[fi].fd, events: fds[fi].events, revents: 0)
        val revents = _check_fd_events(fds[fi].fd, fds[fi].events)
        if revents != 0:
            fds[fi] = PollFd(fd: fds[fi].fd, events: fds[fi].events, revents: revents)
            ready_count = ready_count + 1
        fi = fi + 1

    # If any fd is ready or timeout is 0, return immediately
    if ready_count > 0 or timeout_ms == 0:
        return ready_count

    # Phase 2: Collect notification IDs for blocking wait
    var notif_ids: [u64] = []
    var notif_fd_map: [u64] = []  # Index into fds array for each notif
    fi = 0
    while fi < fds.len():
        val notif = _get_fd_notification(fds[fi].fd, fds[fi].events)
        if notif != 0:
            notif_ids.push(notif)
            notif_fd_map.push(fi)
        fi = fi + 1

    if notif_ids.len() == 0:
        # No blockable notifications — all fds are serial or invalid
        # Re-check once more and return
        return _recheck_all(fds)

    # Phase 3: Use WaitAny to block on collected notifications. Kernel
    # syscall 29 takes up to four notification IDs in arg0..arg3 and the
    # count in arg4.
    val notif_count = if notif_ids.len() > 4: 4u64 else: notif_ids.len()
    val n0 = if notif_count >= 1: notif_ids[0] else: 0u64
    val n1 = if notif_count >= 2: notif_ids[1] else: 0u64
    val n2 = if notif_count >= 3: notif_ids[2] else: 0u64
    val n3 = if notif_count >= 4: notif_ids[3] else: 0u64
    val wait_result = syscall(_SYS_NOTIF_WAIT_ANY, n0, n1, n2, n3, notif_count)

    if wait_result < 0 and timeout_ms > 0:
        return 0  # Timeout expired

    # Phase 4: Re-check all fds after wakeup
    _recheck_all(fds)

# ============================================================================
# posix_select — select on multiple FDs (higher-level wrapper)
# ============================================================================

fn posix_select(nfds: i32, readfds: [i32], writefds: [i32], timeout_ms: i64) -> i64:
    """Select on multiple file descriptors for read/write readiness.

    This is a convenience wrapper that builds PollFd array from separate
    read and write fd lists, calls posix_poll, and returns the count.

    Args:
      nfds:       ignored (included for POSIX signature compatibility)
      readfds:    array of fds to check for readability
      writefds:   array of fds to check for writability
      timeout_ms: -1 = block, 0 = non-blocking, >0 = timeout

    Returns:
      > 0: number of ready fds
      = 0: timeout
      < 0: -errno
    """
    var poll_fds: [PollFd] = []

    # Add read fds
    var ri: u64 = 0
    while ri < readfds.len():
        poll_fds.push(PollFd(fd: readfds[ri], events: POLLIN, revents: 0))
        ri = ri + 1

    # Add write fds
    var wi: u64 = 0
    while wi < writefds.len():
        # Check if this fd is already in the list (avoid duplicates)
        var found = false
        var pi: u64 = 0
        while pi < poll_fds.len():
            if poll_fds[pi].fd == writefds[wi]:
                # Merge: add POLLOUT to existing entry
                poll_fds[pi] = PollFd(
                    fd: poll_fds[pi].fd,
                    events: poll_fds[pi].events | POLLOUT,
                    revents: 0
                )
                found = true
                break
            pi = pi + 1
        if not found:
            poll_fds.push(PollFd(fd: writefds[wi], events: POLLOUT, revents: 0))
        wi = wi + 1

    posix_poll(poll_fds, timeout_ms)

# ============================================================================
# Internal: Per-FD Event Checking
# ============================================================================

fn _check_fd_events(fd: i32, events: i16) -> i16:
    """Non-blocking check of a single fd's readiness. Returns revents bitmask."""
    fd_poll_ready(fd, events)

fn _get_fd_notification(fd: i32, events: i16) -> u64:
    """Get the notification ID to wait on for a given fd and event mask.

    Returns 0 if the fd type doesn't support notification-based waiting.
    """
    fd_poll_notification(fd, events)

fn _recheck_all(fds: [PollFd]) -> i64:
    """Re-check all fds and update revents. Returns count of ready fds."""
    var ready: i64 = 0
    var i: u64 = 0
    while i < fds.len():
        val revents = _check_fd_events(fds[i].fd, fds[i].events)
        fds[i] = PollFd(fd: fds[i].fd, events: fds[i].events, revents: revents)
        if revents != 0:
            ready = ready + 1
        i = i + 1
    ready
