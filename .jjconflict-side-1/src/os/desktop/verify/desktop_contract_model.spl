use std.io_runtime

class SelectionModel:
    w0_id: text
    w0_focused: bool
    w0_visible: bool
    w1_id: text
    w1_focused: bool
    w1_visible: bool
    w2_id: text
    w2_focused: bool
    w2_visible: bool
    total_windows: i32

    static fn create(w0: text, w0f: bool, w0v: bool, w1: text, w1f: bool, w1v: bool, w2: text, w2f: bool, w2v: bool) -> SelectionModel:
        return SelectionModel(
            w0_id: w0,
            w0_focused: w0f,
            w0_visible: w0v,
            w1_id: w1,
            w1_focused: w1f,
            w1_visible: w1v,
            w2_id: w2,
            w2_focused: w2f,
            w2_visible: w2v,
            total_windows: 3
        )

    me focused_count() -> i32:
        var count: i32 = 0
        if self.w0_focused:
            count = count + 1
        if self.w1_focused:
            count = count + 1
        if self.w2_focused:
            count = count + 1
        return count

    me at_most_one_focused() -> bool:
        return self.focused_count() <= 1

    me selection_implies_visible() -> bool:
        if self.w0_focused:
            if self.w0_visible == false:
                return false
        if self.w1_focused:
            if self.w1_visible == false:
                return false
        if self.w2_focused:
            if self.w2_visible == false:
                return false
        return true

class FocusTracker:
    current_focus: text
    previous_focus: text
    transition_count: i32

    static fn none() -> FocusTracker:
        return FocusTracker(
            current_focus: "",
            previous_focus: "",
            transition_count: 0
        )

    me focus_on(wid: text) -> FocusTracker:
        return FocusTracker(
            current_focus: wid,
            previous_focus: self.current_focus,
            transition_count: self.transition_count + 1
        )

    me unfocus() -> FocusTracker:
        return FocusTracker(
            current_focus: "",
            previous_focus: self.current_focus,
            transition_count: self.transition_count
        )

    me has_focus() -> bool:
        return self.current_focus != ""

class WindowProvenance:
    window_id: text
    launcher_id: text
    is_orphan: bool

    static fn owned(wid: text, lid: text) -> WindowProvenance:
        return WindowProvenance(
            window_id: wid,
            launcher_id: lid,
            is_orphan: false
        )

    static fn orphan(wid: text) -> WindowProvenance:
        return WindowProvenance(
            window_id: wid,
            launcher_id: "",
            is_orphan: true
        )

    me launcher_owns() -> bool:
        return self.launcher_id != "" and self.is_orphan == false

class CrashPolicy:
    scope: text
    action: text
    propagates: bool

    static fn process_restart() -> CrashPolicy:
        return CrashPolicy(
            scope: "process",
            action: "restart",
            propagates: false
        )

    static fn window_terminate() -> CrashPolicy:
        return CrashPolicy(
            scope: "window",
            action: "terminate",
            propagates: false
        )

    static fn desktop_contained() -> CrashPolicy:
        return CrashPolicy(
            scope: "desktop",
            action: "restart",
            propagates: false
        )

    me crash_doesnt_propagate() -> bool:
        return self.propagates == false

    me is_restart_safe() -> bool:
        return self.action == "restart"

class CrashVerdict:
    policy_scope: text
    affected_id: text
    was_contained: bool
    restarted: bool

    static fn contained_restart(scope: text, affected: text) -> CrashVerdict:
        return CrashVerdict(
            policy_scope: scope,
            affected_id: affected,
            was_contained: true,
            restarted: true
        )

    static fn uncontained(scope: text, affected: text) -> CrashVerdict:
        return CrashVerdict(
            policy_scope: scope,
            affected_id: affected,
            was_contained: false,
            restarted: false
        )

    me is_safe() -> bool:
        return self.was_contained
