# SimpleOS desktop WM runtime bridge.
#
# Thin SimpleOS-facing adapter over the shared WM scene/runtime contracts.
# The desktop shell loop can call this with framebuffer/compositor pointer
# coordinates and receive the same runtime commands as the host web WM bridge.

use common.ui.taskbar_model.{TaskbarModel}
use common.ui.window_scene.{SharedWmScene, shared_wm_dispatch_pointer}
use common.ui.wm_runtime_dispatch.{WmRuntimeDispatchCommand, WmRuntimeShellState, wm_runtime_apply_command, wm_runtime_command_from_shared_dispatch}

fn simpleos_wm_pointer_runtime_command(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> WmRuntimeDispatchCommand:
    val dispatch = shared_wm_dispatch_pointer(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    wm_runtime_command_from_shared_dispatch(dispatch)

fn simpleos_wm_apply_pointer(state: WmRuntimeShellState, scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> WmRuntimeShellState:
    val command = simpleos_wm_pointer_runtime_command(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    wm_runtime_apply_command(state, command)

fn simpleos_wm_pointer_runtime_marker(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> text:
    val command = simpleos_wm_pointer_runtime_command(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    "[simpleos-wm] command={command.kind} target={command.target_id} app={command.app_id} window={command.window_id} handled={command.handled}"

fn simpleos_wm_event_loop_marker(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> text:
    val command = simpleos_wm_pointer_runtime_command(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    "[simpleos-wm] loop-step command={command.kind} target={command.target_id} app={command.app_id} window={command.window_id} handled={command.handled}"
