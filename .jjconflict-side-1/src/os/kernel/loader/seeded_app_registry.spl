# Central seeded app registry for desktop/toolchain disk images.
#
# Keeps the current seeded filesystem app namespace in one small dependency-light
# module so boot proofs and launchers do not duplicate per-entry path lists.

pub fn seeded_desktop_app_paths() -> [text]:
    [
        "/sys/apps/info",
        "/sys/apps/browser_demo",
        "/sys/apps/hello_world",
        "/sys/apps/file_manager",
        "/sys/apps/shell",
        "/sys/apps/editor",
        "/sys/apps/simple_browser",
        "/sys/apps/smux",
        "/sys/apps/simple_compiler",
        "/sys/apps/simple_interpreter",
        "/sys/apps/simple_loader",
        "/sys/apps/llvm",
        "/sys/apps/clang",
        "/sys/apps/rust"
    ]
