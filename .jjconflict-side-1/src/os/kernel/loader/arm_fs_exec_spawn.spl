# ARM filesystem-exec spawn bridge.
#
# Keeps the ARM QEMU filesystem-exec acceptance entries routed through the
# architecture-specific loader on ARM64 while the ARM32 lane remains on the
# lightweight filesystem probe path.

@cfg(arm64)
use os.kernel.loader.arm64_fs_exec_spawn.{arm64_fs_exec_spawn}

@cfg(arm32)
use os.services.vfs.arm_fs_exec_vfs.{arm_fs_exec_read_file_bytes}

@cfg(arm64)
use os.services.vfs.arm_fs_exec_vfs.{arm_fs_exec_read_file_bytes}

extern fn rt_arm_array_len_u32(arr: [u8]) -> u32

@cfg(arm32)
pub fn arm_fs_exec_spawn_path(path: text) -> i64:
    """Return a unique pid once the ARM32 VFS lane resolves executable bytes."""
    val bytes = arm_fs_exec_read_file_bytes(path)
    val byte_len = rt_arm_array_len_u32(bytes)
    if byte_len <= 4:
        return -2
    byte_len.to_i64()

@cfg(arm64)
pub fn arm_fs_exec_spawn_path(path: text) -> i64:
    """Use the ARM64-owned loader/handoff path on ARM64."""
    arm64_fs_exec_spawn(path, [], [])

@cfg(arm64)
pub fn arm_fs_exec_spawn_hello_world_smf() -> i64:
    """Probe the filesystem-backed `/sys/apps/hello_world.smf` process image."""
    arm_fs_exec_spawn_path("/sys/apps/hello_world.smf")

@cfg(arm32)
pub fn arm_fs_exec_spawn_hello_world_smf() -> i64:
    """Resolve `/sys/apps/hello_world.smf` through the ARM32 fs-exec byte lane."""
    arm_fs_exec_spawn_path("/sys/apps/hello_world.smf")
