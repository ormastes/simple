# x86_32 Paging Adapter Scaffold
#
# Thin wrapper layer over the concrete x86_32 paging module.

use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags}
use os.kernel.memory.pmm.{PhysMemManager}
use os.kernel.arch.x86_32.paging.{X86_32Paging}

fn paging_init(pmm_manager: PhysMemManager):
    """Initialize the x86_32 paging subsystem."""
    var paging = X86_32Paging()
    paging.init(pmm_manager)

fn paging_map_page(virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    """Map one x86_32 page."""
    var paging = X86_32Paging()
    paging.map_page(virt, phys, flags)

fn paging_unmap_page(virt: VirtAddr) -> bool:
    """Unmap one x86_32 page."""
    var paging = X86_32Paging()
    paging.unmap_page(virt)

fn paging_translate(virt: VirtAddr) -> PhysAddr?:
    """Translate one x86_32 virtual address."""
    var paging = X86_32Paging()
    paging.translate(virt)

fn paging_create_address_space() -> u32:
    """Create a new x86_32 address-space root."""
    var paging = X86_32Paging()
    paging.create_address_space()

fn paging_switch_address_space(root_phys: u32):
    """Switch the active x86_32 address space."""
    var paging = X86_32Paging()
    paging.switch_address_space(root_phys)

fn paging_page_size() -> u32:
    """Return the x86_32 page size."""
    var paging = X86_32Paging()
    paging.page_size()

fn paging_levels() -> u32:
    """Return the number of x86_32 paging levels."""
    var paging = X86_32Paging()
    paging.address_levels()
