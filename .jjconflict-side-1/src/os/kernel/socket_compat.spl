# POSIX Socket Compatibility — wrappers over netstack IPC
#
# Provides POSIX-like socket API (socket, bind, listen, connect, accept,
# send, recv, close) that communicates with the netstack service via IPC
# on port 2 (exokernel design — user-space service, not kernel-mediated).
#
# Wire protocol (matches netstack_service.spl IPC handlers):
#   Request:  method(u32) | payload(bytes)
#   Response: status(i32) | payload(bytes)
#
# Each socket operation sends a request to port 2 and blocks waiting
# for the reply. The netstack service manages the actual TCP/UDP state.

use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}
use os.kernel.errno.{EACCES, ENOSYS, ECONNREFUSED, ENOTCONN, EAGAIN, EMFILE, EADDRINUSE}
use os.kernel.fd_table.{fd_alloc, fd_set, fd_close, fd_is_valid, fd_get_status_flags, fd_get_type, fd_get_backend_handle, fd_update_ready}
use os.ai_cli_js_node_contract.{AiCliManifest, ai_cli_socket_network_decision}
use os.kernel.net.loopback_socket.{
    loopback_is_loopback_addr, loopback_register, loopback_is_connected,
    loopback_bind, loopback_connect, loopback_send, loopback_recv, loopback_close
}
# Well-known netstack service IPC port
val _NET_PORT: u64 = 2
val NET_SOCKET: u32 = 1
val NET_BIND: u32 = 2
val NET_LISTEN: u32 = 3
val NET_CONNECT: u32 = 4
val NET_ACCEPT: u32 = 5
val NET_SEND: u32 = 6
val NET_RECV: u32 = 7
val NET_CLOSE: u32 = 8

# Socket types (POSIX)
val SOCK_STREAM: i32 = 1   # TCP
val SOCK_DGRAM: i32 = 2    # UDP
val AF_INET: i32 = 2
val _EBADF: i32 = 9
val _ENOTSOCK: i32 = 88
val _POLLOUT: i16 = 4
val _POLLERR: i16 = 8

# Sentinel backend handle meaning "no netstack-backed socket created yet".
# posix_socket() no longer creates the netstack socket eagerly (that made
# socket() itself depend on a live netstack IPC responder); the real,
# non-loopback backend is created lazily on first non-loopback bind/connect
# via _ensure_netstack_fd(). Loopback (127.0.0.1) traffic never needs a
# netstack fd at all -- see os.kernel.net.loopback_socket.
val _NETSTACK_FD_UNSET: u64 = 0xFFFFFFFFu64

var g_ai_cli_socket_manifest: AiCliManifest? = nil
var g_ai_cli_socket_bound_fds: [i32] = []
var g_ai_cli_socket_bound_endpoints: [text] = []

extern fn unsafe_addr_of(ref: any) -> u64
extern fn mmio_write8(addr: u64, val_: u8)
extern fn mmio_read8(addr: u64) -> u8

# Direct IPC functions — bypasses Cranelift-stubbed syscall
# (inline asm in syscall_raw.spl not supported by Cranelift)
extern fn rt_ipc_send(port: u64, method: u64, flags: u64, buf_addr: u64, buf_len: u64) -> i64
extern fn rt_ipc_recv(port: u64, buf_addr: u64, max_len: u64) -> i64
extern fn rt_ipc_send_bytes(port: u64, method: u64, data: [u8]) -> i64
extern fn rt_ipc_recv_bytes(port: u64, max_len: i64) -> [u8]

# ============================================================================
# Socket Address
# ============================================================================

struct SockaddrIn:
    """IPv4 socket address (POSIX sockaddr_in equivalent)."""
    family: i32     # AF_INET = 2
    port: u16       # Port number (host byte order)
    addr: u32       # IPv4 address as packed u32 (network byte order)

fn sockaddr_in(port: u16, a: u8, b: u8, c: u8, d: u8) -> SockaddrIn:
    """Create an IPv4 socket address from octets and port."""
    val packed = (a as u32) | ((b as u32) << 8) | ((c as u32) << 16) | ((d as u32) << 24)
    SockaddrIn(family: AF_INET, port: port, addr: packed)

fn sockaddr_any(port: u16) -> SockaddrIn:
    """Create an INADDR_ANY socket address (bind to all interfaces)."""
    SockaddrIn(family: AF_INET, port: port, addr: 0)

fn set_ai_cli_socket_manifest_for_test(manifest: AiCliManifest):
    g_ai_cli_socket_manifest = manifest
    g_ai_cli_socket_bound_fds = []
    g_ai_cli_socket_bound_endpoints = []

fn clear_ai_cli_socket_manifest_for_test():
    g_ai_cli_socket_manifest = nil
    g_ai_cli_socket_bound_fds = []
    g_ai_cli_socket_bound_endpoints = []

# ============================================================================
# Socket Operations
# ============================================================================

fn posix_socket(domain: i32, type_: i32, protocol: i32) -> i64:
    """Create a socket. Returns fd or -errno.

    domain:   AF_INET (2)
    type_:    SOCK_STREAM (1) for TCP, SOCK_DGRAM (2) for UDP
    protocol: 0 (auto-select based on type)

    Allocates the local fd immediately without contacting the netstack
    service. The real (non-loopback) netstack-backed socket is created
    lazily by _ensure_netstack_fd() on first non-loopback bind()/connect()
    -- see _NETSTACK_FD_UNSET. Loopback (127.0.0.1) traffic is served
    entirely by os.kernel.net.loopback_socket and never touches the
    netstack IPC path.
    """
    if domain != AF_INET:
        return -22

    var proto: i64 = 0
    if type_ == SOCK_STREAM:
        proto = 1
    elif type_ == SOCK_DGRAM:
        proto = 2
    else:
        return -22

    val fd = fd_alloc()
    log_info("[posix] " + "[socket_compat] fd_alloc -> {fd}")
    if fd < 0:
        return fd as i64

    val set_result = fd_set(fd, 4, proto.to_u32(), _NETSTACK_FD_UNSET)
    if set_result < 0:
        return set_result as i64
    loopback_register(fd)
    fd as i64

fn posix_bind(fd: i32, addr: SockaddrIn) -> i64:
    """Bind socket to address. Returns 0 or -errno.

    Loopback destinations (127.0.0.0/8) bind through the pure in-memory
    os.kernel.net.loopback_socket registry and never touch the netstack
    IPC path.
    """
    if not fd_is_valid(fd):
        return (0 - _EBADF) as i64
    if fd_get_type(fd) != 4:
        return (0 - _ENOTSOCK) as i64
    val endpoint = _sockaddr_endpoint(addr)
    val grant_errno = _socket_grant_errno("bind", endpoint)
    if grant_errno < 0:
        return grant_errno

    if loopback_is_loopback_addr(addr.addr):
        val rc = loopback_bind(fd, addr.port)
        if rc == 0:
            _record_bound_endpoint(fd, endpoint)
        return rc as i64

    val net_fd = _resolve_net_fd(fd)
    if net_fd < 0:
        return net_fd

    var payload: [u8] = []
    _sock_push_i32(payload, net_fd as i32)
    _sock_push_u32(payload, addr.addr)
    _sock_push_u16(payload, addr.port)
    val reply = _net_ipc_request(NET_BIND, payload)
    if reply.status == 0:
        _record_bound_endpoint(fd, endpoint)
    reply.status as i64

fn posix_listen(fd: i32, backlog: i32) -> i64:
    """Start listening for connections. Returns 0 or -errno."""
    val net_fd = _get_net_fd(fd)
    if net_fd < 0:
        return net_fd as i64
    val endpoint = _bound_endpoint_for_fd(fd)
    val listen_endpoint = if endpoint == nil: "0.0.0.0:0" else: endpoint.unwrap()
    val grant_errno = _socket_grant_errno("listen", listen_endpoint)
    if grant_errno < 0:
        return grant_errno

    var payload: [u8] = []
    _sock_push_i32(payload, net_fd)
    _sock_push_u32(payload, backlog.to_u32())
    val reply = _net_ipc_request(NET_LISTEN, payload)
    reply.status as i64

fn posix_connect(fd: i32, addr: SockaddrIn) -> i64:
    """Connect to remote address. Returns 0 or -errno.

    Loopback destinations (127.0.0.0/8) connect through the pure in-memory
    os.kernel.net.loopback_socket registry and never touch the netstack
    IPC path.

    Non-blocking TCP sockets return -EINPROGRESS while the SYN handshake is
    active; write readiness is not set until a later successful completion.
    """
    if not fd_is_valid(fd):
        return (0 - _EBADF) as i64
    if fd_get_type(fd) != 4:
        return (0 - _ENOTSOCK) as i64
    val endpoint = _sockaddr_endpoint(addr)
    val grant_errno = _socket_grant_errno("connect", endpoint)
    if grant_errno < 0:
        return grant_errno

    if loopback_is_loopback_addr(addr.addr):
        val rc = loopback_connect(fd, addr.port)
        if rc == 0:
            fd_update_ready(fd, _POLLOUT, _POLLERR)
        else:
            fd_update_ready(fd, _POLLERR, _POLLOUT)
        return rc as i64

    val net_fd = _resolve_net_fd(fd)
    if net_fd < 0:
        return net_fd

    val nonblocking = (fd_get_status_flags(fd) & 2048) != 0
    var payload: [u8] = []
    _sock_push_i32(payload, net_fd as i32)
    _sock_push_u32(payload, addr.addr)
    _sock_push_u16(payload, addr.port)
    _sock_push_u32(payload, if nonblocking: 1u32 else: 0u32)
    val reply = _net_ipc_request(NET_CONNECT, payload)
    if reply.status == 0:
        fd_update_ready(fd, _POLLOUT, _POLLERR)
    elif reply.status == -115:
        fd_update_ready(fd, 0 as i16, _POLLOUT | _POLLERR)
    else:
        fd_update_ready(fd, _POLLERR, _POLLOUT)
    reply.status as i64

fn posix_accept(fd: i32) -> i64:
    """Accept incoming connection. Returns new fd or -errno."""
    val net_fd = _get_net_fd(fd)
    if net_fd < 0:
        return net_fd as i64

    var payload: [u8] = []
    _sock_push_i32(payload, net_fd)
    val reply = _net_ipc_request(NET_ACCEPT, payload)
    if reply.status < 0:
        return reply.status as i64

    val accepted_fd = fd_alloc()
    if accepted_fd < 0:
        _net_close_remote(reply.value_i32)
        return accepted_fd as i64

    val set_result = fd_set(accepted_fd, 4, 2, reply.value_i32.to_u64())
    if set_result < 0:
        _net_close_remote(reply.value_i32)
        return set_result as i64
    accepted_fd as i64

fn posix_send(fd: i32, data_addr: u64, data_len: u64, flags: i32) -> i64:
    """Send data on connected socket. Returns bytes sent or -errno."""
    posix_send_bytes(fd, _copy_user_bytes(data_addr, data_len), flags)

fn posix_send_bytes(fd: i32, data: [u8], flags: i32) -> i64:
    """Send byte array on connected socket. Returns bytes sent or -errno.

    Loopback-connected sockets deliver directly into the peer's in-memory
    recv queue (os.kernel.net.loopback_socket); never touches netstack IPC.
    """
    if loopback_is_connected(fd):
        return loopback_send(fd, data)

    val net_fd = _get_net_fd(fd)
    if net_fd < 0:
        return net_fd as i64

    var payload: [u8] = []
    _sock_push_i32(payload, net_fd)
    var i: u64 = 0
    while i < data.len():
        payload.push(data[i])
        i = i + 1
    val reply = _net_ipc_request(NET_SEND, payload)
    if reply.status < 0:
        return reply.status as i64
    reply.value_i32 as i64

fn posix_recv(fd: i32, buf_addr: u64, max_len: u64, flags: i32) -> i64:
    """Receive data from socket into user buffer. Returns bytes received or -errno."""
    match posix_recv_bytes(fd, max_len, flags):
        Ok(reply):
            var i: u64 = 0
            while i < reply.len() and i < max_len:
                mmio_write8(buf_addr + i, reply[i])
                i = i + 1
            i as i64
        Err(err):
            -5

fn posix_recv_bytes(fd: i32, max_len: u64, flags: i32) -> Result<[u8], text>:
    """Receive data from socket as byte array. Returns bytes or error text.

    Loopback-connected sockets pop directly from the local in-memory recv
    queue (os.kernel.net.loopback_socket); never touches netstack IPC.
    """
    if loopback_is_connected(fd):
        return Ok(loopback_recv(fd, max_len))

    val net_fd = _get_net_fd(fd)
    if net_fd < 0:
        return Err("bad fd")

    var payload: [u8] = []
    _sock_push_i32(payload, net_fd)
    _sock_push_u32(payload, max_len.to_u32())
    val reply = _net_ipc_request_bytes(NET_RECV, payload)
    if reply.status < 0:
        return Err("recv failed")
    Ok(reply.data)

fn posix_close_socket(fd: i32) -> i64:
    """Close a socket. Returns 0 or -errno."""
    loopback_close(fd)
    val net_fd = _get_net_fd(fd)
    if net_fd >= 0:
        _net_close_remote(net_fd)
    fd_close(fd) as i64

fn _copy_user_bytes(data_addr: u64, data_len: u64) -> [u8]:
    var data: [u8] = []
    var i: u64 = 0
    while i < data_len:
        data.push(mmio_read8(data_addr + i))
        i = i + 1
    data

# ============================================================================
# Internal Helpers
# ============================================================================

struct _NetIpcReply:
    """Parsed IPC reply from netstack."""
    status: i32
    value_i32: i32

struct _NetIpcReplyBytes:
    """Parsed IPC reply with byte payload from netstack."""
    status: i32
    data: [u8]

fn _get_net_fd(fd: i32) -> i32:
    """Get the netstack-side fd for a local socket fd. Returns -EBADF on error."""
    if not fd_is_valid(fd):
        return 0 - _EBADF
    if fd_get_type(fd) != 4:
        return 0 - _ENOTSOCK
    fd_get_backend_handle(fd) as i32

fn _ensure_netstack_fd(fd: i32) -> i32:
    """Lazily create the real netstack-backed socket for fd, if not already
    created. Returns the netstack fd (>= 0) or -errno.

    ponytail: this is the remaining NIC-driver gap -- it still requires a
    live os.services.netstack.netstack_service responder on IPC port 2.
    """
    val handle = fd_get_backend_handle(fd)
    if handle != _NETSTACK_FD_UNSET:
        return handle as i32

    val proto = (fd_get_status_flags(fd) & 3u32).to_i64()
    var payload: [u8] = []
    payload.push(proto.to_u8())
    val reply = _net_ipc_request(NET_SOCKET, payload)
    log_info("[posix] " + "[socket_compat] lazy netstack socket proto={proto} status={reply.status} value={reply.value_i32}")
    if reply.status < 0:
        return reply.status

    val set_result = fd_set(fd, 4, fd_get_status_flags(fd), reply.value_i32.to_u64())
    if set_result < 0:
        _net_close_remote(reply.value_i32)
        return set_result
    reply.value_i32

fn _resolve_net_fd(fd: i32) -> i64:
    """Validate fd is a socket and return its netstack fd, creating the
    netstack-backed socket lazily if needed. Returns -errno on failure."""
    if not fd_is_valid(fd):
        return (0 - _EBADF) as i64
    if fd_get_type(fd) != 4:
        return (0 - _ENOTSOCK) as i64
    _ensure_netstack_fd(fd) as i64

fn _socket_grant_errno(operation: text, endpoint: text) -> i64:
    if not g_ai_cli_socket_manifest.?:
        return 0
    val manifest = g_ai_cli_socket_manifest
    val decision = ai_cli_socket_network_decision(manifest, operation, endpoint)
    if decision.allowed:
        return 0
    log_warn("[posix] " + "[socket_compat] network grant denied operation={operation} endpoint={endpoint} reason={decision.reason}")
    0 - EACCES as i64

fn _sockaddr_endpoint(addr: SockaddrIn) -> text:
    "{_ipv4_addr_text(addr.addr)}:{addr.port as i64}"

fn _ipv4_addr_text(addr: u32) -> text:
    val a = (addr & 0xFF) as u32
    val b = ((addr >> 8) & 0xFF) as u32
    val c = ((addr >> 16) & 0xFF) as u32
    val d = ((addr >> 24) & 0xFF) as u32
    "{a}.{b}.{c}.{d}"

fn _record_bound_endpoint(fd: i32, endpoint: text):
    var i = 0
    while i < g_ai_cli_socket_bound_fds.len():
        if g_ai_cli_socket_bound_fds[i] == fd:
            g_ai_cli_socket_bound_endpoints[i] = endpoint
            return
        i = i + 1
    g_ai_cli_socket_bound_fds.push(fd)
    g_ai_cli_socket_bound_endpoints.push(endpoint)

fn _bound_endpoint_for_fd(fd: i32) -> text?:
    var i = 0
    while i < g_ai_cli_socket_bound_fds.len():
        if g_ai_cli_socket_bound_fds[i] == fd:
            return Some(g_ai_cli_socket_bound_endpoints[i])
        i = i + 1
    nil

fn _array_data_ptr(data: [u8]) -> u64:
    val hdr = unsafe_addr_of(data)
    hdr + 16

fn _net_ipc_request(method: u32, payload: [u8]) -> _NetIpcReply:
    """Send IPC request to netstack and receive i32 reply."""
    val send_result = rt_ipc_send_bytes(_NET_PORT, method as u64, payload)
    if send_result < 0:
        return _NetIpcReply(status: -5, value_i32: 0)

    # Receive reply: status(i32) | value(i32)
    val reply_buf = rt_ipc_recv_bytes(_NET_PORT, 64)
    if reply_buf.len() < 4:
        return _NetIpcReply(status: -5, value_i32: 0)

    val status = _sock_read_i32(reply_buf, 0)
    val value = if reply_buf.len() >= 8: _sock_read_i32(reply_buf, 4) else: 0
    _NetIpcReply(status: status, value_i32: value)

fn _net_ipc_request_bytes(method: u32, payload: [u8]) -> _NetIpcReplyBytes:
    """Send IPC request to netstack and receive byte array reply."""
    val send_result = rt_ipc_send_bytes(_NET_PORT, method as u64, payload)
    if send_result < 0:
        return _NetIpcReplyBytes(status: -5, data: [])

    # Receive reply: status(i32) | data(bytes)
    val reply_buf = rt_ipc_recv_bytes(_NET_PORT, 4096)
    if reply_buf.len() < 4:
        return _NetIpcReplyBytes(status: -5, data: [])

    val status = _sock_read_i32(reply_buf, 0)
    if status < 0:
        return _NetIpcReplyBytes(status: status, data: [])

    # Extract data bytes (after 4-byte status)
    val data_len = if reply_buf.len() > 4: reply_buf.len() - 4 else: 0
    var data: [u8] = []
    var i: u64 = 0
    while i < data_len:
        data.push(reply_buf[4 + i])
        i = i + 1

    _NetIpcReplyBytes(status: 0, data: data)

fn _net_close_remote(net_fd: i32):
    """Send NET_CLOSE to netstack for a netstack-side fd."""
    var payload: [u8] = []
    _sock_push_i32(payload, net_fd)
    rt_ipc_send_bytes(_NET_PORT, NET_CLOSE as u64, payload)
    # Best-effort close: ignore IPC errors

# ============================================================================
# Serialization Helpers
# ============================================================================

fn _sock_push_u16(buf: [u8], val_: u16):
    """Push a u16 in little-endian byte order."""
    buf.push((val_ & 0xFF) as u8)
    buf.push(((val_ >> 8) & 0xFF) as u8)

fn _sock_push_u32(buf: [u8], val_: u32):
    """Push a u32 in little-endian byte order."""
    buf.push((val_ & 0xFF) as u8)
    buf.push(((val_ >> 8) & 0xFF) as u8)
    buf.push(((val_ >> 16) & 0xFF) as u8)
    buf.push(((val_ >> 24) & 0xFF) as u8)

fn _sock_push_i32(buf: [u8], val_: i32):
    """Push an i32 in little-endian byte order."""
    _sock_push_u32(buf, val_ as u32)

fn _sock_read_i32(buf: [u8], offset: u64) -> i32:
    """Read a little-endian i32 from a byte buffer."""
    val b0 = buf[offset] as u32
    val b1 = buf[offset + 1] as u32
    val b2 = buf[offset + 2] as u32
    val b3 = buf[offset + 3] as u32
    (b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)) as i32

fn _sock_read_u32(buf: [u8], offset: u64) -> u32:
    """Read a little-endian u32 from a byte buffer."""
    val b0 = buf[offset] as u32
    val b1 = buf[offset + 1] as u32
    val b2 = buf[offset + 2] as u32
    val b3 = buf[offset + 3] as u32
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
