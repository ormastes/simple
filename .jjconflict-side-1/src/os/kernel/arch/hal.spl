@cfg(x86_64)
fn hal_timer_set_deadline(delay_us: u64):
    """Set one-shot timer deadline in microseconds.

    HAL contract: delay_us is a relative delay in microseconds.
    The x86_64 implementation converts to APIC timer ticks internally.
    """
    var timer = X86Timer()
    timer.set_oneshot(delay_us)

