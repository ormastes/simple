@cfg(x86_64)
fn hal_context_restore(ctx: ArchContext):
    """Restore CPU state — x86_64 load GPRs + rflags + segments."""
    match ctx:
        ArchContext.X86_64(x86_ctx):
            var ctx_switch = X86ContextSwitch()
            # Create a dummy "from" context; switch loads "to" context
            val dummy = ctx_switch.create(0, 0, false)
            ctx_switch.switch(dummy, x86_ctx)
        _:
            pass_todo("context_restore: architecture mismatch")

