# RISC-V 64 stack canary HAL surface.

use os.kernel.arch.riscv64.entropy.{entropy_seed_u64}

var g_canary_value: u64 = 0

fn canary_init(seed: u64):
    if seed == 0:
        g_canary_value = entropy_seed_u64()
    else:
        g_canary_value = seed
    if g_canary_value == 0:
        g_canary_value = 0xA5A55A5AA55A5AA5

fn canary_value() -> u64:
    if g_canary_value == 0:
        canary_init(0)
    g_canary_value

fn canary_fail() -> i32:
    -1
