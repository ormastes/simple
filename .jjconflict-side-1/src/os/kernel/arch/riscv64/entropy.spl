# RISC-V 64 early-boot entropy mixer.

@cfg(riscv64)
extern fn rt_riscv_seed() -> u64
extern fn rt_time_now_unix_micros() -> i64
use os.kernel.arch.riscv64.cpu.{csrr_cycle, csrr_instret, csrr_time}

fn _mix64(x: u64) -> u64:
    var v = x ^ (x >> 30)
    v = v * 0xBF58476D1CE4E5B9
    v = v ^ (v >> 27)
    v = v * 0x94D049BB133111EB
    v ^ (v >> 31)

fn entropy_seed_u64() -> u64:
    # No standard SBI sbi_get_random source is available in the current
    # QEMU/OpenSBI path. Mix the runtime seed with cycle+time+instret as a
    # best-effort early-boot fallback; TLS readiness still requires a true
    # production entropy source before it can be enabled.
    _mix64(
        rt_riscv_seed() ^
        csrr_cycle() ^
        csrr_time() ^
        csrr_instret() ^
        rt_time_now_unix_micros().to_u64() ^
        0x52563634
    )
