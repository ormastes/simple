class SmokeMedia:
    media_type: text
    image_path: text
    is_attached: bool
    mount_point: text

    me is_disk() -> bool:
        return self.media_type == "disk"

    me is_cdrom() -> bool:
        return self.media_type == "cdrom"

    me attach() -> SmokeMedia:
        return SmokeMedia(media_type: self.media_type, image_path: self.image_path, is_attached: true, mount_point: self.mount_point)

    me detach() -> SmokeMedia:
        return SmokeMedia(media_type: self.media_type, image_path: self.image_path, is_attached: false, mount_point: self.mount_point)

    me to_text() -> text:
        return "media:" + self.media_type + " path=" + self.image_path + " attached=" + self.is_attached.to_text()

    static fn disk(path: text, mount: text) -> SmokeMedia:
        return SmokeMedia(media_type: "disk", image_path: path, is_attached: false, mount_point: mount)

    static fn cdrom(path: text) -> SmokeMedia:
        return SmokeMedia(media_type: "cdrom", image_path: path, is_attached: false, mount_point: "/mnt/cdrom")


class BootPhase:
    phase_name: text
    completed: bool
    duration_ms: int
    error_msg: text

    me is_done() -> bool:
        return self.completed

    me complete(ms: int) -> BootPhase:
        return BootPhase(phase_name: self.phase_name, completed: true, duration_ms: ms, error_msg: self.error_msg)

    me fail(msg: text) -> BootPhase:
        return BootPhase(phase_name: self.phase_name, completed: false, duration_ms: self.duration_ms, error_msg: msg)

    me to_text() -> text:
        if self.completed:
            return "phase:" + self.phase_name + " OK " + self.duration_ms.to_text() + "ms"
        return "phase:" + self.phase_name + " PENDING"

    static fn create(name: text) -> BootPhase:
        return BootPhase(phase_name: name, completed: false, duration_ms: 0, error_msg: "")


class HostedBoot:
    f0_phase: BootPhase
    f1_phase: BootPhase
    f2_phase: BootPhase
    f3_phase: BootPhase
    phase_count: int

    me all_complete() -> bool:
        if self.phase_count == 0:
            return false
        if self.phase_count >= 1:
            if self.f0_phase.completed == false:
                return false
        if self.phase_count >= 2:
            if self.f1_phase.completed == false:
                return false
        if self.phase_count >= 3:
            if self.f2_phase.completed == false:
                return false
        if self.phase_count >= 4:
            if self.f3_phase.completed == false:
                return false
        return true

    me add_phase(p: BootPhase) -> HostedBoot:
        if self.phase_count == 0:
            return HostedBoot(f0_phase: p, f1_phase: self.f1_phase, f2_phase: self.f2_phase, f3_phase: self.f3_phase, phase_count: 1)
        if self.phase_count == 1:
            return HostedBoot(f0_phase: self.f0_phase, f1_phase: p, f2_phase: self.f2_phase, f3_phase: self.f3_phase, phase_count: 2)
        if self.phase_count == 2:
            return HostedBoot(f0_phase: self.f0_phase, f1_phase: self.f1_phase, f2_phase: p, f3_phase: self.f3_phase, phase_count: 3)
        return HostedBoot(f0_phase: self.f0_phase, f1_phase: self.f1_phase, f2_phase: self.f2_phase, f3_phase: p, phase_count: 4)

    me current_phase() -> BootPhase:
        if self.phase_count >= 1:
            if self.f0_phase.completed == false:
                return self.f0_phase
        if self.phase_count >= 2:
            if self.f1_phase.completed == false:
                return self.f1_phase
        if self.phase_count >= 3:
            if self.f2_phase.completed == false:
                return self.f2_phase
        if self.phase_count >= 4:
            if self.f3_phase.completed == false:
                return self.f3_phase
        return self.f0_phase

    me to_text() -> text:
        return "boot(" + self.phase_count.to_text() + " phases)"

    static fn create() -> HostedBoot:
        val empty_phase = BootPhase.create("")
        return HostedBoot(f0_phase: empty_phase, f1_phase: empty_phase, f2_phase: empty_phase, f3_phase: empty_phase, phase_count: 0)


class BootReport:
    boot: HostedBoot
    overall_status: text
    total_ms: int
    media_count: int

    me is_success() -> bool:
        return self.overall_status == "success"

    me mark_success(ms: int) -> BootReport:
        return BootReport(boot: self.boot, overall_status: "success", total_ms: ms, media_count: self.media_count)

    me mark_failed() -> BootReport:
        return BootReport(boot: self.boot, overall_status: "failed", total_ms: self.total_ms, media_count: self.media_count)

    me to_text() -> text:
        return "boot-report: " + self.overall_status + " " + self.total_ms.to_text() + "ms"

    static fn create(b: HostedBoot, mc: int) -> BootReport:
        return BootReport(boot: b, overall_status: "pending", total_ms: 0, media_count: mc)
