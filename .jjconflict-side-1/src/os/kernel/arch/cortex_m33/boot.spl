"""Cortex-M33 Boot — Vector Table + Reset Handler for MPS2-AN505.

Bare-metal boot entry for ARMv8-M Mainline (Cortex-M33).
Freestanding: no heap, no runtime, no imports beyond mmio.

Boot chain: vector_table → reset_handler → boot_main → shell_main

Memory layout (MPS2-AN505 QEMU):
  0x00000000  Vector table (initial SP + exception vectors)
  0x00000xxx  .text (code)
  0x20000000  .data / .bss / heap / stack
"""

use os.kernel.arch.cortex_m33.console.{uart_init, uart_writeln}
use os.kernel.arch.cortex_m33.shell_lite.{shell_main}

extern var _sidata: u32
extern var _sdata: u32
extern var _edata: u32
extern var _sbss: u32
extern var _ebss: u32

@section(".vector_table")
@align(512)
val vector_table: [u32] = [
    0x20400000,
    0x00000001,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
    0x00000000,
]

@naked
@noreturn
fn reset_handler():
    unsafe:
        asm volatile:
            "ldr r0, =0x20400000"
            "mov sp, r0"

            "ldr r0, =0xE000ED88"
            "ldr r1, [r0]"
            "orr r1, r1, #(0xF << 20)"
            "str r1, [r0]"
            "dsb"
            "isb"

            "bl {boot_main}"

            ".Lhalt_loop:"
            "b .Lhalt_loop"

            in(reg) boot_main as u32

fn boot_main():
    uart_init()
    uart_writeln("[BOOT] SimpleOS Lite — Cortex-M33 (ARMv8-M)")
    uart_writeln("[BOOT] Platform: MPS2-AN505 (QEMU)")
    uart_writeln("[BOOT] UART0 initialized at 0x40004000")
    uart_writeln("[BOOT] Entering shell...")
    uart_writeln("")
    shell_main()
