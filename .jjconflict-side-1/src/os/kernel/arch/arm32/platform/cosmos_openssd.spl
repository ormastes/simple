# CRZ Cosmos+ OpenSSD platform descriptor — Xilinx Zynq-7000 (XC7Z045), dual Cortex-A9.
#
# This is the firmware-facing platform binding for the real NVMe-fw dev environment
# (config 3). The bootable Cortex-A9 bring-up (Cadence UART, qemu xilinx-zynq-a9 verified)
# lives in ../cosmos/. This module documents the Zynq-7000 memory map and ENUMERATES the
# parts still missing for a silicon port, so `cosmos_selftest` requires an honest
# non-empty gap list rather than pretending the port is complete.
#
# Run: bin/simple run src/os/kernel/arch/arm32/platform/cosmos_openssd.spl

# ── Zynq-7000 / Cosmos+ memory map ─────────────────────────────────────────────
val COSMOS_DDR_BASE: u64    = 0x00100000   # PS DDR3 (kernel load; low OCM/vectors below)
val COSMOS_DDR_SIZE: u64    = 0x40000000   # 1 GiB DDR3 on the Cosmos+ board
val COSMOS_OCM_HIGH: u64    = 0xFFFC0000   # 256 KiB on-chip RAM (high mapping)
val COSMOS_UART0_BASE: u64  = 0xE0000000   # Cadence UART0
val COSMOS_UART1_BASE: u64  = 0xE0001000   # Cadence UART1 (qemu zynq default serial)
val COSMOS_GIC_DIST: u64    = 0xF8F01000   # Cortex-A9 MPCore GIC distributor
val COSMOS_GIC_CPU: u64     = 0xF8F00100   # GIC CPU interface
val COSMOS_SLCR_BASE: u64   = 0xF8000000   # System-level control (clocks, DDR, reset)
val COSMOS_NFC_PL_BASE: u64 = 0x43C00000   # NAND flash controller IP in the PL (AXI GP0)
val COSMOS_PCIE_PL_BASE: u64 = 0x50000000  # PCIe endpoint IP in the PL (NVMe host transport)

struct CosmosPlatform:
    name: text
    soc: text
    cores: i64
    uart_base: u64
    ddr_base: u64
    nfc_base: u64

fn cosmos_openssd_platform() -> CosmosPlatform:
    CosmosPlatform {
        name: "CRZ Cosmos+ OpenSSD",
        soc: "Xilinx Zynq-7000 XC7Z045",
        cores: 2,
        uart_base: COSMOS_UART1_BASE,
        ddr_base: COSMOS_DDR_BASE,
        nfc_base: COSMOS_NFC_PL_BASE
    }

# Firmware seams already present in examples/09_embedded/simpleos_nvme_fw/ that a real
# Cosmos+ port reuses unchanged (they are MMIO-register / host-queue models, not toys).
fn cosmos_present_parts() -> [text]:
    [
        "fil_fmc: flash-memory-controller register model (cf Cosmos+ fmc_driver.c)",
        "fil_scheduler: 8ch x 8way dispatch (cf low_level_scheduler.c)",
        "hil/hil_queue/hil_command: NVMe host-interface queues + command decode",
        "ftl/ftl_map/ftl_gc/ftl_journal: log-structured FTL + GC + P2L recovery",
        "rain: XOR parity reconstruct (Lean-proven)",
        "nvme_controller/nvme_admin: NVMe controller + admin command set"
    ]

# Parts still MISSING for a silicon (not-qemu) NVMe-fw port — discovered by attempting
# the bring-up. Each is a concrete next task, not a vague gap.
fn cosmos_missing_parts() -> [text]:
    [
        "Zynq NAND Flash Controller (PL IP @0x43C00000) MMIO binding — wire fil_fmc's abstract FMC registers to the real PL NFC",
        "PCIe endpoint init (PL IP @0x50000000) — the NVMe-over-PCIe host transport (Zynq-7000 has no hard PCIe)",
        "DDR controller + OCM init — on hardware the FSBL does this; a bare-metal port must init the DDR3 controller via SLCR",
        "Cortex-A9 SMP + GIC bring-up — release/park CPU1, GIC distributor/CPU interface",
        "MMU + L1/L2 (PL310) cache setup for the A9",
        "FSBL / BootROM handoff — package as boot.bin (FSBL + bitstream + this ELF) for real silicon",
        "ARMv7 freestanding Simple runtime — the rt_* runtime for armv7 baremetal (rv32/rv64 have freestanding_runtime.c; arm needs the equivalent)"
    ]

fn cosmos_selftest() -> i64:
    var fail = 0
    val p = cosmos_openssd_platform()

    # Real Zynq-7000 architectural invariants. Each check cross-references constants that
    # are defined INDEPENDENTLY in the memory map above, so a typo'd address genuinely
    # fails the test — unlike asserting that a value equals its own literal.

    # The two Cadence UART instances on the Zynq PS are spaced exactly 0x1000 apart.
    if COSMOS_UART1_BASE != COSMOS_UART0_BASE + 0x1000:
        fail = fail + 1
    # Cortex-A9 MPCore private region (PERIPHBASE = 0xF8F00000): the GIC CPU interface
    # sits at +0x100 and the distributor at +0x1000.
    val periphbase: u64 = 0xF8F00000
    if COSMOS_GIC_CPU != periphbase + 0x100:
        fail = fail + 1
    if COSMOS_GIC_DIST != periphbase + 0x1000:
        fail = fail + 1
    # The DDR load region must lie strictly below the PS peripheral aperture
    # (UART0 @ 0xE0000000): the kernel image cannot overlap the MMIO registers.
    if COSMOS_DDR_BASE + COSMOS_DDR_SIZE > COSMOS_UART0_BASE:
        fail = fail + 1
    # The PL NAND-flash-controller aperture sits in the AXI GP0 PL window, above DDR —
    # not inside the DDR image region.
    if COSMOS_NFC_PL_BASE < COSMOS_DDR_BASE + COSMOS_DDR_SIZE:
        fail = fail + 1
    # The descriptor must bind the firmware-facing UART1 + PL NFC, not leave them zero.
    if p.uart_base != COSMOS_UART1_BASE or p.nfc_base != COSMOS_NFC_PL_BASE:
        fail = fail + 1
    # Port-in-progress invariant: real present seams AND the exact audited gap list, so
    # no one quietly adds/removes a silicon blocker without updating the evidence.
    if cosmos_present_parts().len() != 6 or cosmos_missing_parts().len() != 7:
        fail = fail + 1
    fail

fn main() -> i64:
    val fail = cosmos_selftest()
    if fail == 0:
        print "COSMOS+ OpenSSD platform descriptor OK"
        print "  present firmware seams: {cosmos_present_parts().len()}"
        print "  missing for silicon:    {cosmos_missing_parts().len()}"
        for gap in cosmos_missing_parts():
            print "    - {gap}"
    else:
        print "COSMOS+ platform selftest FAILED: {fail}"
    fail
