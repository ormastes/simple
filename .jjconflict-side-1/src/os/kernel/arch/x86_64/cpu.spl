# x86_64 CPU Primitives — Low-Level CPU Operations
#
# Wraps C runtime functions for privileged x86_64 CPU operations:
# port I/O, control registers, MSRs, interrupt control, descriptor
# table loading.
#
# These are all x86_64-specific instructions that have no equivalent
# on other architectures (e.g., RISC-V uses CSRs instead of MSRs,
# MMIO instead of port I/O).

# ============================================================================
# Port I/O
# ============================================================================

extern fn rt_port_inb(port: u16) -> u8
extern fn rt_port_outb(port: u16, value: u8)
extern fn rt_port_inw(port: u16) -> u16
extern fn rt_port_outw(port: u16, value: u16)
extern fn rt_port_inl(port: u16) -> u32
extern fn rt_port_outl(port: u16, value: u32)
extern fn rt_port_io_wait()

fn port_inb(port: u16) -> u8:
    """Read byte from I/O port."""
    rt_port_inb(port)

fn port_outb(port: u16, value: u8):
    """Write byte to I/O port."""
    rt_port_outb(port, value)

fn port_outb_wait(port: u16, value: u8):
    """Write byte to I/O port with I/O wait."""
    rt_port_outb(port, value)
    rt_port_io_wait()

fn port_inw(port: u16) -> u16:
    """Read word from I/O port."""
    rt_port_inw(port)

fn port_outw(port: u16, value: u16):
    """Write word to I/O port."""
    rt_port_outw(port, value)

fn port_inl(port: u16) -> u32:
    """Read dword from I/O port."""
    rt_port_inl(port)

fn port_outl(port: u16, value: u32):
    """Write dword to I/O port."""
    rt_port_outl(port, value)

# ============================================================================
# Control Registers
# ============================================================================

extern fn rt_read_cr3() -> u64
extern fn rt_write_cr3(value: u64)
extern fn rt_read_cr2() -> u64
extern fn rt_invlpg(addr: u64)

fn read_cr3() -> u64:
    """Read CR3 (page table base address)."""
    rt_read_cr3()

fn write_cr3(value: u64):
    """Write CR3 (switch page tables, flush TLB)."""
    rt_write_cr3(value)

fn read_cr2() -> u64:
    """Read CR2 (faulting address after page fault)."""
    rt_read_cr2()

fn invlpg(addr: u64):
    """Invalidate TLB entry for given virtual address."""
    rt_invlpg(addr)

# ============================================================================
# Model Specific Registers
# ============================================================================

extern fn rt_read_msr(msr: u32) -> u64
extern fn rt_write_msr(msr: u32, value: u64)

fn read_msr(msr: u32) -> u64:
    """Read Model Specific Register."""
    rt_read_msr(msr)

fn write_msr(msr: u32, value: u64):
    """Write Model Specific Register."""
    rt_write_msr(msr, value)

# Common MSR addresses
val MSR_APIC_BASE: u32 = 0x1B
val MSR_EFER: u32 = 0xC0000080
val MSR_STAR: u32 = 0xC0000081        # Syscall segment bases
val MSR_LSTAR: u32 = 0xC0000082       # Syscall entry point (64-bit)
val MSR_SFMASK: u32 = 0xC0000084      # Syscall RFLAGS mask
val MSR_FS_BASE: u32 = 0xC0000100
val MSR_GS_BASE: u32 = 0xC0000101
val MSR_KERNEL_GS_BASE: u32 = 0xC0000102

# EFER bit 0 — System Call Extensions. Required to enable SYSCALL/SYSRET.
val EFER_SCE: u64 = 0x1
# RFLAGS mask: clear IF (bit 9) on SYSCALL entry so kernel runs with
# interrupts disabled until it is ready to re-enable them.
val SYSCALL_FMASK_IF: u64 = 0x200

# ============================================================================
# SYSCALL / SYSRET MSR install
# ============================================================================
#
# Path B (posix_spawn → SYSCALL) requires LSTAR to point at a real kernel
# entry trampoline. Wave 7B (this change) provides that trampoline in
# `examples/simple_os/arch/x86_64/boot/syscall_entry.s` and a C-side
# dispatcher `rt_syscall_dispatch` in baremetal_stubs.c. The asm symbol
# `kernel_syscall_entry_asm` is the address that will eventually go
# into MSR_LSTAR, fetched via the C helper `get_kernel_syscall_entry_addr`.
#
# However, the full install is still GATED on two pre-requisites that
# live outside this file:
#
#   1. The boot GDT (examples/simple_os/arch/x86_64/boot/crt0.s) has
#      only 3 entries today: null, 64-bit kernel code, 64-bit kernel data.
#      MSR_STAR requires a specific 5-entry layout (kernel CS, kernel SS,
#      32-bit compat user code, user data, 64-bit user code). Writing
#      STAR with the current GDT would point user CS/SS at invalid
#      descriptors and triple-fault on the first SYSRET.
#
#   2. There is no C-ABI shim for the Simple-side `_handle_spawn_binary`
#      / `syscall_handler` — those take composite class args
#      (SyscallArgs, Scheduler, IpcManager, KernelLog) which are not
#      plain-C callable. The dispatcher in baremetal_stubs.c forwards
#      to `spl_handle_*` weak symbols that do not yet exist, so every
#      syscall today would return -ENOSYS even if the MSRs were set.
#
# Until those two blockers lift, this installer remains a logged no-op.
# The difference from the pre-7B state is that the trampoline is now
# linked into the kernel image — flipping to the real install only
# requires replacing the no-op body with the four wrmsr calls shown
# in the comment block below, without any further native-side changes
# to this file.
#
# Planned flip (commented out until the blockers above are resolved):
#
#     fn install_syscall_entry():
#         if _syscall_entry_installed:
#             return
#         _syscall_entry_installed = true
#         # 1. Enable SCE in EFER.
#         val efer = read_msr(MSR_EFER)
#         write_msr(MSR_EFER, efer | EFER_SCE)
#         # 2. STAR: kernel CS/SS in [47:32], user CS/SS in [63:48].
#         val star: u64 = (GDT_KERNEL_CS as u64) << 32 | (GDT_USER_CS_STAR as u64) << 48
#         write_msr(MSR_STAR, star)
#         # 3. LSTAR: address of the asm trampoline.
#         write_msr(MSR_LSTAR, get_kernel_syscall_entry_addr())
#         # 4. FMASK: clear IF on syscall entry.
#         write_msr(MSR_SFMASK, SYSCALL_FMASK_IF)
#         serial_println("[arch-init] SYSCALL entry installed (LSTAR real)")

extern fn serial_println(msg: text)

# Trampoline address helper, implemented in
# examples/simple_os/arch/x86_64/boot/syscall_entry.s. Returns the
# runtime address of `kernel_syscall_entry_asm`, which is what MSR_LSTAR
# must be set to once the SYSCALL install is actually enabled.
extern fn get_kernel_syscall_entry_addr() -> u64

var _syscall_entry_installed: bool = false

fn install_syscall_entry():
    """Program MSR_EFER.SCE, MSR_STAR, MSR_LSTAR, MSR_SFMASK to enable SYSCALL.

    Must be called on each CPU exactly once before any user code can issue
    SYSCALL. Called from arch_x86_64_early_init in os_main.spl and
    desktop_e2e_entry.spl.

    Prerequisites (all now in place on disk):
      1. Boot GDT has 5 entries (crt0.s, Wave 10A).
      2. Weak spl_handle_* C-ABI stubs exist in baremetal_stubs.c (Wave 10B)
         so dispatcher returns -ENOSYS instead of linking-breaking.
      3. src/os/kernel/abi/syscall_shim.spl provides @export("C",...) strong
         overrides for 10+ common syscalls.
    """
    if _syscall_entry_installed:
        return
    _syscall_entry_installed = true
    # 1. Enable SYSCALL/SYSRET via EFER.SCE (bit 0).
    val efer = read_msr(MSR_EFER)
    write_msr(MSR_EFER, efer | EFER_SCE)
    # 2. Program MSR_STAR for SYSCALL/SYSRET segment selectors.
    # Kernel CS = 0x08 (bits 32-47); user CS 32-bit compat = 0x18 (bits 48-63).
    # SYSCALL loads CS=0x08, SS=0x10; SYSRET64 loads CS=0x28 (user_cs+16), SS=0x20 (user_cs+8).
    val user_cs_rpl3: u64 = 0x18 | 3
    val star: u64 = (user_cs_rpl3 << 48) | (0x08 as u64 << 32)
    write_msr(MSR_STAR, star)
    # 3. LSTAR = 64-bit SYSCALL entry point.
    val entry = get_kernel_syscall_entry_addr()
    write_msr(MSR_LSTAR, entry)
    # 4. SFMASK: clear IF (RFLAGS bit 9) on SYSCALL so kernel runs with
    # interrupts disabled until it explicitly re-enables them.
    write_msr(MSR_SFMASK, SYSCALL_FMASK_IF)
    serial_println("[syscall] MSRs programmed: LSTAR STAR SFMASK=0x200")

fn syscall_entry_installed() -> bool:
    """Test-visible accessor: did `install_syscall_entry` run?"""
    _syscall_entry_installed

fn kernel_syscall_entry_addr() -> u64:
    """Return the address of the SYSCALL kernel-entry trampoline.

    This is the value that MSR_LSTAR will eventually be programmed
    with. Test-visible so the regression spec can assert the
    trampoline is linked into the kernel image.
    """
    get_kernel_syscall_entry_addr()

# ============================================================================
# Interrupt Control
# ============================================================================

extern fn rt_cli()
extern fn rt_sti()
extern fn rt_hlt()

fn cli():
    """Disable interrupts."""
    rt_cli()

fn sti():
    """Enable interrupts."""
    rt_sti()

fn hlt():
    """Halt until next interrupt."""
    rt_hlt()

fn halt_loop():
    """Halt forever (used for unrecoverable errors)."""
    cli()
    while true:
        hlt()

# ============================================================================
# Descriptor Table Loading
# ============================================================================

extern fn rt_lgdt(gdtr_addr: u64)
extern fn rt_lidt(idtr_addr: u64)
extern fn rt_ltr(selector: u16)

fn lgdt(gdtr_addr: u64):
    """Load Global Descriptor Table Register."""
    rt_lgdt(gdtr_addr)

fn lidt(idtr_addr: u64):
    """Load Interrupt Descriptor Table Register."""
    rt_lidt(idtr_addr)

fn ltr(selector: u16):
    """Load Task Register (TSS selector)."""
    rt_ltr(selector)

# ============================================================================
# X86Cpu — HAL-Compatible CPU Interface
# ============================================================================

struct X86Cpu:
    """x86_64 CPU primitives.

    Provides architecture-specific CPU operations: port I/O,
    control registers, MSRs, interrupt control, descriptor table
    loading, TLB management.
    """
    pass_dn

impl X86Cpu:
    fn cpu_id() -> u64:
        """Return current CPU ID. Single CPU for now."""
        0

    fn cpu_address_width() -> u64:
        """Return virtual address width in bits."""
        64

    fn cpu_enable_interrupts():
        """Enable interrupts (STI)."""
        sti()

    fn cpu_disable_interrupts():
        """Disable interrupts (CLI)."""
        cli()

    fn cpu_halt():
        """Halt until next interrupt (HLT)."""
        hlt()

    fn cpu_halt_loop():
        """Disable interrupts and halt forever."""
        halt_loop()

    fn cpu_flush_tlb(addr: u64):
        """Invalidate TLB entry for a single virtual address."""
        invlpg(addr)

    fn cpu_flush_tlb_all():
        """Flush entire TLB by rewriting CR3."""
        val cr3 = read_cr3()
        write_cr3(cr3)

    fn cpu_read_page_table_base() -> u64:
        """Read current page table base (CR3)."""
        read_cr3()

    fn cpu_write_page_table_base(addr: u64):
        """Write page table base (CR3), switching address space."""
        write_cr3(addr)
