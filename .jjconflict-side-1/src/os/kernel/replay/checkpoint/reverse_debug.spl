# SimpleOS — Container Reverse Debugger (Track 5.9)
#
# Provides reverse-step and reverse-continue across process boundaries
# by combining container checkpoints with the kernel event log.

use os.kernel.replay.checkpoint.checkpoint_types.{ContainerCheckpoint}
use os.kernel.replay.log_buffer.{replay_event_count}

# ============================================================================
# ContainerReverseDebugger
# ============================================================================

class ContainerReverseDebugger:
    checkpoint_dir: text      # directory holding serialized checkpoints
    event_log_path: text      # path to the kernel event log file
    current_cycle: i64        # current replay position

impl ContainerReverseDebugger:
    static fn open(checkpoint_dir: text, event_log: text) -> ContainerReverseDebugger:
        ContainerReverseDebugger(
            checkpoint_dir: checkpoint_dir,
            event_log_path: event_log,
            current_cycle: 0
        )

    # Find the nearest checkpoint at or before target_cycle, restore it, then
    # replay events forward until target_cycle is reached.
    me fn seek_to_cycle(target_cycle: i64) -> Result<text, text>:
        if target_cycle < 0:
            return Err("seek_to_cycle: target_cycle must be >= 0")
        # In a real implementation this would:
        #   1. Scan checkpoint_dir for the latest checkpoint <= target_cycle
        #   2. Deserialize and restore the container state
        #   3. Replay events from checkpoint.replay_event_id up to target_cycle
        self.current_cycle = target_cycle
        Ok("seeked to cycle {target_cycle}")

    # Step back one event: find the last event before current_cycle and
    # seek to its cycle, returning the new position.
    me fn reverse_step() -> Result<i64, text>:
        if self.current_cycle <= 0:
            return Err("reverse_step: already at start of event log")
        val prev_cycle = self.current_cycle - 1
        match self.seek_to_cycle(prev_cycle):
            case Ok(_):
                Ok(self.current_cycle)
            case Err(msg):
                Err(msg)

    # Reverse-continue: step back events until target_cycle is reached.
    me fn reverse_continue_to(target_cycle: i64) -> Result<i64, text>:
        if target_cycle >= self.current_cycle:
            return Err("reverse_continue_to: target {target_cycle} is not before current {self.current_cycle}")
        match self.seek_to_cycle(target_cycle):
            case Ok(_):
                Ok(self.current_cycle)
            case Err(msg):
                Err(msg)

    fn current_position() -> i64:
        self.current_cycle
