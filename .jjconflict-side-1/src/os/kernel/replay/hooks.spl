# SimpleOS Kernel Replay — Hook Functions
#
# Called from kernel subsystems (scheduler, syscall, IPC, interrupts, timer).
# Each hook checks replay_is_off() first — single load + branch, zero cost
# when replay is disabled.

use os.kernel.replay.mode.{replay_is_off, replay_is_recording, replay_mode, KernelReplayMode}
use os.kernel.replay.event_kinds.{ReplayEntry, EventKind}
use os.kernel.replay.log_buffer.{replay_log_event, replay_read_next}
use os.kernel.replay.divergence.{DivergenceKind, report_divergence}

# ============================================================================
# Schedule Hook
# ============================================================================

fn replay_hook_schedule(old_tid: i64, new_tid: i64, tick: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.Schedule, old_tid, 0, 0)
        entry.payload_a = old_tid
        entry.payload_b = new_tid
        entry.payload_c = tick
        replay_log_event(entry)
        return

    # Replay/Verify: consume the schedule event from the log
    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    # Caller should use entry.payload_b as the forced next-tid
                    pass_dn
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    # Verify recorded schedule matches live decision
                    if entry.payload_b != new_tid:
                        report_divergence(DivergenceKind.ScheduleMismatch, entry.event_id, entry.payload_b, new_tid)
                case None:
                    pass_dn
        case _:
            pass_dn

# ============================================================================
# Syscall Hooks
# ============================================================================

fn replay_hook_syscall_enter(task_id: i64, syscall_id: i64, arg0: i64, arg1: i64, arg2: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.SyscallEnter, task_id, 0, 0)
        entry.payload_a = syscall_id
        entry.payload_b = arg0
        entry.payload_c = arg1
        entry.payload_d = arg2
        replay_log_event(entry)
        return

    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    pass_dn  # consumed — replayer drives syscall from log
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    if entry.payload_a != syscall_id:
                        report_divergence(DivergenceKind.SyscallMismatch, entry.event_id, entry.payload_a, syscall_id)
                case None:
                    pass_dn
        case _:
            pass_dn

fn replay_hook_syscall_exit(task_id: i64, syscall_id: i64, retval: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.SyscallExit, task_id, 0, 0)
        entry.payload_a = syscall_id
        entry.payload_b = retval
        replay_log_event(entry)
        return

    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    pass_dn  # caller uses entry.payload_b as forced retval
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    if entry.payload_b != retval:
                        report_divergence(DivergenceKind.SyscallMismatch, entry.event_id, entry.payload_b, retval)
                case None:
                    pass_dn
        case _:
            pass_dn

# ============================================================================
# Interrupt Hook
# ============================================================================

fn replay_hook_irq(vector: i64, task_id: i64, timestamp: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.InterruptDeliver, task_id, 0, 0)
        entry.payload_a = vector
        entry.payload_b = timestamp
        replay_log_event(entry)
        return

    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    pass_dn  # replayer injects IRQ at logged point
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    if entry.payload_a != vector:
                        report_divergence(DivergenceKind.IrqMismatch, entry.event_id, entry.payload_a, vector)
                case None:
                    pass_dn
        case _:
            pass_dn

# ============================================================================
# IPC Hooks
# ============================================================================

fn replay_hook_ipc_send(src_task: i64, dst_port: i64, msg_len: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.IpcSend, src_task, 0, 0)
        entry.payload_a = src_task
        entry.payload_b = dst_port
        entry.payload_c = msg_len
        replay_log_event(entry)
        return

    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    pass_dn  # consumed from log
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    if entry.payload_b != dst_port:
                        report_divergence(DivergenceKind.IpcMismatch, entry.event_id, entry.payload_b, dst_port)
                case None:
                    pass_dn
        case _:
            pass_dn

fn replay_hook_ipc_recv(dst_task: i64, src_port: i64, msg_len: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.IpcReceive, dst_task, 0, 0)
        entry.payload_a = dst_task
        entry.payload_b = src_port
        entry.payload_c = msg_len
        replay_log_event(entry)
        return

    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    pass_dn  # consumed from log
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    if entry.payload_b != src_port:
                        report_divergence(DivergenceKind.IpcMismatch, entry.event_id, entry.payload_b, src_port)
                case None:
                    pass_dn
        case _:
            pass_dn

# ============================================================================
# Timer Hook
# ============================================================================

fn replay_hook_timer_read(source_id: i64, value: i64) -> i64:
    if replay_is_off():
        return value

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.TimerRead, 0, 0, 0)
        entry.payload_a = source_id
        entry.payload_b = value
        replay_log_event(entry)
        return value

    match replay_mode():
        case KernelReplayMode.Replay:
            # Return logged value instead of hardware read
            match replay_read_next():
                case Some(entry):
                    if entry.kind == EventKind.TimerRead.to_i32():
                        return entry.payload_b
                    return value
                case None:
                    return value
        case KernelReplayMode.Verify:
            # Compare live value against logged, return live
            match replay_read_next():
                case Some(entry):
                    if entry.payload_b != value:
                        report_divergence(DivergenceKind.TimerMismatch, entry.event_id, entry.payload_b, value)
                    return value
                case None:
                    return value
        case _:
            return value
    value

# ============================================================================
# Thread Lifecycle Hooks
# ============================================================================

fn replay_hook_thread_create(parent_tid: i64, child_tid: i64, entry_addr: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.ThreadCreate, parent_tid, 0, 0)
        entry.payload_a = parent_tid
        entry.payload_b = child_tid
        entry.payload_c = entry_addr
        replay_log_event(entry)
        return

    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    pass_dn  # replayer forces child_tid from log
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    if entry.payload_b != child_tid:
                        report_divergence(DivergenceKind.ThreadMismatch, entry.event_id, entry.payload_b, child_tid)
                case None:
                    pass_dn
        case _:
            pass_dn

fn replay_hook_thread_exit(task_id: i64, exit_code: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.ThreadExit, task_id, 0, 0)
        entry.payload_a = exit_code
        replay_log_event(entry)
        return

    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    pass_dn  # consumed
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    if entry.payload_a != exit_code:
                        report_divergence(DivergenceKind.ThreadMismatch, entry.event_id, entry.payload_a, exit_code)
                case None:
                    pass_dn
        case _:
            pass_dn

# ============================================================================
# Random/Entropy Hook
# ============================================================================

fn replay_hook_random_read(task_id: i64, value: i64) -> i64:
    if replay_is_off():
        return value

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.RandomSeed, task_id, 0, 0)
        entry.payload_a = value
        replay_log_event(entry)
        return value

    match replay_mode():
        case KernelReplayMode.Replay:
            # Return logged entropy instead of hardware RNG
            match replay_read_next():
                case Some(entry):
                    if entry.kind == EventKind.RandomSeed.to_i32():
                        return entry.payload_a
                    return value
                case None:
                    return value
        case KernelReplayMode.Verify:
            # Compare live entropy against logged, return live
            match replay_read_next():
                case Some(entry):
                    if entry.payload_a != value:
                        report_divergence(DivergenceKind.RandomMismatch, entry.event_id, entry.payload_a, value)
                    return value
                case None:
                    return value
        case _:
            return value
    value

# ============================================================================
# Checkpoint Marker
# ============================================================================

fn replay_hook_checkpoint(checkpoint_id: i64):
    if replay_is_off():
        return

    if replay_is_recording():
        var entry = ReplayEntry.create(EventKind.Checkpoint, 0, 0, 0)
        entry.payload_a = checkpoint_id
        replay_log_event(entry)
        return

    match replay_mode():
        case KernelReplayMode.Replay:
            match replay_read_next():
                case Some(entry):
                    pass_dn  # checkpoint marker consumed
                case None:
                    pass_dn
        case KernelReplayMode.Verify:
            match replay_read_next():
                case Some(entry):
                    if entry.payload_a != checkpoint_id:
                        report_divergence(DivergenceKind.CheckpointMismatch, entry.event_id, entry.payload_a, checkpoint_id)
                case None:
                    pass_dn
        case _:
            pass_dn
