# Freestanding pure-Simple NVMe boot adapter contract.
#
# This module is intentionally data-only. It defines when a freestanding
# pure-Simple NVMe BlockDevice adapter is allowed to enter the shared boot
# filesystem probe path. It must not import the C bridge or hosted VFS.

use os.drivers.nvme.nvme_storage_model.{NvmeTransferEvidence, nvme_transfer_readiness_reason}

struct FreestandingNvmeAdapterContract:
    provider: text
    pure_simple: bool
    block_probe_entry: text
    transfer_ready: bool
    reason: text

fn freestanding_nvme_adapter_contract(e: NvmeTransferEvidence) -> FreestandingNvmeAdapterContract:
    val reason = nvme_transfer_readiness_reason(e)
    FreestandingNvmeAdapterContract(
        provider: e.provider,
        pure_simple: e.provider == "simple-driver",
        block_probe_entry: "boot_fs_mount_from_device",
        transfer_ready: reason == "ready",
        reason: reason
    )

fn freestanding_nvme_adapter_ready(e: NvmeTransferEvidence) -> bool:
    freestanding_nvme_adapter_contract(e).reason == "ready"

fn freestanding_nvme_adapter_refusal_reason(e: NvmeTransferEvidence) -> text:
    freestanding_nvme_adapter_contract(e).reason

fn freestanding_nvme_adapter_provider() -> text:
    "simple-driver"

fn freestanding_nvme_adapter_block_probe_entry() -> text:
    "boot_fs_mount_from_device"
