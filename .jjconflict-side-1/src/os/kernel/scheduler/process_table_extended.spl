# Process Table Extended — Kernel Process Registry with AddressSpace Lifecycle
#
# Extends the minimal stdlib process_table (PID + ASID integer pairs) with
# owned AddressSpace handles so the kernel can track, switch, and reclaim
# address spaces as processes spawn and exit.
#
# Each entry stores:
#   pid       — unique positive i64 allocated by this table
#   space     — AddressSpace handle (phys_root + id)
#   state     — "running" | "blocked" | "zombie"
#   alive     — tombstone flag (false = reaped)
#
# Parallel module-level arrays mirror the stdlib pattern (no dynamic struct
# arrays in interpreter mode). Maximum MAX_PROCS entries; PIDs are monotonic.
#
# MDSOC-only — no ECS, no userland patterns.

use os.kernel.types.task_types.{AddressSpace}
use os.kernel.scheduler.address_space_switch.{as_create, as_destroy, as_kernel_sentinel}

# ============================================================================
# Configuration
# ============================================================================

val MAX_PROCS: i64 = 256

# ============================================================================
# Module-Level Storage (parallel arrays, tombstone-based removal)
# ============================================================================

var _pt_ext_pid_list:   [i64]   = []
var _pt_ext_phys_list:  [u64]   = []
var _pt_ext_asid_list:  [u64]   = []
var _pt_ext_state_list: [text]  = []
var _pt_ext_alive_list: [bool]  = []
var _pt_ext_pid_counter: i64    = 0

# ============================================================================
# ProcessEntryExt — per-entry view returned to callers
# ============================================================================

struct ProcessEntryExt:
    """Snapshot of a single process table entry."""
    pid:   i64
    space: AddressSpace
    state: text

struct ProcessEntryExtOption:
    """Optional ProcessEntryExt — present flag + value."""
    is_some: bool
    entry:   ProcessEntryExt

fn _pt_ext_some(e: ProcessEntryExt) -> ProcessEntryExtOption:
    ProcessEntryExtOption(is_some: true, entry: e)

fn _pt_ext_none() -> ProcessEntryExtOption:
    val sentinel = AddressSpace(phys_root: 0, id: 0)
    val empty = ProcessEntryExt(pid: -1, space: sentinel, state: "")
    ProcessEntryExtOption(is_some: false, entry: empty)

# ============================================================================
# PID Allocation
# ============================================================================

fn pt_ext_alloc_pid() -> i64:
    """Allocate a new unique PID (always > 0, monotonically increasing)."""
    _pt_ext_pid_counter = _pt_ext_pid_counter + 1
    _pt_ext_pid_counter

# ============================================================================
# Register / Lookup / Reap
# ============================================================================

fn pt_ext_register(pid: i64, space: AddressSpace):
    """Register a new process with an owned address space.

    Args:
        pid:   PID from pt_ext_alloc_pid()
        space: AddressSpace handle (ownership transfers to table)
    """
    _pt_ext_pid_list.push(pid)
    _pt_ext_phys_list.push(space.phys_root)
    _pt_ext_asid_list.push(space.id)
    _pt_ext_state_list.push("running")
    _pt_ext_alive_list.push(true)

fn pt_ext_lookup(pid: i64) -> ProcessEntryExtOption:
    """Look up a live process entry by PID.

    Returns:
        ProcessEntryExtOption.is_some = true if found and alive.
    """
    val n = _pt_ext_pid_list.len()
    var i: i64 = 0
    while i < n:
        if _pt_ext_alive_list[i] and _pt_ext_pid_list[i] == pid:
            val space = AddressSpace(
                phys_root: _pt_ext_phys_list[i],
                id:        _pt_ext_asid_list[i]
            )
            val e = ProcessEntryExt(
                pid:   pid,
                space: space,
                state: _pt_ext_state_list[i]
            )
            return _pt_ext_some(e)
        i = i + 1
    _pt_ext_none()

fn pt_ext_set_state(pid: i64, new_state: text):
    """Update the state field of a live process entry.

    Args:
        pid:       PID to update
        new_state: "running" | "blocked" | "zombie"
    """
    val n = _pt_ext_pid_list.len()
    var i: i64 = 0
    while i < n:
        if _pt_ext_alive_list[i] and _pt_ext_pid_list[i] == pid:
            _pt_ext_state_list[i] = new_state
            return
        i = i + 1

fn pt_ext_reap(pid: i64):
    """Reap a process: tombstone the entry and destroy its address space.

    The AddressSpace handle is reconstructed from the stored fields and
    passed to as_destroy() which releases the PML4/SATP tree pages.

    Args:
        pid: PID to reap
    """
    val n = _pt_ext_pid_list.len()
    var i: i64 = 0
    while i < n:
        if _pt_ext_alive_list[i] and _pt_ext_pid_list[i] == pid:
            val space = AddressSpace(
                phys_root: _pt_ext_phys_list[i],
                id:        _pt_ext_asid_list[i]
            )
            as_destroy(space)
            _pt_ext_alive_list[i] = false
            return
        i = i + 1

fn pt_ext_count() -> i64:
    """Return number of live (non-reaped) entries."""
    val n = _pt_ext_pid_list.len()
    var count: i64 = 0
    var i: i64 = 0
    while i < n:
        if _pt_ext_alive_list[i]:
            count = count + 1
        i = i + 1
    count

fn pt_ext_list_pids() -> [i64]:
    """Return a list of all live PIDs (snapshot, not a live reference)."""
    val n = _pt_ext_pid_list.len()
    var result: [i64] = []
    var i: i64 = 0
    while i < n:
        if _pt_ext_alive_list[i]:
            result.push(_pt_ext_pid_list[i])
        i = i + 1
    result

# ============================================================================
# Convenience: spawn a new process with a fresh address space
# ============================================================================

fn pt_ext_spawn() -> i64:
    """Allocate a PID, create a fresh address space, register the entry.

    Returns the new PID. The caller is responsible for loading segments
    into the address space via the VMM before scheduling the process.
    """
    val pid = pt_ext_alloc_pid()
    val space = as_create()
    pt_ext_register(pid, space)
    pid

fn pt_ext_spawn_with_kernel_as() -> i64:
    """Allocate a PID registered with the kernel sentinel address space.

    Used for kernel threads that share the kernel address space and do not
    need a private user address space.
    """
    val pid = pt_ext_alloc_pid()
    val space = as_kernel_sentinel()
    pt_ext_register(pid, space)
    pid

fn pt_ext_address_space_for(pid: i64) -> AddressSpace:
    """Return the AddressSpace for a live PID, or the kernel sentinel if not found."""
    val opt = pt_ext_lookup(pid)
    if opt.is_some:
        return opt.entry.space
    as_kernel_sentinel()
