#![allow(unnamed_duplicate_typed_args)]
# Install-media installer — deploy staged SimpleOS filesystem trees
# MDSOC: feature dimension, apps layer

use os.tools.pkg.pkg_format.{ExtendedManifest, PkgArch, parse_extended_manifest, pkg_arch_to_text, pkg_arch_from_text}
use os.tools.pkg.pkg_manifest.{serialize_manifest}
use os.userlib.fs.{read_text, write_text, readdir, mkdir}

val INSTALLER_ROOT = "/usr/libexec/simpleos-installer"
val INSTALLER_PKG_DIR = "/usr/libexec/simpleos-installer/packages"
val INSTALLER_KERNEL_DIR = "/usr/libexec/simpleos-installer/kernel"
val INSTALLER_DEPLOY_MANIFEST = "/usr/libexec/simpleos-installer/deployed-files.sdn"
val TARGET_MOUNT = "/mnt/target"
val TARGET_EFI_MOUNT = "/mnt/target/boot/efi"

val _TARGET_LAYOUT = [
    "/boot",
    "/boot/efi",
    "/bin",
    "/sbin",
    "/etc",
    "/etc/shell",
    "/etc/pkg",
    "/etc/registry",
    "/lib",
    "/usr",
    "/usr/bin",
    "/usr/sbin",
    "/usr/lib",
    "/usr/libexec",
    "/usr/local",
    "/usr/local/bin",
    "/usr/local/lib",
    "/usr/local/share",
    "/usr/local/share/themes",
    "/var",
    "/var/cache",
    "/var/cache/pkg",
    "/var/db",
    "/var/db/pkg",
    "/var/db/pkg/installed",
    "/var/log",
    "/tmp",
    "/home"
]

struct DetectedDisk:
    path: text
    name: text
    size_mb: u64
    disk_type: text

struct PartitionPlan:
    disk: DetectedDisk
    efi_size_mb: u64
    root_size_mb: u64
    swap_size_mb: u64

fn detect_disks() -> [DetectedDisk]:
    [
        DetectedDisk(path: "/dev/vda", name: "VirtIO Block Device", size_mb: 8192, disk_type: "virtio"),
        DetectedDisk(path: "/dev/nvme0n1", name: "NVMe SSD", size_mb: 0, disk_type: "nvme"),
        DetectedDisk(path: "/dev/sda", name: "SATA Disk", size_mb: 0, disk_type: "sata")
    ]

fn default_partition_plan(disk: DetectedDisk) -> PartitionPlan:
    val swap_mb: u64 = if disk.size_mb > 4096: 2048 else: 512
    PartitionPlan(disk: disk, efi_size_mb: 256, root_size_mb: 0, swap_size_mb: swap_mb)

fn apply_partition_plan(plan: PartitionPlan) -> Result<bool, text>:
    var layout = "[partition_plan]\n"
    layout = layout + "disk = \"{plan.disk.path}\"\n"
    layout = layout + "table = \"gpt\"\n"
    layout = layout + "\n[partition.1]\nlabel = \"EFI\"\ntype = \"efi\"\n"
    layout = layout + "size_mb = {plan.efi_size_mb}\nfs = \"fat32\"\n"
    layout = layout + "\n[partition.2]\nlabel = \"SimpleOS\"\ntype = \"simpleos\"\n"
    layout = layout + "size_mb = {plan.root_size_mb}\nfs = \"simplefs\"\n"
    if plan.swap_size_mb > 0:
        layout = layout + "\n[partition.3]\nlabel = \"Swap\"\ntype = \"swap\"\n"
        layout = layout + "size_mb = {plan.swap_size_mb}\n"
    write_text("/tmp/partition_plan.sdn", layout)
    Result.Ok(true)

fn install_bootloader(plan: PartitionPlan, arch: PkgArch) -> Result<bool, text>:
    _ensure_dir(TARGET_EFI_MOUNT)
    _ensure_dir("{TARGET_EFI_MOUNT}/EFI")
    _ensure_dir("{TARGET_EFI_MOUNT}/EFI/BOOT")

    val kernel_files = readdir(INSTALLER_KERNEL_DIR)
    for kfile in kernel_files:
        val content = read_text("{INSTALLER_KERNEL_DIR}/{kfile}")
        if content != "":
            write_text("{TARGET_EFI_MOUNT}/{kfile}", content)
    write_text("{TARGET_EFI_MOUNT}/limine.cfg", _generate_boot_config(arch))
    Result.Ok(true)

fn install_packages(arch: PkgArch) -> Result<i32, text>:
    val entries = readdir(INSTALLER_PKG_DIR)
    var count = 0
    var errors = 0
    for entry in entries:
        if entry.ends_with(".spk"):
            val result = _install_spk("{INSTALLER_PKG_DIR}/{entry}", TARGET_MOUNT)
            if val Ok(_) = result:
                count = count + 1
            else if val Err(_e) = result:
                errors = errors + 1
    if errors > 0:
        return Result.Err("{errors} packages failed to install")
    Result.Ok(count)

fn install_os_config(hostname: text) -> Result<bool, text>:
    for dir in _TARGET_LAYOUT:
        _ensure_dir("{TARGET_MOUNT}{dir}")

    write_text("{TARGET_MOUNT}/etc/hostname", "{hostname}\n")
    write_text("{TARGET_MOUNT}/etc/pkg/repos.sdn", "[repositories]\nlocal = \"/var/cache/pkg/local\"\n")
    write_text("{TARGET_MOUNT}/etc/fstab", "# SimpleOS filesystem table\n/dev/root / auto defaults 0 1\n/dev/efi /boot/efi fat32 defaults 0 2\n")
    write_text("{TARGET_MOUNT}/etc/rc.conf", "hostname=\"{hostname}\"\nsimpleos_desktop=\"YES\"\n")
    write_text("{TARGET_MOUNT}/etc/shell/profile.sdn", "shell = \"/bin/shell\"\n")
    write_text("{TARGET_MOUNT}/sbin/init", "#!/bin/simple-init\nprint(\"SIMPLEOS_INIT_OK\")\n")

    val deploy_manifest = read_text(INSTALLER_DEPLOY_MANIFEST)
    if deploy_manifest != "":
        _ensure_dir("{TARGET_MOUNT}/var/db/simpleos")
        write_text("{TARGET_MOUNT}/var/db/simpleos/deployed-files.sdn", deploy_manifest)
    Result.Ok(true)

fn run_installer(arch: PkgArch) -> Result<bool, text>:
    _print_banner()
    val disks = detect_disks()
    if disks.len() == 0:
        return Result.Err("No target disks found")

    val target_disk = disks[0]
    val plan = default_partition_plan(target_disk)
    val part_result = apply_partition_plan(plan)
    if val Err(e) = part_result:
        return Result.Err("Partitioning failed: {e}")

    _ensure_dir(TARGET_MOUNT)
    _ensure_dir(TARGET_EFI_MOUNT)

    val boot_result = install_bootloader(plan, arch)
    if val Err(e) = boot_result:
        return Result.Err("Bootloader install failed: {e}")

    val pkg_result = install_packages(arch)
    if val Err(e) = pkg_result:
        return Result.Err("Package install failed: {e}")

    val config_result = install_os_config("simpleos")
    if val Err(e) = config_result:
        return Result.Err("Configuration failed: {e}")

    _print_complete()
    Result.Ok(true)

fn run_upgrade(arch: PkgArch) -> Result<bool, text>:
    val hostname_content = read_text("{TARGET_MOUNT}/etc/hostname")
    if hostname_content == "":
        return Result.Err("No existing SimpleOS installation found at {TARGET_MOUNT}")

    val pkg_result = install_packages(arch)
    if val Err(e) = pkg_result:
        return Result.Err("Package upgrade failed: {e}")

    val kernel_files = readdir(INSTALLER_KERNEL_DIR)
    for kfile in kernel_files:
        val content = read_text("{INSTALLER_KERNEL_DIR}/{kfile}")
        if content != "":
            write_text("{TARGET_EFI_MOUNT}/{kfile}", content)

    val deploy_manifest = read_text(INSTALLER_DEPLOY_MANIFEST)
    if deploy_manifest != "":
        _ensure_dir("{TARGET_MOUNT}/var/db/simpleos")
        write_text("{TARGET_MOUNT}/var/db/simpleos/deployed-files.sdn", deploy_manifest)
    Result.Ok(true)

fn _print_installer_usage():
    print "Usage: installer <command> [OPTIONS]"
    print ""
    print "Commands:"
    print "  install          Fresh installation to target disk"
    print "  upgrade          Upgrade existing installation from install media"
    print "  detect           Detect available disks"
    print ""
    print "Options:"
    print "  --arch=ARCH      Target architecture (default: x86_64)"
    print "  -h               Show this help"

fn run_usb_installer(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_installer_usage()
            return 0
    if args.len() < 1:
        _print_installer_usage()
        return 1

    var arch_str = "x86_64"
    for arg in args:
        if arg.starts_with("--arch="):
            arch_str = arg.slice(7, arg.len())
    val arch_result = pkg_arch_from_text(arch_str)
    if val Err(e) = arch_result:
        print "Error: {e}"
        return 1
    val arch = arch_result.unwrap()

    val command = args[0]
    if command == "install":
        val result = run_installer(arch)
        if val Ok(_) = result:
            return 0
        else if val Err(e) = result:
            print "\nInstallation FAILED: {e}"
            return 1
    else if command == "upgrade":
        val result = run_upgrade(arch)
        if val Ok(_) = result:
            return 0
        else if val Err(e) = result:
            print "\nUpgrade FAILED: {e}"
            return 1
    else if command == "detect":
        val disks = detect_disks()
        print "Detected disks:"
        for disk in disks:
            print "  {disk.path}\t{disk.name}\t{disk.size_mb} MB\t{disk.disk_type}"
        return 0
    print "Unknown command: {command}"
    _print_installer_usage()
    1

fn _install_spk(spk_path: text, target_root: text) -> Result<bool, text>:
    val archive_data = read_text(spk_path)
    if archive_data == "":
        return Result.Err("Empty or missing .spk file")

    var offset = 0
    val block = 512
    if offset + block > archive_data.len():
        return Result.Err("Truncated archive")

    val header_block = archive_data.slice(offset, offset + block).trim()
    val header_parts = header_block.split("\t")
    if header_parts.len() < 2:
        return Result.Err("Invalid archive header")
    val manifest_size = header_parts[1].to_i32()
    offset = offset + block

    val manifest_content = archive_data.slice(offset, offset + manifest_size)
    val padded = manifest_size + (block - (manifest_size % block)) % block
    offset = offset + if manifest_size % block == 0: manifest_size else: padded

    val manifest_result = parse_extended_manifest(manifest_content)
    if val Err(e) = manifest_result:
        return Result.Err("Bad manifest in .spk: {e}")
    val manifest = manifest_result.unwrap()

    var extracted_files = 0
    while offset + block <= archive_data.len():
        val entry_block = archive_data.slice(offset, offset + block).trim()
        if entry_block == "":
            break
        val entry_parts = entry_block.split("\t")
        if entry_parts.len() < 2:
            break
        val entry_name = entry_parts[0]
        val entry_size = entry_parts[1].to_i32()
        offset = offset + block

        if entry_name.starts_with("data/"):
            val rel_path = entry_name.slice(5, entry_name.len())
            val content = archive_data.slice(offset, offset + entry_size)
            _ensure_parent_dirs(target_root, rel_path)
            write_text("{target_root}/{rel_path}", content)
            extracted_files = extracted_files + 1
        val entry_padded = entry_size + (block - (entry_size % block)) % block
        offset = offset + if entry_size % block == 0: entry_size else: entry_padded
    if extracted_files == 0:
        for file_path in manifest.base.files:
            if file_path.ends_with("/"):
                _ensure_dir("{target_root}{file_path}")
            else:
                _ensure_parent_dirs(target_root, file_path)
                write_text("{target_root}{file_path}", _placeholder_payload(manifest, file_path))

    _ensure_dir("{target_root}/var/db/pkg/installed")
    write_text("{target_root}/var/db/pkg/installed/{manifest.base.name}.sdn", serialize_manifest(manifest.base))
    Result.Ok(true)

fn _placeholder_payload(manifest: ExtendedManifest, file_path: text) -> text:
    var out = "# installed from package archive\n"
    out = out + "name = \"{manifest.base.name}\"\n"
    out = out + "path = \"{file_path}\"\n"
    out = out + "arch = \"{pkg_arch_to_text(manifest.arch)}\"\n"
    out

fn _generate_boot_config(arch: PkgArch) -> text:
    var cfg = "# SimpleOS Boot Configuration\n"
    cfg = cfg + "TIMEOUT=3\n\n"
    cfg = cfg + ":SimpleOS\n"
    cfg = cfg + "  PROTOCOL=limine\n"
    cfg = cfg + "  KERNEL_PATH=boot:///kernel.elf\n"
    cfg = cfg + "  CMDLINE=console=serial root=/dev/sda2 arch={pkg_arch_to_text(arch)}\n\n"
    cfg = cfg + ":SimpleOS (Recovery)\n"
    cfg = cfg + "  PROTOCOL=limine\n"
    cfg = cfg + "  KERNEL_PATH=boot:///kernel.elf\n"
    cfg = cfg + "  CMDLINE=console=serial root=/dev/sda2 recovery=1 arch={pkg_arch_to_text(arch)}\n"
    cfg

fn _ensure_dir(path: text):
    if path == "":
        return
    val parts = path.split("/")
    var current = ""
    for raw in parts:
        val part = raw.trim()
        if part == "":
            continue
        current = current + "/" + part
        mkdir(current)

fn _ensure_parent_dirs(rootfs_root: text, file_path: text):
    val parts = file_path.split("/")
    var current = rootfs_root
    var i: u64 = 0
    while i + 1 < parts.len().to_u64():
        val part = parts[i as i64].trim()
        if part != "":
            current = current + "/" + part
            mkdir(current)
        i = i + 1

fn _print_banner():
    print ""
    print "╔══════════════════════════════════════╗"
    print "║     SimpleOS Installer v1.0.0        ║"
    print "║  Deploy staged filesystem to disk    ║"
    print "╚══════════════════════════════════════╝"
    print ""

fn _print_complete():
    print ""
    print "╔══════════════════════════════════════╗"
    print "║     Installation Complete!           ║"
    print "║  Remove install media and reboot.    ║"
    print "╚══════════════════════════════════════╝"
    print ""
