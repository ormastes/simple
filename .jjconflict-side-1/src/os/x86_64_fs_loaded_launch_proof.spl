"""
x86_64 FS-Loaded Tool Apps — launch proof classification.

Classifies evidence present in a serial output for the six tool apps.
Distinguishes process-backed proof from resident-manifest fallback.

MDSOC: os layer — read-only serial log inspection, no spawn or IPC.
"""

# Proof families that must be present for a tool app to pass.
pub val PROOF_VFS_READ: text = "vfs-app-read"
pub val PROOF_PROCESS_BACKED: text = "process-backed"
pub val PROOF_WM_OWNER: text = "wm-owner"
pub val PROOF_RENDER: text = "render-proof"
pub val PROOF_TOOLCHAIN_LAUNCH: text = "toolchain-launch"

class AppLaunchProof:
    app_name: text
    has_vfs_read: bool
    has_process_backed: bool
    has_wm_owner: bool
    has_render_proof: bool
    has_toolchain_launch: bool

    static fn from_serial(app_nm: text, serial_output: text) -> AppLaunchProof:
        val vfs_frag = "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/{app_nm} bytes="
        val pb_frag = "[desktop-e2e] process-backed:ok app={app_nm} pid="
        val wm_frag = "[desktop-e2e] wm-owner:ok app={app_nm} pid="
        val rp_frag = "[desktop-e2e] render-proof:ok app={app_nm} pid="
        val tc_frag = "[desktop-e2e] toolchain-launch:ok app={app_nm}"
        AppLaunchProof(
            app_name: app_nm,
            has_vfs_read: serial_output.contains(vfs_frag),
            has_process_backed: serial_output.contains(pb_frag),
            has_wm_owner: serial_output.contains(wm_frag),
            has_render_proof: serial_output.contains(rp_frag),
            has_toolchain_launch: serial_output.contains(tc_frag)
        )

    # Returns true if the base proof contract is satisfied (vfs-read + process-backed).
    me has_base_proof() -> bool:
        self.has_vfs_read and self.has_process_backed

    # Returns the first absent proof family name, or "none" if all present.
    me first_missing_base_proof() -> text:
        if not self.has_vfs_read:
            return PROOF_VFS_READ
        if not self.has_process_backed:
            return PROOF_PROCESS_BACKED
        "none"

# Returns the AppLaunchProof for each of the six tool apps.
pub fn classify_all_tool_app_proofs(serial_output: text) -> [AppLaunchProof]:
    [
        AppLaunchProof.from_serial("simple_browser", serial_output),
        AppLaunchProof.from_serial("simple_compiler", serial_output),
        AppLaunchProof.from_serial("simple_interpreter", serial_output),
        AppLaunchProof.from_serial("simple_loader", serial_output),
        AppLaunchProof.from_serial("llvm", serial_output),
        AppLaunchProof.from_serial("rust", serial_output)
    ]

# Returns true if ALL six tool apps have base proof (vfs-read + process-backed).
pub fn all_tool_apps_have_base_proof(serial_output: text) -> bool:
    for proof in classify_all_tool_app_proofs(serial_output):
        if not proof.has_base_proof():
            return false
    true

# Returns true if the serial output contains a resident-manifest fallback pattern.
# Resident fallback must fail closed — it must NOT be accepted as completion evidence.
pub fn has_resident_manifest_fallback(serial_output: text) -> bool:
    serial_output.contains("[desktop-e2e] resident-fallback:active") or
    serial_output.contains("[launcher] fallback=resident-manifest")
