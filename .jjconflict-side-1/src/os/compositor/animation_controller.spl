#![allow(unnamed_duplicate_typed_args)]
# Animation Controller — Spring-based window transitions
#
# Manages active animations for compositor window transitions.
# Uses SpringAnimation from spring.spl for physics-based motion.

use common.animation.spring.{SpringConfig, SpringAnimation, spring_step, spring_is_at_rest, spring_progress}

struct AnimationTarget:
    """What property is being animated."""
    window_id: u64
    property: text        # "x", "y", "width", "height", "opacity", "scale"

struct WindowAnimation:
    """A single active animation."""
    target: AnimationTarget
    spring: SpringAnimation
    start_value: f64
    end_value: f64

class AnimationController:
    """Manages all active window animations."""
    animations: [WindowAnimation]

impl AnimationController:
    static fn new() -> AnimationController:
        AnimationController(animations: [])

    me start(window_id: u64, property: text, from: f64, to: f64, config: SpringConfig):
        """Start a new spring animation. Replaces any existing animation for same window+property."""
        # Remove existing animation for this target
        var new_list: [WindowAnimation] = []
        var i: u64 = 0
        while i < self.animations.len():
            val anim = self.animations[i]
            if anim.target.window_id != window_id or anim.target.property != property:
                new_list.push(anim)
            i = i + 1

        # Add new animation
        val spring = SpringAnimation.create(config, from, to)
        val target = AnimationTarget(window_id: window_id, property: property)
        new_list.push(WindowAnimation(
            target: target,
            spring: spring,
            start_value: from,
            end_value: to
        ))
        self.animations = new_list

    me start_default(window_id: u64, property: text, from: f64, to: f64):
        """Start animation with default spring config (iOS-like)."""
        self.start(window_id, property, from, to, SpringConfig.default_config())

    me start_bouncy(window_id: u64, property: text, from: f64, to: f64):
        """Start animation with bouncy spring."""
        self.start(window_id, property, from, to, SpringConfig.bouncy())

    me tick(dt: f64):
        """Step all active animations by dt seconds. Remove completed ones."""
        var active: [WindowAnimation] = []
        var i: u64 = 0
        while i < self.animations.len():
            var anim = self.animations[i]
            anim.spring = spring_step(anim.spring, dt)
            if spring_is_at_rest(anim.spring):
                # Animation complete — snap to final value (don't keep it)
                pass_dn
            else:
                active.push(anim)
            i = i + 1
        self.animations = active

    fn is_animating(window_id: u64) -> bool:
        """Check if any animation is active for this window."""
        var i: u64 = 0
        while i < self.animations.len():
            if self.animations[i].target.window_id == window_id:
                return true
            i = i + 1
        false

    fn has_active() -> bool:
        """Check if any animation is running."""
        self.animations.len() > 0

    fn current_value(window_id: u64, property: text) -> f64:
        """Get current animated value, or 0.0 if not animating."""
        var i: u64 = 0
        while i < self.animations.len():
            val anim = self.animations[i]
            if anim.target.window_id == window_id and anim.target.property == property:
                return anim.spring.current
            i = i + 1
        0.0

    fn progress(window_id: u64, property: text) -> f64:
        """Get animation progress [0.0, 1.0] or 1.0 if not animating."""
        var i: u64 = 0
        while i < self.animations.len():
            val anim = self.animations[i]
            if anim.target.window_id == window_id and anim.target.property == property:
                return spring_progress(anim.spring)
            i = i + 1
        1.0

# Convenience functions for common window animations

fn animate_window_open(ctrl: AnimationController, window_id: u64, target_x: f64, target_y: f64):
    """Animate window appearing: spring from center to target position."""
    ctrl.start_bouncy(window_id, "x", 512.0, target_x)
    ctrl.start_bouncy(window_id, "y", 384.0, target_y)
    ctrl.start_default(window_id, "opacity", 0.0, 1.0)

fn animate_window_close(ctrl: AnimationController, window_id: u64, current_x: f64, current_y: f64):
    """Animate window disappearing: spring to center + fade out."""
    ctrl.start(window_id, "x", current_x, 512.0, SpringConfig.smooth())
    ctrl.start(window_id, "y", current_y, 384.0, SpringConfig.smooth())
    ctrl.start(window_id, "opacity", 1.0, 0.0, SpringConfig.smooth())

fn animate_window_focus(ctrl: AnimationController, window_id: u64):
    """Subtle pulse when window gains focus."""
    ctrl.start(window_id, "scale", 0.98, 1.0, SpringConfig.stiff())
