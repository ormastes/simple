# Window Layout Manager — iOS-style window modes
#
# Supports: FullScreen, Split View, Slide Over, Stage Manager, PiP
# Computes target layouts for windows based on their current mode,
# inspired by iPadOS multi-tasking.

use std.window_protocol.geometry.{WindowId, Px}

# ============================================================================
# Window Mode
# ============================================================================

enum WindowMode:
    FullScreen
    SplitLeft
    SplitRight
    SlideOver
    StageManager
    PictureInPicture
    Minimized

# ============================================================================
# Split Configuration
# ============================================================================

struct SplitConfig:
    """Configuration for split-view mode."""
    ratio: f64           # 0.33, 0.5, 0.67
    left_id: WindowId
    right_id: WindowId

# ============================================================================
# Window Layout
# ============================================================================

struct WindowLayout:
    """Computed layout rectangle for a window."""
    x: Px
    y: Px
    width: Px
    height: Px

# ============================================================================
# Layout Manager
# ============================================================================

class LayoutManager:
    """Manages window layout modes and computes target positions.

    Each window has a mode (FullScreen, Split, SlideOver, etc.)
    and the manager computes the exact pixel layout based on
    screen dimensions and the mode.
    """
    screen_width: Px
    screen_height: Px
    taskbar_height: Px
    modes: Dict<WindowId, WindowMode>
    split_config: SplitConfig?
    slide_over_id: WindowId?
    pip_id: WindowId?
    stage_positions: Dict<WindowId, WindowLayout>

impl LayoutManager:

    static fn create(screen_w: Px, screen_h: Px, taskbar_h: Px) -> LayoutManager:
        """Create a new layout manager for the given screen dimensions."""
        LayoutManager(
            screen_width: screen_w,
            screen_height: screen_h,
            taskbar_height: taskbar_h,
            modes: {},
            split_config: nil,
            slide_over_id: nil,
            pip_id: nil,
            stage_positions: {}
        )

    # -- Layout Computation --------------------------------------------------

    fn compute_layout(window_id: WindowId) -> WindowLayout:
        """Compute target layout based on the window's current mode."""
        val mode = self.get_mode(window_id)
        val sw: i64 = self.screen_width.value.to_i64()
        val sh: i64 = self.screen_height.value.to_i64()
        val th: i64 = self.taskbar_height.value.to_i64()
        val usable_h = sh - th
        match mode:
            WindowMode.FullScreen:
                return WindowLayout(x: Px(value: 0), y: Px(value: 0), width: Px(value: sw.to_i32()), height: Px(value: usable_h.to_i32()))
            WindowMode.SplitLeft:
                val w = self._split_width(sw)
                return WindowLayout(x: Px(value: 0), y: Px(value: 0), width: Px(value: w.to_i32()), height: Px(value: usable_h.to_i32()))
            WindowMode.SplitRight:
                val left_w = self._split_width(sw)
                return WindowLayout(x: Px(value: left_w.to_i32()), y: Px(value: 0), width: Px(value: (sw - left_w).to_i32()), height: Px(value: usable_h.to_i32()))
            WindowMode.SlideOver:
                val w: i64 = 320
                val h = usable_h - 40
                return WindowLayout(x: Px(value: (sw - w - 10).to_i32()), y: Px(value: 20), width: Px(value: w.to_i32()), height: Px(value: h.to_i32()))
            WindowMode.PictureInPicture:
                return WindowLayout(x: Px(value: (sw - 280).to_i32()), y: Px(value: (usable_h - 180).to_i32()), width: Px(value: 260), height: Px(value: 160))
            WindowMode.StageManager:
                val pos = self.stage_positions.get(window_id)
                if pos != nil:
                    return pos
                return self._default_stage_position(window_id)
            WindowMode.Minimized:
                return WindowLayout(x: Px(value: 0), y: Px(value: sh.to_i32()), width: Px(value: 0), height: Px(value: 0))
        # Fallback (should not reach here)
        return WindowLayout(x: Px(value: 0), y: Px(value: 0), width: Px(value: sw.to_i32()), height: Px(value: usable_h.to_i32()))

    # -- Mode Management -----------------------------------------------------

    me set_mode(window_id: WindowId, mode: WindowMode):
        """Set the layout mode for a window."""
        self.modes = self.modes.set(window_id, mode)

    me apply_split_view(left_id: WindowId, right_id: WindowId, ratio: f64):
        """Configure split view between two windows."""
        self.split_config = SplitConfig(ratio: ratio, left_id: left_id, right_id: right_id)
        self.modes = self.modes.set(left_id, WindowMode.SplitLeft)
        self.modes = self.modes.set(right_id, WindowMode.SplitRight)

    me set_slide_over(window_id: WindowId):
        """Set a window as the slide-over panel."""
        self.slide_over_id = window_id
        self.modes = self.modes.set(window_id, WindowMode.SlideOver)

    me set_pip(window_id: WindowId):
        """Set a window as the picture-in-picture overlay."""
        self.pip_id = window_id
        self.modes = self.modes.set(window_id, WindowMode.PictureInPicture)

    me set_stage_position(window_id: WindowId, layout: WindowLayout):
        """Store a custom position for a Stage Manager window."""
        self.stage_positions = self.stage_positions.set(window_id, layout)
        self.modes = self.modes.set(window_id, WindowMode.StageManager)

    # -- Queries -------------------------------------------------------------

    fn get_mode(window_id: WindowId) -> WindowMode:
        """Get the current mode for a window (defaults to FullScreen)."""
        val mode = self.modes.get(window_id)
        if mode != nil:
            return mode
        WindowMode.FullScreen

    fn get_split_config() -> SplitConfig?:
        """Get the current split configuration, if any."""
        self.split_config

    fn get_slide_over_id() -> WindowId?:
        """Get the slide-over window ID (nil if none)."""
        self.slide_over_id

    fn get_pip_id() -> WindowId?:
        """Get the PiP window ID (nil if none)."""
        self.pip_id

    # -- Internal Helpers ----------------------------------------------------

    fn _split_ratio() -> f64:
        """Get the split ratio from config, defaulting to 0.5."""
        if self.split_config != nil:
            return self.split_config.ratio
        0.5

    fn _split_width(screen_w: i64) -> i64:
        """Compute split left-side width from config ratio and screen width.

        Uses the ratio as a float multiplied directly with the screen width,
        then truncates to integer. Defaults to half the screen.
        """
        if self.split_config != nil:
            val ratio = self.split_config.ratio
            return _apply_ratio(screen_w, ratio)
        screen_w / 2

    fn _default_stage_position(window_id: WindowId) -> WindowLayout:
        """Compute a default Stage Manager position based on window ID.

        Offsets each window slightly so they cascade.
        """
        val sw: i64 = self.screen_width.value.to_i64()
        val sh: i64 = self.screen_height.value.to_i64()
        val th: i64 = self.taskbar_height.value.to_i64()
        val usable_h = sh - th
        val offset: i64 = (window_id.value % 5).to_i64() * 40
        val base_w = sw * 3 / 4
        val base_h = usable_h * 3 / 4
        WindowLayout(
            x: Px(value: (60 + offset).to_i32()),
            y: Px(value: (30 + offset).to_i32()),
            width: Px(value: base_w.to_i32()),
            height: Px(value: base_h.to_i32())
        )

# ============================================================================
# Internal Helpers
# ============================================================================

fn _apply_ratio(total: i64, ratio: f64) -> i64:
    """Apply a float ratio to an integer total, returning integer result.

    Uses integer math: multiply total by (ratio * 10000) then divide by 10000.
    This avoids float-to-int conversion issues in interpreter mode.
    Example: _apply_ratio(1920, 0.5) => 1920 * 5000 / 10000 => 960
    """
    # Convert ratio to integer thousandths to avoid float arithmetic on total
    # ratio * 10000 gives us enough precision (0.33 -> 3300, 0.5 -> 5000, 0.67 -> 6700)
    val ratio_scaled = ratio * 10000.0
    # Use integer truncation: add a small value to avoid float imprecision
    val ratio_int = _trunc(ratio_scaled)
    return total * ratio_int / 10000

fn _trunc(v: f64) -> i64:
    """Truncate f64 to i64 using iterative approach.

    Avoids .to_i64() which may not be available in interpreter mode.
    Works for positive values up to reasonable screen sizes.
    """
    # For positive values, find the integer part
    if v < 0.0:
        return 0 - _trunc(0.0 - v)
    var result: i64 = 0
    var remaining = v
    # Fast path: step by 1000s, then 100s, then 10s, then 1s
    while remaining >= 1000.0:
        result = result + 1000
        remaining = remaining - 1000.0
    while remaining >= 100.0:
        result = result + 100
        remaining = remaining - 100.0
    while remaining >= 10.0:
        result = result + 10
        remaining = remaining - 10.0
    while remaining >= 1.0:
        result = result + 1
        remaining = remaining - 1.0
    return result
