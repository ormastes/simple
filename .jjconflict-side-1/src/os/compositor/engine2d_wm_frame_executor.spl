# Canonical Shared WM -> Draw IR -> Engine2D production frame executor.

use common.gpu.simpleos_host_gpu_draw_ir.{SimpleOsHostGpuImageResource, simpleos_host_gpu_image_resource}
use common.gpu.simpleos_host_gpu_protocol.{
    SIMPLEOS_HOST_GPU_PROTOCOL_VERSION,
    SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US,
    SIMPLEOS_HOST_GPU_STATUS_PASS,
    SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED,
    SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST,
    SIMPLEOS_HOST_GPU_REASON_TIMEOUT,
    SIMPLEOS_HOST_GPU_REASON_INVALID_HELLO,
    SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION,
    SIMPLEOS_HOST_GPU_BACKEND_DIRECTX,
    SIMPLEOS_HOST_GPU_BACKEND_METAL,
    SIMPLEOS_HOST_GPU_BACKEND_VULKAN,
    simpleos_host_gpu_backend_name,
    simpleos_host_gpu_backend_mask,
    simpleos_host_gpu_guest_isa_name,
    simpleos_host_gpu_max_readback_bytes
}
use common.ui.draw_ir.{DRAW_IR_BACKEND_AUTO, DrawIrComposition}
use common.ui.taskbar_model.{TaskbarModel}
use common.ui.window_scene.{SharedWmScene, SharedWmWindow, WmContentFrame}
use common.ui.window_scene_draw_ir.{
    shared_wm_content_frame_for_window,
    shared_wm_content_frame_image_uri,
    shared_wm_scene_draw_ir_composition_with_content,
    shared_wm_scene_window_content_rect_with_titlebar
}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{
    Engine2dResolvedDrawIrImage,
    engine2d_draw_ir_adv_composition_present_with_images,
    engine2d_resolved_draw_ir_image
}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver}
use os.kernel.boot.monotonic_hardware.{boot_monotonic_deadline_us, boot_monotonic_elapsed_us, boot_monotonic_now_us}
use os.lib.gpu_bridge.host_gpu_ivshmem.{
    HOST_GPU_IVSHMEM_DEFAULT_TIMEOUT_POLLS,
    host_gpu_ivshmem_device_receipt_valid,
    host_gpu_ivshmem_negotiate,
    host_gpu_ivshmem_next_generation,
    host_gpu_ivshmem_submit_draw_ir
}

extern fn serial_println(msg: text)

class Engine2dWmFrameExecutor:
    engine: Engine2D
    framebuffer: FramebufferDriver
    host_gpu_base: u64
    host_gpu_run_id_hash: i64
    host_gpu_backend: text
    host_gpu_backend_code: i64
    # Trusted scanout dims threaded in by the caller. native-build shifts
    # cross-module FramebufferDriver `.width`/`.height` field reads by one slot
    # (the [u32] back_buffer/host_buffer array fields before them mis-size the
    # class layout as seen here), so reading fb.width here yields garbage. When
    # >0 these trusted scalars override the field read. 0 = field-read fallback
    # (arm64/riscv64 callers that pass no dims — unchanged behavior).
    fb_w: i64
    fb_h: i64

    static fn create(engine: Engine2D, framebuffer: FramebufferDriver, fb_w: i64 = 0, fb_h: i64 = 0) -> Engine2dWmFrameExecutor:
        Engine2dWmFrameExecutor(engine: engine, framebuffer: framebuffer, host_gpu_base: 0u64, host_gpu_run_id_hash: 0, host_gpu_backend: "", host_gpu_backend_code: 0, fb_w: fb_w, fb_h: fb_h)

    static fn create_host_gpu(engine: Engine2D, framebuffer: FramebufferDriver, base: u64, guest_isa_code: i64, backend_code: i64, fb_width: i64, fb_height: i64, negotiation_started_us: i64) -> Engine2dWmFrameExecutor:
        var executor = Engine2dWmFrameExecutor.create(engine, framebuffer, fb_width, fb_height)
        val width = if fb_width > 0: fb_width else: framebuffer.width.to_i64()
        val height = if fb_height > 0: fb_height else: framebuffer.height.to_i64()
        val max_pixels = simpleos_host_gpu_max_readback_bytes() / 4
        val guest_isa = simpleos_host_gpu_guest_isa_name(guest_isa_code)
        if base != 0u64:
            serial_println("HOST_GPU_MAP_OK scope=production isa={guest_isa} base={base}")
        val deadline_us = boot_monotonic_deadline_us(negotiation_started_us, SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US)
        var attempts = 0
        var first_generation = 0
        var final_generation = 0
        var final_reason = SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST
        var decision_elapsed = 0
        if base == 0u64 or width <= 0 or height <= 0 or height > max_pixels or width > max_pixels / height:
            serial_println("[wm-frame] host-gpu-fallback reason=unavailable-or-readback-capacity width={width} height={height}")
            val elapsed = boot_monotonic_elapsed_us(negotiation_started_us, boot_monotonic_now_us())
            serial_println("HOST_GPU_NEGOTIATION_DONE scope=production isa={guest_isa} result=fallback backend=software attempts=0 first_generation=0 final_generation=0 elapsed_us={elapsed} budget_us={SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US} reason={final_reason}")
            return executor
        if guest_isa == "unsupported" or backend_code == 0 or simpleos_host_gpu_backend_mask(backend_code) == 0:
            serial_println("[wm-frame] host-gpu-fallback reason=invalid-session")
            val elapsed = boot_monotonic_elapsed_us(negotiation_started_us, boot_monotonic_now_us())
            serial_println("HOST_GPU_NEGOTIATION_DONE scope=production isa={guest_isa} result=fallback backend=software attempts=0 first_generation=0 final_generation=0 elapsed_us={elapsed} budget_us={SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US} reason={final_reason}")
            return executor
        if deadline_us <= 0:
            final_reason = SIMPLEOS_HOST_GPU_REASON_TIMEOUT
            serial_println("[wm-frame] host-gpu-fallback reason=invalid-clock")
            val elapsed = boot_monotonic_elapsed_us(negotiation_started_us, boot_monotonic_now_us())
            serial_println("HOST_GPU_NEGOTIATION_DONE scope=production isa={guest_isa} result=fallback backend=software attempts=0 first_generation=0 final_generation=0 elapsed_us={elapsed} budget_us={SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US} reason={final_reason}")
            return executor
        val backend_codes = [SIMPLEOS_HOST_GPU_BACKEND_METAL, SIMPLEOS_HOST_GPU_BACKEND_DIRECTX, SIMPLEOS_HOST_GPU_BACKEND_VULKAN]
        val expected_bytes = width * height * 4
        for candidate_code in backend_codes:
            val before_attempt = boot_monotonic_now_us()
            val before_elapsed = boot_monotonic_elapsed_us(negotiation_started_us, before_attempt)
            if before_elapsed <= 0 or before_elapsed >= SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US:
                final_reason = SIMPLEOS_HOST_GPU_REASON_TIMEOUT
                decision_elapsed = before_elapsed
                break
            val generation = host_gpu_ivshmem_next_generation(base)
            if generation <= 0:
                final_reason = SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION
                decision_elapsed = before_elapsed
                break
            val candidate = simpleos_host_gpu_backend_name(candidate_code)
            val candidate_mask = simpleos_host_gpu_backend_mask(candidate_code)
            val hello = host_gpu_ivshmem_negotiate(base, generation, guest_isa, candidate, 0, HOST_GPU_IVSHMEM_DEFAULT_TIMEOUT_POLLS, deadline_us)
            val attempt_finished = boot_monotonic_now_us()
            val attempt_elapsed = boot_monotonic_elapsed_us(before_attempt, attempt_finished)
            val total_elapsed = boot_monotonic_elapsed_us(negotiation_started_us, attempt_finished)
            if not hello.published:
                final_reason = hello.reason
                decision_elapsed = total_elapsed
                break
            if attempts == 0:
                first_generation = generation
            attempts = attempts + 1
            final_generation = generation
            val hello_valid = hello.completed and hello.status == SIMPLEOS_HOST_GPU_STATUS_PASS and hello.reason == 0 and
                hello.version == SIMPLEOS_HOST_GPU_PROTOCOL_VERSION and (hello.render_mask & candidate_mask) != 0 and
                hello.max_readback_bytes >= expected_bytes and hello.elapsed_us > 0 and attempt_elapsed > 0 and
                total_elapsed > 0 and total_elapsed <= SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US
            val retryable = hello.completed and hello.status == SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED and
                hello.reason == SIMPLEOS_HOST_GPU_REASON_INVALID_HELLO and hello.elapsed_us > 0 and attempt_elapsed > 0
            val budget_failed = hello.completed and hello.status == SIMPLEOS_HOST_GPU_STATUS_PASS and hello.reason == 0 and total_elapsed > SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US
            val outcome = if hello_valid: "selected" elif retryable: "rejected" elif not hello.completed and hello.reason == SIMPLEOS_HOST_GPU_REASON_TIMEOUT: "timeout" elif not hello.completed and hello.reason == SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION: "stale" elif budget_failed: "budget" else: "invalid"
            val marker_reason = if budget_failed: SIMPLEOS_HOST_GPU_REASON_TIMEOUT elif hello.reason == 0 and not hello_valid: SIMPLEOS_HOST_GPU_REASON_INVALID_HELLO else: hello.reason
            serial_println("HOST_GPU_NEGOTIATION_ATTEMPT scope=production isa={guest_isa} backend={candidate} generation={generation} outcome={outcome} status={hello.status} reason={marker_reason} daemon_elapsed_us={hello.elapsed_us} guest_elapsed_us={attempt_elapsed}")
            final_reason = marker_reason
            if hello_valid:
                executor.host_gpu_base = base
                executor.host_gpu_run_id_hash = generation
                executor.host_gpu_backend = candidate
                executor.host_gpu_backend_code = candidate_code
                final_reason = 0
                decision_elapsed = total_elapsed
                break
            serial_println("[wm-frame] host-gpu-fallback reason=negotiation status={hello.status} detail={hello.reason}")
            if not retryable:
                decision_elapsed = total_elapsed
                break
        val elapsed = if decision_elapsed > 0: decision_elapsed else: boot_monotonic_elapsed_us(negotiation_started_us, boot_monotonic_now_us())
        val result = if executor.host_gpu_base != 0u64: "selected" else: "fallback"
        val selected_backend = if executor.host_gpu_base != 0u64: executor.host_gpu_backend else: "software"
        serial_println("HOST_GPU_NEGOTIATION_DONE scope=production isa={guest_isa} result={result} backend={selected_backend} attempts={attempts} first_generation={first_generation} final_generation={final_generation} elapsed_us={elapsed} budget_us={SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US} reason={final_reason}")
        if executor.host_gpu_base != 0u64:
            serial_println("[wm-frame] host-gpu-ready backend={executor.host_gpu_backend} generation={executor.host_gpu_run_id_hash}")
        executor

    me _render_host_gpu(composition: DrawIrComposition, resources: [SimpleOsHostGpuImageResource]) -> bool:
        val generation = host_gpu_ivshmem_next_generation(self.host_gpu_base)
        if generation <= 0:
            return false
        # Use trusted scanout dims (native-build shifts cross-module fb field reads).
        val render_w = if self.fb_w > 0: self.fb_w else: self.framebuffer.width.to_i64()
        val render_h = if self.fb_h > 0: self.fb_h else: self.framebuffer.height.to_i64()
        val present_w = if self.fb_w > 0: self.fb_w.to_u32() else: self.framebuffer.width
        val present_h = if self.fb_h > 0: self.fb_h.to_u32() else: self.framebuffer.height
        val expected_bytes = render_w * render_h * 4
        val receipt = host_gpu_ivshmem_submit_draw_ir(
            self.host_gpu_base, generation, self.host_gpu_run_id_hash, generation,
            self.host_gpu_backend, render_w, render_h,
            composition, resources, HOST_GPU_IVSHMEM_DEFAULT_TIMEOUT_POLLS
        )
        if not host_gpu_ivshmem_device_receipt_valid(receipt, generation, self.host_gpu_run_id_hash, generation, self.host_gpu_backend_code, expected_bytes):
            serial_println("[wm-frame] host-gpu-fallback reason=receipt status={receipt.status} detail={receipt.reason}")
            return false
        if not self.framebuffer.present_argb32_from_mmio(receipt.output_addr, present_w, present_h, receipt.output_bytes, receipt.output_checksum):
            serial_println("[wm-frame] host-gpu-fallback reason=readback-presentation")
            return false
        serial_println("[wm-frame] host-gpu-presented backend={self.host_gpu_backend} generation={generation} run={self.host_gpu_run_id_hash} frame={generation} checksum={receipt.output_checksum}")
        true

    me render(scene: SharedWmScene, taskbar: TaskbarModel, content_frames: [WmContentFrame], scene_revision: i64, taskbar_revision: i64, clock_label: text) -> i64:
        if scene_revision <= 0 or taskbar_revision <= 0:
            return 0

        # Per-window fail-closed degrade: a window whose content frame is
        # missing, has an empty URI, or duplicates another window's URI is
        # dropped from the composition (never painted from unresolved content)
        # and counted, while the background + remaining windows still compose.
        # We hand the composition builder a scene + content_frames filtered to
        # only the resolvable windows so no unresolvable image command is emitted.
        var images: [Engine2dResolvedDrawIrImage] = []
        var host_images: [SimpleOsHostGpuImageResource] = []
        var good_windows: [SharedWmWindow] = []
        var good_content_frames: [WmContentFrame] = []
        var expected_images = 0
        var degraded_window_count = 0
        for window in scene.windows:
            val content = shared_wm_scene_window_content_rect_with_titlebar(window, 28)
            val needs_surface = not window.minimized and content.width > 0 and content.height > 0
            if not needs_surface:
                # Minimized / zero-content windows carry no content surface; keep
                # their chrome by leaving them in the scene unchanged.
                good_windows.push(window)
            else:
                expected_images = expected_images + 1
                var resolved = false
                if val frame = shared_wm_content_frame_for_window(content_frames, scene_revision, window, 28):
                    val image_uri = shared_wm_content_frame_image_uri(frame)
                    if image_uri != "":
                        var duplicate_uri = false
                        for image in images:
                            if image.image_uri == image_uri:
                                duplicate_uri = true
                        if not duplicate_uri:
                            images.push(engine2d_resolved_draw_ir_image(image_uri, frame.width, frame.height, frame.pixels))
                            if self.host_gpu_base != 0u64:
                                host_images.push(simpleos_host_gpu_image_resource(image_uri, frame.width, frame.height, frame.pixels))
                            good_windows.push(window)
                            good_content_frames.push(frame)
                            resolved = true
                if not resolved:
                    degraded_window_count = degraded_window_count + 1
                    serial_println("[wm-frame] window-degraded window_id={window.window_id} reason=unresolved-or-duplicate-content")

        val renderable_images = expected_images - degraded_window_count
        if images.len() != renderable_images or good_content_frames.len() != renderable_images:
            serial_println("[wm-frame] engine2d-draw-ir-rejected resolved_images={images.len()} expected_images={expected_images} degraded={degraded_window_count} content_frames={content_frames.len()} reason=resource-coverage")
            return 0
        val filtered_scene = SharedWmScene(width: scene.width, height: scene.height, backend: scene.backend, windows: good_windows, background: scene.background)
        val composition = shared_wm_scene_draw_ir_composition_with_content(filtered_scene, taskbar, good_content_frames, DRAW_IR_BACKEND_AUTO, 1000, clock_label, 0)
        if self.host_gpu_base != 0u64:
            if self._render_host_gpu(composition, host_images):
                if degraded_window_count > 0:
                    serial_println("[wm-frame] frame-degraded degraded_window_count={degraded_window_count} path=host-gpu scene_revision={scene_revision}")
                return scene_revision
        val result = engine2d_draw_ir_adv_composition_present_with_images(self.engine, composition, false, images)
        # A partially-unsupported composition (e.g. one taskbar icon whose
        # image never resolved because the backing disk lease is degraded)
        # must still show the commands that DID render -- rejecting the
        # whole frame over one unresolved icon regressed to a fully black
        # screen even though 9 of 14 commands were perfectly renderable
        # (SimpleOS baremetal desktop, 2026-07-16). Only bail when the
        # composition produced literally nothing.
        if result.rendered_command_count <= 0:
            serial_println("[wm-frame] engine2d-draw-ir-rejected resolved_images={images.len()} expected_images={expected_images} degraded={degraded_window_count} skipped={result.skipped_command_count} rendered={result.rendered_command_count} fallback_required={result.fallback_required} reason={result.fallback_reason}")
            return 0
        if degraded_window_count > 0 or result.skipped_command_count != 0:
            serial_println("[wm-frame] frame-degraded degraded_window_count={degraded_window_count} skipped={result.skipped_command_count} rendered={result.rendered_command_count} scene_revision={scene_revision}")
        scene_revision
