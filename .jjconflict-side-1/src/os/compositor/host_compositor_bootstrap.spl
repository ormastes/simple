# Optional host WM bootstrap providers and alternate backends.
use os.compositor.host_compositor_core.*
use os.compositor.background_image_provider.{HostBackgroundImageProvider}
use os.compositor.background_motion_provider.{HostMotionBackgroundSource}
use os.compositor.hosted_backend_sdl2.{HostedSdl2Backend}
use os.compositor.hosted_backend_cocoa.{HostedCocoaBackend}
use os.compositor.hosted_backend_win32.{HostedWin32Backend}
use common.ui.window_scene.{shared_wm_scene_register_background_image_provider, shared_wm_scene_register_motion_background_source, BackgroundSpec, WM_BACKGROUND_KIND_MOTION}
use app.play.wm_daemon_ensure.{wm_daemon_autoconnect}
extern fn rt_env_get(key: text) -> text?
extern fn rt_time_now_unix_micros() -> i64

fn _create_backend_for_kind(kind: HostBackendKind, w: i32, h: i32, title: text) -> CompositorBackend?:
    if kind == HostBackendKind.Sdl2:
        val sdl = HostedSdl2Backend.try_create(w, h, title)
        if sdl != nil:
            return sdl
        return nil
    if kind == HostBackendKind.Cocoa:
        val cocoa = HostedCocoaBackend.try_create(0, w, h, 0xFF0F172Au32)
        if cocoa != nil:
            return cocoa
        return nil
    if kind == HostBackendKind.Win32:
        val win32 = HostedWin32Backend.try_create(0, w, h, 0xFF0F172Au32)
        if win32 != nil:
            return win32
        return nil
    if kind == HostBackendKind.Tui:
        return nil
    HeadlessHostCompositorBackend.new(w, h)

# Registers the fs-backed BackgroundImageProvider once per process so
# BackgroundSpec kind:"image" resolves for real on the host lane instead of
# falling through to the loud unresolved marker for lack of a provider (see
# common.ui.window_scene.shared_wm_scene_resolve_background). Guarded so
# repeated init_host_wm calls (e.g. across tests in one process) do not churn
# the provider's cache/last-good state.
var _host_background_image_provider_registered: bool = false

fn ensure_host_background_image_provider_registered():
    if not _host_background_image_provider_registered:
        shared_wm_scene_register_background_image_provider(HostBackgroundImageProvider.create())
        _host_background_image_provider_registered = true

# Registers the fs-backed MotionBackgroundSource once per process, but ONLY
# when explicitly configured via SIMPLE_WM_MOTION_MANIFEST (a PPM frame-list
# manifest path; optional SIMPLE_WM_MOTION_FIT selects the per-frame fit
# policy, default "cover"). Unset env keeps the no-motion default lane
# byte-identical (capture-evidence checksum unchanged). A configured-but-bad
# manifest is reported loudly (typed Err from the factory, printed here) and
# leaves no source registered, so kind:"motion" then hits the documented loud
# unresolved marker instead of a silent fallback. `attempted` (not
# "succeeded") is what is latched: a bad manifest is reported once, not
# re-spammed on every init_host_wm call in the same process.
var _host_motion_background_source_attempted: bool = false
# Latched on a SUCCESSFUL registration only (empty otherwise, including the
# never-configured and configured-but-failed cases). init_host_wm reads these
# via host_motion_background_registered_spec() to decide whether the
# HostCompositor it just constructed should adopt a kind:"motion"
# BackgroundSpec — see that function's doc.
var _host_motion_background_manifest_ok: text = ""
var _host_motion_background_fit_ok: text = ""

fn ensure_host_motion_background_source_registered(target_w: i32, target_h: i32):
    if _host_motion_background_source_attempted:
        return
    _host_motion_background_source_attempted = true
    val manifest = rt_env_get("SIMPLE_WM_MOTION_MANIFEST") ?? ""
    if manifest == "":
        return
    val fit = rt_env_get("SIMPLE_WM_MOTION_FIT") ?? "cover"
    match HostMotionBackgroundSource.create(manifest, target_w, target_h, fit):
        Ok(source):
            # Seed the real first due timestamp at registration time (the
            # source's next-due bookkeeping starts at the "not yet scheduled"
            # sentinel per background_motion_provider.spl and only a
            # frame_for_time() call establishes a real due). Registering
            # without this would leave the seam's due permanently at the
            # sentinel — never due — until whatever first consumes a frame,
            # which is not guaranteed to happen promptly. Consuming the
            # current wall-clock frame here also means the very first
            # kind:"motion" resolve after registration is already a
            # (content-hash-cached) warm frame, not a cold decode.
            source.frame_for_time(rt_time_now_unix_micros())
            shared_wm_scene_register_motion_background_source(source)
            _host_motion_background_manifest_ok = manifest
            _host_motion_background_fit_ok = fit
            print "[host-wm] motion-background source registered manifest={manifest} fit={fit} frames={source.frame_paths.len()} interval_micros={source.frame_interval_micros}"
        Err(message):
            print "[host-wm] motion-background source registration FAILED: {message}"

# Returns the BackgroundSpec the hosted compositor should adopt at startup
# when ensure_host_motion_background_source_registered() above successfully
# registered a source (nil when motion was never configured OR configured but
# failed — both keep the default kind:"color" lane byte-identical, per that
# function's `attempted` latch). init_host_wm calls this once, right after
# constructing HostCompositor, so the SAME manifest/fit that registered the
# process-wide MotionBackgroundSource also becomes this compositor's
# resolvable BackgroundSpec (see HostCompositor._resolve_background /
# render_background_only) — the "reuse the shared-MDI resolver path already
# threaded here" wiring the plan's follow-up item 2 calls for.
fn host_motion_background_registered_spec() -> BackgroundSpec?:
    if _host_motion_background_manifest_ok == "":
        return nil
    BackgroundSpec(kind: WM_BACKGROUND_KIND_MOTION, color: 0xFF000000u32, source: _host_motion_background_manifest_ok, fit: _host_motion_background_fit_ok)

fn init_host_wm(cfg: HostWmConfig) -> HostWmHandle?:
    ensure_host_background_image_provider_registered()
    ensure_host_motion_background_source_registered(cfg.initial_size.width.to_i32(), cfg.initial_size.height.to_i32())
    # Auto-ensure the tiny background WM daemon for every REAL hosted GUI
    # launch (item 2 of the WM hardening plan). Guarded to Headless: the
    # daemon's own compositor handle is built via this same init_host_wm
    # with HostBackendKind.Headless (see wm_daemon_build_handle), so this
    # skip is what prevents the daemon from trying to auto-spawn itself; it
    # also means non-GUI Headless test/harness callers never pay the probe.
    # A single lock-file stat (see wm_daemon_autoconnect); zero-overhead,
    # never blocks on daemon init. SIMPLE_WM_DAEMON_AUTOCONNECT=0 opts out
    # (test isolation / in-guest SimpleOS builds, which never reach this
    # backend selection in the first place since init_host_wm is a
    # hosted-only entry point — see recon notes).
    if cfg.backend != HostBackendKind.Headless and (rt_env_get("SIMPLE_WM_DAEMON_AUTOCONNECT") ?? "1") != "0":
        wm_daemon_autoconnect()
    if cfg.backend == HostBackendKind.Tui:
        return nil
    val event_loop_id = 1
    val window_id = 1
    val reason = host_wm_surface_failure_reason(cfg, event_loop_id, window_id)
    if reason != nil:
        return nil
    val w = cfg.initial_size.width.to_i32()
    val h = cfg.initial_size.height.to_i32()
    val backend = _create_backend_for_kind(cfg.backend, w, h, cfg.title)
    if backend == nil:
        return nil
    val comp = HostCompositor.new(backend, cfg.initial_size)
    if val motion_bg = host_motion_background_registered_spec():
        comp.set_background(motion_bg)
    val wm = HostWmLoopState(running: true)
    HostWmHandle(
        compositor: comp,
        wm: wm,
        event_loop_id: event_loop_id,
        window_id: window_id,
        backend: cfg.backend
    )

