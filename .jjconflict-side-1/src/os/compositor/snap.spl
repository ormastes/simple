use os.compositor.layout_manager.{WindowLayout}

enum SnapZone:
    None_
    LeftHalf
    RightHalf
    TopHalf
    BottomHalf
    FullScreen
    TopLeftQuarter
    TopRightQuarter
    BottomLeftQuarter
    BottomRightQuarter

fn detect_snap_zone(x: i64, y: i64, screen_width: i64, screen_height: i64, threshold: i64) -> SnapZone:
    val near_left = x <= threshold
    val near_right = x >= screen_width - threshold
    val near_top = y <= threshold
    val near_bottom = y >= screen_height - threshold
    if near_left and near_top:
        return SnapZone.TopLeftQuarter
    if near_right and near_top:
        return SnapZone.TopRightQuarter
    if near_left and near_bottom:
        return SnapZone.BottomLeftQuarter
    if near_right and near_bottom:
        return SnapZone.BottomRightQuarter
    if near_left:
        return SnapZone.LeftHalf
    if near_right:
        return SnapZone.RightHalf
    if near_top:
        return SnapZone.FullScreen
    if near_bottom:
        return SnapZone.BottomHalf
    SnapZone.None_

fn compute_snap_layout(zone: SnapZone, screen_width: i64, screen_height: i64, taskbar_height: i64) -> WindowLayout:
    val usable_h = screen_height - taskbar_height
    val half_w = screen_width / 2
    val half_h = usable_h / 2
    if zone == SnapZone.LeftHalf:
        return WindowLayout(x: 0, y: 0, width: half_w, height: usable_h)
    if zone == SnapZone.RightHalf:
        return WindowLayout(x: half_w, y: 0, width: screen_width - half_w, height: usable_h)
    if zone == SnapZone.TopLeftQuarter:
        return WindowLayout(x: 0, y: 0, width: half_w, height: half_h)
    if zone == SnapZone.TopRightQuarter:
        return WindowLayout(x: half_w, y: 0, width: screen_width - half_w, height: half_h)
    if zone == SnapZone.BottomLeftQuarter:
        return WindowLayout(x: 0, y: half_h, width: half_w, height: usable_h - half_h)
    if zone == SnapZone.BottomRightQuarter:
        return WindowLayout(x: half_w, y: half_h, width: screen_width - half_w, height: usable_h - half_h)
    if zone == SnapZone.BottomHalf:
        return WindowLayout(x: 0, y: half_h, width: screen_width, height: usable_h - half_h)
    WindowLayout(x: 0, y: 0, width: screen_width, height: usable_h)
