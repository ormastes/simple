# Narrow freestanding Engine2D-shaped rectangle core for RV64 desktop service.
#
# The full engine2d_baremetal_core includes text/image helpers that pull glyph
# and array runtime symbols into --entry-closure baremetal links. This narrow
# core keeps the desktop-service WM scene on the Engine2D-shaped path while
# preserving the freestanding RV64 link surface.

extern fn rt_gui_fill4(xy: u64, wh: u64, color: u64, unused: u64) -> u64

fn _pack(hi: i32, lo: i32) -> u64:
    (hi.to_u64() << 32) | (lo.to_u64() & 0xFFFFFFFF)

fn rect_core_clear(width: i32, height: i32, color: u32):
    rect_core_draw_rect_filled(width, height, 0, 0, width, height, color)

fn rect_core_draw_rect_filled(width: i32, height: i32, x: i32, y: i32, w: i32, h: i32, color: u32):
    if w <= 0 or h <= 0:
        return
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > width:
        x1 = width
    if y1 > height:
        y1 = height
    if x1 <= x0 or y1 <= y0:
        return
    rt_gui_fill4(_pack(x0, y0), _pack(x1 - x0, y1 - y0), color.to_u64(), 0)

fn rect_core_present():
    return
