use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}

extern fn rt_win32_window_new(w: i64, h: i64, title: i64) -> i64
extern fn rt_win32_window_resize(hwnd: i64, w: i64, h: i64) -> bool
extern fn rt_win32_window_close(hwnd: i64) -> bool
extern fn rt_win32_dib_create(hwnd: i64, w: i64, h: i64, fill_color: i64) -> i64
extern fn rt_win32_dib_fill_rect(dib: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> bool
extern fn rt_win32_dib_present(hwnd: i64, dib: i64) -> bool
extern fn rt_win32_dib_present_rect(hwnd: i64, dib: i64, x: i64, y: i64, w: i64, h: i64) -> bool
extern fn rt_win32_dib_free(dib: i64) -> bool
extern fn rt_win32_dib_resize(hwnd: i64, dib: i64, w: i64, h: i64) -> i64
extern fn rt_win32_dib_read_pixel(dib: i64, x: i64, y: i64) -> i64
extern fn rt_win32_message_pump(hwnd: i64) -> i64

class HostedWin32Backend:
    window_id: i64
    buffer_id: i64
    w: i32
    h: i32

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil

    static fn implementation_name() -> text:
        "win32-native"

    static fn uses_native_win32_symbols() -> bool:
        true

    static fn new(window_id: i64, buffer_id: i64, w: i32, h: i32) -> HostedWin32Backend:
        HostedWin32Backend(window_id: window_id, buffer_id: buffer_id, w: w, h: h)

    static fn try_create(window_id: i64, w: i32, h: i32, clear_color: u32) -> HostedWin32Backend?:
        if w <= 0 or h <= 0:
            return nil
        var win = window_id
        if win <= 0:
            win = rt_win32_window_new(w.to_i64(), h.to_i64(), 0)
        if win <= 0:
            return nil
        val dib = rt_win32_dib_create(win, w.to_i64(), h.to_i64(), clear_color.to_i64())
        if dib <= 0:
            if window_id <= 0:
                rt_win32_window_close(win)
            return nil
        HostedWin32Backend.new(win, dib, w, h)

    me clear(color: u32):
        if self.buffer_id > 0:
            rt_win32_dib_fill_rect(self.buffer_id, 0, 0, self.w.to_i64(), self.h.to_i64(), color.to_i64())

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if self.buffer_id > 0:
            rt_win32_dib_fill_rect(self.buffer_id, x.to_i64(), y.to_i64(), w.to_i64(), h.to_i64(), color.to_i64())

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        if text_str.len() > 0:
            self.fill_rect(x, y, text_str.len().to_i32() * 8, 16, bg)
            self.put_pixel(x, y, fg)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        self.fill_rect(x, y, 8, 16, bg)
        self.put_pixel(x, y, fg)

    me put_pixel(x: i32, y: i32, color: u32):
        self.fill_rect(x, y, 1, 1, color)

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val src_idx = row * w + col
                if src_idx >= 0 and src_idx < pixels.len():
                    self.put_pixel(x + col, y + row, pixels[src_idx])
                col = col + 1
            row = row + 1

    me present():
        if self.window_id > 0 and self.buffer_id > 0:
            rt_win32_dib_present(self.window_id, self.buffer_id)

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        if self.window_id > 0 and self.buffer_id > 0:
            rt_win32_dib_present_rect(self.window_id, self.buffer_id, x.to_i64(), y.to_i64(), w.to_i64(), h.to_i64())

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        self.fill_rect(x, y, w, h, color)

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        self.window_id = self.window_id

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color_top: u32, color_bottom: u32):
        self.fill_rect(x, y, w, h, color_top)

    fn read_pixel(x: i32, y: i32) -> u32:
        if self.buffer_id > 0:
            return rt_win32_dib_read_pixel(self.buffer_id, x.to_i64(), y.to_i64()).to_u32()
        0u32

    me resize(w: i32, h: i32) -> bool:
        if self.window_id > 0 and not rt_win32_window_resize(self.window_id, w.to_i64(), h.to_i64()):
            return false
        if self.buffer_id > 0:
            val new_dib = rt_win32_dib_resize(self.window_id, self.buffer_id, w.to_i64(), h.to_i64())
            if new_dib > 0:
                self.buffer_id = new_dib
        self.w = w
        self.h = h
        true

    me free():
        if self.buffer_id > 0:
            rt_win32_dib_free(self.buffer_id)
            self.buffer_id = 0
        if self.window_id > 0:
            rt_win32_window_close(self.window_id)
            self.window_id = 0

impl CompositorBackend for HostedWin32Backend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        if self.buffer_id > 0:
            rt_win32_dib_fill_rect(self.buffer_id, 0, 0, self.w.to_i64(), self.h.to_i64(), color.to_i64())

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if self.buffer_id > 0:
            rt_win32_dib_fill_rect(self.buffer_id, x.to_i64(), y.to_i64(), w.to_i64(), h.to_i64(), color.to_i64())

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        if text_str.len() > 0:
            self.fill_rect(x, y, text_str.len().to_i32() * 8, 16, bg)
            self.put_pixel(x, y, fg)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        self.fill_rect(x, y, 8, 16, bg)
        self.put_pixel(x, y, fg)

    me put_pixel(x: i32, y: i32, color: u32):
        self.fill_rect(x, y, 1, 1, color)

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val src_idx = row * w + col
                if src_idx >= 0 and src_idx < pixels.len():
                    self.put_pixel(x + col, y + row, pixels[src_idx])
                col = col + 1
            row = row + 1

    me present():
        if self.window_id > 0 and self.buffer_id > 0:
            rt_win32_dib_present(self.window_id, self.buffer_id)

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        if self.window_id > 0 and self.buffer_id > 0:
            rt_win32_dib_present_rect(self.window_id, self.buffer_id, x.to_i64(), y.to_i64(), w.to_i64(), h.to_i64())

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil
