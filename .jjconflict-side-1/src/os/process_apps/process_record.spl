"""ProcessRecord — per-process state owned by the SimpleOS scheduler.

Each filesystem-backed user app gets one ProcessRecord when the launcher
calls exec. The record tracks PID, app path, run status, and exit code.
"""

# Process run status values
# "running" | "zombie" | "exited" | "faulted"

class ProcessRecord:
    pid: i64
    app_path: text
    run_status: text
    exit_code: i64
    has_window: bool

    static fn new(pid: i64, app_path: text) -> ProcessRecord:
        ProcessRecord(
            pid: pid,
            app_path: app_path,
            run_status: "running",
            exit_code: 0,
            has_window: false
        )

    me is_running() -> bool:
        self.run_status == "running"

    me is_zombie() -> bool:
        self.run_status == "zombie"

    me is_exited() -> bool:
        self.run_status == "exited"

    me is_faulted() -> bool:
        self.run_status == "faulted"

    me mark_exited(code: i64) -> ProcessRecord:
        ProcessRecord(
            pid: self.pid,
            app_path: self.app_path,
            run_status: "exited",
            exit_code: code,
            has_window: self.has_window
        )

    me mark_zombie() -> ProcessRecord:
        ProcessRecord(
            pid: self.pid,
            app_path: self.app_path,
            run_status: "zombie",
            exit_code: self.exit_code,
            has_window: self.has_window
        )

    me mark_faulted(code: i64) -> ProcessRecord:
        ProcessRecord(
            pid: self.pid,
            app_path: self.app_path,
            run_status: "faulted",
            exit_code: code,
            has_window: self.has_window
        )

    me with_window() -> ProcessRecord:
        ProcessRecord(
            pid: self.pid,
            app_path: self.app_path,
            run_status: self.run_status,
            exit_code: self.exit_code,
            has_window: true
        )
