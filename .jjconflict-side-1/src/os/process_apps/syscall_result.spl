"""SyscallResult — encodes the return value and errno from a syscall.

Syscall 13 (direct spawn) and related process syscalls use this type to
distinguish success, errno errors, and fault conditions.
"""

# errno constants (POSIX subset)
val ENOSYS_CODE = 38
val EINVAL_CODE = 22
val ENOMEM_CODE = 12
val EFAULT_CODE = 14

class SyscallResult:
    is_ok: bool
    retval: i64
    errno_code: i64

    static fn ok(retval: i64) -> SyscallResult:
        SyscallResult(is_ok: true, retval: retval, errno_code: 0)

    static fn err(errno_code: i64) -> SyscallResult:
        SyscallResult(is_ok: false, retval: -1, errno_code: errno_code)

    static fn enosys() -> SyscallResult:
        SyscallResult(is_ok: false, retval: -1, errno_code: ENOSYS_CODE)

    static fn einval() -> SyscallResult:
        SyscallResult(is_ok: false, retval: -1, errno_code: EINVAL_CODE)

    static fn enomem() -> SyscallResult:
        SyscallResult(is_ok: false, retval: -1, errno_code: ENOMEM_CODE)

    static fn efault() -> SyscallResult:
        SyscallResult(is_ok: false, retval: -1, errno_code: EFAULT_CODE)

    me is_enosys() -> bool:
        val not_ok = self.is_ok == false
        not_ok and self.errno_code == ENOSYS_CODE

    me is_efault() -> bool:
        val not_ok = self.is_ok == false
        not_ok and self.errno_code == EFAULT_CODE

    me pid() -> i64:
        if self.is_ok:
            return self.retval
        return -1
