fn scenario_rv64_ssh() -> QemuScenario:
    """RV64 production SSHD lane with host-forwarded SSH."""
    QemuScenario(
        name: "rv64-ssh",
        arch: Architecture.Riscv64,
        machine: "virt",
        cpu: "rv64",
        memory: "1024M",
        qemu_extra: [
            "-bios", "default",
            "-global", "virtio-mmio.force-legacy=false",
            "-drive", "file=build/os/fat32-riscv64.img,if=none,id=rvdisk,format=raw",
            "-device", "virtio-blk-device,drive=rvdisk",
            "-netdev", "user,id=n0,hostfwd=tcp::2222-:2222",
            "-device", "virtio-net-pci,netdev=n0,disable-modern=on,disable-legacy=off"
        ],
        gui_mode: false,
        description: "RV64 production SSH daemon live lane"
    )

fn scenario_rv64_x25519_probe() -> QemuScenario:
    """RV64 pure Simple X25519 diagnostic lane."""
    QemuScenario(
        name: "rv64-x25519-probe",
        arch: Architecture.Riscv64,
        machine: "virt",
        cpu: "rv64",
        memory: "1024M",
        qemu_extra: [
            "-bios", "default",
            "-global", "virtio-mmio.force-legacy=false"
        ],
        gui_mode: false,
        description: "RV64 pure Simple X25519 shallow diagnostic lane"
    )

fn scenario_riscv64_fpga_mmode() -> QemuScenario:
    QemuScenario(
        name: "riscv64-fpga-mmode",
        arch: Architecture.Riscv64,
        machine: "virt",
        cpu: "rv64",
        memory: "64M",
        qemu_extra: [],
        gui_mode: false,
        description: "RV64 FPGA M-mode kernel-only build lane"
    )

fn scenario_riscv32_fpga_mmode() -> QemuScenario:
    QemuScenario(
        name: "riscv32-fpga-mmode",
        arch: Architecture.Riscv32,
        machine: "virt",
        cpu: "rv32",
        memory: "64M",
        qemu_extra: [],
        gui_mode: false,
        description: "RV32 FPGA M-mode kernel-only build lane"
    )

fn scenario_x64_full_stack() -> QemuScenario:
    """x86_64 NVMe + VirtIO-net + experimental VirtIO-GPU integration lane.

    Uses the same release-first disk artifact selection as the other disk
    lanes so the QEMU surface stays aligned with installed/release media.
    """
    QemuScenario(
        name: "x64-full-stack",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "512M",
        qemu_extra: _x64_nvme_disk_args() + [
            "-netdev", "user,id=n0",
            "-device", "virtio-net-pci,netdev=n0",
            "-device", "virtio-gpu,disable-modern=on,disable-legacy=off",
            "-vga", "none",
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
        ],
        gui_mode: false,
        description: "x86_64 NVMe + VirtIO-net + experimental VirtIO-GPU integration lane"
    )

fn scenario_x64_desktop_test() -> QemuScenario:
    """x86_64 desktop integration serial lane (SYS-GUI-001/002).

    Boots examples/09_embedded/simple_os/arch/x86_64/desktop_e2e_entry.spl under QEMU with
    the BGA framebuffer and serial routed to stdio. The entry point drives the
    real shell + launcher + wm path and emits canonical markers:
      boot / shell-ready / launcher-ready / desktop-ready / shortcut:ok / wm:ok
    which test/03_system/os_desktop_integration_spec.spl asserts on.
    """
    QemuScenario(
        name: "x64-desktop-test",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "512M",
        qemu_extra: [
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04",
            "-vga", "std"
        ],
        gui_mode: false,
        description: "x86_64 SimpleOS desktop integration serial lane"
    )

fn arm_fs_exec_disk_image_path(arch: Architecture) -> text:
    match arch:
        Architecture.Arm64: simpleos_platform_disk_image_output("arm64")
        Architecture.Arm32: simpleos_platform_disk_image_output("arm32")
        _: "build/os/fat32-arm.img"

fn arm_fs_exec_kernel_bin_path(arch: Architecture) -> text:
    match arch:
        Architecture.Arm64: "build/os/simpleos_arm64_fs_exec.bin"
        Architecture.Arm32: "build/os/simpleos_arm32_fs_exec.bin"
        _: "build/os/simpleos_arm_fs_exec.bin"

fn _arm_virtio_blk_exec_disk_args(arch: Architecture) -> [text]:
    val img = arm_fs_exec_disk_image_path(arch)
    ["-global", "virtio-mmio.force-legacy=false", "-drive", "file={img},if=none,id=armdisk,format=raw", "-device", "virtio-blk-device,drive=armdisk"]

fn riscv_fs_exec_disk_image_path(arch: Architecture) -> text:
    match arch:
        Architecture.Riscv64: simpleos_platform_disk_image_output("riscv64")
        Architecture.Riscv32: simpleos_platform_disk_image_output("riscv32")
        _: "build/os/fat32-riscv.img"

fn _riscv_virtio_blk_exec_disk_args(arch: Architecture) -> [text]:
    val img = riscv_fs_exec_disk_image_path(arch)
    ["-global", "virtio-mmio.force-legacy=false", "-drive", "file={img},if=none,id=rvdisk,format=raw", "-device", "virtio-blk-device,drive=rvdisk"]

fn ovmf_code_candidates() -> [text]:
    [
        "/usr/share/OVMF/OVMF_CODE_4M.fd",
        "/usr/share/OVMF/OVMF_CODE.fd",
        "/usr/share/edk2/ovmf/OVMF_CODE.fd",
        "/usr/share/edk2-ovmf/x64/OVMF_CODE.fd",
        "/usr/share/qemu/OVMF.fd",
        "/opt/homebrew/share/qemu/edk2-x86_64-code.fd"
    ]

fn ovmf_code_path() -> text:
    """Resolve the OVMF code image for x86_64 UEFI QEMU boots."""
    val env_path = env_get("SIMPLEOS_OVMF_CODE") ?? ""
    if env_path != "":
        return env_path
    for candidate in ovmf_code_candidates():
        if file_exists(candidate):
            return candidate
    ""

fn desktop_uefi_bootloader_candidates() -> [text]:
    [
        "build/os/esp/EFI/BOOT/BOOTX64.EFI",
        "build/os/EFI/BOOT/BOOTX64.EFI",
        "build/os/BOOTX64.EFI",
        "build/third_party/limine-install/share/limine/BOOTX64.EFI",
        "build/third_party/limine-build/bin/BOOTX64.EFI",
        "third_party/limine/BOOTX64.EFI",
        "vendor/limine/BOOTX64.EFI"
    ]

fn desktop_uefi_bootloader_path() -> text:
    """Resolve a repo-managed EFI bootloader artifact for the desktop UEFI lane."""
    val env_path = env_get("SIMPLEOS_UEFI_BOOTLOADER") ?? ""
    if env_path != "":
        return env_path
    for candidate in desktop_uefi_bootloader_candidates():
        if file_exists(candidate):
            return candidate
    ""

fn desktop_uefi_disk_image_path() -> text:
    """Generated FAT32 image used by the desktop UEFI acceptance lane."""
    simpleos_platform_disk_image_output("x86_64")

fn desktop_uefi_esp_dir_path() -> text:
    """Generated ESP directory exposed to OVMF through QEMU vvfat."""
    "build/os/esp"

fn desktop_uefi_boot_media_ready() -> bool:
    """True when the local disk image can be expected to boot under OVMF."""
    ovmf_code_path() != "" and desktop_uefi_bootloader_path() != "" and file_exists(desktop_uefi_disk_image_path()) and file_exists(desktop_uefi_esp_dir_path() + "/EFI/BOOT/BOOTX64.EFI")

fn _x64_desktop_uefi_args() -> [text]:
    val fw = ovmf_code_path()
    val img_path = desktop_uefi_disk_image_path()
    var args: [text] = [
        "-drive", "if=pflash,format=raw,readonly=on,file={fw}",
        "-global", "q35-pcihost.pci-hole64-size=0",
        "-drive", "file=fat:rw:{desktop_uefi_esp_dir_path()},format=raw,media=disk,if=none,id=espdisk",
        "-device", "virtio-blk-pci,drive=espdisk,bootindex=1",
        "-drive", "file={img_path},if=none,id=uefidisk,format=raw",
        "-device", "nvme,serial=uefi-desktop,drive=uefidisk",
        "-netdev", "user,id=n0",
        "-device", "virtio-net-pci,netdev=n0",
        "-device", "virtio-gpu,disable-modern=on,disable-legacy=off",
        "-vga", "none",
        "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
    ]
    args

fn scenario_x64_desktop_uefi() -> QemuScenario:
    """x86_64 desktop acceptance lane booted through OVMF/UEFI from disk."""
    QemuScenario(
        name: "x64-desktop-uefi",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "2048M",
        qemu_extra: _x64_desktop_uefi_args(),
        gui_mode: false,
        description: "x86_64 SimpleOS desktop UEFI/OVMF disk boot acceptance lane"
    )

fn get_all_scenarios() -> [QemuScenario]:
    """Returns all defined QEMU scenarios."""
    [
        scenario_rv64_base(),
        scenario_rv64_dtb_pci(),
        scenario_x64_pci_lab(),
        scenario_x64_nvme(),
        scenario_x64_net_user(),
        scenario_x64_ssh(),
        scenario_x64_toolchain_vfs_probe(),
        scenario_x64_q35_pure_nvme_perf(),
        scenario_x64_gpu_2d(),
        scenario_x64_gui(),
        scenario_x64_gui_tablet(),
        scenario_x64_wm_input_test(),
        scenario_x64_wm_simple_web_check(),
        scenario_x64_nvme_fat32(),
        scenario_x86_32_initrd_fat32_smf(),
        scenario_arm64_virtio_fat32_smf(),
        scenario_arm64_wm_ramfb(),
        scenario_arm64_desktop_engine2d(),
        scenario_simpleos_host_gpu_x86_64(),
        scenario_simpleos_host_gpu_aarch64(),
        scenario_simpleos_host_gpu_riscv64(),
        scenario_arm32_virtio_fat32_smf(),
        scenario_riscv64_virtio_fat32_smf(),
        scenario_riscv64_smoke(),
        scenario_riscv64_display_smoke(),
        scenario_riscv64_hosted(),
        scenario_rv64_ssh(),
        scenario_rv64_x25519_probe(),
        scenario_riscv64_fpga_mmode(),
        scenario_riscv32_virtio_fat32_smf(),
        scenario_riscv32_fpga_mmode(),
        scenario_x64_full_stack(),
        scenario_x64_desktop_test(),
        scenario_x64_desktop_disk(),
        scenario_x64_desktop_gui(),
        scenario_x64_desktop_uefi()
    ]

fn get_scenario(name: text) -> QemuScenario?:
    """Look up a scenario by name.
    NOTE: returning Option<QemuScenario> across calls trips the interpreter
    large-struct Option bug (interp_simpleos_lane_contract_crash) — callers
    that need fields should use scenario_exists + scenario_by_name_direct."""
    for s in get_all_scenarios():
        if s.name == name:
            return s
    nil

# scenario_exists / scenario_by_name_direct use name->constructor dispatch
# instead of indexing get_all_scenarios(): the seed interpreter wraps elements
# of an imported [class] list as Option (see interp_simpleos_lane_contract_crash
# — get_all_scenarios variant), but a single constructor call returns a clean
# QemuScenario. This keeps the os build/run/test scenario path crash-free.
fn scenario_exists(name: text) -> bool:
    if name == "rv64-base":
        return true
    if name == "rv64-dtb-pci":
        return true
    if name == "x64-pci-lab":
        return true
    if name == "x64-nvme":
        return true
    if name == "x64-net-user":
        return true
    if name == "x64-ssh":
        return true
    if name == "x64-toolchain-vfs-probe":
        return true
    if name == "x86_64-q35-pure-nvme-perf":
        return true
    if name == "x64-gpu-2d":
        return true
    if name == "x64-gui":
        return true
    if name == "x64-gui-tablet":
        return true
    if name == "x64-wm-input-test":
        return true
    if name == "x64-wm-simple-web-check":
        return true
    if name == "x64-nvme-fat32":
        return true
    if name == "x86_32-initrd-fat32-smf":
        return true
    if name == "arm64-virtio-fat32-smf":
        return true
    if name == "arm64-wm-ramfb":
        return true
    if name == "arm64-desktop-engine2d":
        return true
    if name == "simpleos-host-gpu-x86_64" or name == "simpleos-host-gpu-aarch64" or name == "simpleos-host-gpu-riscv64":
        return true
    if name == "arm32-virtio-fat32-smf":
        return true
    if name == "riscv64-virtio-fat32-smf":
        return true
    if name == "riscv64-smoke":
        return true
    if name == "riscv64-display-smoke":
        return true
    if name == "riscv64-hosted":
        return true
    if name == "rv64-ssh":
        return true
    if name == "rv64-x25519-probe":
        return true
    if name == "riscv64-fpga-mmode":
        return true
    if name == "riscv32-virtio-fat32-smf":
        return true
    if name == "riscv32-fpga-mmode":
        return true
    if name == "x64-full-stack":
        return true
    if name == "x64-desktop-test":
        return true
    if name == "x64-desktop-disk":
        return true
    if name == "x64-desktop-gui":
        return true
    if name == "x64-desktop-uefi":
        return true
    false

fn scenario_by_name_direct(name: text) -> QemuScenario:
    """Never Option. Caller must check scenario_exists(name) first.
    Unknown names fall back to scenario_x64_nvme()."""
    if name == "rv64-base":
        return scenario_rv64_base()
    if name == "rv64-dtb-pci":
        return scenario_rv64_dtb_pci()
    if name == "x64-pci-lab":
        return scenario_x64_pci_lab()
    if name == "x64-nvme":
