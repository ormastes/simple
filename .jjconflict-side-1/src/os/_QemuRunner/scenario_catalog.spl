    if name == "x64-gui":
        return scenario_x64_gui()
    if name == "x64-gui-tablet":
        return scenario_x64_gui_tablet()
    if name == "x64-wm-input-test":
        return scenario_x64_wm_input_test()
    if name == "x64-wm-simple-web-check":
        return scenario_x64_wm_simple_web_check()
    if name == "x64-nvme-fat32":
        return scenario_x64_nvme_fat32()
    if name == "x86_32-initrd-fat32-smf":
        return scenario_x86_32_initrd_fat32_smf()
    if name == "arm64-virtio-fat32-smf":
        return scenario_arm64_virtio_fat32_smf()
    if name == "arm64-wm-ramfb":
        return scenario_arm64_wm_ramfb()
    if name == "arm64-desktop-engine2d":
        return scenario_arm64_desktop_engine2d()
    if name == "simpleos-host-gpu-x86_64":
        return scenario_simpleos_host_gpu_x86_64()
    if name == "simpleos-host-gpu-aarch64":
        return scenario_simpleos_host_gpu_aarch64()
    if name == "simpleos-host-gpu-riscv64":
        return scenario_simpleos_host_gpu_riscv64()
    if name == "arm32-virtio-fat32-smf":
        return scenario_arm32_virtio_fat32_smf()
    if name == "riscv64-virtio-fat32-smf":
        return scenario_riscv64_virtio_fat32_smf()
    if name == "riscv64-smoke":
        return scenario_riscv64_smoke()
    if name == "riscv64-display-smoke":
        return scenario_riscv64_display_smoke()
    if name == "riscv64-hosted":
        return scenario_riscv64_hosted()
    if name == "rv64-ssh":
        return scenario_rv64_ssh()
    if name == "rv64-x25519-probe":
        return scenario_rv64_x25519_probe()
    if name == "riscv64-fpga-mmode":
        return scenario_riscv64_fpga_mmode()
    if name == "riscv32-virtio-fat32-smf":
        return scenario_riscv32_virtio_fat32_smf()
    if name == "riscv32-fpga-mmode":
        return scenario_riscv32_fpga_mmode()
    if name == "x64-full-stack":
        return scenario_x64_full_stack()
    if name == "x64-desktop-test":
        return scenario_x64_desktop_test()
    if name == "x64-desktop-disk":
        return scenario_x64_desktop_disk()
    if name == "x64-desktop-gui":
        return scenario_x64_desktop_gui()
    if name == "x64-desktop-uefi":
        return scenario_x64_desktop_uefi()
    scenario_x64_nvme()

fn _arm_fs_exec_scenario_name(arch: Architecture) -> text:
    _arm_fs_exec_platform_name(arch) + "-virtio-fat32-smf"

fn _riscv_fs_exec_scenario_name(arch: Architecture) -> text:
    _riscv_fs_exec_platform_name(arch) + "-virtio-fat32-smf"
