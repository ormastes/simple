#![allow(unnamed_duplicate_typed_args)]
# SSH Authentication — RFC 4252
#
# Supports password and public key authentication.
# Uses plaintext password comparison (SHA-256 may FAULT on baremetal).
#
# Authentication flow:
#   1. Client sends SSH_MSG_SERVICE_REQUEST for "ssh-userauth"
#   2. Server responds with SSH_MSG_SERVICE_ACCEPT
#   3. Client sends SSH_MSG_USERAUTH_REQUEST with method
#   4. Server responds SUCCESS or FAILURE

use os.apps.sshd.ssh_packet.{ssh_put_u32, ssh_put_text, ssh_put_string, ssh_put_bool, ssh_put_byte, ssh_get_u32, ssh_get_string, ssh_get_text, ssh_ascii_text_to_bytes, SshTextResult, SshStringResult}

# ============================================================================
# Constants
# ============================================================================

val SSH_MSG_USERAUTH_REQUEST: u8 = 50
val SSH_MSG_USERAUTH_FAILURE: u8 = 51
val SSH_MSG_USERAUTH_SUCCESS: u8 = 52
val SSH_MSG_USERAUTH_BANNER: u8 = 53
val SSH_MSG_USERAUTH_PK_OK: u8 = 60
val SSH_MSG_USERAUTH_INFO_REQUEST: u8 = 60
val SSH_MSG_USERAUTH_INFO_RESPONSE: u8 = 61

# Maximum authentication attempts before disconnect
val MAX_AUTH_ATTEMPTS: u32 = 6

# ============================================================================
# Types
# ============================================================================

struct SshAuthRequest:
    """Parsed authentication request."""
    username: text
    service: text       # "ssh-connection"
    method: text        # "password", "publickey", or "none"
    password: text      # For password auth (empty otherwise)
    key_algo: text      # For publickey auth
    key_blob: [u8]      # For publickey auth
    has_signature: bool  # For publickey: true means verify, false means probe
    signature: [u8]     # For publickey: client's signature over session data

struct SshUser:
    """A user entry in the authentication database."""
    username: text
    password: text          # Plaintext password (SHA-256 FAULTs on baremetal)
    authorized_keys: [[u8]] # List of public key blobs

class SshUserDb:
    """Simple user database for SSH authentication."""
    users: [SshUser]

impl SshUserDb:

    static fn new() -> SshUserDb:
        """Create an empty user database."""
        SshUserDb(users: [])

    me add_user(username: text, password_val: text):
        """Add a user with a password (plaintext storage for baremetal)."""
        self.users.push(SshUser(
            username: username,
            password: password_val,
            authorized_keys: []
        ))

    me add_user_key(username: text, key_blob: [u8]):
        """Add an authorized public key for an existing user."""
        var i: u64 = 0
        while i < self.users.len():
            if self.users[i].username == username:
                self.users[i].authorized_keys.push(key_blob)
                return
            i = i + 1

    fn find_user(username: text) -> SshUser?:
        """Look up a user by name. Returns nil if not found."""
        var i: u64 = 0
        while i < self.users.len():
            if self.users[i].username == username:
                return self.users[i]
            i = i + 1
        nil

    fn authenticate_password(username: text, password_val: text) -> bool:
        """Check password against stored plaintext.
        Password compare is constant-time (_blobs_equal) to avoid a timing
        side-channel on the secret; username compare stays plain (not secret)."""
        var i: u64 = 0
        while i < self.users.len():
            val user = self.users[i]
            if user.username == username:
                var stored_bytes: [u8] = ssh_ascii_text_to_bytes(user.password)
                var given_bytes: [u8] = ssh_ascii_text_to_bytes(password_val)
                if _blobs_equal(stored_bytes, given_bytes):
                    return true
            i = i + 1
        false

    fn authenticate_key(username: text, key_blob: [u8]) -> bool:
        """Check if a public key is authorized for this user.

        Returns true if the key_blob matches one of the user's authorized keys.
        NOTE: Uses var locals to work around baremetal Cranelift codegen bug.
        """
        var user = self.find_user(username)
        if user == nil:
            return false

        var ki: u64 = 0
        while ki < user.authorized_keys.len():
            var stored = user.authorized_keys[ki]
            if _blobs_equal(stored, key_blob):
                return true
            ki = ki + 1

        false

fn sshd_create_default_users() -> SshUserDb:
    """Create default user database for SSH daemon.

    Standalone function to avoid method resolution ambiguity
    between SshDaemon.add_user and SshUserDb.add_user in Cranelift codegen.
    """
    var db = SshUserDb.new()
    db.add_user("root", "simpleos")
    db.add_user("user", "password")
    db

# ============================================================================
# Message Parsing
# ============================================================================

fn ssh_parse_auth_request(data: [u8]) -> Result<SshAuthRequest, text>:
    """Parse SSH_MSG_USERAUTH_REQUEST.

    Format:
      byte      SSH_MSG_USERAUTH_REQUEST (50)
      string    user name
      string    service name ("ssh-connection")
      string    method name ("password", "publickey", "none")
      ... method-specific fields ...
    """
    if data.len() < 2:
        return Err("USERAUTH_REQUEST too short")
    if data[0] != SSH_MSG_USERAUTH_REQUEST:
        return Err("not a USERAUTH_REQUEST")

    var off: u64 = 1

    # Username
    var username: text = ""
    match ssh_get_text(data, off):
        Ok(user_pair):
            username = user_pair.value
            off = user_pair.next_offset
        Err(_):
            return Err("USERAUTH: bad username")

    # Service name
    var service: text = ""
    match ssh_get_text(data, off):
        Ok(svc_pair):
            service = svc_pair.value
            off = svc_pair.next_offset
        Err(_):
            return Err("USERAUTH: bad service")

    # Method name
    var method: text = ""
    match ssh_get_text(data, off):
        Ok(meth_pair):
            method = meth_pair.value
            off = meth_pair.next_offset
        Err(_):
            return Err("USERAUTH: bad method")

    var password_val: text = ""
    var key_algo: text = ""
    var key_blob: [u8] = []
    var has_signature: bool = false
    var signature: [u8] = []

    if method == "password":
        # bool    FALSE (no password change)
        # string  plaintext password
        if off < data.len():
            off = off + 1   # skip bool byte
        match ssh_get_text(data, off):
            Ok(pw_pair):
                password_val = pw_pair.value
                off = pw_pair.next_offset
            Err(_):
                pass_do_nothing("password auth request has no password field")

    elif method == "publickey":
        # bool    has_signature
        # string  public key algorithm name
        # string  public key blob
        # [string signature]  — only present when has_signature is true
        if off < data.len():
            has_signature = data[off] != 0
            off = off + 1
        match ssh_get_text(data, off):
            Ok(algo_pair):
                key_algo = algo_pair.value
                off = algo_pair.next_offset
            Err(_):
                pass_do_nothing("publickey auth request has no algorithm field")
        match ssh_get_string(data, off):
            Ok(blob_pair):
                key_blob = blob_pair.data
                off = blob_pair.next_offset
            Err(_):
                pass_do_nothing("publickey auth request has no key blob")
        # Read signature if has_signature is true
        if has_signature and off < data.len():
            match ssh_get_string(data, off):
                Ok(sig_pair):
                    signature = sig_pair.data
                    off = sig_pair.next_offset
                Err(_):
                    pass_do_nothing("publickey auth request has no signature")

    elif method == "keyboard-interactive":
        # string language tag
        # string submethods
        match ssh_get_text(data, off):
            Ok(lang_pair):
                off = lang_pair.next_offset
            Err(_):
                pass_do_nothing("keyboard-interactive auth request has no language tag")
        match ssh_get_text(data, off):
            Ok(submethods_pair):
                off = submethods_pair.next_offset
            Err(_):
                pass_do_nothing("keyboard-interactive auth request has no submethods")

    # method == "none" has no additional fields

    Ok(SshAuthRequest(
        username: username,
        service: service,
        method: method,
        password: password_val,
        key_algo: key_algo,
        key_blob: key_blob,
        has_signature: has_signature,
        signature: signature
    ))

# ============================================================================
# Message Builders
# ============================================================================

fn ssh_build_auth_success() -> [u8]:
    """Build SSH_MSG_USERAUTH_SUCCESS message."""
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_SUCCESS)
    buf

fn _push_raw_string(buf: [u8], data: [u8]) -> [u8]:
    var out = ssh_put_u32(buf, data.len().to_u32())
    var i: u64 = 0
    while i < data.len():
        out.push(data[i])
        i = i + 1
    out

fn ssh_build_auth_failure(methods: [text], partial_success: bool) -> [u8]:
    """Build SSH_MSG_USERAUTH_FAILURE with available methods.

    Format:
      byte      SSH_MSG_USERAUTH_FAILURE (51)
      name-list authentications that can continue
      boolean   partial success
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_FAILURE)

    # Build comma-separated method list
    var method_str: text = ""
    var i: u64 = 0
    while i < methods.len():
        if i > 0:
            method_str = method_str + ","
        method_str = method_str + methods[i]
        i = i + 1

    buf = _push_raw_string(buf, ssh_ascii_text_to_bytes(method_str))
    buf = ssh_put_bool(buf, partial_success)
    buf

fn ssh_build_auth_banner(message: text) -> [u8]:
    """Build SSH_MSG_USERAUTH_BANNER message.

    Format:
      byte      SSH_MSG_USERAUTH_BANNER (53)
      string    message (UTF-8)
      string    language tag
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_BANNER)
    buf = _push_raw_string(buf, ssh_ascii_text_to_bytes(message))
    buf = ssh_put_u32(buf, 0)   # language tag
    buf

fn ssh_build_userauth_pk_ok(algo: text, key_blob: [u8]) -> [u8]:
    """Build SSH_MSG_USERAUTH_PK_OK response (RFC 4252 section 7).

    Sent when has_signature=false and the key is acceptable.
    Tells the client to retry with a real signature.

    Format:
      byte      SSH_MSG_USERAUTH_PK_OK (60)
      string    public key algorithm name
      string    public key blob
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_PK_OK)
    buf = _push_raw_string(buf, ssh_ascii_text_to_bytes(algo))
    buf = ssh_put_string(buf, key_blob)
    buf

fn ssh_build_userauth_info_request(name: text, instruction: text, prompt: text, echo: bool) -> [u8]:
    """Build SSH_MSG_USERAUTH_INFO_REQUEST for keyboard-interactive auth."""
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_INFO_REQUEST)
    buf = _push_raw_string(buf, ssh_ascii_text_to_bytes(name))
    buf = _push_raw_string(buf, ssh_ascii_text_to_bytes(instruction))
    buf = ssh_put_u32(buf, 0)
    buf = ssh_put_u32(buf, 1)
    buf = _push_raw_string(buf, ssh_ascii_text_to_bytes(prompt))
    buf = ssh_put_bool(buf, echo)
    buf

fn ssh_parse_userauth_info_response(data: [u8]) -> Result<text, text>:
    """Parse SSH_MSG_USERAUTH_INFO_RESPONSE and return the first response."""
    if data.len() < 5:
        return Err("USERAUTH_INFO_RESPONSE too short")
    if data[0] != SSH_MSG_USERAUTH_INFO_RESPONSE:
        return Err("not a USERAUTH_INFO_RESPONSE")
    val count = ssh_get_u32(data, 1).to_u64()
    if count < 1:
        return Err("USERAUTH_INFO_RESPONSE missing response")
    match ssh_get_text(data, 5):
        Ok(response):
            Ok(response.value)
        Err(_):
            Err("USERAUTH_INFO_RESPONSE bad response")

# NOTE: Public key authentication is currently DISABLED in ssh_session.spl.
# To enable it, implement Ed25519 signature verification for userauth here.
# The Ed25519 verify primitive is available at os.crypto.ed25519.ed25519_verify.
# The signed data format is defined in RFC 4252 section 7.

# ============================================================================
# Internal Helpers
# ============================================================================

fn _blobs_equal(a: [u8], b: [u8]) -> bool:
    """Constant-time comparison of two byte arrays."""
    if a.len() != b.len():
        return false

    var diff: u8 = 0
    var i: u64 = 0
    while i < a.len():
        diff = diff | (a[i] ^ b[i])
        i = i + 1

    diff == 0

export SSH_MSG_USERAUTH_REQUEST, SSH_MSG_USERAUTH_FAILURE, SSH_MSG_USERAUTH_PK_OK, SSH_MSG_USERAUTH_SUCCESS, MAX_AUTH_ATTEMPTS
