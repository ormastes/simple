use std.string_builder.{StringBuilder}

class SshRemoteShell:
    input_line: text
    output: text
    running: bool

impl SshRemoteShell:

    static fn new() -> SshRemoteShell:
        SshRemoteShell(
            input_line: "",
            output: "SimpleOS Shell v0.2\nType 'help' for available commands.\n\n",
            running: true
        )

    me show_prompt():
        self.output = "{self.output}user@simpleos:/# $ "

    me feed_remote_input(input: text) -> bool:
        for ch in input:
            if ch == '\r':
                pass_dn
            elif ch == '\n':
                self.output = "{self.output}\n"
                self._execute_line(self.input_line.trim())
                self.input_line = ""
                if self.running:
                    self.show_prompt()
            else:
                self.input_line = "{self.input_line}{ch}"
        self.running

    fn take_remote_output() -> text:
        val out = self.output
        self.output = ""
        out

    me _execute_line(line: text):
        if line == "":
            return
        if line == "exit":
            self.running = false
            return
        if line == "help":
            self.output = "{self.output}Built-ins: echo help pwd true whoami exit\n"
            return
        if line == "pwd":
            self.output = "{self.output}/\n"
            return
        if line == "whoami":
            self.output = "{self.output}root\n"
            return
        if line == "true":
            return
        if line.starts_with("echo "):
            self.output = "{self.output}{line.slice(5, line.len())}\n"
            return
        self.output = "{self.output}command not found: {line}\n"
