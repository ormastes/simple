#![allow(unnamed_duplicate_typed_args)]
# SimpleOS Git — Git VCS Wrapper Application
#
# A git command wrapper for SimpleOS that delegates to the host git binary
# via rt_process_run in hosted mode. Provides argument validation, help text,
# and formatted error messages.
#
# Commands:
#   git init                      — Initialize a .git repository
#   git clone URL [DIR]           — Clone a repository
#   git add FILE...               — Stage files
#   git commit -m "message"       — Create a commit
#   git status                    — Show working tree status
#   git log [--oneline] [-n N]    — Show commit history
#   git diff [FILE]               — Show diff
#   git branch [-a] [NAME]        — List/create branches
#   git checkout BRANCH/FILE      — Switch branch or restore file
#   git merge BRANCH              — Merge a branch
#   git push [REMOTE] [BRANCH]    — Push to remote
#   git pull [--rebase]           — Pull from remote
#   git remote [-v] [add NAME URL] — Manage remotes
#   git stash [pop]               — Stash changes
#   git help                      — Show available commands

# ============================================================================
# FFI
# ============================================================================

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(key: text) -> text

# ============================================================================
# Core: delegate to host git binary
# ============================================================================

fn git_run(args: [text]) -> (text, text, i64):
    """Run git with the given arguments and return (stdout, stderr, exit_code)."""
    rt_process_run("git", args)

fn print_output(stdout: text, stderr: text):
    """Print git output, preferring stdout but falling back to stderr."""
    val out = stdout.trim()
    val err = stderr.trim()
    if out != "":
        print out
    if err != "":
        print err

# ============================================================================
# Individual command handlers
# ============================================================================

fn git_init(args: [text]) -> i64:
    """git init [DIR] — Initialize a new git repository."""
    var cmd_args: [text] = ["init"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_clone(args: [text]) -> i64:
    """git clone URL [DIR] — Clone a repository."""
    if args.len() == 0:
        print "git clone: missing repository URL"
        print "usage: git clone <url> [<directory>]"
        return 1
    var cmd_args: [text] = ["clone"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_add(args: [text]) -> i64:
    """git add FILE... — Stage files for commit."""
    if args.len() == 0:
        print "git add: missing file arguments"
        print "usage: git add <file>..."
        return 1
    var cmd_args: [text] = ["add"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_commit(args: [text]) -> i64:
    """git commit [-m MSG] — Create a commit."""
    # Validate that -m is provided
    var has_message = false
    for a in args:
        if a == "-m":
            has_message = true
    if not has_message and args.len() == 0:
        print "git commit: use -m to provide a commit message"
        print "usage: git commit -m \"<message>\""
        return 1
    var cmd_args: [text] = ["commit"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_status(args: [text]) -> i64:
    """git status — Show working tree status."""
    var cmd_args: [text] = ["status"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_log(args: [text]) -> i64:
    """git log [--oneline] [-n N] — Show commit history."""
    var cmd_args: [text] = ["log"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_diff(args: [text]) -> i64:
    """git diff [FILE] — Show diff."""
    var cmd_args: [text] = ["diff"]
