fn git_checkout(args: [text]) -> i64:
    """git checkout BRANCH/FILE — Switch branch or restore file."""
    if args.len() == 0:
        print "git checkout: missing branch or file argument"
        print "usage: git checkout <branch|file>"
        return 1
    var cmd_args: [text] = ["checkout"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_merge(args: [text]) -> i64:
    """git merge BRANCH — Merge a branch."""
    if args.len() == 0:
        print "git merge: missing branch argument"
        print "usage: git merge <branch>"
        return 1
    var cmd_args: [text] = ["merge"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_push(args: [text]) -> i64:
    """git push [REMOTE] [BRANCH] — Push to remote."""
    var cmd_args: [text] = ["push"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_pull(args: [text]) -> i64:
    """git pull [--rebase] — Pull from remote."""
    var cmd_args: [text] = ["pull"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_remote(args: [text]) -> i64:
    """git remote [-v] [add NAME URL] — Manage remotes."""
    var cmd_args: [text] = ["remote"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_stash(args: [text]) -> i64:
    """git stash [pop] — Stash changes."""
    var cmd_args: [text] = ["stash"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = git_run(cmd_args)
    print_output(out, err)
    code

fn git_passthrough(args: [text]) -> i64:
    """Pass unrecognized git subcommands directly to git."""
    val (out, err, code) = git_run(args)
    print_output(out, err)
    code

# ============================================================================
# Help
# ============================================================================

fn git_help_text() -> text:
    var lines: [text] = []
    lines.append("SimpleOS Git — Git Version Control Wrapper")
    lines.append("")
    lines.append("Commands:")
    lines.append("  git init                      Initialize repository")
    lines.append("  git clone <url> [<dir>]       Clone repository")
    lines.append("  git add <file>...             Stage files")
    lines.append("  git commit -m \"msg\"           Create commit")
    lines.append("  git status                    Show working tree status")
    lines.append("  git log [--oneline] [-n N]    Show commit history")
    lines.append("  git diff [<file>]             Show diff")
    lines.append("  git branch [-a] [<name>]      List/create branches")
    lines.append("  git checkout <branch|file>    Switch branch or restore file")
    lines.append("  git merge <branch>            Merge a branch")
    lines.append("  git push [<remote>] [<branch>] Push to remote")
    lines.append("  git pull [--rebase]           Pull from remote")
    lines.append("  git remote [-v] [add ...]     Manage remotes")
    lines.append("  git stash [pop]               Stash changes")
    lines.append("  git help                      Show this help")
    lines.append("")
    lines.append("Any unrecognized subcommand is passed through to git.")
    lines.join("\n")

fn git_help(args: [text]) -> i64:
    print git_help_text()
    0

# ============================================================================
# CLI Dispatcher
# ============================================================================

fn git_run_cmd(args: [text]) -> i64:
    """Run a git command. Returns 0 on success, non-zero on error."""
    if args.len() == 0:
        print git_help_text()
        return 0

    val subcmd = args[0]
    val rest = args.slice(1, args.len())

    match subcmd:
        "init":     git_init(rest)
        "clone":    git_clone(rest)
        "add":      git_add(rest)
        "commit":   git_commit(rest)
        "status":   git_status(rest)
        "log":      git_log(rest)
        "diff":     git_diff(rest)
        "branch":   git_branch(rest)
        "checkout": git_checkout(rest)
        "merge":    git_merge(rest)
        "push":     git_push(rest)
        "pull":     git_pull(rest)
        "remote":   git_remote(rest)
        "stash":    git_stash(rest)
        "help":     git_help(rest)
        _:          git_passthrough(args)

# ============================================================================
# Standalone entry point (for testing outside shell)
# ============================================================================

fn main() -> i64:
    val args_str = rt_env_get("GIT_ARGS")
    if args_str != "":
        val parts = args_str.split(" ")
        return git_run_cmd(parts)
    print git_help_text()
    return 0
