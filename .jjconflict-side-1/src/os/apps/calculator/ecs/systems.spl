# Calculator ECS Systems — free functions operating on CalcWorld
#
# MDSOC+: systems are stateless functions that query and mutate the World.
# Wired to the capsule's event dispatch loop.

use os.apps.calculator.ecs.world.{CalcWorld}
use os.apps.calculator.ecs.components.{DisplayValue, DisplayExpr, CalcOperator, CalcAccumulator, InputState}

fn sys_clear(world: CalcWorld):
    """Reset all calculator state to initial values."""
    val tick = world.base.now()
    var i: i32 = 0
    while i < world.display_values.len():
        world.display_values.dense[i] = DisplayValue(value: "0")
        world.display_values.ticks[i] = tick
        world.display_exprs.dense[i] = DisplayExpr(expr: "")
        world.display_exprs.ticks[i] = tick
        world.operators.dense[i] = CalcOperator(op: 0)
        world.operators.ticks[i] = tick
        world.accumulators.dense[i] = CalcAccumulator(value: 0.0)
        world.accumulators.ticks[i] = tick
        world.input_states.dense[i] = InputState(entering: true)
        world.input_states.ticks[i] = tick
        i = i + 1
    world.base.advance()
