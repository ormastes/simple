use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class TextEditor:

    static fn new() -> TextEditor:
        TextEditor()

    me build_ui() -> UISession:
        val file_menu = panel("file_menu", "File", [
            row("file_actions", [
                button("btn_new", "New", "editor.file.new"),
                button("btn_open", "Open", "editor.file.open"),
                button("btn_save", "Save", "editor.file.save")
            ])
        ])

        val edit_menu = panel("edit_menu", "Edit", [
            row("edit_actions1", [
                button("btn_undo", "Undo", "editor.edit.undo"),
                button("btn_redo", "Redo", "editor.edit.redo")
            ]),
            row("edit_actions2", [
                button("btn_cut", "Cut", "editor.edit.cut"),
                button("btn_copy", "Copy", "editor.edit.copy"),
                button("btn_paste", "Paste", "editor.edit.paste")
            ])
        ])

        val menu_bar = row("editor_menu_bar", [
            file_menu,
            edit_menu
        ])

        val line_numbers = panel("line_numbers", "Lines", [
            text_widget("ln_1", "1"),
            text_widget("ln_2", "2"),
            text_widget("ln_3", "3"),
            text_widget("ln_4", "4"),
            text_widget("ln_5", "5")
        ])

        val text_area = panel("text_area", "Content", [
            text_widget("line1", "# Welcome to Text Editor"),
            text_widget("line2", ""),
            text_widget("line3", "Start typing your document here."),
            text_widget("line4", ""),
            text_widget("line5", "Use File menu to open or save files.")
        ])

        val editor_body = row("editor_body", [
            line_numbers,
            text_area
        ])

        val status = statusbar("editor_status", "Ln 1, Col 1  |  UTF-8  |  Plain Text", "Untitled")

        val root = column("editor_root", [
            menu_bar,
            editor_body,
            status
        ])

        val tree = build_tree_with_title(root, "Text Editor", "dark")
        UISession.new(tree)
