use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class PaintApp:

    static fn new() -> PaintApp:
        PaintApp()

    me build_ui() -> UISession:
        val tool_palette = panel("tool_palette", "Tools", [
            row("tools_row1", [
                button("btn_pencil", "Pencil", "paint.tool.pencil"),
                button("btn_brush", "Brush", "paint.tool.brush"),
                button("btn_eraser", "Eraser", "paint.tool.eraser")
            ]),
            row("tools_row2", [
                button("btn_fill", "Fill", "paint.tool.fill"),
                button("btn_line", "Line", "paint.tool.line"),
                button("btn_rect", "Rectangle", "paint.tool.rect")
            ]),
            row("tools_row3", [
                button("btn_circle", "Circle", "paint.tool.circle")
            ])
        ])

        val color_palette = panel("color_palette", "Colors", [
            row("colors_row", [
                button("btn_red", "Red", "paint.color.red"),
                button("btn_green", "Green", "paint.color.green"),
                button("btn_blue", "Blue", "paint.color.blue"),
                button("btn_black", "Black", "paint.color.black"),
                button("btn_white", "White", "paint.color.white")
            ])
        ])

        val canvas = panel("canvas_area", "Canvas", [
            text_widget("canvas_placeholder", "[Canvas Area - 800x600]")
        ])

        val status = statusbar("paint_status", "Tool: Pencil  Color: Black", "800x600 | PNG")

        val root = column("paint_root", [
            row("paint_top", [
                tool_palette,
                column("paint_main", [
                    color_palette,
                    canvas
                ])
            ]),
            status
        ])

        val tree = build_tree_with_title(root, "Paint", "dark")
        UISession.new(tree)
