use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree_with_title
}

class HexEditorApp:
    static fn new() -> HexEditorApp:
        HexEditorApp()

    me build_ui() -> UISession:
        val toolbar = row("hex_toolbar", [
            button("hex_open", "Open", "open_file"),
            button("hex_save", "Save", "save_file"),
            button("hex_goto", "Go To", "goto_offset"),
            button("hex_find", "Find", "find_bytes"),
            button("hex_undo", "Undo", "undo"),
            button("hex_redo", "Redo", "redo")
        ])

        val header = text_widget("hex_header",
            "Offset    00 01 02 03 04 05 06 07  08 09 0A 0B 0C 0D 0E 0F  ASCII")

        val hex_view = panel("hex_data", "Hex View", [
            header,
            text_widget("hex_r0", "00000000  7F 45 4C 46 02 01 01 00  00 00 00 00 00 00 00 00  .ELF............"),
            text_widget("hex_r1", "00000010  03 00 3E 00 01 00 00 00  80 04 40 00 00 00 00 00  ..>.......@....."),
            text_widget("hex_r2", "00000020  40 00 00 00 00 00 00 00  C0 19 00 00 00 00 00 00  @..............."),
            text_widget("hex_r3", "00000030  00 00 00 00 40 00 38 00  0D 00 40 00 1E 00 1D 00  ....@.8...@....."),
            text_widget("hex_r4", "00000040  06 00 00 00 04 00 00 00  40 00 00 00 00 00 00 00  ........@......."),
            text_widget("hex_r5", "00000050  40 00 40 00 00 00 00 00  40 00 40 00 00 00 00 00  @.@.....@.@....."),
            text_widget("hex_r6", "00000060  D8 02 00 00 00 00 00 00  D8 02 00 00 00 00 00 00  ................"),
            text_widget("hex_r7", "00000070  08 00 00 00 00 00 00 00  03 00 00 00 04 00 00 00  ................")
        ])

        val info = row("hex_info", [
            label("hex_byte_val", "Byte: 0x7F (127)"),
            label("hex_i16_val", "Int16: 0x457F"),
            label("hex_i32_val", "Int32: 0x464C457F")
        ])

        val status = statusbar("hex_status", "Offset: 0x00000000  |  Size: 128 bytes", "sample.elf")

        val root = column("hex_root", [
            toolbar,
            hex_view,
            info,
            status
        ])

        val tree = build_tree_with_title(root, "Hex Editor", "dark")
        UISession.new(tree)
