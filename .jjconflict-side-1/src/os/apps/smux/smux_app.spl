# smux_app.spl — CLI entry surface for the smux terminal multiplexer.
#
# Routes command-line arguments to smux_api operations.
# Provides smux_run_cmd and help text.

use os.apps.smux.api.{
    smux_create_session,
    smux_list_sessions,
    smux_list_windows,
    smux_list_panes,
    smux_split_pane,
    smux_capture,
    smux_send_command,
    smux_is_deferred_feature
}

pub fn smux_help_text() -> text:
    return "smux <command> [args]\n  new <name>           create session\n  list                 list sessions\n  send <name> <cmd>    send command to active pane\n  capture <name>       capture active pane output\n  split <name>         split active pane\n  deferred <feature>   check deferred feature\n"

pub fn smux_run_cmd(args: [text]) -> int:
    if args.len() == 0:
        return 1

    val cmd = args[0]

    if cmd == "new":
        if args.len() < 2:
            return 1
        smux_create_session(args[1])
        return 0

    if cmd == "list":
        val sessions = smux_list_sessions()
        return 0

    if cmd == "send":
        if args.len() < 3:
            return 1
        val sessions = smux_list_sessions()
        if sessions.len() == 0:
            return 1
        val session = sessions[0]
        val windows = smux_list_windows(session.id)
        if windows.len() == 0:
            return 1
        val panes = smux_list_panes(session.id, windows[0].id)
        if panes.len() == 0:
            return 1
        val command = args[2]
        val _ = smux_send_command(session.id, windows[0].id, panes[0].id, command)
        return 0

    if cmd == "capture":
        if args.len() < 2:
            return 1
        val sessions = smux_list_sessions()
        if sessions.len() == 0:
            return 1
        val session = sessions[0]
        val windows = smux_list_windows(session.id)
        if windows.len() == 0:
            return 1
        val panes = smux_list_panes(session.id, windows[0].id)
        if panes.len() == 0:
            return 1
        val _ = smux_capture(session.id, windows[0].id, panes[0].id, 100)
        return 0

    if cmd == "split":
        if args.len() < 2:
            return 1
        val sessions = smux_list_sessions()
        if sessions.len() == 0:
            return 1
        val session = sessions[0]
        val windows = smux_list_windows(session.id)
        if windows.len() == 0:
            return 1
        val panes = smux_list_panes(session.id, windows[0].id)
        if panes.len() == 0:
            return 1
        val _ = smux_split_pane(session.id, windows[0].id, panes[0].id, "vertical")
        return 0

    if cmd == "deferred":
        if args.len() < 2:
            return 1
        val _ = smux_is_deferred_feature(args[1])
        return 0

    return 1
