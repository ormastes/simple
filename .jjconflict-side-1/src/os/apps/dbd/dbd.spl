# dbd — SimpleOS in-guest database daemon transport
#
# THE real Simple db server: std.nogc_sync_mut.redis.server.RedisServer (the
# same pure-Simple RESP engine src/app/redis_server/main.spl runs hosted).
# This file is ONLY the freestanding-kernel transport seam — it reuses
# RedisServer's parser (parse_next_request) and command dispatcher
# (RedisServer.dispatch) verbatim; it does not reimplement RESP parsing or
# command semantics. See RedisServer's own doc comment: "the request parser
# and command dispatcher are completely independent of the socket... a spec
# can feed RESP byte buffers to parse_next_request / RedisServer.dispatch".
#
# Two storage backends, selected at replay time:
#   - dbfs-engine: the DBFS key/value engine directly. Legitimately
#     DBFS-specific — it IS the db engine, not a generic file store. Lane C1
#     is landing the DbFsDriver root-mount integration; until a live DBFS
#     engine handle is reachable from this boot entry, dbd_try_dbfs_backend()
#     returns false and dbd falls back to vfs-log so this lane does not
#     block on C1.
#   - vfs-log: RedisServer has no persistence of its own (pure in-memory
#     store — see server.spl), so durability is a write-ahead journal of
#     mutating commands (SET/DEL), replayed at startup by re-dispatching
#     each journaled command through the REAL RedisServer.dispatch() (never
#     duplicating SET/DEL/GET semantics). The journal itself is read/written
#     through the switchable VFS hub (os.services.vfs.vfs_init —
#     g_vfs_read_file_bytes / g_vfs_write_file_bytes), which routes to
#     whatever root filesystem driver is mounted (FAT32 today, DBFS once
#     Lane C1's DbFsDriver lands) — no filesystem-specific token appears in
#     this file.
#
# The RESP engine + journal/replay logic lives in the pure, spec-tested
# os.apps.dbd.dbd_protocol module (which wraps the real
# std.nogc_sync_mut.redis.server.RedisServer). This file is ONLY the
# freestanding transport seam.
#
# Networking: the true per-socket rt_net_* primitives (rt_net_socket/bind/
# listen/accept/send_bytes/recv_bytes/close), the same primitives sshd's own
# rt_boot_tcp_* convenience wrappers are built on (see sshd.spl) and the same
# ones src/os/kernel/boot/http_baremetal.spl now uses — NOT
# std.nogc_sync_mut.io.tcp.{TcpListener,TcpStream} (the hosted OS-socket
# wrapper RedisServer.run()/serve_connection() use), which is not proven
# under x86_64-unknown-none freestanding. RedisServer.run()/serve_connection()
# are therefore not called here; this file's accept/read/write loop mirrors
# serve_connection()'s buffering logic (drain all complete commands per read,
# retain a trailing partial fragment) on top of the freestanding primitives.

use std.nogc_sync_mut.redis.server.{parse_next_request}
use os.apps.dbd.dbd_protocol.{DbdEngine, dbd_command_is_mutating, dbd_encode_journal_line}
use os.services.vfs.vfs_init.{g_vfs_read_file_bytes, g_vfs_write_file_bytes, g_vfs_file_exists}

extern fn serial_println(msg: text)
extern fn rt_net_socket(proto: i64) -> i64
extern fn rt_net_bind(sock_fd: i64, port_num: i64) -> i64
extern fn rt_net_listen(sock_fd: i64, backlog: i64) -> i64
extern fn rt_net_accept(sock_fd: i64) -> i64
extern fn rt_net_send_bytes(sock_fd: i64, data: [u8]) -> i64
extern fn rt_net_recv_bytes(sock_fd: i64, max_len: i64) -> [u8]
extern fn rt_net_close(sock_fd: i64) -> i64
extern fn rt_string_from_byte_array(arr: [u8]) -> text
extern fn rt_string_to_byte_array(s: text) -> [u8]

# ============================================================================
# Constants
# ============================================================================

pub val DBD_PORT: i64 = 5433
val DBD_LOG_PATH: text = "/DBD.LOG"
val DBD_MAX_LINE_BYTES: i64 = 512     # bound on one journaled/replayed command line
val DBD_RECV_BOUND_BYTES: i64 = 4096  # bound on one socket read

# Decode helper mirroring sshd's decode_net_runtime_i32/fd (see sshd.spl):
# the direct baremetal net runtime returns ENCODE_INT(value) for successes.
fn _dbd_decode_i64(raw: i64) -> i64:
    if raw > 7:
        return raw >> 3
    raw

class DbdServer:
    """Freestanding-kernel wrapper around the real RedisServer engine."""
    engine: DbdEngine
    log_text: text          # exact durable journal bytes persisted so far
    backend_is_dbfs: bool

impl DbdServer:
    static fn new() -> DbdServer:
        DbdServer(engine: DbdEngine.new(), log_text: "", backend_is_dbfs: false)

    # ------------------------------------------------------------------
    # dbfs-engine backend probe (Lane C1 integration point)
    # ------------------------------------------------------------------

    me try_dbfs_backend() -> bool:
        """Return true iff a live DBFS engine handle is reachable for the
        mounted root today. Currently always false: Lane C1's DbFsDriver
        root-mount is in flight and does not yet expose a boot-reachable
        engine handle from this freestanding entry. Flip this to a real
        probe (route the durability journal through the DBFS engine's own
        persistence instead of the vfs-log journal below) once that lands —
        do not block on it until then.
        """
        false

    # ------------------------------------------------------------------
    # vfs-log backend: write-ahead journal of mutating commands, replayed
    # through the REAL RedisServer.dispatch() at startup.
    # ------------------------------------------------------------------

    me replay_log():
        """Load existing durable state at startup. Selects and logs the backend."""
        if self.try_dbfs_backend():
            self.backend_is_dbfs = true
            serial_println("[dbd] backend=dbfs-engine")
            return
        self.backend_is_dbfs = false
        if not g_vfs_file_exists(DBD_LOG_PATH):
            self.log_text = ""
            serial_println("[dbd] backend=vfs-log (no existing log)")
            return
        val bytes = g_vfs_read_file_bytes(DBD_LOG_PATH)
        self.log_text = rt_string_from_byte_array(bytes)
        # Replay every journaled mutation through the REAL engine (dbd_protocol
        # decodes each line and re-dispatches via RedisServer.dispatch()).
        val replayed = self.engine.replay_journal(self.log_text)
        serial_println("[dbd] backend=vfs-log replayed={replayed}")

    me persist_journal_line(line: text) -> bool:
        """Append one durable journal record. Fail-closed: only returns true
        when the full updated journal verifiably round-trips through the
        VFS write hub."""
        val updated = self.log_text + line + "\n"
        if not g_vfs_write_file_bytes(DBD_LOG_PATH, rt_string_to_byte_array(updated)):
            serial_println("[dbd] persist FAILED (write rejected) line={line}")
            return false
        val verify = g_vfs_read_file_bytes(DBD_LOG_PATH)
        if verify.len().to_i64() != rt_string_to_byte_array(updated).len().to_i64():
            serial_println("[dbd] persist FAILED (verify mismatch) line={line}")
            return false
        self.log_text = updated
        true

    # ------------------------------------------------------------------
    # Command handling — durability wraps the REAL dispatch(); it never
    # duplicates SET/GET/DEL semantics.
    # ------------------------------------------------------------------

    me handle_command(args: [text]) -> text:
        if args.len() == 0:
            return self.engine.dispatch(args)
        # Durability wraps the REAL dispatch(); mutation classification and
        # journal encoding live in dbd_protocol (spec-tested), not here.
        if not dbd_command_is_mutating(args[0]):
            return self.engine.dispatch(args)
        if self.backend_is_dbfs:
            # dbfs-engine path (Lane C1 integration point): not yet wired to
            # a live engine handle; fail closed rather than pretend to persist.
            return "-ERR dbfs backend unavailable\r\n"
        val journal_line = dbd_encode_journal_line(args)
        if journal_line == "" or journal_line.len() > DBD_MAX_LINE_BYTES:
            return "-ERR command too long to journal\r\n"
        if not self.persist_journal_line(journal_line):
            return "-ERR persist failed\r\n"
        self.engine.dispatch(args)

# ============================================================================
# Networking — mirrors sshd's raw rt_net_* accept/read/write idiom (and
# RedisServer.serve_connection()'s buffering: drain all complete commands
# per read, retain a trailing partial fragment), on dbd's OWN independent
# listener socket/port so it can round-robin alongside sshd's and http's
# listeners from a combined multi-service entry.
# ============================================================================

pub fn dbd_bind(port: i64) -> i64:
    """Create, bind, and listen on a dedicated TCP listener socket.

    Returns the listener fd (>= 0) on success, or a negative errno-ish code.
    """
    val sock_raw = rt_net_socket(1)
    val sock_fd = _dbd_decode_i64(sock_raw)
    if sock_fd < 0:
        return sock_fd
    val bind_rc = _dbd_decode_i64(rt_net_bind(sock_fd, port))
    if bind_rc < 0:
        return bind_rc
    val listen_rc = _dbd_decode_i64(rt_net_listen(sock_fd, 8))
    if listen_rc < 0:
        return listen_rc
    sock_fd

pub fn dbd_accept_and_handle_once(listen_fd: i64, server: DbdServer) -> bool:
    """Accept and fully handle a single pending dbd connection, if any.

    Bounded by DBD_RECV_BOUND_BYTES per read; malformed/oversized input
    (no complete RESP frame within the bound) is closed cleanly rather than
    hanging. Returns true iff a connection was processed.
    """
    val raw_client = rt_net_accept(listen_fd)
    val client_fd = _dbd_decode_i64(raw_client)
    if client_fd < 0:
        return false
    val received = rt_net_recv_bytes(client_fd, DBD_RECV_BOUND_BYTES)
    var buf = rt_string_from_byte_array(received)
    if buf.len() == 0:
        rt_net_close(client_fd)
        return true
    var progressed = true
    var handled_any = false
    while progressed:
        progressed = false
        match parse_next_request(buf):
            case Some(r):
                val reply = server.handle_command(r.args)
                rt_net_send_bytes(client_fd, rt_string_to_byte_array(reply))
                buf = r.rest
                progressed = true
                handled_any = true
            case nil:
                pass
    if not handled_any:
        # No complete RESP frame arrived within the bounded read: reject
        # cleanly (covers empty/garbage/oversized-without-terminator input).
        rt_net_send_bytes(client_fd, rt_string_to_byte_array("-ERR malformed or oversized request\r\n"))
    rt_net_close(client_fd)
    true
