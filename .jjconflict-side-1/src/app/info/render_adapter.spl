# Info Render Adapter
#
# Bridges the info app to the shared ui.render contract.
# Produces text (project info summary) and html (info dashboard with
# cards) views of project and system information.

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.fmt.{fmt_number, fmt_bytes}
use app.ui.render.html.{html_page, html_card, html_metric_card, html_grid,
    html_kv_table, html_escape, css_reset, css_dark_theme, css_light_theme}

# =========================================================================
# Data Types
# =========================================================================

class ProjectInfo:
    name: text
    version: text
    description: text
    language: text
    license: text
    repository: text
    homepage: text

class SystemInfo:
    os: text
    arch: text
    compiler_version: text
    memory_bytes: i64
    cpu_cores: i64

class BuildInfo:
    total_files: i64
    total_lines: i64
    total_modules: i64
    build_mode: text

class InfoRenderData:
    project: ProjectInfo
    system: SystemInfo
    build: BuildInfo
    dependencies: [(text, text)]

# =========================================================================
# Render Adapter Entry Point
# =========================================================================

fn render_info(config: RenderConfig, data: InfoRenderData) -> RenderResult:
    """Render project info via the shared render contract.

    Produces a summary for text output and a dashboard with cards
    for HTML output.
    """
    match config.format:
        "html":
            return render_as_html(data, config)
        "both":
            val text_out = render_as_text(data, config)
            val html_out = render_as_html(data, config)
            return RenderResult.both(text_out.text_output, html_out.html_output)
        _:
            return render_as_text(data, config)

# =========================================================================
# Text Rendering
# =========================================================================

fn render_as_text(data: InfoRenderData, config: RenderConfig) -> RenderResult:
    """Render project info as a plain text summary."""
    var lines: [text] = []

    lines.push("Project Information")
    lines.push("===================")
    lines.push("")

    # Project details
    lines.push("Project:")
    lines.push("  Name:        {data.project.name}")
    lines.push("  Version:     {data.project.version}")
    if data.project.description != "":
        lines.push("  Description: {data.project.description}")
    lines.push("  Language:    {data.project.language}")
    if data.project.license != "":
        lines.push("  License:     {data.project.license}")
    if data.project.repository != "":
        lines.push("  Repository:  {data.project.repository}")
    if data.project.homepage != "":
        lines.push("  Homepage:    {data.project.homepage}")

    # System info
    lines.push("")
    lines.push("System:")
    lines.push("  OS:              {data.system.os}")
    lines.push("  Architecture:    {data.system.arch}")
    lines.push("  Compiler:        {data.system.compiler_version}")
    lines.push("  Memory:          {fmt_bytes(data.system.memory_bytes)}")
    lines.push("  CPU Cores:       {data.system.cpu_cores}")

    # Build info
    lines.push("")
    lines.push("Build:")
    lines.push("  Files:   {fmt_number(data.build.total_files)}")
    lines.push("  Lines:   {fmt_number(data.build.total_lines)}")
    lines.push("  Modules: {fmt_number(data.build.total_modules)}")
    lines.push("  Mode:    {data.build.build_mode}")

    # Dependencies
    if data.dependencies.len() > 0:
        lines.push("")
        lines.push("Dependencies:")
        for dep in data.dependencies:
            val dep_name = dep.0
            val dep_ver = dep.1
            lines.push("  {dep_name} {dep_ver}")

    return RenderResult.text(join_lines(lines))

# =========================================================================
# HTML Rendering
# =========================================================================

fn render_as_html(data: InfoRenderData, config: RenderConfig) -> RenderResult:
    """Render project info as an HTML dashboard with cards."""
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    var css = ""
    css = "{css}{css_reset()}\n{theme_css}\n"
    css = "{css}.container { max-width: 1200px; margin: 0 auto; }\n"
    css = "{css}.card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }\n"
    css = "{css}.card h3 { margin-bottom: 8px; }\n"
    css = "{css}.card-body { color: var(--text-dim); font-size: 14px; }\n"
    css = "{css}.value { font-size: 28px; font-weight: bold; color: var(--blue); }\n"
    css = "{css}.sub { font-size: 13px; color: var(--text-dim); margin-top: 4px; }\n"
    css = "{css}table { border-collapse: collapse; width: 100%; }\n"
    css = "{css}th, td { border: 1px solid var(--border); padding: 8px; font-size: 13px; }\n"
    css = "{css}th { background: var(--bg-card); text-align: left; }\n"
    css = "{css}td:first-child { font-weight: 600; padding-right: 16px; }\n"

    var body = ""
    body = "{body}<div class=\"container\">\n"
    body = "{body}<h1>{html_escape(data.project.name)}</h1>\n"
    if data.project.description != "":
        body = "{body}<p style=\"color:var(--text-dim); margin-bottom:16px\">{html_escape(data.project.description)}</p>\n"

    # Top metric cards
    val metric_cards = [
        html_metric_card("Version", data.project.version, data.project.language),
        html_metric_card("Files", fmt_number(data.build.total_files), "{fmt_number(data.build.total_lines)} lines"),
        html_metric_card("Modules", fmt_number(data.build.total_modules), "{data.build.build_mode} mode"),
        html_metric_card("Memory", fmt_bytes(data.system.memory_bytes), "{data.system.cpu_cores} cores")
    ]
    body = "{body}{html_grid(4, \"12px\", metric_cards)}\n"

    # Project details card
    var project_pairs: [(text, text)] = []
    project_pairs.push(("Name", data.project.name))
    project_pairs.push(("Version", data.project.version))
    project_pairs.push(("Language", data.project.language))
    if data.project.license != "":
        project_pairs.push(("License", data.project.license))
    if data.project.repository != "":
        project_pairs.push(("Repository", data.project.repository))
    if data.project.homepage != "":
        project_pairs.push(("Homepage", data.project.homepage))

    body = "{body}<div style=\"margin-top:16px\">\n"
    body = "{body}{html_card(\"Project Details\", html_kv_table(project_pairs))}\n"
    body = "{body}</div>\n"

    # System info card
    val system_pairs: [(text, text)] = [
        ("OS", data.system.os),
        ("Architecture", data.system.arch),
        ("Compiler", data.system.compiler_version),
        ("Memory", fmt_bytes(data.system.memory_bytes)),
        ("CPU Cores", "{data.system.cpu_cores}")
    ]

    body = "{body}<div style=\"margin-top:12px\">\n"
    body = "{body}{html_card(\"System Information\", html_kv_table(system_pairs))}\n"
    body = "{body}</div>\n"

    # Build info card
    val build_pairs: [(text, text)] = [
        ("Total Files", fmt_number(data.build.total_files)),
        ("Total Lines", fmt_number(data.build.total_lines)),
        ("Modules", fmt_number(data.build.total_modules)),
        ("Build Mode", data.build.build_mode)
    ]

    body = "{body}<div style=\"margin-top:12px\">\n"
    body = "{body}{html_card(\"Build Information\", html_kv_table(build_pairs))}\n"
    body = "{body}</div>\n"

    # Dependencies card
    if data.dependencies.len() > 0:
        body = "{body}<div style=\"margin-top:12px\">\n"
        body = "{body}{html_card(\"Dependencies\", html_kv_table(data.dependencies))}\n"
        body = "{body}</div>\n"

    body = "{body}</div>\n"

    return RenderResult.html(html_page("Project Info", css, body))

# =========================================================================
# Helpers
# =========================================================================

fn join_lines(lines: [text]) -> text:
    var result = ""
    var first = true
    for line in lines:
        if not first:
            result = "{result}\n"
        result = "{result}{line}"
        first = false
    return result
