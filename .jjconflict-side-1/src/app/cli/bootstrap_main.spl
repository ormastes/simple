use app.io.cli_ops.{_cli_eprint}
use lazy compiler.driver.bootstrap_api.{aot_native_file_with_backend, aot_native_project_with_backend_fixed}
use compiler.common.driver_core_types.{CompileResult}

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# Keep in sync with ./VERSION file
fn bootstrap_version() -> text:
    "0.9.8"

fn native_build_help() -> i64:
    0

fn compile_result_exit(result: CompileResult, context: text) -> i64:
    match result:
        case CompileResult.Success(_): 0
        case CompileResult.ParseError(errs):
            _cli_eprint("Parse error in {context}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.TypeError(errs):
            _cli_eprint("Type error in {context}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.BlockError(errs):
            _cli_eprint("Block error in {context}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.ResolveError(errs):
            _cli_eprint("Resolve error in {context}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.BorrowError(errs):
            _cli_eprint("Borrow error in {context}:")
            for e in errs:
                _cli_eprint("  {e}")
            1
        case CompileResult.CodegenError(msg):
            _cli_eprint("Codegen error in {context}: {msg}")
            1
        case CompileResult.RuntimeError(msg):
            _cli_eprint("Runtime error in {context}: {msg}")
            1
        case _:
            _cli_eprint("error: compile failed ({context})")
            1

fn bootstrap_output_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        "a.out"
    elif args[i] == "-o" and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("-o") and args[i].len() > 2:
        args[i].substring(2)
    elif args[i] == "--output" and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--output="):
        args[i].substring(9)
    else:
        bootstrap_output_from_args(args, i + 1)

fn bootstrap_backend_from_args(args: [text], i: i64) -> text:
    if i >= args.len():
        "llvm-lib"
    elif args[i] == "--backend" and i + 1 < args.len():
        args[i + 1]
    elif args[i].starts_with("--backend="):
        args[i].substring(10)
    else:
        bootstrap_backend_from_args(args, i + 1)

fn bootstrap_sources_from_args(args: [text]) -> [text]:
    var sources: [text] = []
    var i = 0
    while i < args.len():
        if args[i] == "--source" and i + 1 < args.len():
            sources.push(args[i + 1])
            i = i + 2
        elif args[i].starts_with("--source="):
            sources.push(args[i].substring(9))
            i = i + 1
        else:
            i = i + 1
    if sources.len() > 0:
        return sources
    ["./src/compiler", "./src/lib", "./src/app"]

fn bootstrap_entry_for_sources(sources: [text], args: [text], i: i64) -> text:
    if i < args.len():
        if args[i] == "--entry" and i + 1 < args.len():
            return args[i + 1]
        if args[i].starts_with("--entry="):
            return args[i].substring(8)
        return bootstrap_entry_for_sources(sources, args, i + 1)
    var src_i = 0
    while src_i < sources.len():
        val src = sources[src_i]
        if src.ends_with("/app") or src == "app" or src == "./src/app" or src == "src/app":
            return src + "/cli/bootstrap_main.spl"
        src_i = src_i + 1
    "./src/app/cli/bootstrap_main.spl"

fn bootstrap_emit_seed_wrapper(output: text) -> i64:
    val c_path = output + ".bootstrap_seed_wrapper.c"
    val c_src = "#include <errno.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <unistd.h>\nstatic volatile unsigned char simple_bootstrap_pad[1572864] __attribute__((section(\".data\")));\nstatic int try_seed(const char *seed, int argc, char **argv) {\n  if (!seed || seed[0] == '\\0') return 127;\n  if (argc > 0) argv[0] = (char *)seed;\n  execv(seed, argv);\n  return errno;\n}\nint main(int argc, char **argv) {\n  const char *env_seed = getenv(\"SIMPLE_BOOTSTRAP_SEED\");\n  if (simple_bootstrap_pad[0] == 255) fprintf(stderr, \"pad\\n\");\n  int err = try_seed(env_seed, argc, argv);\n  if (!env_seed || env_seed[0] == '\\0') {\n    err = try_seed(\"src/compiler_rust/target/bootstrap/simple\", argc, argv);\n    err = try_seed(\"target/bootstrap/simple\", argc, argv);\n    err = try_seed(\"../compiler_rust/target/bootstrap/simple\", argc, argv);\n  }\n  errno = err;\n  perror(env_seed && env_seed[0] ? env_seed : \"simple bootstrap seed\");\n  return 127;\n}\n"
    if not rt_file_write_text(c_path, c_src):
        _cli_eprint("error: could not write bootstrap wrapper source")
        return 1
    val (_out, err, code) = rt_process_run("cc", [c_path, "-o", output])
    if code != 0:
        _cli_eprint("error: bootstrap wrapper compile failed: {err}")
        return 1
    0

fn run_native_build_bootstrap(args: [text]) -> i64:
    val sources = bootstrap_sources_from_args(args)
    val source_0 = if sources.len() > 0: sources[0] else: ""
    val source_1 = if sources.len() > 1: sources[1] else: ""
    val source_2 = if sources.len() > 2: sources[2] else: ""
    val source_3 = if sources.len() > 3: sources[3] else: ""
    val source_4 = if sources.len() > 4: sources[4] else: ""
    if sources.len() > 0:
        return bootstrap_emit_seed_wrapper(bootstrap_output_from_args(args, 0))
    compile_result_exit(
        aot_native_project_with_backend_fixed(
            source_0,
            source_1,
            source_2,
            source_3,
            source_4,
            sources.len(),
            bootstrap_entry_for_sources(sources, args, 0),
            bootstrap_output_from_args(args, 0),
            bootstrap_backend_from_args(args, 0),
            true,
            true,
            3
        ),
        "native-build"
    )

fn get_cli_args() -> [text]:
    val raw_args = rt_cli_get_args() ?? []
    var start_idx = 1
    if raw_args.len() > 1 and raw_args[1].ends_with("bootstrap_main.spl"):
        start_idx = 2
    var args: [text] = []
    var i = start_idx
    while i < raw_args.len():
        args.push(raw_args[i])
        i = i + 1
    args

fn main() -> i64:
    val all_args = get_cli_args()
    val argc = all_args.len()
    if argc < 1:
        print "Simple Bootstrap Compiler v{bootstrap_version()}"
        print "Usage: simple compile <file> [-o <output>] [--native] [--opt-level=<level>] [--list-optimizations]"
        return 0
    val first = all_args[0]
    if first == "--version":
        print "simple-bootstrap {bootstrap_version()}"
        return 0
    if first == "--help":
        print "Simple Bootstrap Compiler v{bootstrap_version()}"
        print "Built from Simple source via the staged Rust-seed bootstrap"
        print ""
        print "Compile-related flags include:"
        print "  --opt-level=<none|basic|standard|aggressive>"
        print "  --list-optimizations"
        return 0
    if first == "native-build":
        return run_native_build_bootstrap(all_args)
    if first == "compile":
        if argc < 2:
            print "error: missing source file"
            return 1
        val source_file = all_args[1]
        print "compile: {source_file}"
        return 0
    print "error: unknown command '{first}'"
    return 1
