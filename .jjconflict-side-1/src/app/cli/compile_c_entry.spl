# C Backend Compile Entry Point
#
# Compiles a Simple source file to C++20 using the MIR C backend.
# Used as Path 1 in compile_c_backend (interpreter mode entry point).
#
# Usage: simple compile_c_entry.spl <source.spl> <output.cpp>

use compiler.driver.driver.{aot_c_file}
use compiler.driver.driver_types.{CompileResult}

extern fn sys_get_args() -> [text]

fn normalize_compile_c_args(raw_args: [text]) -> [text]:
    var all_args: [text] = []
    if raw_args != nil:
        all_args = raw_args

    var start = 0
    var found_entry = false
    var i = 0
    while i < all_args.len():
        if all_args[i].ends_with("compile_c_entry.spl"):
            start = i + 1
            found_entry = true
            break
        i = i + 1

    if not found_entry and all_args.len() >= 3:
        start = 1

    var args: [text] = []
    i = start
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn main() -> i64:
    val args = normalize_compile_c_args(sys_get_args())
    if args.len() < 2:
        print "Usage: simple compile_c_entry.spl <source.spl> <output.cpp>"
        return 1

    val source = args[0]
    val output = args[1]

    val result = aot_c_file(source, output)
    match result:
        case CompileResult.Success(_):
            print "Output: {output}"
            return 0
        case _:
            val errors = result.get_errors()
            for err in errors:
                print "error: {err}"
            return 1
