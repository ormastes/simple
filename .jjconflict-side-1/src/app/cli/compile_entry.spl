# Lightweight compile entry point for `simple compile`
#
# This file loads only the minimal imports needed to compile,
# avoiding the overhead of loading the full CLI with all its modules
# (build system, type checker, stats, etc.).
#
# Usage:
#   bin/simple run src/app/cli/compile_entry.spl compile [options] <source.spl>
#
# Performance:
#   Full CLI (main.spl): ~460ms overhead
#   This entry (compile_entry.spl): ~220ms overhead

use app.io.cli_ops (cli_get_args)
use app.io.cli_compile (cli_compile)

fn normalize_compile_args(raw_args: [text]) -> [text]:
    var all_args: [text] = []
    if raw_args != nil:
        all_args = raw_args

    # Accept both `simple compile ...` and `simple run compile_entry.spl compile ...`.
    var start = 0
    var scan = 0
    while scan < all_args.len():
        val arg = all_args[scan]
        if arg.ends_with("compile_entry.spl"):
            start = scan + 1
            break
        elif arg == "compile":
            start = scan
            break
        scan = scan + 1

    var compile_args: [text] = []
    var i = start
    while i < all_args.len():
        compile_args.push(all_args[i])
        i = i + 1

    compile_args

fn main() -> i64:
    val compile_args = normalize_compile_args(cli_get_args())
    cli_compile(compile_args)
