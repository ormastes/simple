# Trait Desugar Pass
#
# Source-level text transformation that rewrites trait declarations
# into struct-with-fn-fields before parsing.
#
# Transformations:
#   trait Name:            -> struct Name:
#   fn method(p: T) -> R  -> method_fn: fn(T) -> R
#   me method(p: T)       -> method_fn: fn(T)
#   impl TraitName for X: -> fn X_as_TraitName() -> TraitName:

fn desugar_traits(source: text) -> text:
    """Transform trait declarations into struct-with-fn-fields.

    This is a source-level text rewrite pass. It processes line-by-line,
    converting trait syntax into struct syntax that the parser understands.
    """
    var result = ""
    var in_trait = false
    var lines = source.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()
        if trimmed.starts_with("trait ") and trimmed.ends_with(":"):
            # Convert trait header to struct header
            val name_part = trimmed.substring(6, trimmed.len())
            result = result + line.replace("trait ", "struct ") + "\n"
            in_trait = true
        elif in_trait and trimmed == "":
            # Empty line ends trait block
            in_trait = false
            result = result + line + "\n"
        elif in_trait and (trimmed.starts_with("fn ") or trimmed.starts_with("me ")):
            # Convert method to fn-field
            val indent = _get_indent(line)
            val field = _method_to_fn_field(trimmed)
            result = result + indent + field + "\n"
        else:
            if in_trait and not trimmed.starts_with("#") and not trimmed.starts_with("\"\"\"") and trimmed.len() > 0:
                val first_char = trimmed.substring(0, 1)
                if first_char != " " and first_char != "\t":
                    in_trait = false
            result = result + line + "\n"
        i = i + 1
    # Remove trailing newline added by loop
    if result.ends_with("\n"):
        result = result.substring(0, result.len() - 1)
    return result

fn _get_indent(line: text) -> text:
    """Extract leading whitespace from a line."""
    var indent = ""
    var i = 0
    while i < line.len():
        val ch = line.substring(i, i + 1)
        if ch == " " or ch == "\t":
            indent = indent + ch
        else:
            return indent
        i = i + 1
    return indent

fn _method_to_fn_field(trimmed: text) -> text:
    """Convert a method signature to a fn-field declaration.

    Input:  fn method(p: T) -> R
    Output: method_fn: fn(T) -> R

    Input:  me method(p: T)
    Output: method_fn: fn(T)
    """
    var sig = trimmed
    # Strip leading fn/me keyword
    if sig.starts_with("fn "):
        sig = sig.substring(3, sig.len())
    elif sig.starts_with("me "):
        sig = sig.substring(3, sig.len())

    # Extract method name (everything before '(')
    val paren_idx = sig.index_of("(")
    if val idx = paren_idx:
        val method_name = sig.substring(0, idx)
        val rest = sig.substring(idx, sig.len())

        # Extract params and return type
        val close_paren = rest.index_of(")")
        if val cp = close_paren:
            val params_str = rest.substring(1, cp)
            val after_paren = rest.substring(cp + 1, rest.len()).trim()

            # Extract just the types from params (strip names)
            val types_str = _extract_param_types(params_str)

            var field_type = "fn({types_str})"
            if after_paren.starts_with("-> "):
                val ret_type = after_paren.substring(3, after_paren.len())
                # Strip trailing colon if present
                var clean_ret = ret_type.trim()
                if clean_ret.ends_with(":"):
                    clean_ret = clean_ret.substring(0, clean_ret.len() - 1).trim()
                field_type = "fn({types_str}) -> {clean_ret}"

            return "{method_name}_fn: {field_type}"
    # Fallback: return as-is if parsing fails
    return sig

fn _extract_param_types(params_str: text) -> text:
    """Extract just the types from a parameter list.

    Input:  'id: text, count: i64'
    Output: 'text, i64'
    """
    if params_str.trim().len() == 0:
        return ""
    val params = params_str.split(",")
    var types = []
    var i = 0
    while i < params.len():
        val param = params[i].trim()
        val colon_idx = param.index_of(":")
        if val ci = colon_idx:
            val type_part = param.substring(ci + 1, param.len()).trim()
            types = types.push(type_part)
        else:
            # No colon — treat whole thing as a type
            types = types.push(param)
        i = i + 1
    return types.join(", ")
