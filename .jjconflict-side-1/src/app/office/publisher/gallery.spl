# Publisher-style Built-in Template Gallery
#
# A small gallery of ready-made publication templates (Publisher's template
# picker), composed entirely from the already-landed page_layout + columns
# primitives. No new storage or flow logic is introduced here — each
# template is just a particular arrangement of frames, filled via
# page_flow_text / flow_into_columns.
#
# Composition notes (frame counts, hand-verified by running the spec):
#   - "flyer": a title frame + a body frame on a plain page_new(612, 792).
#     2 frames total.
#   - "newsletter": built as a page_with_columns(612, 792, 2, ...) page (2
#     column frames: "col0", "col1"), with a title frame ("title") added on
#     top via page_add_frame. page_layout has no z-order/overlap concept —
#     frames are just absolutely-positioned divs — so the title banner and
#     the column region are placed to not overlap (title near the top
#     margin, columns filling the rest). 3 frames total.
#   - "brochure": same idea as newsletter but with page_with_columns(...,
#     3, ...) (3 column frames: "col0".."col2") plus a title frame. 4
#     frames total.
#   - unknown name: fail-soft — a plain page_new(612, 792) with only the
#     title frame filled in. 1 frame total.

use app.office.publisher.page_layout.{Page, page_new, frame_new, page_add_frame, page_flow_text, page_render_html}
use app.office.publisher.columns.{page_with_columns, flow_into_columns}

# =========================================================================
# Gallery listing
# =========================================================================

fn gallery_names() -> [text]:
    """Names of the built-in publication templates, in gallery order."""
    return ["flyer", "newsletter", "brochure"]

fn template_summary(name: text) -> text:
    """One-line preview description for a gallery entry."""
    if name == "flyer":
        return "flyer: title banner + single body frame"
    elif name == "newsletter":
        return "newsletter: title banner + 2 columns"
    elif name == "brochure":
        return "brochure: title banner + 3 columns"
    else:
        return "unknown template: title only"

# =========================================================================
# Individual template builders
# =========================================================================

fn _build_flyer(title: text, body: text) -> Page:
    """Letter page (612x792): a large title frame at top, one big body
    frame below it. Title and body are independent frames (no next_id
    chain between them), each filled directly via page_flow_text."""
    var page = page_new(612, 792)
    val title_frame = frame_new("title", 36, 36, 540, 80, "")
    page = page_add_frame(page, title_frame)
    val body_frame = frame_new("body", 36, 140, 540, 600, "")
    page = page_add_frame(page, body_frame)
    page = page_flow_text(page, "title", title)
    page = page_flow_text(page, "body", body)
    return page

fn _build_newsletter(title: text, body: text) -> Page:
    """A page_with_columns(612, 792, 2, ...) page (col0, col1) with `body`
    flowed across the columns, plus a distinct "title" frame added on top
    for the banner."""
    var page = page_with_columns(612, 792, 2, 20, 40)
    page = flow_into_columns(page, body)
    val title_frame = frame_new("title", 40, 10, 532, 24, "")
    page = page_add_frame(page, title_frame)
    page = page_flow_text(page, "title", title)
    return page

fn _build_brochure(title: text, body: text) -> Page:
    """A landscape page_with_columns(792, 612, 3, ...) page (col0..col2)
    with `body` flowed across the 3 columns, plus a distinct "title"
    frame added on top for the banner."""
    var page = page_with_columns(792, 612, 3, 20, 40)
    page = flow_into_columns(page, body)
    val title_frame = frame_new("title", 40, 10, 712, 24, "")
    page = page_add_frame(page, title_frame)
    page = page_flow_text(page, "title", title)
    return page

fn _build_unknown(title: text) -> Page:
    """Fail-soft fallback: a single empty page_new(612, 792) with just the
    title frame filled in."""
    var page = page_new(612, 792)
    val title_frame = frame_new("title", 36, 36, 540, 80, "")
    page = page_add_frame(page, title_frame)
    page = page_flow_text(page, "title", title)
    return page

# =========================================================================
# Public entry points
# =========================================================================

fn build_template(name: text, title: text, body: text) -> Page:
    """Build a ready-made Page for the named built-in template, filling
    the title frame with `title` and flowing `body` per the template's
    layout. Unknown names fail soft to a title-only page."""
    if name == "flyer":
        return _build_flyer(title, body)
    elif name == "newsletter":
        return _build_newsletter(title, body)
    elif name == "brochure":
        return _build_brochure(title, body)
    else:
        return _build_unknown(title)

fn gallery_render_html(name: text, title: text, body: text) -> text:
    """Build the named template and render it as one self-contained HTML
    string. Column templates are still plain Pages under the hood, so
    page_render_html covers every template."""
    val page = build_template(name, title, body)
    return page_render_html(page)
