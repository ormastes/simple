# LibreOffice Math — equation editor (MathML renderer)
#
# Renders a simple math expression to MathML for display. A flat expression
# (identifiers, numbers, operators) renders to a sequence of <mi>/<mn>/<mo>
# elements; structured forms (superscript, square root) are produced by the
# `math_superscript` / `math_sqrt` helpers. Token processing uses for-in
# iteration (not `.get(index)`) to avoid the array-element corruption.

fn _is_digit(c: text) -> bool:
    (c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or
     c == "5" or c == "6" or c == "7" or c == "8" or c == "9")

fn _is_alpha(c: text) -> bool:
    val code = c.char_code_at(0)
    val is_upper = code >= 65 and code <= 90
    val is_lower = code >= 97 and code <= 122
    is_upper or is_lower

fn _tokenize_math(expr: text) -> [text]:
    """Split a math expression into number / identifier / operator tokens."""
    var tokens: [text] = []
    var i = 0
    val len = expr.len()
    while i < len:
        val c = expr.char_at(i)
        if c == " " or c == "\t":
            i = i + 1
            continue
        if _is_digit(c):
            var num = ""
            while i < len:
                val ch = expr.char_at(i)
                if _is_digit(ch) or ch == ".":
                    num = "{num}{ch}"
                    i = i + 1
                else:
                    break
            tokens.push(num)
            continue
        if _is_alpha(c):
            var word = ""
            while i < len:
                val ch = expr.char_at(i)
                if _is_alpha(ch) or _is_digit(ch):
                    word = "{word}{ch}"
                    i = i + 1
                else:
                    break
            tokens.push(word)
            continue
        # single-character operator / punctuation
        tokens.push(c)
        i = i + 1
    tokens

fn _token_to_mathml(token: text) -> text:
    """Render one token as its MathML element."""
    if token.len() == 0:
        return ""
    val first = token.char_at(0)
    if _is_digit(first):
        return "<mn>{token}</mn>"
    if _is_alpha(first):
        return "<mi>{token}</mi>"
    "<mo>{token}</mo>"

fn math_to_mathml(expr: text) -> text:
    """Render a flat math expression to a MathML document."""
    var body = ""
    for token in _tokenize_math(expr):
        body = "{body}{_token_to_mathml(token)}"
    "<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mrow>{body}</mrow></math>"

fn math_superscript(base: text, exp: text) -> text:
    """A MathML superscript (e.g. x squared): base^exp."""
    "<msup><mi>{base}</mi><mn>{exp}</mn></msup>"

fn math_sqrt(inner: text) -> text:
    """A MathML square root of an identifier or number."""
    "<msqrt><mi>{inner}</mi></msqrt>"
