# Interactive Sheet Editor
#
# A live editing session for Calc: load a sheet (csv/ods/xlsx), then edit it
# interactively — set cells, evaluate formulas, view the grid, save to any
# supported container — driven by stdin lines so it works both at a terminal
# and scripted (`printf 'set A1 5\nsave out.csv\nquit\n' | simple office
# edit-sheet in.csv`). The command core is a pure function over (Sheet, line)
# so the editing surface is unit-testable without a terminal.
#
# ponytail: line-based editor, not a TUI grid; the widget-tree SheetsApp is
# the eventual full-screen surface.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text, CellRef, cell_ref_to_string, parse_cell_ref, col_to_letter}
use app.office.file_formats.{parse_csv_sheet, sheet_to_csv, recalculate_formula_cells}
use app.office.odf_ooxml.{ods_bytes_to_sheet, xlsx_bytes_to_sheet, sheet_to_ods_bytes, sheet_to_xlsx_bytes}
use app.office.odf_export.{sheet_to_fods}
use std.io_runtime.{write_file, read_file, file_exists}
use std.nogc_sync_mut.sffi.io.{file_read_bytes, file_write_bytes}
use std.common.string_core.{char_from_code}
use app.office.gui.{SheetGuiSession, SheetGuiView, session_new, sheet_gui_view_with_selection, office_gui_sheet_session_pixels, office_gui_non_background_pixel_count, office_gui_frame_width, office_gui_frame_height, run_gui_live_step, SlideGuiSession, SlideGuiView, slide_session_new, slide_session_view, slide_gui_step, office_gui_slide_pixels}
use app.office.slides.slide.{Slide}

extern fn rt_stdin_read_line() -> text

struct EditorStep:
    sheet: Sheet
    reply: text
    quit: bool

fn _step(sheet: Sheet, reply: text, quit: bool) -> EditorStep:
    EditorStep(sheet: sheet, reply: reply, quit: quit)

fn sheet_grid_text(sheet: Sheet) -> text:
    """The used range as an aligned ASCII grid with column letters and row
    numbers — the terminal 'view' of the spreadsheet."""
    val range_str = sheet.used_range()
    val parts = range_str.split(":")
    val start = parse_cell_ref(parts[0])
    val end_ref = parse_cell_ref(parts[1])
    if start == nil or end_ref == nil:
        return "(empty sheet)"
    # column widths
    var widths: [i32] = []
    var c = start.col
    while c <= end_ref.col:
        var w = 3
        var r = start.row
        while r <= end_ref.row:
            val ref_str = cell_ref_to_string(CellRef(col: c, row: r))
            val d = cell_display_text(sheet.get_cell(ref_str))
            if d.len() > w:
                w = d.len()
            r = r + 1
        widths.push(w)
        c = c + 1
    var out = "    "
    var ci = 0
    c = start.col
    while c <= end_ref.col:
        out = "{out}{_pad(col_to_letter(c), widths[ci] + 2)}"
        ci = ci + 1
        c = c + 1
    var r = start.row
    while r <= end_ref.row:
        out = "{out}\n{_pad("{r + 1}", 4)}"
        ci = 0
        c = start.col
        while c <= end_ref.col:
            val ref_str = cell_ref_to_string(CellRef(col: c, row: r))
            out = "{out}{_pad(cell_display_text(sheet.get_cell(ref_str)), widths[ci] + 2)}"
            ci = ci + 1
            c = c + 1
        r = r + 1
    out

fn _pad(s: text, w: i32) -> text:
    var out = s
    while out.len() < w:
        out = "{out} "
    out

fn editor_load_sheet(path: text) -> Sheet:
    """Load csv/.ods/.xlsx by extension; missing file yields an empty sheet."""
    if not file_exists(path):
        return Sheet.new(path)
    if path.ends_with(".ods"):
        val b = file_read_bytes(path)
        if b != nil:
            return ods_bytes_to_sheet(b, path)
        return Sheet.new(path)
    if path.ends_with(".xlsx"):
        val b = file_read_bytes(path)
        if b != nil:
            return xlsx_bytes_to_sheet(b, path)
        return Sheet.new(path)
    parse_csv_sheet(read_file(path), path)

fn editor_save_sheet(sheet: Sheet, path: text) -> bool:
    """Save to csv/.fods/.ods/.xlsx by extension."""
    if path.ends_with(".ods"):
        return file_write_bytes(path, sheet_to_ods_bytes(sheet))
    if path.ends_with(".xlsx"):
        return file_write_bytes(path, sheet_to_xlsx_bytes(sheet))
    if path.ends_with(".fods"):
        return write_file(path, sheet_to_fods(sheet))
    write_file(path, sheet_to_csv(sheet))

fn editor_apply(sheet: Sheet, line: text) -> EditorStep:
    """Apply one editor command. Pure over (sheet, line) — the whole editing
    surface, testable without a terminal.

    Commands: set <ref> <value> | get <ref> | del <ref> | show |
              save <path> | help | quit"""
    val trimmed = line.trim()
    if trimmed == "" or trimmed == "quit" or trimmed == "exit":
        return _step(sheet, "bye", true)
    val parts = trimmed.split(" ")
    val cmd = parts[0].lower()
    if cmd == "help":
        return _step(sheet, "commands: set <ref> <value> | get <ref> | del <ref> | show | save <path> | quit", false)
    if cmd == "show":
        return _step(sheet, sheet_grid_text(sheet), false)
    if cmd == "get" and parts.len() >= 2:
        val ref_str = parts[1].upper()
        if parse_cell_ref(ref_str) == nil:
            return _step(sheet, "error: invalid ref {parts[1]}", false)
        return _step(sheet, "{ref_str} = {cell_display_text(sheet.get_cell(ref_str))}", false)
    if cmd == "del" and parts.len() >= 2:
        var sh = sheet
        sh.set_value(parts[1].upper(), "")
        sh = recalculate_formula_cells(sh)
        return _step(sh, "deleted {parts[1].upper()}", false)
    if cmd == "set" and parts.len() >= 3:
        val ref_str = parts[1].upper()
        if parse_cell_ref(ref_str) == nil:
            return _step(sheet, "error: invalid ref {parts[1]}", false)
        val value = parts[2:].join(" ")
        var sh = sheet
        sh.set_value(ref_str, value)
        sh = recalculate_formula_cells(sh)
        return _step(sh, "{ref_str} = {cell_display_text(sh.get_cell(ref_str))}", false)
    if cmd == "save" and parts.len() >= 2:
        if editor_save_sheet(sheet, parts[1]):
            return _step(sheet, "saved {parts[1]}", false)
        return _step(sheet, "error: could not save {parts[1]}", false)
    _step(sheet, "error: unknown command (try 'help')", false)

fn sheet_screen_frame(sheet: Sheet, file_label: text, status: text) -> text:
    """A full-screen ANSI frame: clear+home, inverse-video title bar, the grid,
    and a status bar — redrawn after every command in screen mode."""
    val esc = char_from_code(27)
    val clear = "{esc}[2J{esc}[H"
    val title = "{esc}[7m Simple Calc — {file_label} {esc}[0m"
    val bar = "{esc}[7m {status} {esc}[0m"
    "{clear}{title}\n\n{sheet_grid_text(sheet)}\n\n{bar}\ncalc> "

fn run_sheet_editor_mode(in_path: text, screen: bool) -> i32:
    """The interactive loop: draw, read a line, apply, repeat. In screen mode
    the whole terminal frame is redrawn after every command."""
    var sheet = editor_load_sheet(in_path)
    if screen:
        print sheet_screen_frame(sheet, in_path, "Ready — 'help' for commands")
    else:
        print "Simple Calc — editing {in_path} (type 'help' for commands)"
    var quit = false
    while not quit:
        val line = rt_stdin_read_line() ?? ""
        val step = editor_apply(sheet, line)
        sheet = step.sheet
        quit = step.quit
        if quit:
            print step.reply
        elif screen:
            print sheet_screen_frame(sheet, in_path, step.reply)
        else:
            print step.reply
    0

fn run_sheet_editor(in_path: text) -> i32:
    run_sheet_editor_mode(in_path, false)

# =========================================================================
# Keystroke-level TUI (raw mode, arrow keys, live cell editing)
# =========================================================================

struct TuiState:
    sheet: Sheet
    cur: CellRef
    buffer: text
    status: text
    pending_esc: i32   # 0 none, 1 got ESC, 2 got ESC [
    quit: bool
    dirty: bool

fn tui_new_state(sheet: Sheet) -> TuiState:
    TuiState(sheet: sheet, cur: CellRef(col: 0, row: 0), buffer: "", status: "arrows move - type to edit - Enter commits - s saves - q quits", pending_esc: 0, quit: false, dirty: false)

fn _tui_move(state: TuiState, d_col: i32, d_row: i32) -> TuiState:
    var s = state
    var c = s.cur.col + d_col
    var r = s.cur.row + d_row
    if c < 0:
        c = 0
    if r < 0:
        r = 0
    s.cur = CellRef(col: c, row: r)
    s.pending_esc = 0
    s

struct KeyDecodeResult:
    key: text        # "" = no complete key yet (mid ESC-sequence, or an
                      # unrecognized control byte); otherwise one of
                      # "eof"/"up"/"down"/"left"/"right"/"enter"/
                      # "backspace"/"escape", or a single printable character
    pending_esc: i32

fn decode_key_byte(pending_esc: i32, byte: i64) -> KeyDecodeResult:
    """Shared raw-termios-byte decoder: turns one byte (as read one at a time
    from rt_stdin_read_byte, under rt_terminal_enable_raw_mode) into a
    canonical key name, threading `pending_esc` across calls the same way
    tui_apply_key's own inline state machine used to (0 = no escape pending,
    1 = got ESC, 2 = got ESC [, waiting for the arrow letter). This is the
    ONE arrow-escape-sequence decoder shared by run_sheet_tui_mode's
    tui_apply_key (below) and gui.spl's run_sheet_gui_live live loop
    (interactive.spl) — extracted so the live sheet-GUI loop reuses the
    exact same ESC [ A/B/C/D handling instead of a second, drifting copy.

    A lone ESC not followed by "[" resolves to "escape" (tui_apply_key below
    treats that as a no-op, matching its pre-extraction behavior exactly;
    the live loop maps it to session_key's "escape" — cancel the pending
    typed buffer). An unrecognized byte after ESC [ resolves to "" (no key),
    same as the pre-extraction fallthrough."""
    if byte < 0:
        return KeyDecodeResult(key: "eof", pending_esc: 0)
    if pending_esc == 1:
        if byte == 91:
            return KeyDecodeResult(key: "", pending_esc: 2)
        return KeyDecodeResult(key: "escape", pending_esc: 0)
    if pending_esc == 2:
        if byte == 65:
            return KeyDecodeResult(key: "up", pending_esc: 0)
        if byte == 66:
            return KeyDecodeResult(key: "down", pending_esc: 0)
        if byte == 67:
            return KeyDecodeResult(key: "right", pending_esc: 0)
        if byte == 68:
            return KeyDecodeResult(key: "left", pending_esc: 0)
        return KeyDecodeResult(key: "", pending_esc: 0)
    if byte == 27:
        return KeyDecodeResult(key: "", pending_esc: 1)
    if byte == 10 or byte == 13:
        return KeyDecodeResult(key: "enter", pending_esc: 0)
    if byte == 127 or byte == 8:
        return KeyDecodeResult(key: "backspace", pending_esc: 0)
    if byte >= 32 and byte <= 126:
        return KeyDecodeResult(key: char_from_code(byte), pending_esc: 0)
    KeyDecodeResult(key: "", pending_esc: pending_esc)

fn tui_apply_key(state: TuiState, byte: i64) -> TuiState:
    """Apply one input byte to the editor state. Pure — the whole keystroke
    surface, spec-testable without a terminal. Arrow keys arrive as
    ESC [ A/B/C/D (decoded by the shared decode_key_byte above); printable
    bytes build the cell buffer; Enter commits (formulas recalculate);
    backspace edits; q quits; s marks save. A lone Escape (decode_key_byte's
    "escape") has no action here, same as before this function was rebuilt
    on top of the shared decoder — the TUI has no cancel-buffer key today,
    unlike the GUI live loop's session_key("escape")."""
    var s = state
    s.dirty = false
    val decoded = decode_key_byte(s.pending_esc, byte)
    s.pending_esc = decoded.pending_esc
    val key = decoded.key
    if key == "eof":
        s.quit = true
        return s
    if key == "up":
        return _tui_move(s, 0, -1)
    if key == "down":
        return _tui_move(s, 0, 1)
    if key == "right":
        return _tui_move(s, 1, 0)
    if key == "left":
        return _tui_move(s, -1, 0)
    if key == "enter":
        # Commit the buffer to the active cell and move down
        if s.buffer != "":
            var sh = s.sheet
            sh.set_value(cell_ref_to_string(s.cur), s.buffer)
            sh = recalculate_formula_cells(sh)
            s.sheet = sh
            s.status = "{cell_ref_to_string(s.cur)} = {cell_display_text(sh.get_cell(cell_ref_to_string(s.cur)))}"
            s.buffer = ""
        return _tui_move(s, 0, 1)
    if key == "backspace":
        if s.buffer.len() > 0:
            s.buffer = s.buffer.slice(0, s.buffer.len() - 1)
        return s
    if key == "escape" or key == "":
        return s
    if s.buffer == "" and key == "q":
        s.quit = true
        return s
    if s.buffer == "" and key == "s":
        s.dirty = true
        s.status = "saved"
        return s
    s.buffer = "{s.buffer}{key}"
    s

fn tui_frame(state: TuiState, file_label: text) -> text:
    """The full-screen frame: title bar, grid with the active cell shown in
    the formula bar, input buffer, and status bar."""
    val esc = char_from_code(27)
    val ref_str = cell_ref_to_string(state.cur)
    val current = cell_display_text(state.sheet.get_cell(ref_str))
    val shown = if state.buffer != "": state.buffer else: current
    val title = "{esc}[7m Simple Calc — {file_label} {esc}[0m"
    val formula_bar = "[{ref_str}] {shown}"
    val bar = "{esc}[7m {state.status} {esc}[0m"
    "{esc}[2J{esc}[H{title}\n{formula_bar}\n\n{sheet_grid_text(state.sheet)}\n\n{bar}"

# Raw-mode keystroke loop. rt_stdin_read_byte DOES resolve when called from
# an imported module (proven via a probe entry+module pair piping bytes
# through a same-shaped import); the earlier "module extern registry" claim
# was stale. The real gap was that rt_terminal_enable_raw_mode /
# rt_terminal_disable_raw_mode were no-op stubs in the Rust runtime (returned
# true without calling tcgetattr/tcsetattr), so the terminal never actually
# left canonical/echo mode. Fixed in
# src/compiler_rust/runtime/src/value/sffi/env_process.rs — see
# doc/08_tracking/bug/raw_mode_extern_registry_2026-07-03.md.
extern fn rt_stdin_read_byte() -> i64
extern fn rt_terminal_enable_raw_mode() -> bool
extern fn rt_terminal_disable_raw_mode() -> bool

fn run_sheet_tui_mode(in_path: text) -> i32:
    """Keystroke-driven full-screen editing: real termios raw mode, one byte
    at a time through the pure tui_apply_key state machine. Arrow keys arrive
    as ESC [ A/B/C/D, Enter commits with live recalculation, s saves, q
    quits. Always restores the terminal (disable_raw_mode) before returning,
    including on quit via 'q' or EOF (byte < 0)."""
    var state = tui_new_state(editor_load_sheet(in_path))
    rt_terminal_enable_raw_mode()
    print tui_frame(state, in_path)
    while not state.quit:
        val b = rt_stdin_read_byte()
        state = tui_apply_key(state, b)
        if state.dirty:
            editor_save_sheet(state.sheet, in_path)
        if not state.quit and state.pending_esc == 0:
            print tui_frame(state, in_path)
    rt_terminal_disable_raw_mode()
    print "bye"
    0

# =========================================================================
# Live sheet-GUI keystroke loop (closes doc/08_tracking/bug/
# office_gui_no_per_cell_click_target_2026-07-04.md's residual #4 for
# TERMINAL input): the same real termios raw-mode byte loop as
# run_sheet_tui_mode above, bridged into gui.spl's SheetGuiSession/
# session_key instead of TuiState -- a live interactive GUI-session loop
# driven by real keystrokes, one frame re-rendered through the REAL
# office_gui_sheet_session_pixels pixel path per input. Reuses
# decode_key_byte (the exact same ESC [ A/B/C/D arrow decoder
# run_sheet_tui_mode's tui_apply_key uses above) and the same
# rt_stdin_read_byte/rt_terminal_enable_raw_mode/rt_terminal_disable_raw_mode
# externs declared above -- zero duplicated termios plumbing.
# =========================================================================

val GUI_LIVE_MAX_ROWS: i32 = 5
val GUI_LIVE_MAX_COLS: i32 = 4

fn _gui_live_frame(view: SheetGuiView, selected_ref: text) -> text:
    """One live-loop frame: an ANSI clear+home (mirrors run_sheet_tui_mode's
    tui_frame, which clears/homes before every redraw) followed by the SAME
    pixel-path proof line every other sheet-gui-* CLI command prints
    (office_gui_sheet_session_pixels + office_gui_non_background_pixel_count
    -- a real render through the browser-engine pixel path, not a stub) and
    the session's text_dump, one "sheet-gui-live: <line>" per row (including
    the leading "viewport|..." marker sheet_gui_view_with_selection always
    emits first)."""
    val esc = char_from_code(27)
    val clear = "{esc}[2J{esc}[H"
    val pixels = office_gui_sheet_session_pixels(view, selected_ref)
    val non_background = office_gui_non_background_pixel_count(pixels)
    var out = "{clear}sheet-gui-live: frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels\n"
    for line in view.text_dump.split("\n"):
        out = "{out}sheet-gui-live: {line}\n"
    out

fn run_sheet_gui_live(sheet: Sheet) -> i32:
    """Live keystroke-driven sheet-GUI session: renders the current
    SheetGuiSession through the real pixel path, reads one raw termios byte,
    decodes it with decode_key_byte, and maps the result through gui.spl's
    run_gui_live_step (SheetGuiSession's session_key, plus a quit signal) --
    re-rendering after every accepted key. 'q' or Ctrl-C (byte 3) quits;
    Enter commits the pending typed buffer (formulas recalculate); arrow
    keys move the selection; Escape cancels an in-progress buffer.

    Non-TTY safety: rt_terminal_enable_raw_mode() returns false when stdin
    isn't a real terminal (tcgetattr fails on a pipe/redirect — the same
    signal this codebase already relies on, not a new TTY-detection extern)
    — in that case this prints exactly ONE rendered frame plus a documented
    non-TTY notice and returns 0 immediately, instead of blocking forever on
    a keystroke that will never arrive (so CI/non-interactive callers can
    still exercise this entry point)."""
    var session = session_new(sheet, "A1")
    val first_view = sheet_gui_view_with_selection(session, GUI_LIVE_MAX_ROWS, GUI_LIVE_MAX_COLS)
    print _gui_live_frame(first_view, session.selected_ref)

    if not rt_terminal_enable_raw_mode():
        print "sheet-gui-live: stdin is not a TTY (non-interactive input) -- printed one rendered frame above and exiting instead of blocking on a keystroke that will never arrive. Run 'simple office sheet-gui-live' from a real terminal for the live keystroke loop."
        return 0

    var quit = false
    var pending_esc = 0
    while not quit:
        val b = rt_stdin_read_byte()
        var key = ""
        if b == 3:
            key = "ctrl_c"
        else:
            val decoded = decode_key_byte(pending_esc, b)
            pending_esc = decoded.pending_esc
            key = decoded.key
        if key != "":
            val step = run_gui_live_step(session, key, GUI_LIVE_MAX_ROWS, GUI_LIVE_MAX_COLS, GUI_LIVE_MAX_ROWS, GUI_LIVE_MAX_COLS)
            session = step.session
            quit = step.quit
            if not quit:
                val view = sheet_gui_view_with_selection(session, GUI_LIVE_MAX_ROWS, GUI_LIVE_MAX_COLS)
                print _gui_live_frame(view, session.selected_ref)
    rt_terminal_disable_raw_mode()
    print "bye"
    0

# =========================================================================
# Live slides-GUI presenter loop (`office slides-gui-live`): the same real
# termios raw-mode byte loop as run_sheet_gui_live above, bridged into
# gui.spl's SlideGuiSession/slide_gui_step instead of SheetGuiSession --
# a live keystroke-driven slide presenter, one frame re-rendered through
# the REAL office_gui_slide_pixels pixel path per accepted key. Reuses
# decode_key_byte (the ONE shared arrow-escape decoder above) and the same
# rt_stdin_read_byte/rt_terminal_enable_raw_mode/rt_terminal_disable_raw_mode
# externs -- zero duplicated termios plumbing.
# =========================================================================

fn slides_live_map_key(decoded: text) -> text:
    """Map one decode_key_byte key name to the presenter step key
    slide_gui_step consumes -- the pure per-keystroke translation layer of
    run_slides_gui_live below, extracted so the mapping is spec-testable
    without a terminal. "right" advances ("n"), "left" steps back ("p"),
    and a decoded space -- which decode_key_byte emits as the printable
    " " character, byte 32 -- also advances ("n"; the canonical "space"
    name is accepted too). slide_gui_step's own names pass through
    unchanged: "n"/"p", single digits "1".."9" (1-based goto), and the
    quit keys "q"/"ctrl_c"/"eof". Every other key name (including a lone
    "escape" and mid-escape-sequence "" non-keys) maps to "" -- no step,
    no redraw."""
    if decoded == "right":
        return "n"
    if decoded == "left":
        return "p"
    if decoded == " " or decoded == "space":
        return "n"
    if decoded == "n" or decoded == "p":
        return decoded
    if decoded == "q" or decoded == "ctrl_c" or decoded == "eof":
        return decoded
    if (decoded.len() == 1 and decoded >= "1" and decoded <= "9"):
        return decoded
    ""

fn _slides_live_frame(view: SlideGuiView) -> text:
    """One live presenter frame: an ANSI clear+home (same redraw discipline
    as _gui_live_frame above) followed by the SAME pixel-path proof line the
    slides-gui CLI command prints (office_gui_slide_pixels +
    office_gui_non_background_pixel_count -- a real render through the
    browser-engine pixel path, not a stub) and the view's text_dump, one
    "slides-gui-live: <line>" per row (the leading "slide|<n>/<total>|..."
    header line slide_gui_view always emits first, then one line per
    element)."""
    val esc = char_from_code(27)
    val clear = "{esc}[2J{esc}[H"
    val pixels = office_gui_slide_pixels(view)
    val non_background = office_gui_non_background_pixel_count(pixels)
    var out = "{clear}slides-gui-live: frame {office_gui_frame_width()}x{office_gui_frame_height()}, {non_background} non-background pixels\n"
    for line in view.text_dump.split("\n"):
        out = "{out}slides-gui-live: {line}\n"
    out

fn run_slides_gui_live(deck: [Slide]) -> i32:
    """Live keystroke-driven slide presenter: renders the current
    SlideGuiSession slide through the real pixel path, reads one raw termios
    byte, decodes it with the shared decode_key_byte, maps the decoded key
    name through slides_live_map_key (right/space -> next, left -> prev,
    digits -> 1-based goto), and applies it via gui.spl's slide_gui_step --
    re-rendering after every accepted key. 'q', Ctrl-C (byte 3), or EOF
    quits via slide_gui_step's quit signal.

    Non-TTY safety (same contract as run_sheet_gui_live above):
    rt_terminal_enable_raw_mode() returns false when stdin isn't a real
    terminal (tcgetattr fails on a pipe/redirect) -- in that case this
    prints exactly ONE rendered frame plus a documented non-TTY notice and
    returns 0 immediately, instead of blocking forever on a keystroke that
    will never arrive (so CI/non-interactive callers can still exercise
    this entry point)."""
    var session = slide_session_new(deck)
    print _slides_live_frame(slide_session_view(session))

    if not rt_terminal_enable_raw_mode():
        print "slides-gui-live: stdin is not a TTY (non-interactive input) -- printed one rendered frame above and exiting instead of blocking on a keystroke that will never arrive. Run 'simple office slides-gui-live' from a real terminal for the live presenter loop."
        return 0

    var quit = false
    var pending_esc = 0
    while not quit:
        val b = rt_stdin_read_byte()
        var key = ""
        if b == 3:
            key = "ctrl_c"
        else:
            val decoded = decode_key_byte(pending_esc, b)
            pending_esc = decoded.pending_esc
            key = decoded.key
        val mapped = slides_live_map_key(key)
        if mapped != "":
            val step = slide_gui_step(session, mapped)
            session = step.session
            quit = step.quit
            if not quit:
                print _slides_live_frame(slide_session_view(session))
    rt_terminal_disable_raw_mode()
    print "bye"
    0
