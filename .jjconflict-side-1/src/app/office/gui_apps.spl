"""Interactive-GUI frame rendering for the remaining launcher apps.

office_gui_build_tree in gui.spl wires the counter + word apps. Wiring the
other launcher apps (sheets/slides/mail/planner) there too would fatten
gui.spl's import graph, and since many office specs import gui.spl that slows
the whole office test suite past the 60s runner kill. This module keeps those
four heavier app imports OUT of gui.spl: only specs that import THIS module pay
for them, so gui.spl and the rest of the suite stay lean.

The render pipeline is identical to office_gui_frame's (build_ui UITree ->
render_html_tree -> office_gui_minimal_css -> the production
simple_web_engine2d_render_html_pixels entry) — real pixels, same path.
"""

use app.office.sheets.sheets_app.{SheetsApp}
use app.office.slides.slides_app.{SlidesApp}
use app.office.mail.mail_app.{MailApp}
use app.office.planner.planner_app.{PlannerApp}
use common.ui.widget.{UITree}
use common.ui.state.{init_state}
use app.ui.render.html_widgets.{render_html_tree}
use std.gc_async_mut.gpu.browser_engine.simple_web_engine2d_renderer.{simple_web_engine2d_render_html_pixels}
use app.office.gui.{office_gui_minimal_css}

val OFFICE_GUI_APP_W: i32 = 96
val OFFICE_GUI_APP_H: i32 = 64

fn office_gui_launcher_tree(name: text) -> UITree:
    """Build the named launcher app's UITree. Handles the four apps NOT wired
    into gui.spl's office_gui_build_tree; unknown names fall back to sheets."""
    match name:
        "sheets" =>
            return SheetsApp.new().build_ui()
        "slides" =>
            return SlidesApp.new().build_ui()
        "mail" =>
            return MailApp.new().build_ui()
        "planner" =>
            return PlannerApp.new().build_ui()
        case _("unknown launcher app falls back to sheets"):
            return SheetsApp.new().build_ui()

fn office_gui_launcher_frame(name: text) -> [u32]:
    """Render ONE frame of the named launcher app through the same production
    browser layout/paint pixel path office_gui_frame uses. Returns the ARGB
    pixel buffer."""
    val tree = office_gui_launcher_tree(name)
    val state = init_state(tree)
    val body = render_html_tree(tree.root_node(), state)
    val html = "<html><head><style>" + office_gui_minimal_css() + "</style></head><body>" + body + "</body></html>"
    simple_web_engine2d_render_html_pixels(html, OFFICE_GUI_APP_W, OFFICE_GUI_APP_H, "software")

fn office_gui_launcher_frame_width() -> i32:
    OFFICE_GUI_APP_W

fn office_gui_launcher_frame_height() -> i32:
    OFFICE_GUI_APP_H
