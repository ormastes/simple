# Mail Merge — user-facing workflow layer
#
# The mail_merge engine (app.office.word.mail_merge) already does field
# substitution and batch merging; this module adds the inspection/preview
# surface a real user needs before running a merge: which fields the
# template expects, what one record looks like merged, and whether the
# template/records pairing has problems (missing values, unreferenced
# columns) — fail-closed, advisory only (never raises; the CLI still runs
# the merge even with issues, matching Office's own behavior).
#
# No CLI or file I/O lives here — see `office mail-merge` in mod.spl.

use common.rich_text.attributed_text.{RichDocument}
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text, col_to_letter, parse_cell_ref}
use app.office.word.mail_merge.{merge_fields, merge_document}

fn merge_fields_of(template_doc: RichDocument) -> [text]:
    """Distinct {{field}} placeholder names in template_doc, in document
    order (first occurrence wins). Thin wrapper over
    mail_merge.merge_fields for the mail-merge UI surface."""
    merge_fields(template_doc)

fn merge_preview(template_doc: RichDocument, records: Sheet, index: i32) -> RichDocument:
    """Single-record merge preview: substitutes template_doc's placeholders
    with records' data row `index` (1-based data row; row 1 reads sheet row
    2, since sheet row 1 is the header). Thin wrapper over
    mail_merge.merge_document — returns a new document, doesn't mutate
    template_doc."""
    merge_document(template_doc, records, index)

fn _header_col(records: Sheet, field: text) -> i32:
    """0-based column index whose row-1 header cell equals field, or -1."""
    var col = 0
    while col < records.col_count:
        val ref_str = "{col_to_letter(col)}1"
        if cell_display_text(records.get_cell(ref_str)) == field:
            return col
        col = col + 1
    -1

fn _data_row_count(records: Sheet) -> i32:
    """Number of data rows in records, excluding header row 1."""
    val range_str = records.used_range()
    val parts = range_str.split(":")
    if parts.len() < 2:
        return 0
    val end_ref = parse_cell_ref(parts[1])
    if end_ref == nil:
        return 0
    val total_rows = end_ref.row + 1
    if total_rows <= 1:
        return 0
    total_rows - 1

fn _value_at(records: Sheet, col: i32, row: i32) -> text:
    """Data value at 0-based column `col`, 1-based data `row` (row 1 reads
    sheet row 2, since row 1 is the header)."""
    val ref_str = "{col_to_letter(col)}{row + 1}"
    cell_display_text(records.get_cell(ref_str))

fn _fields_has(fields: [text], name: text) -> bool:
    for f in fields:
        if f == name:
            return true
    false

fn merge_validate(template_doc: RichDocument, records: Sheet) -> [text]:
    """Fail-closed validation of a mail merge before running it. Reports,
    in order:
      - template fields with no matching header column at all
        ("field <<X>> has no matching column")
      - per data record, template fields whose header column exists but
        whose value is blank for that record
        ("record N missing field <<X>>")
      - header columns that no template field references
        ("unused column X")
      - the degenerate zero-record case, so callers get an actionable
        issue line instead of a silent empty merge
        ("no data records found")
    Empty result = clean merge. This function never raises — it's
    advisory; the caller decides whether to proceed."""
    val fields = merge_fields_of(template_doc)
    var issues: [text] = []

    for field in fields:
        if _header_col(records, field) < 0:
            issues.push("field <<{field}>> has no matching column")

    val data_rows = _data_row_count(records)
    var row = 1
    while row <= data_rows:
        for field in fields:
            val col = _header_col(records, field)
            if col >= 0:
                val value = _value_at(records, col, row)
                if value == "":
                    issues.push("record {row} missing field <<{field}>>")
        row = row + 1

    var header_col = 0
    while header_col < records.col_count:
        val ref_str = "{col_to_letter(header_col)}1"
        val name = cell_display_text(records.get_cell(ref_str))
        if name != "" and not _fields_has(fields, name):
            issues.push("unused column {name}")
        header_col = header_col + 1

    if data_rows == 0:
        issues.push("no data records found")

    issues
