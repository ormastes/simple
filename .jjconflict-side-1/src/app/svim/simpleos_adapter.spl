use app.svim.core.*
use app.svim.tui_shell.{svim_render_tui, svim_shell_classify_line}


fn svim_simpleos_dispatch(session: SvimSession, line: text) -> CommandResult:
    """Translate a SimpleOS-side shell line into the shared svim session API."""
    val classified = svim_shell_classify_line(session.mode_state.mode, line)
    val action = classified.0
    val payload = classified.1
    if action == "insert":
        return session.execute_named("insert-text", payload, 1, "")
    if action == "dispatch":
        return _svim_simpleos_dispatch_payload(session, payload)
    if action == "quit":
        return CommandResult(ok: true, message: "quit requested", events: [EditorEvent(kind: "quit-requested", message: "")])
    if action == "help" or action == "buffers" or action == "refresh" or action == "cancel":
        return CommandResult(ok: true, message: action, events: [])
    if action == "prompt":
        return CommandResult(ok: true, message: "prompt:{payload}", events: [])
    CommandResult(ok: false, message: "unknown adapter action: {action}", events: [])

fn svim_simpleos_snapshot(session: SvimSession) -> text:
    """Render the same shared session snapshot for a SimpleOS-facing surface."""
    svim_render_tui(session)

fn _svim_simpleos_dispatch_payload(session: SvimSession, payload: text) -> CommandResult:
    if payload == "save":
        return session.execute_named("save", "", 1, "")
    if payload == "next-buffer":
        return session.execute_named("next-buffer", "", 1, "")
    if payload == "prev-buffer":
        return session.execute_named("prev-buffer", "", 1, "")
    if payload == "quickfix-next":
        return session.execute_named("quickfix-next", "", 1, "")
    if payload == "quickfix-prev":
        return session.execute_named("quickfix-prev", "", 1, "")
    if payload == "jump-back":
        return session.execute_named("jump-back", "", 1, "")
    if payload == "jump-forward":
        return session.execute_named("jump-forward", "", 1, "")
    if payload == "backspace":
        return session.execute_named("backspace", "", 1, "")
    if payload == "newline":
        return session.execute_named("newline", "", 1, "")
    if payload.starts_with("set-mode:"):
        return session.execute_named("set-mode", payload.slice(9, payload.len()), 1, "")
    if payload.starts_with("insert-text:"):
        return session.execute_named("insert-text", payload.slice(12, payload.len()), 1, "")
    if payload.starts_with("open-buffer:"):
        return session.execute_named("open-buffer", payload.slice(12, payload.len()), 1, "")
    if payload.starts_with("save-as:"):
        return session.execute_named("save-as", payload.slice(8, payload.len()), 1, "")
    if payload.starts_with("search-forward:"):
        return session.execute_named("search-forward", payload.slice(15, payload.len()), 1, "")
    if payload.starts_with("commandline:"):
        return session.execute_named("commandline", payload.slice(12, payload.len()), 1, "")
    session.execute(svim_parse_normal_command(payload))
