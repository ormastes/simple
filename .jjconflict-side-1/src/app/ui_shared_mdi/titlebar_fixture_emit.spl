# Emit a full HTML document wrapping the shared MDI titlebar for live capture.
use app.ui_shared_mdi.terminal_window_html.{shared_mdi_terminal_window_html}

fn main() -> i64:
    val frag = shared_mdi_terminal_window_html()
    val doc = "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>html,body{margin:0;padding:0;background:#0b0d10;}.host{width:600px;height:120px;}</style></head><body><div class=\"host\">" + frag + "</div></body></html>"
    print doc
    return 0
