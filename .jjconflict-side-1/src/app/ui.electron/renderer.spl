# Electron Renderer-Side Adapter (V4, Row 6)
#
# Simple-side mirror of the renderer process. The real renderer runs under
# Node/Chromium inside `tools/electron-shell/` and speaks the shared JSON
# IPC protocol (`app.ui.ipc.protocol`). This module exists so the Simple
# side can:
#
#   1. document the renderer-half of the V4 contract in-tree, and
#   2. be unit-tested without spawning a Node process.
#
# Dev-preview only. Do NOT add to CI.

use app.ui.ipc.protocol.{parse_ipc_message, build_ipc_render}
use common.ui.widget.{UIEvent}

# =========================================================================
# ElectronRenderer — simulated renderer process
# =========================================================================

class ElectronRenderer:
    window_id: i64
    bound_to_compositor: bool

    static fn new(window_id: i64) -> ElectronRenderer:
        ElectronRenderer(window_id: window_id, bound_to_compositor: false)

    # Called by the main process via rt_electron_renderer_post_message.
    me handle_main_message(json: text) -> bool:
        # TODO(v4-dev-preview): in a real binding this runs inside the
        # Chromium renderer and switches the <canvas> into blit-mode.
        val evt = parse_ipc_message(json)
        if evt == nil:
            return false
        self.bound_to_compositor = true
        true

    # Called when the user triggers input inside the BrowserWindow.
    fn forward_event(evt: UIEvent) -> text:
        # TODO(v4-dev-preview): serialize to the shared IPC protocol.
        build_ipc_render("event")

    fn is_bound() -> bool:
        return self.bound_to_compositor
