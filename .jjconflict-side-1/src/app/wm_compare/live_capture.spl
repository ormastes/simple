# WM Compare — Live Source-B Capture (Phase 1)
#
# Captures a real rendered frame from the running macOS host Simple Web WM
# (`bin/simple run examples/ui/web_wm.spl` on localhost:3333) by:
#
#   1. curl-ing `http://localhost:3333/` to a temp HTML file
#   2. invoking `tools/electron-shell/screenshot.js` (Electron headless) at
#      160x120 (devicePixelRatio=2 yields 320x240 PPM directly — no resize)
#   3. reading the resulting PPM bytes
#   4. writing them to `test/baselines/wm_compare/<scene>/B_live.ppm`
#
# This is the Phase 1 path that exercises the actual Simple HTML generator
# (`src/app/ui.web/html.spl` + `ws_handler.spl`) end-to-end through a real
# browser engine, instead of the placeholder solid-rectangle renderer in
# `_render_minimal_scene()` from Phase 0.
#
# The Web WM must already be running before this module is invoked.
# Boot it with:
#   SIMPLE_TIMEOUT_SECONDS=600 bin/simple run examples/ui/web_wm.spl &
#
# Why 160x120 and not 320x240? Electron on a Retina display uses
# devicePixelRatio=2, so a 160x120 BrowserWindow yields a 320x240 bitmap.
# screenshot.js writes the PPM at the bitmap's actual size, so we get the
# exact target resolution with no scaling step.

use std.io_runtime.{process_run}
use std.nogc_sync_mut.ffi.io.{file_read_bytes, file_write_bytes, dir_create_all, file_exists}

# ============================================================================
# Constants
# ============================================================================

val LIVE_HTML_TMP = "/tmp/wm_compare_live.html"
val LIVE_PPM_TMP = "/tmp/wm_compare_live.ppm"
val LIVE_WM_HOST = "http://localhost:3333/"
val ELECTRON_SHELL_DIR = "tools/electron-shell"
val ELECTRON_SCREENSHOT_JS = "tools/electron-shell/screenshot.js"

# ============================================================================
# Result type
# ============================================================================

struct LiveCaptureResult:
    """Result of one live source-B capture."""
    success: bool
    width: i32
    height: i32
    ppm_bytes_len: i64
    error: text
    out_path: text

fn _failure(msg: text) -> LiveCaptureResult:
    LiveCaptureResult(
        success: false,
        width: 0,
        height: 0,
        ppm_bytes_len: 0,
        error: msg,
        out_path: ""
    )

# ============================================================================
# Steps
# ============================================================================

fn _check_wm_alive() -> bool:
    """Probe localhost:3333 with curl to confirm the WM is up.

    Returns true on curl exit 0, false on connection refused.
    Uses --fail so non-2xx HTTP responses also yield non-zero exit.
    """
    val r = process_run("curl", ["-sf", "-o", "/dev/null", LIVE_WM_HOST])
    r.2 == 0

fn _fetch_live_html() -> bool:
    """curl the live WM HTML page to LIVE_HTML_TMP."""
    val r = process_run("curl", ["-s", "-o", LIVE_HTML_TMP, LIVE_WM_HOST])
    if r.2 != 0:
        return false
    file_exists(LIVE_HTML_TMP)

fn _run_electron_screenshot(width: i32, height: i32) -> (bool, text):
    """Invoke `npx electron tools/electron-shell/screenshot.js <html> <out> <w> <h>`.

    Returns (success, stderr_or_empty).
    """
    # devicePixelRatio=2 on Retina => the BrowserWindow needs to be HALF the
    # target pixel size to produce a target_w x target_h PPM directly. The
    # caller is responsible for passing the half-size values.
    val r = process_run("npx", [
        "--prefix", ELECTRON_SHELL_DIR,
        "electron", ELECTRON_SCREENSHOT_JS,
        LIVE_HTML_TMP, LIVE_PPM_TMP,
        "{width}", "{height}"
    ])
    val ok = r.2 == 0 and file_exists(LIVE_PPM_TMP)
    val stderr_str = r.1
    (ok, stderr_str)

fn _read_ppm_dims_from_header(data: [u8]) -> (i32, i32):
    """Parse `P6\\n<w> <h>\\n255\\n` and return (w, h). Returns (0,0) on failure."""
    if data.len() < 11:
        return (0, 0)
    if data[0] != 80 or data[1] != 54:
        return (0, 0)

    # Walk past three newlines (magic, dims, maxval)
    var i: i32 = 0
    var nl_count: i32 = 0
    val n_i64 = data.len()
    val n: i32 = n_i64 as i32
    while i < n and nl_count < 1:
        if data[i] == 10:
            nl_count = nl_count + 1
        i = i + 1

    # Now read up to next newline as dim_line
    var dim_start = i
    while i < n and data[i] != 10:
        i = i + 1
    var dim_end = i
    if dim_start >= dim_end:
        return (0, 0)

    # Parse two integers separated by whitespace
    var w: i32 = 0
    var h: i32 = 0
    var k = dim_start
    var have_w = false
    while k < dim_end and (data[k] == 32 or data[k] == 9):
        k = k + 1
    while k < dim_end and data[k] >= 48 and data[k] <= 57:
        val dw: i32 = (data[k] - 48) as i32
        w = w * 10 + dw
        k = k + 1
    while k < dim_end and (data[k] == 32 or data[k] == 9):
        k = k + 1
    while k < dim_end and data[k] >= 48 and data[k] <= 57:
        val dh: i32 = (data[k] - 48) as i32
        h = h * 10 + dh
        k = k + 1
    (w, h)

# ============================================================================
# Public API
# ============================================================================

fn capture_live_source_b(target_width: i32, target_height: i32, out_path: text) -> LiveCaptureResult:
    """Capture the running Simple Web WM at exactly target_width x target_height.

    Steps:
      1. Verify WM is up on localhost:3333
      2. curl live HTML to /tmp/wm_compare_live.html
      3. Run electron screenshot.js at half-size to produce a PPM at target size
         (Retina devicePixelRatio=2 doubles the bitmap)
      4. Read PPM bytes, parse header, copy to out_path

    Returns LiveCaptureResult with success=true if a PPM was written and the
    parsed dimensions match the target.
    """
    if not _check_wm_alive():
        return _failure("Web WM not reachable on " + LIVE_WM_HOST + " — boot it with: SIMPLE_TIMEOUT_SECONDS=600 bin/simple run examples/ui/web_wm.spl &")

    if not _fetch_live_html():
        return _failure("curl failed to fetch " + LIVE_WM_HOST)

    # When invoked via process_run (no parent terminal/display context),
    # Electron uses devicePixelRatio=1, so we pass full target dims and the
    # bitmap comes out at target_width x target_height directly. (Interactive
    # shell sessions on Retina yield dpr=2 — that's a different code path.)
    val (ok, stderr_str) = _run_electron_screenshot(target_width, target_height)
    if not ok:
        return _failure("electron screenshot.js failed: " + stderr_str)

    # NOTE: rt_file_read_bytes in the interpreter returns Option<[u8]> at runtime
    # even though the wrapper signature says [u8]. Match it to unwrap.
    val data_opt = file_read_bytes(LIVE_PPM_TMP)
    var data: [u8] = []
    match data_opt:
        case Some(b): data = b
        case nil:
            return _failure("file_read_bytes returned None for " + LIVE_PPM_TMP)
    if data.len() == 0:
        return _failure("electron PPM is empty: " + LIVE_PPM_TMP)

    val (w, h) = _read_ppm_dims_from_header(data)
    if w != target_width or h != target_height:
        return _failure("electron PPM has wrong dims: got {w}x{h}, expected {target_width}x{target_height}")

    # Make sure parent dir exists, then copy bytes to out_path
    # We don't bother computing dirname — caller's contract is that out_path
    # already lives in a directory the harness has created via baseline_dir().
    val wrote = file_write_bytes(out_path, data)
    if not wrote:
        return _failure("failed to write " + out_path)

    LiveCaptureResult(
        success: true,
        width: w,
        height: h,
        ppm_bytes_len: data.len(),
        error: "",
        out_path: out_path
    )
