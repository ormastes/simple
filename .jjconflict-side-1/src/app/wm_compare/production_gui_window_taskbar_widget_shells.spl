# Production GUI-window and taskbar-shell widget rendering
#
# Builds a realistic Simple-GUI window and the SimpleOS taskbar shell through
# the shared common.ui builder, wraps each in a full themed HTML document
# (generate_css tokens), and renders them on the REAL Simple Web layout
# renderer (parse -> CSS cascade -> block layout -> paint) over Engine2D/Metal.
#
# This module deliberately keeps a lean import set (no engine2d backend
# modules). The engine2d backends are pulled in transitively through the Web
# renderer, but importing them directly (as the sibling backend-parity harness
# does) changes module-init ordering enough to leave a layout-renderer global
# nil during the real layout lane. Keeping this module lean matches the proven
# render path.
#
# Root ids avoid the four pinned production-parity heuristic id sets, and the
# embedded <style> uses class/id selectors, so the renderer routes these shells
# through the genuine layout renderer, not the pinned hand-drawn rasterizer.
#
# Pass criteria target the light-theme generate_css surface tokens
# (background #ffffff, panel #f5f5f5, accent #0066cc) rather than glyph ink, so
# the known GPU-lane text-as-bars rendering does not gate these shells.

use common.ui.builder.{button, column, label, panel, build_tree_with_title}
use common.ui.state.{init_state}
use common.ui.taskbar_model.{TaskbarModel, AppRef, WindowRef, TrayItem}
use os.desktop.taskbar_shell.{build_taskbar_shell_tree}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.web.html.{generate_css}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    simple_web_render_html_to_pixels_with_engine2d_backend,
    simple_web_resolved_engine2d_backend_name}
use std.nogc_sync_mut.env.platform.{is_macos}
use std.nogc_sync_mut.io.time_ops.{time_now_micros}

val WIDGET_SHELL_THEME: text = "light"
val WIDGET_SHELL_BG_COLOR: u32 = 0xFFFFFFFFu32
val WIDGET_SHELL_PANEL_COLOR: u32 = 0xFFF5F5F5u32
val WIDGET_SHELL_ACCENT_COLOR: u32 = 0xFF0066CCu32

struct GuiWidgetShellRenderReport:
    fixture: text
    width: i32
    height: i32
    html_len: i32
    has_widget_markup: bool
    has_style_block: bool
    routes_pinned_stub: bool
    resolved_backend: text
    pixel_count: i32
    distinct_colors: i32
    bg_pixel_count: i32
    panel_pixel_count: i32
    accent_pixel_count: i32
    themed_pixel_count: i32
    first_pixel: u32
    checksum: i64
    render_elapsed_us: i64
    status: text
    reason: text

fn _positive_elapsed_us(start_us: i64) -> i64:
    val elapsed = time_now_micros() - start_us
    if elapsed <= 0:
        return 1
    elapsed

fn _count_distinct_colors(px: [u32]) -> i32:
    var seen: Dict<text, bool> = {}
    var count = 0
    var i = 0
    val px_count = px.len()
    while i < px_count:
        val c = px[i]
        val key = c.to_string()
        if not seen.get(key).?:
            seen[key] = true
            count = count + 1
        i = i + 1
    count

fn _checksum_pixels(px: [u32]) -> i64:
    var sum: i64 = 0
    var i = 0
    val px_count = px.len()
    while i < px_count:
        sum = sum + (px[i] as i64) * ((i + 1) as i64)
        i = i + 1
    sum

fn _sample_pixel(px: [u32], idx: i32) -> u32:
    if idx >= 0 and idx < px.len():
        return px[idx]
    0u32

fn _count_color(px: [u32], color: u32) -> i32:
    var count = 0
    var i = 0
    val n = px.len()
    while i < n:
        if px[i] == color:
            count = count + 1
        i = i + 1
    count

fn _routes_pinned_stub(html: text) -> bool:
    # Mirrors _is_production_parity_widget_html: the four pinned root-id sets
    # that short-circuit to the hand-drawn rasterizer stub.
    if html.contains("prod_gui_root") and html.contains("prod_gui_text") and html.contains("run_production_gui"):
        return true
    if html.contains("web_render_root") and html.contains("web_render_action"):
        return true
    if html.contains("wide_layout_root") and html.contains("wide_layout_7"):
        return true
    if html.contains("browser_queue_root") and html.contains("browser_queue_action"):
        return true
    false

fn _wrap_widget_shell_doc(body: text, theme: text, title: text) -> text:
    val css = generate_css(theme)
    var h = "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n"
    h = h + "<title>" + title + "</title>\n<style>" + css + "</style>\n</head>\n<body>\n"
    h = h + "<div id=\"app\">" + body + "</div>\n</body>\n</html>"
    h

fn gui_window_widget_html() -> text:
    """Realistic Simple GUI window: title label, a titled panel, and labeled
    controls. Routes through the real Web layout renderer (non-pinned id)."""
    val window_title = label("prod_window_title", "Simple Editor")
    val status_line = label("prod_window_status", "Ready")
    val run_action = button("prod_window_run", "Run", "run_editor")
    val save_action = button("prod_window_save", "Save", "save_editor")
    val body_panel = panel("prod_window_panel", "Editor", [status_line, run_action, save_action])
    val root = column("prod_window_root", [window_title, body_panel])
    val tree = build_tree_with_title(root, "Simple Editor Window", WIDGET_SHELL_THEME)
    val state = init_state(tree)
    val body = render_html_tree(state.tree.root_node(), state)
    _wrap_widget_shell_doc(body, WIDGET_SHELL_THEME, "Simple Editor Window")

fn taskbar_shell_widget_html() -> text:
    """SimpleOS taskbar shell (pinned apps | running window | tray) rendered as
    themed HTML through the real Web layout renderer (non-pinned id)."""
    val pinned = [
        AppRef(app_id: "files", display_name: "Files", icon: "folder"),
        AppRef(app_id: "editor", display_name: "Editor", icon: "code"),
        AppRef(app_id: "terminal", display_name: "Terminal", icon: "term")]
    val running = [WindowRef(window_id: "w1", app_id: "editor", title: "main.spl", minimized: false)]
    val tray = [TrayItem(item_id: "clock", label: "09:41", icon: "clock")]
    val model = TaskbarModel(pinned: pinned, running: running, tray: tray)
    val root = build_taskbar_shell_tree(model)
    val tree = build_tree_with_title(root, "Taskbar Shell", WIDGET_SHELL_THEME)
    val state = init_state(tree)
    val body = render_html_tree(state.tree.root_node(), state)
    _wrap_widget_shell_doc(body, WIDGET_SHELL_THEME, "Taskbar Shell")

fn run_gui_widget_shell_render(fixture: text, html: text, width: i32, height: i32) -> GuiWidgetShellRenderReport:
    val has_widget_markup = html.contains("widget-") or html.contains("data-action=")
    val has_style_block = html.contains("<style>")
    val routes_pinned_stub = _routes_pinned_stub(html)
    val resolved_backend = simple_web_resolved_engine2d_backend_name(width, height, "metal")
    val start_us = time_now_micros()
    val pixels = simple_web_render_html_to_pixels_with_engine2d_backend(html, width, height, "metal")
    val render_elapsed_us = _positive_elapsed_us(start_us)
    val pixel_count = pixels.len()
    val distinct = _count_distinct_colors(pixels)
    val bg_count = _count_color(pixels, WIDGET_SHELL_BG_COLOR)
    val panel_count = _count_color(pixels, WIDGET_SHELL_PANEL_COLOR)
    val accent_count = _count_color(pixels, WIDGET_SHELL_ACCENT_COLOR)
    val themed_count = bg_count + panel_count + accent_count
    val checksum = _checksum_pixels(pixels)
    val expect_metal = is_macos()
    val backend_ok = if expect_metal: resolved_backend == "metal" else: (resolved_backend != "" and resolved_backend != "metal-unavailable")
    val expected_pixels = width * height
    # Fail-closed pass criteria. Panel/accent thresholds are a fraction of the
    # observed real-layout output so text-as-bars glyph behavior cannot gate.
    val panel_floor = expected_pixels / 8
    val markup_ok = has_widget_markup and has_style_block and not routes_pinned_stub
    val size_ok = pixel_count == expected_pixels and expected_pixels > 0
    val themed_ok = distinct >= 3 and panel_count >= panel_floor and accent_count >= 50 and bg_count >= 1
    val checksum_ok = checksum > 0
    val status = if markup_ok and size_ok and backend_ok and themed_ok and checksum_ok: "pass" else: "fail"
    var reason = "pass"
    if not markup_ok:
        reason = "widget-markup-or-pinned-stub"
    elif not size_ok:
        reason = "pixel-count-mismatch"
    elif not backend_ok:
        reason = "backend-not-resolved"
    elif not themed_ok:
        reason = "theme-tokens-not-rendered"
    elif not checksum_ok:
        reason = "empty-checksum"
    GuiWidgetShellRenderReport(
        fixture: fixture,
        width: width,
        height: height,
        html_len: html.len(),
        has_widget_markup: has_widget_markup,
        has_style_block: has_style_block,
        routes_pinned_stub: routes_pinned_stub,
        resolved_backend: resolved_backend,
        pixel_count: pixel_count,
        distinct_colors: distinct,
        bg_pixel_count: bg_count,
        panel_pixel_count: panel_count,
        accent_pixel_count: accent_count,
        themed_pixel_count: themed_count,
        first_pixel: _sample_pixel(pixels, 0),
        checksum: checksum,
        render_elapsed_us: render_elapsed_us,
        status: status,
        reason: reason
    )

fn run_gui_window_widget_shell_render(width: i32, height: i32) -> GuiWidgetShellRenderReport:
    run_gui_widget_shell_render("gui_window", gui_window_widget_html(), width, height)

fn run_taskbar_shell_widget_render(width: i32, height: i32) -> GuiWidgetShellRenderReport:
    run_gui_widget_shell_render("taskbar_shell", taskbar_shell_widget_html(), width, height)
