# UI Render Parser Layer
#
# Parses CLI flags and environment variables into a RenderConfig.
# Extracted from ui/main.spl to serve as the dedicated parser layer
# of the render feature caret.
#
# Precedence (lowest to highest):
#   code defaults -> env vars -> CLI flags

use app.ui.render.types.{RenderConfig}

extern fn rt_env_get(key: text) -> text

# =========================================================================
# Public API
# =========================================================================

fn parse_render_args(args: [text]) -> RenderConfig:
    """Parse render sub-command args into a RenderConfig.

    Processes CLI flags (--format, --adapter, --mode, --theme, --width,
    --height, --output, --demo) and falls back to SIMPLE_RENDER_FORMAT env var
    for the format field when no explicit --format flag is given.
    """
    var config = RenderConfig.default()
    var format_from_cli = false

    var i = 1  # skip "render" subcommand token
    while i < args.len():
        val arg = args[i]
        if arg == "--format" and i + 1 < args.len():
            config.format = args[i + 1]
            format_from_cli = true
            i = i + 2
        elif arg.starts_with("--format="):
            config.format = arg[9:]
            format_from_cli = true
            i = i + 1
        elif arg == "--adapter" and i + 1 < args.len():
            config.adapter_name = args[i + 1]
            i = i + 2
        elif arg.starts_with("--adapter="):
            config.adapter_name = arg[10:]
            i = i + 1
        elif arg == "--mode" and i + 1 < args.len():
            config.mode = args[i + 1]
            i = i + 2
        elif arg.starts_with("--mode="):
            config.mode = arg[7:]
            i = i + 1
        elif arg == "--theme" and i + 1 < args.len():
            config.theme = args[i + 1]
            i = i + 2
        elif arg.starts_with("--theme="):
            config.theme = arg[8:]
            i = i + 1
        elif arg == "--width" and i + 1 < args.len():
            config.width = args[i + 1].to_int()
            i = i + 2
        elif arg.starts_with("--width="):
            config.width = arg[8:].to_int()
            i = i + 1
        elif arg == "--height" and i + 1 < args.len():
            config.height = args[i + 1].to_int()
            i = i + 2
        elif arg.starts_with("--height="):
            config.height = arg[9:].to_int()
            i = i + 1
        elif arg == "--output" and i + 1 < args.len():
            config.output_path = args[i + 1]
            i = i + 2
        elif arg == "-o" and i + 1 < args.len():
            config.output_path = args[i + 1]
            i = i + 2
        elif arg.starts_with("--output="):
            config.output_path = arg[9:]
            i = i + 1
        elif arg.starts_with("-o="):
            config.output_path = arg[3:]
            i = i + 1
        elif arg == "--demo":
            config.use_default_demo = true
            config.asset_path = "examples/ui/widget_matrix.ui.sdn"
            i = i + 1
        elif not arg.starts_with("-"):
            config.asset_path = arg
            i = i + 1
        else:
            i = i + 1

    # Apply env-var fallback for format when CLI did not set it
    if not format_from_cli:
        val env_format = rt_env_get("SIMPLE_RENDER_FORMAT")
        if env_format.len() > 0:
            config.format = env_format

    return config
