# TUI Widget Renderers
#
# Standalone TUI renderer surface split from the mixed widgets module so
# terminal-only entry closures do not inherit HTML/web renderer code.

# Split into the transparent _TuiWidgets/ package to keep module cohesion under the 800-line source limit.
export use app.ui.render._TuiWidgets.core_widgets.*
export use app.ui.render._TuiWidgets.extended_widgets.*
