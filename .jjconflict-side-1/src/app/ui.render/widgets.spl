# UI Widget Renderers TUI Compatibility Shim
#
# Backend-specific renderer ownership now lives in app.ui.render.tui_widgets
# and app.ui.render.html_widgets. This shim keeps only the TUI wrapper surface so
# generic widget imports no longer retain the HTML renderer implementation.

use app.ui.render.tui_widgets.{render_tui_tree}
use app.ui.render.colors.{get_theme_color}

export use app.ui.render.html_widgets.{render_html_widget, render_html_tree}

fn render_tui_menubar(screen, node, rect):
    var s = screen
    s = s.fill_row(rect.y, " ")
    var col = rect.x
    val menu_style = get_theme_color("dark", "title")
    val sep_style = get_theme_color("dark", "text_dim")
    for child in node.children():
        val is_separator = child.get_prop("is_separator")
        val has_submenu = child.get_prop("has_submenu")
        val label = child.get_prop("label")
        if is_separator == "true":
            val sep_text = " | "
            s = s.put_styled(rect.y, col, sep_text, sep_style)
            col = col + sep_text.len()
        elif has_submenu == "true":
            if label != "":
                val menu_text = " {label} \u{25be} "
                s = s.put_styled(rect.y, col, menu_text, menu_style)
                col = col + menu_text.len() + 1
        elif label != "":
            val menu_text = " {label} "
            s = s.put_styled(rect.y, col, menu_text, menu_style)
            col = col + menu_text.len() + 1
    return s

fn render_tui_tooltip(screen, node, rect):
    val content = node.get_prop("content")
    var s = screen
    if rect.h >= 3 and rect.w >= 4:
        s = s.draw_box_rounded(rect.y, rect.x, rect.w, rect.h, "")
        val style = get_theme_color("dark", "text_dim")
        val max_text_w = rect.w - 4
        val display = if content.len() > max_text_w: content.slice(0, max_text_w) else: content
        s = s.put_styled(rect.y + 1, rect.x + 2, display, style)
    else:
        val style = get_theme_color("dark", "text_dim")
        s = s.put_styled(rect.y, rect.x, "[?] {content}", style)
    return s

export render_tui_tree, render_tui_menubar, render_tui_tooltip
