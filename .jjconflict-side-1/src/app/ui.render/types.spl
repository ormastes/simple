# UI Render Contract Types
#
# Shared types for the render feature caret. All app adapters (dashboard,
# llm_dashboard, office) import from here instead of defining their own.
#
# Design ref: doc/05_design/ui_render_feature_caret.md

# =========================================================================
# RenderConfig
# =========================================================================

class RenderConfig:
    """Configuration for a render request.

    Fields:
        mode       — adapter-specific mode (e.g. "status", "text", "render")
        backend    — "auto", "headless", "tui", "web", "tauri", "electron"
        format     — "text", "html", "both"
        width      — viewport width in columns
        height     — viewport height in rows
        theme      — "dark", "light", or adapter-specific theme name
        asset_path — path to .ui.sdn or data file
        adapter_name — which app adapter to use
        use_default_demo — use built-in demo asset
    """
    mode: text
    backend: text
    format: text
    width: i64
    height: i64
    theme: text
    asset_path: text
    output_path: text
    adapter_name: text
    use_default_demo: bool

    static fn default() -> RenderConfig:
        return RenderConfig(
            mode: "render",
            backend: "auto",
            format: "text",
            width: 80,
            height: 24,
            theme: "dark",
            asset_path: "",
            output_path: "",
            adapter_name: "",
            use_default_demo: false
        )

    static fn text_export() -> RenderConfig:
        var cfg = RenderConfig.default()
        cfg.format = "text"
        return cfg

    static fn html_export() -> RenderConfig:
        var cfg = RenderConfig.default()
        cfg.format = "html"
        return cfg

# =========================================================================
# RenderRequest
# =========================================================================

class RenderRequest:
    """A render request combining config with export targets."""
    config: RenderConfig
    export_targets: [text]

    static fn from_config(config: RenderConfig) -> RenderRequest:
        return RenderRequest(config: config, export_targets: [])

# =========================================================================
# RenderResult
# =========================================================================

class RenderResult:
    """Result of a render operation."""
    format: text
    text_output: text
    html_output: text
    metadata: Dict<text, text>
    warnings: [text]

    static fn empty() -> RenderResult:
        return RenderResult(
            format: "text",
            text_output: "",
            html_output: "",
            metadata: {},
            warnings: []
        )

    static fn text(content: text) -> RenderResult:
        return RenderResult(
            format: "text",
            text_output: content,
            html_output: "",
            metadata: {},
            warnings: []
        )

    static fn html(content: text) -> RenderResult:
        return RenderResult(
            format: "html",
            text_output: "",
            html_output: content,
            metadata: {},
            warnings: []
        )

    static fn both(text_content: text, html_content: text) -> RenderResult:
        return RenderResult(
            format: "both",
            text_output: text_content,
            html_output: html_content,
            metadata: {},
            warnings: []
        )
