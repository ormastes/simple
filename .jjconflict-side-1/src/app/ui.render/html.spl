# HTML Builder Utilities
#
# Reusable HTML building blocks for page scaffolds, layout containers,
# cards, badges, tables, and common patterns. Eliminates duplicated
# inline HTML across dashboard, llm_dashboard, and office apps.

use common.web.html_escape.{html_escape_core}

# =========================================================================
# HTML Escaping
# =========================================================================

fn html_escape(s: text) -> text:
    """Escape HTML special characters."""
    html_escape_core(s)

# =========================================================================
# CSS Color Variables
# =========================================================================

fn css_color_var(name: text) -> text:
    """Generate a CSS variable reference with fallback."""
    match name:
        "green" => "var(--green, #3fb950)"
        "red" => "var(--red, #f85149)"
        "yellow" => "var(--yellow, #d29922)"
        "blue" => "var(--blue, #58a6ff)"
        "gray" => "var(--gray, #8b949e)"
        "white" => "var(--white, #c9d1d9)"
        "bg" => "var(--bg, #0d1117)"
        "bg-card" => "var(--bg-card, #161b22)"
        "border" => "var(--border, #30363d)"
        _ => "var(--{name})"

# =========================================================================
# Page Scaffold
# =========================================================================

fn html_page(title: text, css: text, body: text) -> text:
    """Generate a complete HTML page with CSS and body content."""
    [
        "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n",
        "  <meta charset=\"utf-8\">\n",
        "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n",
        "  <title>", html_escape(title), "</title>\n",
        "  <style>\n", css, "\n  </style>\n",
        "</head>\n<body>\n", body, "\n</body>\n</html>\n"
    ].join("")

fn html_page_with_js(title: text, css: text, body: text, js: text) -> text:
    """Generate a complete HTML page with CSS, body, and JavaScript."""
    [
        "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n",
        "  <meta charset=\"utf-8\">\n",
        "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n",
        "  <title>", html_escape(title), "</title>\n",
        "  <style>\n", css, "\n  </style>\n",
        "</head>\n<body>\n", body, "\n",
        "<script>\n", js, "\n</script>\n",
        "</body>\n</html>\n"
    ].join("")

# =========================================================================
# CSS Reset and Themes
# =========================================================================

fn css_reset() -> text:
    """Minimal CSS reset for consistent rendering."""
    [
        "* { margin: 0; padding: 0; box-sizing: border-box; }\n",
        "body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif; }\n",
        "img { max-width: 100%; height: auto; }\n",
        "table { border-collapse: collapse; }\n"
    ].join("")

fn css_dark_theme() -> text:
    """Dark theme CSS variables and body styles."""
    [
        ":root {\n",
        "  --bg: #0d1117;\n",
        "  --bg-card: #161b22;\n",
        "  --bg-card-hover: #1c2128;\n",
        "  --text: #c9d1d9;\n",
        "  --text-dim: #8b949e;\n",
        "  --border: #30363d;\n",
        "  --green: #3fb950;\n",
        "  --red: #f85149;\n",
        "  --yellow: #d29922;\n",
        "  --blue: #58a6ff;\n",
        "  --white: #c9d1d9;\n",
        "  --gray: #8b949e;\n",
        "}\n",
        "body {\n",
        "  background: var(--bg);\n",
        "  color: var(--text);\n",
        "  min-height: 100vh;\n",
        "  padding: 20px;\n",
        "}\n"
    ].join("")

fn css_light_theme() -> text:
    """Light theme CSS variables and body styles."""
    [
        ":root {\n",
        "  --bg: #ffffff;\n",
        "  --bg-card: #f6f8fa;\n",
        "  --bg-card-hover: #eef1f5;\n",
        "  --text: #24292f;\n",
        "  --text-dim: #57606a;\n",
        "  --border: #d0d7de;\n",
        "  --green: #1a7f37;\n",
        "  --red: #cf222e;\n",
        "  --yellow: #9a6700;\n",
        "  --blue: #0969da;\n",
        "  --white: #24292f;\n",
        "  --gray: #57606a;\n",
        "}\n",
        "body {\n",
        "  background: var(--bg);\n",
        "  color: var(--text);\n",
        "  min-height: 100vh;\n",
        "  padding: 20px;\n",
        "}\n"
    ].join("")

# =========================================================================
# Layout Containers
# =========================================================================

fn html_grid(columns: i32, gap: text, items: [text]) -> text:
    """Render items in a CSS grid with the given column count and gap."""
    var parts: [text] = ["<div style=\"display:grid; grid-template-columns:repeat({columns}, 1fr); gap:{gap}\">\n"]
    for item in items:
        parts.push("  ")
        parts.push(item)
        parts.push("\n")
    parts.push("</div>\n")
    parts.join("")

fn html_flex_row(items: [text], gap: text) -> text:
    """Render items in a horizontal flex row."""
    var parts: [text] = ["<div style=\"display:flex; flex-direction:row; gap:{gap}; align-items:center\">\n"]
    for item in items:
        parts.push("  ")
        parts.push(item)
        parts.push("\n")
    parts.push("</div>\n")
    parts.join("")

fn html_flex_col(items: [text], gap: text) -> text:
    """Render items in a vertical flex column."""
    var parts: [text] = ["<div style=\"display:flex; flex-direction:column; gap:{gap}\">\n"]
    for item in items:
        parts.push("  ")
        parts.push(item)
        parts.push("\n")
    parts.push("</div>\n")
    parts.join("")

fn html_section(title: text, content: text) -> text:
    """Render a titled section with a heading and content."""
    [
        "<section style=\"margin-bottom:16px\">\n",
        "  <h2 style=\"font-size:16px; margin-bottom:8px; color:var(--text-dim, #8b949e)\">",
        html_escape(title),
        "</h2>\n",
        "  ", content, "\n",
        "</section>\n"
    ].join("")

# =========================================================================
# Cards
# =========================================================================

fn html_card(title: text, body: text) -> text:
    """Render a card with title and body."""
    [
        "<div class=\"card\">\n",
        "  <h3>", html_escape(title), "</h3>\n",
        "  <div class=\"card-body\">", body, "</div>\n",
        "</div>\n"
    ].join("")

fn html_card_with_status(title: text, body: text, status: text) -> text:
    """Render a card with a status indicator dot in the header."""
    val dot = html_status_dot(status)
    [
        "<div class=\"card\">\n",
        "  <div class=\"card-header\">", dot, " <h3 style=\"display:inline\">",
        html_escape(title),
        "</h3></div>\n",
        "  <div class=\"card-body\">", body, "</div>\n",
        "</div>\n"
    ].join("")

fn html_metric_card(label: text, value: text, trend: text) -> text:
    """Render a compact metric card with label, large value, and trend subtitle."""
    var trend_html = ""
    if trend != "":
        trend_html = "<div class=\"sub\">{html_escape(trend)}</div>"
    [
        "<div class=\"card\">\n",
        "  <h3>", html_escape(label), "</h3>\n",
        "  <div class=\"value\">", html_escape(value), "</div>\n",
        "  ", trend_html, "\n",
        "</div>\n"
    ].join("")

# =========================================================================
# Badges and Indicators
# =========================================================================

fn html_badge(label: text, color: text) -> text:
    """Render an inline badge/pill with the given background color."""
    return "<span class=\"badge\" style=\"background:{color}; color:#fff; padding:2px 8px; border-radius:12px; font-size:12px; font-weight:500\">{html_escape(label)}</span>"

fn html_status_dot(status: text) -> text:
    """Render a colored status dot based on status string."""
    val color = match status:
        "ok" => css_color_var("green")
        "success" => css_color_var("green")
        "passed" => css_color_var("green")
        "complete" => css_color_var("green")
        "warning" => css_color_var("yellow")
        "in_progress" => css_color_var("yellow")
        "error" => css_color_var("red")
        "failed" => css_color_var("red")
        "blocked" => css_color_var("red")
        "critical" => css_color_var("red")
        _ => css_color_var("gray")
    return "<span style=\"display:inline-block; width:8px; height:8px; border-radius:50%; background:{color}; margin-right:6px\"></span>"

fn html_progress_bar(percent: i64) -> text:
    """Render a horizontal progress bar (0-100)."""
    val clamped = if percent < 0: 0 elif percent > 100: 100 else: percent
    val bar_color = if clamped >= 80: css_color_var("green") elif clamped >= 50: css_color_var("yellow") else: css_color_var("red")
    [
        "<div style=\"background:var(--border, #30363d); border-radius:4px; height:8px; overflow:hidden; width:100%\">",
        "<div style=\"background:", bar_color, "; height:100%; width:", clamped.to_text(), "%; transition:width 0.3s\"></div>",
        "</div>"
    ].join("")

# =========================================================================
# Tables
# =========================================================================

fn html_table(headers: [text], rows: [[text]]) -> text:
    """Render an HTML table with headers and rows."""
    var parts: [text] = ["<table>\n<thead><tr>\n"]
    for hdr in headers:
        parts.push("  <th>")
        parts.push(html_escape(hdr))
        parts.push("</th>\n")
    parts.push("</tr></thead>\n<tbody>\n")
    for row in rows:
        parts.push("<tr>\n")
        for cell in row:
            parts.push("  <td>")
            parts.push(html_escape(cell))
            parts.push("</td>\n")
        parts.push("</tr>\n")
    parts.push("</tbody>\n</table>\n")
    parts.join("")

fn html_kv_table(pairs: [(text, text)]) -> text:
    """Render a two-column key-value table."""
    var parts: [text] = ["<table>\n<tbody>\n"]
    for pair in pairs:
        val key = pair.0
        val val_text = pair.1
        parts.push("<tr><td style=\"font-weight:600; padding-right:16px\">")
        parts.push(html_escape(key))
        parts.push("</td><td>")
        parts.push(html_escape(val_text))
        parts.push("</td></tr>\n")
    parts.push("</tbody>\n</table>\n")
    parts.join("")
