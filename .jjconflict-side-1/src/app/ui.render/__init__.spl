# UI Render - Re-exports
#
# Shared reusable UI component library.
#
# Layers:
#   types    — RenderConfig, RenderRequest, RenderResult
#   parser   — CLI flag + env-var parsing
#   config   — precedence resolution
#   session  — per-invocation state
#   core     — adapter dispatch
#   export   — text / html / file export
#
# Components:
#   ansi     — ANSI escape sequences, colors, modifiers
#   fmt      — text formatting (numbers, bytes, time, padding)
#   table    — TableBuilder, alignment, key-value tables
#   progress — progress bars, percentage, fraction
#   html     — HTML page scaffolds, cards, grids, badges
#   css      — reusable CSS snippets
#   layout   — TUI layout primitives (rect, grid, splits)
#   border   — box-drawing border styles
#   colors   — theme color palettes
#   widgets  — TUI + HTML widget rendering

# Shared render contract types
export RenderConfig, RenderRequest, RenderResult

# Feature caret layer modules
export parse_render_args
export resolve_config
export RenderSession, create_session
export execute_render
export export_text, export_html, export_to_file

# ANSI escape sequences
export RESET, BOLD, DIM, ITALIC, UNDERLINE, BLINK, INVERSE, STRIKETHROUGH
export BLACK, RED, GREEN, YELLOW, BLUE, MAGENTA, CYAN, WHITE
export BRIGHT_BLACK, BRIGHT_RED, BRIGHT_GREEN, BRIGHT_YELLOW
export BRIGHT_BLUE, BRIGHT_MAGENTA, BRIGHT_CYAN, BRIGHT_WHITE
export fg_256, bg_256, fg_rgb, bg_rgb, colorize, strip_ansi

# Text formatting utilities
export fmt_number, fmt_decimal, fmt_currency, fmt_percent, fmt_fraction
export fmt_bytes, fmt_tokens, fmt_count
export fmt_duration_ms, fmt_duration_secs, fmt_timestamp, fmt_relative_time
export truncate, truncate_middle, word_wrap, indent, indent_lines
export pad_left, pad_right, pad_center, pluralize
export heading, separator, bullet_list, numbered_list

# Table rendering
export TableBuilder, ALIGN_LEFT, ALIGN_RIGHT, ALIGN_CENTER
export render_kv_table, render_html_table_limited

# Progress rendering
export progress_bar, progress_bar_html, percentage, fraction, fraction_html

# HTML builder utilities
export html_page, html_page_with_js, css_reset, css_dark_theme, css_light_theme
export html_grid, html_flex_row, html_flex_col, html_section
export html_card, html_card_with_status, html_metric_card
export html_badge, html_status_dot, html_progress_bar
export html_table, html_kv_table, html_escape, css_color_var

# Reusable CSS snippets
export card_css, grid_css, badge_css, metric_css
export animation_css, responsive_css, table_css, alert_css, progress_css

# Layout primitives
export LayoutRect, grid_layout
export split_horizontal, split_vertical
export split_left, split_right, split_top, split_bottom
export center_in, stack_layout
export text_width, truncate_to_width, pad_to_width, center_text

# Border styles and rendering
export BorderStyle, border_single, border_double, border_rounded, border_heavy, border_ascii
export draw_border, draw_box

# TUI rendering
export render_tui_widget, render_tui_tree

# HTML rendering
export render_html_widget, render_html_tree

# Theme colors
export get_theme_color

# Template helpers
export expand_template, replace_placeholder
