"""
# sj daemon main
"""

use std.io_runtime
use app.sj_daemon.daemon
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

extern fn rt_cli_get_args() -> [text]

fn main() -> i64:
    val raw_args = _sj_daemon_get_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("sj-daemon", log_opts.error)
        return 1i64

    val args = _sj_daemon_clean_args(raw_args)
    if args.len() > 0:
        if args[0] == "--help" or args[0] == "-h" or args[0] == "help":
            _print_sj_daemon_help_with_progress(log_opts.progress)
            return 0i64
        if log_opts.log_mode == "json":
            print "{\"command\":\"sj-daemon\",\"status\":\"error\",\"error\":\"unknown command\"}"
            return 1i64
        print "Unknown sj-daemon command: {args[0]}"
        print "Run 'simple sj-daemon --help' for usage."
        return 1i64

    if log_opts.log_mode == "json":
        print "{\"command\":\"sj-daemon\",\"status\":\"ready\"}"
        return 0i64

    val daemon = sj_daemon_new(".", 120000i64)
    if sj_daemon_start(daemon):
        sj_daemon_stop(daemon)
        return 0i64
    1i64

fn _print_sj_daemon_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    _print_sj_daemon_help()

fn _print_sj_daemon_help():
    print "Simple Jujutsu Daemon"
    print ""
    print "Usage: simple sj-daemon [options]"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn _sj_daemon_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _sj_daemon_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if _sj_daemon_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn _sj_daemon_get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found = false
    var i = 0
    while i < all_args.len():
        if found:
            args.push(all_args[i])
        elif all_args[i] == "sj-daemon" or all_args[i] == "sj_daemon":
            found = true
        i = i + 1
    if found:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("/app/sj_daemon/main.spl") or all_args[i] == "src/app/sj_daemon/main.spl":
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args
