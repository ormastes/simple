"""
# sj daemon ECS — system helpers
"""

use std.io_runtime
use app.sj_daemon.ecs.request_component
use app.sj_daemon.ecs.lease_component
use app.sj_daemon.ecs.operation_component

fn queue_drain_count(requests: [RequestComponent]) -> i64:
    requests.len()

fn active_lease_count(leases: [LeaseComponent]) -> i64:
    leases.len()

fn active_operation_count(ops: [OperationComponent]) -> i64:
    ops.len()
