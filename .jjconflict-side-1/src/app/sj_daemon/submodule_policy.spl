"""
# sj daemon — submodule policy
"""

use std.io_runtime
use std.service.lease_manager.{LEASE_EXCLUSIVE, LEASE_SHARED}

struct SubmodulePlan:
    is_submodule: bool
    lease_kind: i64
    warning: text
    auto_pin_cmd: text

fn submodule_plan_none() -> SubmodulePlan:
    SubmodulePlan(
        is_submodule: false,
        lease_kind: LEASE_EXCLUSIVE,
        warning: "",
        auto_pin_cmd: ""
    )

fn classify_submodule(argv: [text]) -> SubmodulePlan:
    if argv.len() < 3i64:
        return submodule_plan_none()
    if argv[0i64] != "git" or argv[1i64] != "submodule":
        return submodule_plan_none()
    if argv[2i64] == "add":
        val path = if argv.len() > 4i64:
            argv[4i64]
        else if argv.len() > 3i64:
            argv[3i64]
        else:
            "submodule"
        return SubmodulePlan(
            is_submodule: true,
            lease_kind: LEASE_EXCLUSIVE,
            warning: "WARN[SUBMODULE]: submodule add is pinned immediately to preserve the gitlink in jj-managed repos",
            auto_pin_cmd: "git commit --no-verify -m 'chore: pin submodule {path}'"
        )
    if argv[2i64] == "status":
        return SubmodulePlan(
            is_submodule: true,
            lease_kind: LEASE_SHARED,
            warning: "",
            auto_pin_cmd: ""
        )
    SubmodulePlan(
        is_submodule: true,
        lease_kind: LEASE_EXCLUSIVE,
        warning: "",
        auto_pin_cmd: ""
    )
