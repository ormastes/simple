# Markdown report generation for documentation coverage.

use app.doc_coverage.types.coverage_result.{CoverageReport, FileCoverage}

fn _coverage_percent(documented: i64, total: i64) -> i64:
    if total <= 0:
        return 0
    (documented * 100) / total

fn _status_icon(percent: i64) -> text:
    if percent >= 90:
        return "✅"
    if percent >= 60:
        return "⚠️"
    "❌"

fn _scope_for_path(path: text) -> text:
    val parts = path.split("/")
    if parts.len() >= 3:
        return parts[0] + "/" + parts[1]
    path

fn generate_coverage_markdown(report: CoverageReport) -> text:
    val overall = _coverage_percent(report.documented_items, report.total_items)
    var md = "# Documentation Coverage Report\n\n"
    md = md + "## Summary\n\n"
    md = md + "**Total Items:** {report.total_items}\n\n"
    md = md + "**Documented:** {report.documented_items}\n\n"
    md = md + "**Missing Docs:** {report.missing_docs}\n\n"
    md = md + "**Overall Status:** {_status_icon(overall)} {overall}%\n\n"
    md = md + "**SDoctest Coverage:** {report.sdoctest_coverage}\n\n"

    md = md + "## Coverage by Scope\n\n"
    md = md + "| Scope | Files | Items | Documented | Coverage % |\n"
    md = md + "|-------|-------|-------|------------|-----------|\n"
    for file in report.files:
        val scope = _scope_for_path(file.path)
        val pct = _coverage_percent(file.documented_items, file.total_items)
        md = md + "| {scope} | 1 | {file.total_items} | {file.documented_items} | {pct}% |\n"
    md = md + "\n"

    md = md + "## Top 10 Files Needing Documentation\n\n"
    md = md + "| File | Missing Docs | Total Items | Coverage % |\n"
    md = md + "|------|--------------|-------------|------------|\n"
    for file in report.files:
        if file.missing_docs > 0:
            val pct = _coverage_percent(file.documented_items, file.total_items)
            md = md + "| `{file.path}` | {file.missing_docs} | {file.total_items} | {pct}% |\n"
    md = md + "\n"

    md = md + "## Missing SDoctest Examples\n\n"
    md = md + "| Function | File | Line |\n"
    md = md + "|----------|------|------|\n"
    for file in report.files:
        for item in file.items:
            if not item.has_sdoctest:
                md = md + "| {item.name} | `{item.file_path}` | {item.line} |\n"
    md
