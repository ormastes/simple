# ITF CLI — Jira Adapter (delegates to acli)
#
# Shells out to `acli jira ...` with --json flag
# Auth is managed by acli itself

use std.nogc_sync_mut.io.process_ops.{process_run}
use std.common.json.{json_parse, json_object_get, json_array_get, json_array_length, json_serialize, json_get_type}
use app.itf.config.{ItfConfig}
use app.itf.errors.{ItfError}


class JiraIssue:
    key: text
    summary: text
    status: text
    assignee: text
    issue_type: text
    priority: text
    description: text

    fn to_display() -> text:
        """Format issue for human-readable display."""
        var lines: [text] = []
        lines = lines + ["{self.key}: {self.summary}"]
        lines = lines + ["Status: {self.status}"]
        if self.assignee != "":
            lines = lines + ["Assignee: {self.assignee}"]
        if self.issue_type != "":
            lines = lines + ["Type: {self.issue_type}"]
        if self.priority != "":
            lines = lines + ["Priority: {self.priority}"]
        if self.description != "":
            lines = lines + [""]
            lines = lines + [self.description]
        lines.join("\n")


fn _run_acli(config: ItfConfig, args: [text]) -> (bool, text, text):
    """Run acli command and return (success, stdout, stderr)."""
    val acli = config.jira_acli_path
    val (stdout, stderr, code) = process_run(acli, args)
    (code == 0, stdout, stderr)


fn _parse_trace_id(stderr: text) -> text:
    """Extract trace ID from acli error output."""
    # Pattern: "unexpected error, trace id: XXXXXXXX"
    val marker = "trace id: "
    val idx = stderr.find(marker)
    if idx >= 0:
        val start = idx + marker.len()
        val rest = stderr[start:]
        # Take until whitespace or end
        var end = 0
        while end < rest.len() and rest[end] != " " and rest[end] != "\n":
            end = end + 1
        return rest[0:end]
    ""


fn jira_view_issue(config: ItfConfig, key: text) -> (bool, JiraIssue, text):
    """View a Jira issue.

    Returns: (success, issue, raw_json)
    """
    val (ok, stdout, stderr) = _run_acli(config, ["jira", "workitem", "view", key, "--json"])

    val empty = JiraIssue(key: "", summary: "", status: "", assignee: "", issue_type: "", priority: "", description: "")

    if not ok:
        val trace = _parse_trace_id(stderr)
        if trace != "":
            return (false, empty, "acli error (trace: {trace}): {stderr}")
        return (false, empty, "acli error: {stderr}")

    val parsed = json_parse(stdout)
    if parsed == nil:
        return (false, empty, "invalid JSON from acli")

    val issue = _parse_jira_issue(parsed)
    (true, issue, stdout)


fn jira_search(config: ItfConfig, jql: text, fields: text, limit: i64) -> (bool, [JiraIssue], text):
    """Search Jira issues with JQL.

    Returns: (success, issues, raw_json)
    """
    var args = ["jira", "workitem", "search", "--jql", jql, "--json", "--limit", "{limit}"]
    if fields != "":
        args = args + ["--fields", fields]

    val (ok, stdout, stderr) = _run_acli(config, args)
    if not ok:
        return (false, [], "acli error: {stderr}")

    val parsed = json_parse(stdout)
    if parsed == nil:
        return (false, [], "invalid JSON from acli")

    # Parse array of issues
    val data_type = json_get_type(parsed)
    var issues: [JiraIssue] = []

    if data_type == "array":
        val arr_len = json_array_length(parsed)
        var i = 0
        while i < arr_len:
            val item = json_array_get(parsed, i)
            issues = issues + [_parse_jira_issue(item)]
            i = i + 1
    else:
        # Single result or nested
        val results = json_object_get(parsed, "issues")
        if results != nil:
            val arr_len = json_array_length(results)
            var i = 0
            while i < arr_len:
                val item = json_array_get(results, i)
                issues = issues + [_parse_jira_issue(item)]
                i = i + 1

    (true, issues, stdout)


fn jira_create_issue(config: ItfConfig, project: text, summary: text, issue_type: text, description: text) -> (bool, text, text):
    """Create a Jira issue.

    Returns: (success, issue_key, error_msg)
    """
    var args = ["jira", "workitem", "create", "--project", project, "--summary", summary, "--json"]
    if issue_type != "":
        args = args + ["--type", issue_type]
    if description != "":
        args = args + ["--description", description]

    val (ok, stdout, stderr) = _run_acli(config, args)
    if not ok:
        return (false, "", "acli error: {stderr}")

    val parsed = json_parse(stdout)
    if parsed != nil:
        val key = json_object_get(parsed, "key")
        if key != nil:
            return (true, json_serialize(key).replace("\"", ""), stdout)

    (true, stdout.trim(), stdout)


fn _parse_jira_issue(obj: any) -> JiraIssue:
    """Parse a Jira issue from JSON."""
    val key = _jira_str(obj, "key")

    # Fields may be nested under "fields" or flat
    val fields = json_object_get(obj, "fields")
    val source = if fields != nil: fields else: obj

    val summary = _jira_str(source, "summary")
    val description = _jira_str(source, "description")
    val priority_obj = json_object_get(source, "priority")
    val priority = if priority_obj != nil: _jira_str(priority_obj, "name") else: ""
    val status_obj = json_object_get(source, "status")
    val status = if status_obj != nil: _jira_str(status_obj, "name") else: ""
    val type_obj = json_object_get(source, "issuetype")
    val issue_type = if type_obj != nil: _jira_str(type_obj, "name") else: ""
    val assignee_obj = json_object_get(source, "assignee")
    val assignee = if assignee_obj != nil: _jira_str(assignee_obj, "displayName") else: ""

    JiraIssue(key: key, summary: summary, status: status, assignee: assignee, issue_type: issue_type, priority: priority, description: description)


fn _jira_str(obj: any, key: text) -> text:
    """Safely extract a string from JSON object."""
    if obj == nil:
        return ""
    val value = json_object_get(obj, key)
    if value == nil:
        return ""
    val s = json_serialize(value)
    if s.starts_with("\"") and s.ends_with("\""):
        return s[1:s.len() - 1]
    s
