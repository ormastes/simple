# ITF CLI — Raw API command
#
# Usage: itf api <GET|POST|PUT|DELETE> <url> [--data JSON] [--header H]
# Direct REST calls to any Atlassian endpoint

use std.nogc_sync_mut.http_client.{http_get, http_post, http_put, http_delete, create_headers, add_header, response_get_status_code, response_get_body, response_get_headers}
use std.common.json.{json_parse, json_pretty}
use app.itf.config.{load_config}
use app.itf.auth.{confluence_auth_header, confluence_api_base}
use app.itf.flags.{_extract_flag, _has_flag, _positional_args}
use app.itf.output.{print_error}


fn handle_api(args: [text]) -> i64:
    """Raw API call. Usage: itf api <METHOD> <url> [--data JSON] [--header H]"""
    if args.len() < 2:
        _print_api_help()
        return 1

    val method = args[0].to_upper()
    val url = args[1]
    val remaining = if args.len() > 2: args[2:] else: []
    val data = _extract_flag(remaining, "--data", "")
    val extra_header = _extract_flag(remaining, "--header", "")
    val verbose = _has_flag(remaining, "--verbose")
    val include = _has_flag(remaining, "--include")

    # Resolve full URL if relative path given
    val config = load_config()
    var full_url = url
    if url.starts_with("/"):
        val base = confluence_api_base(config)
        if base != "":
            full_url = "{base}{url}"

    # Build headers
    val auth = confluence_auth_header(config)

    if verbose:
        print "> {method} {full_url}"
        if auth != "":
            print "> Authorization: Basic ***"
        if data != "":
            print "> Content-Type: application/json"
            print "> "
            print "> {data}"
        print ""

    # Execute request and extract status + body
    var status = 0
    var body = ""

    if method == "GET":
        val response = http_get(full_url)
        status = response_get_status_code(response)
        body = response_get_body(response)
    else if method == "POST":
        val response = http_post(full_url, data)
        status = response_get_status_code(response)
        body = response_get_body(response)
    else if method == "PUT":
        val response = http_put(full_url, data)
        status = response_get_status_code(response)
        body = response_get_body(response)
    else if method == "DELETE":
        val response = http_delete(full_url)
        status = response_get_status_code(response)
        body = response_get_body(response)
    else:
        print_error("unsupported method: {method}. Use GET, POST, PUT, or DELETE.")
        return 1

    if include or verbose:
        print "HTTP {status}"
        print ""

    # Pretty-print JSON if possible
    val parsed = json_parse(body)
    if parsed != nil:
        print json_pretty(parsed)
    else:
        print body

    if status >= 200 and status < 300:
        0
    else:
        1


fn _print_api_help():
    """Print API command help."""
    print "Usage: itf api <METHOD> <URL> [flags]"
    print ""
    print "Make raw REST API calls (like gh api)."
    print ""
    print "Methods: GET, POST, PUT, DELETE"
    print ""
    print "Flags:"
    print "  --data JSON     Request body"
    print "  --header H      Extra header (Name: Value)"
    print "  --verbose        Print request/response details"
    print "  --include        Print response headers"
    print ""
    print "Examples:"
    print "  itf api GET /pages?limit=5"
    print "  itf api POST /pages --data '{\"spaceId\":\"123\",\"title\":\"Test\"}'"
