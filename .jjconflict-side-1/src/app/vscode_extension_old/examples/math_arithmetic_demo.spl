# Arithmetic Math Rendering Demo
# Open this file in VSCode with the Simple extension enabled.
# Hover on each math block or enable inline rendering to verify output.

# Basic arithmetic
val add_demo = m{ 2 + 3 }
val sub_demo = m{ 10 - 3 }
val mul_demo = m{ 4 * 5 }
val div_demo = m{ 15 / 3 }

# Fraction and power
val frac_demo = m{ frac(1, 2) + alpha^2 }
val nested_frac_demo = m{ frac(1, 1 + exp(-x)) }

# Roots, sums, and integrals
val sqrt_demo = m{ sqrt(x^2 + y^2) }
val sum_demo = m{ sum(i, 0..10) i^2 }
val int_demo = m{ int(x, 0..1) x^2 }

# Matrix-style arithmetic
val transpose_demo = m{ A' + B' }
val mixed_demo = m{ theta - alpha * frac(partial L, partial theta) }
