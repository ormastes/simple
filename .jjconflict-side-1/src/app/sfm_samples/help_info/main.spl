# AC-11/12: native entry driving the SFM Help/Info menu.
#
# Renders the help text and verifies it surfaces the SFM marker and the
# VERSION.md version, printing OK/FAIL.
# Run: bin/simple run src/app/sfm_samples/help_info/main.spl

use app.sfm_samples.help_info.help_menu.{help_info_text}
use std.sfm.version.{read_version_md}

fn ok(cond: bool, label: text):
    if cond:
        print("OK " + label)
    else:
        print("FAIL " + label)

fn main():
    val ver: text = read_version_md("VERSION.md")
    val text: text = help_info_text()
    print(text)
    ok(text.contains("SFM"), "help surfaces SFM marker")
    ok(text.contains(ver), "help surfaces VERSION.md version " + ver)
    ok(ver.len() > 0, "VERSION.md version non-empty")
