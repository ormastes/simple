# Assistant Session Views and Queries
#
# Reads the file-backed assistant store and exposes small reusable views for
# session detail, compact briefs, and timeline/notification collection.

use ..main_lazy_json.{extract_field}
use .types.{
    AssistantSessionRecord, AssistantTimelineRecord, assistant_first_non_empty,
    assistant_timeline_severity, assistant_timeline_title, assistant_timeline_detail
}
use .session_store.{
    assistant_store_load_session, assistant_store_timeline_record_from_json_text,
    assistant_store_resolve_root, assistant_store_timeline_path, assistant_store_notifications_path
}

use std.io_runtime.{file_exists, file_read}

# =========================================================================
# Public Views
# =========================================================================

fn assistant_store_session_detail(root: text, session_id: text) -> AssistantSessionRecord?:
    assistant_store_load_session(root, session_id)

fn assistant_store_session_brief(root: text, session_id: text) -> text:
    val loaded = assistant_store_load_session(root, session_id)
    match loaded:
        case Some(session):
            val timeline_count = assistant_store_count_jsonl_entries(assistant_store_timeline_path(root, session_id))
            val notification_count = assistant_store_count_jsonl_entries(assistant_store_notifications_path(root, session_id))
            var lines: [text] = []
            lines.push("session: " + session.session_id)
            lines.push("name: " + session.name)
            lines.push("state: " + session.state)
            lines.push("mode: " + session.mode)
            if session.summary.trim() != "":
                lines.push("summary: " + session.summary)
            lines.push("timeline events: " + str(timeline_count))
            lines.push("notifications: " + str(notification_count))
            if session.last_event_kind.trim() != "":
                var tail = "last event: " + session.last_event_kind
                if session.last_event_detail.trim() != "":
                    tail = tail + " - " + session.last_event_detail
                lines.push(tail)
            return lines.join("\n")
        case nil:
            pass
    ""

fn assistant_store_collect_timeline(root: text, session_id: text, limit: i64, since_ts: i64) -> [AssistantTimelineRecord]:
    assistant_store_collect_stream(assistant_store_timeline_path(root, session_id), limit, since_ts)

fn assistant_store_collect_notifications(root: text, session_id: text, limit: i64, since_ts: i64) -> [AssistantTimelineRecord]:
    assistant_store_collect_stream(assistant_store_notifications_path(root, session_id), limit, since_ts)

# =========================================================================
# Collection Helpers
# =========================================================================

fn assistant_store_collect_stream(path: text, limit: i64, since_ts: i64) -> [AssistantTimelineRecord]:
    if path.trim() == "" or not file_exists(path):
        return []
    var events: [AssistantTimelineRecord] = []
    val content = file_read(path)
    if content.trim() == "":
        return events
    for raw in content.split("\n"):
        val line = raw.trim()
        if line == "":
            continue
        val event = assistant_store_timeline_record_from_json_text(line)
        if since_ts > 0 and event.timestamp_ms <= since_ts:
            continue
        events.push(event)
    if limit <= 0 or events.len() <= limit:
        return events
    var tail: [AssistantTimelineRecord] = []
    var i = events.len() - limit
    while i < events.len():
        tail.push(events[i])
        i = i + 1
    tail

fn assistant_store_count_jsonl_entries(path: text) -> i64:
    if path.trim() == "" or not file_exists(path):
        return 0
    val content = file_read(path)
    if content.trim() == "":
        return 0
    var count: i64 = 0
    for raw in content.split("\n"):
        if raw.trim() != "":
            count = count + 1
    count
