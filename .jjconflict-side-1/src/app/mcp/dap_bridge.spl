# MCP-to-DAP Bridge
#
# Manages DAP server subprocesses via file-based IPC.
# Each debug session spawns a `bin/simple dap --daemon --session <id>` process
# and communicates via .build/dap_sessions/<id>/requests/ and responses/.
#
# For now, this is a lightweight bridge that spawns DAP processes and
# translates MCP tool calls to DAP requests via file-based IPC.

use std.nogc_sync_mut.debug.remote.session_model.{
    DebugCapabilitySet, DebugConnectionHints, DebugTargetDescriptor, DebugBackendRegistration,
    DebugBootstrapPlan, debug_target_descriptor, debug_select_backend,
    debug_bootstrap_plan
}

extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_is_running(pid: i64) -> bool
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_time_now_unix_micros() -> i64

# Session registry (in-process, per MCP server instance)
class DapSession:
    id: text
    program: text
    target_type: text
    pid: i64
    state: text
    next_bp_id: i64
    breakpoints: [text]
    watches: [text]
    arch: text
    exec_mode: text
    vendor: text
    probe_kind: text
    server_kind: text
    transport: text
    backend_id: text
    attach_semantics: text
    persistent_session: bool
    capabilities: [text]
    host: text
    port: i32
    config_path: text
    probe_serial: text
    bitbang_host: text
    bitbang_port: i32
    jtag_device: text
    bootstrap_discovery_command: text
    bootstrap_launch_command: text
    bootstrap_attach_target: text
    bootstrap_config: text
    bootstrap_notes: [text]

var DAP_SESSIONS: [DapSession] = []
var DAP_NEXT_ID: i64 = 1

fn dap_empty_backend(target: DebugTargetDescriptor) -> DebugBackendRegistration:
    DebugBackendRegistration(
        backend_id: "",
        session_type: "",
        display_name: "",
        transport: target.transport,
        exec_mode: target.exec_mode,
        vendors: [],
        capabilities: DebugCapabilitySet.create(false, false, false, false, false, false),
        default_port: 0,
        attach_semantics: ""
    )

fn dap_make_connection_hints(host: text, port: text, config_path: text, probe_serial: text,
                             bitbang_host: text, bitbang_port: text, jtag_device: text) -> DebugConnectionHints:
    var hints = DebugConnectionHints.empty()
    if host.trim() != "":
        hints.host = host.trim()
    if port.trim() != "":
        hints.port = int(port)
    if config_path.trim() != "":
        hints.config_path = config_path.trim()
    if probe_serial.trim() != "":
        hints.probe_serial = probe_serial.trim()
    if bitbang_host.trim() != "":
        hints.bitbang_host = bitbang_host.trim()
    if bitbang_port.trim() != "":
        hints.bitbang_port = int(bitbang_port)
    if jtag_device.trim() != "":
        hints.jtag_device = jtag_device.trim()
    hints

fn dap_is_embedded_session(target_type: text, target: DebugTargetDescriptor, backend: DebugBackendRegistration) -> bool:
    if target_type == "t32" or target_type == "t32_gdb" or target_type == "openocd" or target_type == "intel_jtagd":
        return true
    val transport = target.transport.to_string()
    if transport == "openocd_jtag" or transport == "openocd_remote_bitbang" or transport == "intel_jtagd" or transport == "trace32_native" or transport == "trace32_gdb":
        return true
    backend.session_type == "openocd" or backend.session_type == "intel_jtagd" or backend.session_type == "t32" or backend.session_type == "t32_gdb"

fn dap_create_session(program: text, target_type: text, transport: text, arch: text, exec_mode: text,
                      vendor: text, probe_kind: text, server_kind: text, host: text, port: text,
                      config_path: text, probe_serial: text, bitbang_host: text,
                      bitbang_port: text, jtag_device: text, persistent_session: text) -> DapSession:
    val sid = "dap-" + str(DAP_NEXT_ID)
    DAP_NEXT_ID = DAP_NEXT_ID + 1
    val target = debug_target_descriptor(target_type, transport, arch, exec_mode, vendor, probe_kind, server_kind)
    val backend_result = debug_select_backend(target)
    var backend = dap_empty_backend(target)
    var backend_error = ""
    match backend_result:
        Ok(selected):
            backend = selected
        Err(err):
            backend_error = err
    val hints = dap_make_connection_hints(host, port, config_path, probe_serial, bitbang_host, bitbang_port, jtag_device)
    var bootstrap_plan = DebugBootstrapPlan(
        backend_id: "",
        discovery_command: "",
        launch_command: "",
        attach_target: "",
        generated_config: "",
        notes: []
    )
    if backend_error == "":
        match debug_bootstrap_plan(target, hints, program):
            Ok(plan):
                bootstrap_plan = plan
            Err(err):
                backend_error = err
    var persistent = false
    if persistent_session == "true" or persistent_session == "1":
        persistent = true
    if backend_error == "" and backend.capabilities.persistent_session:
        persistent = true

    var pid = -1
    var state = "configured"
    if backend_error != "":
        state = "failed"
    elif not dap_is_embedded_session(target_type, target, backend):
        val _bin = _mcp_find_simple_binary()
        pid = rt_process_spawn_async(_bin, ["dap", "--session", sid, program])
        if pid > 0:
            state = "initialized"
        else:
            state = "failed"
    elif target.exec_mode.to_string() == "rtl_sim":
        state = "bootstrap_ready"
    else:
        state = "configured"

    var capabilities: [text] = []
    var bootstrap_notes: [text] = []
    if backend_error == "":
        capabilities = backend.capabilities.to_list()
        bootstrap_notes = bootstrap_plan.notes
    else:
        bootstrap_notes = [backend_error]

    var session = DapSession(
        id: sid,
        program: program,
        target_type: target_type,
        pid: pid,
        state: state,
        next_bp_id: 1,
        breakpoints: [],
        watches: [],
        arch: target.arch.to_string(),
        exec_mode: target.exec_mode.to_string(),
        vendor: target.vendor,
        probe_kind: target.probe_kind,
        server_kind: target.server_kind,
        transport: target.transport.to_string(),
        backend_id: backend.backend_id,
        attach_semantics: backend.attach_semantics,
        persistent_session: persistent,
        capabilities: capabilities,
        host: hints.host,
        port: hints.port,
        config_path: hints.config_path,
        probe_serial: hints.probe_serial,
        bitbang_host: hints.bitbang_host,
        bitbang_port: hints.bitbang_port,
        jtag_device: hints.jtag_device,
        bootstrap_discovery_command: bootstrap_plan.discovery_command,
        bootstrap_launch_command: bootstrap_plan.launch_command,
        bootstrap_attach_target: bootstrap_plan.attach_target,
        bootstrap_config: bootstrap_plan.generated_config,
        bootstrap_notes: bootstrap_notes
    )
    DAP_SESSIONS = DAP_SESSIONS + [session]
    session

fn dap_find_session(session_id: text) -> DapSession:
    for s in DAP_SESSIONS:
        if s.id == session_id:
            return s
    DapSession(
        id: "", program: "", target_type: "", pid: -1, state: "not_found",
        next_bp_id: 1, breakpoints: [], watches: [], arch: "", exec_mode: "",
        vendor: "", probe_kind: "", server_kind: "", transport: "", backend_id: "",
        attach_semantics: "", persistent_session: false, capabilities: [],
        host: "", port: 0, config_path: "", probe_serial: "", bitbang_host: "",
        bitbang_port: 0, jtag_device: "", bootstrap_discovery_command: "",
        bootstrap_launch_command: "", bootstrap_attach_target: "", bootstrap_config: "",
        bootstrap_notes: []
    )

fn dap_close_session(session_id: text) -> bool:
    var new_sessions: [DapSession] = []
    var found = false
    for s in DAP_SESSIONS:
        if s.id == session_id:
            found = true
            if s.pid > 0:
                rt_process_kill(s.pid)
        else:
            new_sessions.push(s)
    DAP_SESSIONS = new_sessions
    found

fn dap_update_session(session: DapSession):
    var new_sessions: [DapSession] = []
    for s in DAP_SESSIONS:
        if s.id == session.id:
            new_sessions.push(session)
        else:
            new_sessions.push(s)
    DAP_SESSIONS = new_sessions

fn dap_add_breakpoint(session_id: text, file: text, line: text, condition: text) -> (i64, text):
    """Returns (bp_id, status)"""
    var session = dap_find_session(session_id)
    if session.id == "":
        return (-1, "session not found")
    val bp_id = session.next_bp_id
    session.next_bp_id = bp_id + 1
    val bp_entry = str(bp_id) + ":" + file + ":" + line
    session.breakpoints = session.breakpoints + [bp_entry]
    dap_update_session(session)
    (bp_id, "set")

fn dap_remove_breakpoint(session_id: text, bp_id_str: text) -> bool:
    var session = dap_find_session(session_id)
    if session.id == "":
        return false
    var new_bps: [text] = []
    var found = false
    for bp in session.breakpoints:
        if bp.starts_with(bp_id_str + ":"):
            found = true
        else:
            new_bps.push(bp)
    session.breakpoints = new_bps
    dap_update_session(session)
    found

fn dap_list_sessions() -> [DapSession]:
    # Refresh running state
    var updated: [DapSession] = []
    for s in DAP_SESSIONS:
        var session = s
        if session.pid > 0 and not rt_process_is_running(session.pid):
            session.state = "terminated"
        updated.push(session)
    DAP_SESSIONS = updated
    DAP_SESSIONS

fn dap_session_supports(session: DapSession, capability: text) -> bool:
    for entry in session.capabilities:
        if entry == capability:
            return true
    false
