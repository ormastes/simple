# Literal DirectX/Metal-on-Vulkan proof for Linux hosts.  Runtime-selected
# backend text is intentionally avoided because that route is separately
# tracked as a compiler-resolution bug.
use std.common.crypto.sha256.{sha256_text}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use common.renderdoc.backend_render_record.{backend_render_field, backend_render_record_finalize, validate_backend_render_record}
use app.test.renderdoc_runtime_ops.{vulkan_renderdoc_device_pointer}

fn _pixel_hash(pixels: [u32]) -> text:
    var text = ""
    for pixel in pixels:
        text = text + pixel.to_text() + ","
    sha256_text(text)

fn _nonblank_pixel_count(pixels: [u32]) -> i64:
    var count: i64 = 0
    for pixel in pixels:
        if pixel != 0:
            count = count + 1
    count

fn _print_directx_vulkan_record(pixels: [u32]):
    val pixel_hash = _pixel_hash(pixels)
    val device = vulkan_renderdoc_device_pointer()
    val fields = [
        backend_render_field("commands.000.kind", "clear", "text", true),
        backend_render_field("commands.001.kind", "draw_rect_filled", "text", true),
        backend_render_field("commands.002.kind", "draw_circle_filled", "text", true),
        backend_render_field("commands.count", "3", "i64", true),
        backend_render_field("frame.backend_handle", device.to_text(), "i64", false),
        backend_render_field("frame.complete", "true", "bool", true),
        backend_render_field("producer.actual_backend", "vulkan", "text", false),
        backend_render_field("producer.adapter", "directx-on-vulkan", "text", false),
        backend_render_field("producer.execution_kind", "translated", "text", false),
        backend_render_field("producer.native_api", "vulkan", "text", false),
        backend_render_field("producer.requested_backend", "directx", "text", false),
        backend_render_field("producer.translation_layer", "directx-on-vulkan", "text", false),
        backend_render_field("readback.content_hash", pixel_hash, "sha256", true),
        backend_render_field("readback.format", "argb-u32", "text", true),
        backend_render_field("readback.height", "48", "i64", true),
        backend_render_field("readback.nonblank_pixel_count", _nonblank_pixel_count(pixels).to_text(), "i64", true),
        backend_render_field("readback.pixel_count", pixels.len().to_text(), "i64", true),
        backend_render_field("readback.source", "engine2d.read_pixels", "text", true),
        backend_render_field("readback.stride", "256", "i64", true),
        backend_render_field("readback.width", "64", "i64", true),
        backend_render_field("target.content_hash", pixel_hash, "sha256", true),
        backend_render_field("target.format", "argb-u32", "text", true),
        backend_render_field("target.height", "48", "i64", true),
        backend_render_field("target.stride", "256", "i64", true),
        backend_render_field("target.width", "64", "i64", true)
    ]
    val record = backend_render_record_finalize("engine2d-directx-on-vulkan", fields)
    match validate_backend_render_record(record):
        Ok(_): print("directx_on_vulkan_record_valid=1 semantic_hash=" + record.semantic_hash + "\n")
        Err(error): print("directx_on_vulkan_record_valid=0 reason=" + error.code + "\n")

fn _directx_on_vulkan_hash() -> Result<text, text>:
    match Engine2D.create_requested_backend(64, 48, "directx-on-vulkan"):
        Err(reason): Err(reason)
        Ok(engine):
            if engine.backend_name() != "directx-on-vulkan":
                return Err("unexpected-backend=" + engine.backend_name())
            engine.clear(0xFF224466u32)
            engine.draw_rect_filled(8, 8, 40, 24, 0xFFCC2020u32)
            engine.draw_circle_filled(48, 36, 8, 0xFF30C060u32)
            engine.present()
            val pixels = engine.read_pixels()
            _print_directx_vulkan_record(pixels)
            val hash = _pixel_hash(pixels)
            engine.shutdown()
            Ok(hash)

fn _metal_on_vulkan_hash() -> Result<text, text>:
    match Engine2D.create_requested_backend(64, 48, "metal-on-vulkan"):
        Err(reason): Err(reason)
        Ok(engine):
            if engine.backend_name() != "metal-on-vulkan":
                return Err("unexpected-backend=" + engine.backend_name())
            engine.clear(0xFF224466u32)
            engine.draw_rect_filled(8, 8, 40, 24, 0xFFCC2020u32)
            engine.draw_circle_filled(48, 36, 8, 0xFF30C060u32)
            engine.present()
            val hash = _pixel_hash(engine.read_pixels())
            engine.shutdown()
            Ok(hash)

fn main():
    match _directx_on_vulkan_hash():
        Err(reason): print("directx_on_vulkan_status=fail reason=" + reason + "\n")
        Ok(directx_hash):
            print("directx_on_vulkan_status=pass pixel_hash=" + directx_hash + "\n")
            match _metal_on_vulkan_hash():
                Err(reason): print("metal_on_vulkan_status=fail reason=" + reason + "\n")
                Ok(metal_hash):
                    print("metal_on_vulkan_status=pass pixel_hash=" + metal_hash + "\n")
                    print("translation_pair_equal=" + (directx_hash == metal_hash).to_text() + "\n")
