# Tauri Application Main Loop
#
# Runs the Tauri mode: loads .ui.sdn, renders HTML via IPC,
# polls stdin for JSON events from the Tauri shell.

use common.ui.widget.{UIState, UITree, UIEvent, UIMode}
use nogc_sync_mut.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state, update_state, update_tree, is_quit_event}
use app.ui.tauri.backend.{TauriBackend, tauri_render_ipc_json}
use app.ui.ipc.protocol.{parse_ipc_message}
use app.ui.tauri.async_app.{run_shared_wm_tauri}
use app.io.env_ops.{env_get}
use std.nogc_sync_mut.concurrent.thread.{thread_sleep}
use std.sffi.cli.{cli_get_args}
use std.io_runtime.{file_exists, read_file}

extern fn rt_stdin_read_line() -> text?

# =========================================================================
# Tauri App
# =========================================================================

class TauriApp:
    file_path: text
    state: UIState
    backend: TauriBackend
    running: bool
    last_file_content: text

    static fn new(file_path: text, port: i32) -> Result<TauriApp, text>:
        return TauriApp.new_from_backend(file_path, TauriBackend.new(port))

    static fn new_mobile(file_path: text, port: i32) -> Result<TauriApp, text>:
        """Mobile (iOS / Android) Tauri app — touch-enabled backend, same
        render path as desktop."""
        return TauriApp.new_from_backend(file_path, TauriBackend.new_mobile(port))

    static fn new_from_backend(file_path: text, backend_result: Result<TauriBackend, text>) -> Result<TauriApp, text>:
        val tree_result = parse_ui_to_tree(file_path)
        match tree_result:
            Err(e):
                return Err(e)
            Ok(tree):
                val state = init_state(tree)
                match backend_result:
                    Err(e):
                        return Err(e)
                    Ok(backend):
                        val init_result = backend.init()
                        match init_result:
                            Err(e):
                                return Err(e)
                            Ok(_):
                                pass_dn

                        val content = if file_exists(file_path):
                            read_file(file_path) ?? ""
                        else:
                            ""

                        return Ok(TauriApp(
                            file_path: file_path,
                            state: state,
                            backend: backend,
                            running: true,
                            last_file_content: content
                        ))

    me run():
        """Main Tauri IPC loop."""
        # Initial render
        self.send_render()

        while self.running:
            val event = self.poll_ipc()

            if event != nil:
                match event:
                    UIEvent.Quit:
                        self.running = false
                    _:
                        self.state = update_state(self.state, event)
                        self.check_file_changes()
                        self.send_render()
            else:
                # No event — check for file changes, then yield. Without this
                # sleep the loop spin-pegs a CPU core (stdin is EOF under the
                # Tauri shell, so poll_ipc returns nil every iteration), which
                # starves the host UI thread and hangs the window.
                self.check_file_changes()
                thread_sleep(16)

        # Cleanup
        self.backend.shutdown()

    fn poll_ipc() -> UIEvent?:
        """Read a line from stdin and parse as IPC message."""
        val line = rt_stdin_read_line()
        if line == nil:
            return nil
        if line == "":
            return nil
        return parse_ipc_message(line)

    fn send_render():
        """Render the current state and send via IPC to stdout."""
        val ipc_msg = tauri_render_ipc_json(self.state, self.backend.viewport_width(), self.backend.viewport_height())
        print ipc_msg


    me check_file_changes():
        """Check if the .ui.sdn file has changed and reload if so."""
        if not file_exists(self.file_path):
            return

        val current_content = read_file(self.file_path) ?? ""
        if current_content != self.last_file_content:
            self.last_file_content = current_content
            val tree_result = parse_ui_to_tree(self.file_path)
            match tree_result:
                Ok(new_tree):
                    self.state = update_tree(self.state, new_tree)
                Err(e):
                    # Keep old state on parse error
                    pass_dn

fn tauri_shared_wm_requested(args: [text], env_val: text) -> bool:
    for a in args:
        if a == "--shared-wm":
            return true
    env_val == "1"

fn tauri_shared_wm_error() -> text:
    return "Tauri shared WM mode routes through the shared host compositor entrypoint."

# =========================================================================
# Entry Point
# =========================================================================

fn run_tauri(file_path: text, port: i32) -> i64:
    """Start Tauri mode for a .ui.sdn file."""
    val args = cli_get_args()
    val shared_wm_env = env_get("SIMPLE_UI_TAURI_SHARED_WM")
    if tauri_shared_wm_requested(args, shared_wm_env):
        return run_shared_wm_tauri("Simple Window Manager")
    if not file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    val app_result = TauriApp.new(file_path, port)
    match app_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(app):
            app.run()
            return 0

fn run_tauri_mobile(file_path: text, port: i32) -> i64:
    """Start Tauri mode for a .ui.sdn file with a mobile (touch) backend.

    The render path is identical to desktop; the same bundle runs inside the
    Tauri iOS / Android webview shell (tools/tauri-shell)."""
    val args = cli_get_args()
    val shared_wm_env = env_get("SIMPLE_UI_TAURI_SHARED_WM")
    if tauri_shared_wm_requested(args, shared_wm_env):
        return run_shared_wm_tauri("Simple Window Manager")
    if not file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    val app_result = TauriApp.new_mobile(file_path, port)
    match app_result:
        Err(e):
            print "Error: {e}"
            return 1
        Ok(app):
            app.run()
            return 0
