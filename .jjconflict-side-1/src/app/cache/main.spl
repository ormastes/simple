# Simple CLI - cache command
# Package cache management

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod (file_exists, dir_create, dir_remove_all, is_dir, home, file_size, dir_list)
use std.log.{error, warn, info, debug}

fn print_help():
    print "Usage: simple cache <subcommand>"
    print ""
    print "Manage the package cache (~/.simple/cache/)."
    print ""
    print "Subcommands:"
    print "  list         List cached packages"
    print "  clean        Remove all cached packages"
    print "  path         Print cache directory path"
    print "  info         Show cache size and statistics"
    print ""
    print "Options:"
    print "  --json       Output as JSON"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help   Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _json_array(names: [text]) -> text:
    var parts: [text] = []
    var i = 0
    while i < names.len():
        parts.push("\"{names[i]}\"")
        i = i + 1
    "[" + parts.join(",") + "]"

fn get_cache_dir() -> text:
    val home = home()
    "{home}/.simple/cache"

fn handle_list(as_json: bool, progress: text) -> i64:
    val cache_dir = get_cache_dir()
    if not is_dir(cache_dir):
        if as_json:
            print "{\"command\":\"list\",\"cache_dir\":\"{cache_dir}\",\"count\":0,\"items\":[]}"
            return 0
        print "Cache is empty."
        return 0

    val entries = dir_list(cache_dir)
    if as_json:
        print "{\"command\":\"list\",\"cache_dir\":\"{cache_dir}\",\"count\":{entries.len()},\"items\":" + _json_array(entries) + "}"
        return 0
    if progress != "summary":
        val progress_line = render_progress(progress, entries.len(), entries.len(), "cache")
        if progress_line != "":
            print progress_line

    print "Cached packages in {cache_dir}:"
    print ""
    if entries.len() == 0:
        print "  (empty)"
    else:
        for entry in entries:
            print "  {entry}"
    print ""
    print "{entries.len()} items cached."
    0

fn handle_clean() -> i64:
    val cache_dir = get_cache_dir()
    if not is_dir(cache_dir):
        print "Cache is already empty."
        return 0

    val result = dir_remove_all(cache_dir)
    if result != 0:
        error("cache", "failed to clean cache directory")
        return 1

    # Recreate empty cache dir
    dir_create(cache_dir, true)

    print "Cache cleaned."
    0

fn handle_path() -> i64:
    print get_cache_dir()
    0

fn handle_info(as_json: bool, progress: text) -> i64:
    val cache_dir = get_cache_dir()
    var exists = is_dir(cache_dir)
    var count = 0
    if exists:
        val entries = dir_list(cache_dir)
        count = entries.len()
    if as_json:
        print "{\"command\":\"info\",\"cache_dir\":\"{cache_dir}\",\"exists\":{exists},\"count\":{count}}"
        return 0
    if progress != "summary":
        val progress_line = render_progress(progress, count, count, "cache")
        if progress_line != "":
            print progress_line
    print "Cache directory: {cache_dir}"
    print ""
    if not exists:
        print "Status: empty (directory does not exist)"
    else:
        print "Status: exists"
        print "Items: {count}"
    0

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("cache", log_opts.error)
        return 1

    if args.len() == 0:
        print_help()
        return 0

    var subcommand = ""
    var as_json = false
    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        elif subcommand == "":
            subcommand = arg
        ai = ai + 1

    if log_opts.log_mode == "json":
        as_json = true

    if subcommand == "":
        print_help()
        return 0

    if subcommand == "-h" or subcommand == "--help":
        print_help()
        return 0

    match subcommand:
        case "list":
            return handle_list(as_json, log_opts.progress)
        case "clean":
            return handle_clean()
        case "path":
            return handle_path()
        case "info":
            return handle_info(as_json, log_opts.progress)
        case _:
            error("cache", "unknown subcommand '{subcommand}'")
            print ""
            print_help()
            return 1
