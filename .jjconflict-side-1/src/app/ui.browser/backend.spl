# Browser Engine Render Backend
#
# Bridges the UI render library to the canonical widget Draw IR + Engine2D
# pipeline. DOM/CSS remains for semantics, hit testing, and Chromium
# compatibility; pure-Simple pixels come from the widget composition.
#
# Architecture:
#   App -> BrowserBackend -> widget_tree_to_draw_ir -> Engine2D

use common.ui.widget.{UITree, UIState, UIEvent, WidgetNode, WidgetRect, widget_store_revision}
use common.ui.widget.{UIMode}
use common.layout.box_model.{LayoutBox, BoxKind, BoxModel}
use common.ui.semantic_contract.{SEMANTIC_UI_STAGE_RENDERER, SEMANTIC_UI_STATUS_AVAILABLE, SemanticUiSnapshot, semantic_ui_snapshot_from_state_with_capabilities, semantic_ui_snapshot_to_json}
use common.ui.semantic_contract.{semantic_ui_snapshot_transport_json}
use common.ui.draw_ir.{DRAW_IR_BACKEND_GPU}
use common.ui.widget_draw_ir.{widget_tree_to_draw_ir}
use common.ui.web_render_api.{WEB_RENDER_ENGINE2D_STATUS_NOT_REQUESTED, WEB_RENDER_QUEUE_STATUS_NOT_REQUESTED, WEB_RENDER_TARGET_PURE_SIMPLE, WebRenderArtifact, WebRenderHostWindowCommand, WebRenderPatchEnvelope, WebRenderSnapshotEnvelope, web_render_adapter_request, web_render_body_html, web_render_full_html, web_render_capabilities_for_target, web_render_host_window_command_to_json, web_render_input_envelope_from_event, web_render_input_envelope_to_json, web_render_ipc_json_with_html_and_semantic, web_render_patch_envelope_to_json, web_render_snapshot_envelope_to_json, web_render_optimization_profile}
use common.ui.web_render_api.{WebRenderRequest, web_render_pixel_artifact, web_render_engine2d_compatibility_artifact}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.web.html.{generate_css}
use app.ui.browser.event_bridge.{translate_key_event, translate_mouse_event, hit_test}
use std.gc_async_mut.ui.web_render_pixel_backend.{web_render_draw_ir_request_to_pixel_artifact, web_render_resolved_engine2d_backend_name}
use std.gc_async_mut.gpu.browser_engine.web_render_backend.{web_render_backend, web_render_backend_names}
use std.nogc_async_mut.gpu.engine2d.host_gpu_draw_ir_event_flow.{engine2d_host_gpu_draw_ir_event_flow, engine2d_host_gpu_draw_ir_event_flow_summary}
use std.gpu.engine2d.helpers_availability.{backend_canonical_name}
use std.io_runtime.{write_file, time_now_unix_micros}

# Gap B (backend_isolation_plan.md): WebRenderer facade selector, distinct
# from the Engine2D `--backend` selector above. "pure_simple" (default)
# executes the canonical widget Draw IR composition through Engine2D;
# "chromium" routes HTML through the
# WebRenderBackend facade's real offscreen-Chromium engine instead.
pub val WEB_RENDER_ENGINE_PURE_SIMPLE: text = "pure_simple"
pub val WEB_RENDER_ENGINE_CHROMIUM: text = "chromium"

pub fn web_render_engine_is_known(name: text) -> bool:
    """Loud-fail gate for `--web-engine`: only the two real WebRenderBackend
    engines are accepted here (no silent alias-to-default normalization like
    the facade's own internal `_normalize_web_backend` does)."""
    val names = web_render_backend_names()
    var i = 0
    while i < names.len():
        if names[i] == name:
            return true
        i = i + 1
    false

fn browser_backend_time_us() -> i64:
    time_now_unix_micros()

fn browser_semantic_render_ipc_json(state: UIState, viewport_w: i32, viewport_h: i32) -> text:
    val theme = state.tree.theme_name()
    val css = generate_css(theme)
    val body_html = render_html_tree(state.tree.root_node(), state)
    val req = web_render_adapter_request(WEB_RENDER_TARGET_PURE_SIMPLE, "", "", body_html, css, "", viewport_w, viewport_h)
    web_render_ipc_json_with_html_and_semantic(req, web_render_full_html(req), semantic_ui_snapshot_to_json(browser_semantic_snapshot(state)))

fn browser_backend_chromium_pixel_artifact(req: WebRenderRequest, width: i32, height: i32, full_html: text) -> WebRenderArtifact:
    """Gap B chromium lane: render through the real WebRenderBackend facade
    (offscreen Chromium) instead of the pure_simple Engine2D cache path, and
    tag the resulting artifact with honest engine2d provenance — status
    "compatibility_renderer" (not Engine2D-backed) and backend "chromium" —
    so callers can tell which engine actually rendered the frame.

    The former interpret/native alias failure for `web_backend_env_get` is fixed
    in web_render_backend.spl by importing the env facade directly instead of
    routing through the mod_stub alias chain."""
    val chromium_pixels = web_render_backend(WEB_RENDER_ENGINE_CHROMIUM, width, height).render_html_to_pixels(full_html)
    web_render_engine2d_compatibility_artifact(
        web_render_pixel_artifact(req, chromium_pixels),
        WEB_RENDER_ENGINE_CHROMIUM,
        "rendered via WebRenderBackend facade (chromium engine, not Engine2D)"
    )

# =========================================================================
# Framebuffer — CPU-side pixel buffer for software and GPU readback
# =========================================================================

class Framebuffer:
    width: i32
    height: i32
    pixels: [i32]

    static fn create(w: i32, h: i32) -> Framebuffer:
        """Create a framebuffer filled with a default background color."""
        val pixel_count = w * h
        # Default background: dark gray (0xFF2D2D2D in ARGB).
        val px = [0x2D2D2D; pixel_count]
        return Framebuffer(width: w, height: h, pixels: px)

    me clear(color: i32):
        """Clear the framebuffer to a solid color."""
        val count = self.width * self.height
        self.pixels = [color; count]

    fn pixel_at(x: i32, y: i32) -> i32:
        """Read a pixel value at (x, y)."""
        if x < 0 or x >= self.width or y < 0 or y >= self.height:
            return 0
        val idx = y * self.width + x
        return self.pixels[idx]

    me set_pixel(x: i32, y: i32, color: i32):
        """Write a pixel value at (x, y)."""
        if x < 0 or x >= self.width or y < 0 or y >= self.height:
            return
        val idx = y * self.width + x
        self.pixels[idx] = color

# =========================================================================
# DomNode — lightweight DOM representation for layout
# =========================================================================

class DomNode:
    tag: text
    id: text
    classes: [text]
    text_content: text
    children: [DomNode]
    style_width: f64
    style_height: f64

    static fn element(tag: text, id: text) -> DomNode:
        return DomNode(
            tag: tag, id: id, classes: [],
            text_content: "", children: [],
            style_width: 0.0, style_height: 0.0
        )

    static fn text_node(content: text) -> DomNode:
        return DomNode(
            tag: "#text", id: "", classes: [],
            text_content: content, children: [],
            style_width: 0.0, style_height: 0.0
        )

    fn add_child(child: DomNode) -> DomNode:
        var new_children = self.children
        new_children.push(child)
        return DomNode(
            tag: self.tag, id: self.id, classes: self.classes,
            text_content: self.text_content, children: new_children,
            style_width: self.style_width, style_height: self.style_height
        )

    fn add_class(cls: text) -> DomNode:
        var new_classes = self.classes
        new_classes.push(cls)
        return DomNode(
            tag: self.tag, id: self.id, classes: new_classes,
            text_content: self.text_content, children: self.children,
            style_width: self.style_width, style_height: self.style_height
        )

# =========================================================================
# BrowserBackend
# =========================================================================

class BrowserBackend:
    width: i32
    height: i32
    gpu_backend_name: text
    framebuffer: Framebuffer
    event_queue: [UIEvent]
    layout_cache: [LayoutEntry]
    initialized: bool
    web_render_engine: text
    web_render_target: text
    last_artifact_html: text
    last_artifact_capabilities: text
    last_artifact_pixels: i32
    last_artifact_engine2d_status: text
    last_artifact_engine2d_backend: text
    last_artifact_engine2d_reason: text
    last_artifact_queue_submit_status: text
    last_artifact_queue_drain_status: text
    last_artifact_queue_packet_id: i64
    last_artifact_queue_drained: i64
    last_artifact_queue_backend_handle: i64
    last_artifact_queue_reason: text
    last_artifact_queue_payload_size: i64
    last_artifact_queue_payload_hash: i64
    last_artifact_queue_payload_text: text
    last_artifact_queue_dispatch_status: text
    last_artifact_queue_dispatch_reason: text
    last_artifact_queue_dispatch_payload_size: i64
    last_artifact_queue_dispatch_payload_hash: i64
    last_artifact_queue_dispatch_payload_text: text
    last_artifact_readback_status: text
    last_artifact_readback_backend: text
    last_artifact_readback_pixel_count: i64
    last_artifact_readback_checksum: i64
    last_artifact_readback_reason: text
    last_artifact_gpu_readback_source: text
    last_artifact_event_correlation_status: text
    last_artifact_event_correlation_id: text
    last_artifact_event_correlation_summary: text
    last_artifact_event_correlation_queue_packet: i64
    last_artifact_event_correlation_readback_source: text
    last_artifact_event_correlation_readback_checksum: i64
    last_input_envelope_json: text
    last_input_event_correlation_id: text
    input_event_enqueued_count: i64
    input_event_polled_count: i64
    input_event_dispatched_count: i64
    input_event_pending_depth: i64
    last_input_event_ingress_us: i64
    last_input_event_dispatch_us: i64
    last_input_event_to_render_us: i64
    last_input_event_roundtrip_status: text
    last_input_event_host_gpu_target_lane: text
    last_input_event_host_gpu_forwarded: bool
    last_input_event_host_gpu_backward_completed: bool
    last_input_event_host_gpu_summary: text
    last_semantic_snapshot_json: text
    static_shell_cache_key: text
    static_shell_full_html: text
    static_shell_html_hits: i32
    static_shell_html_stores: i32
    static_frame_state_valid: bool
    static_frame_root_id: text
    static_frame_mode: UIMode
    static_frame_focused_id: text
    static_frame_command_buffer: text
    static_frame_width: i32
    static_frame_height: i32
    static_frame_revision: i64
    static_frame_fast_hits: i32
    static_frame_fast_stores: i32
    static_frame_hits: i32
    static_frame_stores: i32
    present_pixels_cache: [i64]
    present_pixels_cache_valid: bool
    present_pixels_cache_hits: i32
    present_pixels_cache_stores: i32
    last_render_dom_layout_us: i64
    last_render_html_us: i64
    last_render_pixel_artifact_us: i64
    last_render_draw_ir_dispatch_us: i64
    last_render_framebuffer_copy_us: i64
    last_render_state_store_us: i64

    static fn create(w: i32, h: i32, backend: text, web_engine: text = WEB_RENDER_ENGINE_PURE_SIMPLE) -> Result<BrowserBackend, text>:
        """Create a BrowserBackend with the specified GPU backend.

        backend: "cuda", "vulkan", "cpu", "software", or "auto" (auto-detect).
        web_engine: WebRenderer facade engine name — "pure_simple" (default,
        canonical widget Draw IR Engine2D pipeline) or "chromium" (real offscreen Chromium
        via the WebRenderBackend facade). Unknown names loud-fail (Err) rather
        than silently falling back to the default engine.
        """
        if not web_render_engine_is_known(web_engine):
            val known = web_render_backend_names().join(", ")
            return Err("BrowserBackend.create: unknown --web-engine '{web_engine}' (known: {known})")
        val resolved = resolve_gpu_backend(backend)
        val fb = Framebuffer.create(w, h)

        return Ok(BrowserBackend(
            width: w,
            height: h,
            gpu_backend_name: resolved,
            framebuffer: fb,
            event_queue: [],
            layout_cache: [],
            initialized: true,
            web_render_engine: web_engine,
            web_render_target: WEB_RENDER_TARGET_PURE_SIMPLE,
            last_artifact_html: "",
            last_artifact_capabilities: "",
            last_artifact_pixels: 0,
            last_artifact_engine2d_status: WEB_RENDER_ENGINE2D_STATUS_NOT_REQUESTED,
            last_artifact_engine2d_backend: "",
            last_artifact_engine2d_reason: "pixel output not requested",
            last_artifact_queue_submit_status: WEB_RENDER_QUEUE_STATUS_NOT_REQUESTED,
            last_artifact_queue_drain_status: WEB_RENDER_QUEUE_STATUS_NOT_REQUESTED,
            last_artifact_queue_packet_id: 0,
            last_artifact_queue_drained: 0,
            last_artifact_queue_backend_handle: 0,
            last_artifact_queue_reason: "runtime queue not requested",
            last_artifact_queue_payload_size: 0,
            last_artifact_queue_payload_hash: 0,
            last_artifact_queue_payload_text: "",
            last_artifact_queue_dispatch_status: WEB_RENDER_QUEUE_STATUS_NOT_REQUESTED,
            last_artifact_queue_dispatch_reason: "runtime dispatch not requested",
            last_artifact_queue_dispatch_payload_size: 0,
            last_artifact_queue_dispatch_payload_hash: 0,
            last_artifact_queue_dispatch_payload_text: "",
            last_artifact_readback_status: "not_requested",
            last_artifact_readback_backend: "",
            last_artifact_readback_pixel_count: 0,
            last_artifact_readback_checksum: 0,
            last_artifact_readback_reason: "backend readback not requested",
            last_artifact_gpu_readback_source: "not_requested",
            last_artifact_event_correlation_status: "not_requested",
            last_artifact_event_correlation_id: "",
            last_artifact_event_correlation_summary: "",
            last_artifact_event_correlation_queue_packet: 0,
            last_artifact_event_correlation_readback_source: "not_requested",
            last_artifact_event_correlation_readback_checksum: 0,
            last_input_envelope_json: "",
            last_input_event_correlation_id: "",
            input_event_enqueued_count: 0,
            input_event_polled_count: 0,
            input_event_dispatched_count: 0,
            input_event_pending_depth: 0,
            last_input_event_ingress_us: 0,
            last_input_event_dispatch_us: 0,
            last_input_event_to_render_us: 0,
            last_input_event_roundtrip_status: "not_requested",
            last_input_event_host_gpu_target_lane: "",
            last_input_event_host_gpu_forwarded: false,
            last_input_event_host_gpu_backward_completed: false,
            last_input_event_host_gpu_summary: "",
            last_semantic_snapshot_json: "",
            static_shell_cache_key: "",
            static_shell_full_html: "",
            static_shell_html_hits: 0,
            static_shell_html_stores: 0,
            static_frame_state_valid: false,
            static_frame_root_id: "",
            static_frame_mode: UIMode.Normal,
            static_frame_focused_id: "",
            static_frame_command_buffer: "",
            static_frame_width: 0,
            static_frame_height: 0,
            static_frame_revision: -1,
            static_frame_fast_hits: 0,
            static_frame_fast_stores: 0,
            static_frame_hits: 0,
            static_frame_stores: 0,
            present_pixels_cache: [],
            present_pixels_cache_valid: false,
            present_pixels_cache_hits: 0,
            present_pixels_cache_stores: 0,
            last_render_dom_layout_us: 0,
            last_render_html_us: 0,
            last_render_pixel_artifact_us: 0,
            last_render_draw_ir_dispatch_us: 0,
            last_render_framebuffer_copy_us: 0,
            last_render_state_store_us: 0
        ))

    fn render_html(state: UIState) -> text:
        val body = render_html_tree(state.tree.root_node(), state)
        val req = web_render_adapter_request(WEB_RENDER_TARGET_PURE_SIMPLE, "", "", body, "", "", self.width, self.height)
        return web_render_body_html(req)

    me render_cached_static_frame() -> bool:
        """Reuse the last static frame when the caller knows UI state is unchanged."""
        if self.static_shell_cache_key != "" and self.last_artifact_pixels == self.width * self.height:
            self.static_frame_hits = self.static_frame_hits + 1
            return true
        false

    me reset_runtime_queue_diagnostics():
        self.last_artifact_queue_submit_status = WEB_RENDER_QUEUE_STATUS_NOT_REQUESTED
        self.last_artifact_queue_drain_status = WEB_RENDER_QUEUE_STATUS_NOT_REQUESTED
        self.last_artifact_queue_packet_id = 0
        self.last_artifact_queue_drained = 0
        self.last_artifact_queue_backend_handle = 0
        self.last_artifact_queue_reason = "runtime queue not requested"
        self.last_artifact_queue_payload_size = 0
        self.last_artifact_queue_payload_hash = 0
        self.last_artifact_queue_payload_text = ""
        self.last_artifact_queue_dispatch_status = WEB_RENDER_QUEUE_STATUS_NOT_REQUESTED
        self.last_artifact_queue_dispatch_reason = "runtime dispatch not requested"
        self.last_artifact_queue_dispatch_payload_size = 0
        self.last_artifact_queue_dispatch_payload_hash = 0
        self.last_artifact_queue_dispatch_payload_text = ""
        self.last_artifact_readback_status = "not_requested"
        self.last_artifact_readback_backend = ""
        self.last_artifact_readback_pixel_count = 0
        self.last_artifact_readback_checksum = 0
        self.last_artifact_readback_reason = "backend readback not requested"
        self.last_artifact_gpu_readback_source = "not_requested"
        self.last_artifact_event_correlation_status = "not_requested"
        self.last_artifact_event_correlation_id = ""
        self.last_artifact_event_correlation_summary = ""
        self.last_artifact_event_correlation_queue_packet = 0
        self.last_artifact_event_correlation_readback_source = "not_requested"
        self.last_artifact_event_correlation_readback_checksum = 0

    me finish_event_render_roundtrip():
        if self.last_input_event_dispatch_us > 0:
            val elapsed = browser_backend_time_us() - self.last_input_event_dispatch_us
            self.last_input_event_to_render_us = if elapsed >= 0: elapsed else: 0
            self.last_input_event_roundtrip_status = "rendered"

    fn static_frame_matches(tree: UITree, state: UIState, revision: i64) -> bool:
        (self.static_frame_state_valid
            and self.static_frame_root_id == tree.root_id
            and self.static_frame_mode == state.mode
            and self.static_frame_focused_id == state.focused_id
            and self.static_frame_command_buffer == state.command_buffer
            and self.static_frame_width == self.width
            and self.static_frame_height == self.height
            and self.static_frame_revision == revision)

    me store_static_frame_state(tree: UITree, state: UIState, revision: i64):
        self.static_frame_state_valid = true
        self.static_frame_root_id = tree.root_id
        self.static_frame_mode = state.mode
        self.static_frame_focused_id = state.focused_id
        self.static_frame_command_buffer = state.command_buffer
        self.static_frame_width = self.width
        self.static_frame_height = self.height
        self.static_frame_revision = revision

    me render_frame(tree: UITree, state: UIState):
        """Convert widget tree to DOM, layout, and paint to framebuffer."""
        val revision = widget_store_revision()
        if self.static_frame_matches(tree, state, revision) and self.render_cached_static_frame():
            self.static_frame_fast_hits = self.static_frame_fast_hits + 1
            self.reset_runtime_queue_diagnostics()
            self.finish_event_render_roundtrip()
            return

        val body = render_html_tree(tree.root_node(), state)
        val req = web_render_adapter_request(WEB_RENDER_TARGET_PURE_SIMPLE, "", "", body, generate_css(state.tree.theme_name()), "", self.width, self.height)
        self.last_semantic_snapshot_json = semantic_ui_snapshot_to_json(browser_semantic_snapshot(state))
        val profile = web_render_optimization_profile(req)
        if profile.cacheable_static_shell and self.static_shell_cache_key == profile.cache_key and self.render_cached_static_frame():
            self.reset_runtime_queue_diagnostics()
            self.finish_event_render_roundtrip()
            return

        # Step 1: Build DOM from widget tree
        val dom_layout_start_us = browser_backend_time_us()
        val root_node = tree.root_node()
        val dom = widget_to_dom(root_node)

        # Step 2: Compute layout (block layout)
        val layout = compute_layout(dom, self.width, self.height)

        # Step 3: Cache layout for hit testing
        self.layout_cache = collect_layout_entries(layout, [])
        self.last_render_dom_layout_us = browser_backend_time_us() - dom_layout_start_us

        # Step 4: Render canonical widget Draw IR through Engine2D for the
        # pure-Simple lane; Chromium remains an explicit HTML compatibility
        # renderer. Mirror the selected pixels into the legacy host framebuffer.
        val html_start_us = browser_backend_time_us()
        var full_html = ""
        if profile.cacheable_static_shell and self.static_shell_cache_key == profile.cache_key and self.static_shell_full_html != "":
            self.static_shell_html_hits = self.static_shell_html_hits + 1
            full_html = self.static_shell_full_html
        else:
            full_html = web_render_full_html(req)
            if profile.cacheable_static_shell:
                self.static_shell_cache_key = profile.cache_key
                self.static_shell_full_html = full_html
                self.static_shell_html_stores = self.static_shell_html_stores + 1
        self.last_render_html_us = browser_backend_time_us() - html_start_us
        val pixel_start_us = browser_backend_time_us()
        # Gap B: engine selection happens here, through the WebRenderer facade
        # shape. Default ("pure_simple") executes `widget_tree_to_draw_ir`.
        # "chromium" instead renders through the real
        # WebRenderBackend facade and reports honest provenance (engine2d
        # status "compatibility_renderer" + backend "chromium"). The former
        # `web_backend_env_get` alias-resolution failure is fixed in
        # web_render_backend.spl by using the direct env facade import.
        val composition = widget_tree_to_draw_ir(root_node, self.width, self.height, DRAW_IR_BACKEND_GPU)
        var artifact = if self.web_render_engine == WEB_RENDER_ENGINE_CHROMIUM:
            browser_backend_chromium_pixel_artifact(req, self.width, self.height, full_html)
        else:
            web_render_draw_ir_request_to_pixel_artifact(req, composition, self.gpu_backend_name)
        self.last_render_pixel_artifact_us = browser_backend_time_us() - pixel_start_us
        self.last_render_draw_ir_dispatch_us = 0
        val framebuffer_start_us = browser_backend_time_us()
        self.framebuffer = framebuffer_from_argb_pixels(self.width, self.height, artifact.pixels)
        self.present_pixels_cache_valid = false
        self.last_render_framebuffer_copy_us = browser_backend_time_us() - framebuffer_start_us
        self.web_render_target = artifact.target
        self.last_artifact_html = artifact.html
        self.last_artifact_capabilities = artifact.capability_summary
        self.last_artifact_pixels = artifact.pixels.len()
        self.last_artifact_engine2d_status = artifact.engine2d_status
        self.last_artifact_engine2d_backend = artifact.engine2d_backend
        self.last_artifact_engine2d_reason = artifact.engine2d_reason
        self.last_artifact_queue_submit_status = artifact.queue_submit_status
        self.last_artifact_queue_drain_status = artifact.queue_drain_status
        self.last_artifact_queue_packet_id = artifact.queue_packet_id
        self.last_artifact_queue_drained = artifact.queue_drained
        self.last_artifact_queue_backend_handle = artifact.queue_backend_handle
        self.last_artifact_queue_reason = artifact.queue_reason
        self.last_artifact_queue_payload_size = artifact.queue_payload_size
        self.last_artifact_queue_payload_hash = artifact.queue_payload_hash
        self.last_artifact_queue_payload_text = artifact.queue_payload_text
        self.last_artifact_queue_dispatch_status = artifact.queue_dispatch_status
        self.last_artifact_queue_dispatch_reason = artifact.queue_dispatch_reason
        self.last_artifact_queue_dispatch_payload_size = artifact.queue_dispatch_payload_size
        self.last_artifact_queue_dispatch_payload_hash = artifact.queue_dispatch_payload_hash
        self.last_artifact_queue_dispatch_payload_text = artifact.queue_dispatch_payload_text
        self.last_artifact_readback_status = artifact.readback_status
        self.last_artifact_readback_backend = artifact.readback_backend
        self.last_artifact_readback_pixel_count = artifact.readback_pixel_count
        self.last_artifact_readback_checksum = artifact.readback_checksum
        self.last_artifact_readback_reason = artifact.readback_reason
        self.last_artifact_gpu_readback_source = artifact.gpu_readback_source
        if self.last_input_event_roundtrip_status == "dispatched" and self.last_input_event_correlation_id != "":
            # Honest forward evidence: the event's GPU forwarding is only real
            # once the runtime Draw IR dispatch receipt confirms an actual
            # submission on this frame, not from lane classification alone.
            self.last_input_event_host_gpu_forwarded = artifact.queue_dispatch_status == "dispatched"
            self.last_artifact_event_correlation_id = self.last_input_event_correlation_id
            self.last_artifact_event_correlation_queue_packet = artifact.queue_packet_id
            self.last_artifact_event_correlation_readback_source = artifact.gpu_readback_source
            self.last_artifact_event_correlation_readback_checksum = artifact.readback_checksum
            if artifact.queue_packet_id > 0 and artifact.gpu_readback_source == "device_readback":
                self.last_artifact_event_correlation_status = "event_frame_readback_correlated"
            else:
                self.last_artifact_event_correlation_status = "event_frame_without_device_readback"
            self.last_artifact_event_correlation_summary = "event=" + self.last_artifact_event_correlation_id + ";frame_packet=" + artifact.queue_packet_id.to_text() + ";readback_source=" + artifact.gpu_readback_source + ";checksum=" + artifact.readback_checksum.to_text()
        val state_store_start_us = browser_backend_time_us()
        if profile.cacheable_static_shell:
            self.store_static_frame_state(tree, state, revision)
            self.static_frame_fast_stores = self.static_frame_fast_stores + 1
            self.static_frame_stores = self.static_frame_stores + 1
        self.last_render_state_store_us = browser_backend_time_us() - state_store_start_us
        self.finish_event_render_roundtrip()

    me poll_events() -> [UIEvent]:
        """Return queued events and clear the queue."""
        val events = self.event_queue
        self.event_queue = []
        self.input_event_polled_count = self.input_event_polled_count + events.len().to_i64()
        self.input_event_pending_depth = 0
        return events

    me push_event(event: UIEvent):
        """Push an external event into the queue."""
        val input_env = web_render_input_envelope_from_event(WEB_RENDER_TARGET_PURE_SIMPLE, "browser", event)
        self.last_input_envelope_json = web_render_input_envelope_to_json(input_env)
        self.event_queue = self.event_queue.push(event)
        self.input_event_enqueued_count = self.input_event_enqueued_count + 1
        self.input_event_pending_depth = self.event_queue.len().to_i64()
        self.last_input_event_ingress_us = browser_backend_time_us()
        self.last_input_event_roundtrip_status = "queued"
        self.last_input_event_host_gpu_target_lane = ""
        self.last_input_event_host_gpu_forwarded = false
        self.last_input_event_host_gpu_backward_completed = false
        self.last_input_event_host_gpu_summary = "queued local browser event"
        self.last_input_event_correlation_id = ""

    me record_event_dispatch(event: UIEvent):
        val input_env = web_render_input_envelope_from_event(WEB_RENDER_TARGET_PURE_SIMPLE, "browser", event)
        val envelope_json = web_render_input_envelope_to_json(input_env)
        self.last_input_envelope_json = envelope_json
        self.input_event_dispatched_count = self.input_event_dispatched_count + 1
        self.last_input_event_dispatch_us = browser_backend_time_us()
        self.last_input_event_roundtrip_status = "dispatched"
        self.last_input_event_correlation_id = "browser-input-{self.input_event_dispatched_count}"
        val flow = engine2d_host_gpu_draw_ir_event_flow(self.last_input_event_correlation_id, "frame_batch", envelope_json.len().to_i64(), 4096, true, false, false, false, true, 16)
        self.last_input_event_host_gpu_target_lane = flow.decision.target_lane
        # `forwarded` stays false at classification time: the event-flow only
        # plans a GPU lane. It is set true in render_frame only when the real
        # runtime Draw IR dispatch receipt confirms an actual submission.
        self.last_input_event_host_gpu_forwarded = false
        self.last_input_event_host_gpu_backward_completed = flow.receipt.committed_on_host
        self.last_input_event_host_gpu_summary = engine2d_host_gpu_draw_ir_event_flow_summary(flow)

    fn input_envelope_json(surface_id: text, event: UIEvent) -> text:
        val env = web_render_input_envelope_from_event(WEB_RENDER_TARGET_PURE_SIMPLE, surface_id, event)
        web_render_input_envelope_to_json(env)

    fn snapshot_envelope_json(surface_id: text, revision: u64, snapshot_json: text) -> text:
        web_render_snapshot_envelope_to_json(WebRenderSnapshotEnvelope(target: WEB_RENDER_TARGET_PURE_SIMPLE, surface_id: surface_id, revision: revision, snapshot_json: snapshot_json))

    fn patch_envelope_json(surface_id: text, from_sequence: u64, to_sequence: u64, patches_json: text, snapshot_json: text) -> text:
        web_render_patch_envelope_to_json(WebRenderPatchEnvelope(target: WEB_RENDER_TARGET_PURE_SIMPLE, surface_id: surface_id, from_sequence: from_sequence, to_sequence: to_sequence, patches_json: patches_json, snapshot_json: snapshot_json))

    fn host_window_command_json(cmd: WebRenderHostWindowCommand) -> text:
        web_render_host_window_command_to_json(cmd)

    fn semantic_snapshot_json(state: UIState) -> text:
        semantic_ui_snapshot_to_json(browser_semantic_snapshot(state))

    fn semantic_snapshot_envelope_json(state: UIState, surface_id: text, revision: u64) -> text:
        semantic_ui_snapshot_transport_json(WEB_RENDER_TARGET_PURE_SIMPLE, surface_id, revision, browser_semantic_snapshot(state))

    fn semantic_render_ipc_json(state: UIState) -> text:
        browser_semantic_render_ipc_json(state, self.viewport_width(), self.viewport_height())

    me resize(w: i32, h: i32):
        """Resize the framebuffer."""
        self.width = w
        self.height = h
        self.framebuffer = Framebuffer.create(w, h)
        self.static_frame_state_valid = false
        self.present_pixels_cache = []
        self.present_pixels_cache_valid = false

    me shutdown():
        """Release resources."""
        self.initialized = false
        self.event_queue = []
        self.layout_cache = []

    fn backend_name() -> text:
        return "browser"

    fn gpu_backend() -> text:
        return self.gpu_backend_name

    fn viewport_width() -> i32:
        return self.width

    fn viewport_height() -> i32:
        return self.height

    fn find_widget_at(x: i32, y: i32) -> text:
        """Hit-test: find the widget id at pixel coordinates."""
        return hit_test_entries(self.layout_cache, x, y)

    me pixels_rgba_i64() -> [i64]:
        """Expose the current framebuffer in the host window present format."""
        if self.present_pixels_cache_valid and self.present_pixels_cache.len() == self.framebuffer.pixels.len():
            self.present_pixels_cache_hits = self.present_pixels_cache_hits + 1
            return self.present_pixels_cache

        val pixel_count = self.framebuffer.pixels.len()
        var out: [i64] = [0; pixel_count]
        var i = 0
        while i < pixel_count:
            out[i] = self.framebuffer.pixels[i].to_i64()
            i = i + 1
        self.present_pixels_cache = out
        self.present_pixels_cache_valid = true
        self.present_pixels_cache_stores = self.present_pixels_cache_stores + 1
        return self.present_pixels_cache

    fn pixels_argb_u32() -> [u32]:
        """Expose the framebuffer for the shared web render pixel artifact."""
        val pixel_count = self.framebuffer.pixels.len()
        var out: [u32] = [0u32; pixel_count]
        var i = 0
        while i < pixel_count:
            out[i] = self.framebuffer.pixels[i].to_u32()
            i = i + 1
        return out

    fn snapshot_ppm(path: text) -> bool:
        """Write the current framebuffer to a PPM (P3 ASCII) file.

        Uses the P3 ASCII variant so the body is plain text and can be
        written through the text file facade without corrupting arbitrary bytes.
        Returns true on success, false otherwise.
        """
        return write_file(path, self.snapshot_ppm_text())

    fn snapshot_ppm_text() -> text:
        """Return the current framebuffer as P3 ASCII PPM text."""
        val w = self.framebuffer.width
        val h = self.framebuffer.height
        val pixels = self.framebuffer.pixels
        val pixel_count = w * h
        var parts: [text] = [""; 1 + pixel_count + h]
        var part_idx = 0
        parts[part_idx] = "P3\n{w} {h}\n255\n"
        part_idx = part_idx + 1
        var y = 0
        while y < h:
            var x = 0
            while x < w:
                val idx = y * w + x
                val p = pixels[idx]
                val r = (p / 65536) % 256
                val g = (p / 256) % 256
                val b = p % 256
                parts[part_idx] = "{r} {g} {b} "
                part_idx = part_idx + 1
                x = x + 1
            parts[part_idx] = "\n"
            part_idx = part_idx + 1
            y = y + 1
        return parts.join("")

# =========================================================================
# LayoutEntry — flat list for fast hit testing
# =========================================================================

class LayoutEntry:
    id: text
    x: f64
    y: f64
    width: f64
    height: f64

class LayoutEntryCollector:
    entries: [LayoutEntry]

    static fn create(seed: [LayoutEntry]) -> LayoutEntryCollector:
        LayoutEntryCollector(entries: seed)

    me collect(box: LayoutBox):
        self.entries = self.entries.push(LayoutEntry(
            id: "{box.node_id}",
            x: box.x,
            y: box.y,
            width: box.width,
            height: box.height
        ))
        for child in box.children:
            self.collect(child)

fn framebuffer_from_argb_pixels(width: i32, height: i32, pixels: [u32]) -> Framebuffer:
    var fb = Framebuffer.create(width, height)
    val source_count = pixels.len()
    val target_count = fb.pixels.len()
    val copy_count = if source_count < target_count:
        source_count
    else:
        target_count
    var i = 0
    while i < copy_count:
        fb.pixels[i] = (pixels[i] & 0x00FFFFFFu32).to_i32()
        i = i + 1
    fb

fn collect_layout_entries(box: LayoutBox, acc: [LayoutEntry]) -> [LayoutEntry]:
    """Flatten a LayoutBox tree into a list of entries for hit testing."""
    val collector = LayoutEntryCollector.create(acc)
    collector.collect(box)
    return collector.entries

fn hit_test_entries(entries: [LayoutEntry], px: i32, py: i32) -> text:
    """Find the deepest (last) entry that contains the point."""
    val fx: f64 = px.to_f64()
    val fy: f64 = py.to_f64()
    var best_id = ""
    for entry in entries:
        if (fx >= entry.x and fx < entry.x + entry.width
            and fy >= entry.y and fy < entry.y + entry.height):
            best_id = entry.id
    return best_id

# =========================================================================
# Widget -> DOM Conversion
# =========================================================================

fn widget_to_dom(node: WidgetNode) -> DomNode:
    """Convert a WidgetNode tree into a DomNode tree."""
    val kind = node.kind_name()
    val tag = widget_kind_to_tag(kind)
    var dom = DomNode.element(tag, node.id)
    dom = dom.add_class("widget-{kind}")

    # Add text content for text-bearing widgets.
    # SDN files use `content` for text nodes, while builder APIs may use
    # `text`, `label`, `value`, or status-bar side fields.
    var text_val = node.get_prop("text")
    if text_val == "":
        text_val = node.get_prop("content")
    if text_val == "":
        text_val = node.get_prop("label")
    if text_val == "":
        text_val = node.get_prop("value")
    if text_val == "":
        val left = node.get_prop("left")
        val right = node.get_prop("right")
        if left != "" or right != "":
            text_val = "{left} {right}".strip()
    if text_val != "":
        val text_child = DomNode.text_node(text_val)
        dom = dom.add_child(text_child)

    val title_val = node.get_prop("title")
    if title_val != "" and text_val == "":
        val title_child = DomNode.text_node(title_val)
        dom = dom.add_child(title_child)

    # Recurse into children
    val children = node.children()
    for child in children:
        val child_dom = widget_to_dom(child)
        dom = dom.add_child(child_dom)

    return dom

fn widget_kind_to_tag(kind: text) -> text:
    """Map widget kind names to HTML-like tag names."""
    match kind:
        "panel" => "div"
        "text" => "span"
        "label" => "label"
        "heading" => "h2"
        "button" => "button"
        "input" => "input"
        "textfield" => "input"
        "textarea" => "textarea"
        "list" => "ul"
        "table" => "table"
        "image" => "img"
        "menubar" => "nav"
        "statusbar" => "footer"
        "tabs" => "div"
        "progress" => "progress"
        "checkbox" => "input"
        "dropdown" => "select"
        "divider" => "hr"
        "dialog" => "dialog"
        "tooltip" => "div"
        "tree" => "ul"
        "treenode" => "li"
        "scroll" => "div"
        "card" => "div"
        "switch" => "input"
        _ => "div"

# =========================================================================
# Layout Engine — simple block layout
# =========================================================================

fn compute_layout(dom: DomNode, viewport_w: i32, viewport_h: i32) -> LayoutBox:
    """Compute block layout for a DOM tree.

    This is a simplified block layout: each child is stacked vertically,
    taking the full width of the parent. Text nodes get a fixed height.
    """
    val root = layout_node(dom, 0.0, 0.0, viewport_w.to_f64(), viewport_h.to_f64(), 0)
    return root

fn layout_node(dom: DomNode, x: f64, y: f64, avail_w: f64, avail_h: f64, id_counter: i64) -> LayoutBox:
    """Layout a single DOM node and its children."""
    var box_kind = BoxKind.Block
    if dom.tag == "span" or dom.tag == "#text":
        box_kind = BoxKind.Inline

    var node_id = id_counter

    # Text nodes get a fixed height based on font size approximation
    if dom.tag == "#text":
        val text_height: f64 = 20.0
        val text_width = avail_w
        return LayoutBox(
            node_id: node_id, kind: box_kind,
            x: x, y: y, width: text_width, height: text_height,
            box_model: BoxModel.zero(),
            children: []
        )

    # Container elements: layout children vertically
    var child_y = y
    var child_boxes: [LayoutBox] = []
    var next_id = id_counter + 1

    for child_dom in dom.children:
        val child_box = layout_node(child_dom, x, child_y, avail_w, avail_h, next_id)
        child_y = child_y + child_box.height
        child_boxes.push(child_box)
        next_id = next_id + 1

    val total_height = child_y - y
    val final_height = if total_height > 0.0: total_height else: 0.0

    return LayoutBox(
        node_id: node_id, kind: box_kind,
        x: x, y: y, width: avail_w, height: final_height,
        box_model: BoxModel.zero(),
        children: child_boxes
    )

# =========================================================================
# Paint — rasterize layout boxes to framebuffer
# =========================================================================

fn paint_layout(fb: Framebuffer, box: LayoutBox) -> Framebuffer:
    """Paint a layout box tree into a framebuffer."""
    var out = fb
    match box.kind:
        BoxKind.Block:
            if box.height > 0.0:
                out = paint_rect(out, box.x, box.y, box.width, box.height, 0x2D2D2D)
        BoxKind.Inline:
            if box.height > 0.0:
                out = paint_rect(out, box.x, box.y, box.width, box.height, 0xE0E0E0)
        _:
            pass

    # Recurse into children
    for child in box.children:
        out = paint_layout(out, child)
    out

fn paint_rect(fb: Framebuffer, x: f64, y: f64, w: f64, h: f64, color: i32) -> Framebuffer:
    """Paint a filled rectangle into the framebuffer."""
    var out = fb
    val x0: i32 = x.to_i32()
    val y0: i32 = y.to_i32()
    val x1: i32 = (x + w).to_i32()
    val y1: i32 = (y + h).to_i32()

    var py = y0
    while py < y1 and py < fb.height:
        if py >= 0:
            var px = x0
            while px < x1 and px < out.width:
                if px >= 0:
                    out.set_pixel(px, py, color)
                px = px + 1
        py = py + 1
    out

fn paint_widget_tree(fb: Framebuffer, node: WidgetNode, x: i32, y: i32, w: i32, depth: i32) -> (Framebuffer, i32):
    """Paint a simple semantic widget overlay.

    The browser backend does not have font rasterization yet, so text is shown
    as compact glyph bars. This keeps the native window visibly tied to the
    parsed SDN tree instead of presenting an empty surface.
    """
    var out = fb
    val kind = node.kind_name()
    var cursor = y
    val indent = depth * 4
    val left = x + indent
    var width = w - indent
    if width < 12:
        width = 12

    if kind == "panel":
        val title = node.get_prop("title")
        out = paint_rect_i32(out, left, cursor, width, 14, 0x3A3A3A)
        if title != "":
            out = paint_text_bars(out, left + 4, cursor + 4, title, 0xE8E8E8)
        cursor = cursor + 16
    elif kind == "text":
        val content = node.get_prop("content")
        out = paint_rect_i32(out, left, cursor, width, 12, 0xE0E0E0)
        out = paint_text_bars(out, left + 3, cursor + 3, content, 0x303030)
        cursor = cursor + 14
    elif kind == "progress":
        val value_text = node.get_prop("value")
        var fill_w = width / 2
        if value_text == "75":
            fill_w = (width * 3) / 4
        out = paint_rect_i32(out, left, cursor + 2, width, 8, 0x4A4A4A)
        out = paint_rect_i32(out, left, cursor + 2, fill_w, 8, 0x66CC88)
        cursor = cursor + 14
    elif kind == "statusbar":
        val left_text = node.get_prop("left")
        val right_text = node.get_prop("right")
        val label = "{left_text} {right_text}".strip()
        out = paint_rect_i32(out, left, cursor, width, 12, 0x202A33)
        out = paint_text_bars(out, left + 3, cursor + 3, label, 0xD8E8FF)
        cursor = cursor + 14

    for child in node.children():
        val painted = paint_widget_tree(out, child, x, cursor, w, depth + 1)
        out = painted.0
        cursor = painted.1

    return (out, cursor)

fn paint_rect_i32(fb: Framebuffer, x: i32, y: i32, w: i32, h: i32, color: i32) -> Framebuffer:
    paint_rect(fb, x.to_f64(), y.to_f64(), w.to_f64(), h.to_f64(), color)

fn paint_text_bars(fb: Framebuffer, x: i32, y: i32, text_value: text, color: i32) -> Framebuffer:
    var out = fb
    var cx = x
    val text_len = text_value.len()
    val max_x = fb.width - 4
    var i = 0
    while i < text_len and cx < max_x:
        if text_value[i] != " ":
            val h = 3 + ((i % 3) * 2)
            out = paint_rect_i32(out, cx, y, 2, h, color)
            if i % 2 == 0:
                out = paint_rect_i32(out, cx, y + h + 1, 2, 1, color)
        cx = cx + 4
        i = i + 1
    out

# =========================================================================
# GPU Backend Resolution
# =========================================================================

fn resolve_gpu_backend(name: text) -> text:
    """Resolve a backend name string to a canonical GPU backend name.

    Returns the actual Engine2D backend that SimpleWeb will use. During the
    pure-Simple Metal stage a requested Metal backend may resolve to CPU.
    """
    val canonical = backend_canonical_name(name)
    val requested = if canonical == "auto" or canonical == "metal" or canonical == "cuda" or canonical == "rocm" or canonical == "qualcomm" or canonical == "vulkan" or canonical == "directx" or canonical == "opencl" or canonical == "opengl" or canonical == "intel" or canonical == "webgpu" or canonical == "cpu_simd" or canonical == "cpu" or canonical == "software": canonical else: "software"
    web_render_resolved_engine2d_backend_name(1, 1, requested)

fn browser_semantic_snapshot(state: UIState) -> SemanticUiSnapshot:
    semantic_ui_snapshot_from_state_with_capabilities(state, SEMANTIC_UI_STAGE_RENDERER, SEMANTIC_UI_STATUS_AVAILABLE, web_render_capabilities_for_target(WEB_RENDER_TARGET_PURE_SIMPLE))
