# Contract-only QEMU ARM64 parity evidence for the pure GUI SMF lane.
#
# This module does not boot QEMU and does not render pixels. It proves that the
# same role-2 arm64 SMF artifact contract can be paired with the pure GUI command
# ABI expected by a SimpleOS framebuffer/virtio adapter.

use app.gui_perf.smf_dynlib_artifact.{GuiSmfArtifactContract}
use std.gui.pure_core.{GuiCommandBatch}

class GuiQemuArm64SmfParity:
    status: text
    artifact_path: text
    smf_role: i64
    arch_code: i64
    embedded_dynlib: bool
    symbol_name: text
    adapter: text
    command_count: i32
    dirty_region_count: i32
    same_artifact_contract: bool
    live_qemu: bool
    reason: text

fn gui_qemu_arm64_smf_parity(contract: GuiSmfArtifactContract, batch: GuiCommandBatch) -> GuiQemuArm64SmfParity:
    val same_artifact = contract.status == "pass" and contract.smf_role == 2 and contract.arch_code == 3 and contract.embedded_dynlib and contract.symbol_name == "gui_dynlib_hot_probe_tick"
    val has_commands = batch.commands.len() > 0 and batch.dirty_regions.len() > 0
    val status = if same_artifact and has_commands: "contract-pass" else: "contract-fail"
    val reason = if same_artifact and has_commands: "same-smf-artifact-reaches-pure-gui-adapter" else: "missing-arm64-smf-or-command-batch"
    GuiQemuArm64SmfParity(
        status: status,
        artifact_path: contract.artifact_path,
        smf_role: contract.smf_role,
        arch_code: contract.arch_code,
        embedded_dynlib: contract.embedded_dynlib,
        symbol_name: contract.symbol_name,
        adapter: "simpleos-framebuffer-virtio",
        command_count: batch.commands.len(),
        dirty_region_count: batch.dirty_regions.len(),
        same_artifact_contract: same_artifact,
        live_qemu: false,
        reason: reason
    )

fn gui_qemu_arm64_smf_parity_row(parity: GuiQemuArm64SmfParity) -> text:
    "GUI_QEMU_ARM64_SMF_PARITY " +
    "status=" + parity.status +
    " artifact=" + parity.artifact_path +
    " smf_role=" + parity.smf_role.to_text() +
    " arch=" + parity.arch_code.to_text() +
    " embedded_dynlib=" + parity.embedded_dynlib.to_text() +
    " symbol=" + parity.symbol_name +
    " adapter=" + parity.adapter +
    " command_count=" + parity.command_count.to_text() +
    " dirty_regions=" + parity.dirty_region_count.to_text() +
    " same_artifact_contract=" + parity.same_artifact_contract.to_text() +
    " live_qemu=" + parity.live_qemu.to_text() +
    " reason=" + parity.reason
