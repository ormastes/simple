#![allow(unknown_decorator)]
"""
# Docs Controller

Documentation pages for the Simple programming language.
All actions are public.
"""

use std.http_server.types.{HttpResponseData}
use std.web_framework.controller.{
    ControllerContext, render_page, render_not_found, get_param
}

# ============================================================================
# Actions
# ============================================================================

@public
fn action_docs_index(ctx: ControllerContext) -> HttpResponseData:
    """Render the documentation index page.

    Shows a categorized listing of available documentation.
    """
    var data: Dict<text, text> = {}
    data["title"] = "Documentation"
    data["docs_nav_html"] = build_docs_nav()

    render_page(ctx, "src/app/portal/views/home/index.html", data)

@public
fn action_docs_show(ctx: ControllerContext) -> HttpResponseData:
    """Render a specific documentation page.

    Route param: :page (doc page slug)
    """
    val page = get_param(ctx, "page")
    if page.len() == 0:
        return render_not_found()

    val doc_content = load_doc_content(page)
    if doc_content.len() == 0:
        return render_not_found()

    var data: Dict<text, text> = {}
    data["title"] = format_doc_title(page)
    data["doc_content"] = doc_content
    data["docs_nav_html"] = build_docs_nav()

    render_page(ctx, "src/app/portal/views/home/index.html", data)

# ============================================================================
# Helpers
# ============================================================================

fn build_docs_nav() -> text:
    """Build the documentation navigation sidebar HTML."""
    var parts: [text] = []
    parts.push("<nav class=\"docs-nav\">")
    parts.push("  <h3>Getting Started</h3>")
    parts.push("  <ul>")
    parts.push("    <li><a href=\"/docs/installation\">Installation</a></li>")
    parts.push("    <li><a href=\"/docs/quickstart\">Quick Start</a></li>")
    parts.push("    <li><a href=\"/docs/tutorial\">Tutorial</a></li>")
    parts.push("  </ul>")
    parts.push("  <h3>Language Guide</h3>")
    parts.push("  <ul>")
    parts.push("    <li><a href=\"/docs/syntax\">Syntax Reference</a></li>")
    parts.push("    <li><a href=\"/docs/types\">Type System</a></li>")
    parts.push("    <li><a href=\"/docs/traits\">Traits and Mixins</a></li>")
    parts.push("    <li><a href=\"/docs/error-handling\">Error Handling</a></li>")
    parts.push("    <li><a href=\"/docs/concurrency\">Concurrency</a></li>")
    parts.push("  </ul>")
    parts.push("  <h3>Packages</h3>")
    parts.push("  <ul>")
    parts.push("    <li><a href=\"/docs/packages\">Package Management</a></li>")
    parts.push("    <li><a href=\"/docs/publishing\">Publishing Packages</a></li>")
    parts.push("    <li><a href=\"/docs/api-tokens\">API Tokens</a></li>")
    parts.push("  </ul>")
    parts.push("  <h3>Tools</h3>")
    parts.push("  <ul>")
    parts.push("    <li><a href=\"/docs/cli\">CLI Reference</a></li>")
    parts.push("    <li><a href=\"/docs/testing\">Testing</a></li>")
    parts.push("    <li><a href=\"/docs/lsp\">LSP Support</a></li>")
    parts.push("  </ul>")
    parts.push("</nav>")
    parts.join("\n")

fn load_doc_content(page: text) -> text:
    """Load documentation content for a page.

    Reads from doc/ directory in the repository.

    Args:
        page: Page slug (e.g., "installation", "syntax")

    Returns:
        HTML content or empty string if not found
    """
    # Map slugs to content. In production, read from doc/ files.
    match page:
        "installation":
            "<h1>Installation</h1><p>Download the Simple compiler from the <a href=\"/\">portal</a> or build from source.</p>" +
            "<pre><code># macOS / Linux\ncurl -fsSL https://simple-lang.org/install.shs | sh\n\n# Build from source\ngit clone https://github.com/simple-lang/simple\ncd simple && scripts/setup.sh</code></pre>"
        "quickstart":
            "<h1>Quick Start</h1><p>Create your first Simple program:</p>" +
            "<pre><code>fn main():\n    print \"Hello, Simple!\"</code></pre>" +
            "<p>Run it:</p><pre><code>bin/simple run hello.spl</code></pre>"
        "packages":
            "<h1>Package Management</h1><p>Simple has a built-in package manager.</p>" +
            "<pre><code># Add a dependency\nsimple add web\n\n# Install all dependencies\nsimple install\n\n# Search for packages\nsimple search http</code></pre>"
        "publishing":
            "<h1>Publishing Packages</h1><p>Share your packages with the community.</p>" +
            "<pre><code># Create an API token\n# Visit /profile to generate one\n\n# Publish your package\nsimple publish</code></pre>"
        _: ""

fn format_doc_title(page: text) -> text:
    """Format a documentation page slug into a display title."""
    # Capitalize first letter and replace hyphens with spaces
    if page.len() == 0:
        return "Documentation"
    val first = page[0:1].to_upper()
    val rest = page[1:].replace("-", " ")
    "{first}{rest}"
