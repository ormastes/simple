"""
# Package Model

Published package with metadata and download counts.
Implements DbCodec<Package> for repository operations.
"""

use std.database.sql.types.{DbValue, DbRow, DbError}
use std.database.sql.schema.{TableSchema}
use std.database.sql.codec.{DbCodec}

# ============================================================================
# Package Entity
# ============================================================================

class Package:
    """A published Simple language package."""
    id: i64
    name: text
    description: text
    latest_version: text
    owner_id: i64
    homepage: text
    repository: text
    license: text
    downloads: i64
    created_at: text
    updated_at: text

fn new_package(name: text, description: text, owner_id: i64) -> Package:
    """Create a new Package with default values."""
    Package(
        id: 0,
        name: name,
        description: description,
        latest_version: "0.0.0",
        owner_id: owner_id,
        homepage: "",
        repository: "",
        license: "",
        downloads: 0,
        created_at: "",
        updated_at: ""
    )

# ============================================================================
# PackageVersion Entity
# ============================================================================

class PackageVersion:
    """A specific version of a package."""
    id: i64
    package_id: i64
    version: text
    checksum: text
    size_bytes: i64
    yanked: bool
    readme: text
    created_at: text

# ============================================================================
# PackageCodec — DbCodec<Package> implementation
# ============================================================================

class PackageCodec with DbCodec<Package>:
    """Codec for encoding/decoding Package entities."""

    fn table_name() -> text:
        "packages"

    fn schema() -> TableSchema:
        var s = TableSchema.new("packages")
        s = s.id_col()
        s = s.text_col("name")
        s = s.text_col("description")
        s = s.text_col("latest_version")
        s = s.int_col("owner_id")
        s = s.text_col("homepage")
        s = s.text_col("repository")
        s = s.text_col("license")
        s = s.int_col("downloads")
        s = s.text_col("created_at")
        s = s.text_col("updated_at")
        s

    fn columns() -> [text]:
        ["name", "description", "latest_version", "owner_id", "homepage", "repository", "license", "downloads"]

    fn encode(entity: Package) -> [DbValue]:
        [
            DbValue.Text(value: entity.name),
            DbValue.Text(value: entity.description),
            DbValue.Text(value: entity.latest_version),
            DbValue.Integer(value: entity.owner_id),
            DbValue.Text(value: entity.homepage),
            DbValue.Text(value: entity.repository),
            DbValue.Text(value: entity.license),
            DbValue.Integer(value: entity.downloads)
        ]

    fn decode(row: DbRow) -> Result<Package, DbError>:
        val id = row.get_int("id") ?? 0
        val name = row.get_text("name")
        val description = row.get_text("description")
        val latest_version = row.get_text("latest_version")
        val owner_id = row.get_int("owner_id") ?? 0
        val homepage = row.get_text("homepage")
        val repository = row.get_text("repository")
        val license = row.get_text("license")
        val downloads = row.get_int("downloads") ?? 0
        val created_at = row.get_text("created_at")
        val updated_at = row.get_text("updated_at")

        if name == nil:
            return Err(DbError.TypeMismatch(
                column: "name", expected: "text", actual: "missing"
            ))

        Ok(Package(
            id: id,
            name: name ?? "",
            description: description ?? "",
            latest_version: latest_version ?? "0.0.0",
            owner_id: owner_id,
            homepage: homepage ?? "",
            repository: repository ?? "",
            license: license ?? "",
            downloads: downloads,
            created_at: created_at ?? "",
            updated_at: updated_at ?? ""
        ))

# ============================================================================
# PackageVersionCodec — DbCodec<PackageVersion> implementation
# ============================================================================

class PackageVersionCodec with DbCodec<PackageVersion>:
    """Codec for encoding/decoding PackageVersion entities."""

    fn table_name() -> text:
        "package_versions"

    fn schema() -> TableSchema:
        var s = TableSchema.new("package_versions")
        s = s.id_col()
        s = s.int_col("package_id")
        s = s.text_col("version")
        s = s.text_col("checksum")
        s = s.int_col("size_bytes")
        s = s.int_col("yanked")
        s = s.text_col("readme")
        s = s.text_col("created_at")
        s

    fn columns() -> [text]:
        ["package_id", "version", "checksum", "size_bytes", "yanked", "readme"]

    fn encode(entity: PackageVersion) -> [DbValue]:
        val yanked_int = if entity.yanked: 1 else: 0
        [
            DbValue.Integer(value: entity.package_id),
            DbValue.Text(value: entity.version),
            DbValue.Text(value: entity.checksum),
            DbValue.Integer(value: entity.size_bytes),
            DbValue.Integer(value: yanked_int),
            DbValue.Text(value: entity.readme)
        ]

    fn decode(row: DbRow) -> Result<PackageVersion, DbError>:
        val id = row.get_int("id") ?? 0
        val package_id = row.get_int("package_id") ?? 0
        val version = row.get_text("version")
        val checksum = row.get_text("checksum")
        val size_bytes = row.get_int("size_bytes") ?? 0
        val yanked_int = row.get_int("yanked") ?? 0
        val readme = row.get_text("readme")
        val created_at = row.get_text("created_at")

        Ok(PackageVersion(
            id: id,
            package_id: package_id,
            version: version ?? "",
            checksum: checksum ?? "",
            size_bytes: size_bytes,
            yanked: yanked_int != 0,
            readme: readme ?? "",
            created_at: created_at ?? ""
        ))
