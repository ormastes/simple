# CLI Observer
#
# Attaches to a UISession and renders state as plain text.
# Supports multiple output modes: summary, changes, tree outline,
# and adaptive (auto-selects based on max_lines).

use common.ui.session.{UISession}
use common.ui.widget.{UIState, UITree, WidgetNode}
use common.ui.lifecycle.{describe_lifecycle_event}

# =========================================================================
# CLIObserver
# =========================================================================

class CLIObserver:
    session: UISession
    max_lines: i32

    static fn new(session: UISession) -> CLIObserver:
        """Create an observer with default max_lines (20)."""
        return CLIObserver(session: session, max_lines: 20)

    static fn new_with_lines(session: UISession, max_lines: i32) -> CLIObserver:
        """Create an observer with a specific line budget."""
        return CLIObserver(session: session, max_lines: max_lines)

# =========================================================================
# CLIObserver Methods
# =========================================================================

impl CLIObserver:

    fn render_summary() -> text:
        """Render mode, focused widget, viewport, and surface list."""
        val vp = self.session.viewport
        val state = self.session.current_state()
        val mode = state.mode_name()
        val focused = state.focused_id
        var out = "STATE (observer) {vp.describe()}\n"
        out = "{out}mode: {mode}   focused: {focused}\n"
        # List surfaces with widget counts
        val surfaces = self.session.surfaces
        val ids = surfaces.surface_ids()
        out = "{out}surfaces:\n"
        for sid in ids:
            val tree = surfaces.get(sid)
            if tree != nil:
                val widget_ids = tree.all_widget_ids()
                out = "{out}  {sid}: {widget_ids.len()} widgets\n"
        return out

    fn render_changes(count: i32) -> text:
        """Render the last N lifecycle events."""
        val changes = self.session.recent_changes(count)
        if changes.len() == 0:
            return "No recent changes.\n"
        var out = "Recent changes:\n"
        for desc in changes:
            out = "{out}  {desc}\n"
        return out

    fn render_tree_outline() -> text:
        """Render a tree structure outline of the current widget tree."""
        val root = self.session.current_tree().root_node()
        return render_node_outline(root, 0)

    fn render_adaptive() -> text:
        """Auto-select output based on max_lines budget."""
        if self.max_lines < 5:
            # Tiny: mode + focus only
            val state = self.session.current_state()
            return "mode: {state.mode_name()}   focused: {state.focused_id}\n"
        elif self.max_lines < 12:
            # Medium: header + changes
            val state = self.session.current_state()
            val vp = self.session.viewport
            var out = "STATE (observer) {vp.describe()}\n"
            out = "{out}mode: {state.mode_name()}   focused: {state.focused_id}\n"
            out = "{out}{self.render_changes(5)}"
            return out
        else:
            # Full: summary + changes
            var out = self.render_summary()
            out = "{out}{self.render_changes(10)}"
            return out

# =========================================================================
# Tree Outline Helper
# =========================================================================

fn render_node_outline(node: WidgetNode, depth: i32) -> text:
    """Render a single node and its children with indentation."""
    var indent = ""
    var i = 0
    while i < depth:
        indent = "{indent}  "
        i = i + 1
    var out = "{indent}{node.widget_summary()}\n"
    val children = node.children()
    for child in children:
        out = "{out}{render_node_outline(child, depth + 1)}"
    return out
