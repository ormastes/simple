# Terminal CLI entrypoint.
# Startup-light command planner for source-mode help and readiness probes.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

val TOOL_NAME = "Simple Terminal"
val TOOL_VERSION = "0.1.0"
val DEFAULT_CONFIG_PATH = "config/t32/t32_terminal.sdn"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("terminal", log_opts.error)
        return 1

    val args = terminal_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"terminal\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0

    val unknown = terminal_first_unknown_option(args)
    if unknown != "":
        val message = "Unknown terminal option: {unknown}"
        terminal_print_error(log_opts.log_mode, message)
        return 1

    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"terminal\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            val progress = render_progress(log_opts.progress, 1, 1, "terminal")
            if progress != "":
                print progress
            print "{TOOL_NAME} v{TOOL_VERSION}"
            print "Ready for terminal command planning."
        return 0

    val op = terminal_operation_arg(args)
    if not terminal_is_command(op):
        val message = "Unknown terminal command: {op}"
        terminal_print_error(log_opts.log_mode, message)
        return 1

    val target = terminal_positional_after_operation(args, 0)
    val command_text = terminal_command_text(args)
    if op != "list" and target == "":
        val message = "Terminal command {op} requires a target"
        terminal_print_error(log_opts.log_mode, message)
        return 1
    if op == "exec" and command_text == "":
        terminal_print_error(log_opts.log_mode, "Terminal command exec requires a command")
        return 1

    val config_path = terminal_option_value(args, "--config", DEFAULT_CONFIG_PATH)
    if log_opts.log_mode == "json":
        print "{\"command\":\"terminal\",\"status\":\"planned\",\"operation\":\"{op}\",\"target\":\"{target}\",\"exec\":\"{command_text}\",\"config\":\"{config_path}\"}"
    else:
        val progress = render_progress(log_opts.progress, 1, 1, "terminal-plan")
        if progress != "":
            print progress
        print "Terminal operation: {op}"
        if target != "":
            print "Target: {target}"
        if command_text != "":
            print "Exec: {command_text}"
        print "Config: {config_path}"
    0

fn print_help():
    print "{TOOL_NAME}"
    print ""
    print "Usage: simple terminal <command> [target] [args...] [options]"
    print ""
    print "Commands:"
    print "  connect <name>              Connect to a configured terminal"
    print "  exec <name> <command...>    Execute command on terminal"
    print "  list                        List configured terminals"
    print "  disconnect <name>           Disconnect active terminal"
    print ""
    print "Options:"
    print "  -h, --help          Show this help message"
    print "  -v, --version       Show version information"
    print "  --config <PATH>     Terminal config path (default: {DEFAULT_CONFIG_PATH})"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn terminal_print_error(log_mode: text, message: text):
    if log_mode == "json":
        print "{\"command\":\"terminal\",\"status\":\"error\",\"message\":\"{message}\"}"
    else:
        error("terminal", message)

fn terminal_is_command(op: text) -> bool:
    op == "connect" or op == "exec" or op == "list" or op == "disconnect"

fn terminal_operation_arg(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config":
            i = i + 2
        elif arg.starts_with("--config="):
            i = i + 1
        elif arg.starts_with("-"):
            i = i + 1
        else:
            return arg
    ""

fn terminal_positional_after_operation(args: [text], index: i64) -> text:
    var found_op = false
    var seen = 0
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config":
            i = i + 2
        elif arg.starts_with("--config="):
            i = i + 1
        elif arg.starts_with("-"):
            i = i + 1
        elif not found_op:
            found_op = true
            i = i + 1
        else:
            if seen == index:
                return arg
            seen = seen + 1
            i = i + 1
    ""

fn terminal_command_text(args: [text]) -> text:
    val op = terminal_operation_arg(args)
    if op != "exec":
        return ""
    var command = ""
    var found_op = false
    var skipped_target = false
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config":
            i = i + 2
        elif arg.starts_with("--config="):
            i = i + 1
        elif arg.starts_with("-"):
            i = i + 1
        elif not found_op:
            found_op = true
            i = i + 1
        elif not skipped_target:
            skipped_target = true
            i = i + 1
        else:
            if command == "":
                command = arg
            else:
                command = "{command} {arg}"
            i = i + 1
    command

fn terminal_option_value(args: [text], name: text, fallback: text) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == name and i + 1 < args.len():
            return args[i + 1]
        if arg.starts_with(name + "="):
            return arg.substring(name.len() + 1)
        i = i + 1
    fallback

fn terminal_first_unknown_option(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config":
            i = i + 2
        elif arg.starts_with("--config="):
            i = i + 1
        elif arg.starts_with("-"):
            return arg
        else:
            i = i + 1
    ""

fn terminal_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn terminal_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if terminal_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
