# Remote Test CLI entrypoint.
# Startup-light command planner for source-mode help and readiness probes.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

val TOOL_NAME = "Simple Remote Test"
val TOOL_VERSION = "0.1.0"
val DEFAULT_CONFIG_PATH = "config/t32/t32_terminal.sdn"
val DEFAULT_REMOTE_SIMPLE_BIN = "bin/simple"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("remote-test", log_opts.error)
        return 1

    val args = remote_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"remote-test\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0

    val unknown = remote_first_unknown_option(args)
    if unknown != "":
        val message = "Unknown remote-test option: {unknown}"
        remote_print_error(log_opts.log_mode, message)
        return 1

    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"remote-test\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            val progress = render_progress(log_opts.progress, 1, 1, "remote-test")
            if progress != "":
                print progress
            print "{TOOL_NAME} v{TOOL_VERSION}"
            print "Ready for remote test command planning."
        return 0

    val terminal_name = remote_positional_arg(args, 0)
    val test_path = remote_positional_arg(args, 1)
    if terminal_name == "" or test_path == "":
        remote_print_error(log_opts.log_mode, "remote-test requires a terminal name and test path")
        return 1

    val config_path = remote_option_value(args, "--config", DEFAULT_CONFIG_PATH)
    val simple_bin = remote_option_value(args, "--simple-bin", DEFAULT_REMOTE_SIMPLE_BIN)
    if log_opts.log_mode == "json":
        print "{\"command\":\"remote-test\",\"status\":\"planned\",\"terminal\":\"{terminal_name}\",\"test_path\":\"{test_path}\",\"config\":\"{config_path}\",\"remote_simple_bin\":\"{simple_bin}\"}"
    else:
        val progress = render_progress(log_opts.progress, 1, 1, "remote-test-plan")
        if progress != "":
            print progress
        print "Remote test terminal: {terminal_name}"
        print "Test path: {test_path}"
        print "Config: {config_path}"
        print "Remote simple binary: {simple_bin}"
    0

fn print_help():
    print "{TOOL_NAME}"
    print ""
    print "Usage: simple remote-test <terminal_name> <test_path> [options]"
    print ""
    print "Arguments:"
    print "  terminal_name       Name of the terminal in the config"
    print "  test_path           Path to the test file on the remote host"
    print ""
    print "Options:"
    print "  -h, --help              Show this help message"
    print "  -v, --version           Show version information"
    print "  --config <PATH>         Terminal config path (default: {DEFAULT_CONFIG_PATH})"
    print "  --simple-bin <PATH>     Remote simple binary (default: {DEFAULT_REMOTE_SIMPLE_BIN})"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn remote_print_error(log_mode: text, message: text):
    if log_mode == "json":
        print "{\"command\":\"remote-test\",\"status\":\"error\",\"message\":\"{message}\"}"
    else:
        error("remote-test", message)

fn remote_option_value(args: [text], name: text, fallback: text) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == name and i + 1 < args.len():
            return args[i + 1]
        if arg.starts_with(name + "="):
            return arg.substring(name.len() + 1)
        i = i + 1
    fallback

fn remote_positional_arg(args: [text], index: i64) -> text:
    var seen = 0
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config" or arg == "--simple-bin":
            i = i + 2
        elif arg.starts_with("--config=") or arg.starts_with("--simple-bin="):
            i = i + 1
        elif arg.starts_with("-"):
            i = i + 1
        else:
            if seen == index:
                return arg
            seen = seen + 1
            i = i + 1
    ""

fn remote_first_unknown_option(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config" or arg == "--simple-bin":
            i = i + 2
        elif arg.starts_with("--config=") or arg.starts_with("--simple-bin="):
            i = i + 1
        elif arg.starts_with("-"):
            return arg
        else:
            i = i + 1
    ""

fn remote_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn remote_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if remote_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
