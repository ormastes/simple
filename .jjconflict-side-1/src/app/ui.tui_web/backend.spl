# TUI Web Render Backend
#
# Implements RenderBackend concepts for the TUI-over-web proxy.
# Renders UIState to a Screen buffer, then converts the ANSI output
# to HTML using screen_to_html. Events are injected via push_event
# and polled from an internal queue.

use common.ui.widget.{UIState, UIEvent, WidgetNode, WidgetRect}
use common.ui.capability.{Capability}
use common.ui.semantic_contract.{
    SEMANTIC_UI_STAGE_PROTOCOL,
    SEMANTIC_UI_STATUS_AVAILABLE,
    SemanticUiSnapshot,
    semantic_ui_snapshot_from_state_with_capabilities,
    semantic_ui_snapshot_to_json,
    semantic_ui_snapshot_transport_json
}
use common.ui.web_render_api.{
    WEB_RENDER_TARGET_TUI_WEB,
    WebRenderPatchEnvelope,
    WebRenderSnapshotEnvelope,
    web_render_capabilities_for_target,
    web_render_input_envelope_from_event,
    web_render_input_envelope_to_json,
    web_render_patch_envelope_to_json,
    web_render_snapshot_envelope_to_json
}
use common.ui.layout.{compute_layout}
use app.ui.tui.screen.{Screen}
use app.ui.render.tui_widgets.{render_tui_tree}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.tui_web.screen_to_html.{screen_to_html}

# =========================================================================
# TUI Web Backend
# =========================================================================

class TuiWebBackend:
    width: i32
    height: i32
    initialized: bool
    current_html: text
    event_queue: [UIEvent]
    event_head: i32

    static fn new() -> TuiWebBackend:
        """Create a TUI web backend with a fixed 120x40 virtual terminal."""
        return TuiWebBackend(
            width: 120,
            height: 40,
            initialized: false,
            current_html: "",
            event_queue: [],
            event_head: 0
        )

    # --- Lifecycle ---

    me init() -> Result<bool, text>:
        """Initialize the backend. No alt screen needed since headless."""
        self.initialized = true
        return Ok(true)

    me shutdown():
        """Shutdown the backend."""
        self.initialized = false

    # --- Rendering ---

    me render(state: UIState) -> Result<bool, text>:
        """Render UIState to Screen buffer, then convert to HTML via screen_to_html."""
        var screen = Screen.new(self.width, self.height)

        # Compute layout
        val rects = compute_layout(state.tree.root_node(), 0, 0, self.width, self.height)

        # Render widget tree to screen buffer
        screen = render_tui_tree(screen, state.tree.root_node(), rects, state)

        # Convert ANSI screen output to HTML
        val rendered = screen.render()
        self.current_html = screen_to_html(rendered)

        return Ok(true)

    fn render_html(state: UIState) -> text:
        """Render UIState directly to HTML tree (non-TUI style)."""
        return render_html_tree(state.tree.root_node(), state)

    # --- Events ---

    me push_event(event: UIEvent):
        """Add an event to the internal queue."""
        self.event_queue.push(event)

    me poll_event(timeout_ms: i32) -> UIEvent?:
        """Pop the next event from the queue, or return nil if empty."""
        val queue_len = self.event_queue.len()
        if self.event_head >= queue_len:
            self.event_queue = []
            self.event_head = 0
            return nil
        val event = self.event_queue[self.event_head]
        self.event_head = self.event_head + 1
        if self.event_head >= queue_len:
            self.event_queue = []
            self.event_head = 0
        elif self.event_head > 64 and self.event_head * 2 >= queue_len:
            var compacted: [UIEvent] = []
            var i = self.event_head
            while i < queue_len:
                compacted.push(self.event_queue[i])
                i = i + 1
            self.event_queue = compacted
            self.event_head = 0
        return event

    fn input_envelope_json(surface_id: text, event: UIEvent) -> text:
        val env = web_render_input_envelope_from_event(WEB_RENDER_TARGET_TUI_WEB, surface_id, event)
        web_render_input_envelope_to_json(env)

    fn snapshot_envelope_json(surface_id: text, revision: u64, snapshot_json: text) -> text:
        web_render_snapshot_envelope_to_json(WebRenderSnapshotEnvelope(target: WEB_RENDER_TARGET_TUI_WEB, surface_id: surface_id, revision: revision, snapshot_json: snapshot_json))

    fn patch_envelope_json(surface_id: text, from_sequence: u64, to_sequence: u64, patches_json: text, snapshot_json: text) -> text:
        web_render_patch_envelope_to_json(WebRenderPatchEnvelope(target: WEB_RENDER_TARGET_TUI_WEB, surface_id: surface_id, from_sequence: from_sequence, to_sequence: to_sequence, patches_json: patches_json, snapshot_json: snapshot_json))

    fn semantic_snapshot_json(state: UIState) -> text:
        semantic_ui_snapshot_to_json(tui_web_semantic_snapshot(state))

    fn semantic_snapshot_envelope_json(state: UIState, surface_id: text, revision: u64) -> text:
        semantic_ui_snapshot_transport_json(WEB_RENDER_TARGET_TUI_WEB, surface_id, revision, tui_web_semantic_snapshot(state))

    # --- Capabilities ---

    fn capabilities() -> [Capability]:
        return web_render_capabilities_for_target(WEB_RENDER_TARGET_TUI_WEB)

    fn supports_mouse() -> bool:
        return false

    fn supports_color() -> bool:
        return true

    fn supports_images() -> bool:
        return false

    fn supports_touch() -> bool:
        return false

    # --- Viewport ---

    fn viewport_width() -> i32:
        return self.width

    fn viewport_height() -> i32:
        return self.height

    # --- Backend Info ---

    fn backend_name() -> text:
        return "tui_web"

fn tui_web_semantic_snapshot(state: UIState) -> SemanticUiSnapshot:
    semantic_ui_snapshot_from_state_with_capabilities(state, SEMANTIC_UI_STAGE_PROTOCOL, SEMANTIC_UI_STATUS_AVAILABLE, web_render_capabilities_for_target(WEB_RENDER_TARGET_TUI_WEB))
