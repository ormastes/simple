# Simple CLI - spec-gen command
# Generates spec documentation from *_spec.spl test files

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod (file_exists, file_read, file_write, dir_walk, dir_create)
use std.log.{error}

val SPEC_DIR = "doc/06_spec"

fn print_help():
    print "Usage: simple spec-gen [path] [options]"
    print ""
    print "Generate spec documentation from SPipe test files."
    print ""
    print "Arguments:"
    print "  [path]       Test directory (default: src/lib/test/features/)"
    print ""
    print "Options:"
    print "  --json       Output summary as JSON"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help   Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn extract_spec_doc(content: text, file_path: text) -> text:
    val lines = content.split("\n")
    var doc_lines: [text] = []
    var in_doc_block = false
    var doc_block: [text] = []

    for line in lines:
        val trimmed = line.trim()

        # Triple-quote doc blocks
        if trimmed == "\"\"\"":
            if in_doc_block:
                for dl in doc_block:
                    doc_lines.push(dl)
                doc_block = []
                in_doc_block = false
            else:
                in_doc_block = true
            continue

        if in_doc_block:
            doc_block.push(trimmed)
            continue

        # Doc comments
        if trimmed.starts_with("///"):
            val comment = trimmed.slice(3, trimmed.len()).trim()
            doc_lines.push(comment)
            continue

        # Describe blocks -> ##
        if trimmed.starts_with("describe "):
            val name = extract_quoted(trimmed)
            if name != "":
                doc_lines.push("")
                doc_lines.push("## {name}")
                doc_lines.push("")
            continue

        # Context blocks -> ###
        if trimmed.starts_with("context "):
            val name = extract_quoted(trimmed)
            if name != "":
                doc_lines.push("")
                doc_lines.push("### {name}")
                doc_lines.push("")
            continue

        # It/test blocks -> bullet points
        if trimmed.starts_with("it ") or trimmed.starts_with("test "):
            val name = extract_quoted(trimmed)
            if name != "":
                doc_lines.push("- {name}")
            continue

    doc_lines.join("\n")

fn extract_quoted(line: text) -> text:
    val q1 = line.index_of("\"") ?? -1
    if q1 < 0:
        return ""
    val after = line.slice(q1 + 1, line.len())
    val q2 = after.index_of("\"") ?? -1
    if q2 < 0:
        return ""
    after.slice(0, q2)

fn spec_name_from_path(file_path: text) -> text:
    val parts = file_path.split("/")
    val filename = if parts.len() > 0: parts[parts.len() - 1] else: file_path
    if filename.ends_with("_spec.spl"):
        return filename.slice(0, filename.len() - 9)
    if filename.ends_with(".spl"):
        return filename.slice(0, filename.len() - 4)
    filename

fn spec_relative_dir(file_path: text, search_root: text) -> text:
    var rel = file_path
    if rel.starts_with(search_root):
        rel = rel.slice(search_root.len(), rel.len())
    if rel.starts_with("/"):
        rel = rel.slice(1, rel.len())
    val parts = rel.split("/")
    if parts.len() <= 1:
        return ""
    var dir_parts: [text] = []
    var i = 0
    while i < parts.len() - 1:
        val p = parts[i]
        if p != ".simple" and p != "build":
            dir_parts.push(p)
        i = i + 1
    dir_parts.join("/")

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("spec-gen", log_opts.error)
        return 1

    var search_path = "src/lib/test/features"
    var as_json = log_opts.log_mode == "json"

    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        elif not arg.starts_with("-"):
            search_path = arg
        ai = ai + 1

    if not file_exists(search_path):
        if as_json:
            print "{\"command\":\"spec-gen\",\"status\":\"error\",\"generated\":0,\"path\":\"{search_path}\"}"
        else:
            error("spec_gen", "path not found: {search_path}")
        return 1

    dir_create(SPEC_DIR, true)

    val files = dir_walk(search_path)
    var generated = 0

    for file in files:
        if not file.ends_with("_spec.spl"):
            continue

        val content = file_read(file)
        val doc = extract_spec_doc(content, file)

        if doc.trim() == "":
            continue

        val name = spec_name_from_path(file)
        val rel_dir = spec_relative_dir(file, search_path)
        var out_dir = SPEC_DIR
        if rel_dir != "":
            out_dir = "{SPEC_DIR}/{rel_dir}"
            dir_create(out_dir, true)
        val out_path = "{out_dir}/{name}_spec.md"

        var header = "# {name}\n\n"
        header = header + "_Generated from `{file}`_\n\n"
        file_write(out_path, header + doc + "\n")
        generated = generated + 1

    if log_opts.progress != "summary" and not as_json:
        val progress_line = render_progress(log_opts.progress, generated, if generated > 0: generated else: 1, "spec-gen")
        if progress_line != "":
            print progress_line
    if as_json:
        print "{\"command\":\"spec-gen\",\"status\":\"ok\",\"generated\":{generated},\"path\":\"{SPEC_DIR}\"}"
    else:
        print "Generated {generated} spec documents in {SPEC_DIR}/"
    0
