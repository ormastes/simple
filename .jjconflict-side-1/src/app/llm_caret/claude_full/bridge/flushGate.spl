class FlushGate:
    active: bool
    pending: [text]

impl FlushGate:
    static fn new() -> FlushGate:
        FlushGate(active: false, pending: [])

    me isActive() -> bool:
        me.active

    me pendingCount() -> i64:
        me.pending.len()

    me start() -> ():
        me.active = true

    me end() -> [text]:
        val drained = me.pending
        me.pending = []
        me.active = false
        drained

    me enqueue(item: text) -> bool:
        if not me.active:
            return false
        me.pending = me.pending + [item]
        true

    me enqueue2(first: text, second: text) -> bool:
        if not me.active:
            return false
        me.pending = me.pending + [first, second]
        true

    me enqueueMany(items: [text]) -> bool:
        if not me.active:
            return false
        for item in items:
            me.pending = me.pending + [item]
        true

    me drop() -> i64:
        val count = me.pending.len()
        me.pending = []
        me.active = false
        count

    me deactivate() -> ():
        me.active = false

    me pendingSnapshot() -> [text]:
        me.pending

    me hasPending() -> bool:
        me.pending.len() > 0

    me firstPending() -> text:
        if me.pending.len() == 0:
            return ""
        me.pending[0]

    me lastPending() -> text:
        val count = me.pending.len()
        if count == 0:
            return ""
        me.pending[count - 1]

    me clearPending() -> i64:
        val count = me.pending.len()
        me.pending = []
        count

    me restart() -> ():
        me.pending = []
        me.active = true

fn flushGateNew() -> FlushGate:
    FlushGate.new()

fn flushGateIsActive(gate: FlushGate) -> bool:
    gate.isActive()

fn flushGatePendingCount(gate: FlushGate) -> i64:
    gate.pendingCount()
