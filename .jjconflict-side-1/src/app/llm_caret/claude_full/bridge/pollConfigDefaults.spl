"""
Claude full bridge poll config defaults parity model.
"""

const POLL_CONFIG_DEFAULTS_SOURCE_LINES = 82
const POLL_INTERVAL_MS_NOT_AT_CAPACITY = 2000
const POLL_INTERVAL_MS_AT_CAPACITY = 600000

class PollIntervalConfig:
    poll_interval_ms_not_at_capacity: i64
    poll_interval_ms_at_capacity: i64
    non_exclusive_heartbeat_interval_ms: i64
    multisession_poll_interval_ms_not_at_capacity: i64
    multisession_poll_interval_ms_partial_capacity: i64
    multisession_poll_interval_ms_at_capacity: i64
    reclaim_older_than_ms: i64
    session_keepalive_interval_v2_ms: i64

impl PollIntervalConfig:
    static fn new() -> PollIntervalConfig:
        PollIntervalConfig(
            poll_interval_ms_not_at_capacity: POLL_INTERVAL_MS_NOT_AT_CAPACITY,
            poll_interval_ms_at_capacity: POLL_INTERVAL_MS_AT_CAPACITY,
            non_exclusive_heartbeat_interval_ms: 0,
            multisession_poll_interval_ms_not_at_capacity: POLL_INTERVAL_MS_NOT_AT_CAPACITY,
            multisession_poll_interval_ms_partial_capacity: POLL_INTERVAL_MS_NOT_AT_CAPACITY,
            multisession_poll_interval_ms_at_capacity: POLL_INTERVAL_MS_AT_CAPACITY,
            reclaim_older_than_ms: 5000,
            session_keepalive_interval_v2_ms: 120000,
        )

fn defaultPollConfig() -> PollIntervalConfig:
    PollIntervalConfig.new()

fn pollConfigAtCapacityDisabled(cfg: PollIntervalConfig) -> bool:
    cfg.poll_interval_ms_at_capacity == 0

fn pollConfigHeartbeatEnabled(cfg: PollIntervalConfig) -> bool:
    cfg.non_exclusive_heartbeat_interval_ms > 0

fn pollConfigKeepaliveEnabled(cfg: PollIntervalConfig) -> bool:
    cfg.session_keepalive_interval_v2_ms > 0

fn pollConfigDefaultsSourceLinesModeled() -> i64:
    POLL_CONFIG_DEFAULTS_SOURCE_LINES
