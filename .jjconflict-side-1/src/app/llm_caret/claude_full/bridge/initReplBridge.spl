"""
Deterministic initReplBridge.ts parity surface for initial bridge setup.
"""

const INIT_REPL_BRIDGE_SOURCE_LINES: i64 = 569

class InitBridgeOptions:
    sessionId: text
    sessionUrl: text
    accessToken: text
    ccrV2: bool
    workerEpoch: i64
    initialPrompt: text

impl InitBridgeOptions:
    static fn new(sessionId: text, sessionUrl: text, accessToken: text) -> InitBridgeOptions:
        InitBridgeOptions(sessionId: sessionId, sessionUrl: sessionUrl, accessToken: accessToken, ccrV2: false, workerEpoch: 0, initialPrompt: "")

    me withPrompt(prompt: text) -> InitBridgeOptions:
        InitBridgeOptions(sessionId: me.sessionId, sessionUrl: me.sessionUrl, accessToken: me.accessToken, ccrV2: me.ccrV2, workerEpoch: me.workerEpoch, initialPrompt: prompt)

    me withCcrV2(epoch: i64) -> InitBridgeOptions:
        InitBridgeOptions(sessionId: me.sessionId, sessionUrl: me.sessionUrl, accessToken: me.accessToken, ccrV2: true, workerEpoch: epoch, initialPrompt: me.initialPrompt)

class InitReplBridgeResult:
    ok: bool
    transport: text
    title: text
    patchedPrompt: text
    error: text

impl InitReplBridgeResult:
    static fn ok(transport: text, title: text, patchedPrompt: text) -> InitReplBridgeResult:
        InitReplBridgeResult(ok: true, transport: transport, title: title, patchedPrompt: patchedPrompt, error: "")

    static fn failed(error: text) -> InitReplBridgeResult:
        InitReplBridgeResult(ok: false, transport: "", title: "", patchedPrompt: "", error: error)

fn initReplBridge(opts: InitBridgeOptions) -> InitReplBridgeResult:
    if opts.sessionId == "":
        return InitReplBridgeResult.failed("missing session id")
    if opts.sessionUrl == "":
        return InitReplBridgeResult.failed("missing session url")
    val transport = if opts.ccrV2: "ccr-v2:" + opts.workerEpoch.to_text() else: "ccr-v1"
    val patched = generateAndPatch(opts.initialPrompt, opts.sessionId)
    InitReplBridgeResult.ok(transport, deriveTitle(patched), patched)

fn generateAndPatch(prompt: text, sessionId: text) -> text:
    if prompt == "":
        return "[bridge:" + sessionId + "]"
    prompt + "\n[bridge:" + sessionId + "]"

fn onUserMessage(currentTitle: text, message: text) -> text:
    if currentTitle != "":
        return currentTitle
    deriveTitle(message)

fn deriveTitle(message: text) -> text:
    val trimmed = collapseWhitespace(message)
    if trimmed == "":
        return "Remote Control"
    if trimmed.len() > 80:
        return trimmed.substring(0, 80)
    trimmed

fn collapseWhitespace(value: text) -> text:
    var out = ""
    var pending = false
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch == " " or ch == "\n" or ch == "\t":
            pending = out != ""
        else:
            if pending:
                out = out + " "
            out = out + ch
            pending = false
        i = i + 1
    out

fn initReplBridgeSourceLinesModeled() -> i64:
    INIT_REPL_BRIDGE_SOURCE_LINES

