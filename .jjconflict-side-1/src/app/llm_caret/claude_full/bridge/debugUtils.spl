"""
Claude full bridge debug utilities parity model.
"""

const DEBUG_UTILS_SOURCE_LINES = 141
const DEBUG_MSG_LIMIT = 2000
const REDACT_MIN_LENGTH = 16

class DebugHttpError:
    message: text
    response_status: i64
    response_message: text

impl DebugHttpError:
    static fn new(message: text, status: i64, responseMessage: text) -> DebugHttpError:
        DebugHttpError(message: message, response_status: status, response_message: responseMessage)

class BridgeSkipEvent:
    reason: text
    debug_message: text
    v2: bool
    has_v2: bool

impl BridgeSkipEvent:
    static fn new(reason: text, debugMessage: text, v2: bool, hasV2: bool) -> BridgeSkipEvent:
        BridgeSkipEvent(reason: reason, debug_message: debugMessage, v2: v2, has_v2: hasV2)

fn debugFlatten(s: text) -> text:
    s.replace("\n", "\\n")

fn debugTruncate(s: text) -> text:
    val flat = debugFlatten(s)
    if flat.len() <= DEBUG_MSG_LIMIT:
        return flat
    flat.slice(0, DEBUG_MSG_LIMIT) + "... (" + flat.len().to_text() + " chars)"

fn redactSecretValue(value: text) -> text:
    if value.len() < REDACT_MIN_LENGTH:
        return "[REDACTED]"
    value.slice(0, 8) + "..." + value.slice(value.len() - 4, value.len())

fn debugBody(raw: text) -> text:
    debugTruncate(raw)

fn describeAxiosError(err: DebugHttpError) -> text:
    if err.response_message != "":
        return err.message + ": " + err.response_message
    err.message

fn extractHttpStatus(err: DebugHttpError) -> i64:
    err.response_status

fn extractErrorDetail(message: text, errorMessage: text) -> text:
    if message != "":
        return message
    errorMessage

fn logBridgeSkip(reason: text, debugMsg: text, v2: bool, hasV2: bool) -> BridgeSkipEvent:
    BridgeSkipEvent.new(reason, debugMsg, v2, hasV2)

fn debugUtilsSourceLinesModeled() -> i64:
    DEBUG_UTILS_SOURCE_LINES
