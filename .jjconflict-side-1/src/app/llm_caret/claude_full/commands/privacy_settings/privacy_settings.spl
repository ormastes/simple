"""
Import-safe privacy-settings command parity.
"""

class PrivacySettings:
    telemetry: bool
    crashReports: bool

impl PrivacySettings:
    static fn new(telemetry: bool, crashReports: bool) -> PrivacySettings:
        PrivacySettings(telemetry: telemetry, crashReports: crashReports)

fn privacySettingsCommandName() -> text:
    "privacy-settings"

fn privacySettingsSummary(settings: PrivacySettings) -> text:
    "telemetry=" + settings.telemetry.to_text() + " crashReports=" + settings.crashReports.to_text()

fn privacySettingsSourceLinesModeled() -> i64:
    57
