class CopyCodeBlock:
    code: text
    lang: text

    static fn new(code: text, lang: text) -> CopyCodeBlock:
        CopyCodeBlock(code: code, lang: lang)

class CopyMessage:
    typeName: text
    content: [text]
    isApiErrorMessage: bool

    static fn assistant(parts: [text]) -> CopyMessage:
        CopyMessage(typeName: "assistant", content: parts, isApiErrorMessage: false)

    static fn api_error(parts: [text]) -> CopyMessage:
        CopyMessage(typeName: "assistant", content: parts, isApiErrorMessage: true)

    static fn user(parts: [text]) -> CopyMessage:
        CopyMessage(typeName: "user", content: parts, isApiErrorMessage: false)

class CopyOption:
    label: text
    value: text
    description: text

    static fn new(label: text, value: text, description: text) -> CopyOption:
        CopyOption(label: label, value: value, description: description)

class CopySelectionContent:
    text: text
    filename: text
    blockIndex: i64

    static fn new(text: text, filename: text, blockIndex: i64) -> CopySelectionContent:
        CopySelectionContent(text: text, filename: filename, blockIndex: blockIndex)

class CopyCallResult:
    doneMessage: text
    renderPicker: bool
    selectedAge: i64
    selectedText: text
    blockCount: i64
    always: bool

    static fn new(doneMessage: text, renderPicker: bool, selectedAge: i64, selectedText: text, blockCount: i64, always: bool) -> CopyCallResult:
        CopyCallResult(doneMessage: doneMessage, renderPicker: renderPicker, selectedAge: selectedAge, selectedText: selectedText, blockCount: blockCount, always: always)

fn copyDir() -> text:
    "/tmp/claude"

fn responseFilename() -> text:
    "response.md"

fn maxLookback() -> i64:
    20

fn copyEventName() -> text:
    "tengu_copy"

fn collectRecentAssistantTexts(messages: [CopyMessage]) -> [text]:
    var texts: [text] = []
    var i = messages.len() - 1
    while i >= 0 and texts.len() < maxLookback():
        val msg = messages[i]
        if msg.typeName == "assistant" and not msg.isApiErrorMessage:
            val text = joinTextContent(msg.content)
            if text != "":
                texts.push(text)
        i = i - 1
    texts

fn joinTextContent(parts: [text]) -> text:
    var out = ""
    var i = 0
    while i < parts.len():
        if parts[i] != "":
            if out != "":
                out = out + "\n\n"
            out = out + parts[i]
        i = i + 1
    out

fn stripPromptXMLTags(markdown: text) -> text:
    val withoutOpen = markdown.replace("<prompt>", "")
    withoutOpen.replace("</prompt>", "")

fn extractCodeBlocks(markdown: text) -> [CopyCodeBlock]:
    val lines = stripPromptXMLTags(markdown).split("\n")
    var blocks: [CopyCodeBlock] = []
    var inBlock = false
    var lang = ""
    var code = ""
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if inBlock:
            if line.starts_with("```"):
                blocks.push(CopyCodeBlock.new(code, lang))
                inBlock = false
                lang = ""
                code = ""
            else:
                if code != "":
                    code = code + "\n"
                code = code + line
        else:
            if line.starts_with("```"):
                inBlock = true
                lang = line.substring(3).trim()
                code = ""
        i = i + 1
    blocks

fn isAlnum(ch: text) -> bool:
    val c = ch.to_i64()
    (c >= "a".to_i64() and c <= "z".to_i64()) or (c >= "A".to_i64() and c <= "Z".to_i64()) or (c >= "0".to_i64() and c <= "9".to_i64())

fn sanitizeLanguage(lang: text) -> text:
    var out = lang
    out = out.replace(".", "")
    out = out.replace("/", "")
    out = out.replace("\\", "")
    out = out.replace("-", "")
    out = out.replace("_", "")
    out = out.replace(" ", "")
    out

fn fileExtension(lang: text) -> text:
    if lang != "":
        val sanitized = sanitizeLanguage(lang)
        if sanitized != "" and sanitized != "plaintext":
            return "." + sanitized
    ".txt"

fn copyFilePath(filename: text) -> text:
    copyDir() + "/" + filename

fn countLines(textValue: text) -> i64:
    var count = 1
    var i = 0
    while i < textValue.len():
        if textValue.char_at(i) == "\n":
            count = count + 1
        i = i + 1
    count

fn copyOrWriteResult(textValue: text, filename: text, fileWriteOk: bool) -> text:
    val base = "Copied to clipboard (" + textValue.len().to_string() + " characters, " + countLines(textValue).to_string() + " lines)"
    if fileWriteOk:
        return base + "\nAlso written to " + copyFilePath(filename)
    base

fn writeOnlyResult(textValue: text, filename: text, fileWriteOk: bool, errorMessage: text) -> text:
    if fileWriteOk:
        return "Written to " + copyFilePath(filename)
    "Failed to write file: " + errorMessage

fn truncateLine(textValue: text, maxLen: i64) -> text:
    val firstLine = textValue.split("\n")[0]
    if firstLine.len() <= maxLen:
        return firstLine
    if maxLen <= 3:
        return firstLine.substring(0, maxLen)
    firstLine.substring(0, maxLen - 3) + "..."

fn codeBlockDescription(block: CopyCodeBlock) -> text:
    val lines = countLines(block.code)
    if block.lang != "" and lines > 1:
        return block.lang + ", " + lines.to_string() + " lines"
    if block.lang != "":
        return block.lang
    if lines > 1:
        return lines.to_string() + " lines"
    ""

fn pickerOptions(fullText: text, codeBlocks: [CopyCodeBlock]) -> [CopyOption]:
    var options: [CopyOption] = []
    options.push(CopyOption.new("Full response", "full", fullText.len().to_string() + " chars, " + countLines(fullText).to_string() + " lines"))
    var i = 0
    while i < codeBlocks.len():
        options.push(CopyOption.new(truncateLine(codeBlocks[i].code, 60), i.to_string(), codeBlockDescription(codeBlocks[i])))
        i = i + 1
    options.push(CopyOption.new("Always copy full response", "always", "Skip this picker in the future (revert via /config)"))
    options

fn selectionContent(fullText: text, codeBlocks: [CopyCodeBlock], selected: text) -> CopySelectionContent:
    if selected == "full" or selected == "always":
        return CopySelectionContent.new(fullText, responseFilename(), -1)
    val index = selected.to_i64() ?? 0
    val block = codeBlocks[index]
    CopySelectionContent.new(block.code, "copy" + fileExtension(block.lang), index)

fn handlePickerSelect(fullText: text, codeBlocks: [CopyCodeBlock], selected: text, messageAge: i64, fileWriteOk: bool) -> text:
    val content = selectionContent(fullText, codeBlocks, selected)
    val result = copyOrWriteResult(content.text, content.filename, fileWriteOk)
    if selected == "always":
        return result + "\nPreference saved. Use /config to change copyFullResponse"
    result

fn handlePickerWrite(fullText: text, codeBlocks: [CopyCodeBlock], selected: text, fileWriteOk: bool, errorMessage: text) -> text:
    val content = selectionContent(fullText, codeBlocks, selected)
    writeOnlyResult(content.text, content.filename, fileWriteOk, errorMessage)

fn copyCancelledMessage() -> text:
    "Copy cancelled"

fn parseCopyAge(args: text, available: i64) -> i64:
    val arg = args.trim()
    if arg == "":
        return 0
    val n = arg.to_i64() ?? 0
    if n < 1:
        return -1
    if n > available:
        return -2
    n - 1

fn copyUsageMessage(arg: text) -> text:
    "Usage: /copy [N] where N is 1 (latest), 2, 3, ... Got: " + arg

fn onlyAvailableMessage(count: i64) -> text:
    val noun = if count == 1: "message" else: "messages"
    "Only " + count.to_string() + " assistant " + noun + " available to copy"

fn callCopy(messages: [CopyMessage], args: text, copyFullResponse: bool, fileWriteOk: bool) -> CopyCallResult:
    val texts = collectRecentAssistantTexts(messages)
    if texts.len() == 0:
        return CopyCallResult.new("No assistant message to copy", false, 0, "", 0, copyFullResponse)
    val age = parseCopyAge(args, texts.len())
    if age == -1:
        return CopyCallResult.new(copyUsageMessage(args.trim()), false, 0, "", 0, copyFullResponse)
    if age == -2:
        return CopyCallResult.new(onlyAvailableMessage(texts.len()), false, 0, "", 0, copyFullResponse)
    val textValue = texts[age]
    val blocks = extractCodeBlocks(textValue)
    if blocks.len() == 0 or copyFullResponse:
        return CopyCallResult.new(copyOrWriteResult(textValue, responseFilename(), fileWriteOk), false, age, textValue, blocks.len(), copyFullResponse)
    CopyCallResult.new("", true, age, textValue, blocks.len(), copyFullResponse)

fn copySourceLinesModeled() -> i64:
    370
