"""
Claude full terminalSetup command index parity.
"""

class TerminalSetupCommand:
    typeName: text
    name: text
    description: text
    argumentHint: text
    loadPath: text

impl TerminalSetupCommand:
    static fn new() -> TerminalSetupCommand:
        TerminalSetupCommand(typeName: "local-jsx", name: "terminal-setup", description: "Install Claude Code terminal integration", argumentHint: "", loadPath: "./terminalSetup.js")

fn terminalSetupCommand() -> TerminalSetupCommand:
    TerminalSetupCommand.new()

