class CompactContext:
    messageCount: i64
    args: text
    verbose: bool
    aborted: bool
    sessionMemoryAvailable: bool
    reactiveOnlyMode: bool
    microcompactMessageCount: i64
    userDisplayMessage: text
    upgradeMessage: text
    querySource: text
    agentId: text
    additionalWorkingDirectories: [text]
    tools: [text]
    mainLoopModel: text
    mcpClients: [text]
    customSystemPrompt: text
    appendSystemPrompt: text

    static fn new(messageCount: i64, args: text, verbose: bool, aborted: bool, sessionMemoryAvailable: bool, reactiveOnlyMode: bool, microcompactMessageCount: i64, userDisplayMessage: text, upgradeMessage: text, querySource: text, agentId: text, additionalWorkingDirectories: [text], tools: [text], mainLoopModel: text, mcpClients: [text], customSystemPrompt: text, appendSystemPrompt: text) -> CompactContext:
        CompactContext(messageCount: messageCount, args: args, verbose: verbose, aborted: aborted, sessionMemoryAvailable: sessionMemoryAvailable, reactiveOnlyMode: reactiveOnlyMode, microcompactMessageCount: microcompactMessageCount, userDisplayMessage: userDisplayMessage, upgradeMessage: upgradeMessage, querySource: querySource, agentId: agentId, additionalWorkingDirectories: additionalWorkingDirectories, tools: tools, mainLoopModel: mainLoopModel, mcpClients: mcpClients, customSystemPrompt: customSystemPrompt, appendSystemPrompt: appendSystemPrompt)

class CompactCallResult:
    typeName: text
    path: text
    errorMessage: text
    customInstructions: text
    messagesAfterBoundary: i64
    messagesForCompact: i64
    displayText: text
    userContextCacheCleared: bool
    postCleanupRan: bool
    promptCacheBreakNotified: bool
    postCompactionMarked: bool
    warningSuppressed: bool
    lastSummarizedMessageIdReset: bool
    cacheParamsBuilt: bool
    preHooksExecuted: bool
    progressEvents: [text]
    streamMode: text
    sdkStatus: text
    responseLengthReset: bool

    static fn new(typeName: text, path: text, errorMessage: text, customInstructions: text, messagesAfterBoundary: i64, messagesForCompact: i64, displayText: text, userContextCacheCleared: bool, postCleanupRan: bool, promptCacheBreakNotified: bool, postCompactionMarked: bool, warningSuppressed: bool, lastSummarizedMessageIdReset: bool, cacheParamsBuilt: bool, preHooksExecuted: bool, progressEvents: [text], streamMode: text, sdkStatus: text, responseLengthReset: bool) -> CompactCallResult:
        CompactCallResult(typeName: typeName, path: path, errorMessage: errorMessage, customInstructions: customInstructions, messagesAfterBoundary: messagesAfterBoundary, messagesForCompact: messagesForCompact, displayText: displayText, userContextCacheCleared: userContextCacheCleared, postCleanupRan: postCleanupRan, promptCacheBreakNotified: promptCacheBreakNotified, postCompactionMarked: postCompactionMarked, warningSuppressed: warningSuppressed, lastSummarizedMessageIdReset: lastSummarizedMessageIdReset, cacheParamsBuilt: cacheParamsBuilt, preHooksExecuted: preHooksExecuted, progressEvents: progressEvents, streamMode: streamMode, sdkStatus: sdkStatus, responseLengthReset: responseLengthReset)

class CompactCacheParams:
    systemPrompt: text
    userContext: text
    systemContext: text
    toolUseContextAgentId: text
    forkContextMessages: i64
    tools: [text]
    mainLoopModel: text
    mcpClients: [text]
    additionalWorkingDirectories: [text]

    static fn new(systemPrompt: text, userContext: text, systemContext: text, toolUseContextAgentId: text, forkContextMessages: i64, tools: [text], mainLoopModel: text, mcpClients: [text], additionalWorkingDirectories: [text]) -> CompactCacheParams:
        CompactCacheParams(systemPrompt: systemPrompt, userContext: userContext, systemContext: systemContext, toolUseContextAgentId: toolUseContextAgentId, forkContextMessages: forkContextMessages, tools: tools, mainLoopModel: mainLoopModel, mcpClients: mcpClients, additionalWorkingDirectories: additionalWorkingDirectories)

class CompactReactiveOutcome:
    ok: bool
    reason: text
    userDisplayMessage: text

    static fn ok(userDisplayMessage: text) -> CompactReactiveOutcome:
        CompactReactiveOutcome(ok: true, reason: "", userDisplayMessage: userDisplayMessage)

    static fn failed(reason: text) -> CompactReactiveOutcome:
        CompactReactiveOutcome(ok: false, reason: reason, userDisplayMessage: "")

class CompactHookResult:
    newCustomInstructions: text
    userDisplayMessage: text

    static fn new(newCustomInstructions: text, userDisplayMessage: text) -> CompactHookResult:
        CompactHookResult(newCustomInstructions: newCustomInstructions, userDisplayMessage: userDisplayMessage)

fn callCompact(context: CompactContext) -> CompactCallResult:
    if context.messageCount == 0:
        return compactError("No messages to compact", context.args.trim(), 0)
    val customInstructions = context.args.trim()
    if context.aborted:
        return compactError("Compaction canceled.", customInstructions, context.messageCount)
    if customInstructions == "" and context.sessionMemoryAvailable:
        return CompactCallResult.new("compact", "session-memory", "", customInstructions, context.messageCount, context.messageCount, buildCompactDisplayText(context.verbose, "", context.upgradeMessage), true, true, true, true, true, false, false, false, [], "", "", false)
    if context.reactiveOnlyMode:
        return compactViaReactive(context, CompactHookResult.new("", ""), CompactReactiveOutcome.ok(context.userDisplayMessage))
    CompactCallResult.new("compact", "traditional", "", customInstructions, context.messageCount, context.microcompactMessageCount, buildCompactDisplayText(context.verbose, context.userDisplayMessage, context.upgradeMessage), true, true, false, false, true, true, true, false, [], "", "", false)

fn compactViaReactive(context: CompactContext, hookResult: CompactHookResult, outcome: CompactReactiveOutcome) -> CompactCallResult:
    val customInstructions = mergeHookInstructions(context.args.trim(), hookResult.newCustomInstructions)
    val startEvents = ["hooks_start", "compact_start"]
    if not outcome.ok:
        return CompactCallResult.new("", "reactive", compactReactiveErrorMessage(outcome.reason), customInstructions, context.messageCount, context.messageCount, "", false, false, false, false, false, false, true, true, ["hooks_start", "compact_start", "compact_end"], "requesting", "", true)
    val combined = combineDisplayMessages(hookResult.userDisplayMessage, outcome.userDisplayMessage)
    CompactCallResult.new("compact", "reactive", "", customInstructions, context.messageCount, context.messageCount, buildCompactDisplayText(context.verbose, combined, context.upgradeMessage), true, true, false, false, true, true, true, true, startEvents + ["compact_end"], "requesting", "", true)

fn compactError(message: text, customInstructions: text, messageCount: i64) -> CompactCallResult:
    CompactCallResult.new("", "error", message, customInstructions, messageCount, messageCount, "", false, false, false, false, false, false, false, false, [], "", "", false)

fn buildCompactDisplayText(verbose: bool, userDisplayMessage: text, upgradeMessage: text) -> text:
    var parts: [text] = []
    if not verbose:
        parts.push("(Ctrl+O to see full summary)")
    if userDisplayMessage != "":
        parts.push(userDisplayMessage)
    if upgradeMessage != "":
        parts.push(upgradeMessage)
    if parts.len() == 0:
        return "Compacted "
    "Compacted " + joinLines(parts)

fn getCompactCacheSharingParams(context: CompactContext, forkContextMessages: i64) -> CompactCacheParams:
    CompactCacheParams.new(buildEffectiveCompactSystemPrompt(context), "user-context", "system-context", context.agentId, forkContextMessages, context.tools, context.mainLoopModel, context.mcpClients, context.additionalWorkingDirectories)

fn buildEffectiveCompactSystemPrompt(context: CompactContext) -> text:
    val base = "default:" + context.mainLoopModel
    if context.customSystemPrompt != "":
        return context.customSystemPrompt
    if context.appendSystemPrompt != "":
        return base + "\n" + context.appendSystemPrompt
    base

fn mergeHookInstructions(customInstructions: text, hookInstructions: text) -> text:
    if customInstructions == "":
        return hookInstructions
    if hookInstructions == "":
        return customInstructions
    customInstructions + "\n" + hookInstructions

fn combineDisplayMessages(preCompactMessage: text, postCompactMessage: text) -> text:
    if preCompactMessage == "":
        return postCompactMessage
    if postCompactMessage == "":
        return preCompactMessage
    preCompactMessage + "\n" + postCompactMessage

fn compactReactiveErrorMessage(reason: text) -> text:
    if reason == "too_few_groups":
        return compactErrorNotEnoughMessages()
    if reason == "aborted":
        return compactErrorUserAbort()
    if reason == "exhausted" or reason == "error" or reason == "media_unstrippable":
        return compactErrorIncompleteResponse()
    compactErrorIncompleteResponse()

fn compactErrorNotEnoughMessages() -> text:
    "Not enough messages to compact"

fn compactErrorIncompleteResponse() -> text:
    "Compaction failed because response was incomplete"

fn compactErrorUserAbort() -> text:
    "User aborted compaction"

fn joinLines(parts: [text]) -> text:
    var out = ""
    var i = 0
    while i < parts.len():
        if i > 0:
            out = out + "\n"
        out = out + parts[i]
        i = i + 1
    out

