"""
Claude full theme command parity.
"""

fn themeCommandName() -> text:
    "theme"

fn canonicalTheme(raw: text) -> text:
    val theme = raw.trim().to_lower()
    if theme == "dark" or theme == "light" or theme == "system":
        return theme
    "system"

fn themeStatus(raw: text) -> text:
    "Theme set to: " + canonicalTheme(raw)

fn themeOptions() -> [text]:
    ["dark", "light", "system"]

fn themeSourceLinesModeled() -> i64:
    56
