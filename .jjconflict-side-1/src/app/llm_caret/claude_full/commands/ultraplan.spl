"""
Claude full ultraplan command parity.
"""

class UltraplanSession:
    enabled: bool
    mode: text
    sessionId: text
    currentPlanTitle: text
    currentPlanSummary: text
    acceptedPlanCount: i64

impl UltraplanSession:
    static fn new(enabled: bool, mode: text, sessionId: text, currentPlanTitle: text, currentPlanSummary: text, acceptedPlanCount: i64) -> UltraplanSession:
        UltraplanSession(enabled: enabled, mode: mode, sessionId: sessionId, currentPlanTitle: currentPlanTitle, currentPlanSummary: currentPlanSummary, acceptedPlanCount: acceptedPlanCount)

class UltraplanResult:
    ok: bool
    status: text
    mode: text
    sessionId: text
    title: text
    summary: text
    nextAction: text
    sourceLine: text

impl UltraplanResult:
    static fn new(ok: bool, status: text, mode: text, sessionId: text, title: text, summary: text, nextAction: text, sourceLine: text) -> UltraplanResult:
        UltraplanResult(ok: ok, status: status, mode: mode, sessionId: sessionId, title: title, summary: summary, nextAction: nextAction, sourceLine: sourceLine)

fn ultraplanCommandName() -> text:
    "ultraplan"

fn ultraplanPlanModeName() -> text:
    "ultraplan"

fn ultraplanArgumentHint() -> text:
    "[goal]"

fn ultraplanLoadPath() -> text:
    "./ultraplan.js"

fn ultraplanCommandDescription() -> text:
    "Create and refine an implementation plan before coding"

fn ultraplanSourceLinesModeled() -> i64:
    470

fn ultraplanSourceLine(line: i64) -> text:
    "ultraplan source line " + line.to_text()

fn ultraplanDefaultSession(sessionId: text) -> UltraplanSession:
    UltraplanSession.new(true, "default", sessionId.trim(), "", "", 0)

fn ultraplanDisabledSession(sessionId: text) -> UltraplanSession:
    UltraplanSession.new(false, "default", sessionId.trim(), "", "", 0)

fn ultraplanNormalizeGoal(goal: text) -> text:
    goal.trim()

fn ultraplanValidGoal(goal: text) -> bool:
    ultraplanNormalizeGoal(goal).len() > 0

fn ultraplanTitleFor(goal: text) -> text:
    val normalized = ultraplanNormalizeGoal(goal)
    if normalized.len() == 0:
        return "Untitled ultraplan"
    "Plan: " + normalized

fn ultraplanSummaryFor(goal: text, acceptedPlanCount: i64) -> text:
    val normalized = ultraplanNormalizeGoal(goal)
    if normalized.len() == 0:
        return "No goal supplied for ultraplan planning."
    "Ultraplan for " + normalized + " with " + acceptedPlanCount.to_text() + " prior accepted plan(s)."

fn ultraplanNextActionFor(goal: text) -> text:
    if not ultraplanValidGoal(goal):
        return "Ask for a concrete goal before entering ultraplan mode."
    "Review the proposed plan, then accept or refine it."

fn ultraplanEnterMode(session: UltraplanSession) -> UltraplanSession:
    UltraplanSession.new(session.enabled, ultraplanPlanModeName(), session.sessionId, session.currentPlanTitle, session.currentPlanSummary, session.acceptedPlanCount)

fn ultraplanRecordPlan(session: UltraplanSession, title: text, summary: text) -> UltraplanSession:
    UltraplanSession.new(session.enabled, ultraplanPlanModeName(), session.sessionId, title, summary, session.acceptedPlanCount + 1)

fn ultraplanDisabledResult(session: UltraplanSession) -> UltraplanResult:
    UltraplanResult.new(false, "disabled", session.mode, session.sessionId, session.currentPlanTitle, session.currentPlanSummary, "Enable ultraplan before creating a plan.", ultraplanSourceLine(31))

fn ultraplanInvalidInputResult(session: UltraplanSession) -> UltraplanResult:
    UltraplanResult.new(false, "invalid-input", session.mode, session.sessionId, "", "No goal supplied for ultraplan planning.", ultraplanNextActionFor(""), ultraplanSourceLine(47))

fn ultraplanCreatePlan(session: UltraplanSession, goal: text) -> UltraplanResult:
    if not session.enabled:
        return ultraplanDisabledResult(session)
    if not ultraplanValidGoal(goal):
        return ultraplanInvalidInputResult(session)

    val planning = ultraplanEnterMode(session)
    val title = ultraplanTitleFor(goal)
    val summary = ultraplanSummaryFor(goal, session.acceptedPlanCount)
    val updated = ultraplanRecordPlan(planning, title, summary)
    UltraplanResult.new(true, "plan-created", updated.mode, updated.sessionId, updated.currentPlanTitle, updated.currentPlanSummary, ultraplanNextActionFor(goal), ultraplanSourceLine(89))

fn ultraplanRefinePlan(session: UltraplanSession, feedback: text) -> UltraplanResult:
    if not session.enabled:
        return ultraplanDisabledResult(session)
    if not ultraplanValidGoal(feedback):
        return ultraplanInvalidInputResult(session)

    val title = session.currentPlanTitle
    val baseSummary = session.currentPlanSummary
    val summary = baseSummary + " Refinement: " + ultraplanNormalizeGoal(feedback)
    val updated = ultraplanRecordPlan(ultraplanEnterMode(session), title, summary)
    UltraplanResult.new(true, "plan-refined", updated.mode, updated.sessionId, updated.currentPlanTitle, updated.currentPlanSummary, "Review the refined plan.", ultraplanSourceLine(117))

