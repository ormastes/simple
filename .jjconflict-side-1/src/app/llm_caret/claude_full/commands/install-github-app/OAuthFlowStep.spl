"""
Claude full install-github-app OAuthFlowStep parity.
"""

class OAuthFlowStepModel:
    status: text
    deviceUrl: text
    userCode: text
    error: text

impl OAuthFlowStepModel:
    static fn new(status: text, deviceUrl: text, userCode: text, error: text) -> OAuthFlowStepModel:
        OAuthFlowStepModel(status: oauthFlowStepNormalizeStatus(status), deviceUrl: deviceUrl.trim(), userCode: userCode.trim(), error: error.trim())

fn oauthFlowStepTitle() -> text:
    "Sign in with Anthropic"

fn oauthFlowStepCommandTitle() -> text:
    "Install GitHub App"

fn oauthFlowStepInitialStatus() -> text:
    "starting"

fn oauthFlowStepOpeningStatus() -> text:
    "opening-browser"

fn oauthFlowStepWaitingStatus() -> text:
    "waiting"

fn oauthFlowStepSuccessStatus() -> text:
    "success"

fn oauthFlowStepErrorStatus() -> text:
    "error"

fn oauthFlowStepCancelKey() -> text:
    "escape"

fn oauthFlowStepRetryKey() -> text:
    "r"

fn oauthFlowStepContinueKey() -> text:
    "enter"

fn oauthFlowStepNormalizeStatus(status: text) -> text:
    val value = status.trim()
    if value == "starting" or value == "opening-browser" or value == "waiting" or value == "success" or value == "error" or value == "cancelled":
        return value
    "starting"

fn oauthFlowStepInstructions(deviceUrl: text, userCode: text) -> text:
    val url = deviceUrl.trim()
    val code = userCode.trim()
    if url == "" and code == "":
        return "Opening Anthropic sign-in in your browser"
    if code == "":
        return "Open " + url + " to sign in with Anthropic"
    "Open " + url + " and enter code " + code

fn oauthFlowStepStatusLine(status: text) -> text:
    val value = oauthFlowStepNormalizeStatus(status)
    if value == "opening-browser":
        return "Opening browser"
    if value == "waiting":
        return "Waiting for authentication"
    if value == "success":
        return "Authentication complete"
    if value == "error":
        return "Authentication failed"
    if value == "cancelled":
        return "Authentication cancelled"
    "Starting authentication"

fn oauthFlowStepCanRetry(status: text) -> bool:
    val value = oauthFlowStepNormalizeStatus(status)
    value == "error" or value == "cancelled"

fn oauthFlowStepCanCancel(status: text) -> bool:
    val value = oauthFlowStepNormalizeStatus(status)
    value == "starting" or value == "opening-browser" or value == "waiting"

fn oauthFlowStepNextAction(status: text, key: text) -> text:
    val value = oauthFlowStepNormalizeStatus(status)
    val pressed = key.trim()
    if pressed == oauthFlowStepCancelKey() and oauthFlowStepCanCancel(value):
        return "cancel"
    if pressed == oauthFlowStepRetryKey() and oauthFlowStepCanRetry(value):
        return "retry"
    if pressed == oauthFlowStepContinueKey() and value == "success":
        return "continue"
    "wait"

fn oauthFlowStepErrorLine(error: text) -> text:
    val value = error.trim()
    if value == "":
        return "Authentication failed"
    "Authentication failed: " + value

fn oauthFlowStepSourceLinesModeled() -> i64:
    275
