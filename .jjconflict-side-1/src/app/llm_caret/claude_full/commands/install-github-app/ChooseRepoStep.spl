"""
Claude full install-github-app ChooseRepoStep parity model.
"""

class ChooseRepoStepModel:
    repoUrl: text
    useCurrentRepo: bool
    currentRepo: text
    owner: text
    repo: text
    canContinue: bool
    message: text

impl ChooseRepoStepModel:
    static fn new(repoUrl: text, useCurrentRepo: bool, currentRepo: text) -> ChooseRepoStepModel:
        val selected = chooseRepoSelectedUrl(repoUrl, useCurrentRepo, currentRepo)
        ChooseRepoStepModel(
            repoUrl: selected,
            useCurrentRepo: useCurrentRepo,
            currentRepo: currentRepo.trim(),
            owner: chooseRepoOwner(selected),
            repo: chooseRepoName(selected),
            canContinue: chooseRepoIsValid(selected),
            message: chooseRepoMessage(selected),
        )

fn chooseRepoSelectedUrl(repoUrl: text, useCurrentRepo: bool, currentRepo: text) -> text:
    if useCurrentRepo:
        return currentRepo.trim()
    repoUrl.trim()

fn chooseRepoTrimGithubPrefix(repoUrl: text) -> text:
    var value = repoUrl.trim()
    if value.starts_with("https://github.com/"):
        value = value.slice(19, value.len())
    elif value.starts_with("http://github.com/"):
        value = value.slice(18, value.len())
    elif value.starts_with("git@github.com:"):
        value = value.slice(15, value.len())
    if value.ends_with(".git"):
        value = value.slice(0, value.len() - 4)
    value

fn chooseRepoOwner(repoUrl: text) -> text:
    val value = chooseRepoTrimGithubPrefix(repoUrl)
    val parts = value.split("/")
    if parts.len() >= 2:
        return parts[0].trim()
    ""

fn chooseRepoName(repoUrl: text) -> text:
    val value = chooseRepoTrimGithubPrefix(repoUrl)
    val parts = value.split("/")
    if parts.len() >= 2:
        return parts[1].trim()
    ""

fn chooseRepoIsValid(repoUrl: text) -> bool:
    chooseRepoOwner(repoUrl) != "" and chooseRepoName(repoUrl) != ""

fn chooseRepoMessage(repoUrl: text) -> text:
    if chooseRepoIsValid(repoUrl):
        return "Repository " + chooseRepoOwner(repoUrl) + "/" + chooseRepoName(repoUrl) + " selected"
    "Enter a GitHub repository URL or owner/repo"

fn chooseRepoGhRepoArg(repoUrl: text) -> text:
    if not chooseRepoIsValid(repoUrl):
        return ""
    chooseRepoOwner(repoUrl) + "/" + chooseRepoName(repoUrl)

fn chooseRepoNextStep(repoUrl: text) -> text:
    if chooseRepoIsValid(repoUrl):
        return "check-existing-secret"
    "choose-repo"

fn chooseRepoStepSourceLinesModeled() -> i64:
    210
