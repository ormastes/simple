"""
Claude full tag command parity.
"""

class TagCommandState:
    sessionId: text
    existingTags: [text]
    savedTag: text

impl TagCommandState:
    static fn new(sessionId: text, existingTags: [text], savedTag: text) -> TagCommandState:
        TagCommandState(sessionId: sessionId, existingTags: existingTags, savedTag: savedTag)

class TagCommandResult:
    ok: bool
    tag: text
    message: text
    state: TagCommandState

impl TagCommandResult:
    static fn new(ok: bool, tag: text, message: text, state: TagCommandState) -> TagCommandResult:
        TagCommandResult(ok: ok, tag: tag, message: message, state: state)

fn normalizeTag(raw: text) -> text:
    val trimmed = raw.trim()
    if trimmed == "":
        return ""
    var out = ""
    var i = 0
    while i < trimmed.len():
        val ch = trimmed[i]
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            if out.len() > 0 and not out.ends_with("-"):
                out = out + "-"
        else:
            out = out + ch.to_text().to_lower()
        i = i + 1
    out

fn tagExists(tags: [text], tag: text) -> bool:
    var i = 0
    while i < tags.len():
        if tags[i] == tag:
            return true
        i = i + 1
    false

fn applyTag(raw: text, state: TagCommandState) -> TagCommandResult:
    val tag = normalizeTag(raw)
    if tag == "":
        return TagCommandResult.new(false, "", "Please provide a tag name.", state)
    if tagExists(state.existingTags, tag):
        return TagCommandResult.new(true, tag, "Conversation already tagged: " + tag, state)
    var nextTags = state.existingTags
    nextTags.push(tag)
    val next = TagCommandState.new(state.sessionId, nextTags, tag)
    TagCommandResult.new(true, tag, "Conversation tagged: " + tag, next)

fn formatTagPill(tag: text) -> text:
    "#" + normalizeTag(tag)

fn tagCommandSourceLinesModeled() -> i64:
    214
