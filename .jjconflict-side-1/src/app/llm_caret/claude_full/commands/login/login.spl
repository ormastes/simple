"""
Claude full login command parity.
"""

class LoginCommandDescriptor:
    typeName: text
    name: text
    description: text
    provider: text

impl LoginCommandDescriptor:
    static fn new(provider: text) -> LoginCommandDescriptor:
        LoginCommandDescriptor(typeName: "local-jsx", name: "login", description: "Authenticate Claude Code", provider: provider)

class LoginResult:
    provider: text
    message: text
    shouldOpenBrowser: bool

impl LoginResult:
    static fn new(provider: text, message: text, shouldOpenBrowser: bool) -> LoginResult:
        LoginResult(provider: provider, message: message, shouldOpenBrowser: shouldOpenBrowser)

fn loginCommand(provider: text) -> LoginCommandDescriptor:
    LoginCommandDescriptor.new(provider)

fn runLoginCommand(provider: text, alreadyAuthenticated: bool) -> LoginResult:
    if alreadyAuthenticated:
        return LoginResult.new(provider, "Already logged in", false)
    LoginResult.new(provider, "Open browser to log in with " + provider, true)

fn loginSourceLinesModeled() -> i64:
    103
