class ChromeMenuOption:
    label: text
    value: text

    static fn new(label: text, value: text) -> ChromeMenuOption:
        ChromeMenuOption(label: label, value: value)

class ChromeMenuState:
    isExtensionInstalled: bool
    enabledByDefault: bool
    showInstallHint: bool
    selectKey: i64
    openedUrl: text
    openMode: text

    static fn new(isExtensionInstalled: bool, enabledByDefault: bool) -> ChromeMenuState:
        ChromeMenuState(isExtensionInstalled: isExtensionInstalled, enabledByDefault: enabledByDefault, showInstallHint: false, selectKey: 0, openedUrl: "", openMode: "")

    static fn with_values(isExtensionInstalled: bool, enabledByDefault: bool, showInstallHint: bool, selectKey: i64, openedUrl: text, openMode: text) -> ChromeMenuState:
        ChromeMenuState(isExtensionInstalled: isExtensionInstalled, enabledByDefault: enabledByDefault, showInstallHint: showInstallHint, selectKey: selectKey, openedUrl: openedUrl, openMode: openMode)

fn chromeExtensionUrl() -> text:
    "https://claude.ai/chrome"

fn chromePermissionsUrl() -> text:
    "https://clau.de/chrome/permissions"

fn chromeReconnectUrl() -> text:
    "https://clau.de/chrome/reconnect"

fn chromeLearnMoreUrl() -> text:
    "https://code.claude.com/docs/en/chrome"

fn chromeDialogTitle() -> text:
    "Claude in Chrome (Beta)"

fn chromeDialogColor() -> text:
    "chromeYellow"

fn chromeUsageText() -> text:
    "claude --chrome or claude --no-chrome"

fn chromeIntroText() -> text:
    "Claude in Chrome works with the Chrome extension to let you control your browser directly from Claude Code. Navigate websites, fill forms, capture screenshots, record GIFs, and debug with console logs and network requests."

fn chromePermissionsHelpText() -> text:
    "Site-level permissions are inherited from the Chrome extension. Manage permissions in the Chrome extension settings to control which sites Claude can browse, click, and type on."

fn chromeWslErrorText() -> text:
    "Claude in Chrome is not supported in WSL at this time."

fn chromeSubscriberErrorText() -> text:
    "Claude in Chrome requires a claude.ai subscription."

fn chromeInstallHintText() -> text:
    "Once installed, select \"Reconnect extension\" to connect."

fn claudeInChromeMcpServerName() -> text:
    "claude-in-chrome"

fn chromeRequiresExtensionSuffix(isExtensionInstalled: bool) -> text:
    if isExtensionInstalled:
        return ""
    " (requires extension)"

fn chromeIsDisabled(isWSL: bool, isClaudeAISubscriber: bool) -> bool:
    isWSL or not isClaudeAISubscriber

fn chromeStatusText(isConnected: bool) -> text:
    if isConnected:
        return "Enabled"
    "Disabled"

fn chromeExtensionStatusText(isExtensionInstalled: bool) -> text:
    if isExtensionInstalled:
        return "Installed"
    "Not detected"

fn chromeDefaultLabel(enabledByDefault: bool) -> text:
    if enabledByDefault:
        return "Enabled by default: Yes"
    "Enabled by default: No"

fn chromeOpenMode(isHomespace: bool) -> text:
    if isHomespace:
        return "browser"
    "chrome"

fn chromeOptions(isExtensionInstalled: bool, isHomespace: bool, enabledByDefault: bool) -> [ChromeMenuOption]:
    val suffix = chromeRequiresExtensionSuffix(isExtensionInstalled)
    var options: [ChromeMenuOption] = []
    if not isExtensionInstalled and not isHomespace:
        options.push(ChromeMenuOption.new("Install Chrome extension", "install-extension"))
    options.push(ChromeMenuOption.new("Manage permissions" + suffix, "manage-permissions"))
    options.push(ChromeMenuOption.new("Reconnect extension" + suffix, "reconnect"))
    options.push(ChromeMenuOption.new(chromeDefaultLabel(enabledByDefault), "toggle-default"))
    options

fn chromeIsConnected(clientName: text, clientType: text) -> bool:
    clientName == claudeInChromeMcpServerName() and clientType == "connected"

fn chromeHandleAction(action: text, state: ChromeMenuState, isHomespace: bool, extensionCheckInstalled: bool) -> ChromeMenuState:
    val nextKey = state.selectKey + 1
    val mode = chromeOpenMode(isHomespace)
    if action == "install-extension":
        return ChromeMenuState.with_values(state.isExtensionInstalled, state.enabledByDefault, true, nextKey, chromeExtensionUrl(), mode)
    if action == "reconnect":
        val showHint = if extensionCheckInstalled: false else: state.showInstallHint
        return ChromeMenuState.with_values(extensionCheckInstalled, state.enabledByDefault, showHint, nextKey, chromeReconnectUrl(), mode)
    if action == "manage-permissions":
        return ChromeMenuState.with_values(state.isExtensionInstalled, state.enabledByDefault, state.showInstallHint, nextKey, chromePermissionsUrl(), mode)
    if action == "toggle-default":
        return ChromeMenuState.with_values(state.isExtensionInstalled, not state.enabledByDefault, state.showInstallHint, state.selectKey, "", "")
    state

fn chromeCallSnapshot(isExtensionInstalled: bool, configEnabled: bool, isClaudeAISubscriber: bool, isWSL: bool) -> ChromeMenuState:
    ChromeMenuState.new(isExtensionInstalled, configEnabled)

fn chromeSourceLinesModeled() -> i64:
    284
