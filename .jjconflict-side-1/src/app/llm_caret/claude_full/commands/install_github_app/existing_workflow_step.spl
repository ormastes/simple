"""
Import-safe ExistingWorkflowStep parity.
"""

fn existingWorkflowStepTitle() -> text: "Existing Workflow Found"
fn existingWorkflowStepCommandTitle() -> text: "Install GitHub App"
fn existingWorkflowStepUpdateAction() -> text: "Update workflow file with latest version"
fn existingWorkflowStepUpdateValue() -> text: "update"
fn existingWorkflowStepSkipAction() -> text: "Skip workflow update (configure secrets only)"
fn existingWorkflowStepSkipValue() -> text: "skip"
fn existingWorkflowStepExitAction() -> text: "Exit without making changes"
fn existingWorkflowStepExitValue() -> text: "exit"
fn existingWorkflowStepPath() -> text: ".github/workflows/claude.yml"
fn existingWorkflowStepRepoLine(repoName: text) -> text: "Repository: " + repoName
fn existingWorkflowStepExistsLine() -> text: "A Claude workflow file already exists at"
fn existingWorkflowStepQuestion() -> text: "What would you like to do?"
fn existingWorkflowStepTemplatePrompt() -> text: "View the latest workflow template at:"
fn existingWorkflowStepTemplateUrl() -> text: "https://github.com/anthropics/claude-code-action/blob/main/examples/claude.yml"
fn existingWorkflowStepDefaultAction(action: text) -> text:
    if action == "":
        return existingWorkflowStepUpdateValue()
    action
fn existingWorkflowStepSourceLinesModeled() -> i64: 102
