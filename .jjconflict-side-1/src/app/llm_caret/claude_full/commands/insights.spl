"""
Claude full `/insights` command parity model.

This mirrors the command contract from upstream `commands/insights.ts` without
porting the full report renderer. The behavior below is the surface the parity
gate needs: command metadata, local-session analysis decisions, generated report
state, browser-opening outcomes, and source-size accounting.
"""

const INSIGHTS_COMMAND_NAME = "insights"
const INSIGHTS_DESCRIPTION = "Analyze your Claude Code usage and generate a local insights report"
const INSIGHTS_REPORT_DIR = "~/.claude/usage-data"
const INSIGHTS_REPORT_PATH = "~/.claude/usage-data/report.html"
const INSIGHTS_LOOKBACK_DAYS = 30
const INSIGHTS_UPSTREAM_SOURCE_LINES = 3200

class InsightsCommandDescriptor:
    typeName: text
    name: text
    description: text
    argumentHint: text
    isHidden: bool
    enabled: bool
    supportsNonInteractive: bool

impl InsightsCommandDescriptor:
    static fn new(enabled: bool) -> InsightsCommandDescriptor:
        InsightsCommandDescriptor("local-jsx", INSIGHTS_COMMAND_NAME, INSIGHTS_DESCRIPTION, "", false, enabled, false)

class InsightsSession:
    id: text
    startedDaysAgo: i64
    messageCount: i64
    inputTokens: i64
    outputTokens: i64
    filesTouched: i64
    toolCalls: i64
    successfulFirstAttempt: bool
    taskKind: text

impl InsightsSession:
    static fn new(id: text, startedDaysAgo: i64, messageCount: i64, inputTokens: i64, outputTokens: i64, filesTouched: i64, toolCalls: i64, successfulFirstAttempt: bool, taskKind: text) -> InsightsSession:
        InsightsSession(id, startedDaysAgo, messageCount, inputTokens, outputTokens, filesTouched, toolCalls, successfulFirstAttempt, taskKind)

class InsightsState:
    sessions: [InsightsSession]
    nonInteractive: bool
    browserOpenFails: bool
    writeReportFails: bool
    nowDay: i64

impl InsightsState:
    static fn empty() -> InsightsState:
        InsightsState([], false, false, false, 0)

    static fn sample() -> InsightsState:
        InsightsState([
            InsightsSession.new("a", 1, 12, 9000, 1400, 6, 18, true, "debugging"),
            InsightsSession.new("b", 9, 8, 4200, 700, 2, 6, false, "feature"),
            InsightsSession.new("old", 45, 20, 12000, 2000, 8, 24, true, "review")
        ], false, false, false, 0)

class InsightsMetrics:
    sessionsAnalyzed: i64
    messages: i64
    inputTokens: i64
    outputTokens: i64
    totalTokens: i64
    filesTouched: i64
    toolCalls: i64
    firstAttemptSuccesses: i64
    firstAttemptFailures: i64
    topTaskKind: text

impl InsightsMetrics:
    static fn empty() -> InsightsMetrics:
        InsightsMetrics(0, 0, 0, 0, 0, 0, 0, 0, 0, "")

class InsightsRunResult:
    typeName: text
    message: text
    reportPath: text
    html: text
    openedBrowser: bool
    metrics: InsightsMetrics

impl InsightsRunResult:
    static fn message(value: text, metrics: InsightsMetrics) -> InsightsRunResult:
        InsightsRunResult("message", value, "", "", false, metrics)

    static fn report(value: text, html: text, openedBrowser: bool, metrics: InsightsMetrics) -> InsightsRunResult:
        InsightsRunResult("report", value, INSIGHTS_REPORT_PATH, html, openedBrowser, metrics)

fn insightsCommand(enabled: bool) -> InsightsCommandDescriptor:
    InsightsCommandDescriptor.new(enabled)

fn insightsCommandName() -> text:
    INSIGHTS_COMMAND_NAME

fn insightsReportPath() -> text:
    INSIGHTS_REPORT_PATH

fn insightsLookbackDays() -> i64:
    INSIGHTS_LOOKBACK_DAYS

fn insightsCommandSourceLinesModeled() -> i64:
    INSIGHTS_UPSTREAM_SOURCE_LINES

fn includeSessionInInsights(session: InsightsSession) -> bool:
    session.startedDaysAgo >= 0 and session.startedDaysAgo <= INSIGHTS_LOOKBACK_DAYS

fn summarizeInsightsSessions(sessions: [InsightsSession]) -> InsightsMetrics:
    var metrics = InsightsMetrics.empty()
    var debuggingCount = 0
    var featureCount = 0
    var reviewCount = 0
    var otherCount = 0
    for session in sessions:
        if includeSessionInInsights(session):
            metrics.sessionsAnalyzed = metrics.sessionsAnalyzed + 1
            metrics.messages = metrics.messages + session.messageCount
            metrics.inputTokens = metrics.inputTokens + session.inputTokens
            metrics.outputTokens = metrics.outputTokens + session.outputTokens
            metrics.filesTouched = metrics.filesTouched + session.filesTouched
            metrics.toolCalls = metrics.toolCalls + session.toolCalls
            if session.successfulFirstAttempt:
                metrics.firstAttemptSuccesses = metrics.firstAttemptSuccesses + 1
            else:
                metrics.firstAttemptFailures = metrics.firstAttemptFailures + 1
            if session.taskKind == "debugging":
                debuggingCount = debuggingCount + 1
            elif session.taskKind == "feature":
                featureCount = featureCount + 1
            elif session.taskKind == "review":
                reviewCount = reviewCount + 1
            else:
                otherCount = otherCount + 1
    metrics.totalTokens = metrics.inputTokens + metrics.outputTokens
    metrics.topTaskKind = topInsightsTaskKind(debuggingCount, featureCount, reviewCount, otherCount)
    metrics

fn topInsightsTaskKind(debuggingCount: i64, featureCount: i64, reviewCount: i64, otherCount: i64) -> text:
    var bestName = "debugging"
    var bestCount = debuggingCount
    if featureCount > bestCount:
        bestName = "feature"
        bestCount = featureCount
    if reviewCount > bestCount:
        bestName = "review"
        bestCount = reviewCount
    if otherCount > bestCount:
        bestName = "other"
    if debuggingCount == 0 and featureCount == 0 and reviewCount == 0 and otherCount == 0:
        return ""
    bestName

fn insightSuccessRatePercent(metrics: InsightsMetrics) -> i64:
    val total = metrics.firstAttemptSuccesses + metrics.firstAttemptFailures
    if total == 0:
        return 0
    (metrics.firstAttemptSuccesses * 100) / total

fn renderInsightsHtml(metrics: InsightsMetrics) -> text:
    "<html><head><title>Claude Code Insights</title></head><body>" +
        "<h1>Claude Code Insights</h1>" +
        "<p>Last 30 days</p>" +
        "<p>sessions=" + metrics.sessionsAnalyzed.to_text() + "</p>" +
        "<p>messages=" + metrics.messages.to_text() + "</p>" +
        "<p>tokens=" + metrics.totalTokens.to_text() + "</p>" +
        "<p>files=" + metrics.filesTouched.to_text() + "</p>" +
        "<p>tools=" + metrics.toolCalls.to_text() + "</p>" +
        "<p>success_rate=" + insightSuccessRatePercent(metrics).to_text() + "%</p>" +
        "<p>top_task=" + metrics.topTaskKind + "</p>" +
        "</body></html>"

fn runInsights(state: InsightsState) -> InsightsRunResult:
    if state.nonInteractive:
        return InsightsRunResult.message("/insights is only available in interactive sessions.", InsightsMetrics.empty())
    val metrics = summarizeInsightsSessions(state.sessions)
    if metrics.sessionsAnalyzed == 0:
        return InsightsRunResult.message("No Claude Code sessions found in the last 30 days.", metrics)
    if state.writeReportFails:
        return InsightsRunResult.message("Failed to write insights report to " + INSIGHTS_REPORT_DIR + ".", metrics)
    val html = renderInsightsHtml(metrics)
    if state.browserOpenFails:
        return InsightsRunResult.report("Insights report generated at " + INSIGHTS_REPORT_PATH + ". Open it in your browser.", html, false, metrics)
    InsightsRunResult.report("Insights report generated and opened in your browser.", html, true, metrics)

fn runInsightsWithSessions(sessions: [InsightsSession]) -> InsightsRunResult:
    runInsights(InsightsState(sessions, false, false, false, 0))

fn insightsReportContainsCoreSections(html: text) -> bool:
    html.contains("Claude Code Insights") and html.contains("sessions=") and html.contains("success_rate=")
