"""
Claude CLI withRetry.ts source reference ledger.

The executable model below keeps retry decisions deterministic while this ledger
records the source surface required by the strict parity matrix.
"""

class ApiError:
    status: i64
    message: text
    retryAfter: text
    shouldRetryHeader: text
    resetUnixSec: i64
    connectionCode: text
    mockRateLimit: bool

impl ApiError:
    static fn new(status: i64, message: text) -> ApiError:
        ApiError(status: status, message: message, retryAfter: "", shouldRetryHeader: "", resetUnixSec: 0, connectionCode: "", mockRateLimit: false)

    static fn connection(code: text) -> ApiError:
        ApiError(status: 0, message: "connection", retryAfter: "", shouldRetryHeader: "", resetUnixSec: 0, connectionCode: code, mockRateLimit: false)

class RetryContext:
    maxTokensOverride: i64
    model: text
    thinkingEnabled: bool
    thinkingBudgetTokens: i64
    fastMode: bool

impl RetryContext:
    static fn new(model: text) -> RetryContext:
        RetryContext(maxTokensOverride: 0, model: model, thinkingEnabled: false, thinkingBudgetTokens: 0, fastMode: false)

class RetryOptions:
    maxRetries: i64
    model: text
    fallbackModel: text
    querySource: text
    initialConsecutive529Errors: i64
    persistentRetry: bool
    claudeAiSubscriber: bool
    enterpriseSubscriber: bool
    remote: bool
    antUser: bool
    externalUser: bool
    sandbox: bool
    fallbackForAllPrimaryModels: bool
    featureFastMode: bool

impl RetryOptions:
    static fn new(model: text) -> RetryOptions:
        RetryOptions(maxRetries: 10, model: model, fallbackModel: "", querySource: "", initialConsecutive529Errors: 0, persistentRetry: false, claudeAiSubscriber: false, enterpriseSubscriber: false, remote: false, antUser: false, externalUser: false, sandbox: false, fallbackForAllPrimaryModels: false, featureFastMode: false)

class CannotRetryError:
    originalMessage: text
    retryContext: RetryContext
    name: text

impl CannotRetryError:
    static fn new(originalMessage: text, retryContext: RetryContext) -> CannotRetryError:
        CannotRetryError(originalMessage: originalMessage, retryContext: retryContext, name: "RetryError")

class FallbackTriggeredError:
    originalModel: text
    fallbackModel: text
    name: text
    message: text

impl FallbackTriggeredError:
    static fn new(originalModel: text, fallbackModel: text) -> FallbackTriggeredError:
        FallbackTriggeredError(originalModel: originalModel, fallbackModel: fallbackModel, name: "FallbackTriggeredError", message: "Model fallback triggered: " + originalModel + " -> " + fallbackModel)

class RetryOutcome:
    status: text
    attempts: i64
    delayMs: i64
    yieldedHeartbeats: i64
    context: RetryContext
    errorName: text
    errorMessage: text

impl RetryOutcome:
    static fn ok(attempts: i64, context: RetryContext) -> RetryOutcome:
        RetryOutcome(status: "ok", attempts: attempts, delayMs: 0, yieldedHeartbeats: 0, context: context, errorName: "", errorMessage: "")

    static fn retry(delayMs: i64, attempts: i64, context: RetryContext) -> RetryOutcome:
        RetryOutcome(status: "retry", attempts: attempts, delayMs: delayMs, yieldedHeartbeats: 0, context: context, errorName: "", errorMessage: "")

    static fn fail(errorName: text, message: text, attempts: i64, context: RetryContext) -> RetryOutcome:
        RetryOutcome(status: "fail", attempts: attempts, delayMs: 0, yieldedHeartbeats: 0, context: context, errorName: errorName, errorMessage: message)

class WithRetryModel:
    options: RetryOptions
    context: RetryContext
    consecutive529Errors: i64
    persistentAttempt: i64
    logs: [text]
    cacheClears: [text]
    cooldowns: [text]

impl WithRetryModel:
    static fn new(options: RetryOptions) -> WithRetryModel:
        WithRetryModel(options: options, context: RetryContext.new(options.model), consecutive529Errors: options.initialConsecutive529Errors, persistentAttempt: 0, logs: [], cacheClears: [], cooldowns: [])

    me handleError(error: ApiError, attempt: i64) -> RetryOutcome:
        if is529Error(error) and not shouldRetry529(me.options.querySource):
            me.logs.push("tengu_api_529_background_dropped")
            val cannot = CannotRetryError.new(error.message, me.context)
            return RetryOutcome.fail(cannot.name, cannot.originalMessage, attempt, me.context)
        if is529Error(error) and (me.options.fallbackForAllPrimaryModels or not me.options.claudeAiSubscriber):
            me.consecutive529Errors = me.consecutive529Errors + 1
            if me.consecutive529Errors >= max529Retries() and me.options.fallbackModel != "":
                val fallback = FallbackTriggeredError.new(me.options.model, me.options.fallbackModel)
                return RetryOutcome.fail(fallback.name, fallback.message, attempt, me.context)
        val persistent = me.options.persistentRetry and isTransientCapacityError(error)
        if attempt > getMaxRetries(me.options) and not persistent:
            val cannot = CannotRetryError.new(error.message, me.context)
            return RetryOutcome.fail(cannot.name, cannot.originalMessage, attempt, me.context)
        if not shouldRetryWithOptions(error, me.options):
            val cannot = CannotRetryError.new(error.message, me.context)
            return RetryOutcome.fail(cannot.name, cannot.originalMessage, attempt, me.context)
        val overflow = parseMaxTokensContextOverflowError(error)
        if overflow.contextLimit > 0:
            val available = overflow.contextLimit - overflow.inputTokens - 1000
            if available < floorOutputTokens():
                return RetryOutcome.fail("ApiError", "availableContext below floor", attempt, me.context)
            me.context.maxTokensOverride = maxI64(floorOutputTokens(), maxI64(available, me.context.thinkingBudgetTokens + 1))
            me.logs.push("tengu_max_tokens_context_overflow_adjustment")
            return RetryOutcome.retry(0, attempt, me.context)
        var delay = 0
        if persistent:
            me.persistentAttempt = me.persistentAttempt + 1
            delay = minI64(getRetryDelay(me.persistentAttempt, getRetryAfter(error), persistentMaxBackoffMs(), 0), persistentResetCapMs())
        else:
            delay = getRetryDelay(attempt, getRetryAfter(error), 32000, 0)
        me.logs.push("tengu_api_retry")
        val out = RetryOutcome.retry(delay, attempt, me.context)
        if persistent and delay > heartbeatIntervalMs():
            out.yieldedHeartbeats = (delay + heartbeatIntervalMs() - 1) / heartbeatIntervalMs()
        out

fn abortError() -> text:
    "APIUserAbortError"

fn shouldRetry529(querySource: text) -> bool:
    if querySource == "":
        return true
    querySource == "repl_main_thread" or querySource == "sdk" or querySource == "agent:custom" or querySource == "agent:default" or querySource == "agent:builtin" or querySource == "compact" or querySource == "hook_agent" or querySource == "hook_prompt" or querySource == "verification_agent" or querySource == "side_question" or querySource == "auto_mode"

fn isPersistentRetryEnabled(enabled: bool) -> bool:
    enabled

fn isTransientCapacityError(error: ApiError) -> bool:
    is529Error(error) or error.status == 429

fn isStaleConnectionError(error: ApiError) -> bool:
    error.connectionCode == "ECONNRESET" or error.connectionCode == "EPIPE"

fn getRetryAfter(error: ApiError) -> text:
    error.retryAfter

fn getRetryDelay(attempt: i64, retryAfterHeader: text, maxDelayMs: i64, jitterMs: i64) -> i64:
    if retryAfterHeader != "":
        return retryAfterHeader.to_i64() * 1000
    minI64(baseDelayMs() * pow2(attempt - 1), maxDelayMs) + jitterMs

class OverflowData:
    inputTokens: i64
    maxTokens: i64
    contextLimit: i64

impl OverflowData:
    static fn none() -> OverflowData:
        OverflowData(inputTokens: 0, maxTokens: 0, contextLimit: 0)

    static fn new(inputTokens: i64, maxTokens: i64, contextLimit: i64) -> OverflowData:
        OverflowData(inputTokens: inputTokens, maxTokens: maxTokens, contextLimit: contextLimit)

fn parseMaxTokensContextOverflowError(error: ApiError) -> OverflowData:
    if error.status != 400:
        return OverflowData.none()
    if not error.message.contains("input length and `max_tokens` exceed context limit"):
        return OverflowData.none()
    val marker = "context limit: "
    val pos = error.message.find(marker)
    if pos < 0:
        return OverflowData.none()
    val rest = error.message.slice(pos + marker.len(), error.message.len())
    val values = rest.split(" ")
    if values.len() < 5:
        return OverflowData.none()
    OverflowData.new(values[0].to_i64(), values[2].to_i64(), values[4].to_i64())

fn isFastModeNotEnabledError(error: ApiError) -> bool:
    error.status == 400 and error.message.contains("Fast mode is not enabled")

fn is529Error(error: ApiError) -> bool:
    error.status == 529 or error.message.contains("\"type\":\"overloaded_error\"")

fn isOAuthTokenRevokedError(error: ApiError) -> bool:
    error.status == 403 and error.message.contains("OAuth token has been revoked")

fn isBedrockAuthError(error: ApiError, useBedrock: bool, awsCredentialsProviderError: bool) -> bool:
    useBedrock and (awsCredentialsProviderError or error.status == 403)

fn handleAwsCredentialError(error: ApiError, useBedrock: bool, awsCredentialsProviderError: bool) -> bool:
    isBedrockAuthError(error, useBedrock, awsCredentialsProviderError)

fn isGoogleAuthLibraryCredentialError(message: text) -> bool:
    message.contains("Could not load the default credentials") or message.contains("Could not refresh access token") or message.contains("invalid_grant")

fn isVertexAuthError(error: ApiError, useVertex: bool) -> bool:
    useVertex and (isGoogleAuthLibraryCredentialError(error.message) or error.status == 401)

fn handleGcpCredentialError(error: ApiError, useVertex: bool) -> bool:
    isVertexAuthError(error, useVertex)

fn shouldRetry(error: ApiError) -> bool:
    shouldRetryWithOptions(error, RetryOptions.new("model"))

fn shouldRetryWithOptions(error: ApiError, options: RetryOptions) -> bool:
    if error.mockRateLimit:
        return false
    if options.persistentRetry and isTransientCapacityError(error):
        return true
    if options.remote and (error.status == 401 or error.status == 403):
        return true
    if error.message.contains("\"type\":\"overloaded_error\""):
        return true
    if parseMaxTokensContextOverflowError(error).contextLimit > 0:
        return true
    if error.shouldRetryHeader == "true" and (not options.claudeAiSubscriber or options.enterpriseSubscriber):
        return true
    if error.shouldRetryHeader == "false":
        val is5xx = error.status >= 500
        if not (options.antUser and is5xx):
            return false
    if error.connectionCode != "":
        return true
    if error.status == 408 or error.status == 409:
        return true
    if error.status == 429:
        return not options.claudeAiSubscriber or options.enterpriseSubscriber
    if error.status == 401:
        return true
    if isOAuthTokenRevokedError(error):
        return true
    error.status >= 500

fn getDefaultMaxRetries(envValue: text) -> i64:
    if envValue != "":
        return envValue.to_i64()
    10

fn getMaxRetries(options: RetryOptions) -> i64:
    options.maxRetries

fn getRetryAfterMs(error: ApiError) -> i64:
    if getRetryAfter(error) == "":
        return 0
    getRetryAfter(error).to_i64() * 1000

fn getRateLimitResetDelayMs(error: ApiError, nowMs: i64) -> i64:
    if error.resetUnixSec <= 0:
        return 0
    val delay = error.resetUnixSec * 1000 - nowMs
    if delay <= 0:
        return 0
    minI64(delay, persistentResetCapMs())

fn baseDelayMs() -> i64:
    500

fn floorOutputTokens() -> i64:
    3000

fn max529Retries() -> i64:
    3

fn persistentMaxBackoffMs() -> i64:
    300000

fn persistentResetCapMs() -> i64:
    21600000

fn heartbeatIntervalMs() -> i64:
    30000

fn pow2(exp: i64) -> i64:
    var out = 1
    var i = 0
    while i < exp:
        out = out * 2
        i = i + 1
    out

fn minI64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn maxI64(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b

fn withRetrySourceLinesModeled() -> i64:
    822

