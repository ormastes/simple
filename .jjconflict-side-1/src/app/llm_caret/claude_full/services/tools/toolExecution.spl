const TOOL_EXECUTION_SOURCE_LINES = 1745
const HOOK_TIMING_DISPLAY_THRESHOLD_MS = 1000

fn truncateTextRoute(value: text, limit: i64) -> text:
    if value.len() <= limit:
        return value
    value.substring(0, limit)

fn classifyToolErrorRoute(kind: text, message: text, code: text, name: text) -> text:
    if kind == "telemetry_safe":
        return truncateTextRoute(message, 200)
    if code != "":
        return "Error:" + code
    if name != "" && name != "Error":
        return truncateTextRoute(name, 60)
    "Error"

fn buildSchemaNotSentHintRoute(toolSearchEnabled: bool, toolSearchAvailable: bool, isDeferred: bool, alreadyDiscovered: bool, toolName: text) -> text:
    if !toolSearchEnabled || !toolSearchAvailable || !isDeferred || alreadyDiscovered:
        return "none"
    "select:" + toolName

fn ruleSourceToOTelSourceRoute(source: text) -> text:
    if source == "project" || source == "user" || source == "local":
        return source
    "unknown"

fn decisionReasonToOTelSourceRoute(reason: text) -> text:
    if reason == "allow" || reason == "deny" || reason == "ask":
        return reason
    "unknown"

fn getNextImagePasteIdRoute(highestPriorId: i64) -> i64:
    highestPriorId + 1

fn mcpLookupRoute(serverKnown: bool, toolKnown: bool) -> text:
    if serverKnown && toolKnown:
        return "mcp tool"
    if serverKnown:
        return "mcp server without tool"
    "mcp unknown"

fn runToolUseEnvelopeRoute(toolKnown: bool, aborted: bool, assistantUuid: text) -> text:
    if aborted:
        return "cancel message " + assistantUuid
    if !toolKnown:
        return "tool_result error No such tool available " + assistantUuid
    "tool_result ok " + assistantUuid

fn toolExecutionSourceLinesModeled() -> i64:
    TOOL_EXECUTION_SOURCE_LINES
