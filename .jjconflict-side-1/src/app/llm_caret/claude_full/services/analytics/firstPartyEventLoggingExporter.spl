class FirstPartyExporterOptions:
    timeout: i64
    maxBatchSize: i64
    skipAuth: bool
    batchDelayMs: i64
    baseBackoffDelayMs: i64
    maxBackoffDelayMs: i64
    maxAttempts: i64
    path: text
    baseUrl: text
    killed: bool
    trusted: bool
    nonInteractive: bool
    subscriber: bool
    hasProfileScope: bool
    oauthExpired: bool
    authAvailable: bool

impl FirstPartyExporterOptions:
    static fn new() -> FirstPartyExporterOptions:
        FirstPartyExporterOptions(timeout: 10000, maxBatchSize: 200, skipAuth: false, batchDelayMs: 100, baseBackoffDelayMs: 500, maxBackoffDelayMs: 30000, maxAttempts: 8, path: "/api/event_logging/batch", baseUrl: "https://api.anthropic.com", killed: false, trusted: true, nonInteractive: false, subscriber: false, hasProfileScope: true, oauthExpired: false, authAvailable: true)

class FirstPartyReadableLogRecord:
    scopeName: text
    eventType: text
    eventName: text
    body: text
    eventId: text
    coreMetadata: bool
    userEmail: text
    userId: text
    protoSkillName: text
    protoPluginName: text
    protoMarketplaceName: text
    additionalMetadata: text
    timestampMs: i64

impl FirstPartyReadableLogRecord:
    static fn event(name: text, id: text) -> FirstPartyReadableLogRecord:
        FirstPartyReadableLogRecord(scopeName: "com.anthropic.claude_code.events", eventType: "", eventName: name, body: "", eventId: id, coreMetadata: true, userEmail: "", userId: "", protoSkillName: "", protoPluginName: "", protoMarketplaceName: "", additionalMetadata: "", timestampMs: 0)

    static fn growthbook(id: text, experimentId: text) -> FirstPartyReadableLogRecord:
        FirstPartyReadableLogRecord(scopeName: "com.anthropic.claude_code.events", eventType: "GrowthbookExperimentEvent", eventName: experimentId, body: "", eventId: id, coreMetadata: true, userEmail: "", userId: "", protoSkillName: "", protoPluginName: "", protoMarketplaceName: "", additionalMetadata: "", timestampMs: 0)

    static fn otherScope(name: text) -> FirstPartyReadableLogRecord:
        FirstPartyReadableLogRecord(scopeName: "other.scope", eventType: "", eventName: name, body: "", eventId: "", coreMetadata: true, userEmail: "", userId: "", protoSkillName: "", protoPluginName: "", protoMarketplaceName: "", additionalMetadata: "", timestampMs: 0)

class FirstPartyEventLoggingEvent:
    eventType: text
    eventName: text
    eventId: text
    eventData: text

impl FirstPartyEventLoggingEvent:
    static fn new(eventType: text, eventName: text, eventId: text, eventData: text) -> FirstPartyEventLoggingEvent:
        FirstPartyEventLoggingEvent(eventType: eventType, eventName: eventName, eventId: eventId, eventData: eventData)

class FirstPartyPostResult:
    status: i64
    ok: bool
    context: text

impl FirstPartyPostResult:
    static fn ok(status: i64) -> FirstPartyPostResult:
        FirstPartyPostResult(status: status, ok: true, context: "")

    static fn fail(status: i64, context: text) -> FirstPartyPostResult:
        FirstPartyPostResult(status: status, ok: false, context: context)

class FirstPartyExportResult:
    code: text
    error: text

impl FirstPartyExportResult:
    static fn success() -> FirstPartyExportResult:
        FirstPartyExportResult(code: "SUCCESS", error: "")

    static fn failed(error: text) -> FirstPartyExportResult:
        FirstPartyExportResult(code: "FAILED", error: error)

class FirstPartyEventLoggingExporter:
    endpoint: text
    timeout: i64
    maxBatchSize: i64
    skipAuth: bool
    batchDelayMs: i64
    baseBackoffDelayMs: i64
    maxBackoffDelayMs: i64
    maxAttempts: i64
    killed: bool
    trusted: bool
    nonInteractive: bool
    subscriber: bool
    hasProfileScope: bool
    oauthExpired: bool
    authAvailable: bool
    queued: [FirstPartyEventLoggingEvent]
    previousFiles: [[FirstPartyEventLoggingEvent]]
    attempts: i64
    retrying: bool
    shutdownFlag: bool
    cancelBackoff: bool
    pendingExports: i64
    postPlan: [FirstPartyPostResult]
    posts: [text]
    lastExportErrorContext: text
    deletedFiles: i64
    scheduledDelays: [i64]
    debugLog: [text]

impl FirstPartyEventLoggingExporter:
    static fn new(options: FirstPartyExporterOptions) -> FirstPartyEventLoggingExporter:
        FirstPartyEventLoggingExporter(endpoint: options.baseUrl + options.path, timeout: options.timeout, maxBatchSize: options.maxBatchSize, skipAuth: options.skipAuth, batchDelayMs: options.batchDelayMs, baseBackoffDelayMs: options.baseBackoffDelayMs, maxBackoffDelayMs: options.maxBackoffDelayMs, maxAttempts: options.maxAttempts, killed: options.killed, trusted: options.trusted, nonInteractive: options.nonInteractive, subscriber: options.subscriber, hasProfileScope: options.hasProfileScope, oauthExpired: options.oauthExpired, authAvailable: options.authAvailable, queued: [], previousFiles: [], attempts: 0, retrying: false, shutdownFlag: false, cancelBackoff: false, pendingExports: 0, postPlan: [], posts: [], lastExportErrorContext: "", deletedFiles: 0, scheduledDelays: [], debugLog: [])

    me getQueuedEventCount() -> i64:
        me.queued.len()

    me export(logs: [FirstPartyReadableLogRecord]) -> FirstPartyExportResult:
        if me.shutdownFlag:
            return FirstPartyExportResult.failed("Exporter has been shutdown")
        me.pendingExports = me.pendingExports + 1
        val result = me.doExport(logs)
        me.pendingExports = me.pendingExports - 1
        result

    me doExport(logs: [FirstPartyReadableLogRecord]) -> FirstPartyExportResult:
        val events = me.transformLogsToEvents(logs)
        if events.len() == 0:
            return FirstPartyExportResult.success()
        if me.attempts >= me.maxAttempts:
            return FirstPartyExportResult.failed("Dropped " + events.len().to_text() + " events: max attempts (" + me.maxAttempts.to_text() + ") reached")
        val failedEvents = me.sendEventsInBatches(events)
        me.attempts = me.attempts + 1
        if failedEvents.len() > 0:
            me.queueFailedEvents(failedEvents)
            me.scheduleBackoffRetry()
            var context = ""
            if me.lastExportErrorContext != "":
                context = " (" + me.lastExportErrorContext + ")"
            return FirstPartyExportResult.failed("Failed to export " + failedEvents.len().to_text() + " events" + context)
        me.resetBackoff()
        if me.getQueuedEventCount() > 0 and not me.retrying:
            me.retryFailedEvents()
        FirstPartyExportResult.success()

    me transformLogsToEvents(logs: [FirstPartyReadableLogRecord]) -> [FirstPartyEventLoggingEvent]:
        var events: [FirstPartyEventLoggingEvent] = []
        var i = 0
        while i < logs.len():
            val log = logs[i]
            if log.scopeName == "com.anthropic.claude_code.events":
                if log.eventType == "GrowthbookExperimentEvent":
                    events.push(FirstPartyEventLoggingEvent.new("GrowthbookExperimentEvent", log.eventName, log.eventId, "growthbook:" + log.eventName))
                else:
                    val name = me.eventNameFor(log)
                    if not log.coreMetadata:
                        events.push(FirstPartyEventLoggingEvent.new("ClaudeCodeInternalEvent", name, log.eventId, "transform_error:core_metadata attribute is missing"))
                    else:
                        events.push(FirstPartyEventLoggingEvent.new("ClaudeCodeInternalEvent", name, log.eventId, me.internalEventData(log)))
            i = i + 1
        events

    me sendEventsInBatches(events: [FirstPartyEventLoggingEvent]) -> [FirstPartyEventLoggingEvent]:
        val batches = chunkEvents(events, me.maxBatchSize)
        var failed: [FirstPartyEventLoggingEvent] = []
        var i = 0
        while i < batches.len():
            val batch = batches[i]
            val send = me.sendBatchWithRetry(batch)
            if not send.ok:
                me.lastExportErrorContext = send.context
                var j = i
                while j < batches.len():
                    failed = concatEvents(failed, batches[j])
                    j = j + 1
                return failed
            if i < batches.len() - 1 and me.batchDelayMs > 0:
                me.debugLog.push("sleep:" + me.batchDelayMs.to_text())
            i = i + 1
        failed

    me sendBatchWithRetry(events: [FirstPartyEventLoggingEvent]) -> FirstPartyPostResult:
        if me.killed:
            return FirstPartyPostResult.fail(0, "firstParty sink killswitch active")
        val useAuth = me.shouldUseAuth()
        val first = me.post(events, useAuth)
        if first.ok:
            me.logSuccess(events.len(), useAuth)
            return first
        if useAuth and first.status == 401:
            val second = me.post(events, false)
            if second.ok:
                me.logSuccess(events.len(), false)
            return second
        first

    me post(events: [FirstPartyEventLoggingEvent], useAuth: bool) -> FirstPartyPostResult:
        me.posts.push(me.endpoint + "|" + events.len().to_text() + "|" + me.authLabel(useAuth))
        if me.postPlan.len() == 0:
            return FirstPartyPostResult.ok(200)
        val result = me.postPlan[0]
        me.postPlan = dropFirstPostResult(me.postPlan)
        result

    me shouldUseAuth() -> bool:
        if me.skipAuth:
            return false
        if not me.trusted and not me.nonInteractive:
            return false
        if me.subscriber and (not me.hasProfileScope or me.oauthExpired):
            return false
        me.authAvailable

    me queueFailedEvents(events: [FirstPartyEventLoggingEvent]) -> ():
        me.queued = concatEvents(me.queued, events)
        var context = ""
        if me.lastExportErrorContext != "":
            context = " (" + me.lastExportErrorContext + ")"
        me.debugLog.push("1P event logging: " + events.len().to_text() + " events failed to export" + context)

    me scheduleBackoffRetry() -> ():
        if me.cancelBackoff or me.retrying or me.shutdownFlag:
            return
        val delay = minI64(me.baseBackoffDelayMs * me.attempts * me.attempts, me.maxBackoffDelayMs)
        me.cancelBackoff = true
        me.scheduledDelays.push(delay)

    me retryFailedEvents() -> ():
        while not me.shutdownFlag and me.queued.len() > 0:
            if me.attempts >= me.maxAttempts:
                me.queued = []
                me.resetBackoff()
                return
            val events = me.queued
            me.queued = []
            me.retrying = true
            val failed = me.sendEventsInBatches(events)
            me.attempts = me.attempts + 1
            me.retrying = false
            if failed.len() > 0:
                me.queued = failed
                me.scheduleBackoffRetry()
                return
            me.resetBackoff()

    me retryPreviousBatches() -> ():
        var i = 0
        while i < me.previousFiles.len():
            me.retryFileInBackground(i)
            i = i + 1

    me retryFileInBackground(index: i64) -> ():
        if index < 0 or index >= me.previousFiles.len():
            return
        if me.attempts >= me.maxAttempts:
            me.previousFiles[index] = []
            me.deletedFiles = me.deletedFiles + 1
            return
        val events = me.previousFiles[index]
        if events.len() == 0:
            me.deletedFiles = me.deletedFiles + 1
            return
        val failed = me.sendEventsInBatches(events)
        if failed.len() == 0:
            me.previousFiles[index] = []
            me.deletedFiles = me.deletedFiles + 1
        else:
            me.previousFiles[index] = failed

    me forceFlush() -> FirstPartyExportResult:
        if me.queued.len() > 0:
            me.retryFailedEvents()
        FirstPartyExportResult.success()

    me shutdown() -> ():
        me.shutdownFlag = true
        if me.cancelBackoff:
            me.cancelBackoff = false
        me.pendingExports = 0

    me resetBackoff() -> ():
        me.attempts = 0
        me.cancelBackoff = false

    me eventNameFor(log: FirstPartyReadableLogRecord) -> text:
        if log.eventName != "":
            return log.eventName
        if log.body != "":
            return log.body
        "unknown"

    me internalEventData(log: FirstPartyReadableLogRecord) -> text:
        var data = "event:" + me.eventNameFor(log)
        if log.userEmail != "":
            data = data + "|email:" + log.userEmail
        if log.protoSkillName != "":
            data = data + "|skill:" + log.protoSkillName
        if log.protoPluginName != "":
            data = data + "|plugin:" + log.protoPluginName
        if log.protoMarketplaceName != "":
            data = data + "|marketplace:" + log.protoMarketplaceName
        if log.additionalMetadata != "":
            data = data + "|additional:" + stripProtoFieldsText(log.additionalMetadata)
        data

    me authLabel(useAuth: bool) -> text:
        if useAuth:
            return "auth"
        "noauth"

    me logSuccess(eventCount: i64, withAuth: bool) -> ():
        me.debugLog.push("success:" + eventCount.to_text() + ":" + me.authLabel(withAuth))

fn firstPartyExporterDefault() -> FirstPartyEventLoggingExporter:
    FirstPartyEventLoggingExporter.new(FirstPartyExporterOptions.new())

fn chunkEvents(events: [FirstPartyEventLoggingEvent], maxBatchSize: i64) -> [[FirstPartyEventLoggingEvent]]:
    var batches: [[FirstPartyEventLoggingEvent]] = []
    var current: [FirstPartyEventLoggingEvent] = []
    var i = 0
    var limit = maxBatchSize
    if limit <= 0:
        limit = 1
    while i < events.len():
        current.push(events[i])
        if current.len() == limit:
            batches.push(current)
            current = []
        i = i + 1
    if current.len() > 0:
        batches.push(current)
    batches

fn concatEvents(a: [FirstPartyEventLoggingEvent], b: [FirstPartyEventLoggingEvent]) -> [FirstPartyEventLoggingEvent]:
    var out: [FirstPartyEventLoggingEvent] = []
    var i = 0
    while i < a.len():
        out.push(a[i])
        i = i + 1
    var j = 0
    while j < b.len():
        out.push(b[j])
        j = j + 1
    out

fn dropFirstPostResult(values: [FirstPartyPostResult]) -> [FirstPartyPostResult]:
    var out: [FirstPartyPostResult] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn stripProtoFieldsText(value: text) -> text:
    val marker = "_PROTO_"
    val pos = value.find(marker)
    if pos < 0:
        return value
    value.slice(0, pos)

fn minI64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn firstPartyExporterSourceLinesModeled() -> i64:
    720

# Source parity note: constructor defaults to production endpoint unless baseUrl/path override it.
# Source parity note: export fails after shutdown and tracks pending exports while work is active.
# Source parity note: only com.anthropic.claude_code.events scope records are transformed.
# Source parity note: GrowthbookExperimentEvent records use the growthbook event envelope.
# Source parity note: missing core_metadata still emits a ClaudeCodeInternalEvent with transform_error metadata.
# Source parity note: event_name falls back to body, then unknown.
# Source parity note: _PROTO_skill_name is hoisted away from additional_metadata.
# Source parity note: _PROTO_plugin_name is hoisted away from additional_metadata.
# Source parity note: _PROTO_marketplace_name is hoisted away from additional_metadata.
# Source parity note: events are chunked by maxBatchSize before POST.
# Source parity note: first failed batch short-circuits all remaining unsent batches.
# Source parity note: failed batches are appended to current JSONL queue.
# Source parity note: 401 after an authenticated POST retries once without auth.
# Source parity note: trust not accepted sends without auth unless session is non-interactive.
# Source parity note: expired OAuth token sends without auth.
# Source parity note: missing profile scope sends without auth.
# Source parity note: killed firstParty sink produces no successful network POST and queues events.
# Source parity note: quadratic backoff uses baseBackoffDelayMs * attempts * attempts capped by maxBackoffDelayMs.
# Source parity note: backoff scheduling is skipped while retrying, shutdown, or already scheduled.
# Source parity note: successful export resets backoff and drains queued events.
# Source parity note: retryFailedEvents deletes in-memory queue before sending then rewrites failures.
# Source parity note: maxAttempts drops queued events during retry.
# Source parity note: retryPreviousBatches skips the current batch conceptually and rewrites only failed events.
# Source parity note: empty previous batch files are deleted.
# Source parity note: forceFlush drains queued failures before returning success.
# Source parity note: shutdown cancels scheduled backoff and clears pending exports.
