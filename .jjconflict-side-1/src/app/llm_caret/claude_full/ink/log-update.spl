class VirtualScreen:
    cursor: LogPoint
    viewportWidth: i64
    diff: [LogDiffOp]

impl VirtualScreen:
    static fn new(origin: LogPoint, viewportWidth: i64) -> VirtualScreen:
        VirtualScreen(cursor: LogPoint.new(origin.x, origin.y), viewportWidth: viewportWidth, diff: [])

    me txn(patches: [LogDiffOp], dx: i64, dy: i64) -> ():
        var i = 0
        while i < patches.len():
            me.diff.push(patches[i])
            i = i + 1
        me.cursor.x = me.cursor.x + dx
        me.cursor.y = me.cursor.y + dy
