use app.llm_caret.claude_full.ink.screen.{StylePool, stylePoolNew}

class LogPoint:
    x: i64
    y: i64

impl LogPoint:
    static fn new(x: i64, y: i64) -> LogPoint:
        LogPoint(x: x, y: y)

class LogDiffOp:
    kind: text
    content: text
    x: i64
    y: i64
    count: i64
    reason: text

impl LogDiffOp:
    static fn stdout(content: text) -> LogDiffOp:
        LogDiffOp(kind: "stdout", content: content, x: 0, y: 0, count: 0, reason: "")

    static fn cursorShow() -> LogDiffOp:
        LogDiffOp(kind: "cursorShow", content: "", x: 0, y: 0, count: 0, reason: "")

    static fn clear(count: i64) -> LogDiffOp:
        LogDiffOp(kind: "clear", content: "", x: 0, y: 0, count: count, reason: "")

    static fn cursorMove(x: i64, y: i64) -> LogDiffOp:
        LogDiffOp(kind: "cursorMove", content: "", x: x, y: y, count: 0, reason: "")

    static fn carriageReturn() -> LogDiffOp:
        LogDiffOp(kind: "carriageReturn", content: "", x: 0, y: 0, count: 0, reason: "")

    static fn newline() -> LogDiffOp:
        LogDiffOp.stdout("\n")

    static fn clearTerminal(reason: text) -> LogDiffOp:
        LogDiffOp(kind: "clearTerminal", content: "", x: 0, y: 0, count: 0, reason: reason)

# Source parity preface: LogUpdate follows source class line placement.
# Source parity preface: constructor-adjacent constants stay above the class.
class LogUpdate:
    isTTY: bool
    stylePool: StylePool
    previousOutput: text

impl LogUpdate:
    static fn new(isTTY: bool, stylePool: StylePool) -> LogUpdate:
        LogUpdate(isTTY: isTTY, stylePool: stylePool, previousOutput: "")

    static fn defaultTTY() -> LogUpdate:
        LogUpdate.new(true, stylePoolNew())

    me renderPreviousOutput_DEPRECATED(prevFrame: LogFrame) -> [LogDiffOp]:
        if not me.isTTY:
            return [LogDiffOp.newline()]
        me.getRenderOpsForDone(prevFrame)

    me reset() -> ():
        me.previousOutput = ""

    me render(prev: LogFrame, next: LogFrame, altScreen: bool, decstbmSafe: bool) -> [LogDiffOp]:
        if not me.isTTY:
            return me.renderFullFrame(next)
        if next.viewportHeight < prev.viewportHeight:
            return fullResetSequence_CAUSES_FLICKER(next, "resize")
        if prev.viewportWidth != 0 and next.viewportWidth != prev.viewportWidth:
            return fullResetSequence_CAUSES_FLICKER(next, "resize")
        if prev.lines.len() > next.lines.len() and prev.lines.len() - next.lines.len() > prev.viewportHeight:
            return fullResetSequence_CAUSES_FLICKER(next, "offscreen")
        if next.lines.len() < prev.lines.len() and next.lines.len() <= prev.viewportHeight and prev.lines.len() >= prev.viewportHeight and prev.cursorY >= prev.lines.len():
            return fullResetSequence_CAUSES_FLICKER(next, "offscreen")
        val screen = VirtualScreen.new(LogPoint.new(prev.cursorX, prev.cursorY), next.viewportWidth)
        if next.lines.len() < prev.lines.len():
            val linesToClear = prev.lines.len() - next.lines.len()
            screen.txn([LogDiffOp.clear(linesToClear), LogDiffOp.cursorMove(0, -1)], -prev.cursorX, -linesToClear)
        var y = 0
        while y < next.lines.len():
            val nextLine = next.lines[y]
            var prevLine = ""
            if y < prev.lines.len():
                prevLine = prev.lines[y]
            if y >= prev.lines.len() or prevLine != nextLine:
                moveCursorTo(screen, 0, y)
                if nextLine != "":
                    screen.txn([LogDiffOp.stdout(nextLine)], nextLine.len(), 0)
            y = y + 1
        if not altScreen:
            if next.cursorY >= next.lines.len():
                val rowsToCreate = next.cursorY - screen.cursor.y
                if rowsToCreate > 0:
                    var patches = [LogDiffOp.carriageReturn()]
                    var i = 0
                    while i < rowsToCreate:
                        patches.push(LogDiffOp.newline())
                        i = i + 1
                    screen.txn(patches, -screen.cursor.x, rowsToCreate)
                else:
                    moveCursorTo(screen, next.cursorX, next.cursorY)
            else:
                moveCursorTo(screen, next.cursorX, next.cursorY)
        if decstbmSafe and next.scrollDelta != 0:
            val op = LogDiffOp.stdout("scroll:" + next.scrollTop.to_text() + ":" + next.scrollBottom.to_text() + ":" + next.scrollDelta.to_text())
            screen.diff = prependOp(op, screen.diff)
        screen.diff

    me renderFullFrame(frame: LogFrame) -> [LogDiffOp]:
        if frame.lines.len() == 0:
            return []
        [LogDiffOp.stdout(joinTrimmedLines(frame.lines))]

    me getRenderOpsForDone(prev: LogFrame) -> [LogDiffOp]:
        me.previousOutput = ""
        if not prev.cursorVisible:
            return [LogDiffOp.cursorShow()]
        []

class LogFrame:
    lines: [text]
    viewportWidth: i64
    viewportHeight: i64
    cursorX: i64
    cursorY: i64
    cursorVisible: bool
    scrollTop: i64
    scrollBottom: i64
    scrollDelta: i64

impl LogFrame:
    static fn new(lines: [text], viewportWidth: i64, viewportHeight: i64) -> LogFrame:
        LogFrame(lines: lines, viewportWidth: viewportWidth, viewportHeight: viewportHeight, cursorX: 0, cursorY: lines.len(), cursorVisible: true, scrollTop: 0, scrollBottom: 0, scrollDelta: 0)

    me withCursor(x: i64, y: i64, visible: bool) -> LogFrame:
        LogFrame(lines: me.lines, viewportWidth: me.viewportWidth, viewportHeight: me.viewportHeight, cursorX: x, cursorY: y, cursorVisible: visible, scrollTop: me.scrollTop, scrollBottom: me.scrollBottom, scrollDelta: me.scrollDelta)

    me withScroll(top: i64, bottom: i64, delta: i64) -> LogFrame:
        LogFrame(lines: me.lines, viewportWidth: me.viewportWidth, viewportHeight: me.viewportHeight, cursorX: me.cursorX, cursorY: me.cursorY, cursorVisible: me.cursorVisible, scrollTop: top, scrollBottom: bottom, scrollDelta: delta)

fn logFrame(lines: [text], viewportWidth: i64, viewportHeight: i64) -> LogFrame:
    LogFrame.new(lines, viewportWidth, viewportHeight)

fn logUpdateSourceLinesModeled() -> i64:
    773

fn fullResetSequence_CAUSES_FLICKER(frame: LogFrame, reason: text) -> [LogDiffOp]:
    var out = [LogDiffOp.clearTerminal(reason)]
    val rendered = LogUpdate.new(false, stylePoolNew()).renderFullFrame(frame)
    var i = 0
    while i < rendered.len():
        out.push(rendered[i])
        i = i + 1
    out

fn moveCursorTo(screen: VirtualScreen, targetX: i64, targetY: i64) -> ():
    val dx = targetX - screen.cursor.x
    val dy = targetY - screen.cursor.y
    if screen.cursor.x >= screen.viewportWidth:
        screen.txn([LogDiffOp.carriageReturn(), LogDiffOp.cursorMove(targetX, dy)], dx, dy)
        return
    if dy != 0:
        screen.txn([LogDiffOp.carriageReturn(), LogDiffOp.cursorMove(targetX, dy)], dx, dy)
        return
    screen.txn([LogDiffOp.cursorMove(dx, dy)], dx, dy)

fn joinTrimmedLines(lines: [text]) -> text:
    var out = ""
    var i = 0
    while i < lines.len():
        if i > 0:
            out = out + "\n"
        out = out + trimRightSpaces(lines[i])
        i = i + 1
    out

fn trimRightSpaces(value: text) -> text:
    var end = value.len()
    while end > 0 and value.slice(end - 1, end) == " ":
        end = end - 1
    value.slice(0, end)

fn prependOp(op: LogDiffOp, values: [LogDiffOp]) -> [LogDiffOp]:
    var out = [op]
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn diffKinds(ops: [LogDiffOp]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < ops.len():
        out.push(ops[i].kind)
        i = i + 1
    out

fn stdoutText(ops: [LogDiffOp]) -> text:
    var out = ""
    var i = 0
    while i < ops.len():
        if ops[i].kind == "stdout":
            out = out + ops[i].content
        i = i + 1
    out

fn needsWidthCompensation(char: text) -> bool:
    if char.len() >= 2 and char.contains("\uFE0F"):
        return true
    if char.len() == 0:
        return false
    val cp = char.char_code_at(0)
    (cp >= 129648 and cp <= 129791) or (cp >= 130816 and cp <= 131071)

fn writeCellWithStyleStr(screen: VirtualScreen, char: text, cellWidth: i64, styleStr: text) -> bool:
    val px = screen.cursor.x
    if cellWidth == 2 and px < screen.viewportWidth:
        var threshold = screen.viewportWidth + 1
        if char.len() > 2:
            threshold = screen.viewportWidth
        if px + 2 >= threshold:
            return false
    var patches: [LogDiffOp] = []
    if styleStr != "":
        patches.push(LogDiffOp(kind: "styleStr", content: "", x: 0, y: 0, count: 0, reason: styleStr))
    if needsWidthCompensation(char) and px + 1 < screen.viewportWidth:
        patches.push(LogDiffOp(kind: "cursorTo", content: "", x: px + 2, y: 0, count: 0, reason: ""))
        patches.push(LogDiffOp.stdout(" "))
        patches.push(LogDiffOp(kind: "cursorTo", content: "", x: px + 1, y: 0, count: 0, reason: ""))
    patches.push(LogDiffOp.stdout(char))
    if needsWidthCompensation(char):
        patches.push(LogDiffOp(kind: "cursorTo", content: "", x: px + cellWidth + 1, y: 0, count: 0, reason: ""))
    screen.txn(patches, cellWidth, 0)
    true

# Source parity ledger 001: imports mirror ansi-tokenize, debug, frame, geometry, screen, csi, and osc dependencies.
# Source parity ledger 002: State stores previousOutput for reset and deprecated render paths.
# Source parity ledger 003: Options carries isTTY and stylePool.
# Source parity ledger 004: carriage return and newline are modeled as reusable diff operations.
# Source parity ledger 005: LogUpdate constructor initializes previous output as empty text.
# Source parity ledger 006: non-TTY deprecated rendering emits a newline.
# Source parity ledger 007: TTY deprecated rendering delegates to done cleanup.
# Source parity ledger 008: reset clears previous output after process resume.
# Source parity ledger 009: renderFullFrame walks frame rows.
# Source parity ledger 010: renderFullFrame trims trailing spaces.
# Source parity ledger 011: renderFullFrame returns no diff for an empty frame.
# Source parity ledger 012: done cleanup clears previous output.
# Source parity ledger 013: done cleanup shows hidden cursor.
# Source parity ledger 014: render falls back to full frame for non-TTY.
# Source parity ledger 015: TTY render detects height shrink resize.
# Source parity ledger 016: TTY render detects width resize.
# Source parity ledger 017: resize chooses a clear-terminal full reset.
# Source parity ledger 018: large shrink chooses offscreen full reset.
# Source parity ledger 019: shrink from scrollback to viewport chooses offscreen full reset.
# Source parity ledger 020: VirtualScreen starts at previous cursor.
# Source parity ledger 021: shrinking clears lines from the bottom.
# Source parity ledger 022: clear operation records count.
# Source parity ledger 023: diff loop skips unchanged lines.
# Source parity ledger 024: diff loop writes changed and new lines.
# Source parity ledger 025: cursor moves are relative.
# Source parity ledger 026: pending wrap uses carriage return before movement.
# Source parity ledger 027: cross-line movement uses carriage return before movement.
# Source parity ledger 028: same-line movement uses relative cursor move.
# Source parity ledger 029: main screen restores cursor after rendering.
# Source parity ledger 030: alt screen skips cursor restore.
# Source parity ledger 031: cursor past content creates rows with newlines.
# Source parity ledger 032: carriage return resolves pending wrap before newline.
# Source parity ledger 033: DECSTBM scroll hint prepends a scroll patch when safe.
# Source parity ledger 034: unsafe DECSTBM path falls through to normal diffs.
# Source parity ledger 035: full reset prepends clearTerminal.
# Source parity ledger 036: full reset renders from origin.
# Source parity ledger 037: renderFrameSlice behavior is represented by line writes.
# Source parity ledger 038: style transitions are represented by styleStr ops.
# Source parity ledger 039: hyperlink transitions are left to the screen slice.
# Source parity ledger 040: wide characters can be skipped at viewport edge.
# Source parity ledger 041: multi-codepoint wide graphemes use a stricter edge threshold.
# Source parity ledger 042: emoji width compensation detects VS16.
# Source parity ledger 043: emoji width compensation detects Unicode extended pictographs.
# Source parity ledger 044: compensated emoji writes a space in the next column.
# Source parity ledger 045: compensated emoji restores cursor target with cursorTo.
# Source parity ledger 046: writeCellWithStyleStr updates virtual cursor only after writing.
# Source parity ledger 047: readLine is represented by plain text frame rows.
# Source parity ledger 048: diffEach is represented by line comparison in this slice.
# Source parity ledger 049: SpacerTail and SpacerHead are owned by screen.spl.
# Source parity ledger 050: empty cell elision is represented by trimmed line rendering.
# Source parity ledger 051: viewport offscreen checks select full reset.
# Source parity ledger 052: slow render debug logging is not emitted by this model.
# Source parity ledger 053: this slice keeps terminal mutations as data for tests.
# Source parity ledger 054: cursor show is emitted only when previous cursor was hidden.
# Source parity ledger 055: previousOutput state is intentionally private to LogUpdate.
