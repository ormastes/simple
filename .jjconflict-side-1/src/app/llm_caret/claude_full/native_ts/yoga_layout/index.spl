"""
Pure Simple parity model for native-ts/yoga-layout/index.ts.

This keeps the API surface used by Ink: value parsing, config, Node tree/style
state, dirty tracking, measurement, simple row/column layout, and loader export.
"""

const UNIT_UNDEFINED: text = "undefined"
const UNIT_POINT: text = "point"
const UNIT_PERCENT: text = "percent"
const UNIT_AUTO: text = "auto"

const EDGE_LEFT: i64 = 0
const EDGE_TOP: i64 = 1
const EDGE_RIGHT: i64 = 2
const EDGE_BOTTOM: i64 = 3
const EDGE_HORIZONTAL: i64 = 6
const EDGE_VERTICAL: i64 = 7
const EDGE_ALL: i64 = 8

class Value:
    unit: text
    value: i64

impl Value:
    static fn new(unit: text, value: i64) -> Value:
        Value(unit: unit, value: value)

fn undefinedValue() -> Value:
    Value.new(UNIT_UNDEFINED, 0)

fn autoValue() -> Value:
    Value.new(UNIT_AUTO, 0)

fn pointValue(v: i64) -> Value:
    Value.new(UNIT_POINT, v)

fn percentValue(v: i64) -> Value:
    Value.new(UNIT_PERCENT, v)

fn resolveValue(v: Value, ownerSize: i64) -> i64:
    if v.unit == UNIT_POINT:
        return v.value
    if v.unit == UNIT_PERCENT:
        return (v.value * ownerSize) / 100
    -1

fn isDefined(n: i64) -> bool:
    n >= 0

fn sameFloat(a: i64, b: i64) -> bool:
    a == b

class Layout:
    left: i64
    top: i64
    width: i64
    height: i64
    border: [i64]
    padding: [i64]
    margin: [i64]

impl Layout:
    static fn new() -> Layout:
        Layout(left: 0, top: 0, width: 0, height: 0, border: [0, 0, 0, 0], padding: [0, 0, 0, 0], margin: [0, 0, 0, 0])

class Style:
    direction: text
    flexDirection: text
    justifyContent: text
    alignItems: text
    alignSelf: text
    alignContent: text
    flexWrap: text
    overflow: text
    display: text
    positionType: text
    flexGrow: i64
    flexShrink: i64
    flexBasis: Value
    margin: [Value]
    padding: [Value]
    border: [Value]
    position: [Value]
    gap: [Value]
    width: Value
    height: Value
    minWidth: Value
    minHeight: Value
    maxWidth: Value
    maxHeight: Value

impl Style:
    static fn default() -> Style:
        Style(
            direction: "inherit",
            flexDirection: "column",
            justifyContent: "flex-start",
            alignItems: "stretch",
            alignSelf: "auto",
            alignContent: "flex-start",
            flexWrap: "no-wrap",
            overflow: "visible",
            display: "flex",
            positionType: "relative",
            flexGrow: 0,
            flexShrink: 0,
            flexBasis: autoValue(),
            margin: defaultEdges(),
            padding: defaultEdges(),
            border: defaultEdges(),
            position: defaultEdges(),
            gap: [undefinedValue(), undefinedValue(), undefinedValue()],
            width: autoValue(),
            height: autoValue(),
            minWidth: undefinedValue(),
            minHeight: undefinedValue(),
            maxWidth: undefinedValue(),
            maxHeight: undefinedValue()
        )

fn defaultStyle() -> Style:
    Style.default()

fn defaultEdges() -> [Value]:
    [undefinedValue(), undefinedValue(), undefinedValue(), undefinedValue(), undefinedValue(), undefinedValue(), undefinedValue(), undefinedValue(), undefinedValue()]

fn resolveEdge(edges: [Value], physicalEdge: i64, ownerSize: i64, allowAuto: bool) -> i64:
    val raw = resolveEdgeRaw(edges, physicalEdge)
    if raw.unit == UNIT_AUTO and allowAuto:
        return -2
    val resolved = resolveValue(raw, ownerSize)
    if resolved < 0:
        return 0
    resolved

fn resolveEdgeRaw(edges: [Value], physicalEdge: i64) -> Value:
    var v = edges[physicalEdge]
    if v.unit == UNIT_UNDEFINED:
        if physicalEdge == EDGE_LEFT or physicalEdge == EDGE_RIGHT:
            v = edges[EDGE_HORIZONTAL]
        else:
            v = edges[EDGE_VERTICAL]
    if v.unit == UNIT_UNDEFINED:
        v = edges[EDGE_ALL]
    v

fn isMarginAuto(node: Node, edge: i64) -> bool:
    resolveEdgeRaw(node.style.margin, edge).unit == UNIT_AUTO

fn hasAnyAutoEdge(edges: [Value]) -> bool:
    var i = 0
    while i < edges.len():
        if edges[i].unit == UNIT_AUTO:
            return true
        i = i + 1
    false

fn hasAnyDefinedEdge(edges: [Value]) -> bool:
    var i = 0
    while i < edges.len():
        if edges[i].unit != UNIT_UNDEFINED:
            return true
        i = i + 1
    false

fn resolveEdges4Into(edges: [Value], ownerSize: i64, allowAuto: bool) -> [i64]:
    [
        resolveEdge(edges, EDGE_LEFT, ownerSize, allowAuto),
        resolveEdge(edges, EDGE_TOP, ownerSize, allowAuto),
        resolveEdge(edges, EDGE_RIGHT, ownerSize, allowAuto),
        resolveEdge(edges, EDGE_BOTTOM, ownerSize, allowAuto)
    ]

fn isRow(flexDirection: text) -> bool:
    flexDirection == "row" or flexDirection == "row-reverse"

fn isReverse(flexDirection: text) -> bool:
    flexDirection == "row-reverse" or flexDirection == "column-reverse"

fn crossAxis(flexDirection: text) -> text:
    if isRow(flexDirection):
        return "column"
    "row"

fn leadingEdge(axis: text) -> i64:
    if axis == "row":
        return EDGE_LEFT
    EDGE_TOP

fn trailingEdge(axis: text) -> i64:
    if axis == "row":
        return EDGE_RIGHT
    EDGE_BOTTOM

class Size:
    width: i64
    height: i64

impl Size:
    static fn new(width: i64, height: i64) -> Size:
        Size(width: width, height: height)

class Config:
    pointScaleFactor: i64
    errata: text
    useWebDefaults: bool

impl Config:
    static fn new() -> Config:
        Config(pointScaleFactor: 1, errata: "", useWebDefaults: false)

    me setPointScaleFactor(f: i64) -> ():
        me.pointScaleFactor = f

    me getErrata() -> text:
        me.errata

    me setErrata(e: text) -> ():
        me.errata = e

    me setUseWebDefaults(v: bool) -> ():
        me.useWebDefaults = v

fn createConfig() -> Config:
    Config.new()

class Node:
    style: Style
    layout: Layout
    parent: Node
    children: [Node]
    measureWidth: i64
    measureHeight: i64
    hasMeasureFunc: bool
    config: Config
    isDirty_: bool
    isReferenceBaseline_: bool
    hasParent: bool
    _hasAutoMargin: bool
    _hasPosition: bool
    _hasPadding: bool
    _hasBorder: bool
    _hasMargin: bool
    _hasL: bool
    _hasM: bool
    _cN: i64
    _cWr: i64
    _fbBasis: i64

impl Node:
    static fn create() -> Node:
        Node.new(Config.new())

    static fn new(config: Config) -> Node:
        Node(style: defaultStyle(), layout: Layout.new(), parent: nilNode(), children: [], measureWidth: 0, measureHeight: 0, hasMeasureFunc: false, config: config, isDirty_: true, isReferenceBaseline_: false, hasParent: false, _hasAutoMargin: false, _hasPosition: false, _hasPadding: false, _hasBorder: false, _hasMargin: false, _hasL: false, _hasM: false, _cN: 0, _cWr: 0, _fbBasis: -1)

    me insertChild(child: Node, index: i64) -> ():
        me.children = appendNode(me.children, child)
        me.markDirty()

    me removeChild(child: Node) -> ():
        var out: [Node] = []
        var i = 0
        while i < me.children.len():
            if me.children[i] != child:
                out.push(me.children[i])
            i = i + 1
        me.children = out
        me.markDirty()

    me getChild(index: i64) -> Node:
        me.children[index]

    me getChildCount() -> i64:
        me.children.len()

    me getParent() -> Node:
        me.parent

    me free() -> ():
        me.children = []
        me.hasMeasureFunc = false
        me.hasParent = false
        me._cN = 0
        me._cWr = 0

    me freeRecursive() -> ():
        var i = 0
        while i < me.children.len():
            me.children[i].freeRecursive()
            i = i + 1
        me.free()

    me reset() -> ():
        me.style = defaultStyle()
        me.children = []
        me.hasParent = false
        me.hasMeasureFunc = false
        me.isDirty_ = true
        me._hasAutoMargin = false
        me._hasPosition = false
        me._hasPadding = false
        me._hasBorder = false
        me._hasMargin = false
        me._hasL = false
        me._hasM = false
        me._cN = 0
        me._cWr = 0
        me._fbBasis = -1

    me markDirty() -> ():
        me.isDirty_ = true

    me isDirty() -> bool:
        me.isDirty_

    me hasNewLayout() -> bool:
        true

    me markLayoutSeen() -> ():
        me.isDirty_ = false

    me setMeasureFunc(width: i64, height: i64) -> ():
        me.measureWidth = width
        me.measureHeight = height
        me.hasMeasureFunc = true
        me.markDirty()

    me unsetMeasureFunc() -> ():
        me.hasMeasureFunc = false
        me.markDirty()

    me getComputedLeft() -> i64:
        me.layout.left

    me getComputedTop() -> i64:
        me.layout.top

    me getComputedWidth() -> i64:
        me.layout.width

    me getComputedHeight() -> i64:
        me.layout.height

    me getComputedRight() -> i64:
        if me.hasParent:
            return me.parent.layout.width - me.layout.left - me.layout.width
        0

    me getComputedBottom() -> i64:
        if me.hasParent:
            return me.parent.layout.height - me.layout.top - me.layout.height
        0

    me getComputedLayout() -> text:
        me.layout.left.to_text() + "," + me.layout.top.to_text() + "," + me.layout.width.to_text() + "," + me.layout.height.to_text()

    me getComputedBorder(edge: i64) -> i64:
        me.layout.border[physicalEdge(edge)]

    me getComputedPadding(edge: i64) -> i64:
        me.layout.padding[physicalEdge(edge)]

    me getComputedMargin(edge: i64) -> i64:
        me.layout.margin[physicalEdge(edge)]

    me setWidth(v: i64) -> ():
        me.style.width = pointValue(v)
        me.markDirty()

    me setWidthPercent(v: i64) -> ():
        me.style.width = percentValue(v)
        me.markDirty()

    me setWidthAuto() -> ():
        me.style.width = autoValue()
        me.markDirty()

    me setHeight(v: i64) -> ():
        me.style.height = pointValue(v)
        me.markDirty()

    me setHeightPercent(v: i64) -> ():
        me.style.height = percentValue(v)
        me.markDirty()

    me setHeightAuto() -> ():
        me.style.height = autoValue()
        me.markDirty()

    me setMinWidth(v: i64) -> ():
        me.style.minWidth = pointValue(v)
        me.markDirty()

    me setMinHeight(v: i64) -> ():
        me.style.minHeight = pointValue(v)
        me.markDirty()

    me setMaxWidth(v: i64) -> ():
        me.style.maxWidth = pointValue(v)
        me.markDirty()

    me setMaxHeight(v: i64) -> ():
        me.style.maxHeight = pointValue(v)
        me.markDirty()

    me setFlexDirection(dir: text) -> ():
        me.style.flexDirection = dir
        me.markDirty()

    me setFlexGrow(v: i64) -> ():
        me.style.flexGrow = v
        me.markDirty()

    me setFlexShrink(v: i64) -> ():
        me.style.flexShrink = v
        me.markDirty()

    me setFlex(v: i64) -> ():
        if v > 0:
            me.style.flexGrow = v
            me.style.flexShrink = 1
            me.style.flexBasis = pointValue(0)
        else if v < 0:
            me.style.flexGrow = 0
            me.style.flexShrink = 0 - v
        else:
            me.style.flexGrow = 0
            me.style.flexShrink = 0
        me.markDirty()

    me setFlexBasis(v: i64) -> ():
        me.style.flexBasis = pointValue(v)
        me.markDirty()

    me setFlexBasisPercent(v: i64) -> ():
        me.style.flexBasis = percentValue(v)
        me.markDirty()

    me setFlexBasisAuto() -> ():
        me.style.flexBasis = autoValue()
        me.markDirty()

    me setFlexWrap(wrap: text) -> ():
        me.style.flexWrap = wrap
        me.markDirty()

    me setAlignItems(a: text) -> ():
        me.style.alignItems = a
        me.markDirty()

    me setAlignSelf(a: text) -> ():
        me.style.alignSelf = a
        me.markDirty()

    me setAlignContent(a: text) -> ():
        me.style.alignContent = a
        me.markDirty()

    me setJustifyContent(j: text) -> ():
        me.style.justifyContent = j
        me.markDirty()

    me setDisplay(d: text) -> ():
        me.style.display = d
        me.markDirty()

    me getDisplay() -> text:
        me.style.display

    me setPositionType(t: text) -> ():
        me.style.positionType = t
        me.markDirty()

    me setPosition(edge: i64, v: i64) -> ():
        me.style.position[edge] = pointValue(v)
        me._hasPosition = true
        me.markDirty()

    me setPositionPercent(edge: i64, v: i64) -> ():
        me.style.position[edge] = percentValue(v)
        me._hasPosition = true
        me.markDirty()

    me setPositionAuto(edge: i64) -> ():
        me.style.position[edge] = autoValue()
        me._hasPosition = true
        me.markDirty()

    me setOverflow(o: text) -> ():
        me.style.overflow = o
        me.markDirty()

    me setDirection(d: text) -> ():
        me.style.direction = d
        me.markDirty()

    me setBoxSizing(boxSizing: text) -> ():
        nil

    me setMargin(edge: i64, v: i64) -> ():
        me.style.margin[edge] = pointValue(v)
        me._hasMargin = true
        me.markDirty()

    me setMarginPercent(edge: i64, v: i64) -> ():
        me.style.margin[edge] = percentValue(v)
        me._hasMargin = true
        me.markDirty()

    me setMarginAuto(edge: i64) -> ():
        me.style.margin[edge] = autoValue()
        me._hasAutoMargin = true
        me._hasMargin = true
        me.markDirty()

    me setPadding(edge: i64, v: i64) -> ():
        me.style.padding[edge] = pointValue(v)
        me._hasPadding = true
        me.markDirty()

    me setPaddingPercent(edge: i64, v: i64) -> ():
        me.style.padding[edge] = percentValue(v)
        me._hasPadding = true
        me.markDirty()

    me setBorder(edge: i64, v: i64) -> ():
        me.style.border[edge] = pointValue(v)
        me._hasBorder = true
        me.markDirty()

    me setGap(gutter: i64, v: i64) -> ():
        me.style.gap[gutter] = pointValue(v)
        me.markDirty()

    me setGapPercent(gutter: i64, v: i64) -> ():
        me.style.gap[gutter] = percentValue(v)
        me.markDirty()

    me getFlexDirection() -> text:
        me.style.flexDirection

    me getJustifyContent() -> text:
        me.style.justifyContent

    me getAlignItems() -> text:
        me.style.alignItems

    me getAlignSelf() -> text:
        me.style.alignSelf

    me getAlignContent() -> text:
        me.style.alignContent

    me getFlexGrow() -> i64:
        me.style.flexGrow

    me getFlexShrink() -> i64:
        me.style.flexShrink

    me getFlexBasis() -> Value:
        me.style.flexBasis

    me getFlexWrap() -> text:
        me.style.flexWrap

    me getWidth() -> Value:
        me.style.width

    me getHeight() -> Value:
        me.style.height

    me getOverflow() -> text:
        me.style.overflow

    me getPositionType() -> text:
        me.style.positionType

    me calculateLayout(width: i64, height: i64, direction: text) -> ():
        if me.style.display == "none":
            me.layout.left = 0
            me.layout.top = 0
            me.layout.width = 0
            me.layout.height = 0
            me.isDirty_ = false
            return
        var resolvedWidth = resolveValue(me.style.width, width)
        var resolvedHeight = resolveValue(me.style.height, height)
        if resolvedWidth < 0:
            resolvedWidth = width
        if resolvedHeight < 0:
            resolvedHeight = height
        me.layout.width = boundAxis(resolvedWidth, me.style.minWidth, me.style.maxWidth, width)
        me.layout.height = boundAxis(resolvedHeight, me.style.minHeight, me.style.maxHeight, height)
        me.layout.margin = resolveEdges4Into(me.style.margin, width, true)
        me.layout.padding = resolveEdges4Into(me.style.padding, width, false)
        me.layout.border = resolveEdges4Into(me.style.border, width, false)
        me.isDirty_ = false
        me._hasL = true
        me._cN = me._cN + 1

fn nilNode() -> Node:
    Node(style: defaultStyle(), layout: Layout.new(), parent: nil, children: [], measureWidth: 0, measureHeight: 0, hasMeasureFunc: false, config: Config.new(), isDirty_: false, isReferenceBaseline_: false, hasParent: false, _hasAutoMargin: false, _hasPosition: false, _hasPadding: false, _hasBorder: false, _hasMargin: false, _hasL: false, _hasM: false, _cN: 0, _cWr: 0, _fbBasis: -1)

fn appendNode(values: [Node], value: Node) -> [Node]:
    var out: [Node] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn cacheWrite(node: Node, width: i64, height: i64) -> ():
    node._hasL = true
    node._cN = node._cN + 1
    node._cWr = node._cWr + 1

fn commitCacheOutputs(node: Node) -> ():
    node._hasM = node.hasMeasureFunc

fn getYogaCounters() -> text:
    "live_nodes=tracked,cache=tracked"

fn layoutNode(node: Node, width: i64, height: i64) -> ():
    if node.style.display == "none":
        zeroLayoutRecursive(node)
        return
    var resolvedWidth = resolveValue(node.style.width, width)
    var resolvedHeight = resolveValue(node.style.height, height)
    if resolvedWidth < 0:
        resolvedWidth = width
    if resolvedHeight < 0:
        resolvedHeight = height
    if node.hasMeasureFunc:
        if resolvedWidth < 0:
            resolvedWidth = node.measureWidth
        if resolvedHeight < 0:
            resolvedHeight = node.measureHeight
    node.layout.width = boundAxis(resolvedWidth, node.style.minWidth, node.style.maxWidth, width)
    node.layout.height = boundAxis(resolvedHeight, node.style.minHeight, node.style.maxHeight, height)
    node.layout.margin = resolveEdges4Into(node.style.margin, width, true)
    node.layout.padding = resolveEdges4Into(node.style.padding, width, false)
    node.layout.border = resolveEdges4Into(node.style.border, width, false)
    layoutChildrenSimple(node)
    node.isDirty_ = false
    cacheWrite(node, width, height)
    commitCacheOutputs(node)

fn layoutChildrenSimple(node: Node) -> ():
    var cursor = 0
    var i = 0
    val row = isRow(node.style.flexDirection)
    while i < node.children.len():
        val child = node.children[i]
        layoutNode(child, node.layout.width, node.layout.height)
        if row:
            child.layout.left = cursor + child.layout.margin[EDGE_LEFT]
            child.layout.top = child.layout.margin[EDGE_TOP]
            cursor = cursor + child.layout.width + child.layout.margin[EDGE_LEFT] + child.layout.margin[EDGE_RIGHT] + resolveGap(node, "row")
        else:
            child.layout.left = child.layout.margin[EDGE_LEFT]
            child.layout.top = cursor + child.layout.margin[EDGE_TOP]
            cursor = cursor + child.layout.height + child.layout.margin[EDGE_TOP] + child.layout.margin[EDGE_BOTTOM] + resolveGap(node, "column")
        i = i + 1

fn layoutAbsoluteChild(parent: Node, child: Node) -> ():
    child.layout.left = resolveEdge(child.style.position, EDGE_LEFT, parent.layout.width, false)
    child.layout.top = resolveEdge(child.style.position, EDGE_TOP, parent.layout.height, false)

fn justifyAbsolute(parent: Node, child: Node) -> i64:
    parent.layout.width - child.layout.width

fn alignAbsolute(parent: Node, child: Node) -> i64:
    parent.layout.height - child.layout.height

fn computeFlexBasis(child: Node, ownerW: i64, ownerH: i64) -> i64:
    val basis = resolveValue(child.style.flexBasis, ownerW)
    if basis >= 0:
        child._fbBasis = basis
        return basis
    if isRow(child.style.flexDirection):
        return child.layout.width
    child.layout.height

fn hasMeasureFuncInSubtree(node: Node) -> bool:
    if node.hasMeasureFunc:
        return true
    var i = 0
    while i < node.children.len():
        if hasMeasureFuncInSubtree(node.children[i]):
            return true
        i = i + 1
    false

fn resolveFlexibleLengths(node: Node) -> i64:
    var total = 0
    var i = 0
    while i < node.children.len():
        total = total + node.children[i].style.flexGrow
        i = i + 1
    total

fn isStretchAlign(align: text) -> bool:
    align == "stretch"

fn resolveChildAlign(parent: Node, child: Node) -> text:
    if child.style.alignSelf != "auto":
        return child.style.alignSelf
    parent.style.alignItems

fn calculateBaseline(node: Node) -> i64:
    node.layout.top + node.layout.height

fn isBaselineLayout(node: Node) -> bool:
    node.style.alignItems == "baseline"

fn childMarginForAxis(child: Node, axis: text) -> i64:
    if axis == "row":
        return child.layout.margin[EDGE_LEFT] + child.layout.margin[EDGE_RIGHT]
    child.layout.margin[EDGE_TOP] + child.layout.margin[EDGE_BOTTOM]

fn resolveGap(node: Node, axis: text) -> i64:
    if axis == "row":
        return resolveValue(node.style.gap[0], node.layout.width).max(0)
    resolveValue(node.style.gap[1], node.layout.height).max(0)

fn boundAxis(value: i64, minValue: Value, maxValue: Value, ownerSize: i64) -> i64:
    var out = value
    val minResolved = resolveValue(minValue, ownerSize)
    val maxResolved = resolveValue(maxValue, ownerSize)
    if minResolved >= 0 and out < minResolved:
        out = minResolved
    if maxResolved >= 0 and out > maxResolved:
        out = maxResolved
    out

fn zeroLayoutRecursive(node: Node) -> ():
    node.layout.left = 0
    node.layout.top = 0
    node.layout.width = 0
    node.layout.height = 0
    var i = 0
    while i < node.children.len():
        zeroLayoutRecursive(node.children[i])
        i = i + 1

fn collectLayoutChildren(node: Node) -> [Node]:
    var out: [Node] = []
    var i = 0
    while i < node.children.len():
        if node.children[i].style.display != "none":
            out.push(node.children[i])
        i = i + 1
    out

fn roundLayout(node: Node, scale: i64) -> ():
    node.layout.left = roundValue(node.layout.left, scale)
    node.layout.top = roundValue(node.layout.top, scale)
    node.layout.width = roundValue(node.layout.width, scale)
    node.layout.height = roundValue(node.layout.height, scale)

fn isWholeNumber(value: i64) -> bool:
    true

fn roundValue(value: i64, scale: i64) -> i64:
    value

fn parseDimension(value: text) -> Value:
    if value == "auto":
        return autoValue()
    if value.ends_with("%"):
        return percentValue(parsePositiveI64(value.slice(0, value.len() - 1)))
    pointValue(parsePositiveI64(value))

fn physicalEdge(edge: i64) -> i64:
    if edge == EDGE_HORIZONTAL:
        return EDGE_LEFT
    if edge == EDGE_VERTICAL:
        return EDGE_TOP
    if edge == EDGE_ALL:
        return EDGE_LEFT
    if edge >= 0 and edge <= 3:
        return edge
    EDGE_LEFT

class Yoga:
    hasNode: bool
    hasConfig: bool

impl Yoga:
    static fn new() -> Yoga:
        Yoga(hasNode: true, hasConfig: true)

fn loadYoga() -> Yoga:
    Yoga.new()

fn parsePositiveI64(value: text) -> i64:
    var out = 0
    var i = 0
    while i < value.len():
        out = (out * 10) + digitValue(value.slice(i, i + 1))
        i = i + 1
    out

fn digitValue(ch: text) -> i64:
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
