const BASH_READ_ONLY_VALIDATION_SOURCE_LINES = 1990

fn isCommandSafeViaFlagParsingRoute(command: text) -> bool:
    command == "pwd" || command.starts_with("echo ") || command == "git status" || command.starts_with("ls ")

fn checkReadOnlyConstraintsRoute(command: text, parseOk: bool, hasUncPath: bool, bareRepoCwd: bool, sandboxCwdMismatch: bool) -> text:
    if !parseOk:
        return "passthrough"
    if hasUncPath:
        return "ask unc path"
    if command.contains("*") || command.contains("$_"):
        return "passthrough"
    if command.starts_with("git -c ") || command.starts_with("git --exec-path") || command.starts_with("git --config-env"):
        return "passthrough"
    if command.starts_with("cd ") && command.contains("&& git "):
        return "passthrough"
    if bareRepoCwd || sandboxCwdMismatch:
        return "passthrough"
    if command.contains("hooks/pre-commit") && command.contains("git "):
        return "passthrough"
    if isCommandSafeViaFlagParsingRoute(command):
        return "allow"
    "passthrough"

fn bashReadOnlyValidationSourceLinesModeled() -> i64:
    BASH_READ_ONLY_VALIDATION_SOURCE_LINES
