"""
Claude full assistant tool-use message parity model.
"""

const ASSISTANT_TOOL_USE_MESSAGE_SOURCE_LINES = 367

class AssistantToolUseParam:
    id: text
    name: text
    input_summary: text

impl AssistantToolUseParam:
    static fn new(id: text, name: text, inputSummary: text) -> AssistantToolUseParam:
        AssistantToolUseParam(id: id, name: name, input_summary: inputSummary)

class AssistantToolUseTool:
    name: text
    user_facing_name: text
    transparent_wrapper: bool
    background_color: text
    tag: text

impl AssistantToolUseTool:
    static fn new(name: text, userFacingName: text, transparentWrapper: bool, backgroundColor: text, tag: text) -> AssistantToolUseTool:
        AssistantToolUseTool(name: name, user_facing_name: userFacingName, transparent_wrapper: transparentWrapper, background_color: backgroundColor, tag: tag)

class AssistantToolUseRender:
    visible: bool
    mode: text
    title: text
    detail: text
    queued: bool
    resolved: bool
    show_loader: bool
    show_dot: bool
    classifier_text: text
    waiting_for_permission: bool

impl AssistantToolUseRender:
    static fn hidden() -> AssistantToolUseRender:
        AssistantToolUseRender(visible: false, mode: "hidden", title: "", detail: "", queued: false, resolved: false, show_loader: false, show_dot: false, classifier_text: "", waiting_for_permission: false)

    static fn new(mode: text, title: text, detail: text, queued: bool, resolved: bool, showLoader: bool, showDot: bool, classifierText: text, waitingForPermission: bool) -> AssistantToolUseRender:
        AssistantToolUseRender(visible: true, mode: mode, title: title, detail: detail, queued: queued, resolved: resolved, show_loader: showLoader, show_dot: showDot, classifier_text: classifierText, waiting_for_permission: waitingForPermission)

fn assistantToolUseContains(ids: [text], id: text) -> bool:
    var i = 0
    while i < ids.len():
        if ids[i] == id:
            return true
        i = i + 1
    false

fn assistantToolUseFindTool(tools: [AssistantToolUseTool], name: text) -> AssistantToolUseTool?:
    var i = 0
    while i < tools.len():
        if tools[i].name == name:
            return tools[i]
        i = i + 1
    nil

fn assistantToolUseIsQueued(id: text, inProgressIds: [text], resolvedIds: [text]) -> bool:
    if assistantToolUseContains(inProgressIds, id):
        return false
    if assistantToolUseContains(resolvedIds, id):
        return false
    true

fn assistantToolUseClassifierText(isClassifierChecking: bool, isAutoClassifier: bool) -> text:
    if not isClassifierChecking:
        return ""
    if isAutoClassifier:
        return "Auto classifier checking..."
    "Bash classifier checking..."

fn assistantToolUseProgressText(toolName: text, count: i64, transcript: bool) -> text:
    var out = "Running " + toolName
    if count > 1:
        out = out + " (" + count.to_text() + " active)"
    if transcript:
        out = out + " in transcript"
    out

fn assistantToolUseMessage(param: AssistantToolUseParam, tools: [AssistantToolUseTool], inProgressIds: [text], resolvedIds: [text], erroredIds: [text], shouldAnimate: bool, shouldShowDot: bool, isClassifierChecking: bool, isAutoClassifier: bool, waitingForPermission: bool, inProgressToolCallCount: i64, isTranscriptMode: bool) -> AssistantToolUseRender:
    if val tool = assistantToolUseFindTool(tools, param.name):
        if tool.user_facing_name == "":
            return AssistantToolUseRender.hidden()
        val resolved = assistantToolUseContains(resolvedIds, param.id)
        val queued = assistantToolUseIsQueued(param.id, inProgressIds, resolvedIds)
        if tool.transparent_wrapper:
            if queued or resolved:
                return AssistantToolUseRender.hidden()
            return AssistantToolUseRender.new("transparent-progress", tool.user_facing_name, assistantToolUseProgressText(tool.user_facing_name, inProgressToolCallCount, isTranscriptMode), queued, resolved, shouldAnimate, false, "", waitingForPermission)
        val classifier = assistantToolUseClassifierText(isClassifierChecking, isAutoClassifier)
        var detail = param.input_summary
        if detail == "":
            detail = tool.tag
        if not resolved and not queued:
            if classifier != "":
                detail = classifier
            elif waitingForPermission:
                detail = "Waiting for permission..."
            else:
                detail = assistantToolUseProgressText(tool.user_facing_name, inProgressToolCallCount, isTranscriptMode)
        AssistantToolUseRender.new("tool-use", tool.user_facing_name, detail, queued, resolved, shouldAnimate and not resolved, shouldShowDot, classifier, waitingForPermission)
    AssistantToolUseRender.hidden()

fn assistantToolUseMessageSourceLinesModeled() -> i64:
    ASSISTANT_TOOL_USE_MESSAGE_SOURCE_LINES
