"""
Claude full collapsed team memory count parity model.
"""

const TEAM_MEM_COLLAPSED_SOURCE_LINES = 139

class TeamMemCounts:
    read_count: i64
    search_count: i64
    write_count: i64

impl TeamMemCounts:
    static fn new(readCount: i64, searchCount: i64, writeCount: i64) -> TeamMemCounts:
        TeamMemCounts(read_count: readCount, search_count: searchCount, write_count: writeCount)

fn checkHasTeamMemOps(message: TeamMemCounts) -> bool:
    if message.search_count > 0:
        return true
    if message.read_count > 0:
        return true
    message.write_count > 0

fn teamMemVerb(active: bool, first: bool, activeVerb: text, inactiveVerb: text) -> text:
    var verb = inactiveVerb
    if active:
        verb = activeVerb
    if first:
        return verb
    verb.to_lower()

fn teamMemReadPart(count: i64, active: bool, first: bool) -> text:
    if count <= 0:
        return ""
    val noun = if count == 1: "memory" else: "memories"
    teamMemVerb(active, first, "Recalling", "Recalled") + " " + count.to_text() + " team " + noun

fn teamMemSearchPart(count: i64, active: bool, first: bool) -> text:
    if count <= 0:
        return ""
    teamMemVerb(active, first, "Searching", "Searched") + " team memories"

fn teamMemWritePart(count: i64, active: bool, first: bool) -> text:
    if count <= 0:
        return ""
    val noun = if count == 1: "memory" else: "memories"
    teamMemVerb(active, first, "Writing", "Wrote") + " " + count.to_text() + " team " + noun

fn teamMemCollapsedParts(message: TeamMemCounts, isActiveGroup: bool, hasPrecedingParts: bool) -> text:
    var out = ""
    var count = 0
    if hasPrecedingParts:
        count = 1
    if message.read_count > 0:
        if out != "":
            out = out + ", "
        out = out + teamMemReadPart(message.read_count, isActiveGroup, count == 0)
        count = count + 1
    if message.search_count > 0:
        if out != "":
            out = out + ", "
        out = out + teamMemSearchPart(message.search_count, isActiveGroup, count == 0)
        count = count + 1
    if message.write_count > 0:
        if out != "":
            out = out + ", "
        out = out + teamMemWritePart(message.write_count, isActiveGroup, count == 0)
    out

fn teamMemCollapsedSourceLinesModeled() -> i64:
    TEAM_MEM_COLLAPSED_SOURCE_LINES
