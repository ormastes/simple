"""
Claude full null-rendering attachment parity model.
"""

const NULL_RENDERING_ATTACHMENTS_SOURCE_LINES = 70

class NullRenderingMessage:
    type_name: text
    attachment_type: text

impl NullRenderingMessage:
    static fn new(typeName: text, attachmentType: text) -> NullRenderingMessage:
        NullRenderingMessage(type_name: typeName, attachment_type: attachmentType)

class HiddenModelVisibleFeature:
    name: text
    source_surface: text
    user_visible: bool
    model_visible: bool
    reason: text

impl HiddenModelVisibleFeature:
    static fn new(name: text, sourceSurface: text, reason: text) -> HiddenModelVisibleFeature:
        HiddenModelVisibleFeature(name: name, source_surface: sourceSurface, user_visible: false, model_visible: true, reason: reason)

fn nullRenderingAttachmentTypes() -> [text]:
    [
        "hook_success",
        "hook_additional_context",
        "hook_cancelled",
        "command_permissions",
        "agent_mention",
        "budget_usd",
        "critical_system_reminder",
        "edited_image_file",
        "edited_text_file",
        "opened_file_in_ide",
        "output_style",
        "plan_mode",
        "plan_mode_exit",
        "plan_mode_reentry",
        "structured_output",
        "team_context",
        "todo_reminder",
        "context_efficiency",
        "deferred_tools_delta",
        "mcp_instructions_delta",
        "companion_intro",
        "token_usage",
        "ultrathink_effort",
        "max_turns_reached",
        "task_reminder",
        "auto_mode",
        "auto_mode_exit",
        "output_token_usage",
        "pen_mode_enter",
        "pen_mode_exit",
        "verify_plan_reminder",
        "current_session_memory",
        "compaction_reminder",
        "date_change",
    ]

fn isNullRenderingAttachmentType(attachmentType: text) -> bool:
    val types = nullRenderingAttachmentTypes()
    var i = 0
    while i < types.len():
        if types[i] == attachmentType:
            return true
        i = i + 1
    false

fn isNullRenderingAttachment(msg: NullRenderingMessage) -> bool:
    if msg.type_name != "attachment":
        return false
    isNullRenderingAttachmentType(msg.attachment_type)

fn hiddenModelVisibleFeatures() -> [HiddenModelVisibleFeature]:
    [
        HiddenModelVisibleFeature.new("queued-input-isMeta", "types/textInputTypes.ts:isMeta", "system-generated prompts route through the queue and are hidden in transcript UI"),
        HiddenModelVisibleFeature.new("command-metaMessages", "types/command.ts:metaMessages", "command completion may insert extra isMeta messages for the model"),
        HiddenModelVisibleFeature.new("slash-command-hidden-reentry", "utils/processUserInput/processSlashCommand.tsx:isMeta", "assistant-mode and context commands can re-enter the queue as hidden prompts"),
        HiddenModelVisibleFeature.new("image-metadata-isMeta", "utils/processUserInput/processUserInput.ts:isMeta", "image metadata texts are added as isMeta messages"),
        HiddenModelVisibleFeature.new("scheduled-task-isMeta", "hooks/useScheduledTasks.ts:isMeta", "scheduled task prompts are propagated as hidden model-visible prompts"),
        HiddenModelVisibleFeature.new("context-collapse-marker", "components/ContextVisualization.tsx:isMeta", "collapsed context markers tell the model context was rewritten"),
    ]

fn hiddenModelVisibleFeatureNames() -> [text]:
    val features = hiddenModelVisibleFeatures()
    var out: [text] = []
    var i = 0
    while i < features.len():
        out.push(features[i].name)
        i = i + 1
    out

fn isHiddenModelVisibleFeature(name: text) -> bool:
    val features = hiddenModelVisibleFeatures()
    var i = 0
    while i < features.len():
        if features[i].name == name:
            return features[i].model_visible and not features[i].user_visible
        i = i + 1
    false

fn nullRenderingAttachmentsSourceLinesModeled() -> i64:
    NULL_RENDERING_ATTACHMENTS_SOURCE_LINES
