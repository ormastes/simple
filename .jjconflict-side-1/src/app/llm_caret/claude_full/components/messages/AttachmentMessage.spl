"""
Claude full AttachmentMessage parity model.
"""

const ATTACHMENT_MESSAGE_SOURCE_LINES = 535

class AttachmentSkill:
    name: text
    short_id: text

impl AttachmentSkill:
    static fn new(name: text, shortId: text) -> AttachmentSkill:
        AttachmentSkill(name: name, short_id: shortId)

class AttachmentMailboxMessage:
    from: text
    color: text
    text: text
    summary: text

impl AttachmentMailboxMessage:
    static fn new(from: text, color: text, text: text, summary: text) -> AttachmentMailboxMessage:
        AttachmentMailboxMessage(from: from, color: color, text: text, summary: summary)

class AttachmentMemory:
    path: text
    content: text

impl AttachmentMemory:
    static fn new(path: text, content: text) -> AttachmentMemory:
        AttachmentMemory(path: path, content: content)

class AttachmentContent:
    kind: text
    num_lines: i64
    cells: i64
    original_size: i64

impl AttachmentContent:
    static fn textFile(numLines: i64) -> AttachmentContent:
        AttachmentContent(kind: "text", num_lines: numLines, cells: 0, original_size: 0)

    static fn notebook(cells: i64) -> AttachmentContent:
        AttachmentContent(kind: "notebook", num_lines: 0, cells: cells, original_size: 0)

    static fn unchanged() -> AttachmentContent:
        AttachmentContent(kind: "file_unchanged", num_lines: 0, cells: 0, original_size: 0)

    static fn binary(originalSize: i64) -> AttachmentContent:
        AttachmentContent(kind: "binary", num_lines: 0, cells: 0, original_size: originalSize)

class AttachmentModel:
    type_name: text
    display_path: text
    content: AttachmentContent
    truncated: bool
    page_count: i64
    line_start: i64
    line_end: i64
    ide_name: text
    memories: [AttachmentMemory]
    skill_names: [text]
    skills: [AttachmentSkill]
    is_initial: bool
    added_types: [text]
    prompt_text: text
    image_paste_ids: [text]
    plan_file_path: text
    server: text
    name: text
    hook_event: text
    hook_name: text
    hook_content: text
    hook_decision: text
    blocking_error: text
    status: text
    task_type: text
    task_id: text
    description: text
    count: i64
    mailbox_messages: [AttachmentMailboxMessage]

impl AttachmentModel:
    static fn empty(typeName: text) -> AttachmentModel:
        AttachmentModel(type_name: typeName, display_path: "", content: AttachmentContent.textFile(0), truncated: false, page_count: 0, line_start: 0, line_end: 0, ide_name: "", memories: [], skill_names: [], skills: [], is_initial: false, added_types: [], prompt_text: "", image_paste_ids: [], plan_file_path: "", server: "", name: "", hook_event: "", hook_name: "", hook_content: "", hook_decision: "", blocking_error: "", status: "", task_type: "", task_id: "", description: "", count: 0, mailbox_messages: [])

    static fn file(typeName: text, path: text, content: AttachmentContent, truncated: bool) -> AttachmentModel:
        val item = AttachmentModel.empty(typeName)
        AttachmentModel(type_name: item.type_name, display_path: path, content: content, truncated: truncated, page_count: 0, line_start: 0, line_end: 0, ide_name: "", memories: [], skill_names: [], skills: [], is_initial: false, added_types: [], prompt_text: "", image_paste_ids: [], plan_file_path: "", server: "", name: "", hook_event: "", hook_name: "", hook_content: "", hook_decision: "", blocking_error: "", status: "", task_type: "", task_id: "", description: "", count: 0, mailbox_messages: [])

    static fn mailbox(messages: [AttachmentMailboxMessage]) -> AttachmentModel:
        val item = AttachmentModel.empty("teammate_mailbox")
        AttachmentModel(type_name: item.type_name, display_path: "", content: item.content, truncated: false, page_count: 0, line_start: 0, line_end: 0, ide_name: "", memories: [], skill_names: [], skills: [], is_initial: false, added_types: [], prompt_text: "", image_paste_ids: [], plan_file_path: "", server: "", name: "", hook_event: "", hook_name: "", hook_content: "", hook_decision: "", blocking_error: "", status: "", task_type: "", task_id: "", description: "", count: 0, mailbox_messages: messages)

class AttachmentRender:
    visible: bool
    kind: text
    label: text
    detail: text
    count: i64
    color: text
    children: [text]

impl AttachmentRender:
    static fn hidden() -> AttachmentRender:
        AttachmentRender(visible: false, kind: "hidden", label: "", detail: "", count: 0, color: "", children: [])

    static fn line(kind: text, label: text, detail: text) -> AttachmentRender:
        AttachmentRender(visible: true, kind: kind, label: label, detail: detail, count: 0, color: "", children: [])

    static fn counted(kind: text, label: text, detail: text, count: i64) -> AttachmentRender:
        AttachmentRender(visible: true, kind: kind, label: label, detail: detail, count: count, color: "", children: [])

fn attachmentMessagePlural(count: i64, singular: text) -> text:
    if count == 1:
        return singular
    singular + "s"

fn attachmentMessageBasename(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        val ch = path.slice(i, i + 1)
        if ch == "/" or ch == "\\":
            last = i
        i = i + 1
    if last < 0:
        return path
    path.slice(last + 1, path.len())

fn attachmentMessageFormatSize(size: i64) -> text:
    if size < 1024:
        return "{size} B"
    if size < 1048576:
        return "{size / 1024} KB"
    "{size / 1048576} MB"

fn attachmentMessageIsShutdownText(text: text) -> bool:
    val clean = text.trim().lower()
    clean.contains("shutdown_approved") or clean.contains("shut down approved")

fn attachmentMessageIsHiddenMailboxText(text: text) -> bool:
    val clean = text.trim()
    attachmentMessageIsShutdownText(clean) or clean.contains("\"type\":\"idle_notification\"") or clean.contains("\"type\":\"teammate_terminated\"")

fn attachmentMessageVisibleMailbox(messages: [AttachmentMailboxMessage]) -> [AttachmentMailboxMessage]:
    var result: [AttachmentMailboxMessage] = []
    var i = 0
    while i < messages.len():
        if not attachmentMessageIsHiddenMailboxText(messages[i].text):
            result.push(messages[i])
        i = i + 1
    result

fn attachmentMessageSkillNames(skills: [AttachmentSkill]) -> text:
    var result = ""
    var i = 0
    while i < skills.len():
        val skill = skills[i]
        val label = if skill.short_id != "": "{skill.name} [{skill.short_id}]" else: skill.name
        if result == "":
            result = label
        else:
            result = result + ", " + label
        i = i + 1
    result

fn attachmentMessageFileDetail(content: AttachmentContent, truncated: bool) -> text:
    if content.kind == "notebook":
        return "{content.cells} cells"
    if content.kind == "file_unchanged":
        return "unchanged"
    if content.kind == "text":
        val suffix = if truncated: "+" else: ""
        return "{content.num_lines}{suffix} lines"
    attachmentMessageFormatSize(content.original_size)

fn attachmentMessageHookHidden(event: text) -> bool:
    event == "Stop" or event == "SubagentStop"

fn attachmentMessageTaskStatusText(status: text) -> text:
    if status == "completed":
        return "completed in background"
    if status == "killed":
        return "stopped"
    if status == "running":
        return "still running in background"
    status

fn attachmentMessageRenderMailbox(attachment: AttachmentModel, swarmsEnabled: bool, isTranscriptMode: bool) -> AttachmentRender:
    if not swarmsEnabled:
        return AttachmentRender.hidden()
    val visible = attachmentMessageVisibleMailbox(attachment.mailbox_messages)
    if visible.len() == 0:
        return AttachmentRender.hidden()
    var rows: [text] = []
    var i = 0
    while i < visible.len():
        val msg = visible[i]
        if msg.text.contains("\"type\":\"task_assignment\""):
            rows.push("Task assigned from " + msg.from)
        else:
            val suffix = if isTranscriptMode and msg.summary != "": " " + msg.summary else: ""
            rows.push(msg.from + ": " + msg.text + suffix)
        i = i + 1
    AttachmentRender(visible: true, kind: "teammate_mailbox", label: "mailbox", detail: "", count: rows.len(), color: "", children: rows)

fn attachmentMessageRenderSkillDiscovery(attachment: AttachmentModel, featureEnabled: bool, isDemoEnv: bool) -> AttachmentRender:
    if not featureEnabled or attachment.type_name != "skill_discovery":
        return AttachmentRender.hidden()
    if attachment.skills.len() == 0:
        return AttachmentRender.hidden()
    val first = attachment.skills[0]
    val hint = if first.short_id != "" and not isDemoEnv: " /skill-feedback " + first.short_id else: ""
    AttachmentRender.counted("skill_discovery", "{attachment.skills.len()} relevant " + attachmentMessagePlural(attachment.skills.len(), "skill"), attachmentMessageSkillNames(attachment.skills) + hint, attachment.skills.len())

fn attachmentMessageRender(attachment: AttachmentModel, addMargin: bool, verbose: bool, isTranscriptMode: bool, swarmsEnabled: bool, skillSearchEnabled: bool, isDemoEnv: bool) -> AttachmentRender:
    if attachment.type_name == "teammate_mailbox":
        return attachmentMessageRenderMailbox(attachment, swarmsEnabled, isTranscriptMode)
    if attachment.type_name == "skill_discovery":
        return attachmentMessageRenderSkillDiscovery(attachment, skillSearchEnabled, isDemoEnv)
    if attachment.type_name == "directory":
        return AttachmentRender.line("directory", "Listed directory", attachment.display_path + "/")
    if attachment.type_name == "file" or attachment.type_name == "already_read_file":
        return AttachmentRender.line("file", "Read " + attachment.display_path, attachmentMessageFileDetail(attachment.content, attachment.truncated))
    if attachment.type_name == "compact_file_reference":
        return AttachmentRender.line("compact_file_reference", "Referenced file", attachment.display_path)
    if attachment.type_name == "pdf_reference":
        return AttachmentRender.counted("pdf_reference", "Referenced PDF", attachment.display_path, attachment.page_count)
    if attachment.type_name == "selected_lines_in_ide":
        val lineCount = attachment.line_end - attachment.line_start + 1
        return AttachmentRender.counted("selected_lines_in_ide", "Selected lines from " + attachment.display_path, attachment.ide_name, lineCount)
    if attachment.type_name == "nested_memory":
        return AttachmentRender.line("nested_memory", "Loaded", attachment.display_path)
    if attachment.type_name == "relevant_memories":
        var children: [text] = []
        if verbose or isTranscriptMode:
            var i = 0
            while i < attachment.memories.len():
                val memory = attachment.memories[i]
                children.push(attachmentMessageBasename(memory.path))
                if isTranscriptMode:
                    children.push(memory.content)
                i = i + 1
        return AttachmentRender(visible: true, kind: "relevant_memories", label: "Recalled " + attachmentMessagePlural(attachment.memories.len(), "memory"), detail: "", count: attachment.memories.len(), color: if addMargin: "margin" else: "", children: children)
    if attachment.type_name == "dynamic_skill":
        return AttachmentRender.counted("dynamic_skill", "Loaded " + attachmentMessagePlural(attachment.skill_names.len(), "skill"), attachment.display_path, attachment.skill_names.len())
    if attachment.type_name == "skill_listing":
        if attachment.is_initial:
            return AttachmentRender.hidden()
        return AttachmentRender.counted("skill_listing", attachmentMessagePlural(attachment.count, "skill") + " available", "", attachment.count)
    if attachment.type_name == "agent_listing_delta":
        if attachment.is_initial or attachment.added_types.len() == 0:
            return AttachmentRender.hidden()
        return AttachmentRender.counted("agent_listing_delta", "agent " + attachmentMessagePlural(attachment.added_types.len(), "type") + " available", "", attachment.added_types.len())
    if attachment.type_name == "queued_command":
        val imageLabel = if attachment.image_paste_ids.len() > 0: " images=" + "{attachment.image_paste_ids.len()}" else: ""
        return AttachmentRender.line("queued_command", attachment.prompt_text, imageLabel)
    if attachment.type_name == "plan_file_reference":
        return AttachmentRender.line("plan_file_reference", "Plan file referenced", attachment.plan_file_path)
    if attachment.type_name == "invoked_skills":
        if attachment.skills.len() == 0:
            return AttachmentRender.hidden()
        return AttachmentRender.line("invoked_skills", "Skills restored", attachmentMessageSkillNames(attachment.skills))
    if attachment.type_name == "diagnostics":
        return AttachmentRender.line("diagnostics", "Diagnostics", if verbose: "verbose" else: "summary")
    if attachment.type_name == "mcp_resource":
        return AttachmentRender.line("mcp_resource", "Read MCP resource " + attachment.name, attachment.server)
    if attachment.type_name == "command_permissions":
        return AttachmentRender.hidden()
    if attachment.type_name == "async_hook_response":
        if attachment.hook_event == "SessionStart" and not verbose:
            return AttachmentRender.hidden()
        if not verbose and not isTranscriptMode:
            return AttachmentRender.hidden()
        return AttachmentRender.line("async_hook_response", "Async hook " + attachment.hook_event, "completed")
    if attachment.type_name == "hook_blocking_error":
        if attachmentMessageHookHidden(attachment.hook_event):
            return AttachmentRender.hidden()
        return AttachmentRender.line("hook_blocking_error", attachment.hook_name + " hook returned blocking error", attachment.blocking_error.trim())
    if attachment.type_name == "hook_non_blocking_error":
        if attachmentMessageHookHidden(attachment.hook_event):
            return AttachmentRender.hidden()
        return AttachmentRender.line("hook_non_blocking_error", attachment.hook_name + " hook error", "")
    if attachment.type_name == "hook_error_during_execution":
        if attachmentMessageHookHidden(attachment.hook_event):
            return AttachmentRender.hidden()
        return AttachmentRender.line("hook_error_during_execution", attachment.hook_name + " hook warning", "")
    if attachment.type_name == "hook_success":
        return AttachmentRender.hidden()
    if attachment.type_name == "hook_stopped_continuation":
        if attachmentMessageHookHidden(attachment.hook_event):
            return AttachmentRender.hidden()
        return AttachmentRender.line("hook_stopped_continuation", attachment.hook_name + " hook stopped continuation", attachment.hook_content)
    if attachment.type_name == "hook_system_message":
        return AttachmentRender.line("hook_system_message", attachment.hook_name + " says", attachment.hook_content)
    if attachment.type_name == "hook_permission_decision":
        val action = if attachment.hook_decision == "allow": "Allowed" else: "Denied"
        return AttachmentRender.line("hook_permission_decision", action + " by " + attachment.hook_event + " hook", "")
    if attachment.type_name == "task_status":
        return AttachmentRender.line("task_status", "Task \"" + attachment.description + "\"", attachmentMessageTaskStatusText(attachment.status))
    if attachment.type_name == "teammate_shutdown_batch":
        return AttachmentRender.counted("teammate_shutdown_batch", attachmentMessagePlural(attachment.count, "teammate") + " shut down gracefully", "", attachment.count)
    AttachmentRender.hidden()

