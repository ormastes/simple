"""
Claude full user local command output message parity model.
"""

use app.llm_caret.claude_full.components.messages.UserBashInputMessage.{extractTaggedValue}

const USER_LOCAL_COMMAND_OUTPUT_MESSAGE_SOURCE_LINES = 166
const USER_LOCAL_COMMAND_NO_CONTENT_MESSAGE = "(no content)"
const USER_LOCAL_COMMAND_DIAMOND_OPEN = "◇"
const USER_LOCAL_COMMAND_DIAMOND_FILLED = "◆"
const USER_LOCAL_COMMAND_INDENT = "  ⏿  "

class UserLocalCommandOutputLine:
    key: text
    mode: text
    text: text
    diamond: text
    label: text
    suffix: text
    rest: text
    indent: text
    dim: bool
    bold_label: bool

impl UserLocalCommandOutputLine:
    static fn indented(key: text, textValue: text) -> UserLocalCommandOutputLine:
        UserLocalCommandOutputLine(key: key, mode: "markdown", text: textValue, diamond: "", label: "", suffix: "", rest: "", indent: USER_LOCAL_COMMAND_INDENT, dim: true, bold_label: false)

    static fn cloud(key: text, textValue: text, diamond: text, label: text, suffix: text, rest: text) -> UserLocalCommandOutputLine:
        UserLocalCommandOutputLine(key: key, mode: "cloud-launch", text: textValue, diamond: diamond, label: label, suffix: suffix, rest: rest, indent: USER_LOCAL_COMMAND_INDENT, dim: true, bold_label: true)

class UserLocalCommandOutputRender:
    visible: bool
    empty: bool
    empty_message: text
    lines: [UserLocalCommandOutputLine]

impl UserLocalCommandOutputRender:
    static fn emptyResponse() -> UserLocalCommandOutputRender:
        UserLocalCommandOutputRender(visible: true, empty: true, empty_message: USER_LOCAL_COMMAND_NO_CONTENT_MESSAGE, lines: [])

    static fn new(lines: [UserLocalCommandOutputLine]) -> UserLocalCommandOutputRender:
        UserLocalCommandOutputRender(visible: true, empty: false, empty_message: "", lines: lines)

fn userLocalCommandOutputHasCloudPrefix(children: text) -> bool:
    children.starts_with(USER_LOCAL_COMMAND_DIAMOND_OPEN + " ") or children.starts_with(USER_LOCAL_COMMAND_DIAMOND_FILLED + " ")

fn userLocalCommandOutputHeader(children: text) -> text:
    val nl = children.find("\n")
    if nl < 0:
        return children.slice(2, children.len())
    children.slice(2, nl)

fn userLocalCommandOutputRest(children: text) -> text:
    val nl = children.find("\n")
    if nl < 0:
        return ""
    children.slice(nl + 1, children.len()).trim()

fn userLocalCommandOutputLabel(header: text) -> text:
    val sep = header.find(" · ")
    if sep < 0:
        return header
    header.slice(0, sep)

fn userLocalCommandOutputSuffix(header: text) -> text:
    val sep = header.find(" · ")
    if sep < 0:
        return ""
    header.slice(sep, header.len())

fn userLocalCommandOutputLine(key: text, raw: text) -> UserLocalCommandOutputLine:
    val children = raw.trim()
    if userLocalCommandOutputHasCloudPrefix(children):
        val header = userLocalCommandOutputHeader(children)
        return UserLocalCommandOutputLine.cloud(key, children, children.slice(0, 1), userLocalCommandOutputLabel(header), userLocalCommandOutputSuffix(header), userLocalCommandOutputRest(children))
    UserLocalCommandOutputLine.indented(key, children)

fn userLocalCommandOutputMessage(content: text) -> UserLocalCommandOutputRender:
    val stdout = extractTaggedValue(content, "local-command-stdout")
    val stderr = extractTaggedValue(content, "local-command-stderr")
    if stdout == "" and stderr == "":
        return UserLocalCommandOutputRender.emptyResponse()
    var lines: [UserLocalCommandOutputLine] = []
    val stdoutTrimmed = stdout.trim()
    if stdoutTrimmed != "":
        lines.push(userLocalCommandOutputLine("stdout", stdoutTrimmed))
    val stderrTrimmed = stderr.trim()
    if stderrTrimmed != "":
        lines.push(userLocalCommandOutputLine("stderr", stderrTrimmed))
    UserLocalCommandOutputRender.new(lines)

fn userLocalCommandOutputSummary(render: UserLocalCommandOutputRender) -> text:
    if render.empty:
        return render.empty_message
    var out = ""
    for line in render.lines:
        val body = if line.mode == "cloud-launch": line.diamond + " " + line.label + line.suffix + "|" + line.rest else: line.indent + line.text
        if out == "":
            out = line.key + ":" + body
        else:
            out = out + "\n" + line.key + ":" + body
    out

fn userLocalCommandOutputMessageSourceLinesModeled() -> i64:
    USER_LOCAL_COMMAND_OUTPUT_MESSAGE_SOURCE_LINES
