"""
Claude full DesktopHandoff parity.
"""

class DesktopHandoffState:
    available: bool
    connected: bool
    workspace: text
    reason: text

impl DesktopHandoffState:
    static fn new(available: bool, connected: bool, workspace: text, reason: text) -> DesktopHandoffState:
        DesktopHandoffState(available: available, connected: connected, workspace: workspace.trim(), reason: reason.trim())

fn desktopHandoffAvailable(state: DesktopHandoffState) -> bool:
    state.available

fn desktopHandoffEnabled(state: DesktopHandoffState) -> bool:
    state.available and state.connected

fn desktopHandoffTitle(state: DesktopHandoffState) -> text:
    if state.workspace == "":
        return "Open in desktop"
    "Open " + state.workspace + " in desktop"

fn desktopHandoffReason(state: DesktopHandoffState) -> text:
    if state.reason != "":
        return state.reason
    if not state.available:
        return "Desktop app unavailable"
    if not state.connected:
        return "Desktop app not connected"
    "Ready"

fn desktopHandoffActionLabel(state: DesktopHandoffState) -> text:
    if desktopHandoffEnabled(state):
        return "Hand off"
    "Unavailable"

fn desktopHandoffSummary(state: DesktopHandoffState) -> text:
    desktopHandoffTitle(state) + ": " + desktopHandoffReason(state)

fn desktopHandoffSourceLinesModeled() -> i64:
    192
