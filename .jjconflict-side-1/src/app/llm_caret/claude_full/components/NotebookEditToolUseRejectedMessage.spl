"""
Claude full NotebookEditToolUseRejectedMessage parity model.
"""

const NOTEBOOK_EDIT_TOOL_USE_REJECTED_SOURCE_LINES = 91

class NotebookEditToolUseRejectedMessageState:
    notebook_path: text
    cell_id: text
    new_source: text
    cell_type: text
    edit_mode: text
    verbose: bool
    cwd: text

impl NotebookEditToolUseRejectedMessageState:
    static fn new(notebookPath: text, cellId: text, newSource: text, cellType: text, editMode: text, verbose: bool, cwd: text) -> NotebookEditToolUseRejectedMessageState:
        NotebookEditToolUseRejectedMessageState(notebook_path: notebookPath, cell_id: cellId, new_source: newSource, cell_type: cellType, edit_mode: editMode, verbose: verbose, cwd: cwd)

fn notebookEditToolUseRejectedOperation(editMode: text) -> text:
    if editMode == "delete":
        "delete"
    else if editMode == "":
        "replace cell in"
    else:
        editMode + " cell in"

fn notebookEditToolUseRejectedDisplayPath(state: NotebookEditToolUseRejectedMessageState) -> text:
    if state.verbose:
        state.notebook_path
    else if state.cwd != "" and state.notebook_path.starts_with(state.cwd + "/"):
        state.notebook_path.substring(state.cwd.len() + 1, state.notebook_path.len())
    else:
        state.notebook_path

fn notebookEditToolUseRejectedCodePath(state: NotebookEditToolUseRejectedMessageState) -> text:
    if state.cell_type == "markdown":
        "file.md"
    else:
        "file.py"

fn notebookEditToolUseRejectedHeader(state: NotebookEditToolUseRejectedMessageState) -> text:
    "User rejected " + notebookEditToolUseRejectedOperation(state.edit_mode) + " " + notebookEditToolUseRejectedDisplayPath(state) + " at cell " + state.cell_id

fn notebookEditToolUseRejectedRenderSummary(state: NotebookEditToolUseRejectedMessageState) -> text:
    if state.edit_mode == "delete":
        notebookEditToolUseRejectedHeader(state)
    else:
        notebookEditToolUseRejectedHeader(state) + "\n" + notebookEditToolUseRejectedCodePath(state) + "\n" + state.new_source

fn notebookEditToolUseRejectedSourceLinesModeled() -> i64:
    NOTEBOOK_EDIT_TOOL_USE_REJECTED_SOURCE_LINES
