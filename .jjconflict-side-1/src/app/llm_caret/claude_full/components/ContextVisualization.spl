"""
Claude full ContextVisualization parity surface.
"""

class ContextCategory:
    name: text
    tokens: i64
    color: text
    isDeferred: bool

impl ContextCategory:
    static fn new(name: text, tokens: i64, color: text, isDeferred: bool) -> ContextCategory:
        ContextCategory(name: name, tokens: tokens, color: color, isDeferred: isDeferred)

class ContextGridSquare:
    categoryName: text
    color: text
    squareFullness: i64

impl ContextGridSquare:
    static fn new(categoryName: text, color: text, squareFullness: i64) -> ContextGridSquare:
        ContextGridSquare(categoryName: categoryName, color: color, squareFullness: squareFullness)

class SourceItem:
    name: text
    source: text
    tokens: i64

impl SourceItem:
    static fn new(name: text, source: text, tokens: i64) -> SourceItem:
        SourceItem(name: name, source: source, tokens: tokens)

class SourceGroup:
    sourceDisplay: text
    items: [SourceItem]

impl SourceGroup:
    static fn new(sourceDisplay: text, items: [SourceItem]) -> SourceGroup:
        SourceGroup(sourceDisplay: sourceDisplay, items: items)

class ContextTokenBucket:
    label: text
    tokens: i64
    percentTenths: i64
    status: text
    deferred: bool

impl ContextTokenBucket:
    static fn new(label: text, tokens: i64, percentTenths: i64, status: text, deferred: bool) -> ContextTokenBucket:
        ContextTokenBucket(label: label, tokens: tokens, percentTenths: percentTenths, status: status, deferred: deferred)

class CollapseStatusInput:
    enabled: bool
    collapsedSpans: i64
    collapsedMessages: i64
    stagedSpans: i64
    totalSpawns: i64
    totalErrors: i64
    lastError: text
    emptySpawnWarningEmitted: bool
    totalEmptySpawns: i64

impl CollapseStatusInput:
    static fn disabled() -> CollapseStatusInput:
        CollapseStatusInput(enabled: false, collapsedSpans: 0, collapsedMessages: 0, stagedSpans: 0, totalSpawns: 0, totalErrors: 0, lastError: "", emptySpawnWarningEmitted: false, totalEmptySpawns: 0)

    static fn emptyEnabled() -> CollapseStatusInput:
        CollapseStatusInput(enabled: true, collapsedSpans: 0, collapsedMessages: 0, stagedSpans: 0, totalSpawns: 0, totalErrors: 0, lastError: "", emptySpawnWarningEmitted: false, totalEmptySpawns: 0)

fn reservedCategoryName() -> text:
    "Autocompact buffer"

fn freeSpaceCategoryName() -> text:
    "Free space"

fn sourceDisplayOrder() -> [text]:
    ["Project", "User", "Managed", "Plugin", "Built-in"]

fn contextWarningPercent() -> i64:
    60

fn contextCriticalPercent() -> i64:
    80

fn contextTokenPercentTenths(tokens: i64, rawMaxTokens: i64) -> i64:
    if rawMaxTokens <= 0:
        return 0
    tokens * 1000 / rawMaxTokens

fn contextTokenPercentText(tokens: i64, rawMaxTokens: i64) -> text:
    val tenths = contextTokenPercentTenths(tokens, rawMaxTokens)
    (tenths / 10).to_text() + "." + (tenths % 10).to_text() + "%"

fn formatContextTokens(tokens: i64) -> text:
    if tokens >= 1000000:
        return (tokens / 1000000).to_text() + "M"
    if tokens >= 1000:
        val tenths = tokens / 100
        return (tenths / 10).to_text() + "." + (tenths % 10).to_text() + "k"
    tokens.to_text()

fn contextUsageStatus(percentage: i64) -> text:
    if percentage >= contextCriticalPercent():
        return "critical"
    if percentage >= contextWarningPercent():
        return "warning"
    "ok"

fn contextStatusLine(model: text, totalTokens: i64, rawMaxTokens: i64, percentage: i64) -> text:
    model + " · " + formatContextTokens(totalTokens) + "/" + formatContextTokens(rawMaxTokens) + " tokens (" + percentage.to_text() + "%)"

fn isVisibleContextCategory(cat: ContextCategory) -> bool:
    cat.tokens > 0 and cat.name != freeSpaceCategoryName() and cat.name != reservedCategoryName() and not cat.isDeferred

fn visibleContextCategories(categories: [ContextCategory]) -> [ContextCategory]:
    var out: [ContextCategory] = []
    var i = 0
    while i < categories.len():
        if isVisibleContextCategory(categories[i]):
            out.push(categories[i])
        i = i + 1
    out

fn hasDeferredMcpTools(categories: [ContextCategory]) -> bool:
    var i = 0
    while i < categories.len():
        val cat = categories[i]
        if cat.isDeferred and cat.name.contains("MCP"):
            return true
        i = i + 1
    false

fn contextCategorySymbol(cat: ContextCategory) -> text:
    if cat.isDeferred:
        return " "
    if cat.name == reservedCategoryName():
        return "reserved"
    if cat.name == freeSpaceCategoryName():
        return "free"
    "filled"

fn contextGridSymbol(square: ContextGridSquare) -> text:
    if square.categoryName == freeSpaceCategoryName():
        return "free"
    if square.categoryName == reservedCategoryName():
        return "reserved"
    if square.squareFullness >= 70:
        return "full"
    "partial"

fn contextCategoryLabel(cat: ContextCategory, rawMaxTokens: i64) -> text:
    val percent = if cat.isDeferred: "N/A" else: contextTokenPercentText(cat.tokens, rawMaxTokens)
    contextCategorySymbol(cat) + " " + cat.name + ": " + formatContextTokens(cat.tokens) + " tokens (" + percent + ")"

fn freeSpaceLabel(categories: [ContextCategory], rawMaxTokens: i64) -> text:
    var i = 0
    while i < categories.len():
        val cat = categories[i]
        if cat.name == freeSpaceCategoryName() and cat.tokens > 0:
            return "free " + freeSpaceCategoryName() + ": " + formatContextTokens(cat.tokens) + " (" + contextTokenPercentText(cat.tokens, rawMaxTokens) + ")"
        i = i + 1
    ""

fn autocompactLabel(categories: [ContextCategory], rawMaxTokens: i64) -> text:
    var i = 0
    while i < categories.len():
        val cat = categories[i]
        if cat.name == reservedCategoryName() and cat.tokens > 0:
            return "reserved " + cat.name + ": " + formatContextTokens(cat.tokens) + " tokens (" + contextTokenPercentText(cat.tokens, rawMaxTokens) + ")"
        i = i + 1
    ""

fn contextTokenBuckets(categories: [ContextCategory], rawMaxTokens: i64) -> [ContextTokenBucket]:
    var out: [ContextTokenBucket] = []
    var i = 0
    while i < categories.len():
        val cat = categories[i]
        val pct = contextTokenPercentTenths(cat.tokens, rawMaxTokens)
        val status = contextUsageStatus(pct / 10)
        out.push(ContextTokenBucket.new(cat.name, cat.tokens, pct, status, cat.isDeferred))
        i = i + 1
    out

fn getSourceDisplayName(source: text) -> text:
    if source == "project":
        return "Project"
    if source == "user":
        return "User"
    if source == "managed":
        return "Managed"
    if source == "plugin":
        return "Plugin"
    if source == "built-in" or source == "builtin":
        return "Built-in"
    source

fn copySourceItems(items: [SourceItem]) -> [SourceItem]:
    var out: [SourceItem] = []
    var i = 0
    while i < items.len():
        out.push(items[i])
        i = i + 1
    out

fn sortSourceItemsByTokensDesc(items: [SourceItem]) -> [SourceItem]:
    var out = copySourceItems(items)
    var i = 0
    while i < out.len():
        var j = i + 1
        while j < out.len():
            if out[j].tokens > out[i].tokens:
                val tmp = out[i]
                out[i] = out[j]
                out[j] = tmp
            j = j + 1
        i = i + 1
    out

fn sourceGroupItemsForDisplay(items: [SourceItem], display: text) -> [SourceItem]:
    var group: [SourceItem] = []
    var i = 0
    while i < items.len():
        val item = items[i]
        if getSourceDisplayName(item.source) == display:
            group.push(item)
        i = i + 1
    sortSourceItemsByTokensDesc(group)

fn groupBySource(items: [SourceItem]) -> [SourceGroup]:
    val order = sourceDisplayOrder()
    var groups: [SourceGroup] = []
    var i = 0
    while i < order.len():
        val group = sourceGroupItemsForDisplay(items, order[i])
        if group.len() > 0:
            groups.push(SourceGroup.new(order[i], group))
        i = i + 1
    groups

fn plural(count: i64, word: text) -> text:
    if count == 1:
        return word
    word + "s"

fn collapseStatusSummary(input: CollapseStatusInput) -> text:
    if not input.enabled:
        return ""
    var parts: [text] = []
    if input.collapsedSpans > 0:
        parts.push(input.collapsedSpans.to_text() + " " + plural(input.collapsedSpans, "span") + " summarized (" + input.collapsedMessages.to_text() + " msgs)")
    if input.stagedSpans > 0:
        parts.push(input.stagedSpans.to_text() + " staged")
    if parts.len() == 2:
        return parts[0] + ", " + parts[1]
    if parts.len() == 1:
        return parts[0]
    if input.totalSpawns > 0:
        return input.totalSpawns.to_text() + " " + plural(input.totalSpawns, "spawn") + ", nothing staged yet"
    "waiting for first trigger"

fn truncateText(value: text, maxLen: i64) -> text:
    if value.len() <= maxLen:
        return value
    value.slice(0, maxLen)

fn collapseStatusWarning(input: CollapseStatusInput) -> text:
    if not input.enabled:
        return ""
    if input.totalErrors > 0:
        val suffix = if input.lastError != "": " (last: " + truncateText(input.lastError, 60) + ")" else: ""
        return "Collapse errors: " + input.totalErrors.to_text() + "/" + input.totalSpawns.to_text() + " spawns failed" + suffix
    if input.emptySpawnWarningEmitted:
        return "Collapse idle: " + input.totalEmptySpawns.to_text() + " consecutive empty runs"
    ""

fn collapseStatusLine(input: CollapseStatusInput) -> text:
    val summary = collapseStatusSummary(input)
    if summary == "":
        return ""
    "Context strategy: collapse (" + summary + ")"

fn sourceSummaryLine(title: text, command: text, items: [SourceItem]) -> text:
    title + " · " + command + " · " + items.len().to_text() + " " + plural(items.len(), "source")

fn renderSourceGroups(items: [SourceItem]) -> [text]:
    val groups = groupBySource(items)
    var lines: [text] = []
    var i = 0
    while i < groups.len():
        val group = groups[i]
        lines.push(group.sourceDisplay)
        var j = 0
        while j < group.items.len():
            val item = group.items[j]
            lines.push("└ " + item.name + ": " + formatContextTokens(item.tokens) + " tokens")
            j = j + 1
        i = i + 1
    lines

fn renderContextLegend(categories: [ContextCategory], rawMaxTokens: i64) -> [text]:
    val visible = visibleContextCategories(categories)
    var lines: [text] = []
    lines.push("Estimated usage by category")
    var i = 0
    while i < visible.len():
        lines.push(contextCategoryLabel(visible[i], rawMaxTokens))
        i = i + 1
    val freeLabel = freeSpaceLabel(categories, rawMaxTokens)
    if freeLabel != "":
        lines.push(freeLabel)
    val compactLabel = autocompactLabel(categories, rawMaxTokens)
    if compactLabel != "":
        lines.push(compactLabel)
    lines

fn renderContextVisualization(model: text, totalTokens: i64, rawMaxTokens: i64, percentage: i64, categories: [ContextCategory], collapse: CollapseStatusInput) -> [text]:
    var lines: [text] = []
    lines.push("Context Usage")
    lines.push(contextStatusLine(model, totalTokens, rawMaxTokens, percentage))
    val collapseLine = collapseStatusLine(collapse)
    if collapseLine != "":
        lines.push(collapseLine)
    val warning = collapseStatusWarning(collapse)
    if warning != "":
        lines.push(warning)
    val legend = renderContextLegend(categories, rawMaxTokens)
    var i = 0
    while i < legend.len():
        lines.push(legend[i])
        i = i + 1
    lines

fn contextVisualizationSourceLinesModeled() -> i64:
    488
