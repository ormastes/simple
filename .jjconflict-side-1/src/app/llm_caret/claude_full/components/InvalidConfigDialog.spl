"""
Claude full InvalidConfigDialog parity.
"""

class InvalidConfigState:
    open: bool
    config_path: text
    message: text
    recoverable: bool

impl InvalidConfigState:
    static fn new(open: bool, configPath: text, message: text, recoverable: bool) -> InvalidConfigState:
        InvalidConfigState(open: open, config_path: configPath.trim(), message: message.trim(), recoverable: recoverable)

fn invalidConfigTitle(state: InvalidConfigState) -> text:
    if state.config_path == "":
        return "Invalid configuration"
    "Invalid configuration " + state.config_path

fn invalidConfigMessage(state: InvalidConfigState) -> text:
    if state.message == "":
        return "Configuration could not be parsed"
    state.message

fn invalidConfigAction(state: InvalidConfigState) -> text:
    if state.recoverable:
        return "Open config"
    "Dismiss"

fn invalidConfigSummary(state: InvalidConfigState) -> text:
    invalidConfigTitle(state) + ": " + invalidConfigMessage(state)

fn invalidConfigDialogSourceLinesModeled() -> i64:
    155
