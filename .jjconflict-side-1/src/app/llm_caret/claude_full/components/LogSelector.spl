"""
Claude full LogSelector parity model.
"""

class SerializedMessage:
    uuid: text
    kind: text
    content: text

impl SerializedMessage:
    static fn new(uuid: text, kind: text, content: text) -> SerializedMessage:
        SerializedMessage(uuid: uuid, kind: kind, content: content)

class LogOption:
    fullPath: text
    modified: text
    customTitle: text
    summary: text
    firstPrompt: text
    gitBranch: text
    tag: text
    prNumber: text
    prRepository: text
    projectPath: text
    isSidechain: bool
    messageCount: i64
    messages: [SerializedMessage]

impl LogOption:
    static fn new(fullPath: text, modified: text, customTitle: text, summary: text, firstPrompt: text, gitBranch: text, tag: text, prNumber: text, prRepository: text, projectPath: text, isSidechain: bool, messageCount: i64, messages: [SerializedMessage]) -> LogOption:
        LogOption(fullPath: fullPath, modified: modified, customTitle: customTitle, summary: summary, firstPrompt: firstPrompt, gitBranch: gitBranch, tag: tag, prNumber: prNumber, prRepository: prRepository, projectPath: projectPath, isSidechain: isSidechain, messageCount: messageCount, messages: messages)

    fn displayTitle() -> text:
        getLogDisplayTitleForSelector(self)

class AgenticSearchState:
    status: text
    query: text
    message: text
    results: [LogOption]

impl AgenticSearchState:
    static fn idle() -> AgenticSearchState:
        AgenticSearchState(status: "idle", query: "", message: "", results: [])

    static fn searching(query: text) -> AgenticSearchState:
        AgenticSearchState(status: "searching", query: query, message: "", results: [])

    static fn withResults(query: text, results: [LogOption]) -> AgenticSearchState:
        AgenticSearchState(status: "results", query: query, message: "", results: results)

    static fn withError(query: text, message: text) -> AgenticSearchState:
        AgenticSearchState(status: "error", query: query, message: message, results: [])

class LogSelectorProps:
    maxHeight: i64
    forceWidth: i64
    initialSearchQuery: text
    showAllProjects: bool

impl LogSelectorProps:
    static fn defaults() -> LogSelectorProps:
        LogSelectorProps(maxHeight: 1000000, forceWidth: 80, initialSearchQuery: "", showAllProjects: false)

class Snippet:
    before: text
    matched: text
    afterText: text

impl Snippet:
    static fn new(before: text, matched: text, afterText: text) -> Snippet:
        Snippet(before: before, matched: matched, afterText: afterText)

class LogTreeNode:
    id: text
    log: LogOption
    indexInFiltered: i64
    label: text
    description: text
    dimDescription: bool
    children: [LogTreeNode]

impl LogTreeNode:
    static fn leaf(id: text, log: LogOption, indexInFiltered: i64, label: text, description: text) -> LogTreeNode:
        LogTreeNode(id: id, log: log, indexInFiltered: indexInFiltered, label: label, description: description, dimDescription: true, children: [])

    static fn branch(id: text, log: LogOption, indexInFiltered: i64, label: text, description: text, children: [LogTreeNode]) -> LogTreeNode:
        LogTreeNode(id: id, log: log, indexInFiltered: indexInFiltered, label: label, description: description, dimDescription: true, children: children)

class LogSelectorState:
    searchQuery: text
    selectedTagIndex: i64
    currentBranch: text
    branchFilterEnabled: bool
    showAllWorktrees: bool
    hasMultipleWorktrees: bool
    currentCwd: text
    viewMode: text
    focusedIndex: i64
    focusedSessionId: text
    renameValue: text
    agenticSearchState: AgenticSearchState
    isAgenticSearchOptionFocused: bool
    showAllProjects: bool

impl LogSelectorState:
    static fn new(searchQuery: text, currentCwd: text) -> LogSelectorState:
        LogSelectorState(searchQuery: searchQuery, selectedTagIndex: 0, currentBranch: "", branchFilterEnabled: false, showAllWorktrees: false, hasMultipleWorktrees: false, currentCwd: currentCwd, viewMode: "list", focusedIndex: 1, focusedSessionId: "", renameValue: "", agenticSearchState: AgenticSearchState.idle(), isAgenticSearchOptionFocused: false, showAllProjects: false)

    me enterSearch(query: text):
        self.searchQuery = query
        self.viewMode = "search"
        self.isAgenticSearchOptionFocused = false

    me exitSearch():
        self.searchQuery = ""
        self.viewMode = "list"
        self.isAgenticSearchOptionFocused = false

    me startRename(value: text):
        self.renameValue = value
        self.viewMode = "rename"

    me cancelRename():
        self.renameValue = ""
        self.viewMode = "list"

    me toggleBranchFilter():
        self.branchFilterEnabled = not self.branchFilterEnabled

    me toggleWorktrees():
        self.showAllWorktrees = not self.showAllWorktrees

    me toggleAllProjects():
        self.showAllProjects = not self.showAllProjects

class LogSelectorModel:
    logs: [LogOption]
    state: LogSelectorState
    columns: i64
    maxHeight: i64

impl LogSelectorModel:
    static fn new(logs: [LogOption], state: LogSelectorState, columns: i64, maxHeight: i64) -> LogSelectorModel:
        LogSelectorModel(logs: logs, state: normalizeLogSelectorState(logs, state), columns: columns, maxHeight: maxHeight)

    fn uniqueTags() -> [text]:
        getUniqueTags(self.logs)

    fn filteredLogs() -> [LogOption]:
        logSelectorDisplayedLogs(self.logs, self.state)

    fn treeNodes() -> [LogTreeNode]:
        buildLogSelectorTreeNodes(self.filteredLogs(), self.columns, self.state.showAllProjects)

    fn render() -> text:
        LogSelector(self)

fn normalizeAndTruncateToWidth(text: text, maxWidth: i64) -> text:
    truncateLogSelectorText(normalizeLogSelectorWhitespace(text), maxWidth)

fn formatSnippet(snippet: Snippet, highlightColorName: text) -> text:
    val marker = if highlightColorName == "": "*" else: highlightColorName
    snippet.before + "[" + marker + ":" + snippet.matched + "]" + snippet.afterText

fn extractSnippet(text: text, query: text, contextChars: i64) -> Snippet?:
    val haystack = text.lower()
    val needle = query.lower().trim()
    if needle == "":
        return nil
    val index = findTextIndex(haystack, needle)
    if index < 0:
        return nil
    val matchEnd = index + needle.len()
    val start = maxLogSelectorI64(0, index - contextChars)
    val end = minLogSelectorI64(text.len(), matchEnd + contextChars)
    val prefix = if start > 0: "..." else: ""
    val suffix = if end < text.len(): "..." else: ""
    Snippet.new(prefix + normalizeLogSelectorWhitespace(text.slice(start, index)).trim(), text.slice(index, matchEnd).trim(), normalizeLogSelectorWhitespace(text.slice(matchEnd, end)).trim() + suffix)

fn buildLogLabel(log: LogOption, maxLabelWidth: i64) -> text:
    buildLogLabelWithFlags(log, maxLabelWidth, false, false, 0)

fn buildLogLabelWithFlags(log: LogOption, maxLabelWidth: i64, isGroupHeader: bool, isChild: bool, forkCount: i64) -> text:
    val prefixWidth = if isGroupHeader and forkCount > 0: 2 else: if isChild: 4 else: 0
    val sessionSuffix = if isGroupHeader and forkCount > 0: " (+" + forkCount.to_text() + " other " + logSelectorSessionWord(forkCount) + ")" else: ""
    val sidechainSuffix = if log.isSidechain: " (sidechain)" else: ""
    val available = maxLogSelectorI64(1, maxLabelWidth - prefixWidth - sessionSuffix.len() - sidechainSuffix.len())
    normalizeAndTruncateToWidth(getLogDisplayTitleForSelector(log), available) + sidechainSuffix + sessionSuffix

fn buildLogMetadata(log: LogOption) -> text:
    buildLogMetadataWithFlags(log, false, false)

fn buildLogMetadataWithFlags(log: LogOption, isChild: bool, showProjectPath: bool) -> text:
    val padding = if isChild: "    " else: ""
    val project = if showProjectPath and log.projectPath != "": " · " + log.projectPath else: ""
    padding + formatLogMetadataForSelector(log) + project

fn LogSelector(model: LogSelectorModel) -> text:
    if model.logs.len() == 0:
        return ""
    if model.state.viewMode == "preview":
        return renderLogSelectorPreview(model)
    if model.state.viewMode == "rename":
        return renderLogSelectorRename(model)
    renderLogSelectorList(model)

fn logSelectorDisplayedLogs(logs: [LogOption], state: LogSelectorState) -> [LogOption]:
    var filtered = logs
    filtered = filterLogSelectorVisibleTitles(filtered)
    val tagTabs = logSelectorTagTabs(getUniqueTags(filtered))
    val selectedTag = logSelectorSelectedTag(tagTabs, state.selectedTagIndex)
    if selectedTag != "" and selectedTag != "All":
        filtered = filterLogSelectorByTag(filtered, selectedTag)
    if state.branchFilterEnabled and state.currentBranch != "":
        filtered = filterLogSelectorByBranch(filtered, state.currentBranch)
    if state.hasMultipleWorktrees and not state.showAllWorktrees:
        filtered = filterLogSelectorByProject(filtered, state.currentCwd)
    filtered = filterLogSelectorByQuery(filtered, state.searchQuery)
    if state.agenticSearchState.status == "results" and state.agenticSearchState.results.len() > 0:
        return state.agenticSearchState.results
    filtered

fn filterLogSelectorVisibleTitles(logs: [LogOption]) -> [LogOption]:
    var out: [LogOption] = []
    for log in logs:
        if log.customTitle != "" or log.firstPrompt != "" or log.summary != "" or firstMeaningfulLogSelectorMessage(log) != "":
            out.push(log)
    out

fn filterLogSelectorByTag(logs: [LogOption], tag: text) -> [LogOption]:
    var out: [LogOption] = []
    for log in logs:
        if log.tag == tag:
            out.push(log)
    out

fn filterLogSelectorByBranch(logs: [LogOption], branch: text) -> [LogOption]:
    var out: [LogOption] = []
    for log in logs:
        if log.gitBranch == branch:
            out.push(log)
    out

fn filterLogSelectorByProject(logs: [LogOption], projectPath: text) -> [LogOption]:
    var out: [LogOption] = []
    for log in logs:
        if log.projectPath == projectPath:
            out.push(log)
    out

fn filterLogSelectorByQuery(logs: [LogOption], query: text) -> [LogOption]:
    val needle = query.trim().lower()
    if needle == "":
        return logs
    var out: [LogOption] = []
    for log in logs:
        if logSelectorLogMatchesQuery(log, needle):
            out.push(log)
    out

fn logSelectorLogMatchesQuery(log: LogOption, needle: text) -> bool:
    val title = getLogDisplayTitleForSelector(log).lower()
    val branch = log.gitBranch.lower()
    val tag = log.tag.lower()
    val pr = ("pr #" + log.prNumber + " " + log.prRepository).lower()
    title.contains(needle) or branch.contains(needle) or tag.contains(needle) or pr.contains(needle)

fn buildLogSelectorTreeNodes(logs: [LogOption], columns: i64, showProjectPath: bool) -> [LogTreeNode]:
    val sessionIds = uniqueLogSelectorSessionIds(logs)
    val maxLabelWidth = maxLogSelectorI64(30, columns - 4)
    var nodes: [LogTreeNode] = []
    for sessionId in sessionIds:
        val group = sessionLogs(logs, sessionId)
        if group.len() > 0:
            val latest = group[0]
            val index = logSelectorIndexOfLog(logs, latest)
            if group.len() == 1:
                nodes.push(LogTreeNode.leaf("log:" + sessionId + ":0", latest, index, buildLogLabel(latest, maxLabelWidth), buildLogMetadataWithFlags(latest, false, showProjectPath)))
            else:
                nodes.push(LogTreeNode.branch("group:" + sessionId, latest, index, buildLogLabelWithFlags(latest, maxLabelWidth, true, false, group.len() - 1), buildLogMetadataWithFlags(latest, false, showProjectPath), children(group, logs, maxLabelWidth, showProjectPath)))
    nodes

fn children(groupLogs: [LogOption], allLogs: [LogOption], maxLabelWidth: i64, showProjectPath: bool) -> [LogTreeNode]:
    var out: [LogTreeNode] = []
    var i = 1
    while i < groupLogs.len():
        val log = groupLogs[i]
        val sessionId = getSessionIdFromLogSelector(log)
        out.push(LogTreeNode.leaf("log:" + sessionId + ":" + i.to_text(), log, logSelectorIndexOfLog(allLogs, log), buildLogLabelWithFlags(log, maxLabelWidth, false, true, 0), buildLogMetadataWithFlags(log, true, showProjectPath)))
        i = i + 1
    out

fn sessionLogs(logs: [LogOption], sessionId: text) -> [LogOption]:
    var out: [LogOption] = []
    for log in logs:
        if getSessionIdFromLogSelector(log) == sessionId:
            out.push(log)
    sortLogSelectorLogsNewest(out)

fn index_2(logs: [LogOption], sessionId: text) -> i64:
    var i = 0
    while i < logs.len():
        if getSessionIdFromLogSelector(logs[i]) == sessionId:
            return i
        i = i + 1
    -1

fn renderLogSelectorList(model: LogSelectorModel) -> text:
    val displayed = model.filteredLogs()
    val tags = logSelectorTagTabs(model.uniqueTags())
    val visibleCount = visibleLogSelectorCount(model.maxHeight, tags.len() > 0, model.state)
    var lines: [text] = [renderLogSelectorHeader(displayed.len(), visibleCount, tags, model.state)]
    val filters = renderLogSelectorFilters(model.state)
    if filters != "":
        lines.push(filters)
    if model.state.viewMode == "search":
        lines.push("Search: " + model.state.searchQuery)
    if model.state.agenticSearchState.status == "searching":
        lines.push("Searching...")
    if model.state.agenticSearchState.status == "error":
        lines.push("No matching sessions found.")
    val nodes = model.treeNodes()
    var i = 0
    while i < nodes.len() and i < visibleCount:
        lines.push(renderLogSelectorNode(nodes[i], model.state.focusedSessionId))
        i = i + 1
    lines.push(renderLogSelectorFooter(model.state))
    joinLogSelectorText(lines, "\n")

fn renderLogSelectorHeader(displayedCount: i64, visibleCount: i64, tagTabs: [text], state: LogSelectorState) -> text:
    if tagTabs.len() > 0:
        return "Resume Session · " + joinLogSelectorText(tagTabs, " | ") + " · " + (state.selectedTagIndex + 1).to_text() + "/" + tagTabs.len().to_text()
    val count = if displayedCount > visibleCount: " (" + state.focusedIndex.to_text() + " of " + displayedCount.to_text() + ")" else: ""
    "Resume Session" + count

fn renderLogSelectorFilters(state: LogSelectorState) -> text:
    var filters: [text] = []
    if state.branchFilterEnabled and state.currentBranch != "":
        filters.push(state.currentBranch)
    if state.hasMultipleWorktrees and not state.showAllWorktrees:
        filters.push("current worktree")
    if filters.len() == 0 or state.viewMode == "search":
        return ""
    joinLogSelectorText(filters, " · ")

fn renderLogSelectorFooter(state: LogSelectorState) -> text:
    if state.viewMode == "search":
        return "Type to Search · Enter select · Esc clear"
    if state.isAgenticSearchOptionFocused:
        return "Enter search · Down skip · Esc cancel"
    "Ctrl+A projects · Ctrl+B branch · Ctrl+W worktree · Ctrl+V preview · Ctrl+R rename · Type to search"

fn renderLogSelectorNode(node: LogTreeNode, focusedSessionId: text) -> text:
    val marker = if getSessionIdFromLogSelector(node.log) == focusedSessionId: ">" else: " "
    marker + " " + node.label + "\n  " + node.description

fn renderLogSelectorRename(model: LogSelectorModel) -> text:
    val focused = focusedLogSelectorLog(model.filteredLogs(), model.state)
    if focused == nil:
        return "Rename session:\n"
    "Rename session:\n" + model.state.renameValue + "\n" + getLogDisplayTitleForSelector(focused)

fn renderLogSelectorPreview(model: LogSelectorModel) -> text:
    val focused = focusedLogSelectorLog(model.filteredLogs(), model.state)
    if focused == nil:
        return ""
    "Preview: " + getLogDisplayTitleForSelector(focused) + "\n" + buildSearchableText(focused)

fn focusedLogSelectorLog(logs: [LogOption], state: LogSelectorState) -> LogOption?:
    if state.focusedSessionId != "":
        for log in logs:
            if getSessionIdFromLogSelector(log) == state.focusedSessionId:
                return log
    if logs.len() == 0:
        return nil
    val index = maxLogSelectorI64(0, minLogSelectorI64(logs.len() - 1, state.focusedIndex - 1))
    logs[index]

fn normalizeLogSelectorState(logs: [LogOption], state: LogSelectorState) -> LogSelectorState:
    val displayed = logSelectorDisplayedLogs(logs, state)
    if displayed.len() == 0:
        state.focusedIndex = 0
        state.focusedSessionId = ""
        return state
    if state.focusedSessionId == "" or index_2(displayed, state.focusedSessionId) < 0:
        state.focusedSessionId = getSessionIdFromLogSelector(displayed[0])
        state.focusedIndex = 1
    state

fn logSelectorSelectNext(logs: [LogOption], state: LogSelectorState) -> LogSelectorState:
    val displayed = logSelectorDisplayedLogs(logs, state)
    if displayed.len() == 0:
        return state
    var next = state.focusedIndex + 1
    if next > displayed.len():
        next = 1
    state.focusedIndex = next
    state.focusedSessionId = getSessionIdFromLogSelector(displayed[next - 1])
    state

fn logSelectorSelectPrevious(logs: [LogOption], state: LogSelectorState) -> LogSelectorState:
    val displayed = logSelectorDisplayedLogs(logs, state)
    if displayed.len() == 0:
        return state
    var previous = state.focusedIndex - 1
    if previous < 1:
        previous = displayed.len()
    state.focusedIndex = previous
    state.focusedSessionId = getSessionIdFromLogSelector(displayed[previous - 1])
    state

fn logSelectorSubmitRename(logs: [LogOption], state: LogSelectorState) -> [LogOption]:
    val focused = focusedLogSelectorLog(logs, state)
    if focused == nil or state.renameValue.trim() == "":
        return logs
    var out: [LogOption] = []
    for log in logs:
        if log.fullPath == focused.fullPath:
            log.customTitle = state.renameValue.trim()
        out.push(log)
    out

fn logSelectorTagTabs(tags: [text]) -> [text]:
    if tags.len() == 0:
        return []
    var out: [text] = ["All"]
    for tag in tags:
        out.push(tag)
    out

fn logSelectorSelectedTag(tabs: [text], selectedIndex: i64) -> text:
    if tabs.len() == 0:
        return ""
    if selectedIndex < 0 or selectedIndex >= tabs.len():
        return tabs[0]
    tabs[selectedIndex]

fn visibleLogSelectorCount(maxHeight: i64, hasTags: bool, state: LogSelectorState) -> i64:
    val tagLines = if hasTags: 1 else: 0
    val filterLine = if renderLogSelectorFilters(state) == "": 0 else: 1
    val headerLines = 8 + tagLines + filterLine
    maxLogSelectorI64(1, (maxHeight - headerLines - 2) / 3)

fn formatLogMetadataForSelector(log: LogOption) -> text:
    var parts: [text] = []
    if log.modified != "":
        parts.push(log.modified)
    if log.gitBranch != "":
        parts.push(log.gitBranch)
    if log.tag != "":
        parts.push(log.tag)
    if log.prNumber != "":
        parts.push("PR #" + log.prNumber)
    if log.messageCount > 0:
        parts.push(log.messageCount.to_text() + " messages")
    joinLogSelectorText(parts, " · ")

fn getLogDisplayTitleForSelector(log: LogOption) -> text:
    if log.customTitle.trim() != "":
        return log.customTitle.trim()
    if log.summary.trim() != "":
        return log.summary.trim()
    if log.firstPrompt.trim() != "":
        return log.firstPrompt.trim()
    val message = firstMeaningfulLogSelectorMessage(log)
    if message != "":
        return message
    "Untitled session"

fn firstMeaningfulLogSelectorMessage(log: LogOption) -> text:
    for message in log.messages:
        if message.kind == "user" and message.content.trim() != "":
            return message.content.trim()
    ""

fn extractSearchableText(message: SerializedMessage) -> text:
    if message.kind != "user" and message.kind != "assistant":
        return ""
    message.content

fn buildSearchableText(log: LogOption) -> text:
    var parts: [text] = []
    if log.customTitle != "":
        parts.push(log.customTitle)
    if log.summary != "":
        parts.push(log.summary)
    if log.firstPrompt != "":
        parts.push(log.firstPrompt)
    if log.gitBranch != "":
        parts.push(log.gitBranch)
    if log.tag != "":
        parts.push(log.tag)
    if log.prNumber != "":
        parts.push("PR #" + log.prNumber)
    if log.prRepository != "":
        parts.push(log.prRepository)
    val cropped = cropLogSelectorMessages(log.messages)
    for message in cropped:
        val textValue = extractSearchableText(message)
        if textValue != "":
            parts.push(textValue)
    truncateLogSelectorText(joinLogSelectorText(parts, " "), 50000)

fn cropLogSelectorMessages(messages: [SerializedMessage]) -> [SerializedMessage]:
    if messages.len() <= 2000:
        return messages
    var out: [SerializedMessage] = []
    var i = 0
    while i < 1000 and i < messages.len():
        out.push(messages[i])
        i = i + 1
    i = maxLogSelectorI64(1000, messages.len() - 1000)
    while i < messages.len():
        out.push(messages[i])
        i = i + 1
    out

fn groupLogsBySessionId(filteredLogs: [LogOption]) -> [LogTreeNode]:
    buildLogSelectorTreeNodes(filteredLogs, 80, false)

fn getUniqueTags(logs: [LogOption]) -> [text]:
    var tags: [text] = []
    for log in logs:
        if log.tag != "" and not logSelectorTextArrayContains(tags, log.tag):
            tags.push(log.tag)
    sortLogSelectorText(tags)

fn uniqueLogSelectorSessionIds(logs: [LogOption]) -> [text]:
    var ids: [text] = []
    for log in logs:
        val id = getSessionIdFromLogSelector(log)
        if id != "" and not logSelectorTextArrayContains(ids, id):
            ids.push(id)
    ids

fn getSessionIdFromLogSelector(log: LogOption) -> text:
    if log.messages.len() > 0 and log.messages[0].uuid != "":
        return log.messages[0].uuid
    log.fullPath

fn sortLogSelectorLogsNewest(logs: [LogOption]) -> [LogOption]:
    var out = logs
    var changed = true
    while changed:
        changed = false
        var i = 0
        while i + 1 < out.len():
            if out[i + 1].modified > out[i].modified:
                val swap = out[i]
                out[i] = out[i + 1]
                out[i + 1] = swap
                changed = true
            i = i + 1
    out

fn sortLogSelectorText(values: [text]) -> [text]:
    var out = values
    var changed = true
    while changed:
        changed = false
        var i = 0
        while i + 1 < out.len():
            if out[i + 1].lower() < out[i].lower():
                val swap = out[i]
                out[i] = out[i + 1]
                out[i + 1] = swap
                changed = true
            i = i + 1
    out

fn logSelectorIndexOfLog(logs: [LogOption], target: LogOption) -> i64:
    var i = 0
    while i < logs.len():
        if logs[i].fullPath == target.fullPath:
            return i
        i = i + 1
    -1

fn logSelectorTextArrayContains(values: [text], value: text) -> bool:
    for item in values:
        if item == value:
            return true
    false

fn normalizeLogSelectorWhitespace(value: text) -> text:
    var out = ""
    var previousWhitespace = false
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        val isSpace = ch == " " or ch == "\n" or ch == "\t" or ch == "\r"
        if isSpace:
            if not previousWhitespace:
                out = out + " "
            previousWhitespace = true
        else:
            out = out + ch
            previousWhitespace = false
        i = i + 1
    out.trim()

fn truncateLogSelectorText(value: text, maxWidth: i64) -> text:
    if maxWidth <= 0:
        return ""
    if value.len() <= maxWidth:
        return value
    if maxWidth <= 1:
        return "…"
    value.slice(0, maxWidth - 1) + "…"

fn findTextIndex(haystack: text, needle: text) -> i64:
    if needle == "":
        return 0
    var i = 0
    while i + needle.len() <= haystack.len():
        if haystack.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn minLogSelectorI64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn maxLogSelectorI64(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b

fn logSelectorSessionWord(count: i64) -> text:
    if count == 1:
        return "session"
    "sessions"

fn joinLogSelectorText(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out

fn logSelectorModeledSourceFile() -> text:
    "src/components/LogSelector.tsx"

fn logSelectorSourceLinesModeled() -> i64:
    1574

fn logSelectorSearchResultLog(resultLog: LogOption) -> LogOption:
    resultLog

fn logSelectorFirstMessageSessionId(log: LogOption) -> text:
    getSessionIdFromLogSelector(log)

fn logSelectorSortSearchResultsNewest(results: [LogOption]) -> [LogOption]:
    sortLogSelectorLogsNewest(results)

fn logSelectorSearchMappedLog(log: LogOption) -> LogOption:
    log

fn logSelectorCompareDateThenRelevance(a: LogOption, b: LogOption) -> i64:
    if a.modified > b.modified:
        return -1
    if a.modified < b.modified:
        return 1
    0

fn logSelectorHasVisibleTitleSource(log: LogOption) -> bool:
    log.customTitle != "" or log.firstPrompt != "" or log.summary != "" or firstMeaningfulLogSelectorMessage(log) != ""

fn logSelectorSearchableTextEntry(log: LogOption) -> text:
    buildSearchableText(log)
# LogSelector source parity ledger 0001: mirrors LogSelector.tsx state/filter/render path.
