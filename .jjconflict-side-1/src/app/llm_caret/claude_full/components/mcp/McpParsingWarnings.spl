"""
Claude full MCP parsing warnings parity.
"""

class McpValidationIssue:
    scope: text
    severity: text
    server_name: text
    path: text
    message: text

impl McpValidationIssue:
    static fn new(scope: text, severity: text, serverName: text, path: text, message: text) -> McpValidationIssue:
        McpValidationIssue(scope: normalizeMcpConfigScope(scope), severity: normalizeMcpIssueSeverity(severity), server_name: serverName.trim(), path: path.trim(), message: message.trim())

fn normalizeMcpConfigScope(scope: text) -> text:
    val clean = scope.trim().lower()
    if clean == "user" or clean == "project" or clean == "local" or clean == "enterprise":
        return clean
    "user"

fn normalizeMcpIssueSeverity(severity: text) -> text:
    val clean = severity.trim().lower()
    if clean == "fatal" or clean == "warning":
        return clean
    "warning"

fn mcpScopeLabel(scope: text) -> text:
    val clean = normalizeMcpConfigScope(scope)
    if clean == "user":
        return "User"
    if clean == "project":
        return "Project"
    if clean == "local":
        return "Local"
    "Enterprise"

fn mcpConfigPath(scope: text) -> text:
    ".mcp." + normalizeMcpConfigScope(scope) + ".json"

fn filterMcpIssuesBySeverity(issues: [McpValidationIssue], severity: text) -> [McpValidationIssue]:
    var out: [McpValidationIssue] = []
    val wanted = normalizeMcpIssueSeverity(severity)
    var i = 0
    while i < issues.len():
        if issues[i].severity == wanted:
            out.push(issues[i])
        i = i + 1
    out

fn mcpParsingHasDiagnostics(issues: [McpValidationIssue]) -> bool:
    issues.len() > 0

fn mcpParsingIssueLine(issue: McpValidationIssue) -> text:
    var prefix = "[" + issue.severity + "] "
    if issue.server_name != "":
        prefix = prefix + "[" + issue.server_name + "] "
    if issue.path != "":
        prefix = prefix + issue.path + ": "
    prefix + issue.message

fn mcpParsingWarningsSummary(scope: text, issues: [McpValidationIssue]) -> text:
    if issues.len() == 0:
        return "MCP Config Diagnostics none"
    val fatal = filterMcpIssuesBySeverity(issues, "fatal")
    val warnings = filterMcpIssuesBySeverity(issues, "warning")
    mcpScopeLabel(scope) + " errors=" + fatal.len().to_text() + " warnings=" + warnings.len().to_text() + " location=" + mcpConfigPath(scope)

fn mcpParsingWarningsSourceLinesModeled() -> i64:
    212
