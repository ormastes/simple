class PrBadgeView:
    text: text
    url: text
    fallbackLabel: text
    linkBody: text
    statusColor: text
    dimPrLabel: bool
    dimNumber: bool
    bold: bool
    underline: bool

impl PrBadgeView:
    static fn new(text: text, url: text, fallbackLabel: text, linkBody: text, statusColor: text, dimPrLabel: bool, dimNumber: bool, bold: bool, underline: bool) -> PrBadgeView:
        PrBadgeView(text: text, url: url, fallbackLabel: fallbackLabel, linkBody: linkBody, statusColor: statusColor, dimPrLabel: dimPrLabel, dimNumber: dimNumber, bold: bold, underline: underline)

fn prStatusColorRoute(reviewState: text) -> text:
    if reviewState == "approved":
        return "success"
    if reviewState == "changes_requested":
        return "error"
    if reviewState == "pending":
        return "warning"
    if reviewState == "merged":
        return "merged"
    ""

fn getPrStatusColor(reviewState: text) -> text:
    prStatusColorRoute(reviewState)

fn prBadgeNumberText(number: i64) -> text:
    "#" + number.to_text()

fn renderPrBadgeRoute(number: i64, url: text, reviewState: text, bold: bool) -> PrBadgeView:
    val color = prStatusColorRoute(reviewState)
    val dim = color == "" && not bold
    val numberText = prBadgeNumberText(number)
    PrBadgeView.new("PR " + numberText, url, numberText, numberText, color, not bold, dim, bold, true)

fn PrBadge(number: i64, url: text, reviewState: text, bold: bool) -> PrBadgeView:
    renderPrBadgeRoute(number, url, reviewState, bold)
