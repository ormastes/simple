"""
Claude full BashModeProgress component parity.
"""

fn bashModeProgressLabel(command: text, running: bool) -> text:
    if running:
        return "Running: " + command.trim()
    "Finished: " + command.trim()

fn bashModeProgressPercent(done: i64, total: i64) -> i64:
    if total <= 0:
        return 0
    (done * 100) / total

fn bashModeProgressSourceLinesModeled() -> i64:
    55
