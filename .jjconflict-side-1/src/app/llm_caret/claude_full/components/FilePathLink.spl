"""
Claude full FilePathLink parity.
"""

fn filePathLinkLabel(path: text) -> text:
    val clean = path.trim()
    if clean == "":
        return "unknown file"
    clean

fn filePathLinkHref(path: text, line: i64) -> text:
    val clean = filePathLinkLabel(path)
    if line > 0:
        return clean + ":" + line.to_text()
    clean

fn filePathLinkTitle(path: text, line: i64) -> text:
    "Open " + filePathLinkHref(path, line)

fn filePathLinkSourceLinesModeled() -> i64:
    42
