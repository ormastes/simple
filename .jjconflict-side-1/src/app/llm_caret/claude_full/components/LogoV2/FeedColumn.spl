"""
Claude full LogoV2 feed column parity.
"""

class FeedColumnState:
    title: text
    width: i64
    priority: i64
    visible: bool

impl FeedColumnState:
    static fn new(title: text, width: i64, priority: i64, visible: bool) -> FeedColumnState:
        FeedColumnState(title: feedColumnTitle(title), width: feedColumnWidth(width), priority: priority, visible: visible)

fn feedColumnTitle(title: text) -> text:
    val clean = title.trim()
    if clean == "":
        return "Updates"
    clean

fn feedColumnWidth(width: i64) -> i64:
    if width < 16:
        return 16
    if width > 120:
        return 120
    width

fn feedColumnVisible(state: FeedColumnState) -> bool:
    state.visible and state.width >= 16

fn feedColumnSummary(state: FeedColumnState) -> text:
    if not feedColumnVisible(state):
        return "feed-column hidden"
    "feed-column " + state.title + " width=" + state.width.to_text()

fn feedColumnSourceLinesModeled() -> i64:
    58
