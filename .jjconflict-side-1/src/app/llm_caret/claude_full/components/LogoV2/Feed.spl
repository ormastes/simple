"""
Claude full LogoV2 feed parity.
"""

use app.llm_caret.claude_full.components.LogoV2.feedConfigs.*

class FeedItem:
    id: text
    title: text
    body: text
    unread: bool

impl FeedItem:
    static fn new(id: text, title: text, body: text, unread: bool) -> FeedItem:
        FeedItem(id: normalizeFeedConfigId(id), title: feedItemTitle(title), body: body.trim(), unread: unread)

class FeedState:
    config: FeedConfig
    items: [FeedItem]
    collapsed: bool

impl FeedState:
    static fn new(config: FeedConfig, items: [FeedItem], collapsed: bool) -> FeedState:
        FeedState(config: config, items: items, collapsed: collapsed)

fn feedItemTitle(title: text) -> text:
    val clean = title.trim()
    if clean == "":
        return "Untitled"
    clean

fn feedVisible(state: FeedState) -> bool:
    state.config.enabled and not state.collapsed

fn feedUnreadCount(state: FeedState) -> i64:
    var count = 0
    var i = 0
    while i < state.items.len():
        if state.items[i].unread:
            count = count + 1
        i = i + 1
    count

fn feedSummary(state: FeedState) -> text:
    if not feedVisible(state):
        return "feed hidden"
    "feed " + state.config.label + " items=" + state.items.len().to_text() + " unread=" + feedUnreadCount(state).to_text()

fn renderFeed(state: FeedState) -> text:
    if state.items.len() == 0:
        return feedSummary(state) + " empty"
    feedSummary(state) + " first=" + state.items[0].title

fn feedSourceLinesModeled() -> i64:
    111
