"""
Claude full HelpV2 parity.
"""

class HelpV2State:
    open: bool
    tab: text
    query: text

impl HelpV2State:
    static fn new(open: bool, tab: text, query: text) -> HelpV2State:
        HelpV2State(open: open, tab: normalizeHelpTab(tab), query: query.trim())

fn normalizeHelpTab(tab: text) -> text:
    val clean = tab.trim()
    if clean == "commands" or clean == "general":
        return clean
    "general"

fn helpV2Visible(state: HelpV2State) -> bool:
    state.open

fn helpV2Title(state: HelpV2State) -> text:
    if state.tab == "commands":
        return "Command help"
    "General help"

fn helpV2Summary(state: HelpV2State) -> text:
    val search = if state.query == "": "all" else: state.query
    helpV2Title(state) + " search=" + search

fn helpV2SwitchTab(state: HelpV2State, tab: text) -> HelpV2State:
    HelpV2State.new(state.open, tab, state.query)

fn helpV2SourceLinesModeled() -> i64:
    183
