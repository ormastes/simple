"""
Claude full submitTranscriptShare parity.
"""

class TranscriptShareSubmission:
    allowed: bool
    transcript_id: text
    email: text
    reason: text

impl TranscriptShareSubmission:
    static fn new(allowed: bool, transcriptId: text, email: text, reason: text) -> TranscriptShareSubmission:
        TranscriptShareSubmission(allowed: allowed, transcript_id: transcriptId.trim(), email: email.trim(), reason: reason.trim())

fn transcriptShareCanSubmit(state: TranscriptShareSubmission) -> bool:
    state.allowed and state.transcript_id != ""

fn transcriptSharePayload(state: TranscriptShareSubmission) -> text:
    if not transcriptShareCanSubmit(state):
        return "share=disabled"
    "share=" + state.transcript_id + "&email=" + state.email

fn transcriptShareResultMessage(state: TranscriptShareSubmission) -> text:
    if transcriptShareCanSubmit(state):
        return "Transcript share submitted"
    if state.reason != "":
        return state.reason
    "Transcript share unavailable"

fn submitTranscriptShareSourceLinesModeled() -> i64:
    112
