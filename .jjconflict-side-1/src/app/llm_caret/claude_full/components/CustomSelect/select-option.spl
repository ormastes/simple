"""
Claude full CustomSelect select option parity.
"""

class SelectOptionRow:
    value: text
    label: text
    highlighted: bool

impl SelectOptionRow:
    static fn new(value: text, label: text, highlighted: bool) -> SelectOptionRow:
        SelectOptionRow(value: value.trim(), label: label.trim(), highlighted: highlighted)

fn selectOptionRowLabel(row: SelectOptionRow) -> text:
    if row.highlighted:
        return "> " + row.label
    "  " + row.label

fn selectOptionSourceLinesModeled() -> i64:
    67
