"""
Claude full design-system Divider parity.
"""

fn dividerLine(width: i64) -> text:
    var out = ""
    var i = 0
    while i < width:
        out = out + "-"
        i = i + 1
    out

fn dividerSourceLinesModeled() -> i64:
    148
