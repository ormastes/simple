"""
Claude full design-system Byline parity.
"""

fn bylineText(author: text, detail: text) -> text:
    author.trim() + " - " + detail.trim()

fn bylineVisible(author: text) -> bool:
    author.trim() != ""

fn bylineSourceLinesModeled() -> i64:
    76
