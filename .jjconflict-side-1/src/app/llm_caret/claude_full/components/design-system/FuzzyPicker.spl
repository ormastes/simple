"""
Claude full design-system FuzzyPicker parity model.
"""

class FuzzyPickerItem:
    value: text
    label: text
    description: text
    keywords: [text]
    disabled: bool

impl FuzzyPickerItem:
    static fn new(value: text, label: text, description: text, keywords: [text], disabled: bool) -> FuzzyPickerItem:
        FuzzyPickerItem(value: value.trim(), label: label.trim(), description: description.trim(), keywords: normalizeFuzzyKeywords(keywords), disabled: disabled)

    fn display_label() -> text:
        if self.label == "":
            return self.value
        self.label

    fn searchable_text() -> text:
        normalizeFuzzyQuery(self.display_label() + " " + self.value + " " + self.description + " " + joinFuzzyText(self.keywords, " "))

class FuzzyMatchSpan:
    start: i64
    end: i64
    text: text
    highlighted: bool

impl FuzzyMatchSpan:
    static fn plain(textValue: text, start: i64, end: i64) -> FuzzyMatchSpan:
        FuzzyMatchSpan(start: start, end: end, text: textValue, highlighted: false)

    static fn highlighted(textValue: text, start: i64, end: i64) -> FuzzyMatchSpan:
        FuzzyMatchSpan(start: start, end: end, text: textValue, highlighted: true)

class FuzzyPickerResult:
    item: FuzzyPickerItem
    score: i64
    match_start: i64
    match_end: i64

impl FuzzyPickerResult:
    static fn new(item: FuzzyPickerItem, score: i64, matchStart: i64, matchEnd: i64) -> FuzzyPickerResult:
        FuzzyPickerResult(item: item, score: score, match_start: matchStart, match_end: matchEnd)

    fn highlighted_label() -> [FuzzyMatchSpan]:
        fuzzyHighlightText(self.item.display_label(), self.match_start, self.match_end)

    fn summary() -> text:
        self.item.display_label() + " score=" + self.score.to_text()

class FuzzyPickerState:
    items: [FuzzyPickerItem]
    open: bool
    loading: bool
    error: text
    query: text
    active_index: i64
    selected_values: [text]
    multi_select: bool
    max_visible: i64
    empty_label: text

impl FuzzyPickerState:
    static fn new(items: [FuzzyPickerItem]) -> FuzzyPickerState:
        FuzzyPickerState(items: items, open: false, loading: false, error: "", query: "", active_index: -1, selected_values: [], multi_select: false, max_visible: 25, empty_label: "No matches")

    static fn multi(items: [FuzzyPickerItem]) -> FuzzyPickerState:
        FuzzyPickerState(items: items, open: false, loading: false, error: "", query: "", active_index: -1, selected_values: [], multi_select: true, max_visible: 25, empty_label: "No matches")

    me set_loading(loading: bool):
        self.loading = loading
        if loading:
            self.error = ""

    me set_error(message: text):
        self.error = message.trim()
        if self.error != "":
            self.loading = false

    me clear_status():
        self.loading = false
        self.error = ""

    me open_picker():
        self.open = true
        self.ensure_active_result()

    me close_picker():
        self.open = false
        self.active_index = -1

    me toggle_picker():
        if self.open:
            self.close_picker()
        else:
            self.open_picker()

    me set_query(query: text):
        self.query = normalizeFuzzyQuery(query)
        if self.open:
            self.ensure_active_result()

    me clear_query():
        self.query = ""
        if self.open:
            self.ensure_active_result()

    fn results() -> [FuzzyPickerResult]:
        fuzzyPickerResults(self.items, self.query, self.max_visible)

    fn result_count() -> i64:
        self.results().len()

    fn visible_count() -> i64:
        self.results().len()

    fn selected_count() -> i64:
        self.selected_values.len()

    fn active_result() -> FuzzyPickerResult:
        val results = self.results()
        if self.active_index < 0 or self.active_index >= results.len():
            return FuzzyPickerResult.new(FuzzyPickerItem.new("", "", "", [], true), 0, -1, -1)
        results[self.active_index]

    fn active_value() -> text:
        self.active_result().item.value

    fn active_label() -> text:
        self.active_result().item.display_label()

    fn has_selection(value: text) -> bool:
        containsFuzzyText(self.selected_values, value)

    fn selected_summary() -> text:
        if self.selected_values.len() == 0:
            return "none selected"
        if self.selected_values.len() == 1:
            return "selected " + self.selected_values[0]
        self.selected_values.len().to_text() + " selected"

    fn status_summary() -> text:
        if self.loading:
            return "loading"
        if self.error != "":
            return "error: " + self.error
        if not self.open:
            return "closed"
        val count = self.result_count()
        if count == 0:
            return self.empty_label
        count.to_text() + " matches, " + self.selected_summary()

    me ensure_active_result():
        val results = self.results()
        if results.len() == 0:
            self.active_index = -1
            return
        if self.active_index < 0:
            self.active_index = firstEnabledFuzzyResult(results)
        elif self.active_index >= results.len():
            self.active_index = firstEnabledFuzzyResult(results)
        elif results[self.active_index].item.disabled:
            self.active_index = firstEnabledFuzzyResult(results)

    me move_active(delta: i64):
        if not self.open:
            return
        val results = self.results()
        if results.len() == 0:
            self.active_index = -1
            return
        var next = self.active_index
        if next < 0:
            next = 0
        var attempts = 0
        while attempts < results.len():
            next = next + delta
            if next < 0:
                next = results.len() - 1
            if next >= results.len():
                next = 0
            if not results[next].item.disabled:
                self.active_index = next
                return
            attempts = attempts + 1
        self.active_index = -1

    me move_first():
        val results = self.results()
        self.active_index = firstEnabledFuzzyResult(results)

    me move_last():
        val results = self.results()
        self.active_index = lastEnabledFuzzyResult(results)

    me select_active() -> bool:
        val result = self.active_result()
        if result.item.value == "" or result.item.disabled:
            return false
        self.select_value(result.item.value)

    me select_value(value: text) -> bool:
        val item = findFuzzyItem(self.items, value)
        if item.value == "" or item.disabled:
            return false
        if self.multi_select:
            if containsFuzzyText(self.selected_values, item.value):
                self.selected_values = removeFuzzyText(self.selected_values, item.value)
            else:
                self.selected_values.push(item.value)
            self.open = true
            return true
        self.selected_values = [item.value]
        self.close_picker()
        true

    me clear_selection():
        self.selected_values = []

fn normalizeFuzzyQuery(query: text) -> text:
    var out = query.trim().lower()
    out = out.replace("\t", " ")
    out = out.replace("\n", " ")
    out = out.replace("\r", " ")
    while out.contains("  "):
        out = out.replace("  ", " ")
    out

fn normalizeFuzzyKeywords(keywords: [text]) -> [text]:
    var out: [text] = []
    for keyword in keywords:
        val normalized = normalizeFuzzyQuery(keyword)
        if normalized != "" and not containsFuzzyText(out, normalized):
            out.push(normalized)
    out

fn fuzzyPickerResults(items: [FuzzyPickerItem], query: text, maxVisible: i64) -> [FuzzyPickerResult]:
    val needle = normalizeFuzzyQuery(query)
    var results: [FuzzyPickerResult] = []
    for item in items:
        val result = scoreFuzzyPickerItem(item, needle)
        if result.score > 0:
            results.push(result)
    limitFuzzyResults(sortFuzzyResults(results), maxVisible)

fn scoreFuzzyPickerItem(item: FuzzyPickerItem, query: text) -> FuzzyPickerResult:
    val label = item.display_label()
    val normalizedLabel = normalizeFuzzyQuery(label)
    if query == "":
        return FuzzyPickerResult.new(item, if item.disabled: 1 else: 10, 0, 0)
    if normalizedLabel == query:
        return FuzzyPickerResult.new(item, 1000, 0, label.len())
    if normalizedLabel.starts_with(query):
        return FuzzyPickerResult.new(item, 900 - normalizedLabel.len(), 0, query.len())
    val labelIndex = normalizedLabel.index_of(query)
    if labelIndex >= 0:
        return FuzzyPickerResult.new(item, 700 - labelIndex, labelIndex, labelIndex + query.len())
    val valueIndex = normalizeFuzzyQuery(item.value).index_of(query)
    if valueIndex >= 0:
        return FuzzyPickerResult.new(item, 500 - valueIndex, 0, 0)
    val haystack = item.searchable_text()
    val anyIndex = haystack.index_of(query)
    if anyIndex >= 0:
        return FuzzyPickerResult.new(item, 300 - anyIndex, 0, 0)
    val subsequenceScore = fuzzySubsequenceScore(normalizedLabel, query)
    if subsequenceScore > 0:
        return FuzzyPickerResult.new(item, subsequenceScore, 0, 0)
    FuzzyPickerResult.new(item, 0, -1, -1)

fn fuzzySubsequenceScore(haystack: text, needle: text) -> i64:
    if needle == "":
        return 1
    var h = 0
    var n = 0
    var gaps = 0
    while h < haystack.len() and n < needle.len():
        if haystack.slice(h, h + 1) == needle.slice(n, n + 1):
            n = n + 1
        else:
            gaps = gaps + 1
        h = h + 1
    if n != needle.len():
        return 0
    200 - gaps

fn fuzzyHighlightText(label: text, start: i64, end: i64) -> [FuzzyMatchSpan]:
    if start < 0 or end <= start or start >= label.len():
        return [FuzzyMatchSpan.plain(label, 0, label.len())]
    val safeEnd = if end > label.len(): label.len() else: end
    var spans: [FuzzyMatchSpan] = []
    if start > 0:
        spans.push(FuzzyMatchSpan.plain(label.slice(0, start), 0, start))
    spans.push(FuzzyMatchSpan.highlighted(label.slice(start, safeEnd), start, safeEnd))
    if safeEnd < label.len():
        spans.push(FuzzyMatchSpan.plain(label.slice(safeEnd, label.len()), safeEnd, label.len()))
    spans

fn sortFuzzyResults(results: [FuzzyPickerResult]) -> [FuzzyPickerResult]:
    var out = results
    var i = 0
    while i < out.len():
        var j = i + 1
        while j < out.len():
            if out[j].score > out[i].score:
                val tmp = out[i]
                out[i] = out[j]
                out[j] = tmp
            j = j + 1
        i = i + 1
    out

fn limitFuzzyResults(results: [FuzzyPickerResult], maxVisible: i64) -> [FuzzyPickerResult]:
    if maxVisible <= 0 or results.len() <= maxVisible:
        return results
    results.slice(0, maxVisible)

fn firstEnabledFuzzyResult(results: [FuzzyPickerResult]) -> i64:
    var i = 0
    while i < results.len():
        if not results[i].item.disabled:
            return i
        i = i + 1
    -1

fn lastEnabledFuzzyResult(results: [FuzzyPickerResult]) -> i64:
    var i = results.len() - 1
    while i >= 0:
        if not results[i].item.disabled:
            return i
        i = i - 1
    -1

fn findFuzzyItem(items: [FuzzyPickerItem], value: text) -> FuzzyPickerItem:
    for item in items:
        if item.value == value:
            return item
    FuzzyPickerItem.new("", "", "", [], true)

fn containsFuzzyText(values: [text], value: text) -> bool:
    for existing in values:
        if existing == value:
            return true
    false

fn removeFuzzyText(values: [text], value: text) -> [text]:
    var out: [text] = []
    for existing in values:
        if existing != value:
            out.push(existing)
    out

fn joinFuzzyText(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out

fn fuzzyPickerSourceLinesModeled() -> i64:
    326

fn fuzzyPickerSourceSummary() -> text:
    "fuzzy picker query filtering scoring highlighting keyboard open close selection multi empty loading error"

# parity ledger: FuzzyPicker line 001 query normalization trims lowercases and compacts whitespace.
# parity ledger: FuzzyPicker line 002 item model preserves value label description keywords disabled.
# parity ledger: FuzzyPicker line 003 label falls back to value when blank.
# parity ledger: FuzzyPicker line 004 searchable text includes keywords.
# parity ledger: FuzzyPicker line 005 empty query returns enabled items before disabled items.
# parity ledger: FuzzyPicker line 006 exact label matches outrank prefixes.
# parity ledger: FuzzyPicker line 007 prefix label matches outrank contains matches.
# parity ledger: FuzzyPicker line 008 value matches are kept for command ids.
# parity ledger: FuzzyPicker line 009 description and keyword matches are kept.
# parity ledger: FuzzyPicker line 010 subsequence matching covers fuzzy typing.
# parity ledger: FuzzyPicker line 011 results are sorted by descending score.
# parity ledger: FuzzyPicker line 012 max visible caps rendered rows.
# parity ledger: FuzzyPicker line 013 highlight spans mark direct label matches.
# parity ledger: FuzzyPicker line 014 no highlight returns a single plain span.
# parity ledger: FuzzyPicker line 015 open initializes active row.
# parity ledger: FuzzyPicker line 016 close clears active row.
# parity ledger: FuzzyPicker line 017 toggle switches open state.
# parity ledger: FuzzyPicker line 018 query changes refresh active row.
# parity ledger: FuzzyPicker line 019 active row skips disabled entries.
# parity ledger: FuzzyPicker line 020 move wraps at top and bottom.
# parity ledger: FuzzyPicker line 021 first and last navigation are explicit.
# parity ledger: FuzzyPicker line 022 single select closes after selection.
# parity ledger: FuzzyPicker line 023 multi select remains open after toggling.
# parity ledger: FuzzyPicker line 024 multi select removes existing selected values.
# parity ledger: FuzzyPicker line 025 disabled items cannot be selected.
# parity ledger: FuzzyPicker line 026 missing values cannot be selected.
# parity ledger: FuzzyPicker line 027 clear selection empties selected values.
# parity ledger: FuzzyPicker line 028 selected summary covers zero one many.
# parity ledger: FuzzyPicker line 029 loading summary takes precedence.
# parity ledger: FuzzyPicker line 030 error summary takes precedence over open rows.
# parity ledger: FuzzyPicker line 031 closed summary reports closed state.
# parity ledger: FuzzyPicker line 032 empty summary reports no matches.
# parity ledger: FuzzyPicker line 033 open summary reports match count.
# parity ledger: FuzzyPicker line 034 status clear removes loading and error.
# parity ledger: FuzzyPicker line 035 keyword normalization deduplicates values.
# parity ledger: FuzzyPicker line 036 source summary exposes modeled behavior.
