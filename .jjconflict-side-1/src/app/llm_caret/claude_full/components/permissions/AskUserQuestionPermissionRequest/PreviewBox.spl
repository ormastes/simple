"""
Claude full ask-user-question PreviewBox parity model.
"""

const PREVIEW_BOX_SOURCE_LINES = 228
const PREVIEW_BOX_DEFAULT_MAX_LINES = 20
const PREVIEW_BOX_DEFAULT_MIN_WIDTH = 40

class PreviewBoxProps:
    content: text
    max_lines: i64
    min_height: i64
    min_width: i64
    max_width: i64
    terminal_width: i64

impl PreviewBoxProps:
    static fn new(content: text, maxLines: i64, minHeight: i64, minWidth: i64, maxWidth: i64, terminalWidth: i64) -> PreviewBoxProps:
        PreviewBoxProps(content: content, max_lines: maxLines, min_height: minHeight, min_width: minWidth, max_width: maxWidth, terminal_width: terminalWidth)

class PreviewBoxLine:
    original: text
    display: text
    padding_width: i64

impl PreviewBoxLine:
    static fn new(original: text, display: text, paddingWidth: i64) -> PreviewBoxLine:
        PreviewBoxLine(original: original, display: display, padding_width: paddingWidth)

class PreviewBoxRender:
    content_lines: [text]
    visible_lines: [PreviewBoxLine]
    is_truncated: bool
    hidden_count: i64
    padding_needed: i64
    content_width: i64
    box_width: i64
    inner_width: i64
    top_border: text
    bottom_border: text
    truncation_bar: text
    highlight_enabled: bool

impl PreviewBoxRender:
    static fn new(contentLines: [text], visibleLines: [PreviewBoxLine], isTruncated: bool, hiddenCount: i64, paddingNeeded: i64, contentWidth: i64, boxWidth: i64, innerWidth: i64, topBorder: text, bottomBorder: text, truncationBar: text, highlightEnabled: bool) -> PreviewBoxRender:
        PreviewBoxRender(content_lines: contentLines, visible_lines: visibleLines, is_truncated: isTruncated, hidden_count: hiddenCount, padding_needed: paddingNeeded, content_width: contentWidth, box_width: boxWidth, inner_width: innerWidth, top_border: topBorder, bottom_border: bottomBorder, truncation_bar: truncationBar, highlight_enabled: highlightEnabled)

fn previewBoxRepeat(ch: text, count: i64) -> text:
    var out = ""
    var i = 0
    while i < count:
        out = out + ch
        i = i + 1
    out

fn previewBoxMax(a: i64, b: i64) -> i64:
    if a > b:
        a
    else:
        b

fn previewBoxMin(a: i64, b: i64) -> i64:
    if a < b:
        a
    else:
        b

fn previewBoxEffectiveMaxLines(maxLines: i64) -> i64:
    if maxLines > 0:
        maxLines
    else:
        PREVIEW_BOX_DEFAULT_MAX_LINES

fn previewBoxEffectiveMinWidth(minWidth: i64) -> i64:
    if minWidth > 0:
        minWidth
    else:
        PREVIEW_BOX_DEFAULT_MIN_WIDTH

fn previewBoxEffectiveMaxWidth(maxWidth: i64, terminalWidth: i64) -> i64:
    if maxWidth > 0:
        maxWidth
    else:
        terminalWidth - 4

fn previewBoxLineWidth(line: text) -> i64:
    line.len()

fn previewBoxContentWidth(lines: [text], minWidth: i64) -> i64:
    var width = minWidth
    for line in lines:
        width = previewBoxMax(width, previewBoxLineWidth(line))
    width

fn previewBoxTruncatedLines(lines: [text], maxLines: i64) -> [text]:
    var out: [text] = []
    var i = 0
    for line in lines:
        if i < maxLines:
            out.push(line)
        i = i + 1
    out

fn previewBoxPadLines(lines: [text], paddingNeeded: i64) -> [text]:
    var out: [text] = []
    for line in lines:
        out.push(line)
    var i = 0
    while i < paddingNeeded:
        out.push("")
        i = i + 1
    out

fn previewBoxDisplayLine(line: text, innerWidth: i64) -> PreviewBoxLine:
    var display = line
    if previewBoxLineWidth(line) > innerWidth:
        display = line.substring(0, innerWidth)
    val padding = previewBoxMax(0, innerWidth - previewBoxLineWidth(display))
    PreviewBoxLine.new(line, display, padding)

fn previewBoxDisplayLines(lines: [text], innerWidth: i64) -> [PreviewBoxLine]:
    var out: [PreviewBoxLine] = []
    for line in lines:
        out.push(previewBoxDisplayLine(line, innerWidth))
    out

fn previewBoxTruncationBar(hiddenCount: i64, boxWidth: i64) -> text:
    if hiddenCount <= 0:
        ""
    else:
        val label = previewBoxRepeat("─", 3) + " ✂ " + previewBoxRepeat("─", 3) + " " + hiddenCount.to_text() + " lines hidden "
        val fillWidth = previewBoxMax(0, boxWidth - 2 - previewBoxLineWidth(label))
        "├" + label + previewBoxRepeat("─", fillWidth) + "┤"

fn previewBoxBody(props: PreviewBoxProps, syntaxHighlightingDisabled: bool) -> PreviewBoxRender:
    val maxLines = previewBoxEffectiveMaxLines(props.max_lines)
    val minWidth = previewBoxEffectiveMinWidth(props.min_width)
    val maxWidth = previewBoxEffectiveMaxWidth(props.max_width, props.terminal_width)
    val contentLines = props.content.split("\n")
    val isTruncated = contentLines.len() > maxLines
    val truncatedLines = previewBoxTruncatedLines(contentLines, maxLines)
    val effectiveMinHeight = previewBoxMin(props.min_height, maxLines)
    val truncationLineCount = if isTruncated: 1 else: 0
    val paddingNeeded = previewBoxMax(0, effectiveMinHeight - truncatedLines.len() - truncationLineCount)
    val paddedLines = previewBoxPadLines(truncatedLines, paddingNeeded)
    val contentWidth = previewBoxContentWidth(paddedLines, minWidth)
    val boxWidth = previewBoxMin(contentWidth + 4, maxWidth)
    val innerWidth = boxWidth - 4
    val hiddenCount = if isTruncated: contentLines.len() - maxLines else: 0
    val topBorder = "┌" + previewBoxRepeat("─", boxWidth - 2) + "┐"
    val bottomBorder = "└" + previewBoxRepeat("─", boxWidth - 2) + "┘"
    val truncationBar = previewBoxTruncationBar(hiddenCount, boxWidth)
    PreviewBoxRender.new(contentLines, previewBoxDisplayLines(paddedLines, innerWidth), isTruncated, hiddenCount, paddingNeeded, contentWidth, boxWidth, innerWidth, topBorder, bottomBorder, truncationBar, not syntaxHighlightingDisabled)

fn previewBox(content: text, maxLines: i64, minHeight: i64, minWidth: i64, maxWidth: i64, terminalWidth: i64, syntaxHighlightingDisabled: bool) -> PreviewBoxRender:
    previewBoxBody(PreviewBoxProps.new(content, maxLines, minHeight, minWidth, maxWidth, terminalWidth), syntaxHighlightingDisabled)

fn previewBoxSourceLinesModeled() -> i64:
    PREVIEW_BOX_SOURCE_LINES
