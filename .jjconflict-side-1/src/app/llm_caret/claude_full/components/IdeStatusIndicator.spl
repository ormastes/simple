"""
Claude full IdeStatusIndicator parity.
"""

fn ideStatusLabel(connected: bool, name: text) -> text:
    val clean = name.trim()
    if connected:
        if clean == "":
            return "IDE connected"
        return clean + " connected"
    "IDE disconnected"

fn ideStatusTone(connected: bool, warning: bool) -> text:
    if warning:
        return "warning"
    if connected:
        return "success"
    "muted"

fn ideStatusIndicatorSourceLinesModeled() -> i64:
    57
