"""
Claude full LanguagePicker parity.
"""

class LanguagePickerState:
    language: text
    open: bool
    query: text

impl LanguagePickerState:
    static fn new(language: text, open: bool, query: text) -> LanguagePickerState:
        LanguagePickerState(language: normalizeLanguage(language), open: open, query: query.trim())

fn normalizeLanguage(language: text) -> text:
    val clean = language.trim()
    if clean == "":
        return "en"
    clean

fn languagePickerLabel(state: LanguagePickerState) -> text:
    "Language " + state.language

fn languagePickerVisible(state: LanguagePickerState) -> bool:
    state.open

fn languagePickerSummary(state: LanguagePickerState) -> text:
    languagePickerLabel(state) + " query=" + state.query

fn languagePickerSourceLinesModeled() -> i64:
    85
