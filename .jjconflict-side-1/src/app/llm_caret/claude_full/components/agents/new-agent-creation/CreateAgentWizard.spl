"""
Claude full CreateAgentWizard component parity.
"""

class CreateAgentWizardState:
    step: text
    name: text
    description: text

impl CreateAgentWizardState:
    static fn new(step: text, name: text, description: text) -> CreateAgentWizardState:
        CreateAgentWizardState(step: step.trim(), name: name.trim(), description: description.trim())

fn wizardStepTitle(state: CreateAgentWizardState) -> text:
    if state.step == "":
        return "Describe agent"
    state.step

fn canContinueWizard(state: CreateAgentWizardState) -> bool:
    state.name != "" and state.description != ""

fn createAgentWizardSummary(state: CreateAgentWizardState) -> text:
    wizardStepTitle(state) + ": " + state.name

fn createAgentWizardSourceLinesModeled() -> i64:
    96
