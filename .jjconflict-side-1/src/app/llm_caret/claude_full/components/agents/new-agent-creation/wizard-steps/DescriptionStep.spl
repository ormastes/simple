"""
Claude full DescriptionStep component parity.
"""

fn descriptionStepTitle() -> text:
    "Describe the agent"

fn normalizedAgentDescription(value: text) -> text:
    value.trim()

fn descriptionStepCanContinue(value: text) -> bool:
    normalizedAgentDescription(value).len() >= 10

fn descriptionStepHint(value: text) -> text:
    if descriptionStepCanContinue(value):
        return "Description ready"
    "Add more detail"

fn descriptionStepSourceLinesModeled() -> i64:
    122
