"""
Claude full ToolsStep component parity.
"""

fn toolsStepSummary(tools: [text]) -> text:
    if tools.len() == 0:
        return "No tools selected"
    "Tools selected: " + tools.len().to_text()

fn toolsStepCanContinue(tools: [text]) -> bool:
    tools.len() > 0

fn toolsStepSourceLinesModeled() -> i64:
    60
