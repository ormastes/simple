"""
Claude full agent component shared types parity.
"""

class AgentTypeSummary:
    name: text
    model: text
    color: text

impl AgentTypeSummary:
    static fn new(name: text, model: text, color: text) -> AgentTypeSummary:
        AgentTypeSummary(name: name.trim(), model: model.trim(), color: color.trim())

fn agentTypeSummaryLabel(summary: AgentTypeSummary) -> text:
    summary.name + " uses " + summary.model + " in " + summary.color

fn agentTypesSourceLinesModeled() -> i64:
    27
