"""
Minimal AgentDetail parity model for Claude full agents UI.
"""

class AgentDetailAction:
    label: text
    enabled: bool
    reason: text

impl AgentDetailAction:
    static fn new(label: text, enabled: bool, reason: text) -> AgentDetailAction:
        AgentDetailAction(label: label, enabled: enabled, reason: reason)

class AgentDetailRow:
    label: text
    value: text

impl AgentDetailRow:
    static fn new(label: text, value: text) -> AgentDetailRow:
        AgentDetailRow(label: label, value: value)

class AgentDetailModel:
    name: text
    description: text
    model: text
    tools: [text]
    enabled: bool
    missing: bool
    sourcePath: text

impl AgentDetailModel:
    static fn new(name: text, description: text, model: text, tools: [text], enabled: bool, missing: bool, sourcePath: text) -> AgentDetailModel:
        AgentDetailModel(name: name, description: description, model: model, tools: tools, enabled: enabled, missing: missing, sourcePath: sourcePath)

    me statusLabel() -> text:
        if me.missing:
            return "missing"
        if not me.enabled:
            return "disabled"
        "enabled"

    me rows() -> [AgentDetailRow]:
        if me.missing:
            return [
                AgentDetailRow.new("Name", me.name),
                AgentDetailRow.new("Status", "missing"),
                AgentDetailRow.new("Source", me.sourcePath),
            ]
        [
            AgentDetailRow.new("Name", me.name),
            AgentDetailRow.new("Description", me.description),
            AgentDetailRow.new("Model", me.model),
            AgentDetailRow.new("Tools", joinAgentTools(me.tools)),
            AgentDetailRow.new("Status", me.statusLabel()),
            AgentDetailRow.new("Source", me.sourcePath),
        ]

    me actions() -> [AgentDetailAction]:
        if me.missing:
            return [
                AgentDetailAction.new("Create", true, ""),
                AgentDetailAction.new("Edit", false, "agent file is missing"),
                AgentDetailAction.new("Run", false, "agent file is missing"),
            ]
        if not me.enabled:
            return [
                AgentDetailAction.new("Enable", true, ""),
                AgentDetailAction.new("Edit", true, ""),
                AgentDetailAction.new("Run", false, "agent is disabled"),
            ]
        [
            AgentDetailAction.new("Disable", true, ""),
            AgentDetailAction.new("Edit", true, ""),
            AgentDetailAction.new("Run", true, ""),
        ]

    me renderSummary() -> text:
        me.name + " | " + me.statusLabel() + " | " + me.model + " | " + joinAgentTools(me.tools)

fn joinAgentTools(tools: [text]) -> text:
    if tools.len() == 0:
        return "none"
    var out = tools[0]
    var i = 1
    while i < tools.len():
        out = out + ", " + tools[i]
        i = i + 1
    out

fn agentDetailReady(name: text, description: text, model: text, tools: [text], sourcePath: text) -> AgentDetailModel:
    AgentDetailModel.new(name, description, model, tools, true, false, sourcePath)

fn agentDetailDisabled(name: text, description: text, model: text, tools: [text], sourcePath: text) -> AgentDetailModel:
    AgentDetailModel.new(name, description, model, tools, false, false, sourcePath)

fn agentDetailMissing(name: text, sourcePath: text) -> AgentDetailModel:
    AgentDetailModel.new(name, "", "", [], false, true, sourcePath)

fn agentDetailSourceLinesModeled() -> i64:
    219

fn agentDetailModeledStatusCount() -> i64:
    3

fn agentDetailModeledActionCount() -> i64:
    3

