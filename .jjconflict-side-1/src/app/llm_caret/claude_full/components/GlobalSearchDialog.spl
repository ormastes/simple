"""
Claude full GlobalSearchDialog component parity model.
"""

class GlobalSearchResult:
    id: text
    title: text
    subtitle: text
    category: text
    path: text
    keywords: [text]
    disabled: bool

impl GlobalSearchResult:
    static fn new(id: text, title: text, subtitle: text, category: text, path: text, keywords: [text], disabled: bool) -> GlobalSearchResult:
        GlobalSearchResult(id: id.trim(), title: title.trim(), subtitle: subtitle.trim(), category: normalizeGlobalSearchCategory(category), path: path.trim(), keywords: keywords, disabled: disabled)

    me haystack() -> text:
        (me.id + " " + me.title + " " + me.subtitle + " " + me.category + " " + me.path + " " + joinGlobalSearchText(me.keywords, " ")).lower()

    me matches(query: text, categoryFilter: text) -> bool:
        val category = normalizeGlobalSearchCategoryFilter(categoryFilter)
        if category != "all" and me.category != category:
            return false
        val q = normalizeGlobalSearchQuery(query)
        if q == "":
            return true
        globalSearchScore(me, q) > 0

    me categoryLabel() -> text:
        globalSearchCategoryLabel(me.category)

    me statusLabel() -> text:
        if me.disabled:
            return "disabled"
        "enabled"

class GlobalSearchRow:
    result: GlobalSearchResult
    score: i64
    selected: bool

impl GlobalSearchRow:
    static fn new(result: GlobalSearchResult, score: i64, selected: bool) -> GlobalSearchRow:
        GlobalSearchRow(result: result, score: score, selected: selected)

class GlobalSearchGroup:
    category: text
    label: text
    rows: [GlobalSearchRow]

impl GlobalSearchGroup:
    static fn new(category: text, rows: [GlobalSearchRow]) -> GlobalSearchGroup:
        GlobalSearchGroup(category: normalizeGlobalSearchCategory(category), label: globalSearchCategoryLabel(category), rows: rows)

class GlobalSearchDialogState:
    isOpen: bool
    query: text
    categoryFilter: text
    selectedIndex: i64
    loading: bool
    error: text
    lastAction: text

impl GlobalSearchDialogState:
    static fn new(isOpen: bool, query: text, categoryFilter: text, selectedIndex: i64, loading: bool, error: text, lastAction: text) -> GlobalSearchDialogState:
        GlobalSearchDialogState(isOpen: isOpen, query: query, categoryFilter: normalizeGlobalSearchCategoryFilter(categoryFilter), selectedIndex: selectedIndex, loading: loading, error: error.trim(), lastAction: lastAction)

    static fn closed() -> GlobalSearchDialogState:
        GlobalSearchDialogState.new(false, "", "all", 0, false, "", "")

    me open() -> GlobalSearchDialogState:
        GlobalSearchDialogState.new(true, me.query, me.categoryFilter, me.selectedIndex, me.loading, me.error, "open")

    me close() -> GlobalSearchDialogState:
        GlobalSearchDialogState.new(false, me.query, me.categoryFilter, me.selectedIndex, me.loading, me.error, "close")

    me withQuery(query: text) -> GlobalSearchDialogState:
        GlobalSearchDialogState.new(me.isOpen, query, me.categoryFilter, 0, me.loading, me.error, "query")

    me withCategoryFilter(categoryFilter: text) -> GlobalSearchDialogState:
        GlobalSearchDialogState.new(me.isOpen, me.query, categoryFilter, 0, me.loading, me.error, "filter")

    me withSelectedIndex(selectedIndex: i64) -> GlobalSearchDialogState:
        GlobalSearchDialogState.new(me.isOpen, me.query, me.categoryFilter, selectedIndex, me.loading, me.error, "select")

    me withLoading(loading: bool) -> GlobalSearchDialogState:
        GlobalSearchDialogState.new(me.isOpen, me.query, me.categoryFilter, me.selectedIndex, loading, me.error, "loading")

    me withError(error: text) -> GlobalSearchDialogState:
        GlobalSearchDialogState.new(me.isOpen, me.query, me.categoryFilter, me.selectedIndex, false, error, "error")

class GlobalSearchDialogModel:
    results: [GlobalSearchResult]
    state: GlobalSearchDialogState

impl GlobalSearchDialogModel:
    static fn new(results: [GlobalSearchResult], state: GlobalSearchDialogState) -> GlobalSearchDialogModel:
        GlobalSearchDialogModel(results: results, state: normalizeGlobalSearchState(results, state))

    me open() -> GlobalSearchDialogModel:
        GlobalSearchDialogModel.new(me.results, me.state.open())

    me close() -> GlobalSearchDialogModel:
        GlobalSearchDialogModel.new(me.results, me.state.close())

    me query(query: text) -> GlobalSearchDialogModel:
        GlobalSearchDialogModel.new(me.results, me.state.withQuery(query))

    me filter(categoryFilter: text) -> GlobalSearchDialogModel:
        GlobalSearchDialogModel.new(me.results, me.state.withCategoryFilter(categoryFilter))

    me loading() -> GlobalSearchDialogModel:
        GlobalSearchDialogModel.new(me.results, me.state.withLoading(true))

    me fail(error: text) -> GlobalSearchDialogModel:
        GlobalSearchDialogModel.new(me.results, me.state.withError(error))

    me rows() -> [GlobalSearchRow]:
        globalSearchRows(me.results, me.state)

    me groups() -> [GlobalSearchGroup]:
        groupGlobalSearchRows(me.rows())

    me selectedResult() -> GlobalSearchResult?:
        val rows = me.rows()
        if rows.len() == 0:
            return nil
        val index = clampGlobalSearchIndex(me.state.selectedIndex, rows.len())
        rows[index].result

    me handleKey(key: text) -> GlobalSearchDialogModel:
        GlobalSearchDialogModel.new(me.results, globalSearchHandleKey(me.results, me.state, key))

    me summary() -> text:
        globalSearchSummary(me.results, me.state)

    me render() -> text:
        renderGlobalSearchDialog(me.results, me.state)

fn sampleGlobalSearchResults() -> [GlobalSearchResult]:
    [
        GlobalSearchResult.new("cmd-review", "Review current diff", "Run the review command on workspace changes", "commands", "/review", ["diff", "code", "changes"], false),
        GlobalSearchResult.new("cmd-model", "Switch model", "Choose the active Claude model", "commands", "/model", ["opus", "sonnet", "haiku"], false),
        GlobalSearchResult.new("file-readme", "README.md", "Project overview and quick start", "files", "README.md", ["docs", "start"], false),
        GlobalSearchResult.new("file-agents", "AGENTS.md", "Agent operating instructions", "files", "AGENTS.md", ["codex", "rules"], false),
        GlobalSearchResult.new("help-shortcuts", "Keyboard shortcuts", "Navigation and input help", "help", "help://shortcuts", ["keys", "navigation"], false),
        GlobalSearchResult.new("session-resume", "Resume conversation", "Continue a previous Claude session", "sessions", "session://resume", ["history", "continue"], false),
        GlobalSearchResult.new("mcp-disabled", "Install MCP server", "Unavailable while offline", "commands", "/mcp add", ["server", "tools"], true)
    ]

fn createGlobalSearchDialog(results: [GlobalSearchResult]) -> GlobalSearchDialogModel:
    GlobalSearchDialogModel.new(results, GlobalSearchDialogState.closed())

fn openGlobalSearchDialog(results: [GlobalSearchResult]) -> GlobalSearchDialogModel:
    createGlobalSearchDialog(results).open()

fn normalizeGlobalSearchState(results: [GlobalSearchResult], state: GlobalSearchDialogState) -> GlobalSearchDialogState:
    val rows = globalSearchRowsForQuery(results, state.query, state.categoryFilter)
    if rows.len() == 0:
        return GlobalSearchDialogState.new(state.isOpen, state.query, state.categoryFilter, 0, state.loading, state.error, state.lastAction)
    GlobalSearchDialogState.new(state.isOpen, state.query, state.categoryFilter, clampGlobalSearchIndex(state.selectedIndex, rows.len()), state.loading, state.error, state.lastAction)

fn globalSearchRows(results: [GlobalSearchResult], state: GlobalSearchDialogState) -> [GlobalSearchRow]:
    val sorted = globalSearchRowsForQuery(results, state.query, state.categoryFilter)
    val index = clampGlobalSearchIndex(state.selectedIndex, sorted.len())
    var rows: [GlobalSearchRow] = []
    var i = 0
    while i < sorted.len():
        rows.push(GlobalSearchRow.new(sorted[i].result, sorted[i].score, i == index))
        i = i + 1
    rows

fn globalSearchRowsForQuery(results: [GlobalSearchResult], query: text, categoryFilter: text) -> [GlobalSearchRow]:
    val q = normalizeGlobalSearchQuery(query)
    var rows: [GlobalSearchRow] = []
    var i = 0
    while i < results.len():
        if results[i].matches(q, categoryFilter):
            rows.push(GlobalSearchRow.new(results[i], globalSearchScore(results[i], q), false))
        i = i + 1
    sortGlobalSearchRows(rows)

fn sortGlobalSearchRows(rows: [GlobalSearchRow]) -> [GlobalSearchRow]:
    var out = rows
    var changed = true
    while changed:
        changed = false
        var i = 0
        while i + 1 < out.len():
            if globalSearchRowSortKey(out[i + 1]) < globalSearchRowSortKey(out[i]):
                val tmp = out[i]
                out[i] = out[i + 1]
                out[i + 1] = tmp
                changed = true
            i = i + 1
    out

fn globalSearchRowSortKey(row: GlobalSearchRow) -> text:
    val invertedScore = 100000 - row.score
    padGlobalSearchNumber(invertedScore, 6) + "|" + globalSearchCategoryRank(row.result.category).to_text() + "|" + row.result.title.lower() + "|" + row.result.id.lower()

fn globalSearchScore(result: GlobalSearchResult, query: text) -> i64:
    val q = normalizeGlobalSearchQuery(query)
    if q == "":
        return globalSearchCategoryBaseScore(result.category)
    var score = 0
    val title = result.title.lower()
    val subtitle = result.subtitle.lower()
    val path = result.path.lower()
    val id = result.id.lower()
    if title == q:
        score = score + 1000
    if title.starts_with(q):
        score = score + 500
    if title.contains(q):
        score = score + 250
    if id.contains(q):
        score = score + 150
    if path.contains(q):
        score = score + 120
    if subtitle.contains(q):
        score = score + 90
    if joinGlobalSearchText(result.keywords, " ").lower().contains(q):
        score = score + 80
    if score == 0:
        return 0
    score + globalSearchCategoryBaseScore(result.category)

fn groupGlobalSearchRows(rows: [GlobalSearchRow]) -> [GlobalSearchGroup]:
    var groups: [GlobalSearchGroup] = []
    var i = 0
    while i < globalSearchCategoryOptions().len():
        val category = globalSearchCategoryOptions()[i]
        if category != "all":
            val categoryRows = globalSearchRowsByCategory(rows, category)
            if categoryRows.len() > 0:
                groups.push(GlobalSearchGroup.new(category, categoryRows))
        i = i + 1
    groups

fn globalSearchRowsByCategory(rows: [GlobalSearchRow], category: text) -> [GlobalSearchRow]:
    var out: [GlobalSearchRow] = []
    val normalized = normalizeGlobalSearchCategory(category)
    var i = 0
    while i < rows.len():
        if rows[i].result.category == normalized:
            out.push(rows[i])
        i = i + 1
    out

fn globalSearchHandleKey(results: [GlobalSearchResult], state: GlobalSearchDialogState, key: text) -> GlobalSearchDialogState:
    val k = key.trim()
    if k == "Escape":
        return state.close()
    if k == "ArrowDown" or k == "Tab":
        return globalSearchMoveSelection(results, state, 1)
    if k == "ArrowUp" or k == "Shift+Tab":
        return globalSearchMoveSelection(results, state, -1)
    if k == "Home":
        return state.withSelectedIndex(0)
    if k == "End":
        val rows = globalSearchRowsForQuery(results, state.query, state.categoryFilter)
        if rows.len() == 0:
            return state.withSelectedIndex(0)
        return state.withSelectedIndex(rows.len() - 1)
    if k == "Enter":
        return GlobalSearchDialogState.new(state.isOpen, state.query, state.categoryFilter, state.selectedIndex, state.loading, state.error, "submit")
    state

fn globalSearchMoveSelection(results: [GlobalSearchResult], state: GlobalSearchDialogState, delta: i64) -> GlobalSearchDialogState:
    val rows = globalSearchRowsForQuery(results, state.query, state.categoryFilter)
    if rows.len() == 0:
        return state.withSelectedIndex(0)
    var next = state.selectedIndex + delta
    if next < 0:
        next = rows.len() - 1
    if next >= rows.len():
        next = 0
    state.withSelectedIndex(next)

fn renderGlobalSearchDialog(results: [GlobalSearchResult], state: GlobalSearchDialogState) -> text:
    if not state.isOpen:
        return "Global search closed"
    if state.error != "":
        return "Global search error: " + state.error
    if state.loading:
        return "Global search loading" + globalSearchQuerySuffix(state.query)
    val rows = globalSearchRows(results, state)
    if rows.len() == 0:
        return globalSearchEmptySummary(state)
    val normalized = normalizeGlobalSearchState(results, state)
    val groups = groupGlobalSearchRows(globalSearchRows(results, normalized))
    var lines: [text] = [renderGlobalSearchHeader(rows.len(), results.len(), normalized)]
    var i = 0
    while i < groups.len():
        lines.push(renderGlobalSearchGroup(groups[i]))
        i = i + 1
    joinGlobalSearchText(lines, "\n")

fn renderGlobalSearchHeader(visibleCount: i64, totalCount: i64, state: GlobalSearchDialogState) -> text:
    "Global search " + visibleCount.to_text() + "/" + totalCount.to_text() + " · " + globalSearchCategoryLabel(state.categoryFilter) + globalSearchQuerySuffix(state.query)

fn renderGlobalSearchGroup(group: GlobalSearchGroup) -> text:
    var lines: [text] = [group.label]
    var i = 0
    while i < group.rows.len():
        lines.push(renderGlobalSearchRow(group.rows[i]))
        i = i + 1
    joinGlobalSearchText(lines, "\n")

fn renderGlobalSearchRow(row: GlobalSearchRow) -> text:
    val marker = if row.selected: ">" else: " "
    marker + " " + row.result.title + " [" + row.result.categoryLabel() + "] " + row.result.statusLabel() + " · " + row.result.subtitle + " · " + row.result.path

fn globalSearchSummary(results: [GlobalSearchResult], state: GlobalSearchDialogState) -> text:
    if not state.isOpen:
        return "closed"
    if state.error != "":
        return "error: " + state.error
    if state.loading:
        return "loading"
    val rows = globalSearchRowsForQuery(results, state.query, state.categoryFilter)
    if rows.len() == 0:
        return globalSearchEmptySummary(state)
    "showing " + rows.len().to_text() + " of " + results.len().to_text() + " results"

fn globalSearchEmptySummary(state: GlobalSearchDialogState) -> text:
    if normalizeGlobalSearchQuery(state.query) == "" and normalizeGlobalSearchCategoryFilter(state.categoryFilter) == "all":
        return "No global search results"
    "No global search results for " + globalSearchFilterSummary(state)

fn globalSearchFilterSummary(state: GlobalSearchDialogState) -> text:
    var parts: [text] = []
    val q = normalizeGlobalSearchQuery(state.query)
    if q != "":
        parts.push("search \"" + q + "\"")
    if normalizeGlobalSearchCategoryFilter(state.categoryFilter) != "all":
        parts.push("category " + globalSearchCategoryLabel(state.categoryFilter))
    if parts.len() == 0:
        return "current filters"
    joinGlobalSearchText(parts, " and ")

fn globalSearchQuerySuffix(query: text) -> text:
    val q = normalizeGlobalSearchQuery(query)
    if q == "":
        return ""
    " · search:" + q

fn clampGlobalSearchIndex(index: i64, length: i64) -> i64:
    if length <= 0:
        return 0
    if index < 0:
        return 0
    if index >= length:
        return length - 1
    index

fn normalizeGlobalSearchQuery(query: text) -> text:
    query.trim().lower()

fn normalizeGlobalSearchCategory(category: text) -> text:
    val c = category.trim().lower()
    if c == "commands" or c == "command":
        return "commands"
    if c == "files" or c == "file":
        return "files"
    if c == "help":
        return "help"
    if c == "sessions" or c == "session":
        return "sessions"
    "commands"

fn normalizeGlobalSearchCategoryFilter(category: text) -> text:
    val c = category.trim().lower()
    if c == "" or c == "all":
        return "all"
    normalizeGlobalSearchCategory(c)

fn globalSearchCategoryLabel(category: text) -> text:
    val c = normalizeGlobalSearchCategoryFilter(category)
    if c == "commands":
        return "Commands"
    if c == "files":
        return "Files"
    if c == "help":
        return "Help"
    if c == "sessions":
        return "Sessions"
    "All"

fn globalSearchCategoryOptions() -> [text]:
    ["all", "commands", "files", "help", "sessions"]

fn globalSearchCategoryRank(category: text) -> i64:
    val c = normalizeGlobalSearchCategory(category)
    if c == "commands":
        return 1
    if c == "files":
        return 2
    if c == "help":
        return 3
    4

fn globalSearchCategoryBaseScore(category: text) -> i64:
    val rank = globalSearchCategoryRank(category)
    20 - rank

fn padGlobalSearchNumber(value: i64, width: i64) -> text:
    var out = value.to_text()
    while out.len() < width:
        out = "0" + out
    out

fn joinGlobalSearchText(values: [text], separator: text) -> text:
    if values.len() == 0:
        return ""
    var out = values[0]
    var i = 1
    while i < values.len():
        out = out + separator + values[i]
        i = i + 1
    out

fn globalSearchModeledSourceFile() -> text:
    "src/components/GlobalSearchDialog.tsx"

fn globalSearchModeledHook() -> text:
    "useGlobalSearch"

fn globalSearchModeledKeyboardHelper() -> text:
    "handleKeyDown"

fn globalSearchModeledSourceLines() -> i64:
    342

