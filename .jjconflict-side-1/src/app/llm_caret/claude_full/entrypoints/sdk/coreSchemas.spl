const SDK_CORE_SCHEMAS_SOURCE_LINES = 1889

fn modelUsageSchemaRoute(counterCount: i64, hasMaxOutputTokens: bool) -> bool:
    counterCount == 8 && hasMaxOutputTokens

fn apiKeySourceSchemaRoute(value: text) -> bool:
    value == "temporary" || value == "oauth"

fn permissionModeSchemaRoute(value: text) -> bool:
    value == "acceptEdits" || value == "dontAsk"

fn sdkStatusSchemaRoute(value: text) -> bool:
    value == "compacting" || value == "null"

fn sdkUserMessageSchemaRoute(hasUuid: bool, hasSessionId: bool, isReplay: bool) -> bool:
    if isReplay:
        return hasUuid && hasSessionId
    true

fn sdkAssistantMessageSchemaRoute(hasMessage: bool, hasParentToolUseId: bool, hasUuid: bool, hasSessionId: bool) -> bool:
    hasMessage && hasParentToolUseId && hasUuid && hasSessionId

fn sdkResultMessageSchemaRoute(kind: text, hasResult: bool, hasPermissionDenials: bool, hasModelUsage: bool, hasErrors: bool) -> bool:
    if kind == "success":
        return hasResult && hasPermissionDenials && hasModelUsage
    if kind == "error":
        return hasErrors
    false

fn sdkMessageSchemaRoute(kind: text) -> bool:
    kind == "user" || kind == "assistant" || kind == "result"

fn fastModeStateSchemaRoute(value: text) -> bool:
    value == "off" || value == "cooldown" || value == "on"

fn sdkCoreSchemasSourceLinesModeled() -> i64:
    SDK_CORE_SCHEMAS_SOURCE_LINES
