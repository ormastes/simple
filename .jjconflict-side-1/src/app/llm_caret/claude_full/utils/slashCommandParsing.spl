class ParsedSlashCommand:
    commandName: text
    args: text
    isMcp: bool

impl ParsedSlashCommand:
    static fn new(commandName: text, args: text, isMcp: bool) -> ParsedSlashCommand:
        ParsedSlashCommand(commandName: commandName, args: args, isMcp: isMcp)

fn parseSlashCommand(input: text) -> Option<ParsedSlashCommand>:
    val trimmedInput = input.trim()
    if not trimmedInput.starts_with("/"):
        return nil

    val withoutSlash = trimmedInput.slice(1, trimmedInput.len())
    val words = withoutSlash.split(" ")
    if words.len() == 0 or words[0] == "":
        return nil

    var commandName = words[0]
    var isMcp = false
    var argsStartIndex = 1

    if words.len() > 1 and words[1] == "(MCP)":
        commandName = commandName + " (MCP)"
        isMcp = true
        argsStartIndex = 2

    ParsedSlashCommand.new(commandName, joinWordsFrom(words, argsStartIndex), isMcp)

fn joinWordsFrom(words: [text], startIndex: i64) -> text:
    var out = ""
    var i = startIndex
    while i < words.len():
        if i > startIndex:
            out = out + " "
        out = out + words[i]
        i = i + 1
    out
