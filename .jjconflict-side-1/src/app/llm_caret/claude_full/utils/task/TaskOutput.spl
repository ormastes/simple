"""
Claude full task output parity surface.
"""

const DEFAULT_MAX_MEMORY = 8388608
const POLL_INTERVAL_MS = 1000
const PROGRESS_TAIL_BYTES = 4096

class TaskOutput:
    taskId: text
    path: text
    stdoutToFile: bool
    stdoutBuffer: text
    stderrBuffer: text
    diskEnabled: bool
    recentLines: [text]
    totalLinesValue: i64
    totalBytesValue: i64
    maxMemory: i64
    progressEvents: [TaskProgressEvent]
    outputFileRedundant: bool
    outputFileSize: i64
    polling: bool

impl TaskOutput:
    static fn new(taskId: text, taskOutputDir: text, stdoutToFile: bool, maxMemory: i64) -> TaskOutput:
        TaskOutput(
            taskId: taskId,
            path: taskOutputDir + "/" + taskId + ".output",
            stdoutToFile: stdoutToFile,
            stdoutBuffer: "",
            stderrBuffer: "",
            diskEnabled: false,
            recentLines: [],
            totalLinesValue: 0,
            totalBytesValue: 0,
            maxMemory: maxMemory,
            progressEvents: [],
            outputFileRedundant: false,
            outputFileSize: 0,
            polling: false,
        )

    fn writeStdout(data: text) -> TaskOutput:
        var next = self.copy()
        next.totalBytesValue = next.totalBytesValue + data.len()
        next.totalLinesValue = next.totalLinesValue + countTaskLines(data)
        next.recentLines = appendRecentTaskLines(next.recentLines, data)
        if next.stdoutToFile:
            next.outputFileSize = next.outputFileSize + data.len()
            return next
        if next.stdoutBuffer.len() + data.len() > next.maxMemory:
            next.diskEnabled = true
        else:
            next.stdoutBuffer = next.stdoutBuffer + data
        next

    fn writeStderr(data: text) -> TaskOutput:
        var next = self.copy()
        if next.stdoutToFile:
            return next
        next.stderrBuffer = next.stderrBuffer + data
        next

    fn startPolling() -> TaskOutput:
        var next = self.copy()
        if next.stdoutToFile:
            next.polling = true
        next

    fn stopPolling() -> TaskOutput:
        var next = self.copy()
        next.polling = false
        next

    fn tickTail(content: text, bytesTotal: i64) -> TaskOutput:
        var next = self.copy()
        next.outputFileSize = bytesTotal
        next.progressEvents.push(TaskProgressEvent.new(lastTaskLines(content, 5), lastTaskLines(content, 100), countTaskLines(content), bytesTotal, false))
        next

    fn getStdout(maxOutputLength: i64) -> text:
        if self.stdoutToFile:
            return tailText(self.stdoutBuffer, maxOutputLength)
        tailText(self.stdoutBuffer, maxOutputLength)

    fn getStderr() -> text:
        if self.stdoutToFile:
            return ""
        self.stderrBuffer

    fn cleanup() -> TaskOutput:
        var next = self.copy()
        next.stdoutBuffer = ""
        next.stderrBuffer = ""
        next.polling = false
        next

    fn copy() -> TaskOutput:
        TaskOutput(
            taskId: self.taskId,
            path: self.path,
            stdoutToFile: self.stdoutToFile,
            stdoutBuffer: self.stdoutBuffer,
            stderrBuffer: self.stderrBuffer,
            diskEnabled: self.diskEnabled,
            recentLines: copyTaskOutputText(self.recentLines),
            totalLinesValue: self.totalLinesValue,
            totalBytesValue: self.totalBytesValue,
            maxMemory: self.maxMemory,
            progressEvents: copyTaskProgress(self.progressEvents),
            outputFileRedundant: self.outputFileRedundant,
            outputFileSize: self.outputFileSize,
            polling: self.polling,
        )

class TaskProgressEvent:
    lastLines: text
    allLines: text
    totalLines: i64
    totalBytes: i64
    isIncomplete: bool

impl TaskProgressEvent:
    static fn new(lastLines: text, allLines: text, totalLines: i64, totalBytes: i64, isIncomplete: bool) -> TaskProgressEvent:
        TaskProgressEvent(lastLines: lastLines, allLines: allLines, totalLines: totalLines, totalBytes: totalBytes, isIncomplete: isIncomplete)

fn countTaskLines(value: text) -> i64:
    if value == "":
        return 0
    value.split("\n").len()

fn appendRecentTaskLines(existing: [text], data: text) -> [text]:
    var out = copyTaskOutputText(existing)
    val lines = data.split("\n")
    var i = 0
    while i < lines.len():
        out.push(lines[i])
        if out.len() > 1000:
            out = dropFirstTaskOutputLine(out)
        i = i + 1
    out

fn dropFirstTaskOutputLine(values: [text]) -> [text]:
    var out: [text] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn lastTaskLines(value: text, maxLines: i64) -> text:
    val lines = value.split("\n")
    var start = lines.len() - maxLines
    if start < 0:
        start = 0
    var selected: [text] = []
    var i = start
    while i < lines.len():
        selected.push(lines[i])
        i = i + 1
    joinTaskOutputLines(selected)

fn tailText(value: text, maxLength: i64) -> text:
    if maxLength <= 0 or value.len() <= maxLength:
        return value
    value.slice(value.len() - maxLength, value.len())

fn joinTaskOutputLines(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + "\n"
        out = out + values[i]
        i = i + 1
    out

fn copyTaskOutputText(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyTaskProgress(values: [TaskProgressEvent]) -> [TaskProgressEvent]:
    var out: [TaskProgressEvent] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn taskOutputSourceLinesModeled() -> i64:
    390
