"""
Computer-use host adapter parity surface.
"""

class DebugLogEntry:
    level: text
    message: text

impl DebugLogEntry:
    static fn new(level: text, message: text) -> DebugLogEntry:
        DebugLogEntry(level: level, message: message)

class DebugLogger:
    entries: [DebugLogEntry]

impl DebugLogger:
    static fn new() -> DebugLogger:
        DebugLogger(entries: [])

    fn silly(message: text) -> DebugLogger:
        self.append("debug", message)

    fn debug(message: text) -> DebugLogger:
        self.append("debug", message)

    fn info(message: text) -> DebugLogger:
        self.append("info", message)

    fn warn(message: text) -> DebugLogger:
        self.append("warn", message)

    fn error(message: text) -> DebugLogger:
        self.append("error", message)

    fn append(level: text, message: text) -> DebugLogger:
        var entries = copyDebugLogEntriesHostAdapter(self.entries)
        entries.push(DebugLogEntry.new(level, message))
        DebugLogger(entries: entries)

class ComputerUseHostAdapterModel:
    serverName: text
    autoUnhideEnabled: bool
    disabled: bool

impl ComputerUseHostAdapterModel:
    static fn new(serverName: text, disabled: bool) -> ComputerUseHostAdapterModel:
        ComputerUseHostAdapterModel(serverName: serverName, autoUnhideEnabled: true, disabled: disabled)

fn copyDebugLogEntriesHostAdapter(values: [DebugLogEntry]) -> [DebugLogEntry]:
    var out: [DebugLogEntry] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

