fn isGeneratedFile(filePath: text) -> bool:
    val normalizedPath = "/" + stripLeadingSlashes(filePath.replace("\\", "/"))
    val fileName = generatedFileBasename(filePath).lower()
    val ext = generatedFileExt(fileName)
    if generatedFileExcludedName(fileName):
        return true
    if generatedFileExcludedExt(ext):
        return true
    if generatedFileExcludedCompoundExt(fileName):
        return true
    if generatedFileExcludedDirectory(normalizedPath):
        return true
    generatedFileExcludedNamePattern(fileName)

fn filterGeneratedFiles(files: [text]) -> [text]:
    var out: [text] = []
    for filePath in files:
        if not isGeneratedFile(filePath):
            out = out + [filePath]
    out

fn generatedFileBasename(filePath: text) -> text:
    val normalized = filePath.replace("\\", "/")
    val found = generatedFileLastIndexOf(normalized, "/")
    if found >= 0:
        return normalized.slice(found + 1, normalized.len())
    normalized

fn stripLeadingSlashes(value: text) -> text:
    var i = 0
    while i < value.len() and value.slice(i, i + 1) == "/":
        i = i + 1
    value.slice(i, value.len())

fn generatedFileExt(fileName: text) -> text:
    val found = generatedFileLastIndexOf(fileName, ".")
    if found >= 0:
        return fileName.slice(found, fileName.len())
    ""

fn generatedFileLastIndexOf(value: text, needle: text) -> i64:
    var found = -1
    var i = 0
    while i + needle.len() <= value.len():
        if value.slice(i, i + needle.len()) == needle:
            found = i
        i = i + 1
    found

fn generatedFileExcludedName(fileName: text) -> bool:
    fileName == "package-lock.json" or fileName == "yarn.lock" or fileName == "pnpm-lock.yaml" or fileName == "bun.lockb" or fileName == "bun.lock" or fileName == "composer.lock" or fileName == "gemfile.lock" or fileName == "cargo.lock" or fileName == "poetry.lock" or fileName == "pipfile.lock" or fileName == "shrinkwrap.json" or fileName == "npm-shrinkwrap.json"

fn generatedFileExcludedExt(ext: text) -> bool:
    ext == ".lock" or ext == ".min.js" or ext == ".min.css" or ext == ".min.html" or ext == ".bundle.js" or ext == ".bundle.css" or ext == ".generated.ts" or ext == ".generated.js" or ext == ".d.ts"

fn generatedFileExcludedCompoundExt(fileName: text) -> bool:
    fileName.ends_with(".min.js") or fileName.ends_with(".min.css") or fileName.ends_with(".min.html") or fileName.ends_with(".bundle.js") or fileName.ends_with(".bundle.css") or fileName.ends_with(".generated.ts") or fileName.ends_with(".generated.js") or fileName.ends_with(".d.ts")

fn generatedFileExcludedDirectory(normalizedPath: text) -> bool:
    normalizedPath.contains("/dist/") or normalizedPath.contains("/build/") or normalizedPath.contains("/out/") or normalizedPath.contains("/output/") or normalizedPath.contains("/node_modules/") or normalizedPath.contains("/vendor/") or normalizedPath.contains("/vendored/") or normalizedPath.contains("/third_party/") or normalizedPath.contains("/third-party/") or normalizedPath.contains("/external/") or normalizedPath.contains("/.next/") or normalizedPath.contains("/.nuxt/") or normalizedPath.contains("/.svelte-kit/") or normalizedPath.contains("/coverage/") or normalizedPath.contains("/__pycache__/") or normalizedPath.contains("/.tox/") or normalizedPath.contains("/venv/") or normalizedPath.contains("/.venv/") or normalizedPath.contains("/target/release/") or normalizedPath.contains("/target/debug/")

fn generatedFileExcludedNamePattern(fileName: text) -> bool:
    if fileName.contains(".min.") or fileName.contains("-min.") or fileName.contains(".bundle.") or fileName.contains(".generated.") or fileName.contains(".gen.") or fileName.contains(".auto.") or fileName.contains("_generated.") or fileName.contains("_gen."):
        return true
    if generatedFileHasAlphaExtAfter(fileName, ".grpc.") or generatedFileHasAlphaExtAfter(fileName, ".swagger.") or generatedFileHasAlphaExtAfter(fileName, ".openapi."):
        return true
    if fileName.ends_with(".pb.go") or fileName.ends_with(".pb.js") or fileName.ends_with(".pb.ts") or fileName.ends_with(".pb.py") or fileName.ends_with(".pb.rb") or fileName.ends_with("_pb.py") or fileName.ends_with("_pb2.py") or fileName.ends_with(".pb.h"):
        return true
    false

fn generatedFileHasAlphaExtAfter(fileName: text, marker: text) -> bool:
    val index = findGeneratedFileText(fileName, marker)
    if index < 0:
        return false
    val start = index + marker.len()
    if start >= fileName.len():
        return false
    var i = start
    while i < fileName.len():
        val ch = fileName.slice(i, i + 1)
        if ch < "a" or ch > "z":
            return false
        i = i + 1
    true

fn findGeneratedFileText(value: text, needle: text) -> i64:
    var i = 0
    while i + needle.len() <= value.len():
        if value.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1
