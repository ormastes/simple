"""
Claude full text highlighting parity surface.
"""

class TextHighlight:
    start: i64
    end: i64
    color: text
    priority: i64

impl TextHighlight:
    static fn new(start: i64, end: i64, color: text, priority: i64) -> TextHighlight:
        TextHighlight(start: start, end: end, color: color, priority: priority)

class TextSegment:
    text: text
    start: i64
    highlight: TextHighlight
    highlighted: bool

impl TextSegment:
    static fn plain(text: text, start: i64) -> TextSegment:
        TextSegment(text: text, start: start, highlight: TextHighlight.new(0, 0, "", 0), highlighted: false)

    static fn marked(text: text, start: i64, highlight: TextHighlight) -> TextSegment:
        TextSegment(text: text, start: start, highlight: highlight, highlighted: true)

class HighlightSegmenter:
    text: text
    visiblePos: i64

impl HighlightSegmenter:
    static fn new(text: text) -> HighlightSegmenter:
        HighlightSegmenter(text: text, visiblePos: 0)

    fn segment(highlights: [TextHighlight]) -> [TextSegment]:
        var segments: [TextSegment] = []
        var pos = 0
        var i = 0
        while i < highlights.len():
            val h = highlights[i]
            if h.start > pos:
                segments.push(TextSegment.plain(self.text.slice(pos, h.start), pos))
            if h.end > h.start:
                segments.push(TextSegment.marked(self.text.slice(h.start, h.end), h.start, h))
                pos = h.end
            i = i + 1
        if pos < self.text.len():
            segments.push(TextSegment.plain(self.text.slice(pos, self.text.len()), pos))
        segments

fn segmentTextByHighlights(textValue: text, highlights: [TextHighlight]) -> [TextSegment]:
    if highlights.len() == 0:
        return [TextSegment.plain(textValue, 0)]
    val resolved = resolveHighlights(highlights)
    HighlightSegmenter.new(textValue).segment(resolved)

fn resolveHighlights(highlights: [TextHighlight]) -> [TextHighlight]:
    var sorted = sortHighlightsByStartAndPriority(highlights)
    var resolved: [TextHighlight] = []
    var i = 0
    while i < sorted.len():
        val h = sorted[i]
        if h.start != h.end and not overlapsAnyHighlight(h, resolved):
            resolved.push(h)
        i = i + 1
    resolved

fn sortHighlightsByStartAndPriority(highlights: [TextHighlight]) -> [TextHighlight]:
    var out = copyHighlights(highlights)
    var i = 0
    while i < out.len():
        var j = i + 1
        while j < out.len():
            if out[j].start < out[i].start or (out[j].start == out[i].start and out[j].priority > out[i].priority):
                val tmp = out[i]
                out[i] = out[j]
                out[j] = tmp
            j = j + 1
        i = i + 1
    out

fn overlapsAnyHighlight(h: TextHighlight, values: [TextHighlight]) -> bool:
    var i = 0
    while i < values.len():
        val v = values[i]
        if (h.start >= v.start and h.start < v.end) or (h.end > v.start and h.end <= v.end) or (h.start <= v.start and h.end >= v.end):
            return true
        i = i + 1
    false

fn copyHighlights(values: [TextHighlight]) -> [TextHighlight]:
    var out: [TextHighlight] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn textHighlightingSourceLinesModeled() -> i64:
    166
