class ModelUpgrade:
    alias: text
    name: text
    multiplier: i64

fn getAvailableUpgrade(model: text, allowOpus1m: bool, allowSonnet1m: bool, opus1mMergeEnabled: bool) -> Option<ModelUpgrade>:
    val normalized = model.lower()
    if normalized.contains("[1m]"):
        return nil
    if normalized.contains("opus") and (allowOpus1m or opus1mMergeEnabled):
        return Some(ModelUpgrade(alias: "opus[1m]", name: "Opus 1M", multiplier: 5))
    if normalized.contains("sonnet") and allowSonnet1m:
        return Some(ModelUpgrade(alias: "sonnet[1m]", name: "Sonnet 1M", multiplier: 5))
    nil

fn getUpgradeMessage(model: text, allowOpus1m: bool, allowSonnet1m: bool, opus1mMergeEnabled: bool, context: text) -> Option<text>:
    match getAvailableUpgrade(model, allowOpus1m, allowSonnet1m, opus1mMergeEnabled):
        Some(upgrade):
            if context == "warning":
                return Some("/model " + upgrade.alias)
            if context == "tip":
                return Some("Tip: You have access to " + upgrade.name + " with " + upgrade.multiplier.to_text() + "x more context")
            nil
        nil:
            nil
