class ObjectGroupByTextGroup:
    key: text
    values: [text]

fn objectGroupByText(items: [text], keys: [text]) -> [ObjectGroupByTextGroup]:
    var groups: [ObjectGroupByTextGroup] = []
    var i = 0
    while i < items.len() and i < keys.len():
        val key = keys[i]
        var found = false
        var j = 0
        while j < groups.len():
            if groups[j].key == key:
                val nextValues = appendText(groups[j].values, items[i])
                groups[j] = ObjectGroupByTextGroup(key: groups[j].key, values: nextValues)
                found = true
            j = j + 1
        if not found:
            groups.push(ObjectGroupByTextGroup(key: key, values: [items[i]]))
        i = i + 1
    groups

fn objectGroupByParityScope() -> text:
    "text values grouped by selected key"

fn appendText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out
