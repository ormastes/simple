"""
Claude full tagged ID parity.
"""

use std.common.encoding.base58.{base58_encode}

fn toTaggedId(tag: text, uuid: text) -> text:
    val bytes = taggedIdUuidBytes(uuid)
    if bytes.len() != 16:
        return ""
    tag + "_01" + taggedIdPadBase58(base58_encode(bytes))

fn taggedIdUuidBytes(uuid: text) -> [u8]:
    val hex = uuid.replace("-", "")
    var out: [u8] = []
    if hex.len() != 32:
        return out
    var i = 0
    while i < hex.len():
        val hi = taggedIdHexValue(hex.slice(i, i + 1))
        val lo = taggedIdHexValue(hex.slice(i + 1, i + 2))
        if hi < 0 or lo < 0:
            return []
        out.push(((hi << 4) | lo) as u8)
        i = i + 2
    out

fn taggedIdHexValue(ch: text) -> i64:
    if ch >= "0" and ch <= "9":
        return ch.ord() - "0".ord()
    if ch >= "a" and ch <= "f":
        return 10 + ch.ord() - "a".ord()
    if ch >= "A" and ch <= "F":
        return 10 + ch.ord() - "A".ord()
    -1

fn taggedIdPadBase58(encoded: text) -> text:
    var out = encoded
    while out.len() < 22:
        out = "1" + out
    out
