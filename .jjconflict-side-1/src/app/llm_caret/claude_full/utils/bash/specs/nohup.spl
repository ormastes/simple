use app.llm_caret.claude_full.utils.bash.specs.types.{BashCommandArgSpec, BashCommandSpec}

fn nohupCommandSpec() -> BashCommandSpec:
    BashCommandSpec.new(
        "nohup",
        "Run a command immune to hangups",
        Some(BashCommandArgSpec.new("command", "Command to run with nohup", nil, nil, Some(true)))
    )
