use app.llm_caret.claude_full.utils.bash.specs.types.{BashCommandArgSpec, BashCommandSpec}

fn sleepCommandSpec() -> BashCommandSpec:
    BashCommandSpec.new(
        "sleep",
        "Delay for a specified amount of time",
        Some(BashCommandArgSpec.new("duration", "Duration to sleep (seconds or with suffix like 5s, 2m, 1h)", Some(false), nil, nil))
    )
