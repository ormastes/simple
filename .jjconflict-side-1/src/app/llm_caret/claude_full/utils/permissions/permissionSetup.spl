const PERMISSION_SETUP_SOURCE_LINES = 1532

fn dangerousPermissionInfoRoute(toolName: text, content: text) -> text:
    toolName + ":" + content

fn isDangerousBashPermissionRoute(toolName: text, content: text) -> bool:
    if toolName != "Bash":
        return false
    val rule = content.trim()
    rule == "" || rule == "*" || rule == "python" || rule == "python:*" || rule == "python*" || rule == "python *" || rule == "python -c *"

fn isDangerousPowerShellPermissionRoute(toolName: text, content: text) -> bool:
    if toolName != "PowerShell":
        return false
    val rule = content.trim().to_lower()
    rule == "*" || rule == "iex:*" || rule.starts_with("start-process") || rule.starts_with("add-type")

fn isDangerousTaskPermissionRoute(toolName: text, content: text) -> bool:
    val normalized = toolName.to_lower()
    normalized == "task" || normalized == "agent"

fn permissionSetupSourceLinesModeled() -> i64:
    PERMISSION_SETUP_SOURCE_LINES
