const PLUGIN_LOADER_SOURCE_LINES = 3302

fn sanitizePluginPathPart(value: text) -> text:
    var out = value.replace(" ", "-")
    out = out.replace("@", "-")
    out.replace("/", "-")

fn getPluginCachePathRoute(root: text) -> text:
    root + "/plugins/cache"

fn getVersionedCachePathInRoute(base: text, pluginName: text, marketplace: text, version: text) -> text:
    if marketplace != "":
        return base + "/" + sanitizePluginPathPart(marketplace) + "/" + sanitizePluginPathPart(pluginName) + "/" + sanitizePluginPathPart(version)
    base + "/" + sanitizePluginPathPart(pluginName) + "/" + sanitizePluginPathPart(version)

fn getVersionedCachePathRoute(root: text, pluginName: text, marketplace: text, version: text) -> text:
    getVersionedCachePathInRoute(getPluginCachePathRoute(root), pluginName, marketplace, version)

fn getVersionedZipCachePathRoute(root: text, pluginName: text, marketplace: text, version: text) -> text:
    getVersionedCachePathRoute(root, pluginName, marketplace, version) + ".zip"

fn probeSeedCacheAnyVersionRoute(seedCount: i64, versionDirCount: i64) -> text:
    if seedCount == 1 && versionDirCount == 1:
        return "seed cache version path"
    if seedCount == 0:
        return "no seed cache"
    "ambiguous seed cache"

fn getLegacyCachePathRoute(root: text, pluginName: text) -> text:
    getPluginCachePathRoute(root) + "/" + sanitizePluginPathPart(pluginName)

fn resolvePluginPathRoute(hasVersioned: bool, hasLegacy: bool, hasVersion: bool) -> text:
    if hasVersioned:
        return "versioned cache path"
    if hasLegacy:
        return "legacy cache path"
    if hasVersion:
        return "computed versioned cache path"
    "computed legacy cache path"

fn copyDirRoute(hasNestedFiles: bool, preservesContents: bool) -> text:
    if hasNestedFiles && preservesContents:
        return "copy nested tree"
    if preservesContents:
        return "copy files"
    "copy failed"

fn copyPluginToVersionedCacheRoute(hasCacheHit: bool, seedOnly: bool, copiedEmpty: bool) -> text:
    if hasCacheHit:
        return "return existing cached path"
    if seedOnly:
        return "return seed cache path"
    if copiedEmpty:
        return "empty plugin cache error"
    "copy plugin to versioned cache"

fn validateGitUrlRoute(url: text) -> text:
    if url.starts_with("https://") || url.starts_with("http://") || url.starts_with("file://") || url.starts_with("git@"):
        return "git url accepted"
    "git url rejected"

fn installFromNpmRoute(hasPackage: bool, installOk: bool) -> text:
    if !hasPackage:
        return "npm package missing"
    if installOk:
        return "npm install cached plugin"
    "npm install failed"

fn pluginLoaderSourceLinesModeled() -> i64:
    PLUGIN_LOADER_SOURCE_LINES
