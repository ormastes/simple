"""
Fixed-size circular buffer parity for Claude Code's `utils/CircularBuffer.ts`.
"""

class CircularBuffer:
    capacity: i64
    buffer: [text]
    head: i64
    size: i64

impl CircularBuffer:
    static fn new(capacity: i64) -> CircularBuffer:
        CircularBuffer(capacity: capacity, buffer: [], head: 0, size: 0)

    me add(item: text) -> ():
        if me.capacity <= 0:
            return
        if me.buffer.len() < me.capacity:
            me.buffer = me.buffer + [""]
        me.buffer[me.head] = item
        me.head = (me.head + 1) % me.capacity
        if me.size < me.capacity:
            me.size = me.size + 1

    me addAll(items: [text]) -> ():
        for item in items:
            me.add(item)

    me getRecent(count: i64) -> [text]:
        if count <= 0 or me.capacity <= 0:
            return []
        val start = if me.size < me.capacity: 0 else: me.head
        val available = if count < me.size: count else: me.size
        var result: [text] = []
        var i = 0
        while i < available:
            val index = (start + me.size - available + i) % me.capacity
            result = result + [me.buffer[index]]
            i = i + 1
        result

    me toArray() -> [text]:
        if me.size == 0 or me.capacity <= 0:
            return []
        val start = if me.size < me.capacity: 0 else: me.head
        var result: [text] = []
        var i = 0
        while i < me.size:
            val index = (start + i) % me.capacity
            result = result + [me.buffer[index]]
            i = i + 1
        result

    me clear() -> ():
        me.buffer = []
        me.head = 0
        me.size = 0

    me length() -> i64:
        me.size

fn circularBufferNew(capacity: i64) -> CircularBuffer:
    CircularBuffer.new(capacity)

