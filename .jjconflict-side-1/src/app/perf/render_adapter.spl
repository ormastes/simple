# Performance Profiling Render Adapter
#
# Bridges the perf app to the shared ui.render contract.
# Produces text (profiling table) and html (flame chart style report)
# views of performance profiling results.

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.fmt.{fmt_duration_ms, fmt_percent, fmt_number}
use app.ui.render.html.{html_page, html_metric_card, html_grid, html_card,
    html_escape, css_reset, css_dark_theme, css_light_theme}
use app.ui.render.progress.{progress_bar_html}
use app.ui.render.table.{TableBuilder, ALIGN_LEFT, ALIGN_RIGHT}

# =========================================================================
# Data Types
# =========================================================================

class PerfEntry:
    name: text
    total_ms: i64
    self_ms: i64
    call_count: i64
    percent_total: f64

class PerfSummary:
    total_duration_ms: i64
    total_functions: i64
    hottest_function: text
    entries: [PerfEntry]

# =========================================================================
# Render Adapter Entry Point
# =========================================================================

fn render_perf(config: RenderConfig, data: PerfSummary) -> RenderResult:
    """Render profiling results via the shared render contract.

    Produces a timing table for text output and a flame chart style
    report with bars for HTML output.
    """
    match config.format:
        "html":
            return render_as_html(data, config)
        "both":
            val text_out = render_as_text(data, config)
            val html_out = render_as_html(data, config)
            return RenderResult.both(text_out.text_output, html_out.html_output)
        _:
            return render_as_text(data, config)

# =========================================================================
# Text Rendering
# =========================================================================

fn render_as_text(data: PerfSummary, config: RenderConfig) -> RenderResult:
    """Render profiling results as a plain text table with timing info."""
    var lines: [text] = []

    lines.push("Performance Profile")
    lines.push("  Total duration: {fmt_duration_ms(data.total_duration_ms)}")
    lines.push("  Functions profiled: {fmt_number(data.total_functions)}")
    lines.push("  Hottest function: {data.hottest_function}")
    lines.push("")

    # Build profiling results table
    var table = TableBuilder.new(["Function", "Total", "Self", "Calls", "% Total"])
    table = table.set_alignment(1, ALIGN_RIGHT)
    table = table.set_alignment(2, ALIGN_RIGHT)
    table = table.set_alignment(3, ALIGN_RIGHT)
    table = table.set_alignment(4, ALIGN_RIGHT)
    table = table.set_max_width(0, 40)

    for entry in data.entries:
        table = table.add_row([
            entry.name,
            fmt_duration_ms(entry.total_ms),
            fmt_duration_ms(entry.self_ms),
            fmt_number(entry.call_count),
            fmt_percent(entry.percent_total)
        ])

    lines.push(table.build())

    return RenderResult.text(join_lines(lines))

# =========================================================================
# HTML Rendering
# =========================================================================

fn render_as_html(data: PerfSummary, config: RenderConfig) -> RenderResult:
    """Render profiling results as an HTML flame chart style report."""
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    var css = ""
    css = "{css}{css_reset()}\n{theme_css}\n"
    css = "{css}.container { max-width: 1200px; margin: 0 auto; }\n"
    css = "{css}.card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }\n"
    css = "{css}.card h3 { margin-bottom: 8px; }\n"
    css = "{css}.card-body { color: var(--text-dim); font-size: 14px; }\n"
    css = "{css}.value { font-size: 28px; font-weight: bold; color: var(--blue); }\n"
    css = "{css}.sub { font-size: 13px; color: var(--text-dim); margin-top: 4px; }\n"
    css = "{css}.flame-row { display: flex; align-items: center; gap: 12px; margin: 6px 0; padding: 8px 12px;\n"
    css = "{css}  background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; }\n"
    css = "{css}.flame-row:hover { border-color: var(--blue); }\n"
    css = "{css}.flame-name { flex: 0 0 280px; font-weight: 500; font-size: 13px; overflow: hidden;\n"
    css = "{css}  text-overflow: ellipsis; white-space: nowrap; }\n"
    css = "{css}.flame-bar-wrap { flex: 1; }\n"
    css = "{css}.flame-bar { height: 20px; border-radius: 3px; min-width: 2px; transition: width 0.3s; }\n"
    css = "{css}.flame-stats { flex: 0 0 200px; font-size: 12px; color: var(--text-dim); text-align: right; }\n"
    css = "{css}table { border-collapse: collapse; width: 100%; margin-top: 16px; }\n"
    css = "{css}th, td { border: 1px solid var(--border); padding: 8px; font-size: 13px; }\n"
    css = "{css}th { background: var(--bg-card); text-align: left; }\n"

    var body = ""
    body = "{body}<div class=\"container\">\n"
    body = "{body}<h1>Performance Profile</h1>\n"

    # Summary metric cards
    val summary_cards = [
        html_metric_card("Total Duration", fmt_duration_ms(data.total_duration_ms), "wall clock time"),
        html_metric_card("Functions", fmt_number(data.total_functions), "profiled"),
        html_metric_card("Hottest", data.hottest_function, "most CPU time")
    ]
    body = "{body}{html_grid(3, \"12px\", summary_cards)}\n"

    # Flame chart style bars
    body = "{body}<h2 style=\"margin:20px 0 12px\">CPU Time Breakdown</h2>\n"

    for entry in data.entries:
        val bar_width = entry.percent_total
        val bar_color = flame_color(entry.percent_total)
        val cpu_ms = entry.self_ms
        val total_pct_i64 = (entry.percent_total * 10.0) as i64
        val cpu_bar_width = if total_pct_i64 > 1000: 100 else: total_pct_i64 / 10

        body = "{body}<div class=\"flame-row\">\n"
        body = "{body}  <div class=\"flame-name\">{html_escape(entry.name)}</div>\n"
        body = "{body}  <div class=\"flame-bar-wrap\">\n"
        body = "{body}    <div class=\"flame-bar\" style=\"width:{cpu_bar_width}%; background:{bar_color}\"></div>\n"
        body = "{body}  </div>\n"
        body = "{body}  <div class=\"flame-stats\">{fmt_duration_ms(entry.self_ms)} self | {fmt_duration_ms(entry.total_ms)} total | {fmt_number(entry.call_count)} calls | {fmt_percent(entry.percent_total)}</div>\n"
        body = "{body}</div>\n"

    # Detailed table
    body = "{body}<h2 style=\"margin:20px 0 12px\">Detailed Results</h2>\n"
    var table = TableBuilder.new(["Function", "Total", "Self", "Calls", "% Total"])
    table = table.set_alignment(1, ALIGN_RIGHT)
    table = table.set_alignment(2, ALIGN_RIGHT)
    table = table.set_alignment(3, ALIGN_RIGHT)
    table = table.set_alignment(4, ALIGN_RIGHT)
    for entry in data.entries:
        table = table.add_row([
            entry.name,
            fmt_duration_ms(entry.total_ms),
            fmt_duration_ms(entry.self_ms),
            fmt_number(entry.call_count),
            fmt_percent(entry.percent_total)
        ])
    body = "{body}{table.build_html()}\n"

    body = "{body}</div>\n"

    return RenderResult.html(html_page("Performance Profile", css, body))

# =========================================================================
# Helpers
# =========================================================================

fn flame_color(percent: f64) -> text:
    """Get a flame chart color based on CPU percentage."""
    if percent >= 50.0:
        return "var(--red, #f85149)"
    if percent >= 20.0:
        return "var(--yellow, #d29922)"
    if percent >= 5.0:
        return "var(--blue, #58a6ff)"
    return "var(--green, #3fb950)"

fn join_lines(lines: [text]) -> text:
    var result = ""
    var first = true
    for line in lines:
        if not first:
            result = "{result}\n"
        result = "{result}{line}"
        first = false
    return result
