# Manifest Daemon — Background watcher that keeps test manifest up to date
#
# Polls test/src/doc directories for changes every 2 seconds.
# When changes are detected, incrementally updates the manifest file.
# The test runner reads this manifest for near-instant discovery.


use std.daemon_sdk.daemon.{DaemonRunner, daemon_runner_start}
use std.daemon_sdk.types.{
    DaemonConfig, DaemonRequest, DaemonResponse,
    daemon_response_new
}
use test_manifest.{
    TestManifest, MANIFEST_PATH, manifest_load, manifest_save
}
use test_manifest_scanner.{manifest_full_scan, manifest_incremental_update}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_sleep_ms(ms: i64)
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# ============================================================================
# Constants
# ============================================================================

val MANIFEST_DAEMON_LOCK = ".simple/test-manifest-daemon.lock"
val MANIFEST_DAEMON_POLL_MS = 2000
val MANIFEST_SCAN_DIRS: [text] = ["test/"]

# ============================================================================
# Manifest Daemon
# ============================================================================

class ManifestDaemon:
    runner: DaemonRunner
    current_manifest: TestManifest
    scan_dirs: [text]

impl ManifestDaemon:
    fn is_running() -> bool:
        self.runner.is_running()

    me run():
        # Initial full scan
        self.current_manifest = manifest_full_scan(self.scan_dirs)
        manifest_save(self.current_manifest, MANIFEST_PATH)

        # Poll loop
        while self.runner.is_running():
            rt_sleep_ms(MANIFEST_DAEMON_POLL_MS)

            # Incremental update
            val updated = manifest_incremental_update(self.current_manifest, self.scan_dirs)

            # Only save if something changed (entry count or timestamp)
            val entries_changed = updated.entries.len() != self.current_manifest.entries.len()
            val sd_changed = updated.sdoctest_entries.len() != self.current_manifest.sdoctest_entries.len()
            val ts_changed = updated.scan_timestamp != self.current_manifest.scan_timestamp
            if entries_changed or sd_changed or ts_changed:
                manifest_save(updated, MANIFEST_PATH)

            self.current_manifest = updated

            # Handle any stop requests via daemon runner
            self.runner.run_poll_cycle(handle_manifest_request)

    me shutdown():
        self.runner.shutdown()

# ============================================================================
# Request Handler (minimal — just supports status/stop)
# ============================================================================

fn handle_manifest_request(req: DaemonRequest) -> DaemonResponse:
    if req.request_type == "stop":
        return daemon_response_new(req.id, "stopped", "Manifest daemon stopping")
    if req.request_type == "status":
        return daemon_response_new(req.id, "ok", "Manifest daemon running")
    daemon_response_new(req.id, "error", "Unknown request type")

# ============================================================================
# Factory
# ============================================================================

fn manifest_daemon_start() -> ManifestDaemon:
    rt_mkdir_p(".simple")

    val config = DaemonConfig(
        name: "manifest-daemon",
        lock_path: MANIFEST_DAEMON_LOCK,
        request_dir: ".simple/manifest-requests",
        response_dir: ".simple/manifest-responses",
        poll_interval_ms: MANIFEST_DAEMON_POLL_MS,
        request_timeout_ms: 5000,
        max_concurrent: 1
    )
    val runner = daemon_runner_start(config)

    ManifestDaemon(
        runner: runner,
        current_manifest: manifest_load(MANIFEST_PATH),
        scan_dirs: MANIFEST_SCAN_DIRS
    )

# ============================================================================
# Auto-start Helper
# ============================================================================

fn manifest_daemon_ensure_running():
    # Check if daemon is already running via lock file
    if rt_file_exists(MANIFEST_DAEMON_LOCK):
        val pid_str = rt_file_read_text(MANIFEST_DAEMON_LOCK) ?? ""
        if pid_str.trim() != "":
            # Check if PID is still alive
            val pid = pid_str.trim()
            val (out, err, code) = rt_process_run("kill", ["-0", pid])
            if code == 0:
                return  # Daemon already running

    # Not running — start it in background
    # The daemon will be started as part of the test runner process
    # For now, just do a one-shot manifest refresh if stale
    val manifest = manifest_load(MANIFEST_PATH)
    if not manifest_is_fresh_quick(manifest):
        val fresh = manifest_full_scan(MANIFEST_SCAN_DIRS)
        manifest_save(fresh, MANIFEST_PATH)

fn manifest_is_fresh_quick(manifest: TestManifest) -> bool:
    if manifest.scan_timestamp == 0:
        return false
    val now = rt_time_now_unix_micros()
    val age = now - manifest.scan_timestamp
    # Consider fresh if less than 5 minutes old
    age < 300000000
