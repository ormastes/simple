fn _triple_quote_count(line: text) -> i64:
    val stripped = line.replace("\"\"\"", "")
    (line.len() - stripped.len()) / 3


fn _is_spec_import(line: text) -> bool:
    if line.starts_with(" ") or line.starts_with("\t"):
        return false
    val statement = line.trim()
    val use_import = statement == "use std.spec" or statement.starts_with("use std.spec.")
    val legacy_import = statement == "import std.spec" or statement.starts_with("import std.spec.")
    use_import or legacy_import


fn check_sspec_guidance(source: text, path: text) -> text:
    var has_spec_import = false
    var has_describe = false
    var in_triple_string = false
    for line in source.split("\n"):
        val triple_quotes = _triple_quote_count(line)
        if in_triple_string or triple_quotes > 0:
            if triple_quotes % 2 == 1:
                in_triple_string = not in_triple_string
            continue
        val trimmed = line.trim()
        if _is_spec_import(line):
            has_spec_import = true
        if not line.starts_with(" ") and not line.starts_with("\t") and trimmed.starts_with("describe ") and trimmed.ends_with(":"):
            has_describe = true
    if has_spec_import and has_describe:
        return "error[E-SSPEC-CHECK]: SSpec command-block files must use `bin/simple test {path} --mode=interpreter`"
    ""
