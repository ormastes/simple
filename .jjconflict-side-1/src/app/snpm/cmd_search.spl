# snpm search — Search registry for packages

use app.snpm.config.{SnpmConfig}

fn cmd_search(config: SnpmConfig, args: [text]):
    """Search the registry or show package info."""
    if args.len() == 0:
        print "Usage: snpm search <query>"
        return

    var show_info = false
    var query = ""
    var i = 0
    while i < args.len():
        if args[i] == "--info":
            show_info = true
        else:
            query = args[i]
        i = i + 1

    if query == "":
        print "snpm: missing search query"
        return

    if show_info:
        print "{query}:"
        print "  registry: {config.registry_url}/{query}"
        print "  (use 'snpm install {query}' to install)"
        return

    print "Searching for '{query}' on {config.registry_url}..."
    print ""
    print "  (registry search not yet connected)"
    print "  Try: snpm install {query}"
