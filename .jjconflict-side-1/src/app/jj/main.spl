# JJ (Jujutsu) VCS Integration - Main entry point
#
# Provides built-in JJ version control operations for the Simple compiler CLI.
# Dispatches to submodules: status, commit, sync, log, diff
#
# Usage:
#   simple jj status              Show JJ status with structured output
#   simple jj commit "message"    Create new commit
#   simple jj describe "message"  Update working copy description
#   simple jj sync                Full sync workflow (fetch, rebase, push)
#   simple jj log                 Show commit log
#   simple jj diff                Show diff
#   simple jj diff --stat         Show diff statistics

use app.jj.status.{run_status}
use app.jj.commit.{run_commit}
use app.jj.sync.{run_sync}
use app.jj.log.{run_log}
use app.jj.diff.{run_diff}

fn print_jj_help():
    print "Simple JJ (Jujutsu) VCS Integration"
    print ""
    print "Usage: simple jj <command> [args...]"
    print ""
    print "Commands:"
    print "  status                      Show working copy status"
    print "  commit \"message\"            Create new commit with message"
    print "  describe \"message\"          Update working copy description"
    print "  describe -r REV \"message\"   Update specific revision description"
    print "  sync                        Full sync: fetch, rebase, bookmark, push"
    print "  sync --no-push              Sync without pushing"
    print "  log                         Show commit log (last 10)"
    print "  log -n N                    Show last N commits"
    print "  log -r REVSET              Show specific revset"
    print "  diff                        Show working copy diff"
    print "  diff --stat                 Show diff statistics"
    print "  diff -r REV                 Show diff for specific revision"
    print ""
    print "File count safety:"
    print "  The sync command checks file counts before/after rebase."
    print "  If >20% of files are lost, it warns and aborts the push."
    print "  Use --force to override."

fn handle_jj(args: [text]) -> i64:
    """Main dispatcher for jj subcommands"""
    if args.len() == 0:
        print_jj_help()
        return 0

    val subcmd = args[0]
    val sub_args = if args.len() > 1: args[1:] else: []

    match subcmd:
        case "status" | "st":
            return run_status(sub_args)

        case "commit":
            # Prepend "commit" so run_commit knows the subcmd
            var commit_args = ["commit"]
            for a in sub_args:
                commit_args.push(a)
            return run_commit(commit_args)

        case "describe" | "desc":
            var desc_args = ["describe"]
            for a in sub_args:
                desc_args.push(a)
            return run_commit(desc_args)

        case "sync":
            return run_sync(sub_args)

        case "log":
            return run_log(sub_args)

        case "diff":
            return run_diff(sub_args)

        case "-h" | "--help" | "help":
            print_jj_help()
            return 0

        case _:
            print "Unknown jj command: {subcmd}"
            print ""
            print_jj_help()
            return 1
