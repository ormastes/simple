# LLVM Lib Type Mapper
#
# Maps MIR types to LLVM C API type handles (i64 = LLVMTypeRef).
# Uses the LLVM C API FFI bindings from std.ffi.llvm.

use compiler.mir.mir_data.*
use std.ffi.llvm.{
    llvm_void_type_in_context, llvm_int1_type_in_context,
    llvm_int8_type_in_context, llvm_int16_type_in_context,
    llvm_int32_type_in_context, llvm_int64_type_in_context,
    llvm_float_type_in_context, llvm_double_type_in_context,
    llvm_pointer_type, llvm_function_type,
    llvm_struct_type_in_context, llvm_array_type2
}

# ============================================================================
# LlvmLibTypeMapper
# ============================================================================

class LlvmLibTypeMapper:
    ctx: i64          # LLVMContextRef
    target_bits: i64  # 32 or 64

    static fn create(ctx: i64) -> LlvmLibTypeMapper:
        LlvmLibTypeMapper(ctx: ctx, target_bits: 64)

    static fn create_for_bits(ctx: i64, bits: i64) -> LlvmLibTypeMapper:
        LlvmLibTypeMapper(ctx: ctx, target_bits: bits)

    fn map_type(ty: MirType) -> i64:
        match ty.kind:
            case I8: llvm_int8_type_in_context(self.ctx)
            case I16: llvm_int16_type_in_context(self.ctx)
            case I32: llvm_int32_type_in_context(self.ctx)
            case I64: llvm_int64_type_in_context(self.ctx)
            case U8: llvm_int8_type_in_context(self.ctx)
            case U16: llvm_int16_type_in_context(self.ctx)
            case U32: llvm_int32_type_in_context(self.ctx)
            case U64: llvm_int64_type_in_context(self.ctx)
            case F32: llvm_float_type_in_context(self.ctx)
            case F64: llvm_double_type_in_context(self.ctx)
            case Bool: llvm_int1_type_in_context(self.ctx)
            case Char: llvm_int32_type_in_context(self.ctx)
            case Unit: llvm_void_type_in_context(self.ctx)
            case Ptr(_, _): self.ptr_type()
            case Ref(_, _): self.ptr_type()
            case FuncPtr(_): self.ptr_type()
            case Array(elem, size): llvm_array_type2(self.map_type(elem), size)
            case Tuple(elements): self.map_tuple(elements)
            case Struct(_): self.ptr_type()
            case Enum(_): self.ptr_type()
            case Function(_, _): self.ptr_type()
            case Never: llvm_void_type_in_context(self.ctx)
            case Opaque(_): self.ptr_type()
            case Promise(_): self.ptr_type()
            case Generator(_, _): self.ptr_type()
            case ActorType(_): self.ptr_type()
            case Slice(_): self.ptr_type()
            case Union(_): self.ptr_type()
            case _: self.native_int_type()

    fn map_tuple(elements: [MirType]) -> i64:
        if elements.len() == 0:
            return llvm_struct_type_in_context(self.ctx, [], false)
        var elem_types: [i64] = []
        for elem in elements:
            elem_types.push(self.map_type(elem))
        llvm_struct_type_in_context(self.ctx, elem_types, false)

    fn ptr_type() -> i64:
        # Opaque pointers (LLVM 15+): pointer to i8 in address space 0
        llvm_pointer_type(llvm_int8_type_in_context(self.ctx), 0)

    fn native_int_type() -> i64:
        if self.target_bits == 32:
            llvm_int32_type_in_context(self.ctx)
        else:
            llvm_int64_type_in_context(self.ctx)

    fn is_float_mir_type(ty: MirType) -> bool:
        match ty.kind:
            case F32 | F64: true
            case _: false

    fn is_int_mir_type(ty: MirType) -> bool:
        match ty.kind:
            case I8 | I16 | I32 | I64 | U8 | U16 | U32 | U64 | Bool | Char: true
            case _: false

    fn is_void_mir_type(ty: MirType) -> bool:
        match ty.kind:
            case Unit | Never: true
            case _: false


