# VHDL helper subprogram support.

use compiler.mir.mir_data.*

struct VhdlHelperNamePlan:
    source_name: text
    vhdl_name: text

fn vhdl_sanitize_identifier(name: text) -> text:
    """Return a deterministic VHDL-safe identifier fragment."""
    var result = name.trim()
    if result.len() == 0:
        result = "helper"
    result = result.replace(" ", "_")
    result = result.replace("-", "_")
    result = result.replace(".", "_")
    result = result.replace(":", "_")
    result = result.replace("/", "_")
    result = result.replace("\\", "_")
    result = result.replace("(", "_")
    result = result.replace(")", "_")
    result = result.replace("[", "_")
    result = result.replace("]", "_")
    result

fn vhdl_function_is_hardware_entity(func: MirFunction) -> bool:
    if func.has_vhdl_metadata:
        return func.vhdl_metadata.is_hardware
    false

fn vhdl_helper_is_procedure(func: MirFunction) -> bool:
    func.signature.return_type.kind == MirTypeKind.Unit

fn vhdl_helper_collision_message(name: text, first: text, second: text) -> text:
    "Duplicate VHDL helper subprogram name after sanitization: `{name}` from `{first}` and `{second}`"

