# VHDL Target Profiles — synthesis-policy selection for production VHDL.

enum VhdlResetPreference:
    Sync
    Async
    None

struct VhdlTargetProfile:
    name: text
    vhdl_standard: text
    attribute_style: text
    memory_template_style: text
    dsp_template_style: text
    reset_preference: VhdlResetPreference
    allow_process_all: bool
    allow_initial_values: bool

fn vhdl_generic_2008_profile() -> VhdlTargetProfile:
    VhdlTargetProfile(
        name: "generic-vhdl-2008",
        vhdl_standard: "2008",
        attribute_style: "standard",
        memory_template_style: "portable",
        dsp_template_style: "portable",
        reset_preference: Sync,
        allow_process_all: true,
        allow_initial_values: false
    )

fn vhdl_ghdl_yosys_profile() -> VhdlTargetProfile:
    VhdlTargetProfile(
        name: "ghdl-yosys",
        vhdl_standard: "2008",
        attribute_style: "yosys",
        memory_template_style: "ghdl-yosys",
        dsp_template_style: "yosys",
        reset_preference: Sync,
        allow_process_all: false,
        allow_initial_values: false
    )

fn vhdl_vivado_profile() -> VhdlTargetProfile:
    VhdlTargetProfile(
        name: "vivado",
        vhdl_standard: "2008",
        attribute_style: "xilinx",
        memory_template_style: "xilinx",
        dsp_template_style: "xilinx",
        reset_preference: Sync,
        allow_process_all: true,
        allow_initial_values: true
    )

fn vhdl_quartus_profile() -> VhdlTargetProfile:
    VhdlTargetProfile(
        name: "quartus",
        vhdl_standard: "2008",
        attribute_style: "intel",
        memory_template_style: "intel",
        dsp_template_style: "intel",
        reset_preference: Sync,
        allow_process_all: true,
        allow_initial_values: true
    )

fn vhdl_yosys_nextpnr_profile() -> VhdlTargetProfile:
    VhdlTargetProfile(
        name: "yosys-nextpnr",
        vhdl_standard: "2008",
        attribute_style: "yosys",
        memory_template_style: "yosys",
        dsp_template_style: "yosys",
        reset_preference: Sync,
        allow_process_all: false,
        allow_initial_values: false
    )

fn vhdl_openroad_asic_profile() -> VhdlTargetProfile:
    VhdlTargetProfile(
        name: "openroad-asic",
        vhdl_standard: "2008",
        attribute_style: "asic",
        memory_template_style: "explicit-flops",
        dsp_template_style: "standard-cell",
        reset_preference: Async,
        allow_process_all: false,
        allow_initial_values: false
    )

fn vhdl_target_profile(name: text) -> VhdlTargetProfile:
    if name == "ghdl-yosys":
        return vhdl_ghdl_yosys_profile()
    if name == "vivado":
        return vhdl_vivado_profile()
    if name == "quartus":
        return vhdl_quartus_profile()
    if name == "yosys-nextpnr":
        return vhdl_yosys_nextpnr_profile()
    if name == "openroad-asic":
        return vhdl_openroad_asic_profile()
    return vhdl_generic_2008_profile()

fn vhdl_profile_supports_vendor_attributes(profile: VhdlTargetProfile) -> bool:
    profile.attribute_style != "standard"
