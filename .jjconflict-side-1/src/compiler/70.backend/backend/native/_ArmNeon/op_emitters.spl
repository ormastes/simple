# ARM NEON — vector op emitters (min/max/cmp/crc32)
use compiler.backend.backend.native.arm_neon.*
# ARM NEON Code Generation
#
# Generates ARM NEON SIMD instructions for vector operations.
# Supports ARMv8-A NEON (128-bit Q registers, 32-bit opcodes).
#
# NEON Instructions use fixed 32-bit encoding:
#   FADD.4S Vd, Vn, Vm (add 4 single-precision floats)
#
# Instruction structure (32-bit):
#   [cond(4)] [opcode bits(24)] [Rd(4)] [Rn(4)] [Rm(4)]
#   For NEON: fixed encoding with register fields in specific positions
#
# Q registers (128-bit): Q0-Q15 (encoded as V0-V15 in ARMv8-A)
# D registers (64-bit): D0-D31 (lower half of Q registers)
#
# ARMv8-A NEON uses "Advanced SIMD" encoding with:
#   - Fixed 32-bit instruction size
#   - Vector registers V0-V31 (we use V0-V15 for Q register compatibility)
#   - Scalar and vector forms

use compiler.backend.native.mach_inst.{MachReg, MachRegKind, physical_reg, reg_id, Operand, OperandKind, MachInst, MachBlock, MachFunction, MachModule}
use compiler.backend.native.mach_inst.{AARCH64_Q0, AARCH64_Q1, AARCH64_Q2, AARCH64_Q3, AARCH64_Q4, AARCH64_Q5, AARCH64_Q6, AARCH64_Q7}
use compiler.backend.native.mach_inst.{AARCH64_Q8, AARCH64_Q9, AARCH64_Q10, AARCH64_Q11, AARCH64_Q12, AARCH64_Q13, AARCH64_Q14, AARCH64_Q15}
use compiler.backend.native.mach_inst.{AARCH64_Q_ALLOCATABLE}

# ============================================================================
# ARM NEON Register IDs (Re-export mach_inst constants for compatibility)
# ============================================================================

fn emit_neon_vminq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FMIN Vd.4S, Vn.4S, Vm.4S — minimum of 4 single-precision floats (NaN-propagating).
    Base opcode 0x4EA0F400: Q=1, U=0, sz=1, size=00 (f32), opcode=11110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.135 FMIN (vector) — NaN-propagating per §C7.2.135
    # For IEEE minimumNumber (non-NaN preference) use FMINNM §C7.2.137 (follow-up).
    # Canonical bytes (V0,V0,V0): 0x00 0xF4 0xA0 0x4E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fmin(rd, rn, rm)

fn emit_neon_vmaxq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FMAX Vd.4S, Vn.4S, Vm.4S — maximum of 4 single-precision floats (NaN-propagating).
    Base opcode 0x4E20F400: Q=1, U=0, sz=0, size=00 (f32), opcode=11110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.136 FMAX (vector) — NaN-propagating per §C7.2.136
    # For IEEE maximumNumber (non-NaN preference) use FMAXNM §C7.2.138 (follow-up).
    # Canonical bytes (V0,V0,V0): 0x00 0xF4 0x20 0x4E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fmax(rd, rn, rm)

fn emit_neon_vcgtq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FCMGT Vd.4S, Vn.4S, Vm.4S — compare greater-than for 4 f32 lanes.
    Produces all-ones mask per lane where Vn > Vm.
    Base opcode 0x6EA0E400: Q=1, U=1, sz=1, size=00 (f32), opcode=11100.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.111 FCMGT (vector, register form)
    # V-25 POLARITY: for cmp_lt(a, b), call emit_neon_vcgtq_f32(rd, b_reg, a_reg).
    #   The encoder passes (rn, rm) to hardware as Vn, Vm — operand swap is caller's job.
    # Canonical bytes (V0,V0,V0): 0x00 0xE4 0xA0 0x6E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fcmgt(rd, rn, rm)

fn emit_neon_vcgeq_f32(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit FCMGE Vd.4S, Vn.4S, Vm.4S — compare greater-or-equal for 4 f32 lanes.
    Produces all-ones mask per lane where Vn >= Vm.
    Base opcode 0x6E20E400: Q=1, U=1, sz=0, size=00 (f32), opcode=11100.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.110 FCMGE (vector, register form)
    # V-25 NOTE: for cmp_le(a, b), call emit_neon_vcgeq_f32(rd, b_reg, a_reg).
    # Canonical bytes (V0,V0,V0): 0x00 0xE4 0x20 0x6E  (llvm-mc VERIFIED)
    """
    neon_encode_3reg_4s_fcmge(rd, rn, rm)

# ============================================================================
# CRC32/CRC32C — ARMv8.1 Scalar CRC Instructions
# ============================================================================

fn _crc32_encode(base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """Encode CRC32 instruction: base + Rm*65536 + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rm % 32) * 65536 + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_neon_crc32b(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32B Wd, Wn, Wm — CRC-32 on byte input.
    # ARMv8 ARM §C7.2.36 CRC32B; base 0x1AC04000
    # Canonical (W0,W0,W0): 0x00 0x40 0xC0 0x1A
    """
    _crc32_encode(0x1AC04000, rd, rn, rm)

fn emit_neon_crc32h(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32H Wd, Wn, Wm — CRC-32 on halfword input.
    # ARMv8 ARM §C7.2.36 CRC32H; base 0x1AC04400
    # Canonical (W0,W0,W0): 0x00 0x44 0xC0 0x1A
    """
    _crc32_encode(0x1AC04400, rd, rn, rm)

fn emit_neon_crc32w(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32W Wd, Wn, Wm — CRC-32 on word input.
    # ARMv8 ARM §C7.2.36 CRC32W; base 0x1AC04800
    # Canonical (W0,W0,W0): 0x00 0x48 0xC0 0x1A
    """
    _crc32_encode(0x1AC04800, rd, rn, rm)

fn emit_neon_crc32x(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32X Wd, Wn, Xm — CRC-32 on doubleword input.
    # ARMv8 ARM §C7.2.36 CRC32X; base 0x9AC04C00
    # Canonical (W0,W0,X0): 0x00 0x4C 0xC0 0x9A
    """
    _crc32_encode(0x9AC04C00, rd, rn, rm)

fn emit_neon_crc32cb(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32CB Wd, Wn, Wm — CRC-32C (Castagnoli) on byte input.
    # ARMv8 ARM §C7.2.37 CRC32CB; base 0x1AC05000
    # Canonical (W0,W0,W0): 0x00 0x50 0xC0 0x1A
    """
    _crc32_encode(0x1AC05000, rd, rn, rm)

fn emit_neon_crc32ch(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32CH Wd, Wn, Wm — CRC-32C on halfword input.
    # ARMv8 ARM §C7.2.37 CRC32CH; base 0x1AC05400
    # Canonical (W0,W0,W0): 0x00 0x54 0xC0 0x1A
    """
    _crc32_encode(0x1AC05400, rd, rn, rm)

fn emit_neon_crc32cw(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32CW Wd, Wn, Wm — CRC-32C on word input.
    # ARMv8 ARM §C7.2.37 CRC32CW; base 0x1AC05800
    # Canonical (W0,W0,W0): 0x00 0x58 0xC0 0x1A
    """
    _crc32_encode(0x1AC05800, rd, rn, rm)

fn emit_neon_crc32cx(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit CRC32CX Wd, Wn, Xm — CRC-32C on doubleword input.
    # ARMv8 ARM §C7.2.37 CRC32CX; base 0x9AC05C00
    # Canonical (W0,W0,X0): 0x00 0x5C 0xC0 0x9A
    """
    _crc32_encode(0x9AC05C00, rd, rn, rm)

# ============================================================================
# SDOT / UDOT — Integer Dot Product (ARMv8.2-DotProd)
# ============================================================================

fn _dot_encode(base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """Encode SDOT/UDOT: base + Rm*65536 + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rm % 32) * 65536 + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_neon_sdot_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit SDOT Vd.4S, Vn.16B, Vm.16B — signed int8 dot product, 4 lanes.
    # ARMv8 ARM §C7.2.258 SDOT (vector); Q=1, U=0, size=10
    # Canonical (V0,V0,V0): 0x00 0x94 0x80 0x4E  [llvm-mc VERIFIED]
    """
    _dot_encode(0x4E809400, rd, rn, rm)

fn emit_neon_udot_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit UDOT Vd.4S, Vn.16B, Vm.16B — unsigned int8 dot product, 4 lanes.
    # ARMv8 ARM §C7.2.363 UDOT (vector); Q=1, U=1, size=10
    # Canonical (V0,V0,V0): 0x00 0x94 0x80 0x6E  [llvm-mc VERIFIED]
    """
    _dot_encode(0x6E809400, rd, rn, rm)

fn emit_neon_sdot_2s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit SDOT Vd.2S, Vn.8B, Vm.8B — signed int8 dot product, 2 lanes (64-bit).
    # ARMv8 ARM §C7.2.258 SDOT (vector); Q=0, U=0, size=10
    # Canonical (V0,V0,V0): 0x00 0x94 0x80 0x0E
    """
    _dot_encode(0x0E809400, rd, rn, rm)

fn emit_neon_udot_2s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit UDOT Vd.2S, Vn.8B, Vm.8B — unsigned int8 dot product, 2 lanes (64-bit).
    # ARMv8 ARM §C7.2.363 UDOT (vector); Q=0, U=1, size=10
    # Canonical (V0,V0,V0): 0x00 0x94 0x80 0x2E
    """
    _dot_encode(0x2E809400, rd, rn, rm)

# ============================================================================
# SQADD / UQADD / SQSUB / UQSUB — Saturating Arithmetic (NEON)
# ============================================================================

fn _sat_encode(base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """Encode saturating op: base + Rm*65536 + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rm % 32) * 65536 + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_neon_sqadd_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit SQADD Vd.4S, Vn.4S, Vm.4S — signed saturating add, 4×32-bit.
    # ARMv8 ARM §C7.2.274 SQADD; Q=1, U=0, size=10
    # Canonical (V0,V0,V0): 0x00 0x0C 0xA0 0x4E  [llvm-mc VERIFIED]
    """
    _sat_encode(0x4EA00C00, rd, rn, rm)

fn emit_neon_uqadd_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit UQADD Vd.4S, Vn.4S, Vm.4S — unsigned saturating add, 4×32-bit.
    # ARMv8 ARM §C7.2.363 UQADD; Q=1, U=1, size=10
    # Canonical (V0,V0,V0): 0x00 0x0C 0xA0 0x6E  [llvm-mc VERIFIED]
    """
    _sat_encode(0x6EA00C00, rd, rn, rm)

fn emit_neon_sqsub_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit SQSUB Vd.4S, Vn.4S, Vm.4S — signed saturating subtract, 4×32-bit.
    # ARMv8 ARM §C7.2.277 SQSUB; Q=1, U=0, size=10
    # Canonical (V0,V0,V0): 0x00 0x2C 0xA0 0x4E  [llvm-mc VERIFIED]
    """
    _sat_encode(0x4EA02C00, rd, rn, rm)

fn emit_neon_uqsub_4s(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit UQSUB Vd.4S, Vn.4S, Vm.4S — unsigned saturating subtract, 4×32-bit.
    # ARMv8 ARM §C7.2.366 UQSUB; Q=1, U=1, size=10
    # Canonical (V0,V0,V0): 0x00 0x2C 0xA0 0x6E  [llvm-mc VERIFIED]
    """
    _sat_encode(0x6EA02C00, rd, rn, rm)

# ============================================================================
# BFDOT / BFMMLA / BFCVTN / BFCVTN2 — BFloat16 Instructions (ARMv8.6-A)
# ============================================================================
#
# BF16 register arguments are raw vector register indices 0-31.
# All return [i64] (4 bytes, little-endian).
#
# Encodings verified from ARMv8 ARM §C7.2.19-21.

fn _bf16_3reg_encode(base: i64, rd: i64, rn: i64, rm: i64) -> [i64]:
    """Encode 3-register BF16 op: base + Rm*65536 + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rm % 32) * 65536 + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn _bf16_2reg_encode(base: i64, rd: i64, rn: i64) -> [i64]:
    """Encode 2-register BF16 op: base + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_bfdot_v4bf16(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit BFDOT Vd.2S, Vn.4H, Vm.4H — BF16 dot product accumulate, 64-bit (Q=0).
    # ARMv8 ARM §C7.2.20 BFDOT (vector); Q=0, size=01
    # Base 0x2E40FC00
    # Canonical (V0,V0,V0): 0x00 0xFC 0x40 0x2E
    """
    _bf16_3reg_encode(0x2E40FC00, rd, rn, rm)

fn emit_bfmmla_v4bf16(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    Emit BFMMLA Vd.4S, Vn.8H, Vm.8H — BF16 matrix multiply-accumulate, 128-bit (Q=1).
    # ARMv8 ARM §C7.2.21 BFMMLA; Q=1, size=01
    # Base 0x6E40EC00
    # Canonical (V0,V0,V0): 0x00 0xEC 0x40 0x6E
    """
    _bf16_3reg_encode(0x6E40EC00, rd, rn, rm)

fn emit_bfcvtn_v4bf16(rd: i64, rn: i64) -> [i64]:
    """
    Emit BFCVTN Vd.4H, Vn.4S — narrow float32→bfloat16 into lower half (Q=0).
    # ARMv8 ARM §C7.2.19 BFCVTN; Q=0
    # Base 0x0EA16800
    # Canonical (V0,V0): 0x00 0x68 0xA1 0x0E
    """
    _bf16_2reg_encode(0x0EA16800, rd, rn)

fn emit_bfcvtn2_v8bf16(rd: i64, rn: i64) -> [i64]:
    """
    Emit BFCVTN2 Vd.8H, Vn.4S — narrow float32→bfloat16 into upper half (Q=1).
    # ARMv8 ARM §C7.2.19 BFCVTN2; Q=1
    # Base 0x4EA16800
    # Canonical (V0,V0): 0x00 0x68 0xA1 0x4E
    """
    _bf16_2reg_encode(0x4EA16800, rd, rn)

# ============================================================================
# FCVTN / FCVTL / FCVTZS / FCVTZU — FP16 Conversion Instructions (ARMv8.2-A)
# ============================================================================
#
# These are 2-register (Vd, Vn) Advanced SIMD instructions.
# Encoding: base + (rn % 32) * 32 + (rd % 32) → 4 LE bytes.
# All accept raw register indices 0-31 and return [i64] (4 bytes, little-endian).
#
# ARMv8.2-A FP16 extension required for FCVTN/FCVTL .4H/.8H variants.
# FCVTZS/FCVTZU operate on .4S (f32→int32) and do not require FP16 extension.

fn _fp16_2reg_encode(base: i64, rd: i64, rn: i64) -> [i64]:
    """Encode 2-register FP16 conversion: base + Rn*32 + Rd → 4 LE bytes."""
    val word = base + (rn % 32) * 32 + (rd % 32)
    val b0 = word % 256
    val b1 = (word / 256) % 256
    val b2 = (word / 65536) % 256
    val b3 = (word / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_fcvtn_4h(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTN Vd.4H, Vn.4S — narrow float32→float16 into lower half (Q=0).
    Base opcode 0x0E216800: Q=0, U=0, sz=0, opcode=10110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.67 FCVTN (vector, .4H form)
    # Encoding: 0_Q_0_01110_0_sz_10001_11010_00_Rn_Rd
    # Q=0 (64-bit result), sz=0 (fp16 output from fp32 input)
    # Base word: 0x0E216800 → LE: 0x00 0x68 0x21 0x0E
    # Canonical: FCVTN V0.4H, V0.4S → [0x00, 0x68, 0x21, 0x0E]
    """
    _fp16_2reg_encode(0x0E216800, rd, rn)

fn emit_fcvtn2_8h(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTN2 Vd.8H, Vn.4S — narrow float32→float16 into upper half (Q=1).
    Base opcode 0x4E216800: Q=1, U=0, sz=0, opcode=10110.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.67 FCVTN (vector, .8H form, FCVTN2)
    # Q=1 (128-bit, writes upper half of Vd.8H)
    # Base word: 0x4E216800 → LE: 0x00 0x68 0x21 0x4E
    # Canonical: FCVTN2 V0.8H, V0.4S → [0x00, 0x68, 0x21, 0x4E]
    """
    _fp16_2reg_encode(0x4E216800, rd, rn)

fn emit_fcvtl_4s(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTL Vd.4S, Vn.4H — widen float16→float32 from lower half (Q=0).
    Base opcode 0x0E217800: Q=0, U=0, sz=0, opcode=10111.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.66 FCVTL (vector, .4S form)
    # Q=0 (reads lower 4 lanes of Vn.4H, widens to Vd.4S)
    # Base word: 0x0E217800 → LE: 0x00 0x78 0x21 0x0E
    # Canonical: FCVTL V0.4S, V0.4H → [0x00, 0x78, 0x21, 0x0E]
    """
    _fp16_2reg_encode(0x0E217800, rd, rn)

fn emit_fcvtl2_4s(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTL2 Vd.4S, Vn.8H — widen float16→float32 from upper half (Q=1).
    Base opcode 0x4E217800: Q=1, U=0, sz=0, opcode=10111.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.66 FCVTL (vector, .4S form, FCVTL2)
    # Q=1 (reads upper 4 lanes of Vn.8H, widens to Vd.4S)
    # Base word: 0x4E217800 → LE: 0x00 0x78 0x21 0x4E
    # Canonical: FCVTL2 V0.4S, V0.8H → [0x00, 0x78, 0x21, 0x4E]
    """
    _fp16_2reg_encode(0x4E217800, rd, rn)

fn emit_fcvtzs_4s(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTZS Vd.4S, Vn.4S — float32→signed int32, truncate toward zero, 4 lanes.
    Base opcode 0x4EA1B800: Q=1, U=0, sz=1 (f32), opcode=11011.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.68 FCVTZS (vector, integer, .4S form)
    # Q=1 (128-bit), U=0 (signed), sz=1 (single-precision input)
    # Base word: 0x4EA1B800 → LE: 0x00 0xB8 0xA1 0x4E
    # Canonical: FCVTZS V0.4S, V0.4S → [0x00, 0xB8, 0xA1, 0x4E]
    """
    _fp16_2reg_encode(0x4EA1B800, rd, rn)

fn emit_fcvtzu_4s(rd: i64, rn: i64) -> [i64]:
    """
    Emit FCVTZU Vd.4S, Vn.4S — float32→unsigned int32, truncate toward zero, 4 lanes.
    Base opcode 0x6EA1B800: Q=1, U=1, sz=1 (f32), opcode=11011.
    Raw register indices 0-31.

    # ARMv8 ARM §C7.2.69 FCVTZU (vector, integer, .4S form)
    # Q=1 (128-bit), U=1 (unsigned), sz=1 (single-precision input)
    # Base word: 0x6EA1B800 → LE: 0x00 0xB8 0xA1 0x6E
    # Canonical: FCVTZU V0.4S, V0.4S → [0x00, 0xB8, 0xA1, 0x6E]
    """
    _fp16_2reg_encode(0x6EA1B800, rd, rn)

# ============================================================================
# Exports
# ============================================================================
