# Class Reference Model — object registry for the HIR interpreter backend
#
# Task #112. The interpreter's `Value` is a value-enum, so `Value.Struct`
# instances get value semantics (copied on bind/assign) — correct for STRUCTS.
# CLASSES must instead have REFERENCE semantics: two holders of the same class
# instance observe each other's mutations, and a class element read out of an
# array shares with the array slot.
#
# The model: a class instance lives as a record in a single shared `ObjectStore`
# (held by the interpreter's `Environment`, which is the proven shared
# reference-typed state carrier — see env.spl). A `Value.Object` carries only an
# integer HANDLE (the record's index). Copying a `Value.Object` copies the int
# handle, so every copy dereferences the SAME store record — reference semantics
# fall out for free, independent of struct/Dict value-vs-reference behavior on
# stage4. Field mutations go through the store, so all holders see them.

use compiler.backend.backend_types.*

# A single class-instance record: its class name plus its mutable field map.
struct ObjectRecord:
    class_name: text
    fields: Dict<text, Value>

# Shared object registry. Handle == index into `records`. Mirrors Environment's
# reference-typed `me`-method style (array-field reassignment persists in place)
# so all EvalContext copies that share one Environment share one store.
struct ObjectStore:
    records: [ObjectRecord]

impl ObjectStore:
    static fn new() -> ObjectStore:
        ObjectStore(records: [])

    # Allocate a new object record and return its handle (index).
    me alloc(class_name: text, fields: Dict<text, Value>) -> i64:
        val handle = self.records.len()
        self.records = self.records.push(ObjectRecord(class_name: class_name, fields: fields))
        handle

    fn has_object(handle: i64) -> bool:
        handle >= 0 and handle < self.records.len()

    fn class_name_of(handle: i64) -> text:
        if handle < 0 or handle >= self.records.len():
            return ""
        val rec: ObjectRecord = self.records[handle]
        rec.class_name

    # Dereference a field. `.has()` + `[]` is the stage4-proven Dict read idiom
    # (bare Dict.get is unreliable — bug doc iter 11/12).
    fn get_field(handle: i64, name: text) -> Value?:
        if handle < 0 or handle >= self.records.len():
            return nil
        val rec: ObjectRecord = self.records[handle]
        val f: Dict<text, Value> = rec.fields
        if f.has(name):
            return Some(f[name])
        nil

    # Mutate a field in the shared record. Read-modify-write with a single-level
    # array element assignment (mirrors env.spl's `self.scopes[i][...] = ...`),
    # so the mutation is visible through every holder of the handle.
    me set_field(handle: i64, name: text, value: Value):
        if handle < 0 or handle >= self.records.len():
            return
        var rec: ObjectRecord = self.records[handle]
        rec.fields[name] = value
        self.records[handle] = rec

export ObjectRecord, ObjectStore
