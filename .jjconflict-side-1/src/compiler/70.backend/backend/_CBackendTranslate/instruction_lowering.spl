# Part 2 of src/compiler/70.backend/backend/c_backend_translate.spl
use compiler.backend.backend.c_backend_translate.*
# C Backend - MIR to C++20 Translation (MirToC class)
#
# Contains the MirToC class with core translation methods.
# Translates MIR to C++20 source code that links against runtime.h.
# Follows the pattern of MirToLlvm in llvm_ir_builder.spl.
# Generated code uses the spl_ runtime API for strings, arrays, dicts.
#
# Lower-level helpers (translate_binop, translate_unaryop, translate_container_call,
# translate_composite_const, translate_operand, translate_const_value, etc.) are in
# c_backend_translate_ops.spl (impl MirToC continued there).
#
# Output is C++20 suitable for clang++/g++ compilation:
#   clang++ -std=c++20 -O2 generated.cpp runtime.c -o output

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock, MirAsmOperand, MirPlace}
use compiler.mir.mir_types.{LocalId}
use compiler.backend.c_type_mapper.{CTypeMapper}
use compiler.backend.c_ir_builder.{CIRBuilder, escape_c_string}
use compiler.backend.backend.backend_types.{CodegenTarget, CompileOptions, CompiledModule}
use compiler.backend.error_conversion.{is_result_type, map_result_type, emit_error_type_definitions, emit_error_converting_wrapper}
use compiler.backend.callback_trampoline.{is_callback_type, build_callback_typedef, emit_callback_typedef, emit_callback_trampoline, CallbackTypedef}
use compiler.types.type_layout.{LayoutVerification, LayoutAttr, layoutattr_c_repr, verify_c_layout, generate_runtime_layout_asserts}
from hir_definitions import {HirField}
from hir_types import {HirType}

# ============================================================================
# Utility
# ============================================================================

# Sanitize a SPL type name containing generics to a valid C identifier.
# Examples: "Box<i64>" -> "Box_i64", "Dict<Text, i64>" -> "Dict_Text_i64"

impl MirToC:
    me translate_instruction(inst: MirInst):
        """Translate a MIR instruction to C++."""
        match inst.kind:
            # === Constants ===
            case Const(dest, value, type_):
                if self.translate_composite_const(dest, value):
                    pass_dn
                else:
                    val dest_name = self.get_local(dest.id)
                    val const_val = self.translate_const_value(value)
                    self.builder.emit_assign(dest_name, const_val)

            # === Copy/Move ===
            case Copy(dest, src):
                val dest_name = self.get_local(dest.id)
                val src_name = self.get_local(src.id)
                self.builder.emit_assign(dest_name, src_name)

            case Move(dest, src):
                val dest_name = self.get_local(dest.id)
                val src_name = self.get_local(src.id)
                self.builder.emit_assign(dest_name, src_name)

            # === Binary Operations ===
            case BinOp(dest, op, left, right):
                self.translate_binop(dest, op, left, right)

            # === Unary Operations ===
            case UnaryOp(dest, op, operand):
                self.translate_unaryop(dest, op, operand)

            # === Memory Operations ===
            case Alloc(dest, type_):
                val size = self.type_mapper.size_of(type_)
                val slot_name = self.ensure_stack_slot(dest.id, size)
                self.emit_pointer_assign(dest.id, slot_name)

            case Load(dest, ptr):
                val dest_name = self.get_local(dest.id)
                val ptr_val = self.translate_operand(ptr)
                val ty = self.get_local_type(dest.id)
                self.builder.emit_assign(dest_name, r"*(" + ty + r"*)" + ptr_val)

            case Store(ptr, value):
                val ptr_val = self.translate_operand(ptr)
                val value_val = self.translate_operand(value)
                val ty = self.get_operand_type(value)
                self.builder.emit(r"*(" + ty + r"*)" + ptr_val + r" = " + value_val + r";")

            case GetElementPtr(dest, base, indices):
                val dest_name = self.get_local(dest.id)
                val base_val = self.translate_operand(base)
                # Simple single-index GEP -> pointer arithmetic
                if indices.len() == 1:
                    val idx_val = self.translate_operand(indices[0])
                    self.builder.emit_assign(dest_name, r"(void*)((char*)" + base_val + r" + " + idx_val + r" * 8)")
                else:
                    self.builder.emit_assign(dest_name, r"(void*)" + base_val)
                    self.builder.emit_comment(r"GEP with " + indices.len() + r" indices")

            # === Function Calls ===
            case Call(dest, func, args):
                val func_val = self.translate_operand(func)
                # Try container call interception first
                if self.translate_container_call(func_val, dest, args):
                    pass_dn
                else:
                    var arg_vals: [text] = []
                    for arg in args:
                        arg_vals = arg_vals.push(self.translate_operand(arg))
                    val args_str = arg_vals.join(", ")
                    if dest.?:
                        val dest_name = self.get_local(dest.unwrap().id)
                        val ret_ty = self.get_local_type(dest.unwrap().id)
                        self.builder.emit_assign(dest_name, func_val + r"(" + args_str + r")")
                    else:
                        self.builder.emit(func_val + r"(" + args_str + r");")

            case CallIndirect(dest, ptr, args, sig):
                val ptr_val = self.translate_operand(ptr)
                var arg_vals: [text] = []
                for arg in args:
                    arg_vals = arg_vals.push(self.translate_operand(arg))
                val args_str = arg_vals.join(", ")
                val ret_ty = if dest.?:
                    self.get_local_type(dest.unwrap().id)
                else:
                    if sig.return_type == nil: "void" else: self.type_mapper.map_type(sig.return_type)
                if dest.?:
                    val dest_name = self.get_local(dest.unwrap().id)
                    self.builder.emit_assign(dest_name, r"((" + ret_ty + r"(*)(...))(" + ptr_val + r"))(" + args_str + r")")
                else:
                    self.builder.emit(r"((" + ret_ty + r"(*)(...))(" + ptr_val + r"))(" + args_str + r");")

            # === Casts ===
            case Cast(dest, operand, target):
                val dest_name = self.get_local(dest.id)
                val operand_val = self.translate_operand(operand)
                val target_ty = self.type_mapper.map_type(target)
                self.builder.emit_assign(dest_name, r"(" + target_ty + r")" + operand_val)

            case Bitcast(dest, operand, target):
                val dest_name = self.get_local(dest.id)
                val operand_val = self.translate_operand(operand)
                val target_ty = self.type_mapper.map_type(target)
                self.builder.emit_assign(dest_name, r"(" + target_ty + r")" + operand_val)

            # === Aggregates ===
            case Aggregate(dest, kind, operands):
                val num_fields = operands.len()
                val byte_size = num_fields * 8
                val slot_name = self.ensure_stack_slot(dest.id, byte_size)
                self.builder.emit_comment(r"aggregate construction (" + num_fields + r" fields, " + byte_size + r" bytes) [stack slot]")
                self.emit_pointer_assign(dest.id, slot_name)
                var field_idx = 0
                for op in operands:
                    val field_val = self.translate_operand(op)
                    self.builder.emit(r"((int64_t*)(void*)" + slot_name + r")[" + field_idx + r"] = (int64_t)" + field_val + r";")
                    field_idx = field_idx + 1

            case GetField(dest, base, field):
                val dest_name = self.get_local(dest.id)
                val base_val = self.translate_operand(base)
                self.builder.emit_assign(dest_name, r"((int64_t*)" + base_val + r")[" + field + r"]")

            case SetField(base, field, value):
                val base_val = self.translate_operand(base)
                val value_val = self.translate_operand(value)
                self.builder.emit(r"((int64_t*)" + base_val + r")[" + field + r"] = " + value_val + r";")

            # === Intrinsics ===
            case Intrinsic(dest, name, args):
                # Delegated to a method (like BinOp -> translate_binop) so the bulk-op
                # lowering logic lives in a plain method body, not a deeply-nested match arm.
                self.translate_intrinsic(dest, name, args)

            case CheckedBinOp(dest, op, left, right):
                self.translate_binop(dest, op, left, right)

            # === Pipeline operators ===
            case PipeForward(dest, value, func):
                val dest_name = self.get_local(dest.id)
                val value_val = self.translate_operand(value)
                val func_val = self.translate_operand(func)
                val ret_ty = self.get_local_type(dest.id)
                self.builder.emit_assign(dest_name, r"((" + ret_ty + r"(*)(int64_t))(" + func_val + r"))(" + value_val + r")")

            case Compose(dest, f, g, forward):
                val dest_name = self.get_local(dest.id)
                val f_val = self.translate_operand(f)
                val g_val = self.translate_operand(g)
                self.builder.emit_assign(dest_name, "(void*)0")
                self.builder.emit_comment("compose (runtime support needed)")

            case Parallel(dest, funcs):
                val dest_name = self.get_local(dest.id)
                self.builder.emit_assign(dest_name, "(void*)0")
                self.builder.emit_comment(r"parallel (" + funcs.len() + r" functions)")

            case LayerConnect(dest, layer1, layer2):
                val dest_name = self.get_local(dest.id)
                val l1_val = self.translate_operand(layer1)
                val l2_val = self.translate_operand(layer2)
                self.builder.emit_assign(dest_name, "(void*)0")
                self.builder.emit_comment("layer connect (~>)")

            # === Inline Assembly ===
            case InlineAsm(asm_template, is_volatile, inputs, outputs, clobbers):
                val volatile_str = if is_volatile: " volatile" else: ""
                self.builder.emit(r"#if !(defined(_MSC_VER) && !defined(__clang__))")

                # Convert template placeholders {0},{1} to GCC %0,%1 syntax
                var c_template = asm_template
                var placeholder_idx = 0
                while placeholder_idx < 20:
                    c_template = c_template.replace("{" + placeholder_idx.to_string() + "}", "%" + placeholder_idx.to_string())
                    placeholder_idx = placeholder_idx + 1

                # Build output constraints: "=r" (var), "=&r" (late_out_var)
                var output_parts: [text] = []
                var out_idx = 0
                while out_idx < outputs.len():
                    val out_op: MirAsmOperand = outputs[out_idx]
                    val constraint = self.asm_constraint_for_c(out_op.kind, out_op.location)
                    val operand_val = self.translate_operand(out_op.operand)
                    output_parts.push("\"" + constraint + "\" (" + operand_val + ")")
                    out_idx = out_idx + 1

                # Build input constraints: "r" (expr), "m" (addr)
                var input_parts: [text] = []
                var in_idx = 0
                while in_idx < inputs.len():
                    val in_op: MirAsmOperand = inputs[in_idx]
                    val constraint = self.asm_constraint_for_c(in_op.kind, in_op.location)
                    val operand_val = self.translate_operand(in_op.operand)
                    input_parts.push("\"" + constraint + "\" (" + operand_val + ")")
                    in_idx = in_idx + 1

                # Build clobber list: "memory", "cc", register names
                var clobber_parts: [text] = []
                for clob in clobbers:
                    clobber_parts.push("\"" + clob + "\"")

                # Emit GCC extended asm
                var asm_str = "__asm__" + volatile_str + " (\n"
                asm_str = asm_str + "    \"" + c_template + "\""

                # Output operands section
                asm_str = asm_str + "\n    : " + output_parts.join(", ")

                # Input operands section
                asm_str = asm_str + "\n    : " + input_parts.join(", ")

                # Clobber section
                if clobber_parts.len() > 0:
                    asm_str = asm_str + "\n    : " + clobber_parts.join(", ")

                asm_str = asm_str + "\n);"
                self.builder.emit(asm_str)
                self.builder.emit(r"#endif")

            # === Debug/Nop ===
            case DebugValue(local, name):
                pass_dn

            case Nop:
                pass_dn

            # === Async/Actor (unsupported on C backend) ===
            case CreatePromise(dest, body, result_type):
                self.emit_unsupported_panic("C backend does not support async CreatePromise lowering")

            case Await(dest, promise):
                self.emit_unsupported_panic("C backend does not support async Await lowering")

            case Yield(value):
                self.emit_unsupported_panic("C backend does not support async Yield lowering")

            case Spawn(dest, handler, args):
                self.emit_unsupported_panic("C backend does not support async Spawn lowering")

            case Send(target, message):
                self.emit_unsupported_panic("C backend does not support actor Send lowering")

            case Receive(dest, timeout):
                self.emit_unsupported_panic("C backend does not support actor Receive lowering")

            # === Borrow checking ===
            case Ref(dest, borrow_kind, place):
                val dest_name = self.get_local(dest.id)
                val place_val = self.get_local(place.local.id)
                self.builder.emit_assign(dest_name, place_val)

            # === GPU instructions (unsupported on C backend) ===
            case GpuKernelDef(name):
                self.emit_unsupported_panic("C backend does not support GPU kernel definitions")
            case GpuLaunch(args):
                self.emit_unsupported_panic("C backend does not support GPU launches")
            case GpuGlobalId(dest, dim):
                self.emit_unsupported_panic("C backend does not support GpuGlobalId")
            case GpuLocalId(dest, dim):
                self.emit_unsupported_panic("C backend does not support GpuLocalId")
            case GpuBlockId(dest, dim):
                self.emit_unsupported_panic("C backend does not support GpuBlockId")
            case GpuBlockDim(dest, dim):
                self.emit_unsupported_panic("C backend does not support GpuBlockDim")
            case GpuGridDim(dest, dim):
                self.emit_unsupported_panic("C backend does not support GpuGridDim")
            case GpuBarrier(scope):
                self.emit_unsupported_panic("C backend does not support GpuBarrier")
            case GpuMemFence(scope):
                self.emit_unsupported_panic("C backend does not support GpuMemFence")
            case GpuSharedAlloc(dest, type_, size):
                self.emit_unsupported_panic("C backend does not support GpuSharedAlloc")
            case GpuAtomicOp(dest, op, ptr, value):
                self.emit_unsupported_panic("C backend does not support GpuAtomicOp")
            case GpuAtomicCas(dest, ptr, expected, desired):
                self.emit_unsupported_panic("C backend does not support GpuAtomicCas")

            # === VHDL instructions (unsupported on C backend) ===
            case VhdlProcess(kind, body_block):
                self.emit_unsupported_panic("C backend does not support VHDL process lowering")
            case VhdlSignalAssign(target, value, delay_ns):
                self.emit_unsupported_panic("C backend does not support VHDL signal assignment lowering")
            case VhdlVarAssign(target, value):
                self.emit_unsupported_panic("C backend does not support VHDL variable assignment lowering")
            case VhdlPortMap(entity, instance, connections):
                self.emit_unsupported_panic("C backend does not support VHDL port maps")
            case VhdlResize(dest, operand, new_width, signed):
                self.emit_unsupported_panic("C backend does not support VHDL resize")
            case VhdlSlice(dest, signal, hi, lo):
                self.emit_unsupported_panic("C backend does not support VHDL slice")
            case VhdlConcat(dest, parts):
                self.emit_unsupported_panic("C backend does not support VHDL concat")

            # === SIMD instructions (unsupported on C backend) ===
            case SimdAddF32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD add_f32x4")
            case SimdSubF32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD sub_f32x4")
            case SimdMulF32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD mul_f32x4")
            case SimdDivF32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD div_f32x4")
            case SimdFmaF32x4(dest, a, b, c):
                self.emit_unsupported_panic("C backend does not support SIMD fma_f32x4")
            case SimdAddF32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD add_f32x8")
            case SimdSubF32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD sub_f32x8")
            case SimdMulF32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD mul_f32x8")
            case SimdDivF32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD div_f32x8")
            case SimdFmaF32x8(dest, a, b, c):
                self.emit_unsupported_panic("C backend does not support SIMD fma_f32x8")
            case SimdAddF64x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD add_f64x4")
            case SimdSubF64x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD sub_f64x4")
            case SimdMulF64x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD mul_f64x4")
            case SimdDivF64x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD div_f64x4")
            case SimdFmaF64x4(dest, a, b, c):
                self.emit_unsupported_panic("C backend does not support SIMD fma_f64x4")
            case SimdAddI32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD add_i32x4")
            case SimdSubI32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD sub_i32x4")
            case SimdMulI32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD mul_i32x4")
            case SimdXorI32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD xor_i32x4")
            case SimdAndI32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD and_i32x4")
            case SimdOrI32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD or_i32x4")
            case SimdShlI32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD shl_i32x4")
            case SimdShrI32x4(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD shr_i32x4")
            case SimdAddI32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD add_i32x8")
            case SimdSubI32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD sub_i32x8")
            case SimdMulI32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD mul_i32x8")
            case SimdXorI32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD xor_i32x8")
            case SimdAndI32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD and_i32x8")
            case SimdOrI32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD or_i32x8")
            case SimdShlI32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD shl_i32x8")
            case SimdShrI32x8(dest, a, b):
                self.emit_unsupported_panic("C backend does not support SIMD shr_i32x8")
            case SimdHaddF32x4(dest, a):
                self.emit_unsupported_panic("C backend does not support SIMD hadd_f32x4")
            case SimdHmaxF32x4(dest, a):
                self.emit_unsupported_panic("C backend does not support SIMD hmax_f32x4")
            case SimdHminF32x4(dest, a):
                self.emit_unsupported_panic("C backend does not support SIMD hmin_f32x4")

    # === Terminators ===

    me translate_terminator(term: MirTerminator):
        match term:
            case Ret(value):
                if value.?:
                    val val_str = self.translate_operand(value.unwrap())
                    self.builder.emit_return(Some(val_str))
                else:
                    self.builder.emit_return(nil)

            case Goto(target):
                self.builder.emit_goto(r"bb" + target.id)

            case If(cond, then_, else_):
                val cond_val = self.translate_operand(cond)
                self.builder.emit_if(cond_val + r" != 0", r"bb" + then_.id, r"bb" + else_.id)

            case Switch(value, targets, default):
                val discr_val = self.translate_operand(value)
                self.builder.emit_switch_start(discr_val)
                for switch_case in targets:
                    self.builder.emit_switch_case(r"" + switch_case.value, r"bb" + switch_case.target.id)
                self.builder.emit_switch_default(r"bb" + default.id)
                self.builder.emit_switch_end()

            case Unreachable:
                self.builder.emit(r"SPL_UNREACHABLE();")

            case Abort(message):
                self.builder.emit(r"spl_panic(" + "\"" + message + "\"" + r");")

            case CallTerminator(dest, func, args, normal, unwind):
                val func_val = self.translate_operand(func)
                var arg_vals: [text] = []
                for arg in args:
                    arg_vals = arg_vals.push(self.translate_operand(arg))
                val args_str = arg_vals.join(", ")
                if dest.?:
                    val dest_name = self.get_local(dest.unwrap().id)
                    self.builder.emit_assign(dest_name, func_val + r"(" + args_str + r")")
                else:
                    self.builder.emit(func_val + r"(" + args_str + r");")
                self.builder.emit_goto(r"bb" + normal.id)

    # ================================================================
    # Shared Library Preamble
    # ================================================================

    me emit_shared_library_preamble():
        """Emit shared library lifecycle declarations when SPL_SHARED_LIBRARY is defined."""
        self.builder.emit_raw(r"#ifdef SPL_SHARED_LIBRARY")
        self.builder.emit_raw(r"static int spl_library_initialized = 0;")
        self.builder.emit_raw(r"extern " + "\"C\"" + r" void spl_library_init(void) {")
        self.builder.emit_raw(r"    if (spl_library_initialized) return;")
        self.builder.emit_raw(r"    spl_library_initialized = 1;")
        self.builder.emit_raw(r"}")
        self.builder.emit_raw(r"extern " + "\"C\"" + r" void spl_library_shutdown(void) {")
        self.builder.emit_raw(r"    if (!spl_library_initialized) return;")
        self.builder.emit_raw(r"    spl_library_initialized = 0;")
        self.builder.emit_raw(r"}")
        self.builder.emit_raw(r"")
        self.builder.emit_raw(r"// Auto-init for shared libraries")
        self.builder.emit_raw(r"#if defined(_WIN32)")
        self.builder.emit_raw(r"#include <windows.h>")
        self.builder.emit_raw(r"BOOL APIENTRY DllMain(HMODULE hModule, DWORD reason, LPVOID lpReserved) {")
        self.builder.emit_raw(r"    if (reason == DLL_PROCESS_ATTACH) spl_library_init();")
        self.builder.emit_raw(r"    else if (reason == DLL_PROCESS_DETACH) spl_library_shutdown();")
        self.builder.emit_raw(r"    return TRUE;")
        self.builder.emit_raw(r"}")
        self.builder.emit_raw(r"#else")
        self.builder.emit_raw(r"__attribute__((constructor)) static void _spl_auto_init(void) { spl_library_init(); }")
        self.builder.emit_raw(r"__attribute__((destructor))  static void _spl_auto_fini(void) { spl_library_shutdown(); }")
        self.builder.emit_raw(r"#endif")
        self.builder.emit_raw(r"#endif // SPL_SHARED_LIBRARY")
        self.builder.emit_raw(r"")

    # ================================================================
    # @export("C") Wrapper Generation
    # ================================================================

    me emit_export_wrappers(module: MirModule):
        """Emit extern "C" wrappers for all @export("C") functions and classes."""
        var has_exports = false

        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        # Check if there are any exports
        for _sym in module.functions.keys():
            val func: MirFunction = module.functions[_sym]
            if func.is_export_c:
                has_exports = true
        for _sym in module.types.keys():
            val type_def = module.types[_sym]
            if type_def.is_export_c:
                has_exports = true

        if not has_exports:
            return

        self.builder.emit_blank()
        self.builder.emit_raw(r"// ================================================================")
        self.builder.emit_raw(r"// @export(" + "\"C\"" + r") ABI Wrappers")
        self.builder.emit_raw(r"// ================================================================")
        self.builder.emit_blank()

        # Emit error type infrastructure if any export returns Result<T,E>
        var has_result_exports = false
        for _sym in module.functions.keys():
            val func: MirFunction = module.functions[_sym]
            if func.is_export_c and is_result_type(func.signature.return_type):
                has_result_exports = true
        if has_result_exports:
            self.builder.emit_raw(emit_error_type_definitions())

        # Emit callback typedefs for any function pointer parameters
        val callback_typedefs = self._collect_callback_typedefs_from_module(module)
        if callback_typedefs.len() > 0:
            self.builder.emit_raw(r"// Callback typedefs (borrowed — caller retains ownership)")
            var cb_idx = 0
            while cb_idx < callback_typedefs.len():
                self.builder.emit_raw(emit_callback_typedef(callback_typedefs[cb_idx]))
                cb_idx = cb_idx + 1
            self.builder.emit_blank()

            # Emit trampolines for each callback typedef
            var tr_idx = 0
            while tr_idx < callback_typedefs.len():
                val cb = callback_typedefs[tr_idx]
                val trampoline_name = r"_spl_trampoline_" + cb.name
                self.builder.emit_raw(emit_callback_trampoline(trampoline_name, cb))
                self.builder.emit_blank()
                tr_idx = tr_idx + 1

        # Emit function wrappers
        for _sym in module.functions.keys():
            val func: MirFunction = module.functions[_sym]
            if func.is_export_c:
                self.emit_function_export_wrapper(func)

        # Emit class/struct wrappers
        for _sym in module.types.keys():
            val type_def = module.types[_sym]
            if type_def.is_export_c:
                self.emit_type_export_wrapper(type_def, module)

        # Emit runtime layout verification function for @repr("C") / @export("C") types
        self.emit_verify_layouts(module)
