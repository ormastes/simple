# LLD FFI — In-process ELF linker bridge
#
# Wraps the C shim `simple_lld_elf_link` (see lld_shim.cpp) so SimpleOS builds
# can invoke LLD without fork/exec. Stub shim returns exit_code=1 with an
# explanatory message until the host toolchain is rebuilt with SIMPLE_HAVE_LLD.
#
# Used by linker_wrapper.spl when target is SimpleOS (see Wave 3 CRT guard).

use std.ffi.dynamic.{DynLib}

# ============================================================================
# Runtime FFI primitives (same set llvm.spl / dyn_ffi.spl rely on)
# ============================================================================

extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64)
extern fn rt_memset(dest: i64, val: i64, len: i64) -> i64
extern fn rt_memcpy(dest: i64, src: i64, len: i64)
extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64)
extern fn rt_cstring_to_text(ptr: i64) -> text
extern fn spl_str_ptr(s: text) -> i64
extern fn spl_dlsym(handle: i64, name: text) -> i64
extern fn spl_wffi_call_i64(fptr: i64, args: [i64], nargs: i64) -> i64

# ============================================================================
# Result class
# ============================================================================

class LldResult:
    exit_code: i32
    stderr_text: text

# ============================================================================
# lld_elf_link — build argv / stderr buffer, call shim, return LldResult
# ============================================================================

fn lld_elf_link(args: [text]) -> LldResult:
    # Resolve shim symbol via self-handle dlsym.
    val fptr = spl_dlsym(0, "simple_lld_elf_link")
    if fptr == 0:
        return LldResult(
            exit_code: 127,
            stderr_text: "lld_ffi: symbol 'simple_lld_elf_link' not found; shim not linked into this binary",
        )

    # Build NULL-terminated char** (argc+1 slots, each 8 bytes for a pointer).
    val argc = args.len()
    val argv_bytes = (argc + 1) * 8
    val argv_ptr = rt_alloc(argv_bytes)
    rt_memset(argv_ptr, 0, argv_bytes)

    var i = 0
    while i < argc:
        val sp = spl_str_ptr(args[i])
        rt_ptr_write_i64(argv_ptr, i * 8, sp)
        i = i + 1
    # Trailing NULL terminator slot already zeroed by rt_memset.

    # Allocate 4096-byte stderr capture buffer.
    val stderr_cap = 4096
    val stderr_ptr = rt_alloc(stderr_cap)
    rt_memset(stderr_ptr, 0, stderr_cap)

    # Invoke: simple_lld_elf_link(argv, stderr_buf, stderr_cap)
    val rc_i64 = spl_wffi_call_i64(fptr, [argv_ptr, stderr_ptr, stderr_cap], 3)
    val rc_i32 = rc_i64 as i32

    # Copy stderr text out before freeing buffer.
    val msg = rt_cstring_to_text(stderr_ptr)

    rt_free(argv_ptr)
    rt_free(stderr_ptr)

    LldResult(exit_code: rc_i32, stderr_text: msg)

# ============================================================================
# Parse-only entry point
# ============================================================================

fn main():
    print "lld_ffi: in-process LLD bridge (use lld_elf_link(args) from linker_wrapper)"
