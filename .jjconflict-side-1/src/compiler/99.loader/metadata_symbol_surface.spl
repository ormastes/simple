use std.io_runtime

class MetadataSymbolEntry:
    mangled_name: text
    module_path: text
    is_instantiation: bool

    static fn create(name: text, path: text, is_inst: bool) -> MetadataSymbolEntry:
        return MetadataSymbolEntry(mangled_name: name, module_path: path, is_instantiation: is_inst)

    me belongs_to(path: text) -> bool:
        return self.module_path == path


class MetadataSymbolIndex:
    m0_path: text
    m0_count: i32
    m0_s0: text
    m0_s1: text
    m0_s2: text
    m0_s3: text

    m1_path: text
    m1_count: i32
    m1_s0: text
    m1_s1: text
    m1_s2: text
    m1_s3: text

    m2_path: text
    m2_count: i32
    m2_s0: text
    m2_s1: text
    m2_s2: text
    m2_s3: text

    total_modules: i32

    static fn empty() -> MetadataSymbolIndex:
        return MetadataSymbolIndex(
            m0_path: "", m0_count: 0, m0_s0: "", m0_s1: "", m0_s2: "", m0_s3: "",
            m1_path: "", m1_count: 0, m1_s0: "", m1_s1: "", m1_s2: "", m1_s3: "",
            m2_path: "", m2_count: 0, m2_s0: "", m2_s1: "", m2_s2: "", m2_s3: "",
            total_modules: 0
        )

    me symbols_for(path: text) -> i32:
        if self.m0_path == path:
            return self.m0_count
        if self.m1_path == path:
            return self.m1_count
        if self.m2_path == path:
            return self.m2_count
        return 0

    me has_path(path: text) -> bool:
        if self.m0_path == path:
            return true
        if self.m1_path == path:
            return true
        if self.m2_path == path:
            return true
        return false


class GlobalSymbolOwnership:
    sym0_name: text
    sym0_owner: text
    sym1_name: text
    sym1_owner: text
    sym2_name: text
    sym2_owner: text
    sym3_name: text
    sym3_owner: text
    total_symbols: i32

    static fn empty() -> GlobalSymbolOwnership:
        return GlobalSymbolOwnership(
            sym0_name: "", sym0_owner: "",
            sym1_name: "", sym1_owner: "",
            sym2_name: "", sym2_owner: "",
            sym3_name: "", sym3_owner: "",
            total_symbols: 0
        )

    me owned_by(owner: text) -> i32:
        var count: i32 = 0
        if self.sym0_owner == owner:
            count = count + 1
        if self.sym1_owner == owner:
            count = count + 1
        if self.sym2_owner == owner:
            count = count + 1
        if self.sym3_owner == owner:
            count = count + 1
        return count

    me without_owner(owner: text) -> i32:
        return self.total_symbols - self.owned_by(owner)


class OwnershipTransfer:
    owner: text
    removed_count: i32
    remaining_count: i32

    static fn create(owner: text, removed: i32, remaining: i32) -> OwnershipTransfer:
        return OwnershipTransfer(owner: owner, removed_count: removed, remaining_count: remaining)

    me was_clean() -> bool:
        return self.removed_count > 0
