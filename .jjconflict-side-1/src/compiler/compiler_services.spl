# Forwarding module: compiler.compiler_services -> compiler.common.compiler_services
#
# Many test files import `compiler.compiler_services.{create_default_services, ...}`.
# The actual definition lives in `compiler/00.common/compiler_services.spl` which
# resolves as `compiler.common.compiler_services`. This file re-exports everything
# so the shorter import path works.

use compiler.common.compiler_services.{
    LexerPort,
    ParserPort,
    DesugarPort,
    TypeCheckPort,
    HirLowerPort,
    MirLowerPort,
    LoggerPort,
    ModuleLoaderPort,
    CompilerServices,
    create_default_services,
    logger_debug,
    logger_info,
    logger_warn,
    logger_error
}

pub use LexerPort
pub use ParserPort
pub use DesugarPort
pub use TypeCheckPort
pub use HirLowerPort
pub use MirLowerPort
pub use LoggerPort
pub use ModuleLoaderPort
pub use CompilerServices
pub use create_default_services
pub use logger_debug
pub use logger_info
pub use logger_warn
pub use logger_error
