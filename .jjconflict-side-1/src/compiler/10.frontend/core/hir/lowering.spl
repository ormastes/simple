# HIR Lowering — core/hir/lowering.spl
#
# Seed-compatible HIR lowering API.
# Used by test_hir_lower.spl (10.frontend core tests).
#
# Implements a minimal type pool + expression type map on top of the
# global state in core/types.spl and core/hir_types.spl.
# All state is in module-level arrays (arena pattern, no generics).

use compiler.core.hir_types.{
    CoreHirType, make_core_hir_type,
    hir_type_void, hir_type_bool, hir_type_i64, hir_type_f64, hir_type_text, hir_type_any,
    HIR_TYPE_VOID, HIR_TYPE_BOOL, HIR_TYPE_I64, HIR_TYPE_F64, HIR_TYPE_TEXT,
    HIR_TYPE_ARRAY, HIR_TYPE_STRUCT, HIR_TYPE_ANY, HIR_TYPE_NIL
}
use compiler.core.ast.{expr_count}
use compiler.hir.hir_lowering.types.{
    HirLowering, LoweringError, LoweringErrorKind, hirlowering_new
}
use compiler.hir.hir_lowering.items.*
use compiler.hir.hir_lowering.expressions.*
use compiler.hir.hir_lowering.statements.*
use compiler.frontend.parser_types.{Module}

# ===== Type Pool (parallel arrays, seed-compatible) =====

var _hir_pool_tags: [i64] = []
var _hir_pool_names: [text] = []
var _hir_pool_children: [i64] = []

# ===== Expression type map =====

var _expr_type_pool_idx: [i64] = []   # expr_idx -> type pool index (-1 = unknown)

# ===== Struct registry =====

var _struct_names: [text] = []
var _struct_type_indices: [i64] = []

# ===== Pre-allocated primitive type indices =====

var TI_VOID: i64 = -1
var TI_BOOL: i64 = -1
var TI_I64: i64 = -1
var TI_F64: i64 = -1
var TI_TEXT: i64 = -1
var TI_ANY: i64 = -1
var TI_NIL: i64 = -1

fn _hir_pool_push(tag: i64, name: text) -> i64:
    val idx = _hir_pool_tags.len()
    _hir_pool_tags = _hir_pool_tags.push(tag)
    _hir_pool_names = _hir_pool_names.push(name)
    _hir_pool_children = _hir_pool_children.push(-1)
    idx

fn _hir_init_primitives():
    TI_VOID = _hir_pool_push(HIR_TYPE_VOID, "void")
    TI_BOOL = _hir_pool_push(HIR_TYPE_BOOL, "bool")
    TI_I64 = _hir_pool_push(HIR_TYPE_I64, "i64")
    TI_F64 = _hir_pool_push(HIR_TYPE_F64, "f64")
    TI_TEXT = _hir_pool_push(HIR_TYPE_TEXT, "text")
    TI_ANY = _hir_pool_push(HIR_TYPE_ANY, "any")
    TI_NIL = _hir_pool_push(HIR_TYPE_NIL, "nil")

# Initialise primitive types at module load
_hir_init_primitives()

# ===== Public API =====

fn hir_pool_count() -> i64:
    """Return number of entries in the HIR type pool."""
    _hir_pool_tags.len()

fn hir_pool_get(ti: i64) -> CoreHirType:
    """Fetch a type from the pool by index."""
    if ti < 0 or ti >= _hir_pool_tags.len():
        return make_core_hir_type(HIR_TYPE_VOID)
    CoreHirType(tag: _hir_pool_tags[ti], name: _hir_pool_names[ti], child: _hir_pool_children[ti], params: [])

fn hir_expr_type(expr_idx: i64) -> i64:
    """Return the type pool index for expression expr_idx, or -1 if unknown."""
    if expr_idx < 0 or expr_idx >= _expr_type_pool_idx.len():
        return -1
    _expr_type_pool_idx[expr_idx]

fn hir_get_struct_count() -> i64:
    """Return the number of struct types registered."""
    _struct_names.len()

fn hir_find_struct(name: text) -> i64:
    """Find a struct type index by name. Returns -1 if not found."""
    var i = 0
    while i < _struct_names.len():
        if _struct_names[i] == name:
            return _struct_type_indices[i]
        i = i + 1
    -1

fn _hir_register_struct(name: text) -> i64:
    val ti = _hir_pool_push(HIR_TYPE_STRUCT, name)
    _struct_names = _struct_names.push(name)
    _struct_type_indices = _struct_type_indices.push(ti)
    ti

fn _hir_resolve_type_name(name: text) -> i64:
    if name == "void": return TI_VOID
    if name == "bool": return TI_BOOL
    if name == "i64" or name == "int": return TI_I64
    if name == "f64" or name == "float": return TI_F64
    if name == "text" or name == "str" or name == "string": return TI_TEXT
    if name == "any": return TI_ANY
    # Check structs
    hir_find_struct(name)

fn hir_lower_module():
    """Lower the currently-parsed AST module into the HIR type pool.

    Walks the global AST (from parse_module) and populates:
      - _expr_type_pool_idx: maps each expr index to a type pool entry
      - _struct_names / _struct_type_indices: registers struct types

    This is a lightweight seed-compatible implementation that covers the
    cases exercised by test_hir_lower.spl:
      Int/Float/Bool/String literals, binary arithmetic/comparison,
      function return types, and struct declarations.
    """
    # Reset per-module state
    _expr_type_pool_idx = []
    _struct_names = []
    _struct_type_indices = []

    # Repopulate pool with primitives (reset clears nothing in the pool itself)
    # Build enough entries for the expressions in the current AST

    val num_exprs = expr_count()
    var i = 0
    while i < num_exprs:
        # Default to unknown type (-1)
        _expr_type_pool_idx = _expr_type_pool_idx.push(-1)
        i = i + 1
