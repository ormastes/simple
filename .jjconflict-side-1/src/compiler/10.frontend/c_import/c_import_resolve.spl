# C Import Resolve
#
# Resolves import_c header paths using include search paths.
# Resolution order: src/include/, user-specified paths, system paths.

extern fn rt_file_exists(path: text) -> bool

fn resolve_c_header(header_path: text, include_paths: [text]) -> text:
    var i = 0
    while i < include_paths.length:
        val candidate = include_paths[i] + "/" + header_path
        if rt_file_exists(candidate):
            return candidate
        i = i + 1

    val src_include = "src/include/" + header_path
    if rt_file_exists(src_include):
        return src_include

    ""

fn default_include_paths() -> [text]:
    ["src/include"]

fn resolve_c_header_default(header_path: text) -> text:
    resolve_c_header(header_path, default_include_paths())

fn validate_self_contained(header_source: text) -> [text]:
    var errors: [text] = []
    val lines = header_source.split("\n")
    var line_num = 0
    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        if trimmed.starts_with("#include"):
            val rest = trimmed.substring(8, trimmed.length).trim()
            if rest.starts_with("<"):
                val header = rest.substring(1, rest.length)
                val end_idx = header.index_of(">")
                if end_idx >= 0:
                    val sys_header = header.substring(0, end_idx)
                    errors.push("system include not allowed in self-contained header: <" + sys_header + "> at line " + line_num.to_text())
    errors
