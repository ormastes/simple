# Parser Factory - Convenience constructor functions for Parser
#
# The Parser struct has no static fn new(); keep construction centralized here.

use compiler.frontend.core.lexer.{Lexer}
use compiler.frontend.lexer_types.{Token, TokenKind}
use compiler.frontend.parser_types.{Parser}
use compiler.frontend.block_types.{Span}
use compiler.frontend.parser_types.*
use compiler.frontend.block_types.{LexerMode}

fn create_parser(src: text) -> Parser:
    """Create a Parser from source text."""
    val lexer = Lexer.new(src)
    var p = Parser(
        source: src,
        lexer: lexer,
        current: Token(kind: TokenKind.Eof, span: Span(start: 0, end: 0, line: 1, col: 0), text: ""),
        previous: Token(kind: TokenKind.Eof, span: Span(start: 0, end: 0, line: 1, col: 0), text: ""),
        errors: [],
        has_outline: false,
        outline: nil,
        has_resolved_blocks: false,
        resolved_blocks: nil
    )
    p

fn parser_with_resolved_blocks(src: text, resolved: any) -> Parser:
    """Create a Parser from source text with pre-resolved blocks."""
    val lexer = Lexer.new(src)
    var p = Parser(
        source: src,
        lexer: lexer,
        current: Token(kind: TokenKind.Eof, span: Span(start: 0, end: 0, line: 1, col: 0), text: ""),
        previous: Token(kind: TokenKind.Eof, span: Span(start: 0, end: 0, line: 1, col: 0), text: ""),
        errors: [],
        has_outline: false,
        outline: nil,
        has_resolved_blocks: true,
        resolved_blocks: resolved
    )
    p
