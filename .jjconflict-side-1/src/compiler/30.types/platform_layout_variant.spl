# Platform Layout Variant — AC-6 layout variant integration, AC-7 pointer width from bit
#
# PointerWidth:         resolves @platform(bit) annotation to pointer size/alignment
# FieldLayout:          layout of a single field within a struct
# PlatformLayoutVariant: layout metadata for a type variant selected by platform
# PlatformLayoutSelector: chooses the layout variant based on platform match

use std.io_runtime

class PointerWidth:
    bit_text: text
    byte_size: i32
    alignment: i32

impl PointerWidth:
    static fn from_bit(bit: text) -> PointerWidth:
        if bit == "32":
            return PointerWidth(bit_text: bit, byte_size: 4, alignment: 4)
        elif bit == "64":
            return PointerWidth(bit_text: bit, byte_size: 8, alignment: 8)
        else:
            return PointerWidth(bit_text: bit, byte_size: 8, alignment: 8)

    me usize_size() -> i32:
        return self.byte_size

    me isize_size() -> i32:
        return self.byte_size


class FieldLayout:
    field_name: text
    field_size: i32
    field_align: i32
    field_offset: i32

impl FieldLayout:
    static fn create(name: text, size: i32, align_val: i32, offset: i32) -> FieldLayout:
        return FieldLayout(field_name: name, field_size: size, field_align: align_val, field_offset: offset)

    me end_offset() -> i32:
        return self.field_offset + self.field_size


class PlatformLayoutVariant:
    variant_id: text
    total_size: i32
    total_align: i32
    field_count: i32
    f0_name: text
    f0_size: i32
    f0_offset: i32
    f1_name: text
    f1_size: i32
    f1_offset: i32
    f2_name: text
    f2_size: i32
    f2_offset: i32
    f3_name: text
    f3_size: i32
    f3_offset: i32

impl PlatformLayoutVariant:
    static fn create(vid: text, size: i32, align_val: i32, count: i32) -> PlatformLayoutVariant:
        return PlatformLayoutVariant(
            variant_id: vid,
            total_size: size,
            total_align: align_val,
            field_count: count,
            f0_name: "",
            f0_size: 0,
            f0_offset: 0,
            f1_name: "",
            f1_size: 0,
            f1_offset: 0,
            f2_name: "",
            f2_size: 0,
            f2_offset: 0,
            f3_name: "",
            f3_size: 0,
            f3_offset: 0
        )

    me with_field(idx: i32, name: text, size: i32, offset: i32) -> PlatformLayoutVariant:
        if idx == 0:
            return PlatformLayoutVariant(
                variant_id: self.variant_id,
                total_size: self.total_size,
                total_align: self.total_align,
                field_count: self.field_count,
                f0_name: name,
                f0_size: size,
                f0_offset: offset,
                f1_name: self.f1_name,
                f1_size: self.f1_size,
                f1_offset: self.f1_offset,
                f2_name: self.f2_name,
                f2_size: self.f2_size,
                f2_offset: self.f2_offset,
                f3_name: self.f3_name,
                f3_size: self.f3_size,
                f3_offset: self.f3_offset
            )
        elif idx == 1:
            return PlatformLayoutVariant(
                variant_id: self.variant_id,
                total_size: self.total_size,
                total_align: self.total_align,
                field_count: self.field_count,
                f0_name: self.f0_name,
                f0_size: self.f0_size,
                f0_offset: self.f0_offset,
                f1_name: name,
                f1_size: size,
                f1_offset: offset,
                f2_name: self.f2_name,
                f2_size: self.f2_size,
                f2_offset: self.f2_offset,
                f3_name: self.f3_name,
                f3_size: self.f3_size,
                f3_offset: self.f3_offset
            )
        elif idx == 2:
            return PlatformLayoutVariant(
                variant_id: self.variant_id,
                total_size: self.total_size,
                total_align: self.total_align,
                field_count: self.field_count,
                f0_name: self.f0_name,
                f0_size: self.f0_size,
                f0_offset: self.f0_offset,
                f1_name: self.f1_name,
                f1_size: self.f1_size,
                f1_offset: self.f1_offset,
                f2_name: name,
                f2_size: size,
                f2_offset: offset,
                f3_name: self.f3_name,
                f3_size: self.f3_size,
                f3_offset: self.f3_offset
            )
        elif idx == 3:
            return PlatformLayoutVariant(
                variant_id: self.variant_id,
                total_size: self.total_size,
                total_align: self.total_align,
                field_count: self.field_count,
                f0_name: self.f0_name,
                f0_size: self.f0_size,
                f0_offset: self.f0_offset,
                f1_name: self.f1_name,
                f1_size: self.f1_size,
                f1_offset: self.f1_offset,
                f2_name: self.f2_name,
                f2_size: self.f2_size,
                f2_offset: self.f2_offset,
                f3_name: name,
                f3_size: size,
                f3_offset: offset
            )
        else:
            return PlatformLayoutVariant(
                variant_id: self.variant_id,
                total_size: self.total_size,
                total_align: self.total_align,
                field_count: self.field_count,
                f0_name: self.f0_name,
                f0_size: self.f0_size,
                f0_offset: self.f0_offset,
                f1_name: self.f1_name,
                f1_size: self.f1_size,
                f1_offset: self.f1_offset,
                f2_name: self.f2_name,
                f2_size: self.f2_size,
                f2_offset: self.f2_offset,
                f3_name: self.f3_name,
                f3_size: self.f3_size,
                f3_offset: self.f3_offset
            )

    me field_offset_for(name: text) -> i32:
        if self.f0_name == name:
            return self.f0_offset
        elif self.f1_name == name:
            return self.f1_offset
        elif self.f2_name == name:
            return self.f2_offset
        elif self.f3_name == name:
            return self.f3_offset
        else:
            return -1

    me size_differs_from(other_size: i32) -> bool:
        return self.total_size != other_size


class PlatformLayoutSelector:
    v0_id: text
    v0_size: i32
    v0_align: i32
    v1_id: text
    v1_size: i32
    v1_align: i32
    selected_id: text
    selected_size: i32
    selected_align: i32
    has_variation: bool

impl PlatformLayoutSelector:
    static fn from_two(v0_id: text, v0_size: i32, v0_align: i32, v1_id: text, v1_size: i32, v1_align: i32, selected: text) -> PlatformLayoutSelector:
        val varies = (v0_size != v1_size) or (v0_align != v1_align)
        var sel_size = v0_size
        var sel_align = v0_align
        if selected == v1_id:
            sel_size = v1_size
            sel_align = v1_align
        return PlatformLayoutSelector(
            v0_id: v0_id,
            v0_size: v0_size,
            v0_align: v0_align,
            v1_id: v1_id,
            v1_size: v1_size,
            v1_align: v1_align,
            selected_id: selected,
            selected_size: sel_size,
            selected_align: sel_align,
            has_variation: varies
        )

    me needs_platform_attr() -> bool:
        return self.has_variation

    me effective_size() -> i32:
        return self.selected_size

    me effective_align() -> i32:
        return self.selected_align
