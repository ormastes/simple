# Type layout - C/C++ static-assert and struct-definition generation.
use compiler.types.type_layout.*
# Type Layout Computation
#
# Computes memory layout for types including:
# - Size in bytes
# - Alignment requirements
# - Field offsets
# - Padding
#
# Supports layout attributes:
# - @repr("C")   - C-compatible layout
# - @repr("packed") or @packed - No padding between fields
# - @repr("transparent") - Same layout as single field
# - @align(N)    - Minimum alignment (power of 2)
#
# Architecture-aware sizing:
# - usize/isize scale with pointer size (8/16/32/64-bit)
# - Alignment rules vary by architecture
#
# Example:
#   @repr("C")
#   @align(16)
#   struct AlignedData:
#       x: i32
#       y: i32

use compiler.hir.hir_types.{HirType, SymbolId}
use compiler.hir.hir_definitions.{HirStruct, HirClass, HirField}
use compiler.common.diagnostics.span.{Span}
use std.common.target.{TargetArch}


# Platform predicate model for @platform layout variants.
fn generate_c_static_asserts(verification: LayoutVerification) -> text:
    """Generate C _Static_assert statements for layout verification.

    Produces code like:
        _Static_assert(sizeof(spl_ClassName) == 16, "size mismatch");
        _Static_assert(offsetof(spl_ClassName, field) == 0, "offset mismatch");

    This is emitted into the generated C header so the C compiler catches
    any ABI mismatch at compile time.
    """
    val name = verification.class_name
    var lines: [text] = []

    # Size assertion
    lines.push("_Static_assert(sizeof(spl_{name}) == {verification.total_size}, \"spl_{name} size mismatch\");")

    # Alignment assertion (using _Alignof in C11)
    lines.push("_Static_assert(_Alignof(spl_{name}) == {verification.alignment}, \"spl_{name} alignment mismatch\");")

    # Field offset assertions
    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        if not field.has_bits:
            lines.push("_Static_assert(offsetof(spl_{name}, {field.name}) == {field.offset}, \"spl_{name}.{field.name} offset mismatch\");")
        fi = fi + 1

    lines.join("\n")

fn generate_cpp_static_asserts(verification: LayoutVerification) -> text:
    """Generate C++ static_assert statements for layout verification."""
    val name = verification.class_name
    var lines: [text] = []

    lines.push("static_assert(sizeof(spl_{name}) == {verification.total_size}, \"spl_{name} size mismatch\");")
    lines.push("static_assert(alignof(spl_{name}) == {verification.alignment}, \"spl_{name} alignment mismatch\");")

    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        if not field.has_bits:
            lines.push("static_assert(offsetof(spl_{name}, {field.name}) == {field.offset}, \"spl_{name}.{field.name} offset mismatch\");")
        fi = fi + 1

    lines.join("\n")

fn generate_c_struct_def(verification: LayoutVerification) -> text:
    """Generate a C struct definition matching the computed layout.

    Produces code like:
        typedef struct spl_ClassName {
            int32_t precision;
            double value;
        } spl_ClassName;

    Used by the header generator alongside _Static_assert checks.
    """
    val name = verification.class_name
    var lines: [text] = []

    lines.push("typedef struct spl_{name} {")

    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        val c_type = _field_to_c_type(field)
        if field.has_bits:
            lines.push("    {c_type} {field.name} : {field.bits_width};")
        else:
            lines.push("    {c_type} {field.name};")
        fi = fi + 1

    lines.push("} spl_{name};")

    lines.join("\n")

fn _field_to_c_type(field: FieldLayout) -> text:
    """Map a field's size and alignment to the corresponding C type name.

    Uses size and alignment to determine the correct C type since we don't
    have the original HirType here — only the computed layout.
    """
    # Map by size (assuming standard C types)
    match field.size:
        case 1:
            if field.align == 1:
                "uint8_t"
            else:
                "uint8_t"
        case 2: "uint16_t"
        case 4:
            if field.align == 4:
                # Could be int32_t or float — default to int32_t
                "int32_t"
            else:
                "int32_t"
        case 8:
            if field.align == 8:
                # Could be int64_t or double — default to int64_t
                "int64_t"
            else:
                "int64_t"
        case 16: "__int128"
        case _: "uint8_t /* unknown size {field.size} */"

fn compute_padding_bytes(verification: LayoutVerification) -> i64:
    """Compute the total number of padding bytes in a struct layout.

    This helps developers understand how much space is wasted on alignment
    padding, which is useful for optimizing struct layout.
    """
    var data_bytes: i64 = 0
    var fi = 0
    while fi < verification.fields.len():
        data_bytes = data_bytes + verification.fields[fi].size
        fi = fi + 1

    verification.total_size - data_bytes


# ============================================================================
# Runtime Layout Verification
# ============================================================================
#
# Generates C runtime assert() calls for spl_verify_layouts().
# Complements the compile-time _Static_assert checks: the runtime function
# can be called from an init path to catch layout drift in dynamically
# loaded shared libraries where the header was compiled separately.

struct FieldOffset:
    """Simplified field offset record for runtime verification."""
    name: text
    offset: i64
    size: i64

fn compute_layout_verification(class_name: text, fields: [HirField], layout_attr: LayoutAttr) -> LayoutVerification:
    """Compute layout verification data for runtime assert generation.

    Wraps verify_c_layout and returns the same LayoutVerification
    struct. This is the public entry point for the runtime layout
    verification pipeline used by the C backend.
    """
    verify_c_layout(class_name, fields, layout_attr)

fn generate_runtime_layout_asserts(verification: LayoutVerification) -> text:
    """Generate C runtime assert() calls for spl_verify_layouts().

    Produces code like:
        assert(sizeof(spl_ClassName) == 16 && "spl_ClassName size mismatch");
        assert(offsetof(spl_ClassName, field) == 0 && "spl_ClassName.field offset mismatch");

    These are runtime checks (stdlib assert) rather than _Static_assert,
    so they catch mismatches when a shared library is loaded against
    a different header version at runtime.
    """
    val name = verification.class_name
    var lines: [text] = []

    # Size assertion
    lines.push("    assert(sizeof(spl_{name}) == {verification.total_size} && \"spl_{name} size mismatch\");")

    # Alignment assertion
    lines.push("    assert(_Alignof(spl_{name}) == {verification.alignment} && \"spl_{name} alignment mismatch\");")

    # Field offset assertions (skip bitfields — offsetof not meaningful for them)
    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        if not field.has_bits:
            lines.push("    assert(offsetof(spl_{name}, {field.name}) == {field.offset} && \"spl_{name}.{field.name} offset mismatch\");")
        fi = fi + 1

    lines.join("\n")

fn extract_field_offsets(verification: LayoutVerification) -> [FieldOffset]:
    """Extract simplified FieldOffset records from a LayoutVerification.

    Useful for tooling that only needs name/offset/size triples without
    the full FieldLayout details (type, alignment, bitfield info).
    """
    var offsets: [FieldOffset] = []
    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        offsets.push(FieldOffset(
            name: field.name,
            offset: field.offset,
            size: field.size
        ))
        fi = fi + 1
    offsets
