#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Type Layout Computation
#
# Computes memory layout for types including:
# - Size in bytes
# - Alignment requirements
# - Field offsets
# - Padding
#
# Supports layout attributes:
# - @repr("C")   - C-compatible layout
# - @repr("packed") or @packed - No padding between fields
# - @repr("transparent") - Same layout as single field
# - @align(N)    - Minimum alignment (power of 2)
#
# Architecture-aware sizing:
# - usize/isize scale with pointer size (8/16/32/64-bit)
# - Alignment rules vary by architecture
#
# Example:
#   @repr("C")
#   @align(16)
#   struct AlignedData:
#       x: i32
#       y: i32

from hir_types import {HirType, SymbolId}
from hir_definitions import {HirStruct, HirClass, HirField}
from std.common.target import {TargetArch}


# Layout kind (from @repr attribute)
enum LayoutKind:
    Simple      # Default Simple language layout (like Rust)
    C           # C ABI compatible layout
    Packed      # No padding (alignment = 1)
    Transparent # Same layout as inner type


# ============================================================================
# LayoutKind Methods (was: impl LayoutKind:)
# ============================================================================

# Layout attributes for a type
struct LayoutAttr:
    layout_kind: LayoutKind   # Layout kind
    # # DESUGARED: explicit_align: i64
    has_explicit_align: bool
    explicit_align: i64
    is_packed: bool         # @packed shorthand


# ============================================================================
# LayoutAttr Methods (was: impl LayoutAttr:)
# ============================================================================

fn layoutattr_default_() -> LayoutAttr:
        LayoutAttr(
            layout_kind: LayoutKind.Simple,
            #  # DESUGARED: explicit_align: nil
            is_packed: false
        )


fn layoutattr_c_repr() -> LayoutAttr:
        LayoutAttr(
            layout_kind: LayoutKind.C,
            #  # DESUGARED: explicit_align: nil
            is_packed: false
        )


fn layoutattr_packed() -> LayoutAttr:
        LayoutAttr(
            layout_kind: LayoutKind.Packed,
            #  # DESUGARED: explicit_align: nil
            is_packed: true
        )


# Single field layout information
struct FieldLayout:
    name: text
    type_: HirType
    offset: i64     # Byte offset from struct start
    size: i64       # Size of field in bytes
    align: i64      # Alignment of field
    has_bits: bool
    bits_width: i64
    bit_offset: i64 # Bit offset within the storage unit when has_bits is true


# ============================================================================
# FieldLayout Methods (was: impl FieldLayout:)
# ============================================================================

# Complete type layout
struct TypeLayout:
    size: i64               # Total size in bytes
    align: i64              # Required alignment
    fields: [FieldLayout]   # Field layouts (for struct/class)
    stride: i64             # Size when used in array (size rounded up to align)


# ============================================================================
# TypeLayout Methods (was: impl TypeLayout:)
# ============================================================================

# Primitive type sizes (in bytes)
fn primitive_size(type_name: text) -> has_i64:
    match type_name:
        case "i8": 1
        case "u8": 1
        case "bool": 1
        case "i16": 2
        case "u16": 2
        case "i32": 4
        case "u32": 4
        case "f32": 4
        case "char": 4
        case "i64": 8  # Assuming 64-bit
        case "u64": 8  # Assuming 64-bit
        case "f64": 8  # Assuming 64-bit
        case "isize": 8  # Assuming 64-bit
        case "usize": 8  # Assuming 64-bit
        case "i128": 16
        case "u128": 16
        case "()": 0
        case "unit": 0
        case "void": 0
        case _: nil

# Primitive type alignment (in bytes)
fn primitive_align(type_name: text) -> has_i64:
    match type_name:
        case "i8": 1
        case "u8": 1
        case "bool": 1
        case "i16": 2
        case "u16": 2
        case "i32": 4
        case "u32": 4
        case "f32": 4
        case "char": 4
        case "i64": 8
        case "u64": 8
        case "f64": 8
        case "isize": 8
        case "usize": 8
        case "i128": 16
        case "u128": 16
        case "()": 1  # ZST has alignment 1
        case "unit": 1  # ZST has alignment 1
        case "void": 1  # ZST has alignment 1
        case _: nil

# Get size of a type
fn size_of_type(type_: HirType) -> i64:
    val name = type__to_text(type_)
    primitive_size(name) ?? 8  # Default to pointer size

# Get alignment of a type
fn align_of_type(type_: HirType) -> i64:
    val name = type__to_text(type_)
    primitive_align(name) ?? 8  # Default to pointer alignment

# Compute layout for a struct
fn compute_struct_layout(fields: [HirField], attr: LayoutAttr) -> TypeLayout:
    match attr.layout_kind:
        case LayoutKind.Packed:
            compute_packed_layout(fields)
        case LayoutKind.C:
            compute_c_layout(fields, attr)
        case LayoutKind.Transparent:
            compute_transparent_layout(fields)
        case LayoutKind.Simple:
            # Default layout (may reorder fields for optimization)
            compute_c_layout(fields, attr)  # Use C layout for now

# Packed layout: no padding, alignment = 1
fn compute_packed_layout(fields: [HirField]) -> TypeLayout:
    var field_layouts: [FieldLayout] = []
    var offset: i64 = 0

    for field in fields:
        val size = size_of_type(field.type_)
        field_layouts.push(FieldLayout(
            name: field.name,
            type_: field.type_,
            offset: offset,
            size: size,
            align: 1,
            has_bits: field.has_bits_attr,
            bits_width: if field.has_bits_attr: field.bits_width else: 0,
            bit_offset: 0
        ))
        offset = offset + size

    TypeLayout(
        size: offset,
        align: 1,
        fields: field_layouts,
        stride: offset
    )

# C ABI layout: fields in order, each aligned
fn compute_c_layout(fields: [HirField], attr: LayoutAttr) -> TypeLayout:
    var field_layouts: [FieldLayout] = []
    var offset: i64 = 0
    var max_align: i64 = 1
    var active_bitfield = false
    var bitfield_unit_offset: i64 = 0
    var bitfield_unit_size: i64 = 0
    var bitfield_unit_align: i64 = 1
    var bitfield_unit_bits: i64 = 0
    var bitfield_used_bits: i64 = 0

    for field in fields:
        val size = size_of_type(field.type_)
        val align = align_of_type(field.type_)

        # Update max alignment
        if align > max_align:
            max_align = align

        if field.has_bits_attr:
            val bits_width = field.bits_width
            val storage_bits = size * 8
            val needs_new_unit = not active_bitfield or
                size != bitfield_unit_size or
                align != bitfield_unit_align or
                bitfield_used_bits + bits_width > bitfield_unit_bits

            if needs_new_unit:
                if active_bitfield:
                    offset = bitfield_unit_offset + bitfield_unit_size
                offset = align_up(offset, align)
                bitfield_unit_offset = offset
                bitfield_unit_size = size
                bitfield_unit_align = align
                bitfield_unit_bits = storage_bits
                bitfield_used_bits = 0
                active_bitfield = true

            field_layouts.push(FieldLayout(
                name: field.name,
                type_: field.type_,
                offset: bitfield_unit_offset,
                size: size,
                align: align,
                has_bits: true,
                bits_width: bits_width,
                bit_offset: bitfield_used_bits
            ))

            bitfield_used_bits = bitfield_used_bits + bits_width
            if bitfield_used_bits >= bitfield_unit_bits:
                offset = bitfield_unit_offset + bitfield_unit_size
                active_bitfield = false
                bitfield_used_bits = 0
            continue

        if active_bitfield:
            offset = bitfield_unit_offset + bitfield_unit_size
            active_bitfield = false
            bitfield_used_bits = 0

        # Align offset for this field
        offset = align_up(offset, align)

        field_layouts.push(FieldLayout(
            name: field.name,
            type_: field.type_,
            offset: offset,
            size: size,
            align: align,
            has_bits: false,
            bits_width: 0,
            bit_offset: 0
        ))

        offset = offset + size

    if active_bitfield:
        offset = bitfield_unit_offset + bitfield_unit_size

    # Apply explicit alignment
    val final_align = attr_effective_align(attr, max_align)

    # Pad struct size to alignment
    val final_size = align_up(offset, final_align)

    TypeLayout(
        size: final_size,
        align: final_align,
        fields: field_layouts,
        stride: final_size
    )

# Transparent layout: same as single field
fn compute_transparent_layout(fields: [HirField]) -> TypeLayout:
    if fields_len(fields) != 1:
        # Transparent requires exactly one field
        # Fall back to default layout
        return compute_c_layout(fields, layoutattr_default_())

    val field = fields[0]
    val size = size_of_type(field.type_)
    val align = align_of_type(field.type_)

    TypeLayout(
        size: size,
        align: align,
        fields: [FieldLayout(
            name: field.name,
            type_: field.type_,
            offset: 0,
            size: size,
            align: align,
            has_bits: field.has_bits_attr,
            bits_width: if field.has_bits_attr: field.bits_width else: 0,
            bit_offset: 0
        )],
        stride: size
    )

# Compute field offset in a struct
fn compute_field_offset(struct_fields: [HirField], field_name: text, attr: LayoutAttr) -> has_i64:
    val layout = compute_struct_layout(struct_fields, attr)
    for field in layout.fields:
        if field.name == field_name:
            return field.offset
    nil

# General layout computation
fn compute_layout(type_: HirType, attr: LayoutAttr) -> TypeLayout:
    val size = size_of_type(type_)
    val align = attr_effective_align(attr, align_of_type(type_))
    val stride = align_up(size, align)

    TypeLayout(
        size: size,
        align: align,
        fields: [],
        stride: stride
    )

# Align value up to alignment boundary
fn align_up(value: i64, align: i64) -> i64:
    (value + align - 1) & ~(align - 1)

# Check if value is aligned
fn is_aligned(value: i64, align: i64) -> bool:
    (value & (align - 1)) == 0

# Check if alignment is power of 2
fn is_power_of_two(n: i64) -> bool:
    n > 0 and (n & (n - 1)) == 0

# --- Architecture-Aware Type Sizing ---

# Primitive type sizes for a specific architecture
fn primitive_size_for_arch(type_name: text, arch: TargetArch) -> has_i64:
    match type_name:
        # Fixed-size types (same on all architectures)
        case "i8": 1
        case "u8": 1
        case "bool": 1
        case "i16": 2
        case "u16": 2
        case "i32": 4
        case "u32": 4
        case "f32": 4
        case "char": 4
        case "i64": 8
        case "u64": 8
        case "f64": 8
        case "i128": 16
        case "u128": 16
        case "()": 0
        case "unit": 0
        case "void": 0

        # Pointer-sized types (vary by architecture)
        case "usize":
            arch_pointer_bytes(arch)

        case "isize":
            arch_pointer_bytes(arch)

        # Pointer types
        case _ if type_name.ends_with("*") or type_name.starts_with("&"):
            arch_pointer_bytes(arch)

        case _: nil

# Primitive type alignment for a specific architecture
fn primitive_align_for_arch(type_name: text, arch: TargetArch) -> has_i64:
    match type_name:
        # Fixed-alignment types
        case "i8": 1
        case "u8": 1
        case "bool": 1
        case "i16": 2
        case "u16": 2
        case "i32": 4
        case "u32": 4
        case "f32": 4
        case "char": 4
        case "()": 1
        case "unit": 1
        case "void": 1

        # 64-bit types: alignment depends on architecture
        case "i64":
            val bits = arch_bits(arch)
            if bits <= 8:
                1     # 8-bit: byte aligned
            elif bits <= 16:
                2     # 16-bit: word aligned
            elif bits <= 32:
                4     # 32-bit: 4-byte aligned (x86 ABI)
            else:
                8     # 64-bit: natural alignment
        case "u64":
            val bits = arch_bits(arch)
            if bits <= 8:
                1
            elif bits <= 16:
                2
            elif bits <= 32:
                4
            else:
                8
        case "f64":
            val bits = arch_bits(arch)
            if bits <= 8:
                1
            elif bits <= 16:
                2
            elif bits <= 32:
                4
            else:
                8

        # 128-bit types
        case "i128":
            val bits = arch_bits(arch)
            if bits <= 16:
                2
            elif bits <= 32:
                4
            else:
                16
        case "u128":
            val bits = arch_bits(arch)
            if bits <= 16:
                2
            elif bits <= 32:
                4
            else:
                16

        # Pointer-sized types
        case "usize":
            arch_pointer_bytes(arch)

        case "isize":
            arch_pointer_bytes(arch)

        # Pointer types
        case _ if type_name.ends_with("*") or type_name.starts_with("&"):
            arch_pointer_bytes(arch)

        case _: nil

# Get size of a type for a specific architecture
fn size_of_type_for_arch(type_: HirType, arch: TargetArch) -> i64:
    val name = type__to_text(type_)
    primitive_size_for_arch(name, arch) ?? arch_pointer_bytes(arch)

# Get alignment of a type for a specific architecture
fn align_of_type_for_arch(type_: HirType, arch: TargetArch) -> i64:
    val name = type__to_text(type_)
    primitive_align_for_arch(name, arch) ?? arch_pointer_bytes(arch)

# --- Architecture-Aware Struct Layout ---

# Compute struct layout for a specific architecture
fn compute_struct_layout_for_arch(fields: [HirField], attr: LayoutAttr, arch: TargetArch) -> TypeLayout:
    match attr.layout_kind:
        case LayoutKind.Packed:
            compute_packed_layout_for_arch(fields, arch)
        case LayoutKind.C:
            compute_c_layout_for_arch(fields, attr, arch)
        case LayoutKind.Transparent:
            compute_transparent_layout_for_arch(fields, arch)
        case LayoutKind.Simple:
            compute_c_layout_for_arch(fields, attr, arch)

fn compute_packed_layout_for_arch(fields: [HirField], arch: TargetArch) -> TypeLayout:
    var field_layouts: [FieldLayout] = []
    var offset: i64 = 0

    for field in fields:
        val size = size_of_type_for_arch(field.type_, arch)
        field_layouts.push(FieldLayout(
            name: field.name,
            type_: field.type_,
            offset: offset,
            size: size,
            align: 1,
            has_bits: field.has_bits_attr,
            bits_width: if field.has_bits_attr: field.bits_width else: 0,
            bit_offset: 0
        ))
        offset = offset + size

    TypeLayout(
        size: offset,
        align: 1,
        fields: field_layouts,
        stride: offset
    )

fn compute_c_layout_for_arch(fields: [HirField], attr: LayoutAttr, arch: TargetArch) -> TypeLayout:
    var field_layouts: [FieldLayout] = []
    var offset: i64 = 0
    var max_align: i64 = 1
    var active_bitfield = false
    var bitfield_unit_offset: i64 = 0
    var bitfield_unit_size: i64 = 0
    var bitfield_unit_align: i64 = 1
    var bitfield_unit_bits: i64 = 0
    var bitfield_used_bits: i64 = 0

    for field in fields:
        val size = size_of_type_for_arch(field.type_, arch)
        val align = align_of_type_for_arch(field.type_, arch)

        if align > max_align:
            max_align = align

        if field.has_bits_attr:
            val bits_width = field.bits_width
            val storage_bits = size * 8
            val needs_new_unit = not active_bitfield or
                size != bitfield_unit_size or
                align != bitfield_unit_align or
                bitfield_used_bits + bits_width > bitfield_unit_bits

            if needs_new_unit:
                if active_bitfield:
                    offset = bitfield_unit_offset + bitfield_unit_size
                offset = align_up(offset, align)
                bitfield_unit_offset = offset
                bitfield_unit_size = size
                bitfield_unit_align = align
                bitfield_unit_bits = storage_bits
                bitfield_used_bits = 0
                active_bitfield = true

            field_layouts.push(FieldLayout(
                name: field.name,
                type_: field.type_,
                offset: bitfield_unit_offset,
                size: size,
                align: align,
                has_bits: true,
                bits_width: bits_width,
                bit_offset: bitfield_used_bits
            ))

            bitfield_used_bits = bitfield_used_bits + bits_width
            if bitfield_used_bits >= bitfield_unit_bits:
                offset = bitfield_unit_offset + bitfield_unit_size
                active_bitfield = false
                bitfield_used_bits = 0
            continue

        if active_bitfield:
            offset = bitfield_unit_offset + bitfield_unit_size
            active_bitfield = false
            bitfield_used_bits = 0

        offset = align_up(offset, align)

        field_layouts.push(FieldLayout(
            name: field.name,
            type_: field.type_,
            offset: offset,
            size: size,
            align: align,
            has_bits: false,
            bits_width: 0,
            bit_offset: 0
        ))

        offset = offset + size

    if active_bitfield:
        offset = bitfield_unit_offset + bitfield_unit_size

    val final_align = attr_effective_align(attr, max_align)
    val final_size = align_up(offset, final_align)

    TypeLayout(
        size: final_size,
        align: final_align,
        fields: field_layouts,
        stride: final_size
    )

fn compute_transparent_layout_for_arch(fields: [HirField], arch: TargetArch) -> TypeLayout:
    if fields_len(fields) != 1:
        return compute_c_layout_for_arch(fields, layoutattr_default_(), arch)

    val field = fields[0]
    val size = size_of_type_for_arch(field.type_, arch)
    val align = align_of_type_for_arch(field.type_, arch)

    TypeLayout(
        size: size,
        align: align,
        fields: [FieldLayout(
            name: field.name,
            type_: field.type_,
            offset: 0,
            size: size,
            align: align,
            has_bits: field.has_bits_attr,
            bits_width: if field.has_bits_attr: field.bits_width else: 0,
            bit_offset: 0
        )],
        stride: size
    )

# --- Type Size Summary by Architecture ---

# Get a summary of sizes for a type across all architectures
struct TypeSizeSummary:
    type_name: text
    size_8bit: i64
    size_16bit: i64
    size_32bit: i64
    size_64bit: i64
    align_8bit: i64
    align_16bit: i64
    align_32bit: i64
    align_64bit: i64

fn get_type_size_summary(type_name: text) -> TypeSizeSummary:
    TypeSizeSummary(
        type_name: type_name,
        size_8bit: primitive_size_for_arch(type_name, TargetArch.AVR) ?? 1,
        size_16bit: primitive_size_for_arch(type_name, TargetArch.MSP430) ?? 2,
        size_32bit: primitive_size_for_arch(type_name, TargetArch.X86) ?? 4,
        size_64bit: primitive_size_for_arch(type_name, TargetArch.X86_64) ?? 8,
        align_8bit: primitive_align_for_arch(type_name, TargetArch.AVR) ?? 1,
        align_16bit: primitive_align_for_arch(type_name, TargetArch.MSP430) ?? 2,
        align_32bit: primitive_align_for_arch(type_name, TargetArch.X86) ?? 4,
        align_64bit: primitive_align_for_arch(type_name, TargetArch.X86_64) ?? 8
    )


# ============================================================================
# Layout Verification for SFFI Export
# ============================================================================
#
# Computes and verifies struct layouts for C interop. The computed layout
# is used by the header generator to emit _Static_assert checks in generated
# C headers, catching ABI mismatches at C compile time.

struct LayoutMismatch:
    """Describes a layout mismatch between Simple and expected C layout."""
    field_name: text
    expected_offset: i64
    actual_offset: i64
    expected_size: i64
    actual_size: i64

struct LayoutVerification:
    """Result of layout verification for a struct/class.

    Contains the computed layout and any mismatches found. Used by the
    header generator to emit _Static_assert checks.
    """
    class_name: text
    total_size: i64
    alignment: i64
    fields: [FieldLayout]
    mismatches: [LayoutMismatch]
    is_valid: bool

fn verify_c_layout(class_name: text, fields: [HirField], attr: LayoutAttr) -> LayoutVerification:
    """Compute and verify C-compatible layout for an exported class.

    This function:
    1. Computes field offsets using C alignment rules
    2. Validates that the layout is self-consistent
    3. Returns a LayoutVerification with all field offsets for header generation

    The caller (header generator) uses the field offsets to emit:
        _Static_assert(offsetof(spl_ClassName, field) == N, "offset mismatch");
        _Static_assert(sizeof(spl_ClassName) == M, "size mismatch");
    """
    val layout = compute_struct_layout(fields, attr)
    var mismatches: [LayoutMismatch] = []

    # Verify each field's alignment is respected
    var fi = 0
    while fi < layout.fields.len():
        val field_layout = layout.fields[fi]

        # Check that offset is properly aligned
        if not is_aligned(field_layout.offset, field_layout.align):
            mismatches.push(LayoutMismatch(
                field_name: field_layout.name,
                expected_offset: align_up(field_layout.offset, field_layout.align),
                actual_offset: field_layout.offset,
                expected_size: field_layout.size,
                actual_size: field_layout.size
            ))

        fi = fi + 1

    # Verify total size is aligned to struct alignment
    val expected_total = align_up(layout.size, layout.align)
    if layout.size != expected_total:
        mismatches.push(LayoutMismatch(
            field_name: "__total_size__",
            expected_offset: 0,
            actual_offset: 0,
            expected_size: expected_total,
            actual_size: layout.size
        ))

    LayoutVerification(
        class_name: class_name,
        total_size: layout.size,
        alignment: layout.align,
        fields: layout.fields,
        mismatches: mismatches,
        is_valid: mismatches.len() == 0
    )

fn verify_c_layout_for_arch(class_name: text, fields: [HirField], attr: LayoutAttr, arch: TargetArch) -> LayoutVerification:
    """Compute and verify C-compatible layout for a specific target architecture.

    Same as verify_c_layout but uses architecture-specific sizes and alignments.
    """
    val layout = compute_struct_layout_for_arch(fields, attr, arch)
    var mismatches: [LayoutMismatch] = []

    var fi = 0
    while fi < layout.fields.len():
        val field_layout = layout.fields[fi]

        if not is_aligned(field_layout.offset, field_layout.align):
            mismatches.push(LayoutMismatch(
                field_name: field_layout.name,
                expected_offset: align_up(field_layout.offset, field_layout.align),
                actual_offset: field_layout.offset,
                expected_size: field_layout.size,
                actual_size: field_layout.size
            ))

        fi = fi + 1

    val expected_total = align_up(layout.size, layout.align)
    if layout.size != expected_total:
        mismatches.push(LayoutMismatch(
            field_name: "__total_size__",
            expected_offset: 0,
            actual_offset: 0,
            expected_size: expected_total,
            actual_size: layout.size
        ))

    LayoutVerification(
        class_name: class_name,
        total_size: layout.size,
        alignment: layout.align,
        fields: layout.fields,
        mismatches: mismatches,
        is_valid: mismatches.len() == 0
    )

fn generate_c_static_asserts(verification: LayoutVerification) -> text:
    """Generate C _Static_assert statements for layout verification.

    Produces code like:
        _Static_assert(sizeof(spl_ClassName) == 16, "size mismatch");
        _Static_assert(offsetof(spl_ClassName, field) == 0, "offset mismatch");

    This is emitted into the generated C header so the C compiler catches
    any ABI mismatch at compile time.
    """
    val name = verification.class_name
    var lines: [text] = []

    # Size assertion
    lines.push("_Static_assert(sizeof(spl_{name}) == {verification.total_size}, \"spl_{name} size mismatch\");")

    # Alignment assertion (using _Alignof in C11)
    lines.push("_Static_assert(_Alignof(spl_{name}) == {verification.alignment}, \"spl_{name} alignment mismatch\");")

    # Field offset assertions
    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        if not field.has_bits:
            lines.push("_Static_assert(offsetof(spl_{name}, {field.name}) == {field.offset}, \"spl_{name}.{field.name} offset mismatch\");")
        fi = fi + 1

    lines.join("\n")

fn generate_cpp_static_asserts(verification: LayoutVerification) -> text:
    """Generate C++ static_assert statements for layout verification."""
    val name = verification.class_name
    var lines: [text] = []

    lines.push("static_assert(sizeof(spl_{name}) == {verification.total_size}, \"spl_{name} size mismatch\");")
    lines.push("static_assert(alignof(spl_{name}) == {verification.alignment}, \"spl_{name} alignment mismatch\");")

    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        if not field.has_bits:
            lines.push("static_assert(offsetof(spl_{name}, {field.name}) == {field.offset}, \"spl_{name}.{field.name} offset mismatch\");")
        fi = fi + 1

    lines.join("\n")

fn generate_c_struct_def(verification: LayoutVerification) -> text:
    """Generate a C struct definition matching the computed layout.

    Produces code like:
        typedef struct spl_ClassName {
            int32_t precision;
            double value;
        } spl_ClassName;

    Used by the header generator alongside _Static_assert checks.
    """
    val name = verification.class_name
    var lines: [text] = []

    lines.push("typedef struct spl_{name} {")

    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        val c_type = _field_to_c_type(field)
        if field.has_bits:
            lines.push("    {c_type} {field.name} : {field.bits_width};")
        else:
            lines.push("    {c_type} {field.name};")
        fi = fi + 1

    lines.push("} spl_{name};")

    lines.join("\n")

fn _field_to_c_type(field: FieldLayout) -> text:
    """Map a field's size and alignment to the corresponding C type name.

    Uses size and alignment to determine the correct C type since we don't
    have the original HirType here — only the computed layout.
    """
    # Map by size (assuming standard C types)
    match field.size:
        case 1:
            if field.align == 1:
                "uint8_t"
            else:
                "uint8_t"
        case 2: "uint16_t"
        case 4:
            if field.align == 4:
                # Could be int32_t or float — default to int32_t
                "int32_t"
            else:
                "int32_t"
        case 8:
            if field.align == 8:
                # Could be int64_t or double — default to int64_t
                "int64_t"
            else:
                "int64_t"
        case 16: "__int128"
        case _: "uint8_t /* unknown size {field.size} */"

fn compute_padding_bytes(verification: LayoutVerification) -> i64:
    """Compute the total number of padding bytes in a struct layout.

    This helps developers understand how much space is wasted on alignment
    padding, which is useful for optimizing struct layout.
    """
    var data_bytes: i64 = 0
    var fi = 0
    while fi < verification.fields.len():
        data_bytes = data_bytes + verification.fields[fi].size
        fi = fi + 1

    verification.total_size - data_bytes


# ============================================================================
# Runtime Layout Verification
# ============================================================================
#
# Generates C runtime assert() calls for spl_verify_layouts().
# Complements the compile-time _Static_assert checks: the runtime function
# can be called from an init path to catch layout drift in dynamically
# loaded shared libraries where the header was compiled separately.

struct FieldOffset:
    """Simplified field offset record for runtime verification."""
    name: text
    offset: i64
    size: i64

fn compute_layout_verification(class_name: text, fields: [HirField], layout_attr: LayoutAttr) -> LayoutVerification:
    """Compute layout verification data for runtime assert generation.

    Wraps verify_c_layout and returns the same LayoutVerification
    struct. This is the public entry point for the runtime layout
    verification pipeline used by the C backend.
    """
    verify_c_layout(class_name, fields, layout_attr)

fn generate_runtime_layout_asserts(verification: LayoutVerification) -> text:
    """Generate C runtime assert() calls for spl_verify_layouts().

    Produces code like:
        assert(sizeof(spl_ClassName) == 16 && "spl_ClassName size mismatch");
        assert(offsetof(spl_ClassName, field) == 0 && "spl_ClassName.field offset mismatch");

    These are runtime checks (stdlib assert) rather than _Static_assert,
    so they catch mismatches when a shared library is loaded against
    a different header version at runtime.
    """
    val name = verification.class_name
    var lines: [text] = []

    # Size assertion
    lines.push("    assert(sizeof(spl_{name}) == {verification.total_size} && \"spl_{name} size mismatch\");")

    # Alignment assertion
    lines.push("    assert(_Alignof(spl_{name}) == {verification.alignment} && \"spl_{name} alignment mismatch\");")

    # Field offset assertions (skip bitfields — offsetof not meaningful for them)
    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        if not field.has_bits:
            lines.push("    assert(offsetof(spl_{name}, {field.name}) == {field.offset} && \"spl_{name}.{field.name} offset mismatch\");")
        fi = fi + 1

    lines.join("\n")

fn extract_field_offsets(verification: LayoutVerification) -> [FieldOffset]:
    """Extract simplified FieldOffset records from a LayoutVerification.

    Useful for tooling that only needs name/offset/size triples without
    the full FieldLayout details (type, alignment, bitfield info).
    """
    var offsets: [FieldOffset] = []
    var fi = 0
    while fi < verification.fields.len():
        val field = verification.fields[fi]
        offsets.push(FieldOffset(
            name: field.name,
            offset: field.offset,
            size: field.size
        ))
        fi = fi + 1
    offsets
