# EasyFix Rules - Shared Helpers
#
# Line iteration utilities, byte offset computation, and cached line splitting.
# Used by all rule sub-modules to avoid duplicating line-processing logic.

use std.tooling.easy_fix.{EasyFix}
use std.text.{levenshtein_distance}

# ============================================================================
# Data type: Line context for per-line rule callbacks
# ============================================================================

struct LineContext:
    """Context information for processing a source line."""
    line: text
    line_num: i64
    byte_offset: i64
    trimmed: text
    indent: i64

fn line_contexts(source: text) -> [LineContext]:
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0
    var contexts: [LineContext] = []

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()
        contexts.push(LineContext(
            line: line,
            line_num: line_num,
            byte_offset: byte_offset,
            trimmed: trimmed,
            indent: indent
        ))
        byte_offset = byte_offset + _text_index_len(line) + 1

    contexts

fn for_each_line(source: text, callback: fn(LineContext) -> [EasyFix]) -> [EasyFix]:
    """
    Iterate over source lines and collect fixes from callback.

    Handles the common pattern of splitting source, tracking line numbers/offsets,
    and collecting fixes. Reduces duplication in rule implementations.
    """
    var all_fixes: [EasyFix] = []

    for raw_context in line_contexts(source):
        val context: LineContext = raw_context
        val line_fixes: [EasyFix] = callback(context)
        for fix in line_fixes:
            all_fixes.push(fix)

    all_fixes

# ============================================================================
# Helper: compute byte offset for a given line/column (1-based)
# ============================================================================

fn byte_offset_of(source: String, target_line: Int, target_col: Int) -> Int:
    var lines = source.split("\n")
    var offset = 0
    var line_num = 1
    for line in lines:
        if line_num == target_line:
            return offset + target_col - 1
        offset = offset + _text_index_len(line) + 1  # +1 for \n
        line_num = line_num + 1
    offset

fn line_start_offset(source: String, target_line: Int) -> Int:
    byte_offset_of(source, target_line, 1)

fn line_end_offset(source: String, target_line: Int) -> Int:
    var lines = source.split("\n")
    var offset = 0
    var line_num = 1
    for line in lines:
        if line_num == target_line:
            return offset + _text_index_len(line)
        offset = offset + _text_index_len(line) + 1
        line_num = line_num + 1
    offset

# ============================================================================
# Cache management functions — now no-ops (globals removed to fix NULL-data crash)
# ============================================================================

fn set_line_cache(source: text):
    val _ = source

fn clear_line_cache():
    val _ = 0

fn get_cached_lines() -> [text]:
    []

fn get_cached_source() -> text:
    ""

# ============================================================================
# Levenshtein distance wrapper (used by check_typo_suggestion)
# ============================================================================

fn levenshtein(a: String, b: String) -> Int:
    levenshtein_distance(a, b)

fn replace_interpolation_identifier(expr: text, param: text, replacement: text) -> text:
    var result = ""
    var i = 0
    var in_interpolation = false
    while i < expr.len():
        val ch = expr[i:i + 1]
        if ch == "{" and i + 1 < expr.len() and expr[i + 1:i + 2] == "{":
            result = result + "{" + "{"
            i = i + 2
        elif ch == "}" and i + 1 < expr.len() and expr[i + 1:i + 2] == "}":
            result = result + "}" + "}"
            i = i + 2
        elif ch == "{":
            in_interpolation = true
            result = result + ch
            i = i + 1
        elif ch == "}":
            in_interpolation = false
            result = result + ch
            i = i + 1
        elif in_interpolation and i + param.len() <= expr.len() and expr[i:i + param.len()] == param:
            val before = if i == 0: "" else: expr[i - 1:i]
            val after = if i + param.len() >= expr.len(): "" else: expr[i + param.len():i + param.len() + 1]
            if (before == "" or not _helper_is_identifier_char(before)) and (after == "" or not _helper_is_identifier_char(after)):
                result = result + replacement
                i = i + param.len()
            else:
                result = result + ch
                i = i + 1
        else:
            result = result + ch
            i = i + 1
    result

fn _text_index_len(value: text) -> i64:
    var count = 0
    for _ch in value:
        count = count + 1
    count

fn _helper_is_identifier_char(ch: text) -> bool:
    "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789".contains(ch)
