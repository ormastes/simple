# Incremental duplicate detection - only reprocess changed files
#
# Caches previous analysis results and reuses them for unchanged files.
# Based on src/app/build/incremental.spl pattern.

use compiler.tools.duplicate_check.config.{DuplicationConfig, compute_config_hash}
use compiler.tools.duplicate_check.detector.{DuplicateBlock, find_duplicates_in_file, new_token_interner}
use compiler.tools.duplicate_check.math_utils.{hash_string}
use std.nogc_sync_mut.io.file_ops.{file_exists, file_read, file_write, file_hash_sha256}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}
use std.nogc_sync_mut.io.dir_ops.{dir_create_all}

struct IncrementalCacheEntry:
    file_path: text
    source_hash: text       # SHA256 hash of file content
    timestamp: i64          # When this was cached
    blocks: [DuplicateBlock]

struct IncrementalCache:
    entries: {text: IncrementalCacheEntry}
    cache_path: text
    config_hash: text       # Hash of config to detect config changes

fn escape_cache_text(value: text) -> text:
    var escaped = value.replace("\\", "\\\\")
    escaped = escaped.replace("|", "\\p")
    escaped = escaped.replace("\n", "\\n")
    escaped

fn unescape_cache_text(value: text) -> text:
    var unescaped = value.replace("\\n", "\n")
    unescaped = unescaped.replace("\\p", "|")
    unescaped = unescaped.replace("\\\\", "\\")
    unescaped

fn stable_block_hash(block: DuplicateBlock) -> i64:
    if block.code.len() > 0:
        return int(hash_string("{block.token_count}|{block.line_end - block.line_start}|{block.code}"))
    block.hash_value

fn normalize_block_hashes(blocks: [DuplicateBlock]) -> [DuplicateBlock]:
    var normalized = []
    for block in blocks:
        normalized.push(DuplicateBlock(
            file: block.file,
            line_start: block.line_start,
            line_end: block.line_end,
            token_count: block.token_count,
            hash_value: stable_block_hash(block),
            snippet_start_offset: block.snippet_start_offset,
            snippet_end_offset: block.snippet_end_offset,
            code: block.code
        ))
    normalized

fn cache_parent_dir(path: text) -> text:
    var last_slash = -1
    var i = 0
    while i < path.len():
        if path[i:i + 1] == "/":
            last_slash = i
        i = i + 1

    if last_slash <= 0:
        return "."

    path[0:last_slash]

fn load_incremental_cache(cache_path: text, config: DuplicationConfig) -> IncrementalCache:
    if not file_exists(cache_path):
        return IncrementalCache(
            entries: {},
            cache_path: cache_path,
            config_hash: compute_config_hash(config)
        )

    val content = file_read(cache_path)
    val lines = content.split("\n")

    var entries = {}
    var stored_config_hash = ""
    var i = 0

    while i < lines.len():
        val line = lines[i].trim()

        if line.starts_with("# config_hash:"):
            stored_config_hash = line[14:].trim()
        elif line.starts_with("#") or line.len() == 0:
            i = i + 1
            continue
        elif line.starts_with("file:"):
            # Parse file entry: file|hash|timestamp|block_count
            val parts = line.split("|")
            if parts.len() >= 4:
                val file_path = parts[0][5:].trim()  # Remove "file:" prefix
                val source_hash = parts[1].trim()
                val timestamp = int(parts[2])
                val block_count = int(parts[3])

                # Read blocks (next block_count lines)
                var blocks = []
                var j = 0
                while j < block_count and i + 1 + j < lines.len():
                    val block_line = lines[i + 1 + j].trim()
                    if block_line.len() > 0:
                        # Parse block: start_line|end_line|token_count|hash|start_offset|end_offset|code
                        val block_parts = block_line.split("|")
                        if block_parts.len() >= 7:
                            blocks.push(DuplicateBlock(
                                file: file_path,
                                line_start: int(block_parts[0]),
                                line_end: int(block_parts[1]),
                                token_count: int(block_parts[2]),
                                hash_value: int(block_parts[3]),
                                snippet_start_offset: int(block_parts[4]),
                                snippet_end_offset: int(block_parts[5]),
                                code: unescape_cache_text(block_parts[6])
                            ))
                    j = j + 1

                entries[file_path] = IncrementalCacheEntry(
                    file_path: file_path,
                    source_hash: source_hash,
                    timestamp: timestamp,
                    blocks: blocks
                )

                i = i + block_count

        i = i + 1

    # Invalidate cache if config changed
    val current_config_hash = compute_config_hash(config)
    if stored_config_hash.len() > 0 and stored_config_hash != current_config_hash:
        return IncrementalCache(
            entries: {},
            cache_path: cache_path,
            config_hash: current_config_hash
        )

    IncrementalCache(
        entries: entries,
        cache_path: cache_path,
        config_hash: current_config_hash
    )

fn save_incremental_cache(cache: IncrementalCache):
    # Ensure the cache directory exists before writing the serialized snapshot
    val cache_dir = cache_parent_dir(cache.cache_path)
    dir_create_all(cache_dir)

    var lines = []
    lines.push("# Duplicate detection incremental cache")
    lines.push("# config_hash: {cache.config_hash}")
    lines.push("")

    for file_path in cache.entries.keys():
        val entry = cache.entries[file_path]
        lines.push("file:{file_path}|{entry.source_hash}|{entry.timestamp}|{entry.blocks.len()}")

        for block in entry.blocks:
            val code = escape_cache_text(block.code)
            lines.push("  {block.line_start}|{block.line_end}|{block.token_count}|{block.hash_value}|{block.snippet_start_offset}|{block.snippet_end_offset}|{code}")

        lines.push("")

    file_write(cache.cache_path, lines.join("\n"))

fn needs_reprocessing(
    file_path: text,
    cache: IncrementalCache
) -> bool:
    if not cache.entries.has(file_path):
        return true  # File not in cache

    val entry = cache.entries[file_path]
    val current_hash = file_hash_sha256(file_path)

    current_hash != entry.source_hash

fn get_cached_blocks(
    file_path: text,
    cache: IncrementalCache
) -> [DuplicateBlock]:
    if cache.entries.has(file_path):
        val entry = cache.entries[file_path]
        val current_hash = file_hash_sha256(file_path)
        if current_hash == entry.source_hash:
            return entry.blocks

    []

fn update_cache_entry(
    cache: IncrementalCache,
    file_path: text,
    blocks: [DuplicateBlock]
):
    val source_hash = file_hash_sha256(file_path)
    val timestamp = current_time_ms()

    cache.entries[file_path] = IncrementalCacheEntry(
        file_path: file_path,
        source_hash: source_hash,
        timestamp: timestamp,
        blocks: blocks
    )

fn process_files_incremental(
    files: [text],
    config: DuplicationConfig,
    cache: IncrementalCache,
    cache_manager
) -> ([DuplicateBlock], IncrementalStats):
    var all_blocks: [DuplicateBlock] = []
    var cached_files = 0
    val interner = new_token_interner()

    for file_path in files:
        if needs_reprocessing(file_path, cache):
            val raw_blocks = find_duplicates_in_file(file_path, config, cache_manager, interner)
            val blocks = normalize_block_hashes(raw_blocks)
            update_cache_entry(cache, file_path, blocks)
            all_blocks.merge(blocks)
        else:
            cached_files = cached_files + 1
            val cached_blocks = get_cached_blocks(file_path, cache)
            all_blocks.merge(cached_blocks)

    val stats = compute_incremental_stats(files.len(), cached_files)
    save_incremental_cache(cache)
    (all_blocks, stats)

struct IncrementalStats:
    total_files: i64
    cached_files: i64
    reprocessed_files: i64
    cache_hit_rate: f64

fn compute_incremental_stats(
    total_files: i64,
    cached_files: i64
) -> IncrementalStats:
    val cache_hit_rate = if total_files > 0:
        (cached_files * 100) / total_files
    else:
        0

    IncrementalStats(
        total_files: total_files,
        cached_files: cached_files,
        reprocessed_files: total_files - cached_files,
        cache_hit_rate: cache_hit_rate
    )

fn format_incremental_stats(stats: IncrementalStats) -> text:
    "Incremental: {stats.reprocessed_files} changed, {stats.cached_files} cached ({stats.cache_hit_rate}% hit rate)"
