# Join point structs for AOP weaving


use mir (BlockId)
use compiler.mdsoc.weaving.join_point_kind.{JoinPointKind}

struct JoinPoint:
    """A detected join point in the MIR."""
    kind: JoinPointKind
    block_id: BlockId
    instruction_index: usize
    context: JoinPointContext

struct JoinPointContext:
    """Context information for join point matching."""
    function_name: text
    module_path: text
    signature: text
    attributes: [text]
    effects: [text]
