{
  "schema_version": 1,
  "compiler_abi": "simple.opt.mir.v1",
  "name": "trivial-copy-elim",
  "version": "1.0.0",
  "min_compiler_version": "0.9.8",
  "passes": [],
  "rules": [
    {
      "name": "copy_self_elim",
      "pattern": {
        "inst_count": 1,
        "slots": [
          {
            "kind_tag": "Copy",
            "operand_0": "$x",
            "operand_1": null,
            "dest": "$x"
          }
        ]
      },
      "rewrite": {
        "kind_tag": "Remove",
        "dest": "$x",
        "operands": []
      },
      "cost_delta": -1,
      "safety": "pure"
    }
  ]
}
