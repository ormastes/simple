# Auto-Vectorization Pass - Shared Types
#
# Common data structures used across all auto-vectorization sub-modules.
# This file has no dependencies on other auto_vectorize modules to prevent cycles.

use compiler.mir.mir_data.{LocalId, BlockId}

# ============================================================================
# Loop Analysis Types
# ============================================================================

struct LoopInfo:
    """Information about a detected loop."""
    header_block: BlockId
    body_blocks: [BlockId]
    exit_block: BlockId
    induction_var: LocalId
    start_value: i64
    end_value: i64
    step: i64

struct ArrayAccess:
    """Array access pattern."""
    base_array: LocalId
    index_expr: LocalId
    is_load: bool
    element_type: text

struct ComparisonPattern:
    """Byte-level comparison pattern for SIMD vectorization.
    Covers: byte < 0x80, byte >= 0x41, (byte & mask) != 0x80, etc."""
    operand: LocalId
    op: text
    threshold: i64
    has_mask: bool
    mask_value: i64

struct BitwisePattern:
    """Byte-level bitwise operation pattern for SIMD vectorization.
    Covers: byte | 0x20 (tolower), byte & 0xDF (toupper), byte ^ key, etc."""
    operand: LocalId
    op: text
    constant: i64

# ============================================================================
# Exports
# ============================================================================

