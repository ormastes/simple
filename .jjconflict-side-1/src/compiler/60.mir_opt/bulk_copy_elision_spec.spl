# SG-1.3 SOUND bulk-copy elision — firing + NON-FIRING safety proof (incl. H1/H2).
#
# elide_bulk_copy replaces a canonical contiguous element-copy run with one active `bulk_copy`
# intrinsic (the C backend lowers it to memmove). It is sound by STRICTNESS — fires ONLY on a
# consecutive run of `GEP src[i]; Load; GEP dst[i]; Store` units (i=0..k-1, k>=2, same
# src_base != dst_base, dst[i]=src[i]) AND when:
#   H1: the run's temporaries are dead outside the run (no other inst/terminator uses them);
#   H2: every loaded element is exactly 8 bytes (memmove copies count*8 bytes).
#
# The NON-FIRING tests are the safety proof — each targets one guard and asserts the block is
# left UNCHANGED (no bulk_copy). An over-eager bug flips one red; a lazy bug is harmless.
#
# Run:  SIMPLE_BOOTSTRAP_DRIVER=bin/release/x86_64-unknown-linux-gnu/simple_seed \
#       bin/simple run src/compiler/60.mir_opt/bulk_copy_elision_spec.spl

use compiler.mir.mir_instructions.{
    MirFunction, MirBlock, MirInst, MirInstKind,
    MirTerminator, MirOperand, MirOperandKind, BlockId
}
use compiler.mir.mir_types.{
    MirType, MirTypeKind, MirSignature, MirConstValue, LocalId, MirLocal, LocalKind
}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir_opt._OptimizationPasses.io_passes.{elide_bulk_copy}
use compiler.mir_opt.optimization_passes.{OptimizationStats}

fn _copy_op(id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(LocalId(id: id)))

fn _const_idx(v: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(v), MirType(kind: MirTypeKind.I64)))

fn _marker(name: text) -> MirInst:
    MirInst(kind: MirInstKind.Intrinsic(nil, name, []), span: nil)

# One canonical copy unit: GEP gs=src[idx]; Load ld=*gs; GEP gd=dst[idx]; Store *gd=ld.
fn _unit(src_base: i64, dst_base: i64, gs: i64, ld: i64, gd: i64, src_idx: i64, dst_idx: i64) -> [MirInst]:
    var u: [MirInst] = []
    u = u.push(MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: gs), _copy_op(src_base), [_const_idx(src_idx)]), span: nil))
    u = u.push(MirInst(kind: MirInstKind.Load(LocalId(id: ld), _copy_op(gs)), span: nil))
    u = u.push(MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: gd), _copy_op(dst_base), [_const_idx(dst_idx)]), span: nil))
    u = u.push(MirInst(kind: MirInstKind.Store(_copy_op(gd), _copy_op(ld)), span: nil))
    u

fn _fn_from2(insts: [MirInst], locals: [MirLocal]) -> MirFunction:
    val i64t = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(params: [], return_type: i64t, is_variadic: false)
    val block = MirBlock(
        id: BlockId(id: 0), label: Some("bb0"),
        instructions: insts, terminator: MirTerminator.Ret(nil)
    )
    MirFunction(
        symbol: SymbolId.new(0), name: "f", signature: sig,
        locals: locals, blocks: [block], entry_block: BlockId.new(0),
        span: nil, generic_params: [], is_generic_template: false,
        specialization_of: nil, type_bindings: {}
    )

fn _fn_from(insts: [MirInst]) -> MirFunction:
    _fn_from2(insts, [])

fn _local(id: i64, kind: MirTypeKind) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: nil, type_: MirType(kind: kind), kind: LocalKind.Temp, is_ghost: false)

fn _count(func: MirFunction, which: text) -> i64:
    var n = 0
    var bi = 0
    while bi < func.blocks.len():
        val insts = func.blocks[bi].instructions
        var ii = 0
        while ii < insts.len():
            match insts[ii].kind:
                case GetElementPtr(_, _, _):
                    if which == "gep": n = n + 1
                case Load(_, _):
                    if which == "load": n = n + 1
                case Store(_, _):
                    if which == "store": n = n + 1
                case Intrinsic(_, nm, _):
                    if which == "bulkcopy" and nm == "bulk_copy": n = n + 1
                    if which == "marker" and nm == "m": n = n + 1
                case _:
                    pass
            ii = ii + 1
        bi = bi + 1
    n

fn _bulk_copy_count(func: MirFunction) -> i64:
    var result = -1
    var bi = 0
    while bi < func.blocks.len():
        val insts = func.blocks[bi].instructions
        var ii = 0
        while ii < insts.len():
            match insts[ii].kind:
                case Intrinsic(_, nm, args):
                    if nm == "bulk_copy" and args.len() == 3:
                        match args[2].kind:
                            case Const(cv, _):
                                match cv:
                                    case Int(num): result = num
                                    case _: pass
                            case _: pass
                case _:
                    pass
            ii = ii + 1
        bi = bi + 1
    result

fn _elide(insts: [MirInst]) -> MirFunction:
    elide_bulk_copy(_fn_from(insts), OptimizationStats.create())

fn _elide2(insts: [MirInst], locals: [MirLocal]) -> MirFunction:
    elide_bulk_copy(_fn_from2(insts, locals), OptimizationStats.create())

fn _canonical(k: i64) -> [MirInst]:
    var insts: [MirInst] = []
    var i = 0
    while i < k:
        insts = insts.concat(_unit(10, 20, 100 + i * 4, 101 + i * 4, 102 + i * 4, i, i))
        i = i + 1
    insts

# i64 (8-byte) type entries for the loaded values of a canonical k-copy, so H2 passes
# (it now requires positive 8-byte confirmation; absent type blocks).
fn _canonical_locals(k: i64) -> [MirLocal]:
    var ls: [MirLocal] = []
    var i = 0
    while i < k:
        ls = ls.push(_local(101 + i * 4, MirTypeKind.I64))
        i = i + 1
    ls

describe "SG-1.3 sound bulk-copy elision":
    # ── FIRING ─────────────────────────────────────────────────────────────
    it "fires on a canonical 2-element copy: emits 1 bulk_copy, removes element ops":
        val out = _elide2(_canonical(2), _canonical_locals(2))
        expect(_count(out, "bulkcopy")).to_equal(1)
        expect(_count(out, "gep")).to_equal(0)
        expect(_count(out, "load")).to_equal(0)
        expect(_count(out, "store")).to_equal(0)

    it "carries the element count (k=3)":
        expect(_bulk_copy_count(_elide2(_canonical(3), _canonical_locals(3)))).to_equal(3)

    it "preserves surrounding instructions (only the copy run is replaced)":
        var insts: [MirInst] = []
        insts = insts.push(_marker("m"))
        insts = insts.concat(_canonical(2))
        insts = insts.push(_marker("m"))
        val out = _elide2(insts, _canonical_locals(2))
        expect(_count(out, "bulkcopy")).to_equal(1)
        expect(_count(out, "marker")).to_equal(2)
        expect(_count(out, "gep")).to_equal(0)

    # ── NON-FIRING: structural guards ──────────────────────────────────────
    it "does NOT fire when indices are not contiguous from 0 (1,2 not 0,1)":
        var insts: [MirInst] = []
        insts = insts.concat(_unit(10, 20, 100, 101, 102, 1, 1))
        insts = insts.concat(_unit(10, 20, 104, 105, 106, 2, 2))
        expect(_count(_elide(insts), "bulkcopy")).to_equal(0)
        expect(_count(_elide(insts), "store")).to_equal(2)

    it "does NOT fire when dst index != src index":
        var insts: [MirInst] = []
        insts = insts.concat(_unit(10, 20, 100, 101, 102, 0, 0))
        insts = insts.concat(_unit(10, 20, 104, 105, 106, 1, 0))
        expect(_count(_elide(insts), "bulkcopy")).to_equal(0)

    it "does NOT fire when an instruction is interleaved between copy units":
        var insts: [MirInst] = []
        insts = insts.concat(_unit(10, 20, 100, 101, 102, 0, 0))
        insts = insts.push(_marker("x"))
        insts = insts.concat(_unit(10, 20, 104, 105, 106, 1, 1))
        expect(_count(_elide(insts), "bulkcopy")).to_equal(0)

    # ── NON-FIRING: H1 (temp liveness) and H2 (element size) ───────────────
    # NOTE: these H1 tests pass i64 locals so H2 is satisfied — H1 is then the SOLE blocker
    # (otherwise a 0 count could be H2's doing, giving false confidence about H1).
    it "H1: does NOT fire when a loaded temp is used (via BinOp) after the run":
        var insts: [MirInst] = []
        insts = insts.concat(_canonical(2))
        # BinOp reads local 101 (= ld of unit 0) AFTER the run -> deleting its Load would dangle
        insts = insts.push(MirInst(kind: MirInstKind.BinOp(LocalId(id: 300), MirBinOp.Add, _copy_op(101), _const_idx(1)), span: nil))
        val out = _elide2(insts, _canonical_locals(2))
        expect(_count(out, "bulkcopy")).to_equal(0)
        expect(_count(out, "store")).to_equal(2)

    it "H1: does NOT fire when a loaded temp is used by a Copy INSTRUCTION after the run":
        # Regression for the re-review finding: Copy's src is a raw LocalId, not a MirOperand;
        # H1 must match it directly. Without the fix this WRONGLY fires.
        var insts: [MirInst] = []
        insts = insts.concat(_canonical(2))
        insts = insts.push(MirInst(kind: MirInstKind.Copy(LocalId(id: 500), LocalId(id: 101)), span: nil))
        val out = _elide2(insts, _canonical_locals(2))
        expect(_count(out, "bulkcopy")).to_equal(0)

    it "H1: does NOT fire when an element pointer escapes via the terminator":
        # Ret returns local 102 (= gd of unit 0); eliding would drop its defining GEP.
        var insts: [MirInst] = []
        insts = insts.concat(_canonical(2))
        val i64t = MirType(kind: MirTypeKind.I64)
        val sig = MirSignature(params: [], return_type: i64t, is_variadic: false)
        val block = MirBlock(id: BlockId(id: 0), label: Some("bb0"), instructions: insts, terminator: MirTerminator.Ret(Some(_copy_op(102))))
        val func = MirFunction(symbol: SymbolId.new(0), name: "f", signature: sig, locals: _canonical_locals(2), blocks: [block], entry_block: BlockId.new(0), span: nil, generic_params: [], is_generic_template: false, specialization_of: nil, type_bindings: {})
        val out = elide_bulk_copy(func, OptimizationStats.create())
        expect(_count(out, "bulkcopy")).to_equal(0)

    it "H2: does NOT fire when the loaded element is sub-8-byte (i32)":
        # Same canonical run, but the loaded values (101,105) are typed i32 (4 bytes).
        var locals: [MirLocal] = []
        locals = locals.push(_local(101, MirTypeKind.I32))
        locals = locals.push(_local(105, MirTypeKind.I32))
        val out = _elide2(_canonical(2), locals)
        expect(_count(out, "bulkcopy")).to_equal(0)
        expect(_count(out, "store")).to_equal(2)

    it "H2: STILL fires when elements are explicitly typed i64 (8 bytes)":
        var locals: [MirLocal] = []
        locals = locals.push(_local(101, MirTypeKind.I64))
        locals = locals.push(_local(105, MirTypeKind.I64))
        expect(_count(_elide2(_canonical(2), locals), "bulkcopy")).to_equal(1)
