# General IO Passes — Stats and Regression Tests
#
# Co-located with optimization_passes.spl. Tests the new stat fields
# and verifies no regression in existing optimization engine.

use compiler.mir_opt.optimization_passes.{
    OptimizationStats, OptimizationEngine, OptimizationLevel
}
use compiler.mir.mir_types.{MirType, MirConstValue}
use compiler.mir.mir_instructions.{MirOperand, MirOperandKind, MirBinOp, LocalId}

describe "General IO Stats Fields":
    it "has bulk_copy_count initialized to zero":
        val stats = OptimizationStats.create()
        expect(stats.bulk_copy_count).to_equal(0)

    it "has bulk_fill_count initialized to zero":
        val stats = OptimizationStats.create()
        expect(stats.bulk_fill_count).to_equal(0)

    it "has bulk_cmp_count initialized to zero":
        val stats = OptimizationStats.create()
        expect(stats.bulk_cmp_count).to_equal(0)

    it "has endian_load_count initialized to zero":
        val stats = OptimizationStats.create()
        expect(stats.endian_load_count).to_equal(0)

    it "has endian_store_count initialized to zero":
        val stats = OptimizationStats.create()
        expect(stats.endian_store_count).to_equal(0)

describe "Existing Stats Regression":
    it "has write_coalesce_count initialized to zero":
        val stats = OptimizationStats.create()
        expect(stats.write_coalesce_count).to_equal(0)

    it "has read_ahead_hoist_count initialized to zero":
        val stats = OptimizationStats.create()
        expect(stats.read_ahead_hoist_count).to_equal(0)

    it "has syscall_batch_count initialized to zero":
        val stats = OptimizationStats.create()
        expect(stats.syscall_batch_count).to_equal(0)

describe "Optimization Engine Regression":
    it "constant folding still works":
        val engine = OptimizationEngine.create(OptimizationLevel.Basic)
        val left = MirOperand.const_int(3)
        val right = MirOperand.const_int(7)
        val result = engine.try_fold_binop(MirBinOp.Add, left, right)
        expect(result.?).to_equal(true)

    it "strength reduction log2 still works":
        val engine = OptimizationEngine.create(OptimizationLevel.Standard)
        val shift = engine.log2_if_power_of_2(8)
        expect(shift.?).to_equal(true)
        expect(shift.unwrap()).to_equal(3)
