# HWIR optimization pass model.

use compiler.mir.hwir.types.{HwModule, HwCostModel}

class HwirOptPassConfig:
    """Shared enable/disable flags for HWIR optimization passes."""
    width_narrowing: bool
    structural_simplify: bool
    resource_binding: bool
    fsm_opt: bool
    memory_inference: bool
    dsp_inference: bool
    profile: text

    static fn all_enabled(profile: text) -> HwirOptPassConfig:
        return HwirOptPassConfig(
            width_narrowing: true,
            structural_simplify: true,
            resource_binding: true,
            fsm_opt: true,
            memory_inference: true,
            dsp_inference: true,
            profile: profile
        )

    static fn none(profile: text) -> HwirOptPassConfig:
        return HwirOptPassConfig(
            width_narrowing: false,
            structural_simplify: false,
            resource_binding: false,
            fsm_opt: false,
            memory_inference: false,
            dsp_inference: false,
            profile: profile
        )

class HwirOptPassResult:
    """Deterministic summary of one HWIR optimization pass."""
    pass_name: text
    changed: bool
    removed_nodes: i32
    narrowed_bits: i32
    shared_resources: i32
    inserted_pipeline_stages: i32
    cost_before: HwCostModel
    cost_after: HwCostModel
    note: text

    me to_text() -> text:
        return self.pass_name + ": changed=" + self.changed.to_text() + ", removed=" + self.removed_nodes.to_text() + ", narrowed_bits=" + self.narrowed_bits.to_text()

    static fn unchanged(pass_name: text, module: HwModule, note: text) -> HwirOptPassResult:
        return HwirOptPassResult(
            pass_name: pass_name,
            changed: false,
            removed_nodes: 0,
            narrowed_bits: 0,
            shared_resources: 0,
            inserted_pipeline_stages: 0,
            cost_before: module.cost,
            cost_after: module.cost,
            note: note
        )

    static fn changed(pass_name: text, module: HwModule, cost_after: HwCostModel, removed: i32, narrowed: i32, shared: i32, stages: i32, note: text) -> HwirOptPassResult:
        return HwirOptPassResult(
            pass_name: pass_name,
            changed: true,
            removed_nodes: removed,
            narrowed_bits: narrowed,
            shared_resources: shared,
            inserted_pipeline_stages: stages,
            cost_before: module.cost,
            cost_after: cost_after,
            note: note
        )

fn hwir_cost_delta_lut(cost: HwCostModel, delta: i32) -> HwCostModel:
    return HwCostModel(
        lut_count: cost.lut_count + delta,
        ff_count: cost.ff_count,
        dsp_count: cost.dsp_count,
        bram_count: cost.bram_count,
        latency_cycles: cost.latency_cycles,
        fmax_mhz: cost.fmax_mhz
    )

fn hwir_cost_delta_ff(cost: HwCostModel, delta: i32) -> HwCostModel:
    return HwCostModel(
        lut_count: cost.lut_count,
        ff_count: cost.ff_count + delta,
        dsp_count: cost.dsp_count,
        bram_count: cost.bram_count,
        latency_cycles: cost.latency_cycles,
        fmax_mhz: cost.fmax_mhz
    )

fn hwir_cost_with_resource_delta(cost: HwCostModel, lut_delta: i32, ff_delta: i32, dsp_delta: i32, bram_delta: i32, latency_delta: i32) -> HwCostModel:
    return HwCostModel(
        lut_count: cost.lut_count + lut_delta,
        ff_count: cost.ff_count + ff_delta,
        dsp_count: cost.dsp_count + dsp_delta,
        bram_count: cost.bram_count + bram_delta,
        latency_cycles: cost.latency_cycles + latency_delta,
        fmax_mhz: cost.fmax_mhz
    )
