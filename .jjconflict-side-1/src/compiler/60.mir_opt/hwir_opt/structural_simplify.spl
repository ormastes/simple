# HWIR structural simplification.

use compiler.mir.hwir.types.{HwModule}
use compiler.mir_opt.hwir_opt.pass_model.{HwirOptPassResult, hwir_cost_delta_lut}

class HwirStructuralStats:
    """Counts of structural simplifications found in an HWIR module."""
    constant_folds: i32
    dead_signals: i32
    dead_registers: i32
    redundant_muxes: i32
    cse_hits: i32

    me removed_nodes() -> i32:
        return self.dead_signals + self.dead_registers + self.redundant_muxes + self.cse_hits

    me total_changes() -> i32:
        return self.constant_folds + self.removed_nodes()

fn hwir_structural_simplify_pass(module: HwModule, stats: HwirStructuralStats) -> HwirOptPassResult:
    val changes = stats.total_changes()
    if changes == 0:
        return HwirOptPassResult.unchanged("structural_simplify", module, "no constant folds or removable nodes")
    val lut_reduction = 0 - changes
    return HwirOptPassResult.changed("structural_simplify", module, hwir_cost_delta_lut(module.cost, lut_reduction), stats.removed_nodes(), 0, 0, 0, "folded constants and removed redundant structure")
