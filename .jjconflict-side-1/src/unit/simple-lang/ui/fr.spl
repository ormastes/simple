# Unit: Fr
# Kind: UiFraction
# Symbol: fr
# Canonical scale: 1.0 fr

class Fr:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Fr) -> Fr: Fr(value: self.value + other.value)
    fn sub(other: Fr) -> Fr: Fr(value: self.value - other.value)

    static fn kind() -> text: "UiFraction"
    static fn symbol() -> text: "fr"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "fr"
    static fn zero() -> Fr: Fr(value: 0.0)

export Fr
