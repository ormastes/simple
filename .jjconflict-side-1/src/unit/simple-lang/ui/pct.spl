# Unit: Pct
# Kind: UiFraction
# Symbol: pct
# Canonical scale: 0.01 ratio

class Pct:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Pct) -> Pct: Pct(value: self.value + other.value)
    fn sub(other: Pct) -> Pct: Pct(value: self.value - other.value)

    static fn kind() -> text: "UiFraction"
    static fn symbol() -> text: "pct"
    static fn scale_to_base() -> f64: 0.01
    static fn base_unit() -> text: "ratio"
    static fn zero() -> Pct: Pct(value: 0.0)

export Pct
