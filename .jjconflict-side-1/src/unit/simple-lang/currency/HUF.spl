# Unit: Huf
# Kind: Currency
# Symbol: HUF
# Canonical scale: 1.0 USD

class Huf:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Huf) -> Huf: Huf(value: self.value + other.value)
    fn sub(other: Huf) -> Huf: Huf(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "HUF"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Huf: Huf(value: 0.0)

export Huf
