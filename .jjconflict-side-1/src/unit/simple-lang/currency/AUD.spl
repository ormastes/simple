# Unit: Aud
# Kind: Currency
# Symbol: AUD
# Canonical scale: 1.0 USD

class Aud:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Aud) -> Aud: Aud(value: self.value + other.value)
    fn sub(other: Aud) -> Aud: Aud(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "AUD"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Aud: Aud(value: 0.0)

export Aud
