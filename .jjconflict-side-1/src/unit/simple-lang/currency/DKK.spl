# Unit: Dkk
# Kind: Currency
# Symbol: DKK
# Canonical scale: 1.0 USD

class Dkk:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Dkk) -> Dkk: Dkk(value: self.value + other.value)
    fn sub(other: Dkk) -> Dkk: Dkk(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "DKK"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Dkk: Dkk(value: 0.0)

export Dkk
