# Unit: NewtonF
# Kind: Force
# Symbol: N
# Canonical scale: 1.0 N

class NewtonF:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: NewtonF) -> NewtonF: NewtonF(value: self.value + other.value)
    fn sub(other: NewtonF) -> NewtonF: NewtonF(value: self.value - other.value)

    static fn kind() -> text: "Force"
    static fn symbol() -> text: "N"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "N"
    static fn zero() -> NewtonF: NewtonF(value: 0.0)

export NewtonF
