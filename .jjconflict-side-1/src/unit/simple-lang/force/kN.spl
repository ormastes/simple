# Unit: KiloNewton
# Kind: Force
# Symbol: kN
# Canonical scale: 1000.0 N

class KiloNewton:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloNewton) -> KiloNewton: KiloNewton(value: self.value + other.value)
    fn sub(other: KiloNewton) -> KiloNewton: KiloNewton(value: self.value - other.value)

    static fn kind() -> text: "Force"
    static fn symbol() -> text: "kN"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "N"
    static fn zero() -> KiloNewton: KiloNewton(value: 0.0)

export KiloNewton
