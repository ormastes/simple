# Unit: Lbf
# Kind: Force
# Symbol: lbf
# Canonical scale: 4.4482216152605 N

class Lbf:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Lbf) -> Lbf: Lbf(value: self.value + other.value)
    fn sub(other: Lbf) -> Lbf: Lbf(value: self.value - other.value)

    static fn kind() -> text: "Force"
    static fn symbol() -> text: "lbf"
    static fn scale_to_base() -> f64: 4.4482216152605
