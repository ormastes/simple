# Unit: Kg
# Kind: Mass
# Symbol: kg
# Canonical scale: 1.0 kg

class Kg:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Kg) -> Kg: Kg(value: self.value + other.value)
    fn sub(other: Kg) -> Kg: Kg(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "kg"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "kg"
    static fn zero() -> Kg: Kg(value: 0.0)

export Kg
