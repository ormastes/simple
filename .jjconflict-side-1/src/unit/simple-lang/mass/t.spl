# Unit: Tonne
# Kind: Mass
# Symbol: t
# Canonical scale: 1000.0 kg

class Tonne:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Tonne) -> Tonne: Tonne(value: self.value + other.value)
    fn sub(other: Tonne) -> Tonne: Tonne(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "t"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "kg"
    static fn zero() -> Tonne: Tonne(value: 0.0)

export Tonne
