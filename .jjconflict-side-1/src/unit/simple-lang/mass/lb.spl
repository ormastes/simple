# Unit: Lb
# Kind: Mass
# Symbol: lb
# Canonical scale: 0.45359237 kg

class Lb:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Lb) -> Lb: Lb(value: self.value + other.value)
    fn sub(other: Lb) -> Lb: Lb(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "lb"
    static fn scale_to_base() -> f64: 0.45359237
    static fn base_unit() -> text: "kg"
    static fn zero() -> Lb: Lb(value: 0.0)

export Lb
