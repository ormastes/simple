# Unit: Month
# Kind: Time
# Symbol: month
# Canonical scale: 2629746.0 s

class Month:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Month) -> Month: Month(value: self.value + other.value)
    fn sub(other: Month) -> Month: Month(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "month"
    static fn scale_to_base() -> f64: 2629746.0
    static fn base_unit() -> text: "s"
    static fn zero() -> Month: Month(value: 0.0)

export Month
