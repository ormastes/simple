# Unit: Century
# Kind: Time
# Symbol: century
# Canonical scale: 3155695200.0 s

class Century:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Century) -> Century: Century(value: self.value + other.value)
    fn sub(other: Century) -> Century: Century(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "century"
    static fn scale_to_base() -> f64: 3155695200.0
    static fn base_unit() -> text: "s"
    static fn zero() -> Century: Century(value: 0.0)

export Century
