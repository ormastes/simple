# Unit: Week
# Kind: Time
# Symbol: week
# Canonical scale: 604800.0 s

class Week:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Week) -> Week: Week(value: self.value + other.value)
    fn sub(other: Week) -> Week: Week(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "week"
    static fn scale_to_base() -> f64: 604800.0
    static fn base_unit() -> text: "s"
    static fn zero() -> Week: Week(value: 0.0)

export Week
