# Unit: Day
# Kind: Time
# Symbol: day
# Canonical scale: 86400.0 s

class Day:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Day) -> Day: Day(value: self.value + other.value)
    fn sub(other: Day) -> Day: Day(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "day"
    static fn scale_to_base() -> f64: 86400.0
    static fn base_unit() -> text: "s"
    static fn zero() -> Day: Day(value: 0.0)

export Day
