# Unit: Fortnight
# Kind: Time
# Symbol: fortnight
# Canonical scale: 1209600.0 s

class Fortnight:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Fortnight) -> Fortnight: Fortnight(value: self.value + other.value)
    fn sub(other: Fortnight) -> Fortnight: Fortnight(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "fortnight"
    static fn scale_to_base() -> f64: 1209600.0
    static fn base_unit() -> text: "s"
    static fn zero() -> Fortnight: Fortnight(value: 0.0)

export Fortnight
