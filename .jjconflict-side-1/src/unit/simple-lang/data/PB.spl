# Unit: PetaByte
# Kind: Data
# Symbol: PB
# Canonical scale: 1000000000000000.0 B

class PetaByte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: PetaByte) -> PetaByte: PetaByte(value: self.value + other.value)
    fn sub(other: PetaByte) -> PetaByte: PetaByte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "PB"
    static fn scale_to_base() -> f64: 1000000000000000.0
    static fn base_unit() -> text: "B"
    static fn zero() -> PetaByte: PetaByte(value: 0.0)

export PetaByte
