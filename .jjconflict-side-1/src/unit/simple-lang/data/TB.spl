# Unit: TeraByte
# Kind: Data
# Symbol: TB
# Canonical scale: 1000000000000.0 B

class TeraByte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: TeraByte) -> TeraByte: TeraByte(value: self.value + other.value)
    fn sub(other: TeraByte) -> TeraByte: TeraByte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "TB"
    static fn scale_to_base() -> f64: 1000000000000.0
    static fn base_unit() -> text: "B"
    static fn zero() -> TeraByte: TeraByte(value: 0.0)

export TeraByte
