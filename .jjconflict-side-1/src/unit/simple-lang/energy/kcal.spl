# Unit: KiloCalorie
# Kind: Energy
# Symbol: kcal
# Canonical scale: 4184.0 J

class KiloCalorie:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloCalorie) -> KiloCalorie: KiloCalorie(value: self.value + other.value)
    fn sub(other: KiloCalorie) -> KiloCalorie: KiloCalorie(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "kcal"
    static fn scale_to_base() -> f64: 4184.0
    static fn base_unit() -> text: "J"
    static fn zero() -> KiloCalorie: KiloCalorie(value: 0.0)

export KiloCalorie
