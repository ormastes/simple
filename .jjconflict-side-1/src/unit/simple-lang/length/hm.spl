# Unit: Hm
# Kind: Length
# Symbol: hm
# Canonical scale: 100.0 m

class Hm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Hm) -> Hm: Hm(value: self.value + other.value)
    fn sub(other: Hm) -> Hm: Hm(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "hm"
    static fn scale_to_base() -> f64: 100.0
    static fn base_unit() -> text: "m"
    static fn zero() -> Hm: Hm(value: 0.0)

export Hm
