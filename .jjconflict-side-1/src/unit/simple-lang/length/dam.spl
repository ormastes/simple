# Unit: Dam
# Kind: Length
# Symbol: dam
# Canonical scale: 10.0 m

class Dam:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Dam) -> Dam: Dam(value: self.value + other.value)
    fn sub(other: Dam) -> Dam: Dam(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "dam"
    static fn scale_to_base() -> f64: 10.0
    static fn base_unit() -> text: "m"
    static fn zero() -> Dam: Dam(value: 0.0)

export Dam
