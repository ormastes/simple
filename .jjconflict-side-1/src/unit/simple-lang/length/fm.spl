# Unit: Fm
# Kind: Length
# Symbol: fm
# Canonical scale: 1e-15 m

class Fm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Fm) -> Fm: Fm(value: self.value + other.value)
    fn sub(other: Fm) -> Fm: Fm(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "fm"
    static fn scale_to_base() -> f64: 1e-15
    static fn base_unit() -> text: "m"
    static fn zero() -> Fm: Fm(value: 0.0)

export Fm
