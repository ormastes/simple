# Unit: Pm
# Kind: Length
# Symbol: pm
# Canonical scale: 1e-12 m

class Pm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Pm) -> Pm: Pm(value: self.value + other.value)
    fn sub(other: Pm) -> Pm: Pm(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "pm"
    static fn scale_to_base() -> f64: 1e-12
    static fn base_unit() -> text: "m"
    static fn zero() -> Pm: Pm(value: 0.0)

export Pm
