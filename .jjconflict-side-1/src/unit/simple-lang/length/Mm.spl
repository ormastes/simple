# Unit: Megametre
# Kind: Length
# Symbol: Mm
# Canonical scale: 1000000.0 m

class Megametre:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Megametre) -> Megametre: Megametre(value: self.value + other.value)
    fn sub(other: Megametre) -> Megametre: Megametre(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "Mm"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "m"
    static fn zero() -> Megametre: Megametre(value: 0.0)

export Megametre
