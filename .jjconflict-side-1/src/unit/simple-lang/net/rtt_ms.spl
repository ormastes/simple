# Unit: RttMs
# Kind: NetLatency
# Symbol: rtt_ms
# Canonical scale: 0.001 s

class RttMs:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: RttMs) -> RttMs: RttMs(value: self.value + other.value)
    fn sub(other: RttMs) -> RttMs: RttMs(value: self.value - other.value)

    static fn kind() -> text: "NetLatency"
    static fn symbol() -> text: "rtt_ms"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "s"
