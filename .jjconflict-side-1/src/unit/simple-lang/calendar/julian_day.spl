# Unit: JulianDay
# Kind: CalendarDay
# Symbol: julian_day
# Canonical scale: 1.0 day

class JulianDay:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: JulianDay) -> JulianDay: JulianDay(value: self.value + other.value)
    fn sub(other: JulianDay) -> JulianDay: JulianDay(value: self.value - other.value)

    static fn kind() -> text: "CalendarDay"
    static fn symbol() -> text: "julian_day"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "day"
    static fn zero() -> JulianDay: JulianDay(value: 0.0)

export JulianDay
