# Unit: IsoWeek
# Kind: CalendarWeek
# Symbol: iso_week
# Canonical scale: 7.0 day

class IsoWeek:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: IsoWeek) -> IsoWeek: IsoWeek(value: self.value + other.value)
    fn sub(other: IsoWeek) -> IsoWeek: IsoWeek(value: self.value - other.value)

    static fn kind() -> text: "CalendarWeek"
    static fn symbol() -> text: "iso_week"
    static fn scale_to_base() -> f64: 7.0
    static fn base_unit() -> text: "day"
    static fn zero() -> IsoWeek: IsoWeek(value: 0.0)

export IsoWeek
