# Unit: EarthMass
# Kind: Mass
# Symbol: earth_mass
# Canonical scale: 5.9722e+24 kg

class EarthMass:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: EarthMass) -> EarthMass: EarthMass(value: self.value + other.value)
    fn sub(other: EarthMass) -> EarthMass: EarthMass(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "earth_mass"
    static fn scale_to_base() -> f64: 5.9722e+24
    static fn base_unit() -> text: "kg"
    static fn zero() -> EarthMass: EarthMass(value: 0.0)

export EarthMass
