# Unit: KiloWatt
# Kind: Power
# Symbol: kW
# Canonical scale: 1000.0 W

class KiloWatt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloWatt) -> KiloWatt: KiloWatt(value: self.value + other.value)
    fn sub(other: KiloWatt) -> KiloWatt: KiloWatt(value: self.value - other.value)

    static fn kind() -> text: "Power"
    static fn symbol() -> text: "kW"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "W"
    static fn zero() -> KiloWatt: KiloWatt(value: 0.0)

export KiloWatt
