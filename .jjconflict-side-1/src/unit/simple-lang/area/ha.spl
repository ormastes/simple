# Unit: Hectare
# Kind: Area
# Symbol: ha
# Canonical scale: 10000.0 m2

class Hectare:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Hectare) -> Hectare: Hectare(value: self.value + other.value)
    fn sub(other: Hectare) -> Hectare: Hectare(value: self.value - other.value)

    static fn kind() -> text: "Area"
    static fn symbol() -> text: "ha"
    static fn scale_to_base() -> f64: 10000.0
    static fn base_unit() -> text: "m2"
    static fn zero() -> Hectare: Hectare(value: 0.0)

export Hectare
