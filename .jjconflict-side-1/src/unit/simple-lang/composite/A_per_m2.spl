# Composite Unit: AperM2
# Kind: CurrentDensity
# Symbol: A_per_m2
# Scale to SI base: 1.0 A/m^2

class AperM2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: AperM2) -> AperM2: AperM2(value: self.value + other.value)
    fn sub(other: AperM2) -> AperM2: AperM2(value: self.value - other.value)

    static fn kind() -> text: "CurrentDensity"
    static fn symbol() -> text: "A_per_m2"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "A/m^2"
    static fn numerator() -> [text]: ["A"]
    static fn denominator() -> [text]: ["m", "m"]
    static fn zero() -> AperM2: AperM2(value: 0.0)

export AperM2
