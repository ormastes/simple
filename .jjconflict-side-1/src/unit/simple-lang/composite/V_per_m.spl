# Composite Unit: VperM
# Kind: ElectricField
# Symbol: V_per_m
# Scale to SI base: 1.0 V/m

class VperM:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: VperM) -> VperM: VperM(value: self.value + other.value)
    fn sub(other: VperM) -> VperM: VperM(value: self.value - other.value)

    static fn kind() -> text: "ElectricField"
    static fn symbol() -> text: "V_per_m"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "V/m"
    static fn numerator() -> [text]: ["V"]
    static fn denominator() -> [text]: ["m"]
    static fn zero() -> VperM: VperM(value: 0.0)

export VperM
