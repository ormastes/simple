# Composite Unit: KmPerL
# Kind: FuelEconomy
# Symbol: km_per_L
# Scale to SI base: 1.0 km/L

class KmPerL:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KmPerL) -> KmPerL: KmPerL(value: self.value + other.value)
    fn sub(other: KmPerL) -> KmPerL: KmPerL(value: self.value - other.value)

    static fn kind() -> text: "FuelEconomy"
    static fn symbol() -> text: "km_per_L"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "km/L"
    static fn numerator() -> [text]: ["km"]
    static fn denominator() -> [text]: ["L"]
    static fn zero() -> KmPerL: KmPerL(value: 0.0)

export KmPerL
