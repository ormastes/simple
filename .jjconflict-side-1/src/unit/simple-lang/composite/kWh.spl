# Composite Unit: KiloWattHour
# Kind: Energy
# Symbol: kWh
# Scale to SI base: 3600000.0 J

class KiloWattHour:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloWattHour) -> KiloWattHour: KiloWattHour(value: self.value + other.value)
    fn sub(other: KiloWattHour) -> KiloWattHour: KiloWattHour(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "kWh"
    static fn scale_to_base() -> f64: 3600000.0
    static fn base_unit() -> text: "J"
    static fn numerator() -> [text]: ["kW", "h"]
    static fn denominator() -> [text]: []
    static fn zero() -> KiloWattHour: KiloWattHour(value: 0.0)

export KiloWattHour
