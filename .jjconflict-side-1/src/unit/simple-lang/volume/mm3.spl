# Unit: Mm3
# Kind: Volume
# Symbol: mm3
# Canonical scale: 1e-09 m3

class Mm3:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mm3) -> Mm3: Mm3(value: self.value + other.value)
    fn sub(other: Mm3) -> Mm3: Mm3(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "mm3"
    static fn scale_to_base() -> f64: 1e-09
    static fn base_unit() -> text: "m3"
    static fn zero() -> Mm3: Mm3(value: 0.0)

export Mm3
