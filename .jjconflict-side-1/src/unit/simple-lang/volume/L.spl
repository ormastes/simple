# Unit: L
# Kind: Volume
# Symbol: L
# Canonical scale: 0.001 m3

class L:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: L) -> L: L(value: self.value + other.value)
    fn sub(other: L) -> L: L(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "L"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "m3"
    static fn zero() -> L: L(value: 0.0)

export L
