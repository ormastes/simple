# Unit: PicoFarad
# Kind: Capacitance
# Symbol: pF
# Canonical scale: 1e-12 F

class PicoFarad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: PicoFarad) -> PicoFarad: PicoFarad(value: self.value + other.value)
    fn sub(other: PicoFarad) -> PicoFarad: PicoFarad(value: self.value - other.value)

    static fn kind() -> text: "Capacitance"
    static fn symbol() -> text: "pF"
    static fn scale_to_base() -> f64: 1e-12
    static fn base_unit() -> text: "F"
    static fn zero() -> PicoFarad: PicoFarad(value: 0.0)

export PicoFarad
