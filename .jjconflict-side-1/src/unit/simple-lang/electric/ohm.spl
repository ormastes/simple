# Unit: Ohm
# Kind: ElectricResistance
# Symbol: ohm
# Canonical scale: 1.0 ohm

class Ohm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ohm) -> Ohm: Ohm(value: self.value + other.value)
    fn sub(other: Ohm) -> Ohm: Ohm(value: self.value - other.value)

    static fn kind() -> text: "ElectricResistance"
    static fn symbol() -> text: "ohm"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "ohm"
    static fn zero() -> Ohm: Ohm(value: 0.0)

export Ohm
