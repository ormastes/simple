# Unit: NanoFarad
# Kind: Capacitance
# Symbol: nF
# Canonical scale: 1e-09 F

class NanoFarad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: NanoFarad) -> NanoFarad: NanoFarad(value: self.value + other.value)
    fn sub(other: NanoFarad) -> NanoFarad: NanoFarad(value: self.value - other.value)

    static fn kind() -> text: "Capacitance"
    static fn symbol() -> text: "nF"
    static fn scale_to_base() -> f64: 1e-09
    static fn base_unit() -> text: "F"
    static fn zero() -> NanoFarad: NanoFarad(value: 0.0)

export NanoFarad
