# Unit: Weber
# Kind: MagneticFlux
# Symbol: Wb
# Canonical scale: 1.0 Wb

class Weber:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Weber) -> Weber: Weber(value: self.value + other.value)
    fn sub(other: Weber) -> Weber: Weber(value: self.value - other.value)

    static fn kind() -> text: "MagneticFlux"
    static fn symbol() -> text: "Wb"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "Wb"
    static fn zero() -> Weber: Weber(value: 0.0)

export Weber
