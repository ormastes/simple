# Unit: ArcSec
# Kind: Angle
# Symbol: arcsec
# Canonical scale: 4.84813681109536e-06 rad

class ArcSec:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: ArcSec) -> ArcSec: ArcSec(value: self.value + other.value)
    fn sub(other: ArcSec) -> ArcSec: ArcSec(value: self.value - other.value)

    static fn kind() -> text: "Angle"
    static fn symbol() -> text: "arcsec"
    static fn scale_to_base() -> f64: 4.84813681109536e-06
    static fn base_unit() -> text: "rad"
    static fn zero() -> ArcSec: ArcSec(value: 0.0)

export ArcSec
