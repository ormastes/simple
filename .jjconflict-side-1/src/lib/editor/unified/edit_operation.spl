# Edit Operation — operation-based undo/redo for the unified editor.
#
# Each edit is recorded as a discrete operation with an inverse,
# enabling undo without full-snapshot copies.
#
# Provides: EditOperation, OperationKind, OperationHistory.

enum OperationKind:
    Insert
    Delete
    Replace

struct EditOperation:
    kind: OperationKind
    line: i64
    col: i64
    content: text
    replaced: text
    cursor_before_line: i64
    cursor_before_col: i64
    cursor_after_line: i64
    cursor_after_col: i64

fn op_insert(line: i64, col: i64, content: text, cursor_line: i64, cursor_col: i64) -> EditOperation:
    EditOperation(
        kind: OperationKind.Insert,
        line: line,
        col: col,
        content: content,
        replaced: "",
        cursor_before_line: cursor_line,
        cursor_before_col: cursor_col,
        cursor_after_line: cursor_line,
        cursor_after_col: cursor_col + content.len()
    )

fn op_delete(line: i64, col: i64, deleted: text, cursor_line: i64, cursor_col: i64) -> EditOperation:
    EditOperation(
        kind: OperationKind.Delete,
        line: line,
        col: col,
        content: "",
        replaced: deleted,
        cursor_before_line: cursor_line,
        cursor_before_col: cursor_col,
        cursor_after_line: cursor_line,
        cursor_after_col: col
    )

fn op_replace(line: i64, col: i64, old_text: text, new_text: text, cursor_line: i64, cursor_col: i64) -> EditOperation:
    EditOperation(
        kind: OperationKind.Replace,
        line: line,
        col: col,
        content: new_text,
        replaced: old_text,
        cursor_before_line: cursor_line,
        cursor_before_col: cursor_col,
        cursor_after_line: cursor_line,
        cursor_after_col: col + new_text.len()
    )

fn invert_operation(op: EditOperation) -> EditOperation:
    """Returns the inverse operation for undo."""
    if op.kind == OperationKind.Insert:
        return EditOperation(
            kind: OperationKind.Delete,
            line: op.line,
            col: op.col,
            content: "",
            replaced: op.content,
            cursor_before_line: op.cursor_after_line,
            cursor_before_col: op.cursor_after_col,
            cursor_after_line: op.cursor_before_line,
            cursor_after_col: op.cursor_before_col
        )
    if op.kind == OperationKind.Delete:
        return EditOperation(
            kind: OperationKind.Insert,
            line: op.line,
            col: op.col,
            content: op.replaced,
            replaced: "",
            cursor_before_line: op.cursor_after_line,
            cursor_before_col: op.cursor_after_col,
            cursor_after_line: op.cursor_before_line,
            cursor_after_col: op.cursor_before_col
        )
    # Replace: swap content and replaced
    EditOperation(
        kind: OperationKind.Replace,
        line: op.line,
        col: op.col,
        content: op.replaced,
        replaced: op.content,
        cursor_before_line: op.cursor_after_line,
        cursor_before_col: op.cursor_after_col,
        cursor_after_line: op.cursor_before_line,
        cursor_after_col: op.cursor_before_col
    )

class OperationHistory:
    past: [EditOperation]
    future: [EditOperation]
    max_depth: i64

    static fn new(max_depth: i64) -> OperationHistory:
        OperationHistory(past: [], future: [], max_depth: max_depth)

    static fn with_defaults() -> OperationHistory:
        OperationHistory(past: [], future: [], max_depth: 500)

    me record(op: EditOperation):
        """Record a new operation, clearing the redo stack."""
        me.future = []
        me.past.push(op)
        if me.past.len() > me.max_depth:
            var trimmed: [EditOperation] = []
            var i = me.past.len() - me.max_depth
            while i < me.past.len():
                trimmed.push(me.past[i])
                i = i + 1
            me.past = trimmed

    me undo() -> EditOperation?:
        """Pop the last operation and push its inverse onto redo."""
        if me.past.len() == 0:
            return Option.None
        val op = me.past[me.past.len() - 1]
        var new_past: [EditOperation] = []
        var i = 0
        while i < me.past.len() - 1:
            new_past.push(me.past[i])
            i = i + 1
        me.past = new_past
        me.future.push(op)
        Option.Some(invert_operation(op))

    me redo() -> EditOperation?:
        """Pop the last redo entry and push its inverse onto undo."""
        if me.future.len() == 0:
            return Option.None
        val op = me.future[me.future.len() - 1]
        var new_future: [EditOperation] = []
        var i = 0
        while i < me.future.len() - 1:
            new_future.push(me.future[i])
            i = i + 1
        me.future = new_future
        me.past.push(op)
        Option.Some(invert_operation(op))

    fn can_undo() -> bool:
        me.past.len() > 0

    fn can_redo() -> bool:
        me.future.len() > 0

    fn undo_count() -> i64:
        me.past.len()

    fn redo_count() -> i64:
        me.future.len()
