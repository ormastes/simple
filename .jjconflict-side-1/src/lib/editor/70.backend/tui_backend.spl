# TUI Backend
#
# Formalizes the TUI rendering backend as a trait-like interface.
# Delegates to std.tui for terminal operations.

struct TuiBackendConfig:
    color_mode: text
    mouse_enabled: bool
    line_numbers: bool
    status_bar: bool

fn tui_backend_default_config() -> TuiBackendConfig:
    TuiBackendConfig(
        color_mode: "256",
        mouse_enabled: false,
        line_numbers: true,
        status_bar: true
    )

struct TuiRenderRequest:
    buffer_text: text
    cursor_row: i64
    cursor_col: i64
    viewport_top: i64
    viewport_height: i64
    viewport_width: i64
    mode: text
    path: text
    dirty: bool
    status_message: text

fn tui_backend_render_line(line_num: i64, content: text, is_cursor_line: bool, num_width: i64) -> text:
    val num_str = str(line_num)
    var padding = ""
    var p = 0
    while p < num_width - num_str.len():
        padding = padding + " "
        p = p + 1
    val prefix = padding + num_str + " "
    if is_cursor_line:
        return "\x1b[7m" + prefix + content + "\x1b[0m"
    prefix + content

fn tui_backend_render_status(mode: text, path: text, dirty: bool, row: i64, col: i64, width: i64) -> text:
    val dirty_str = if dirty then " [+]" else: ""
    val path_str = if path != "" then path else: "[No Name]"
    val left = " {mode} | {path_str}{dirty_str}"
    val right = "{row + 1},{col + 1} "
    var fill = ""
    var f = 0
    val fill_len = width - left.len() - right.len()
    while f < fill_len:
        fill = fill + " "
        f = f + 1
    "\x1b[7m" + left + fill + right + "\x1b[0m"
