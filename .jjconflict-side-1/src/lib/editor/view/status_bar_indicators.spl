# Editor Status Bar Indicators
#
# Indicator widgets displayed in the status bar: mode, language,
# line/col, encoding, indentation, diagnostics summary, and git branch.

struct StatusBarIndicator:
    key: text
    value: text
    icon: text
    priority: i64

struct StatusBarIndicators:
    indicators: [StatusBarIndicator]
    mode: text
    language_id: text
    line: i64
    col: i64
    encoding: text
    indent_style: text
    indent_size: i64
    error_count: i64
    warning_count: i64
    git_branch: text

fn status_bar_indicators_new() -> StatusBarIndicators:
    StatusBarIndicators(
        indicators: [],
        mode: "NORMAL",
        language_id: "",
        line: 0,
        col: 0,
        encoding: "UTF-8",
        indent_style: "spaces",
        indent_size: 4,
        error_count: 0,
        warning_count: 0,
        git_branch: ""
    )

fn status_bar_indicators_render_left(bar: StatusBarIndicators) -> text:
    " " + bar.mode + " "

fn status_bar_indicators_render_right(bar: StatusBarIndicators) -> text:
    var parts: [text] = []
    if bar.error_count > 0:
        parts.push("E:" + bar.error_count.to_text())
    if bar.warning_count > 0:
        parts.push("W:" + bar.warning_count.to_text())
    parts.push(bar.language_id)
    parts.push((bar.line + 1).to_text() + ":" + (bar.col + 1).to_text())
    parts.push(bar.encoding)
    var result = ""
    var i = 0
    while i < parts.len():
        if parts[i] != "":
            if result != "":
                result = result + "  "
            result = result + parts[i]
        i = i + 1
    result + " "
