# Editor Plugin Host
#
# Lightweight plugin registry that loads, activates, and dispatches
# to editor plugins at runtime.

struct PluginEntry:
    name: text
    version: text
    active: bool
    path: text

struct PluginHost:
    plugins: [PluginEntry]
    event_log: [text]

fn plugin_host_new() -> PluginHost:
    PluginHost(plugins: [], event_log: [])

fn plugin_host_register(host: PluginHost, name: text, version: text, path: text) -> PluginHost:
    var plugins = host.plugins
    plugins.push(PluginEntry(name: name, version: version, active: false, path: path))
    PluginHost(plugins: plugins, event_log: host.event_log)

fn plugin_host_activate(host: PluginHost, name: text) -> PluginHost:
    var plugins: [PluginEntry] = []
    for p in host.plugins:
        if p.name == name:
            plugins.push(PluginEntry(name: p.name, version: p.version, active: true, path: p.path))
        else:
            plugins.push(p)
    PluginHost(plugins: plugins, event_log: host.event_log)

fn plugin_host_is_active(host: PluginHost, name: text) -> bool:
    for p in host.plugins:
        if p.name == name and p.active:
            return true
    false

fn plugin_host_dispatch(host: PluginHost, event: text) -> PluginHost:
    var log = host.event_log
    log.push(event)
    PluginHost(plugins: host.plugins, event_log: log)
