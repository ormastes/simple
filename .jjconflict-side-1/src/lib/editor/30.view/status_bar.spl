# Status Bar
#
# Formalized status bar state extracted from the editor session.
# Provides both TUI (ANSI) and HTML renderers.

struct StatusBarState:
    mode: text
    file_path: text
    dirty: bool
    cursor_row: i64
    cursor_col: i64
    line_count: i64
    language_id: text
    encoding: text
    diagnostics_error_count: i64
    diagnostics_warn_count: i64
    git_branch: text
    message: text

fn status_bar_from_session(session: EditSession) -> StatusBarState:
    val mode_text = editor_mode_name(session.mode)
    val doc = session.active_document()
    var fp = ""
    var lang = ""
    var enc = "utf-8"
    var dr = false
    var crow = 0
    var ccol = 0
    var lc = 0
    if doc != nil:
        fp = doc.path()
        lang = doc.language_id
        enc = doc.encoding
        val buf = doc.buffer
        if buf != nil:
            dr = buf.dirty
            crow = buf.cursor_row
            ccol = buf.cursor_col
            lc = buf.line_count()
    StatusBarState(
        mode: mode_text,
        file_path: fp,
        dirty: dr,
        cursor_row: crow,
        cursor_col: ccol,
        line_count: lc,
        language_id: lang,
        encoding: enc,
        diagnostics_error_count: 0,
        diagnostics_warn_count: 0,
        git_branch: "",
        message: session.status_message
    )

fn status_bar_render_tui(state: StatusBarState, width: i64) -> text:
    var dirty_mark = ""
    if state.dirty:
        dirty_mark = "[+]"
    var left = "[" + state.mode + "]"
    left = left + " | " + state.file_path + dirty_mark
    if state.language_id != "":
        left = left + " | " + state.language_id
    var right = "E:" + str(state.diagnostics_error_count)
    right = right + " W:" + str(state.diagnostics_warn_count)
    right = right + " | " + state.encoding
    right = right + " | Ln " + str(state.cursor_row + 1)
    right = right + ", Col " + str(state.cursor_col + 1)
    var pad_len = width - left.len() - right.len()
    if pad_len < 1:
        pad_len = 1
    var pad = ""
    var i = 0
    while i < pad_len:
        pad = pad + " "
        i = i + 1
    left + pad + right

fn status_bar_render_html(state: StatusBarState) -> text:
    var dirty_mark = ""
    if state.dirty:
        dirty_mark = " [+]"
    var html = "<div class=\"status-bar\">"
    html = html + "<span class=\"mode\">" + state.mode + "</span>"
    html = html + "<span class=\"file\">" + state.file_path + dirty_mark + "</span>"
    html = html + "<span class=\"lang\">" + state.language_id + "</span>"
    html = html + "<span class=\"diag\">E:" + str(state.diagnostics_error_count)
    html = html + " W:" + str(state.diagnostics_warn_count) + "</span>"
    html = html + "<span class=\"enc\">" + state.encoding + "</span>"
    html = html + "<span class=\"pos\">Ln " + str(state.cursor_row + 1)
    html = html + ", Col " + str(state.cursor_col + 1) + "</span>"
    html = html + "</div>"
    html
