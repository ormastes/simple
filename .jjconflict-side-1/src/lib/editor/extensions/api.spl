# Extension API — base types for the editor extension system.
#
# Provides: ExtensionDebugAdapter, ExtensionContext, ExtensionCapability,
#           ExtensionContribution, ExtensionActivationEvent.

struct ExtensionDebugAdapter:
    id: text
    label: text
    program: text

struct ExtensionContext:
    name: text
    extension_id: text
    storage_path: text
    subscriptions: [text]
    workspace_state_keys: [text]
    workspace_state_values: [text]

fn extension_context_new(storage_path: text, extension_id: text) -> ExtensionContext:
    ExtensionContext(name: extension_id, extension_id: extension_id, storage_path: storage_path, subscriptions: [], workspace_state_keys: [], workspace_state_values: [])

fn extension_context_subscribe(ctx: ExtensionContext, event: text) -> ExtensionContext:
    var subscriptions: [text] = []
    for existing in ctx.subscriptions:
        if existing == event:
            return ctx
        subscriptions.push(existing)
    subscriptions.push(event)
    ExtensionContext(name: ctx.name, extension_id: ctx.extension_id, storage_path: ctx.storage_path, subscriptions: subscriptions, workspace_state_keys: ctx.workspace_state_keys, workspace_state_values: ctx.workspace_state_values)

fn extension_context_is_subscribed(ctx: ExtensionContext, event: text) -> bool:
    for existing in ctx.subscriptions:
        if existing == event or existing == "*":
            return true
    false

fn extension_context_set_state(ctx: ExtensionContext, key: text, value: text) -> ExtensionContext:
    var keys: [text] = []
    var values: [text] = []
    var replaced = false
    var i = 0
    while i < ctx.workspace_state_keys.len():
        keys.push(ctx.workspace_state_keys[i])
        if ctx.workspace_state_keys[i] == key:
            values.push(value)
            replaced = true
        else:
            values.push(ctx.workspace_state_values[i])
        i = i + 1
    if not replaced:
        keys.push(key)
        values.push(value)
    ExtensionContext(name: ctx.name, extension_id: ctx.extension_id, storage_path: ctx.storage_path, subscriptions: ctx.subscriptions, workspace_state_keys: keys, workspace_state_values: values)

fn extension_context_get_state(ctx: ExtensionContext, key: text) -> text:
    var i = 0
    while i < ctx.workspace_state_keys.len():
        if ctx.workspace_state_keys[i] == key:
            return ctx.workspace_state_values[i]
        i = i + 1
    ""

struct ExtensionCapability:
    name: text
    enabled: bool

struct ExtensionContribution:
    kind: text
    id: text
    payload: text

enum ExtensionActivationEvent:
    OnLanguage(language_id: text)
    OnCommand(command_id: text)
    OnFilePattern(pattern: text)
    OnStartup
