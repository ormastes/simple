# Markdown Spreadsheet Grid (sgrid)
#
# Sgrid blocks embed formulas and formatting directives that bind to Markdown
# tables, enabling lightweight spreadsheet operations in documents.

use std.editor.services.md_document_decor.*

struct MdSgridFormula:
    target: text
    expr: text

struct MdSgridFormat:
    target: text
    expr: text

struct MdSgridBlock:
    carrier: text
    line: i64
    id: text
    table_ref: text
    formulas: [MdSgridFormula]
    formats: [MdSgridFormat]
    body: text

struct MdSgridBinding:
    index: i64
    id: text
    table_ref: text
    table_start: i64
    table_end: i64

struct MdSgridPivotRow:
    key: text
    value: text

fn md_sgrid_scan(content: text) -> [MdSgridBlock]:
    val lines = _mds_split_lines(content)
    var blocks: [MdSgridBlock] = []
    var i = 0
    while i < lines.len():
        val trimmed = lines[i].trim()
        if trimmed.starts_with("<!-- sgrid"):
            val carrier_line = i
            var body: [text] = []
            i = i + 1
            while i < lines.len() and not lines[i].trim().starts_with("-->"):
                body.push(lines[i])
                i = i + 1
            var parsed = _mds_parse_sgrid_body(body.join("\n"), "html")
            parsed.line = carrier_line
            blocks.push(parsed)
        elif trimmed.starts_with("```sgrid") or trimmed.starts_with("~~~sgrid"):
            val carrier_line2 = i
            val fence = if trimmed.starts_with("~~~") then "~~~" else: "```"
            var body2: [text] = []
            i = i + 1
            while i < lines.len() and not lines[i].trim().starts_with(fence):
                body2.push(lines[i])
                i = i + 1
            var parsed2 = _mds_parse_sgrid_body(body2.join("\n"), "fence")
            parsed2.line = carrier_line2
            blocks.push(parsed2)
        i = i + 1
    blocks

fn md_sgrid_bind_tables(content: text) -> [MdSgridBinding]:
    val blocks = md_sgrid_scan(content)
    var bindings: [MdSgridBinding] = []
    var i = 0
    while i < blocks.len():
        val block = blocks[i]
        val span = _mds_bind_sgrid_table(content, block.table_ref, block.line)
        bindings.push(MdSgridBinding(index: i + 1, id: block.id, table_ref: block.table_ref, table_start: span.0, table_end: span.1))
        i = i + 1
    bindings

fn md_sgrid_apply(content: text) -> [MdSheetCell]:
    val blocks = md_sgrid_scan(content)
    if blocks.len() == 0:
        return md_document_sheet_cells(content)
    val table = _mds_table_text_for_ref(content, blocks[0].table_ref, blocks[0].line)
    var cells = md_document_sheet_cells(table)
    for block in blocks:
        for formula in block.formulas:
            cells = _mds_apply_sgrid_formula(cells, formula)
    cells

fn md_sgrid_selection_sum(content: text, range: text) -> text:
    val cells = md_sgrid_apply(content)
    var total = 0
    for cell in cells:
        if _mds_cell_in_range(cell.address, range):
            total = total + (cell.value.to_i64() ?? 0)
    total.to_text()

fn md_sgrid_copy_selection(content: text, range: text) -> text:
    val cells = md_sgrid_apply(content)
    val span = _mds_range_span(range)
    var rows: [text] = []
    var row = span.0
    while row <= span.2:
        var cols: [text] = []
        var col = span.1
        while col <= span.3:
            cols.push(_mds_cell_value_at(cells, row, col))
            col = col + 1
        rows.push(cols.join("\t"))
        row = row + 1
    rows.join("\n")

fn md_sgrid_pivot_sum(content: text, key_col: text, value_col: text) -> [MdSgridPivotRow]:
    val cells = md_sgrid_apply(content)
    val key_index = _mds_address_col(key_col + "1")
    val value_index = _mds_address_col(value_col + "1")
    var rows: [MdSgridPivotRow] = []
    var row = 2
    while row <= _mds_max_cell_row(cells):
        val key = _mds_cell_value_at(cells, row, key_index)
        val amount = _mds_cell_value_at(cells, row, value_index).to_i64() ?? 0
        if key != "":
            rows = _mds_pivot_add(rows, key, amount)
        row = row + 1
    rows

fn md_sgrid_common_libraries() -> [text]:
    ["sum(range)", "avg(range)", "min(range)", "max(range)", "count(range)", "money(USD)", "copy(range)", "pivot_sum(key_col,value_col)", "selection_sum(range)"]

fn md_sgrid_inline_annotations(content: text) -> [MdSgridFormula]:
    val cells = md_document_sheet_cells(content)
    var formulas: [MdSgridFormula] = []
    for cell in cells:
        val inline = _mds_inline_formula(cell.raw)
        if inline != "":
            formulas.push(MdSgridFormula(target: cell.address, expr: inline))
    formulas

fn md_sgrid_header_types(content: text) -> [MdSgridFormat]:
    val cells = md_document_sheet_cells(content)
    var types: [MdSgridFormat] = []
    for cell in cells:
        if cell.row == 1 and cell.raw.contains(":"):
            val sep = cell.raw.index_of(":")
            types.push(MdSgridFormat(target: _mds_col_name(cell.col), expr: "type(" + cell.raw.slice(sep + 1, cell.raw.len()).trim() + ")"))
    types

# --- Private helpers ---

fn _mds_parse_sgrid_body(body: text, carrier: text) -> MdSgridBlock:
    val lines = _mds_split_lines(body)
    var block = MdSgridBlock(carrier: carrier, line: 0, id: "", table_ref: "previous", formulas: [], formats: [], body: body)
    var section = ""
    for raw_line in lines:
        val line = raw_line.trim()
        if line == "":
            continue
        if line.ends_with(":") and not line.contains("="):
            section = line.slice(0, line.len() - 1).trim()
        elif section == "" and line.contains(":"):
            val sep = line.index_of(":")
            val key = line.slice(0, sep).trim()
            val value = line.slice(sep + 1, line.len()).trim()
            if key == "id":
                block.id = value
            elif key == "table":
                block.table_ref = value
        elif section == "f" and line.contains("="):
            val sep2 = line.index_of("=")
            block.formulas.push(MdSgridFormula(target: line.slice(0, sep2).trim(), expr: line.slice(sep2 + 1, line.len()).trim()))
        elif section == "fmt" and line.contains("="):
            val sep3 = line.index_of("=")
            block.formats.push(MdSgridFormat(target: line.slice(0, sep3).trim(), expr: line.slice(sep3 + 1, line.len()).trim()))
    block

fn _mds_bind_sgrid_table(content: text, table_ref: text, carrier_line: i64) -> tuple:
    val lines = _mds_split_lines(content)
    var tables_start: [i64] = []
    var tables_end: [i64] = []
    var i = 0
    while i < lines.len():
        if lines[i].trim().starts_with("|"):
            val start = i
            while i < lines.len() and lines[i].trim().starts_with("|"):
                i = i + 1
            tables_start.push(start)
            tables_end.push(i - 1)
        i = i + 1
    if tables_start.len() == 0:
        return (-1, -1)
    if table_ref.starts_with("#"):
        val named = _mds_find_named_table(lines, tables_start, tables_end, table_ref.slice(1, table_ref.len()))
        if named.0 >= 0:
            return named
    if table_ref == "next":
        var ni = 0
        while ni < tables_start.len():
            if tables_start[ni] > carrier_line:
                return (tables_start[ni], tables_end[ni])
            ni = ni + 1
        return (tables_start[0], tables_end[0])
    if table_ref == "previous":
        var pi = tables_start.len() - 1
        while pi >= 0:
            if tables_end[pi] < carrier_line:
                return (tables_start[pi], tables_end[pi])
            pi = pi - 1
        return (tables_start[0], tables_end[0])
    if table_ref.to_i64() != nil:
        val idx = (table_ref.to_i64() ?? 1) - 1
        if idx >= 0 and idx < tables_start.len():
            return (tables_start[idx], tables_end[idx])
    (tables_start[0], tables_end[0])

fn _mds_table_text_for_ref(content: text, table_ref: text, carrier_line: i64) -> text:
    val span = _mds_bind_sgrid_table(content, table_ref, carrier_line)
    if span.0 < 0:
        return content
    val lines = _mds_split_lines(content)
    var table: [text] = []
    var i = span.0
    while i <= span.1 and i < lines.len():
        table.push(lines[i])
        i = i + 1
    table.join("\n")

fn _mds_find_named_table(lines: [text], starts: [i64], ends: [i64], name: text) -> tuple:
    var i = 0
    while i < starts.len():
        var scan = starts[i] - 1
        while scan >= 0 and lines[scan].trim() == "":
            scan = scan - 1
        if scan >= 0:
            val marker = lines[scan].trim()
            if marker.contains(name) or marker.contains("#" + name):
                return (starts[i], ends[i])
        i = i + 1
    (-1, -1)

fn _mds_apply_sgrid_formula(cells: [MdSheetCell], formula: MdSgridFormula) -> [MdSheetCell]:
    var out = cells
    if formula.target.contains(":"):
        val span = _mds_range_span(formula.target)
        var row = span.0
        while row <= span.2:
            val value = _mds_eval_sgrid_expr_for_row(formula.expr, out, row)
            val address = _mds_cell_address(row, span.1)
            out = _mds_set_cell_value(out, address, value)
            row = row + 1
    else:
        out = _mds_set_cell_value(out, formula.target, _mds_eval_sgrid_expr_for_row(formula.expr, out, _mds_address_row(formula.target)))
    out

fn _mds_eval_sgrid_expr_for_row(expr: text, cells: [MdSheetCell], row: i64) -> text:
    val trimmed = expr.trim()
    if trimmed.starts_with("sum(") and trimmed.ends_with(")"):
        val range = trimmed.slice(4, trimmed.len() - 1).trim()
        return _mds_range_sum(cells, range).to_text()
    if trimmed.starts_with("avg(") and trimmed.ends_with(")"):
        val range2 = trimmed.slice(4, trimmed.len() - 1).trim()
        val count = _mds_range_count(cells, range2)
        if count == 0:
            return "0"
        return (_mds_range_sum(cells, range2) / count).to_text()
    if trimmed.starts_with("min(") and trimmed.ends_with(")"):
        return _mds_range_min(cells, trimmed.slice(4, trimmed.len() - 1).trim()).to_text()
    if trimmed.starts_with("max(") and trimmed.ends_with(")"):
        return _mds_range_max(cells, trimmed.slice(4, trimmed.len() - 1).trim()).to_text()
    if trimmed.starts_with("count(") and trimmed.ends_with(")"):
        return _mds_range_count(cells, trimmed.slice(6, trimmed.len() - 1).trim()).to_text()
    val mul = trimmed.index_of("*")
    if mul >= 0:
        val left = _mds_expr_value(trimmed.slice(0, mul).trim(), cells, row)
        val right = _mds_expr_value(trimmed.slice(mul + 1, trimmed.len()).trim(), cells, row)
        return (left * right).to_text()
    _mds_expr_value(trimmed, cells, row).to_text()

fn _mds_expr_value(token: text, cells: [MdSheetCell], row: i64) -> i64:
    if token.len() == 1:
        return _mds_cell_value_at(cells, row, _mds_address_col(token + "1")).to_i64() ?? 0
    if _mds_address_row(token) > 0:
        return _mds_cell_value_at(cells, _mds_address_row(token), _mds_address_col(token)).to_i64() ?? 0
    token.to_i64() ?? 0

fn _mds_range_sum(cells: [MdSheetCell], range: text) -> i64:
    var total = 0
    for cell in cells:
        if _mds_cell_in_range(cell.address, range):
            total = total + (cell.value.to_i64() ?? 0)
    total

fn _mds_range_count(cells: [MdSheetCell], range: text) -> i64:
    var count = 0
    for cell in cells:
        if _mds_cell_in_range(cell.address, range) and cell.value != "":
            count = count + 1
    count

fn _mds_range_min(cells: [MdSheetCell], range: text) -> i64:
    var found = false
    var best = 0
    for cell in cells:
        if _mds_cell_in_range(cell.address, range) and cell.value != "":
            val value = cell.value.to_i64() ?? 0
            if not found or value < best:
                best = value
                found = true
    best

fn _mds_range_max(cells: [MdSheetCell], range: text) -> i64:
    var found = false
    var best = 0
    for cell in cells:
        if _mds_cell_in_range(cell.address, range) and cell.value != "":
            val value = cell.value.to_i64() ?? 0
            if not found or value > best:
                best = value
                found = true
    best

fn _mds_set_cell_value(cells: [MdSheetCell], address: text, value: text) -> [MdSheetCell]:
    var out = cells
    var i = 0
    while i < out.len():
        var cell = out[i]
        if cell.address == address:
            cell.value = value
            out[i] = cell
        i = i + 1
    out

fn _mds_inline_formula(raw: text) -> text:
    if not raw.contains("`="):
        return ""
    val parts = raw.split("`=")
    if parts.len() < 2:
        return ""
    val tail = parts[1]
    val end_parts = tail.split("`")
    if end_parts.len() == 0:
        return ""
    end_parts[0].trim()

fn _mds_range_span(range: text) -> tuple:
    val sep = range.index_of(":")
    if sep < 0:
        val row = _mds_address_row(range)
        val col = _mds_address_col(range)
        return (row, col, row, col)
    val left = range.slice(0, sep).trim()
    val right = range.slice(sep + 1, range.len()).trim()
    (_mds_address_row(left), _mds_address_col(left), _mds_address_row(right), _mds_address_col(right))

fn _mds_cell_in_range(address: text, range: text) -> bool:
    val span = _mds_range_span(range)
    val row = _mds_address_row(address)
    val col = _mds_address_col(address)
    row >= span.0 and row <= span.2 and col >= span.1 and col <= span.3

fn _mds_cell_value_at(cells: [MdSheetCell], row: i64, col: i64) -> text:
    val address = _mds_cell_address(row, col)
    for cell in cells:
        if cell.address == address:
            return cell.value
    ""

fn _mds_max_cell_row(cells: [MdSheetCell]) -> i64:
    var max_row = 0
    for cell in cells:
        if cell.row > max_row:
            max_row = cell.row
    max_row

fn _mds_pivot_add(rows: [MdSgridPivotRow], key: text, amount: i64) -> [MdSgridPivotRow]:
    var out = rows
    var i = 0
    while i < out.len():
        var row = out[i]
        if row.key == key:
            row.value = ((row.value.to_i64() ?? 0) + amount).to_text()
            out[i] = row
            return out
        i = i + 1
    out.push(MdSgridPivotRow(key: key, value: amount.to_text()))
    out

# --- Duplicated shared helpers (module-private, not importable from md_document_decor) ---

fn _mds_cell_address(row: i64, col: i64) -> text:
    _mds_col_name(col) + row.to_text()

fn _mds_address_col(address: text) -> i64:
    if address.len() == 0:
        return 0
    val col = address.char_at(0)
    if col == "A":
        return 1
    if col == "B":
        return 2
    if col == "C":
        return 3
    if col == "D":
        return 4
    if col == "E":
        return 5
    0

fn _mds_address_row(address: text) -> i64:
    if address.len() <= 1:
        return 0
    address.slice(1, address.len()).to_i64() ?? 0

fn _mds_col_name(col: i64) -> text:
    if col == 1:
        return "A"
    if col == 2:
        return "B"
    if col == 3:
        return "C"
    if col == 4:
        return "D"
    if col == 5:
        return "E"
    "C" + col.to_text()

fn _mds_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            lines.push(content.slice(start, i))
            start = i + 1
        i = i + 1
    if start <= content.len():
        lines.push(content.slice(start, content.len()))
    lines
