# ImeComposition: input method composition state machine

enum CompositionState:
    Idle
    Composing
    Committing

class ImeComposition:
    text_buffer: text
    cursor_pos: i32
    state: CompositionState

    static fn idle() -> ImeComposition:
        ImeComposition(
            text_buffer: "",
            cursor_pos: 0,
            state: CompositionState.Idle
        )

    me start_composing():
        me.state = CompositionState.Composing
        me.text_buffer = ""
        me.cursor_pos = 0

    me update(text_v: text, cursor: i32):
        me.text_buffer = text_v
        me.cursor_pos = cursor

    me commit():
        me.state = CompositionState.Committing
