"""
# I/O Facade

Re-exports all I/O types for convenient access via `use std.io.*`.
Unifies sync and async I/O under a single import path.

## Import

```simple
use std.io.*
```

## Sync File I/O

```simple
use std.io.*

File.write("/tmp/io_facade_test.txt", "hello from facade")?
val content = File.read("/tmp/io_facade_test.txt")?
expect content == "hello from facade"
File.delete("/tmp/io_facade_test.txt")?
```

## Sync Handle-Based I/O

```simple
use std.io.*

val fh = FileHandle.open("/tmp/io_facade_handle.txt", FileMode.WriteOnly)?
fh.write_text("handle data")?
fh.close()?

val fh2 = FileHandle.read_file("/tmp/io_facade_handle.txt")?
val data = fh2.read_text()?
expect data == "handle data"
fh2.close()?
```

## Error Handling

```simple
use std.io.*

val err = IoError(kind: IoErrorKind.NotFound, message: "missing file", source: nil)
expect err.is_not_found() == true
```

## Async File I/O (Mirrors Sync)

```simple
use std.io.*

# Sync:
#   val text = File.read("config.sdn")?
#
# Async — same API, just add await:
#   val text = await AsyncFile.read("config.sdn")?
```

## Async TCP (Mirrors Sync)

```simple
use std.io.*

# Sync:
#   val listener = TcpListener.bind("0.0.0.0:8080")?
#   val stream = listener.accept()?
#
# Async:
#   val listener = await AsyncTcpListener.bind("0.0.0.0:8080")?
#   val stream = await listener.accept()?
```
"""

# --- Shared types ---
use std.io.types.{IoErrorKind, IoError, SeekFrom, IoMode, Interest, ReadyState, IoEvent, FileMode, FileMetadata, Shutdown}

# Re-export the real sync I/O package so `use std.io.{env_get, file_read, ...}`
# resolves to the same runtime helpers as `use std.nogc_async_mut.io.{...}`.
use std.nogc_async_mut.io.*

# --- Sync traits ---
use std.io.traits.{Read, Write, Seek, Close}

# --- Async traits ---
use std.io.async_traits.{AsyncRead, AsyncWrite, AsyncSeek, AsyncClose}

# --- Sync implementations ---
use std.nogc_async_mut.io.file.{FileHandle, File}
use std.nogc_async_mut.io.tcp.{TcpListener, TcpStream}
use std.nogc_async_mut.io.udp.{UdpSocket}
use std.nogc_async_mut.io.buffer.{BufferedReader, BufferedWriter}
use std.nogc_async_mut.io.pipe.{Stdin, Stdout, Stderr}

# --- Async implementations ---
use std.nogc_async_mut.io.file.{ThreadPool, AsyncFileHandle, AsyncFile}
use std.nogc_async_mut.io.tcp.{AsyncTcpListener, AsyncTcpStream}
use std.nogc_async_mut.io.udp.{AsyncUdpSocket}
use std.nogc_async_mut.io.buffer.{AsyncBufferedReader, AsyncBufferedWriter}
use std.nogc_async_mut.io.event_loop.{Waker, EventLoop}

# ============================================================================
# Exports
# ============================================================================

# Shared types
export IoErrorKind, IoError, SeekFrom, IoMode, Interest, ReadyState, IoEvent, FileMode, FileMetadata, Shutdown

# Sync traits
export Read, Write, Seek, Close

# Async traits
export AsyncRead, AsyncWrite, AsyncSeek, AsyncClose

# Sync implementations
export FileHandle, File
export TcpListener, TcpStream
export UdpSocket
export BufferedReader, BufferedWriter
export Stdin, Stdout, Stderr

# Async implementations
export ThreadPool, AsyncFileHandle, AsyncFile
export AsyncTcpListener, AsyncTcpStream
export AsyncUdpSocket
export AsyncBufferedReader, AsyncBufferedWriter
export Waker, EventLoop

# Host I/O helpers (sync, delegated via wildcard from std.nogc_async_mut.io.*)
export shell, shell_output, shell_bool, shell_lines, shell_int, shell_output_trimmed, ProcessResult
export file_read, file_read_lines, file_read_bytes, file_read_text, file_write, file_write_bytes
export file_exists, file_delete, file_copy, file_size, file_append, file_modified_time
export file_remove, file_hash_sha256, env_get, env_set, dir_list, dir_exists
export dir_create, dir_create_all, dir_walk, dir_walk_native, dir_remove_all, is_dir, cwd
export file_atomic_write, file_lock, file_unlock
export getpid, host_os, host_arch, hostname, cpu_count, path_basename
export process_kill, process_run, process_run_timeout, process_spawn_async, process_wait, process_is_running
export time_now_unix_micros, current_time_unix, current_time_ms, time_now_nanos, time_now_micros
export rt_timestamp_now, rt_debug_set_active
export use std.nogc_sync_mut.io.{timestamp_year, timestamp_month, timestamp_day, timestamp_hour, timestamp_minute, timestamp_second}
export use std.nogc_sync_mut.io.{rt_debug_add_breakpoint_at, rt_debug_remove_breakpoint_at, rt_debug_continue_exec, rt_debug_pause_exec, rt_debug_set_step_mode_val, rt_debug_stack_trace_lines, rt_debug_local_vars, rt_debug_get_current_file, rt_debug_get_current_line, rt_debug_add_breakpoint_rich, rt_debug_add_function_breakpoint, rt_debug_set_breakpoint_enabled, rt_debug_get_breakpoint_info, rt_debug_list_breakpoints, rt_debug_get_source_lines, rt_debug_add_watch, rt_debug_remove_watch, rt_debug_list_watches, rt_debug_set_variable, rt_debug_terminate, rt_debug_select_frame, rt_debug_get_selected_frame, rt_debug_frame_locals}
