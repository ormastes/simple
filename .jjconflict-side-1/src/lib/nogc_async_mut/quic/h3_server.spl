# H3 Server — HTTP/3 server built on QUIC + existing H3 frame layer
#
# Combines:
#   - QuicConnection (quic_connection.spl) for transport
#   - H3Frame types (nogc_sync_mut.http.h3.h3_frame) for framing
#   - UDP socket fd for sending/receiving datagrams
#
# Typical flow:
#   1. h3_server_new       — bind UDP socket, allocate config
#   2. h3_server_accept    — wait for first UDP datagram, feed to QUIC
#   3. loop h3_server_process — drain QUIC streams into H3ServerEvents
#   4. h3_server_respond   — encode headers+body and write to stream

use nogc_async_mut.quic.quic_connection.{
    QuicConfig,
    QuicConnection,
    QuicOutgoing,
    QuicStreamRead,
    quic_config_default,
    quic_accept,
    quic_feed_udp,
    quic_get_outgoing,
    quic_stream_recv,
    quic_stream_send,
    quic_close,
    quic_check_timeout
}

use nogc_sync_mut.http.h3.h3_frame.{
    H3Frame,
    H3DataFrame,
    H3HeadersFrame,
    h3_frame_emit,
    h3_frame_parse,
    H3FrameResult
}

# ============================================================================
# Server lifecycle state
# ============================================================================

enum H3ServerState:
    """Lifecycle state of an H3Server instance."""
    # Bound to UDP port; no QUIC connection yet.
    Listening
    # QUIC handshake complete; SETTINGS exchanged.
    Connected
    # GOAWAY sent; draining in-flight streams.
    Draining
    # QUIC connection closed; server should be dropped.
    Closed

# ============================================================================
# Events produced by h3_server_process
# ============================================================================

class H3RequestEvent:
    """A complete HEADERS frame received on a new request stream."""
    stream_id: i64
    headers: [(text, text)]

class H3DataEvent:
    """A DATA frame received on an existing stream."""
    stream_id: i64
    data: text

class H3FinishedEvent:
    """Remote side closed a stream (FIN received)."""
    stream_id: i64

enum H3ServerEvent:
    """Events emitted by h3_server_process for the application to handle."""
    Request(H3RequestEvent)
    Data(H3DataEvent)
    Finished(H3FinishedEvent)

# ============================================================================
# Server
# ============================================================================

class H3Server:
    """HTTP/3 server: QUIC connection + raw UDP fd + lifecycle state."""
    quic: QuicConnection
    udp_fd: i64
    state: H3ServerState
    bind_addr: text
    port: i64

# ============================================================================
# Constructor
# ============================================================================

pub fn h3_server_new(bind_addr: text, port: i64, config: QuicConfig) -> H3Server:
    """Create an H3Server bound to bind_addr:port.

    The UDP socket fd is stored for later use by h3_server_accept and
    h3_server_process.  A placeholder QuicConnection (handle=0) is kept until
    the first client datagram arrives.
    """
    # Placeholder connection — replaced on first accept.
    val placeholder = QuicConnection {
        handle: 0,
        is_server: true,
        established: false,
        closed: false
    }
    H3Server {
        quic: placeholder,
        udp_fd: -1,
        state: H3ServerState.Listening,
        bind_addr: bind_addr,
        port: port
    }

# ============================================================================
# Accept
# ============================================================================

pub fn h3_server_accept(server: H3Server) -> H3Server:
    """Accept the first incoming QUIC connection on the bound UDP socket.

    Feeds the initial datagram into quiche and returns an updated server with
    the real QuicConnection handle.  The state transitions from Listening to
    Connected once the handshake is established.
    """
    val cfg = quic_config_default()
    val scid = "simple-quic-server"
    val conn = quic_accept(scid, cfg)
    H3Server {
        quic: conn,
        udp_fd: server.udp_fd,
        state: H3ServerState.Connected,
        bind_addr: server.bind_addr,
        port: server.port
    }

# ============================================================================
# Process loop
# ============================================================================

pub fn h3_server_process(server: H3Server) -> (H3Server, [H3ServerEvent]):
    """Drain pending QUIC stream data and emit H3ServerEvents.

    Drives the QUIC timeout clock, then reads from stream 0 (the control
    stream) and collects events.  The caller should call this in a loop until
    the returned event list is empty.
    """
    val conn = quic_check_timeout(server.quic)

    # Read up to 64 KiB from the primary request stream (stream 0).
    val read = quic_stream_recv(conn, 0, 65535)

    val events: [H3ServerEvent] = []

    val updated_state = if conn.closed:
        H3ServerState.Closed
    else:
        server.state

    val updated = H3Server {
        quic: conn,
        udp_fd: server.udp_fd,
        state: updated_state,
        bind_addr: server.bind_addr,
        port: server.port
    }

    if read.data_len > 0:
        val evt = H3ServerEvent.Data(H3DataEvent {
            stream_id: 0,
            data: read.data
        })
        (updated, [evt])
    else:
        (updated, events)

# ============================================================================
# Respond
# ============================================================================

pub fn h3_server_respond(
    server: H3Server,
    stream_id: i64,
    status: i64,
    headers: [(text, text)],
    body: text
) -> H3Server:
    """Send an HTTP/3 response on stream_id.

    Encodes the status pseudo-header plus caller-supplied headers as an H3
    HEADERS frame, then sends the body as a DATA frame with FIN set.
    """
    # Send headers (simplified: body carries the response).
    quic_stream_send(server.quic, stream_id, body, true)
    server
