    get_architecture, get_pointer_size, is_x86_64, is_aarch64,
    is_64bit, is_32bit, has_feature, has_generics, has_async,
    has_macros, has_effects, has_inline_asm, has_gpu, has_cuda,
    has_simd, has_avx2, has_neon, get_cpu_cores, is_multi_core,
    has_module, has_library, has_env, get_env, is_ci,
    has_symlinks, has_permissions, is_case_sensitive, has_xattr,
