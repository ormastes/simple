# HTTP/2 Server-Side Multiplexing Engine
#
# Dispatches incoming H2Frames to connection and stream handlers, producing
# a list of actions the caller should execute (send frames, dispatch requests,
# close streams, shut down).
#
# Scope:
#   - h2_server_handle_connection: main dispatch entry point
#   - H2ServerAction: tagged union of server actions
#   - Frame dispatch: DATA, HEADERS, RST_STREAM, SETTINGS, WINDOW_UPDATE,
#     PING, GOAWAY
#
# Depends on: h2_connection.spl, h2_stream.spl, h2_hpack.spl, h2_frame.spl,
#             h2_writer.spl

# ============================================================================
# Server action payloads
# ============================================================================

class H2SendFrameAction:
    """Instruct the caller to serialize and send a frame."""
    frame: H2Frame

class H2DispatchRequestAction:
    """A complete request is ready for routing."""
    stream_id: i64
    headers: [HpackEntry]
    body: [u8]

class H2CloseStreamAction:
    """The stream should be cleaned up by the caller."""
    stream_id: i64

class H2GoAwayAction:
    """The connection is going away with the given error code."""
    error_code: i64

# ============================================================================
# Server action enum
# ============================================================================

enum H2ServerAction:
    """Actions the server layer must perform after frame dispatch."""
    SendFrame(H2SendFrameAction)
    DispatchRequest(H2DispatchRequestAction)
    CloseStream(H2CloseStreamAction)
    GoAway(H2GoAwayAction)

# ============================================================================
# Internal helpers — stream body accumulation
#
# Simple does not yet have a Map type available in this layer, so body
# accumulation across multiple DATA frames is left to the caller via the
# DispatchRequest action (body is the payload of the single DATA frame, or
# empty when HEADERS carries END_STREAM).  A caller that needs reassembly
# collects DataChunk actions between DispatchRequest events.
# ============================================================================

fn _hpack_table() -> HpackTable:
    return hpack_static_table()

# ============================================================================
# Main dispatch function
# ============================================================================

pub fn h2_server_handle_connection(conn: H2Connection, frame: H2Frame) -> (H2Connection, [H2ServerAction]):
    """Dispatch a single incoming frame and return (updated_conn, actions).

    Frame dispatch rules (RFC 9113):
      DATA          — deliver body chunk; if END_STREAM close stream
      HEADERS       — open/continue stream; HPACK-decode; dispatch request if END_HEADERS+END_STREAM
      RST_STREAM    — close stream
      SETTINGS      — apply settings (ack only for now) + send ACK
      WINDOW_UPDATE — update connection or stream window
      PING          — send PONG
      GOAWAY        — initiate shutdown
      PRIORITY      — ignored (deprecated RFC 9113)
      PUSH_PROMISE  — not expected from client; ignored
      CONTINUATION  — partial header block; not yet assembled (deferred)
    """
    var actions: [H2ServerAction] = []
    match frame:
        case Data(d):
            val updated_conn = _handle_data(conn, d, actions)
            return (updated_conn, actions)
        case Headers(h):
            val updated_conn = _handle_headers(conn, h, actions)
            return (updated_conn, actions)
        case RstStream(r):
            val updated_conn = _handle_rst_stream(conn, r, actions)
            return (updated_conn, actions)
        case Settings(s):
            val updated_conn = _handle_settings(conn, s, actions)
            return (updated_conn, actions)
        case WindowUpdate(w):
            val updated_conn = h2_connection_update_window(conn, w.stream_id, w.increment)
            return (updated_conn, actions)
        case Ping(p):
            val updated_conn = _handle_ping(conn, p, actions)
            return (updated_conn, actions)
        case Goaway(g):
            val updated_conn = _handle_goaway(conn, g, actions)
            return (updated_conn, actions)
        case Priority(p):
            # PRIORITY is deprecated in RFC 9113 §5.3.2 — ignore
            return (conn, actions)
        case PushPromise(pp):
            # PUSH_PROMISE from client is a protocol error — ignore gracefully
            return (conn, actions)
        case Continuation(c):
            # CONTINUATION without preceding HEADERS state machine is deferred
            return (conn, actions)

# ============================================================================
# Per-frame handlers
# ============================================================================

fn _handle_data(conn: H2Connection, d: H2DataFrame, actions: [H2ServerAction]) -> H2Connection:
    """Handle DATA frame: emit DispatchRequest action; close stream if END_STREAM."""
    val end_stream = (d.flags & H2_FLAG_END_STREAM) != 0
    # Deliver the body chunk to the caller — caller accumulates across frames
    val stream = h2_connection_get_stream(conn, d.stream_id)
    var empty_headers: [HpackEntry] = []
    actions.push(H2ServerAction.DispatchRequest(H2DispatchRequestAction(
        stream_id: d.stream_id,
        headers: empty_headers,
        body: d.data
    )))
    if end_stream:
        val closed_stream = h2_stream_transition(stream, H2StreamEvent.RecvEndStream)
        actions.push(H2ServerAction.CloseStream(H2CloseStreamAction(stream_id: d.stream_id)))
        return _conn_upsert_stream(conn, closed_stream)
    return conn

fn _handle_headers(conn: H2Connection, h: H2HeadersFrame, actions: [H2ServerAction]) -> H2Connection:
    """Handle HEADERS frame: accept stream, decode headers, dispatch if END_HEADERS+END_STREAM."""
    val table = _hpack_table()
    val decode_result = hpack_decode(h.header_block, table)
    val end_stream = (h.flags & H2_FLAG_END_STREAM) != 0
    val end_headers = (h.flags & H2_FLAG_END_HEADERS) != 0
    # Accept the stream (Idle → Open)
    var updated_conn = h2_connection_accept_stream(conn, h.stream_id)
    if end_headers:
        if end_stream:
            # Complete request ready
            actions.push(H2ServerAction.DispatchRequest(H2DispatchRequestAction(
                stream_id: h.stream_id,
                headers: decode_result.headers,
                body: []
            )))
            # Transition to HalfClosedRemote then Closed
            val stream = h2_connection_get_stream(updated_conn, h.stream_id)
            val closed_stream = h2_stream_transition(stream, H2StreamEvent.RecvEndStream)
            updated_conn = _conn_upsert_stream(updated_conn, closed_stream)
        else:
            # Headers done, body will follow via DATA frames
            actions.push(H2ServerAction.DispatchRequest(H2DispatchRequestAction(
                stream_id: h.stream_id,
                headers: decode_result.headers,
                body: []
            )))
    return updated_conn

fn _handle_rst_stream(conn: H2Connection, r: H2RstStreamFrame, actions: [H2ServerAction]) -> H2Connection:
    """Handle RST_STREAM: transition stream to Closed, emit CloseStream action."""
    val stream = h2_connection_get_stream(conn, r.stream_id)
    val closed_stream = h2_stream_transition(stream, H2StreamEvent.RecvRstStream)
    actions.push(H2ServerAction.CloseStream(H2CloseStreamAction(stream_id: r.stream_id)))
    return _conn_upsert_stream(conn, closed_stream)

fn _handle_settings(conn: H2Connection, s: H2SettingsFrame, actions: [H2ServerAction]) -> H2Connection:
    """Handle SETTINGS frame: if not ACK, apply and send ACK; if ACK, process ack."""
    val is_ack = (s.flags & H2_FLAG_ACK) != 0
    if is_ack:
        return h2_connection_handle_settings_ack(conn)
    # Send SETTINGS ACK
    var empty_settings: [H2Setting] = []
    val ack_frame = H2Frame.Settings(H2SettingsFrame(flags: H2_FLAG_ACK, settings: empty_settings))
    actions.push(H2ServerAction.SendFrame(H2SendFrameAction(frame: ack_frame)))
    # Apply peer settings we care about (initial_window_size, max_frame_size)
    var new_initial_window = conn.settings.initial_window_size
    var new_max_frame_size = conn.settings.max_frame_size
    var i = 0
    while i < s.settings.len():
        val param = s.settings[i]
        if param.identifier == H2_SETTINGS_INITIAL_WINDOW_SIZE:
            new_initial_window = param.value
        if param.identifier == H2_SETTINGS_MAX_FRAME_SIZE:
            new_max_frame_size = param.value
        i = i + 1
    val new_settings = H2Settings(
        max_concurrent_streams: conn.settings.max_concurrent_streams,
        initial_window_size: new_initial_window,
        max_frame_size: new_max_frame_size,
        header_table_size: conn.settings.header_table_size,
        enable_push: conn.settings.enable_push
    )
    return H2Connection(
        streams: conn.streams,
        settings: new_settings,
        next_stream_id: conn.next_stream_id,
        connection_window: conn.connection_window,
        max_concurrent_streams: conn.max_concurrent_streams,
        goaway_sent: conn.goaway_sent,
        last_stream_id: conn.last_stream_id
    )

fn _handle_ping(conn: H2Connection, p: H2PingFrame, actions: [H2ServerAction]) -> H2Connection:
    """Handle PING: if not ACK, send PONG (PING with ACK flag)."""
    val is_ack = (p.flags & H2_FLAG_ACK) != 0
    if not is_ack:
        val pong = H2Frame.Ping(H2PingFrame(flags: H2_FLAG_ACK, opaque_data: p.opaque_data))
        actions.push(H2ServerAction.SendFrame(H2SendFrameAction(frame: pong)))
    return conn

fn _handle_goaway(conn: H2Connection, g: H2GoawayFrame, actions: [H2ServerAction]) -> H2Connection:
    """Handle GOAWAY from client: emit GoAway action to shut down."""
    actions.push(H2ServerAction.GoAway(H2GoAwayAction(error_code: g.error_code)))
    return conn
