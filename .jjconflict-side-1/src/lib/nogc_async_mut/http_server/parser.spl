"""
# Incremental HTTP/1.1 Request Parser

Streaming parser that processes partial data and resumes on next recv.
Designed for non-blocking I/O where data arrives in chunks.

## Usage

```simple
val parser = HttpRequestParser.new()

# Feed data as it arrives from recv completions
val consumed = parser.feed("GET / HTTP/1.1\r\nHost: example.com\r\n")
val consumed2 = parser.feed("\r\n")

if parser.is_complete():
    val request = parser.to_request("127.0.0.1")
```
"""

use std.http.headers.{get_content_length, is_chunked, decode_chunked}
use std.http_server.types.{HttpRequestData}
use std.http_server.error.{HttpServerError}

# ============================================================================
# Parse State
# ============================================================================

enum ParseState:
    """State of the incremental parser."""
    RequestLine
    Headers
    Body
    Complete
    Error

# ============================================================================
# Incremental Parser
# ============================================================================

class HttpRequestParser:
    """Incremental HTTP/1.1 request parser.

    Feeds partial data via `feed()` and tracks parse progress.
    Once `is_complete()` returns true, call `to_request()` to
    get the parsed HttpRequestData.
    """
    state: ParseState
    buffer: text
    method: text
    path: text
    query: text
    version: text
    headers: [(text, text)]
    body: text
    content_length: i64
    is_chunked_encoding: bool
    error_message: text

    static fn new() -> HttpRequestParser:
        """Create a new parser ready to receive data."""
        HttpRequestParser(
            state: ParseState.RequestLine,
            buffer: "",
            method: "",
            path: "",
            query: "",
            version: "",
            headers: [],
            body: "",
            content_length: 0,
            is_chunked_encoding: false,
            error_message: ""
        )

    me feed(data: text) -> Result<i64, HttpServerError>:
        """Feed data to the parser.

        Processes as much as possible and buffers the rest.

        Args:
            data: Raw bytes received from socket

        Returns:
            Number of bytes consumed, or ParseError
        """
        self.buffer = self.buffer + data
        var consumed = 0

        while true:
            match self.state:
                ParseState.RequestLine:
                    val line_end = self.buffer.index_of("\r\n")
                    if line_end.? and line_end >= 0:
                        val line = self.buffer.slice(0, line_end)
                        self.buffer = self.buffer.slice(line_end + 2, self.buffer.len())
                        consumed = consumed + line_end + 2
                        if not self.parse_request_line(line):
                            return Err(HttpServerError.ParseError(self.error_message))
                        self.state = ParseState.Headers
                    else:
                        return Ok(consumed)

                ParseState.Headers:
                    val line_end = self.buffer.index_of("\r\n")
                    if line_end.? and line_end >= 0:
                        if line_end == 0:
                            # Empty line = end of headers
                            self.buffer = self.buffer.slice(2, self.buffer.len())
                            consumed = consumed + 2
                            self.finalize_headers()
                            if self.content_length > 0 or self.is_chunked_encoding:
                                self.state = ParseState.Body
                            else:
                                self.state = ParseState.Complete
                        else:
                            val line = self.buffer.slice(0, line_end)
                            self.buffer = self.buffer.slice(line_end + 2, self.buffer.len())
                            consumed = consumed + line_end + 2
                            self.parse_header_line(line)
                    else:
                        return Ok(consumed)

                ParseState.Body:
                    if self.is_chunked_encoding:
                        # Simplified: accumulate until 0-length chunk
                        val term = self.buffer.index_of("0\r\n\r\n")
                        if term.? and term >= 0:
                            val raw = self.buffer.slice(0, term + 5)
                            self.body = decode_chunked(raw)
                            consumed = consumed + term + 5
                            self.buffer = self.buffer.slice(term + 5, self.buffer.len())
                            self.state = ParseState.Complete
                        else:
                            return Ok(consumed)
                    else:
                        val remaining = self.content_length - self.body.len()
                        if self.buffer.len() >= remaining:
                            self.body = self.body + self.buffer.slice(0, remaining)
                            self.buffer = self.buffer.slice(remaining, self.buffer.len())
                            consumed = consumed + remaining
                            self.state = ParseState.Complete
                        else:
                            self.body = self.body + self.buffer
                            consumed = consumed + self.buffer.len()
                            self.buffer = ""
                            return Ok(consumed)

                ParseState.Complete:
                    return Ok(consumed)

                ParseState.Error:
                    return Err(HttpServerError.ParseError(self.error_message))

        Ok(consumed)

    fn is_complete() -> bool:
        """Check if a complete request has been parsed."""
        match self.state:
            ParseState.Complete: true
            _: false

    fn has_error() -> bool:
        """Check if the parser encountered an error."""
        match self.state:
            ParseState.Error: true
            _: false

    fn to_request(peer_addr: text) -> HttpRequestData:
        """Convert parsed data to HttpRequestData.

        Should only be called after is_complete() returns true.

        Args:
            peer_addr: Remote address of the client

        Returns:
            Parsed request data
        """
        HttpRequestData(
            method: self.method,
            path: self.path,
            query: self.query,
            version: self.version,
            headers: self.headers,
            body: self.body,
            params: {},
            peer_addr: peer_addr
        )

    me reset():
        """Reset parser for next request on keep-alive connection."""
        self.state = ParseState.RequestLine
        self.method = ""
        self.path = ""
        self.query = ""
        self.version = ""
        self.headers = []
        self.body = ""
        self.content_length = 0
        self.is_chunked_encoding = false
        self.error_message = ""
        # Keep buffer — may contain pipelined request data

    # ========================================================================
    # Internal Parsing
    # ========================================================================

    me parse_request_line(line: text) -> bool:
        """Parse 'METHOD /path HTTP/1.1' line."""
        val parts = line.split(" ")
        if parts.len() < 3:
            self.error_message = "Malformed request line: {line}"
            self.state = ParseState.Error
            return false

        self.method = parts[0]
        val raw_path = parts[1]
        self.version = parts[2]

        # Split path and query string
        val qmark = raw_path.index_of("?")
        if qmark.? and qmark >= 0:
            self.path = raw_path.slice(0, qmark)
            self.query = raw_path.slice(qmark + 1, raw_path.len())
        else:
            self.path = raw_path
            self.query = ""

        true

    me parse_header_line(line: text):
        """Parse a single 'Name: Value' header line."""
        val colon = line.index_of(":")
        if colon.? and colon > 0:
            val name = line.slice(0, colon).trim()
            val value = line.slice(colon + 1, line.len()).trim()
            self.headers = self.headers + [(name, value)]

    me finalize_headers():
        """Extract content-length and transfer-encoding after all headers parsed."""
        val cl = get_content_length(self.headers)
        if cl.?:
            self.content_length = cl

        self.is_chunked_encoding = is_chunked(self.headers)
