"""
# Protocol Handler

ALPN-based HTTP protocol dispatch for the async HTTP server.
Maps negotiated ALPN strings to the correct protocol engine.

## Usage

```simple
val kind = protocol_from_alpn("h2")
val label = protocol_handler_label(kind)
```
"""

# ============================================================================
# Protocol Kind
# ============================================================================

enum ProtocolKind:
    """Enumeration of supported application-layer HTTP protocol versions."""
    Http1
    Http2
    Http3

# ============================================================================
# ALPN Dispatch
# ============================================================================

fn protocol_from_alpn(alpn: text) -> ProtocolKind:
    """Map a negotiated ALPN protocol string to a ProtocolKind.

    "h2"  → Http2
    "h3"  → Http3 (rejected on TCP by the caller; signalled here for logging)
    Any other value (including "http/1.1" or empty) → Http1

    Args:
        alpn: Negotiated ALPN string from TLS handshake. May be empty.

    Returns:
        ProtocolKind variant matching the negotiated protocol.
    """
    if alpn == "h2":
        return ProtocolKind.Http2
    if alpn == "h3":
        return ProtocolKind.Http3
    ProtocolKind.Http1

fn protocol_handler_label(kind: ProtocolKind) -> text:
    """Return a human-readable label for a ProtocolKind (used in logs).

    Args:
        kind: Protocol variant to describe.

    Returns:
        Short lowercase label string.
    """
    match kind:
        ProtocolKind.Http1:
            "http/1.1"
        ProtocolKind.Http2:
            "h2"
        ProtocolKind.Http3:
            "h3"
