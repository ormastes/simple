"""
# No-GC Async Coverage

Compatibility facade over the no-GC sync coverage backend. Coverage data
loading is a synchronous environment/file operation, so the async family reuses
the shared no-GC declaration owner.
"""

export use std.nogc_sync_mut.coverage.{
    FileResult, CoverageResult,
    _coverage_data_loaded, _coverage_data_path, _coverage_files, _coverage_last_error,
    _coverage_error, get_coverage_error, clear_coverage_error,
    _get_coverage_data_path, _load_coverage_data, _parse_coverage_file,
    _safe_parse_int, _find_or_add, _match_pattern, _calculate_coverage,
    check_coverage, get_coverage_summary, print_coverage_report,
    reload_coverage_data, check_coverage_file, check_coverage_class
}
