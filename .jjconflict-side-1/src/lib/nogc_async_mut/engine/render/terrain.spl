# Terrain System — heightmap-based terrain with texture layers

struct HeightmapCell:
    height: f64
    normal_x: f64
    normal_y: f64
    normal_z: f64

struct TerrainLayer:
    name: text
    tiling: f64
    metallic: f64
    smoothness: f64

class TerrainData:
    width: i32
    depth: i32
    max_height: f64
    cells: [HeightmapCell]
    layers: [TerrainLayer]

impl TerrainData:
    static fn new(width: i32, depth: i32, max_height: f64) -> TerrainData:
        var cells: [HeightmapCell] = []
        var i = 0
        val total = width * depth
        while i < total:
            val cell = HeightmapCell(height: 0.0, normal_x: 0.0, normal_y: 1.0, normal_z: 0.0)
            cells.push(cell)
            i = i + 1
        TerrainData(width: width, depth: depth, max_height: max_height, cells: cells, layers: [])

    me set_height(x: i32, z: i32, height: f64):
        if x < 0 or x >= self.width or z < 0 or z >= self.depth:
            return
        val idx = z * self.width + x
        val old = self.cells[idx]
        var h = height
        if h > self.max_height:
            h = self.max_height
        if h < 0.0:
            h = 0.0
        self.cells[idx] = HeightmapCell(
            height: h, normal_x: old.normal_x, normal_y: old.normal_y, normal_z: old.normal_z
        )

    fn get_height(x: i32, z: i32) -> f64:
        if x < 0 or x >= self.width or z < 0 or z >= self.depth:
            return 0.0
        val idx = z * self.width + x
        self.cells[idx].height

    fn sample_height(fx: f64, fz: f64) -> f64:
        var ix = 0
        var tmp = fx
        while tmp >= 1.0:
            ix = ix + 1
            tmp = tmp - 1.0
        var iz = 0
        tmp = fz
        while tmp >= 1.0:
            iz = iz + 1
            tmp = tmp - 1.0
        if ix < 0 or ix >= self.width or iz < 0 or iz >= self.depth:
            return 0.0
        val idx = iz * self.width + ix
        self.cells[idx].height

    me add_layer(name: text, tiling: f64, metallic: f64, smoothness: f64):
        val layer = TerrainLayer(name: name, tiling: tiling, metallic: metallic, smoothness: smoothness)
        self.layers.push(layer)

    fn layer_count() -> i32:
        self.layers.len().to_i32()

    fn cell_count() -> i32:
        self.cells.len().to_i32()

    me raise_area(cx: i32, cz: i32, radius: i32, amount: f64):
        var x = cx - radius
        while x <= cx + radius:
            var z = cz - radius
            while z <= cz + radius:
                if x >= 0 and x < self.width and z >= 0 and z < self.depth:
                    val dx = x - cx
                    val dz = z - cz
                    if dx * dx + dz * dz <= radius * radius:
                        val idx = z * self.width + x
                        val old = self.cells[idx]
                        var h = old.height + amount
                        if h > self.max_height:
                            h = self.max_height
                        self.cells[idx] = HeightmapCell(
                            height: h, normal_x: old.normal_x, normal_y: old.normal_y, normal_z: old.normal_z
                        )
                z = z + 1
            x = x + 1

    me flatten_area(cx: i32, cz: i32, radius: i32, target_height: f64):
        var x = cx - radius
        while x <= cx + radius:
            var z = cz - radius
            while z <= cz + radius:
                if x >= 0 and x < self.width and z >= 0 and z < self.depth:
                    val dx = x - cx
                    val dz = z - cz
                    if dx * dx + dz * dz <= radius * radius:
                        val idx = z * self.width + x
                        val old = self.cells[idx]
                        self.cells[idx] = HeightmapCell(
                            height: target_height, normal_x: old.normal_x, normal_y: old.normal_y, normal_z: old.normal_z
                        )
                z = z + 1
            x = x + 1
