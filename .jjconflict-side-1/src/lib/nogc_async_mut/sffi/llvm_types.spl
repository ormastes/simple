# LLVM SFFI — Context, Module, Types, Constants, Functions & Globals.

use std.nogc_async_mut.sffi.llvm_loader.{
    _lc0, _lc1, _lc2, _lc3, _lc4, _lcn,
    llvm_make_array, llvm_free_array,
    rt_alloc, rt_free, rt_ptr_write_i64, rt_ptr_read_i64
}

# ============================================================================
# LLVM Enum Constants
# ============================================================================

# IntPredicate
val LLVM_INT_EQ = 32
val LLVM_INT_NE = 33
val LLVM_INT_UGT = 34
val LLVM_INT_UGE = 35
val LLVM_INT_ULT = 36
val LLVM_INT_ULE = 37
val LLVM_INT_SGT = 38
val LLVM_INT_SGE = 39
val LLVM_INT_SLT = 40
val LLVM_INT_SLE = 41

# RealPredicate
val LLVM_REAL_OEQ = 1
val LLVM_REAL_OGT = 2
val LLVM_REAL_OGE = 3
val LLVM_REAL_OLT = 4
val LLVM_REAL_OLE = 5
val LLVM_REAL_ONE = 6
val LLVM_REAL_ORD = 7
val LLVM_REAL_UNO = 8

# Linkage
val LLVM_EXTERNAL_LINKAGE = 0
val LLVM_INTERNAL_LINKAGE = 8
val LLVM_PRIVATE_LINKAGE = 9

# CodeGenOptLevel
val LLVM_CODE_GEN_LEVEL_NONE = 0
val LLVM_CODE_GEN_LEVEL_LESS = 1
val LLVM_CODE_GEN_LEVEL_DEFAULT = 2
val LLVM_CODE_GEN_LEVEL_AGGRESSIVE = 3

# RelocMode
val LLVM_RELOC_DEFAULT = 0
val LLVM_RELOC_STATIC = 1
val LLVM_RELOC_PIC = 2

# CodeModel
val LLVM_CODE_MODEL_DEFAULT = 0
val LLVM_CODE_MODEL_SMALL = 2
val LLVM_CODE_MODEL_LARGE = 4

# CodeGenFileType
val LLVM_ASSEMBLY_FILE = 0
val LLVM_OBJECT_FILE = 1

# ============================================================================
# 1. Context & Module
# ============================================================================

fn llvm_context_create() -> i64:
    _lc0("LLVMContextCreate")

fn llvm_context_dispose(ctx: i64):
    _lc1("LLVMContextDispose", ctx)

fn llvm_module_create_with_name_in_context(name: text, ctx: i64) -> i64:
    _lc2("LLVMModuleCreateWithNameInContext", name.ptr(), ctx)

fn llvm_dispose_module(mod_: i64):
    _lc1("LLVMDisposeModule", mod_)

fn llvm_set_target(mod_: i64, triple: text):
    _lc2("LLVMSetTarget", mod_, triple.ptr())

fn llvm_set_data_layout(mod_: i64, layout: text):
    _lc2("LLVMSetDataLayout", mod_, (layout + "\0").ptr())

fn llvm_set_source_file_name(mod_: i64, name: text):
    _lc3("LLVMSetSourceFileName", mod_, name.ptr(), name.len())

fn llvm_verify_module(mod_: i64) -> bool:
    # LLVMVerifyModule(M, Action, OutMessage) — Action=0=AbortProcess, 1=PrintMessage, 2=ReturnStatus
    val err_ptr = rt_alloc(8)
    rt_ptr_write_i64(err_ptr, 0, 0)
    var args: [i64] = []
    args.push(mod_)
    args.push(2)
    args.push(err_ptr)
    val result = _lcn("LLVMVerifyModule", args)
    rt_free(err_ptr)
    if result != 0:
        # Re-run with Action=1 (PrintMessage): LLVM prints the specific
        # verification failures to stderr, so the refuse-to-emit error is
        # diagnosable without a char*->text bridge.
        val err2 = rt_alloc(8)
        rt_ptr_write_i64(err2, 0, 0)
        var args2: [i64] = []
        args2.push(mod_)
        args2.push(1)
        args2.push(err2)
        _lcn("LLVMVerifyModule", args2)
        rt_free(err2)
    result == 0

fn llvm_print_module_to_string(mod_: i64) -> i64:
    _lc1("LLVMPrintModuleToString", mod_)

fn llvm_dispose_message(msg: i64):
    _lc1("LLVMDisposeMessage", msg)

# ============================================================================
# 2. Types
# ============================================================================

fn llvm_void_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMVoidTypeInContext", ctx)

fn llvm_int1_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt1TypeInContext", ctx)

fn llvm_int8_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt8TypeInContext", ctx)

fn llvm_int16_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt16TypeInContext", ctx)

fn llvm_int32_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt32TypeInContext", ctx)

fn llvm_int64_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt64TypeInContext", ctx)

fn llvm_float_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMFloatTypeInContext", ctx)

fn llvm_double_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMDoubleTypeInContext", ctx)

# reason: positional sffi llvm API
fn llvm_pointer_type(elem_ty: i64, addr_space: i64) -> i64:
    _lc2("LLVMPointerType", elem_ty, addr_space)

fn llvm_function_type(ret_ty: i64, param_types: [i64], is_var_arg: bool) -> i64:
    val n = param_types.len()
    val arr = llvm_make_array(param_types)
    val va = if is_var_arg: 1 else: 0
    val result = _lc4("LLVMFunctionType", ret_ty, arr, n, va)
    llvm_free_array(arr)
    result

fn llvm_struct_type_in_context(ctx: i64, elem_types: [i64], packed: bool) -> i64:
    val n = elem_types.len()
    val arr = llvm_make_array(elem_types)
    val pk = if packed: 1 else: 0
    val result = _lc4("LLVMStructTypeInContext", ctx, arr, n, pk)
    llvm_free_array(arr)
    result

# reason: positional sffi llvm API
fn llvm_array_type2(elem_ty: i64, count: i64) -> i64:
    _lc2("LLVMArrayType2", elem_ty, count)

fn llvm_get_type_kind(ty: i64) -> i64:
    _lc1("LLVMGetTypeKind", ty)

fn llvm_type_of(value: i64) -> i64:
    _lc1("LLVMTypeOf", value)

fn llvm_get_element_type(ty: i64) -> i64:
    _lc1("LLVMGetElementType", ty)

fn llvm_count_struct_element_types(ty: i64) -> i64:
    _lc1("LLVMCountStructElementTypes", ty)

fn llvm_get_return_type(fn_ty: i64) -> i64:
    _lc1("LLVMGetReturnType", fn_ty)

fn llvm_get_int_type_width(ty: i64) -> i64:
    _lc1("LLVMGetIntTypeWidth", ty)

fn llvm_global_get_value_type(global: i64) -> i64:
    _lc1("LLVMGlobalGetValueType", global)

# ============================================================================
# 3. Constants
# ============================================================================

# reason: positional sffi llvm API
fn llvm_const_int(ty: i64, value: i64, sign_extend: bool) -> i64:
    val se = if sign_extend: 1 else: 0
    _lc3("LLVMConstInt", ty, value, se)

fn llvm_const_real_of_string(ty: i64, value: text) -> i64:
    _lc2("LLVMConstRealOfString", ty, value.ptr())

fn llvm_const_string_in_context(ctx: i64, str: text, dont_null_terminate: bool) -> i64:
    val dnt = if dont_null_terminate: 1 else: 0
    _lc4("LLVMConstStringInContext", ctx, str.ptr(), str.len(), dnt)

fn llvm_const_null(ty: i64) -> i64:
    _lc1("LLVMConstNull", ty)

fn llvm_get_undef(ty: i64) -> i64:
    _lc1("LLVMGetUndef", ty)

fn llvm_const_array(elem_ty: i64, values: [i64]) -> i64:
    val n = values.len()
    val arr = llvm_make_array(values)
    val result = _lc3("LLVMConstArray", elem_ty, arr, n)
    llvm_free_array(arr)
    result

fn llvm_const_struct_in_context(ctx: i64, values: [i64], packed: bool) -> i64:
    val n = values.len()
    val arr = llvm_make_array(values)
    val pk = if packed: 1 else: 0
    val result = _lc4("LLVMConstStructInContext", ctx, arr, n, pk)
    llvm_free_array(arr)
    result

fn llvm_const_pointer_null(ty: i64) -> i64:
    _lc1("LLVMConstPointerNull", ty)

# ============================================================================
# 4. Functions & Globals
# ============================================================================

# reason: positional sffi llvm API
fn llvm_add_function(mod_: i64, name: text, fn_ty: i64) -> i64:
    # Null-terminate: LLVMAddFunction strlen()s the name into the symbol table,
    # and seed strings aren't guaranteed null-terminated, so a bare .ptr() stores
    # a garbage symbol and the linker can't resolve e.g. __simple_main.
    _lc3("LLVMAddFunction", mod_, (name + "\0").ptr(), fn_ty)

fn llvm_get_named_function(mod_: i64, name: text) -> i64:
    _lc2("LLVMGetNamedFunction", mod_, (name + "\0").ptr())

# reason: positional sffi llvm API
fn llvm_get_param(func: i64, index: i64) -> i64:
    _lc2("LLVMGetParam", func, index)

# reason: positional sffi llvm API
fn llvm_set_linkage(global: i64, linkage: i64):
    _lc2("LLVMSetLinkage", global, linkage)

# reason: positional sffi llvm API
fn llvm_add_global(mod_: i64, ty: i64, name: text) -> i64:
    _lc3("LLVMAddGlobal", mod_, ty, name.ptr())

# reason: positional sffi llvm API
fn llvm_set_initializer(global: i64, const_val: i64):
    _lc2("LLVMSetInitializer", global, const_val)

fn llvm_set_global_constant(global: i64, is_const: bool):
    val ic = if is_const: 1 else: 0
    _lc2("LLVMSetGlobalConstant", global, ic)

fn llvm_set_unnamed_addr(global: i64, has_unnamed_addr: bool):
    val hua = if has_unnamed_addr: 1 else: 0
    _lc2("LLVMSetUnnamedAddr", global, hua)

fn llvm_count_params(func: i64) -> i64:
    _lc1("LLVMCountParams", func)

# reason: positional sffi llvm API
fn llvm_set_function_call_conv(func: i64, cc: i64):
    _lc2("LLVMSetFunctionCallConv", func, cc)

# reason: positional sffi llvm API
fn llvm_add_attribute_at_index(func: i64, idx: i64, attr: i64):
    _lc3("LLVMAddAttributeAtIndex", func, idx, attr)

# reason: positional sffi llvm API
fn llvm_create_enum_attribute(ctx: i64, kind_id: i64, value: i64) -> i64:
    _lc3("LLVMCreateEnumAttribute", ctx, kind_id, value)

fn llvm_get_enum_attribute_kind_for_name(name: text) -> i64:
    _lc2("LLVMGetEnumAttributeKindForName", name.ptr(), name.len())

export LLVM_INT_EQ, LLVM_INT_NE, LLVM_INT_UGT, LLVM_INT_UGE, LLVM_INT_ULT, LLVM_INT_ULE
export LLVM_INT_SGT, LLVM_INT_SGE, LLVM_INT_SLT, LLVM_INT_SLE
export LLVM_REAL_OEQ, LLVM_REAL_OGT, LLVM_REAL_OGE, LLVM_REAL_OLT, LLVM_REAL_OLE
export LLVM_REAL_ONE, LLVM_REAL_ORD, LLVM_REAL_UNO
export LLVM_EXTERNAL_LINKAGE, LLVM_INTERNAL_LINKAGE, LLVM_PRIVATE_LINKAGE
export LLVM_CODE_GEN_LEVEL_NONE, LLVM_CODE_GEN_LEVEL_LESS, LLVM_CODE_GEN_LEVEL_DEFAULT, LLVM_CODE_GEN_LEVEL_AGGRESSIVE
export LLVM_RELOC_DEFAULT, LLVM_RELOC_STATIC, LLVM_RELOC_PIC
export LLVM_CODE_MODEL_DEFAULT, LLVM_CODE_MODEL_SMALL, LLVM_CODE_MODEL_LARGE
export LLVM_ASSEMBLY_FILE, LLVM_OBJECT_FILE
export llvm_context_create, llvm_context_dispose
export llvm_module_create_with_name_in_context, llvm_dispose_module
export llvm_set_target, llvm_set_data_layout, llvm_set_source_file_name
export llvm_add_attribute_at_index, llvm_create_enum_attribute, llvm_get_enum_attribute_kind_for_name
