"""
# No-GC Async Vulkan 2D engine SFFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous SFFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine2d.sffi_vulkan.{
    VulkanFfi, vulkan_sffi_init, vulkan_sffi_shutdown, vulkan_sffi_is_available,
    vulkan_sffi_device_count, vulkan_sffi_select_device, vulkan_sffi_alloc_buffer,
    vulkan_sffi_free_buffer, vulkan_sffi_compile_glsl, vulkan_sffi_destroy_shader,
    vulkan_sffi_create_compute_pipeline, vulkan_sffi_destroy_pipeline,
    vulkan_sffi_create_descriptor_set, vulkan_sffi_bind_buffer,
    vulkan_sffi_destroy_descriptor_set, vulkan_sffi_begin_compute, vulkan_sffi_bind_pipeline,
    vulkan_sffi_bind_descriptors, vulkan_sffi_push_constants, vulkan_sffi_dispatch,
    vulkan_sffi_end_compute, vulkan_sffi_submit_and_wait, vulkan_sffi_copy_from_buffer,
    vulkan_sffi_copy_to_buffer, vulkan_sffi_wait_idle
}
