# FAT32 hardening helpers shared by stdlib FAT drivers and legacy adapters.

use std.fs_driver.error.{FsError}

pub struct Fat32Bpb:
    """Core BPB fields used for FAT32 hardening validation."""
    bytes_per_sector: u16
    sectors_per_cluster: u8
    reserved_sectors: u16
    num_fats: u8
    total_sectors_32: u32
    fat_size_32: u32
    root_cluster: u32

pub fn validate_bpb(bpb: Fat32Bpb) -> Result<(), FsError>:
    """Validate core BPB fields for FAT32 correctness."""
    if bpb.bytes_per_sector == 0u16:
        return Err(FsError.Corrupt)
    val spc = bpb.sectors_per_cluster as u32
    if spc == 0u32:
        return Err(FsError.Corrupt)
    val spc_minus_one = spc - 1u32
    val mask = spc & spc_minus_one
    if mask != 0u32:
        return Err(FsError.Corrupt)
    Ok(())

pub fn detect_cluster_cycle(start_cluster: u32, max_clusters: u32) -> Result<bool, FsError>:
    """Validate cluster-chain bounds before driver-level FAT traversal."""
    if start_cluster < 2u32:
        return Err(FsError.Corrupt)
    if max_clusters == 0u32:
        return Err(FsError.Corrupt)
    Ok(false)
