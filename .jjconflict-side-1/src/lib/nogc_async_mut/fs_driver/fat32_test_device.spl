# FAT32 — Test device registry and per-device operation wrappers.
#
# Provides a global Fat32Core registry keyed by DeviceId for use in tests.

use std.driver.types.{DeviceId, DriverClass}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.types.{FileHandle, DirEntry}
use std.fs_driver.fat32_core.{Fat32Core, fat32_write_4k_overwrite}

var __fat32_test_devices: [Fat32Core] = []
var __fat32_test_devices_ready: bool = false

fn _fat32_test_devices_init():
    if not __fat32_test_devices_ready:
        __fat32_test_devices = []
        __fat32_test_devices_ready = true

fn fat32_reset_test_devices():
    __fat32_test_devices = []
    __fat32_test_devices_ready = true

fn fat32_register_test_device(device: BlockDevice) -> DeviceId:
    _fat32_test_devices_init()
    val slot = __fat32_test_devices.len() as i64
    var devices = __fat32_test_devices
    devices.push(Fat32Core.new(device))
    __fat32_test_devices = devices
    DeviceId(value: slot, dclass: DriverClass.Block)

fn _fat32_active_index() -> Result<i32, text>:
    _fat32_test_devices_init()
    if __fat32_test_devices.len() <= 0:
        return Err("unknown FAT32 device")
    Ok(0)

fn fat32_active_mount() -> Result<(), text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val rc = core.mount()
    __fat32_test_devices[idx] = core
    rc

fn fat32_active_create_file(path: text) -> Result<FileHandle, text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val rc = core.create_file(path)
    __fat32_test_devices[idx] = core
    rc

fn fat32_active_create_read4k_file() -> Result<FileHandle, text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val alloc_rc = core.alloc_cluster()
    if alloc_rc.is_err():
        __fat32_test_devices[idx] = core
        return Err(alloc_rc.unwrap_err())
    val rc = Ok(core.alloc_file_handle(alloc_rc.unwrap(), 0, false))
    __fat32_test_devices[idx] = core
    rc

fn fat32_active_create_write4k_file() -> Result<FileHandle, text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val alloc_rc = core.alloc_cluster()
    if alloc_rc.is_err():
        __fat32_test_devices[idx] = core
        return Err(alloc_rc.unwrap_err())
    val rc = Ok(core.alloc_file_handle(alloc_rc.unwrap(), 0, false))
    __fat32_test_devices[idx] = core
    rc

fn fat32_active_close(handle: FileHandle) -> Result<(), text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val rc = core.close(handle)
    __fat32_test_devices[idx] = core
    rc

fn fat32_active_seek(handle: FileHandle, position: i64) -> Result<(), text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val rc = core.seek(handle, position)
    __fat32_test_devices[idx] = core
    rc

fn fat32_active_read(handle: FileHandle, buf: [u8], len: i64) -> Result<i64, text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val rc = core.read(handle, buf, len)
    __fat32_test_devices[idx] = core
    rc

fn fat32_active_write(handle: FileHandle, buf: [u8], len: i64) -> Result<i64, text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val rc = core.write(handle, buf, len)
    __fat32_test_devices[idx] = core
    rc

fn fat32_active_write_4k_overwrite(handle: FileHandle, buf: [u8]) -> Result<i64, text>:
    val idx_rc = _fat32_active_index()
    if idx_rc.is_err():
        return Err(idx_rc.unwrap_err())
    val idx = idx_rc.unwrap()
    var core = __fat32_test_devices[idx]
    val rc = fat32_write_4k_overwrite(core, handle, buf)
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_probe(dev: DeviceId) -> Result<bool, text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Ok(false)
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Ok(false)
    var core = __fat32_test_devices[idx]
    val rc = core.probe_boot_sector()
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_mount(dev: DeviceId) -> Result<(), text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.mount()
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_unmount(dev: DeviceId) -> Result<(), text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.unmount()
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_is_mounted(dev: DeviceId) -> Result<bool, text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Ok(false)
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Ok(false)
    Ok(__fat32_test_devices[idx].mounted)

