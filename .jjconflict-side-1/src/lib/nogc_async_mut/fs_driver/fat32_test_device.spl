fn fat32_test_device_truncate(dev: DeviceId, handle: FileHandle, size: i64) -> Result<(), text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.truncate(handle, size)
    __fat32_test_devices[idx] = core
    rc

export fat32_test_device_probe, fat32_test_device_mount, fat32_test_device_unmount
export fat32_test_device_is_mounted, fat32_test_device_open, fat32_test_device_create_file
export fat32_test_device_close, fat32_test_device_seek, fat32_test_device_read_bytes
export fat32_test_device_read, fat32_test_device_write, fat32_test_device_write_4k_overwrite
