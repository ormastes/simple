"""
# TCP Connection Pool

Pure Simple connection-pool data structures for HTTP keep-alive and client
connection reuse. The pool tracks idle connections by host:port key, enforces
a maximum idle count per host, and exposes acquire/release/eviction helpers.

No runtime externs are needed — the pool holds integer file descriptors and
timestamps (ms since epoch) that callers supply; the actual socket operations
remain in `tcp.spl`.
"""

use std.io.socket_options.{TcpSocketOptions, tcp_socket_options_default}

struct PooledConnection:
    """A single idle connection slot held by the pool."""
    fd: i64
    host: text
    port: u16
    idle_since_ms: u64
    options: TcpSocketOptions

struct ConnectionPoolConfig:
    """Policy parameters for one connection pool."""
    max_idle_per_host: u32
    idle_timeout_ms: u64
    acquire_timeout_ms: u64

struct ConnectionPool:
    """Idle connection pool indexed by host:port key."""
    config: ConnectionPoolConfig
    idle: [PooledConnection]
    total_acquired: u64
    total_released: u64
    total_evicted: u64

struct AcquireResult:
    """Outcome of a pool acquire call."""
    fd: i64
    host: text
    port: u16
    reused: bool
    found: bool

struct PoolStats:
    """Snapshot of pool counters for monitoring."""
    idle_count: u64
    total_acquired: u64
    total_released: u64
    total_evicted: u64

fn pool_config_default() -> ConnectionPoolConfig:
    """Conservative defaults: 8 idle per host, 30 s idle timeout."""
    ConnectionPoolConfig(
        max_idle_per_host: 8u32,
        idle_timeout_ms: 30000u64,
        acquire_timeout_ms: 5000u64
    )

fn pool_config_new(max_idle_per_host: u32,
                   idle_timeout_ms: u64,
                   acquire_timeout_ms: u64) -> ConnectionPoolConfig:
    """Create a pool config with explicit policy values."""
    ConnectionPoolConfig(
        max_idle_per_host: max_idle_per_host,
        idle_timeout_ms: idle_timeout_ms,
        acquire_timeout_ms: acquire_timeout_ms
    )

fn connection_pool_new(config: ConnectionPoolConfig) -> ConnectionPool:
    """Create an empty connection pool."""
    ConnectionPool(
        config: config,
        idle: [],
        total_acquired: 0u64,
        total_released: 0u64,
        total_evicted: 0u64
    )

fn pooled_connection_new(fd: i64, host: text, port: u16,
                         now_ms: u64) -> PooledConnection:
    """Wrap a socket fd in a pool entry with the current timestamp."""
    PooledConnection(
        fd: fd,
        host: host,
        port: port,
        idle_since_ms: now_ms,
        options: tcp_socket_options_default()
    )

fn pooled_connection_is_expired(conn: PooledConnection,
                                now_ms: u64,
                                idle_timeout_ms: u64) -> bool:
    """True when the connection has been idle longer than the configured timeout."""
    now_ms > conn.idle_since_ms and (now_ms - conn.idle_since_ms) >= idle_timeout_ms

fn pool_host_key(host: text, port: u16) -> text:
    """Canonical host:port key used for pool lookup."""
    "{host}:{port}"

fn pool_acquire(pool: ConnectionPool,
                host: text,
                port: u16,
                now_ms: u64) -> (ConnectionPool, AcquireResult):
    """Try to acquire an idle connection for host:port.

    If a matching non-expired idle entry exists it is removed from the pool and
    returned (reused=true). Otherwise the caller must open a new connection.
    """
    val key = pool_host_key(host, port)
    val timeout = pool.config.idle_timeout_ms
    val result = pool_find_idle(pool.idle, key, now_ms, timeout, 0)
    if result.found:
        val new_idle = pool_remove_at(pool.idle, result.fd)
        val new_pool = ConnectionPool(
            config: pool.config,
            idle: new_idle,
            total_acquired: pool.total_acquired + 1u64,
            total_released: pool.total_released,
            total_evicted: pool.total_evicted
        )
        return (new_pool, result)
    val miss_result = AcquireResult(
        fd: -1,
        host: host,
        port: port,
        reused: false,
        found: false
    )
    (ConnectionPool(
        config: pool.config,
        idle: pool.idle,
        total_acquired: pool.total_acquired + 1u64,
        total_released: pool.total_released,
        total_evicted: pool.total_evicted
    ), miss_result)

fn pool_find_idle(idle: [PooledConnection],
                  key: text,
                  now_ms: u64,
                  timeout_ms: u64,
                  start: i64) -> AcquireResult:
    """Scan idle entries for a matching, non-expired slot. Returns first match."""
    if start < 0 or start >= idle.len():
        return AcquireResult(fd: -1, host: "", port: 0u16, reused: false, found: false)
    val conn = idle[start]
    if pool_host_key(conn.host, conn.port) == key and not pooled_connection_is_expired(conn, now_ms, timeout_ms):
        return AcquireResult(
            fd: conn.fd,
            host: conn.host,
            port: conn.port,
            reused: true,
            found: true
        )
    pool_find_idle(idle, key, now_ms, timeout_ms, start + 1)

fn _pool_remove_at_acc(idle: [PooledConnection],
                       target_fd: i64,
                       result: [PooledConnection],
                       index: i64) -> [PooledConnection]:
    if index < 0 or index >= idle.len():
        return result
    val conn = idle[index]
    if conn.fd == target_fd:
        return _pool_remove_at_acc(idle, target_fd, result, index + 1)
    _pool_remove_at_acc(idle, target_fd, result.push(conn), index + 1)

fn _pool_count_host(idle: [PooledConnection], key: text, index: i64) -> u32:
    if index < 0 or index >= idle.len():
        return 0u32
    val conn = idle[index]
    val rest = _pool_count_host(idle, key, index + 1)
    if pool_host_key(conn.host, conn.port) == key:
        return rest + 1u32
    rest

fn _pool_oldest_host_fd(idle: [PooledConnection],
                        key: text,
                        index: i64,
                        best_fd: i64,
                        best_idle_since: u64) -> i64:
    if index < 0 or index >= idle.len():
        return best_fd
    val conn = idle[index]
    if pool_host_key(conn.host, conn.port) == key and (best_fd < 0 or conn.idle_since_ms < best_idle_since):
        return _pool_oldest_host_fd(idle, key, index + 1, conn.fd, conn.idle_since_ms)
    _pool_oldest_host_fd(idle, key, index + 1, best_fd, best_idle_since)

fn _pool_evict_expired_acc(idle: [PooledConnection],
                           now_ms: u64,
                           timeout_ms: u64,
                           result: [PooledConnection],
                           evicted: u64,
                           index: i64) -> ([PooledConnection], u64):
    if index < 0 or index >= idle.len():
        return (result, evicted)
    val conn = idle[index]
    if pooled_connection_is_expired(conn, now_ms, timeout_ms):
        return _pool_evict_expired_acc(idle, now_ms, timeout_ms, result, evicted + 1u64, index + 1)
    _pool_evict_expired_acc(idle, now_ms, timeout_ms, result.push(conn), evicted, index + 1)

fn pool_remove_at(idle: [PooledConnection], target_fd: i64) -> [PooledConnection]:
    """Return a copy of idle with the entry for target_fd removed."""
    _pool_remove_at_acc(idle, target_fd, [], 0)

fn pool_release(pool: ConnectionPool,
                conn: PooledConnection,
                now_ms: u64) -> ConnectionPool:
    """Return a connection to the pool. Evicts the oldest when at capacity."""
    val key = pool_host_key(conn.host, conn.port)
    val max_idle = pool.config.max_idle_per_host
    val refreshed = PooledConnection(
        fd: conn.fd,
        host: conn.host,
        port: conn.port,
        idle_since_ms: now_ms,
        options: conn.options
    )
    val deduped = pool_remove_at(pool.idle, conn.fd)
    if max_idle == 0u32:
        return ConnectionPool(
            config: pool.config,
            idle: deduped,
            total_acquired: pool.total_acquired,
            total_released: pool.total_released + 1u64,
            total_evicted: pool.total_evicted + 1u64
        )
    val host_count = _pool_count_host(deduped, key, 0)
    var retained = deduped
    var evicted = 0u64
    if host_count >= max_idle:
        val oldest_fd = _pool_oldest_host_fd(deduped, key, 0, -1, 0u64)
        if oldest_fd >= 0:
            retained = pool_remove_at(deduped, oldest_fd)
            evicted = 1u64
    ConnectionPool(
        config: pool.config,
        idle: retained.push(refreshed),
        total_acquired: pool.total_acquired,
        total_released: pool.total_released + 1u64,
        total_evicted: pool.total_evicted + evicted
    )

fn pool_evict_expired(pool: ConnectionPool, now_ms: u64) -> (ConnectionPool, u64):
    """Remove all expired idle connections. Returns (new_pool, evicted_count)."""
    val timeout = pool.config.idle_timeout_ms
    val result = _pool_evict_expired_acc(pool.idle, now_ms, timeout, [], 0u64, 0)
    (ConnectionPool(
        config: pool.config,
        idle: result[0],
        total_acquired: pool.total_acquired,
        total_released: pool.total_released,
        total_evicted: pool.total_evicted + result[1]
    ), result[1])

fn pool_stats(pool: ConnectionPool) -> PoolStats:
    """Snapshot current pool counters."""
    PoolStats(
        idle_count: pool.idle.len().to_u64(),
        total_acquired: pool.total_acquired,
        total_released: pool.total_released,
        total_evicted: pool.total_evicted
    )

fn pool_stats_summary(stats: PoolStats) -> text:
    """One-line pool stats for CI logs."""
    "pool: idle={stats.idle_count}, acquired={stats.total_acquired}, released={stats.total_released}, evicted={stats.total_evicted}"
