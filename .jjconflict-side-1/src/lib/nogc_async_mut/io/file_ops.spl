"""
# No-GC Async File Operations

This module is a compatibility facade over the no-GC sync file operations.
The path-based file runtime hooks are owned by `nogc_sync_mut.io.file_ops`.
"""

export use std.nogc_sync_mut.io.file_ops.{
    file_exists, file_read, file_write, file_copy, file_delete,
    file_atomic_write, file_append, file_modified_time, file_remove,
    file_hash_sha256, file_read_lines, file_lock, file_unlock, file_size,
    file_size_raw, file_read_text, file_read_bytes, file_mmap_read_text,
    file_mmap_read_bytes, file_read_text_at, file_write_text_at, file_fsync,
    file_fsync_cached, file_mmap, file_munmap, file_madvise, file_msync,
    rt_file_rename
}
