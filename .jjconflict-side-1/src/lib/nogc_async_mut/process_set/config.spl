use nogc_async_mut.process_set.types.*
use std.nogc_sync_mut.io.file_ops.{file_read_text, file_exists}

fn load_process_config(path: text) -> Result<ProcessSeparationConfig, ProcessSetError>:
    if not file_exists(path):
        return Err(ProcessSetError.ConfigError(message: "config file not found: {path}"))

    val content = file_read_text(path)
    if content == "" or content == nil:
        return Err(ProcessSetError.ConfigError(message: "empty config file: {path}"))

    parse_process_config(content)

fn parse_process_config(content: text) -> Result<ProcessSeparationConfig, ProcessSetError>:
    var config = default_process_config()
    var lines = content.split("\n")

    var current_section = ""
    var current_subsection = ""

    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            continue

        val indent = _count_indent(line)

        if indent == 0 and trimmed.ends_with(":"):
            current_section = trimmed[0..(trimmed.len() - 1)]
            current_subsection = ""
            continue

        if indent == 4 and trimmed.ends_with(":"):
            current_subsection = trimmed[0..(trimmed.len() - 1)]
            continue

        if trimmed.contains(":"):
            val colon_idx = _find_colon(trimmed)
            if colon_idx < 0:
                continue
            val key = trimmed[0..colon_idx].trim()
            val value = trimmed[(colon_idx + 1)..trimmed.len()].trim()

            if current_section == "process":
                _apply_process_field(config, key, value)
            elif current_section == "service_groups" and current_subsection != "":
                _apply_service_group_field(config, current_subsection, key, value)
            elif current_section == "db_groups" and current_subsection != "":
                _apply_db_group_field(config, current_subsection, key, value)
            elif current_section == "workers" and current_subsection != "":
                _apply_worker_field(config, current_subsection, key, value)

    Ok(config)

fn _count_indent(line: text) -> i64:
    var count: i64 = 0
    var i = 0
    while i < line.len():
        if line[i] == " ":
            count = count + 1
        else:
            return count
        i = i + 1
    count

fn _find_colon(s: text) -> i64:
    var i = 0
    while i < s.len():
        if s[i] == ":":
            return i
        i = i + 1
    -1

fn _apply_process_field(config: ProcessSeparationConfig, key: text, value: text):
    if key == "mode":
        config.mode = ProcessMode.from_text(value)
    elif key == "ipc_transport":
        config.ipc_transport = IpcTransport.from_text(value)
    elif key == "queue_dir":
        config.queue_dir = value

fn _parse_csv(value: text) -> [text]:
    var result: [text] = []
    val parts = value.split(",")
    for part in parts:
        val trimmed = part.trim()
        if trimmed != "":
            result.push(trimmed)
    result

fn _find_or_create_service_group(config: ProcessSeparationConfig, name: text) -> ServiceGroupConfig:
    for sg in config.service_groups:
        if sg.name == name:
            return sg
    val sg = ServiceGroupConfig(name: name, services: [], db_group: "", process_name: "")
    config.service_groups.push(sg)
    sg

fn _apply_service_group_field(config: ProcessSeparationConfig, subsection: text, key: text, value: text):
    var sg = _find_or_create_service_group(config, subsection)
    if key == "services":
        sg.services = _parse_csv(value)
    elif key == "db_group":
        sg.db_group = value
    elif key == "process":
        sg.process_name = value

fn _find_or_create_db_group(config: ProcessSeparationConfig, name: text) -> DbGroupConfig:
    for dg in config.db_groups:
        if dg.name == name:
            return dg
    val dg = DbGroupConfig(name: name, path: "", db_type: "sdn", databases: [])
    config.db_groups.push(dg)
    dg

fn _apply_db_group_field(config: ProcessSeparationConfig, subsection: text, key: text, value: text):
    var dg = _find_or_create_db_group(config, subsection)
    if key == "path":
        dg.path = value
    elif key == "db_type":
        dg.db_type = value
    elif key == "databases":
        dg.databases = _parse_csv(value)

fn _find_or_create_worker(config: ProcessSeparationConfig, name: text) -> WorkerConfig:
    for w in config.workers:
        if w.name == name:
            return w
    val w = WorkerConfig(name: name, restart: "permanent", max_memory_mb: 512, count: 1)
    config.workers.push(w)
    w

fn _apply_worker_field(config: ProcessSeparationConfig, subsection: text, key: text, value: text):
    var w = _find_or_create_worker(config, subsection)
    if key == "restart":
        w.restart = value
    elif key == "max_memory_mb":
        w.max_memory_mb = value.to_int() ?? 512
    elif key == "count":
        w.count = value.to_int() ?? 1

fn validate_process_config(config: ProcessSeparationConfig) -> [text]:
    var warnings: [text] = []

    var sg_names: [text] = []
    for sg in config.service_groups:
        if sg.name == "":
            warnings.push("service group has empty name")
            continue

        for existing in sg_names:
            if existing == sg.name:
                warnings.push("duplicate service group: {sg.name}")
        sg_names.push(sg.name)

        var db_found = false
        for dg in config.db_groups:
            if dg.name == sg.db_group:
                db_found = true
        if not db_found and sg.db_group != "":
            warnings.push("service group '{sg.name}' references unknown db_group '{sg.db_group}'")

        var worker_found = false
        for w in config.workers:
            if w.name == sg.process_name:
                worker_found = true
        if not worker_found and sg.process_name != "":
            warnings.push("service group '{sg.name}' references unknown worker '{sg.process_name}'")

    warnings
