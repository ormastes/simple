# Experiment Tracking Library
#
# Local-first experiment tracking with .exp/ folder.
# SDN-based config, append-only event logs, content-addressed artifacts.
#
# Modules:
#   config   - SDN config composition, overrides, interpolation
#   storage  - Append-only event log + SDN index
#   run      - Run lifecycle, metric logging, system info
#   artifact - Content-addressed artifact store
#   sweep    - Study/Trial/Sampler/Pruner (Optuna-like)
#   query    - Run comparison, filtering, aggregation

export {ConfigValue, ExpConfig, load_exp_config, load_sdn_config, merge_configs, parse_cli_overrides} from config
export {Event, init_exp_dir, ensure_run_dir, run_dir_path, run_exists, append_event, read_events, write_run_meta, read_run_meta, store_blob, store_blob_file, read_blob, blob_exists, update_index, list_run_ids, list_blob_hashes, delete_blob} from storage
export {RunStatus, SystemInfo, MetricEntry, Run, start_run, resume_run} from run
export {ArtifactEntry, ArtifactStore, gc_artifacts} from artifact
export {TrialStatus, Trial, SamplerKind, Sampler, PrunerKind, Pruner, StudyConfig, Study} from sweep
export {RunSummary, RunFilter, RunDetail, MetricPoint, DiffResult, ConfigDiff, MetricDiff, list_runs, show_run, diff_runs, best_run} from query

# Re-exported from artifact.spl
export ArtifactEntry, ArtifactStore
export gc_artifacts

# Re-exported from config.spl
export ConfigValue, ExpConfig
export load_exp_config, load_sdn_config, merge_configs, parse_cli_overrides

# Re-exported from query.spl
export RunSummary, RunFilter, RunDetail, MetricPoint
export DiffResult, ConfigDiff, MetricDiff
export list_runs, show_run, diff_runs, best_run

# Re-exported from run.spl
export RunStatus, SystemInfo, MetricEntry, Run
export start_run, resume_run

# Re-exported from storage.spl
export Event
export init_exp_dir, ensure_run_dir, run_dir_path, run_exists
export append_event, read_events
export write_run_meta, read_run_meta
export store_blob, store_blob_file, read_blob, blob_exists
export update_index, list_run_ids
export list_blob_hashes, delete_blob

# Re-exported from sweep.spl
export TrialStatus, Trial, SamplerKind, Sampler, PrunerKind, Pruner
