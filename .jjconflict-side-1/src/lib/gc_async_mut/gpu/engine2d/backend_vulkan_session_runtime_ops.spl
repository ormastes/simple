#[runtime_intrinsics]
extern fn rt_vk_create_device() -> i64
extern fn rt_vk_has_spirv_support(handle: i64) -> bool
extern fn rt_vk_has_glslc(handle: i64) -> bool
extern fn rt_vk_clear(handle: i64, r: i64, g: i64, b: i64, a: i64) -> text
extern fn rt_vk_draw_rect(handle: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> text
extern fn rt_vk_readback(handle: i64, x: i64, y: i64, w: i64, h: i64) -> text
extern fn rt_vk_submit(handle: i64, cmd_count: i64) -> text
extern fn rt_vk_present(handle: i64) -> text
extern fn rt_vk_cleanup(handle: i64) -> i64

pub fn backend_vulkan_session_create_device() -> i64:
    rt_vk_create_device()

pub fn backend_vulkan_session_has_spirv_support(handle: i64) -> bool:
    rt_vk_has_spirv_support(handle)

pub fn backend_vulkan_session_has_glslc(handle: i64) -> bool:
    rt_vk_has_glslc(handle)

pub fn backend_vulkan_session_clear(handle: i64, r: i64, g: i64, b: i64, a: i64) -> text:
    rt_vk_clear(handle, r, g, b, a)

pub fn backend_vulkan_session_draw_rect(handle: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> text:
    rt_vk_draw_rect(handle, x, y, w, h, color)

pub fn backend_vulkan_session_readback(handle: i64, x: i64, y: i64, w: i64, h: i64) -> text:
    rt_vk_readback(handle, x, y, w, h)

pub fn backend_vulkan_session_submit(handle: i64, cmd_count: i64) -> text:
    rt_vk_submit(handle, cmd_count)

pub fn backend_vulkan_session_present(handle: i64) -> text:
    rt_vk_present(handle)

pub fn backend_vulkan_session_cleanup(handle: i64) -> i64:
    rt_vk_cleanup(handle)
