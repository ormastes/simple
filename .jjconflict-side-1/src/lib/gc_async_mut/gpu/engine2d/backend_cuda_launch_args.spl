# CUDA Engine2D launch argument and host pixel helpers.
#
# Shared by the CUDA backend self-test and runtime draw paths.

extern fn rt_ptr_read_i32(addr: i64, offset: i64) -> i32
extern fn rt_ptr_write_u8(addr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64)

val CUDA_FONT_ARG_COUNT: i64 = 15
val CUDA_FONT_ARG_BYTES: i64 = CUDA_FONT_ARG_COUNT * 8
# Private runtime PTX ABI: two pointer-valued u64 slots followed by thirteen
# s64 slots. Unsigned dimensions/color are zero-extended; destination offsets
# remain signed. The same pointer array is valid for compiler-emitted CUDA C:
# each bounded scalar's low 32 bits match its emitted u32/i32 parameter.

fn cuda_launch_args_read_i32(addr: i64, offset: i64) -> i32:
    rt_ptr_read_i32(addr, offset)

fn cuda_launch_args_write_u8(addr: i64, offset: i64, value: i64) -> i64:
    rt_ptr_write_u8(addr, offset, value)

fn cuda_launch_args_write_i64(addr: i64, offset: i64, value: i64):
    rt_ptr_write_i64(addr, offset, value)

fn _i64(v: i32) -> i64:
    v as i64

fn _i64_from_u32(v: u32) -> i64:
    v as i64

fn _read_u32_pixels_from_host(ptr: i64, count: i32) -> [u32]:
    var out: [u32] = [0u32; count]
    var idx = 0
    while idx < count:
        out[idx] = cuda_launch_args_read_i32(ptr, _i64(idx) * 4) as u32
        idx = idx + 1
    out

fn _write_clear_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, color: u32, width: i32, height: i32):
    cuda_launch_args_write_i64(val_ptr, 0, d_framebuffer)
    cuda_launch_args_write_i64(val_ptr, 8, _i64(width))
    cuda_launch_args_write_i64(val_ptr, 16, _i64(height))
    cuda_launch_args_write_i64(val_ptr, 24, _i64_from_u32(color))
    cuda_launch_args_write_i64(args_ptr, 0, val_ptr)
    cuda_launch_args_write_i64(args_ptr, 8, val_ptr + 8)
    cuda_launch_args_write_i64(args_ptr, 16, val_ptr + 16)
    cuda_launch_args_write_i64(args_ptr, 24, val_ptr + 24)

fn _write_rect_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, x: i32, y: i32, w: i32, h: i32, color: u32, stride: i32, surface_h: i32):
    cuda_launch_args_write_i64(val_ptr, 0, d_framebuffer)
    cuda_launch_args_write_i64(val_ptr, 8, _i64(x))
    cuda_launch_args_write_i64(val_ptr, 16, _i64(y))
    cuda_launch_args_write_i64(val_ptr, 24, _i64(w))
    cuda_launch_args_write_i64(val_ptr, 32, _i64(h))
    cuda_launch_args_write_i64(val_ptr, 40, _i64_from_u32(color))
    cuda_launch_args_write_i64(val_ptr, 48, _i64(stride))
    cuda_launch_args_write_i64(val_ptr, 56, _i64(surface_h))
    cuda_launch_args_write_i64(args_ptr, 0, val_ptr)
    cuda_launch_args_write_i64(args_ptr, 8, val_ptr + 8)
    cuda_launch_args_write_i64(args_ptr, 16, val_ptr + 16)
    cuda_launch_args_write_i64(args_ptr, 24, val_ptr + 24)
    cuda_launch_args_write_i64(args_ptr, 32, val_ptr + 32)
    cuda_launch_args_write_i64(args_ptr, 40, val_ptr + 40)
    cuda_launch_args_write_i64(args_ptr, 48, val_ptr + 48)
    cuda_launch_args_write_i64(args_ptr, 56, val_ptr + 56)

fn _write_image_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, d_pixels: i64, x: i32, y: i32, w: i32, h: i32, stride: i32, surface_h: i32):
    cuda_launch_args_write_i64(val_ptr, 0, d_framebuffer)
    cuda_launch_args_write_i64(val_ptr, 8, d_pixels)
    cuda_launch_args_write_i64(val_ptr, 16, _i64(x))
    cuda_launch_args_write_i64(val_ptr, 24, _i64(y))
    cuda_launch_args_write_i64(val_ptr, 32, _i64(w))
    cuda_launch_args_write_i64(val_ptr, 40, _i64(h))
    cuda_launch_args_write_i64(val_ptr, 48, _i64(stride))
    cuda_launch_args_write_i64(val_ptr, 56, _i64(surface_h))
    cuda_launch_args_write_i64(args_ptr, 0, val_ptr)
    cuda_launch_args_write_i64(args_ptr, 8, val_ptr + 8)
    cuda_launch_args_write_i64(args_ptr, 16, val_ptr + 16)
    cuda_launch_args_write_i64(args_ptr, 24, val_ptr + 24)
    cuda_launch_args_write_i64(args_ptr, 32, val_ptr + 32)
    cuda_launch_args_write_i64(args_ptr, 40, val_ptr + 40)
    cuda_launch_args_write_i64(args_ptr, 48, val_ptr + 48)
    cuda_launch_args_write_i64(args_ptr, 56, val_ptr + 56)

fn _write_gradient_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32, stride: i32, surface_h: i32):
    cuda_launch_args_write_i64(val_ptr, 0, d_framebuffer)
    cuda_launch_args_write_i64(val_ptr, 8, _i64(x))
    cuda_launch_args_write_i64(val_ptr, 16, _i64(y))
    cuda_launch_args_write_i64(val_ptr, 24, _i64(w))
    cuda_launch_args_write_i64(val_ptr, 32, _i64(h))
    cuda_launch_args_write_i64(val_ptr, 40, _i64_from_u32(top_color))
    cuda_launch_args_write_i64(val_ptr, 48, _i64_from_u32(bottom_color))
    cuda_launch_args_write_i64(val_ptr, 56, _i64(stride))
    cuda_launch_args_write_i64(val_ptr, 64, _i64(surface_h))
    cuda_launch_args_write_i64(args_ptr, 0, val_ptr)
    cuda_launch_args_write_i64(args_ptr, 8, val_ptr + 8)
    cuda_launch_args_write_i64(args_ptr, 16, val_ptr + 16)
    cuda_launch_args_write_i64(args_ptr, 24, val_ptr + 24)
    cuda_launch_args_write_i64(args_ptr, 32, val_ptr + 32)
    cuda_launch_args_write_i64(args_ptr, 40, val_ptr + 40)
    cuda_launch_args_write_i64(args_ptr, 48, val_ptr + 48)
    cuda_launch_args_write_i64(args_ptr, 56, val_ptr + 56)
    cuda_launch_args_write_i64(args_ptr, 64, val_ptr + 64)

fn _write_line_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32, stride: i32, surface_h: i32):
    cuda_launch_args_write_i64(val_ptr, 0, d_framebuffer)
    cuda_launch_args_write_i64(val_ptr, 8, _i64(x1))
    cuda_launch_args_write_i64(val_ptr, 16, _i64(y1))
    cuda_launch_args_write_i64(val_ptr, 24, _i64(x2))
    cuda_launch_args_write_i64(val_ptr, 32, _i64(y2))
    cuda_launch_args_write_i64(val_ptr, 40, _i64_from_u32(color))
    cuda_launch_args_write_i64(val_ptr, 48, _i64(thickness))
    cuda_launch_args_write_i64(val_ptr, 56, _i64(stride))
    cuda_launch_args_write_i64(val_ptr, 64, _i64(surface_h))
    cuda_launch_args_write_i64(args_ptr, 0, val_ptr)
    cuda_launch_args_write_i64(args_ptr, 8, val_ptr + 8)
    cuda_launch_args_write_i64(args_ptr, 16, val_ptr + 16)
    cuda_launch_args_write_i64(args_ptr, 24, val_ptr + 24)
    cuda_launch_args_write_i64(args_ptr, 32, val_ptr + 32)
    cuda_launch_args_write_i64(args_ptr, 40, val_ptr + 40)
    cuda_launch_args_write_i64(args_ptr, 48, val_ptr + 48)
    cuda_launch_args_write_i64(args_ptr, 56, val_ptr + 56)
    cuda_launch_args_write_i64(args_ptr, 64, val_ptr + 64)

fn _write_circle_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, cx: i32, cy: i32, r: i32, color: u32, stride: i32, surface_h: i32, filled: i32):
    cuda_launch_args_write_i64(val_ptr, 0, d_framebuffer)
    cuda_launch_args_write_i64(val_ptr, 8, _i64(cx))
    cuda_launch_args_write_i64(val_ptr, 16, _i64(cy))
    cuda_launch_args_write_i64(val_ptr, 24, _i64(r))
    cuda_launch_args_write_i64(val_ptr, 32, _i64_from_u32(color))
    cuda_launch_args_write_i64(val_ptr, 40, _i64(stride))
    cuda_launch_args_write_i64(val_ptr, 48, _i64(surface_h))
    cuda_launch_args_write_i64(val_ptr, 56, _i64(filled))
    cuda_launch_args_write_i64(args_ptr, 0, val_ptr)
    cuda_launch_args_write_i64(args_ptr, 8, val_ptr + 8)
    cuda_launch_args_write_i64(args_ptr, 16, val_ptr + 16)
    cuda_launch_args_write_i64(args_ptr, 24, val_ptr + 24)
    cuda_launch_args_write_i64(args_ptr, 32, val_ptr + 32)
    cuda_launch_args_write_i64(args_ptr, 40, val_ptr + 40)
    cuda_launch_args_write_i64(args_ptr, 48, val_ptr + 48)
    cuda_launch_args_write_i64(args_ptr, 56, val_ptr + 56)

fn _write_rounded_rect_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, stride: i32, surface_h: i32):
    cuda_launch_args_write_i64(val_ptr, 0, d_framebuffer)
    cuda_launch_args_write_i64(val_ptr, 8, _i64(x))
    cuda_launch_args_write_i64(val_ptr, 16, _i64(y))
    cuda_launch_args_write_i64(val_ptr, 24, _i64(w))
    cuda_launch_args_write_i64(val_ptr, 32, _i64(h))
    cuda_launch_args_write_i64(val_ptr, 40, _i64(radius))
    cuda_launch_args_write_i64(val_ptr, 48, _i64_from_u32(color))
    cuda_launch_args_write_i64(val_ptr, 56, _i64(stride))
    cuda_launch_args_write_i64(val_ptr, 64, _i64(surface_h))
    cuda_launch_args_write_i64(args_ptr, 0, val_ptr)
    cuda_launch_args_write_i64(args_ptr, 8, val_ptr + 8)
    cuda_launch_args_write_i64(args_ptr, 16, val_ptr + 16)
    cuda_launch_args_write_i64(args_ptr, 24, val_ptr + 24)
    cuda_launch_args_write_i64(args_ptr, 32, val_ptr + 32)
    cuda_launch_args_write_i64(args_ptr, 40, val_ptr + 40)
    cuda_launch_args_write_i64(args_ptr, 48, val_ptr + 48)
    cuda_launch_args_write_i64(args_ptr, 56, val_ptr + 56)
    cuda_launch_args_write_i64(args_ptr, 64, val_ptr + 64)

fn _write_font_atlas_composite_launch_args(
    val_ptr: i64, args_ptr: i64, d_atlas: i64, d_framebuffer: i64,
    atlas_width: u32, atlas_height: u32, atlas_count: u32,
    atlas_x: u32, atlas_y: u32, quad_width: u32, quad_height: u32,
    dst_width: u32, dst_height: u32, dst_count: u32,
    dst_x: i32, dst_y: i32, color: u32
):
    cuda_launch_args_write_i64(val_ptr, 0, d_atlas)
    cuda_launch_args_write_i64(val_ptr, 8, d_framebuffer)
    cuda_launch_args_write_i64(val_ptr, 16, _i64_from_u32(atlas_width))
    cuda_launch_args_write_i64(val_ptr, 24, _i64_from_u32(atlas_height))
    cuda_launch_args_write_i64(val_ptr, 32, _i64_from_u32(atlas_count))
    cuda_launch_args_write_i64(val_ptr, 40, _i64_from_u32(atlas_x))
    cuda_launch_args_write_i64(val_ptr, 48, _i64_from_u32(atlas_y))
    cuda_launch_args_write_i64(val_ptr, 56, _i64_from_u32(quad_width))
    cuda_launch_args_write_i64(val_ptr, 64, _i64_from_u32(quad_height))
    cuda_launch_args_write_i64(val_ptr, 72, _i64_from_u32(dst_width))
    cuda_launch_args_write_i64(val_ptr, 80, _i64_from_u32(dst_height))
    cuda_launch_args_write_i64(val_ptr, 88, _i64_from_u32(dst_count))
    cuda_launch_args_write_i64(val_ptr, 96, _i64(dst_x))
    cuda_launch_args_write_i64(val_ptr, 104, _i64(dst_y))
    cuda_launch_args_write_i64(val_ptr, 112, _i64_from_u32(color))
    var index: i64 = 0
    while index < CUDA_FONT_ARG_COUNT:
        val offset = index * 8
        cuda_launch_args_write_i64(args_ptr, offset, val_ptr + offset)
        index = index + 1

fn _write_u32_pixels_to_host(ptr: i64, pixels: [u32], count: i32):
    var idx = 0
    while idx < count:
        val pixel = pixels[idx] as i64
        val base = _i64(idx) * 4
        cuda_launch_args_write_u8(ptr, base, pixel & 0xFF)
        cuda_launch_args_write_u8(ptr, base + 1, (pixel >> 8) & 0xFF)
        cuda_launch_args_write_u8(ptr, base + 2, (pixel >> 16) & 0xFF)
        cuda_launch_args_write_u8(ptr, base + 3, (pixel >> 24) & 0xFF)
        idx = idx + 1
