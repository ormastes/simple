"""2D Engine — Clip Rect and Mask Region Helpers

Class-based clip rectangle with intersection, containment, and area queries.
No backend state or SFFI dependencies. Shared by all 2D engine backends.

Usage:
    use std.gpu.engine2d.helpers.clip_mask.ClipRect

@tag:stdlib
@tag:gpu
"""

# ============================================================================
# ClipRect
# ============================================================================

class ClipRect:
    """Axis-aligned clip rectangle. All coordinates are in pixels."""
    x: i64
    y: i64
    w: i64
    h: i64

    static fn create(x: i64, y: i64, w: i64, h: i64) -> ClipRect:
        """Construct a ClipRect from position and size."""
        ClipRect(x: x, y: y, w: w, h: h)

    static fn full_screen(width: i64, height: i64) -> ClipRect:
        """Construct a ClipRect covering the full framebuffer."""
        ClipRect(x: 0, y: 0, w: width, h: height)

    me intersect(other: ClipRect) -> ClipRect:
        """Return the intersection of this rect and other.

        If the rects are disjoint the returned rect will have w <= 0 or h <= 0.
        Check is_empty() on the result before use.
        """
        val ix1 = if self.x > other.x: self.x else: other.x
        val iy1 = if self.y > other.y: self.y else: other.y
        val ix2_a = self.x + self.w
        val ix2_b = other.x + other.w
        val ix2 = if ix2_a < ix2_b: ix2_a else: ix2_b
        val iy2_a = self.y + self.h
        val iy2_b = other.y + other.h
        val iy2 = if iy2_a < iy2_b: iy2_a else: iy2_b
        ClipRect(x: ix1, y: iy1, w: ix2 - ix1, h: iy2 - iy1)

    me contains_point(px: i64, py: i64) -> bool:
        """Return true if (px, py) lies strictly inside this clip rect."""
        px >= self.x and px < self.x + self.w and py >= self.y and py < self.y + self.h

    me is_empty() -> bool:
        """Return true if the rect has zero or negative area."""
        self.w <= 0 or self.h <= 0

    me area() -> i64:
        """Return the pixel area. Returns 0 for empty rects."""
        if self.w <= 0 or self.h <= 0:
            return 0
        self.w * self.h

    me info() -> text:
        """Return a human-readable description of this rect."""
        "ClipRect(x=" + self.x.to_text() + " y=" + self.y.to_text() + " w=" + self.w.to_text() + " h=" + self.h.to_text() + " area=" + self.area().to_text() + ")"
