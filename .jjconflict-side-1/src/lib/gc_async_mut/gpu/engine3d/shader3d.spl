"""3D Engine — Shader and Pipeline Types

@tag:stdlib
@tag:api
@tag:gpu

Defines shader module, vertex buffer layout, and render pipeline descriptor
types mirroring the Chrome WebGPU shader pipeline API.

Usage:
    use std.gpu.engine3d.shader3d.{ShaderModule3D, RenderPipelineDescriptor3D}
"""

use std.gpu.engine3d.texture3d.{TEX_FMT_RGBA8_UNORM, TEX_FMT_DEPTH32_FLOAT}

# ============================================================================
# Shader Stage Constants
# ============================================================================

val SHADER_STAGE_VERTEX: i32 = 0
val SHADER_STAGE_FRAGMENT: i32 = 1
val SHADER_STAGE_COMPUTE: i32 = 2

# ============================================================================
# Primitive Topology Constants
# ============================================================================

val TOPOLOGY_TRIANGLE_LIST: i32 = 0
val TOPOLOGY_TRIANGLE_STRIP: i32 = 1
val TOPOLOGY_LINE_LIST: i32 = 2
val TOPOLOGY_LINE_STRIP: i32 = 3
val TOPOLOGY_POINT_LIST: i32 = 4

# ============================================================================
# Vertex Format Constants
# ============================================================================

val VERT_FMT_FLOAT32: i32 = 0
val VERT_FMT_FLOAT32X2: i32 = 1
val VERT_FMT_FLOAT32X3: i32 = 2
val VERT_FMT_FLOAT32X4: i32 = 3
val VERT_FMT_UINT32: i32 = 10
val VERT_FMT_SINT32: i32 = 11
val VERT_FMT_UINT8X4: i32 = 20
val VERT_FMT_UNORM8X4: i32 = 21

val STEP_MODE_VERTEX: i32 = 0
val STEP_MODE_INSTANCE: i32 = 1

# ============================================================================
# Shader Module
# ============================================================================

class ShaderModule3D:
    id: i32
    stage: i32
    source: text
    entry_point: text

    static fn create_vertex(source: text) -> ShaderModule3D:
        ShaderModule3D(id: -1, stage: SHADER_STAGE_VERTEX, source: source, entry_point: "vs_main")

    static fn create_fragment(source: text) -> ShaderModule3D:
        ShaderModule3D(id: -1, stage: SHADER_STAGE_FRAGMENT, source: source, entry_point: "fs_main")

    static fn create_compute(source: text) -> ShaderModule3D:
        ShaderModule3D(id: -1, stage: SHADER_STAGE_COMPUTE, source: source, entry_point: "cs_main")

    static fn create(stage: i32, source: text, entry_point: text) -> ShaderModule3D:
        ShaderModule3D(id: -1, stage: stage, source: source, entry_point: entry_point)

# ============================================================================
# Vertex Attribute / Layout
# ============================================================================

class VertexAttribute3D:
    format: i32
    offset: i32
    shader_location: i32

    static fn create(format: i32, offset: i32, location: i32) -> VertexAttribute3D:
        VertexAttribute3D(format: format, offset: offset, shader_location: location)

class VertexBufferLayout3D:
    array_stride: i32
    step_mode: i32
    attributes: [VertexAttribute3D]

    static fn create(stride: i32, attrs: [VertexAttribute3D]) -> VertexBufferLayout3D:
        VertexBufferLayout3D(array_stride: stride, step_mode: STEP_MODE_VERTEX, attributes: attrs)

    static fn create_instanced(stride: i32, attrs: [VertexAttribute3D]) -> VertexBufferLayout3D:
        VertexBufferLayout3D(array_stride: stride, step_mode: STEP_MODE_INSTANCE, attributes: attrs)

fn vertex_format_size(format: i32) -> i32:
    if format == VERT_FMT_FLOAT32:
        4
    else if format == VERT_FMT_FLOAT32X2:
        8
    else if format == VERT_FMT_FLOAT32X3:
        12
    else if format == VERT_FMT_FLOAT32X4:
        16
    else if format == VERT_FMT_UINT32 or format == VERT_FMT_SINT32:
        4
    else if format == VERT_FMT_UINT8X4 or format == VERT_FMT_UNORM8X4:
        4
    else:
        4

# ============================================================================
# Render Pipeline Descriptor
# ============================================================================

class RenderPipelineDescriptor3D:
    vertex_shader: ShaderModule3D
    fragment_shader: ShaderModule3D
    vertex_buffers: [VertexBufferLayout3D]
    primitive_topology: i32
    depth_stencil_format: i32
    color_target_format: i32
    blend_mode: i32
    cull_mode: i32
    multi_sample_count: i32

    static fn create(vs: ShaderModule3D, fs: ShaderModule3D) -> RenderPipelineDescriptor3D:
        RenderPipelineDescriptor3D(
            vertex_shader: vs, fragment_shader: fs,
            vertex_buffers: [],
            primitive_topology: TOPOLOGY_TRIANGLE_LIST,
            depth_stencil_format: TEX_FMT_DEPTH32_FLOAT,
            color_target_format: TEX_FMT_RGBA8_UNORM,
            blend_mode: 0, cull_mode: 1, multi_sample_count: 1
        )

# ============================================================================
# Compute Pipeline Descriptor
# ============================================================================

class ComputePipelineDescriptor3D:
    compute_shader: ShaderModule3D
    workgroup_size_x: i32
    workgroup_size_y: i32
    workgroup_size_z: i32

    static fn create(cs: ShaderModule3D) -> ComputePipelineDescriptor3D:
        ComputePipelineDescriptor3D(
            compute_shader: cs,
            workgroup_size_x: 64, workgroup_size_y: 1, workgroup_size_z: 1
        )
