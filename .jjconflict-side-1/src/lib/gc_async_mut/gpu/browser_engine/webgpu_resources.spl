"""Browser WebGPU resource MVP for integrated JS/WASM browser specs."""

pub val WEBGPU_BUFFER_USAGE_COPY_DST = 8
pub val WEBGPU_BUFFER_USAGE_COPY_SRC = 4
pub val WEBGPU_BUFFER_USAGE_UNIFORM = 16
pub val WEBGPU_BUFFER_USAGE_INDEX = 32
pub val WEBGPU_BUFFER_USAGE_VERTEX = 64
pub val WEBGPU_BUFFER_USAGE_INDIRECT = 128
pub val WEBGPU_TEXTURE_USAGE_TEXTURE_BINDING = 1
pub val WEBGPU_TEXTURE_USAGE_COPY_DST = 2
pub val WEBGPU_TEXTURE_USAGE_COPY_SRC = 4
pub val WEBGPU_TEXTURE_USAGE_RENDER_ATTACHMENT = 8
pub val WEBGPU_SHADER_STAGE_VERTEX = 1
pub val WEBGPU_SHADER_STAGE_FRAGMENT = 2
pub val WEBGPU_SHADER_STAGE_COMPUTE = 4
pub val WEBGPU_BINDING_TYPE_UNIFORM_BUFFER = "uniform-buffer"
pub val WEBGPU_BINDING_TYPE_TEXTURE = "texture"
pub val WEBGPU_BINDING_TYPE_SAMPLER = "sampler"

pub class GPUBufferHandle:
    id: i32
    label: text
    size: i64
    usage: i64

pub class WebGPUResourceTable:
    next_buffer_id: i32
    buffers: [GPUBufferHandle]

    static fn create() -> WebGPUResourceTable:
        WebGPUResourceTable(next_buffer_id: 1, buffers: [])

    me create_buffer(label: text, size: i64, usage: i64) -> GPUBufferHandle:
        val handle = GPUBufferHandle(id: self.next_buffer_id, label: label, size: size, usage: usage)
        self.next_buffer_id = self.next_buffer_id + 1
        self.buffers.push(handle)
        handle

    me buffer_exists(id: i32) -> bool:
        for buffer in self.buffers:
            if buffer.id == id:
                return true
        false

pub class GPUTextureHandle:
    id: i32
    label: text

pub class GPUSamplerHandle:
    id: i32
    label: text

pub class GPUBindGroupLayoutEntry:
    binding: i32

pub class GPUBindGroupEntry:
    binding: i32

pub class GPUBindGroupLayoutHandle:
    id: i32

pub class GPUBindGroupHandle:
    id: i32

pub fn webgpu_validate_buffer_descriptor(size: i64, usage: i64) -> bool:
    size >= 0

pub fn webgpu_validate_texture_descriptor(width: i32, height: i32, usage: i64) -> bool:
    width >= 0 and height >= 0

pub fn webgpu_validate_sampler_descriptor(label: text) -> bool:
    true

pub fn webgpu_validate_bind_group_layout_descriptor(entries: [GPUBindGroupLayoutEntry]) -> bool:
    true

pub fn webgpu_find_buffer(table: WebGPUResourceTable, id: i32) -> GPUBufferHandle?:
    for buffer in table.buffers:
        if buffer.id == id:
            return Some(buffer)
    nil

pub fn webgpu_find_texture(table: WebGPUResourceTable, id: i32) -> GPUTextureHandle?:
    nil

pub fn webgpu_find_bind_group(table: WebGPUResourceTable, id: i32) -> GPUBindGroupHandle?:
    nil

pub fn webgpu_find_bind_group_entry(entries: [GPUBindGroupEntry], binding: i32) -> GPUBindGroupEntry?:
    for entry in entries:
        if entry.binding == binding:
            return Some(entry)
    nil

pub fn webgpu_count_dynamic_bind_group_layout_entries(entries: [GPUBindGroupLayoutEntry]) -> i32:
    0

pub fn webgpu_validate_bind_group_buffer_range(buffer: GPUBufferHandle, offset: i64, size: i64) -> bool:
    offset >= 0 and size >= 0 and offset + size <= buffer.size

export GPUTextureHandle
export GPUSamplerHandle
export GPUBindGroupLayoutEntry
export GPUBindGroupEntry
export GPUBindGroupLayoutHandle
export GPUBindGroupHandle
export WEBGPU_BUFFER_USAGE_COPY_DST
export WEBGPU_BUFFER_USAGE_COPY_SRC
export WEBGPU_BUFFER_USAGE_UNIFORM
export WEBGPU_BUFFER_USAGE_INDEX
export WEBGPU_BUFFER_USAGE_VERTEX
