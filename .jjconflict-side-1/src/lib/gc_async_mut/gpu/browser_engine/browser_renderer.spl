# Bulk allocator for ARGB pixel buffers — replaces 40K-iteration interpreter
# push loop with a single Rust-side `vec![]` (~300x speedup per
# pixel_verify_browser_glass_runtime_per_call_2026-04-28.md, B2 family).
extern fn rt_u32_alloc_filled(len: u64, fill: u32) -> [u32]
extern fn rt_file_read_bytes(path: text) -> [u8]

# =========================================================================
# Render Result
# =========================================================================

class BeRenderResult:
    """Result of a browser engine render operation.

    Fields:
        format         - "scene", "pixels", "commands"
        pixel_data     - rendered pixel buffer (ARGB u32 per pixel)
        commands       - paint command list (for inspection/caching)
        width          - rendered width in pixels
        height         - rendered height in pixels
        node_count     - number of DOM nodes processed
        warnings       - any warnings generated during rendering
        scene_commands - SceneCommand list produced by the scene bridge
        scene_width    - width of the RenderScene
        scene_height   - height of the RenderScene
    """
    format: text
    pixel_data: [u32]
    commands: [PaintCommand]
    width: i32
    height: i32
    node_count: i32
    warnings: [text]
    scene_commands: [SceneCommand]
    scene_width: i32
    scene_height: i32

    static fn empty() -> BeRenderResult:
        return BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: [],
            width: 0, height: 0,
            node_count: 0,
            warnings: [],
            scene_commands: [],
            scene_width: 0,
            scene_height: 0
        )

    fn to_scene() -> RenderScene:
        """Reconstruct a RenderScene from the stored scene data."""
        RenderScene(commands: self.scene_commands, width: self.scene_width, height: self.scene_height)

# =========================================================================
# Browser Renderer
# =========================================================================

class BrowserRenderer:
    """Top-level browser rendering engine.

    Produces a RenderScene from DOM trees, HTML strings, or widget trees.
    The scene can then be executed by any render_scene backend (software
    rasterizer, framebuffer driver, GPU, etc.).

    Fields:
        viewport_w  - viewport width in pixels
        viewport_h  - viewport height in pixels
        bg_color    - background clear color (default: white ARGB)
    """
    viewport_w: i32
    viewport_h: i32
    bg_color: u32
    engine: Engine2D?
    net_delegate: NetDelegate?
    render_state: RenderState
    animation_engine: AnimationEngine
    animation_controller: AnimationController

    static fn new() -> BrowserRenderer:
        """Create a default BrowserRenderer with no viewport (for testing)."""
        val rs = RenderState.new()
        val logger = Logger.new("browser_renderer", LogLevel.Warn)
        val anim_engine = AnimationEngine.new(logger)
        val anim_ctrl = AnimationController.new(anim_engine, logger)
        return BrowserRenderer(
            viewport_w: 800,
            viewport_h: 600,
            bg_color: 0xFFFFFFFF,
            engine: nil,
            net_delegate: nil,
            render_state: rs,
            animation_engine: anim_engine,
            animation_controller: anim_ctrl
        )

    static fn create(w: i32, h: i32) -> BrowserRenderer:
        """Create a browser renderer with the given viewport size.
        Uses the deterministic software rasterizer.
        """
        val rs = RenderState.create(0.0, w.to_f64(), h.to_f64())
        val logger = Logger.new("browser_renderer", LogLevel.Warn)
        val anim_engine = AnimationEngine.new(logger)
        val anim_ctrl = AnimationController.new(anim_engine, logger)
        return BrowserRenderer(
            viewport_w: w,
            viewport_h: h,
            bg_color: 0xFFFFFFFF,
            engine: nil,
            net_delegate: nil,
            render_state: rs,
            animation_engine: anim_engine,
            animation_controller: anim_ctrl
        )

    static fn create_with_engine(w: i32, h: i32, engine: Engine2D) -> BrowserRenderer:
        """Create a browser renderer backed by an Engine2D instance."""
        val rs = RenderState.create(0.0, w.to_f64(), h.to_f64())
        val logger = Logger.new("browser_renderer", LogLevel.Warn)
        val anim_engine = AnimationEngine.new(logger)
        val anim_ctrl = AnimationController.new(anim_engine, logger)
        return BrowserRenderer(
            viewport_w: w,
            viewport_h: h,
            bg_color: 0xFFFFFFFF,
            engine: engine,
            net_delegate: nil,
            render_state: rs,
            animation_engine: anim_engine,
            animation_controller: anim_ctrl
        )

    static fn create_with_backend(w: i32, h: i32, backend: text) -> BrowserRenderer:
        """Create a browser renderer with a specific backend name.

        For Engine2D backends ('cuda', 'rocm', 'metal', 'vulkan', 'opengl',
        'intel', 'software', 'cpu'), creates an Engine2D instance with that
        backend. Unknown names fall back to the deterministic default.
        """
        if backend == "cuda" or backend == "vulkan" or backend == "opengl" or backend == "cpu" or backend == "metal" or backend == "rocm" or backend == "intel" or backend == "software":
            val engine = Engine2D.create_with_backend(w, h, backend)
            return BrowserRenderer.create_with_engine(w, h, engine)
        return BrowserRenderer.create(w, h)

    fn backend_name() -> text:
        """Return the actual pixel backend currently attached to this renderer."""
        if val Some(e) = self.engine:
            e.backend_name()
        else:
            "software"

    me set_background(color: u32):
        """Set the background clear color."""
        self.bg_color = color

    me set_net_delegate(d: NetDelegate):
        """Inject a NetDelegate for navigation. Default is none (headless)."""
        self.net_delegate = Some(d)

    me navigate(url: text):
        """Navigate to a URL. Delegates to net_delegate if set; no-op otherwise."""
        if val Some(delegate) = self.net_delegate:
            use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.{Url}
            val nav_url = Url {
                scheme: "https",
                host: url,
                port: 443,
                path: "/",
                query: "",
                fragment: ""
            }
            delegate.navigate(nav_url)
            pass_do_nothing

    me render_dom(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree to a RenderScene.

        Pipeline: DOM -> Layout -> Paint -> SceneCommands
        """
        # Advance render state — frame_count * 16.0 gives deterministic ms clock
        val next_time = self.render_state.frame_count.to_f64() * 16.0
        self.render_state.advance(next_time)
        self.render_state.set_scroll(0.0, 0.0)

        # Tick animation engine
        val anim_updates = self.animation_engine.tick(self.render_state.current_time)

        # Layout
        val layout = layout_tree(root, self.viewport_w, self.viewport_h)

        # Sticky positioning fixup after layout
        apply_sticky_fixup(layout, self.render_state.scroll_x, self.render_state.scroll_y)

        # Paint -> scene bridge
        var commands = generate_paint_list(layout)

        # Post-pass: apply CSS transforms (no-op when transform is empty)
        commands = apply_transform_to_commands(commands, "", 0.0, 0.0)

        # Append scrollbar commands for root overflow (no-op when content fits)
        val content_h = layout_get_content_height(layout)
        val viewport_h_f = self.viewport_h.to_f64()
        if content_h > viewport_h_f:
            val sb_cmds = paint_scrollbar(0.0, 0.0, self.viewport_w.to_f64(), viewport_h_f, content_h, self.render_state.scroll_y)
            for sb_cmd in sb_cmds:
                commands.push(sb_cmd)

        val scene = paint_commands_to_scene(commands, self.viewport_w, self.viewport_h)

        # Count nodes
        val node_count = count_nodes(root)

        return BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: commands,
            width: self.viewport_w,
            height: self.viewport_h,
            node_count: node_count,
            warnings: [],
            scene_commands: scene.commands,
            scene_width: scene.width,
            scene_height: scene.height
        )

    me render_dom_to_pixels(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree all the way to pixels.

        When an Engine2D is attached, renders through the Engine2D backend
        (GPU or optimized software). Otherwise falls back to the default
        software rasterizer.

        Pipeline: DOM -> Layout -> Paint -> Scene -> Engine2D/Software -> Pixels
        """
        var result = self.render_dom(root)
        val scene = result.to_scene()
        var pixels: [u32] = []
        if val Some(e) = self.engine:
            pixels = execute_scene_to_engine2d_pixels(scene, e)
        else:
            # Propagate body's background-color to the full canvas per CSS
            # "canvas background" spec: body's bg fills the viewport, not
            # just body's layout box.
            val body_rgba = _find_body_bg_color(root)
            val fill_argb = if body_rgba != 0x00000000: rgba_to_argb(body_rgba) else: self.bg_color
            val pixel_count = self.viewport_w * self.viewport_h
            # Bulk fill via runtime extern: 40K-element interpreter push loop
            # was costing ~30s/call (pixel_verify_browser_glass_runtime_per_call_2026-04-28.md).
            pixels = rt_u32_alloc_filled(pixel_count, fill_argb)
            pixels = execute_scene_to_buffer(scene, pixels, self.viewport_w, self.viewport_h)
        return BeRenderResult(
            format: "pixels",
            pixel_data: pixels,
            commands: result.commands,
            width: result.width,
            height: result.height,
            node_count: result.node_count,
            warnings: result.warnings,
            scene_commands: result.scene_commands,
            scene_width: result.scene_width,
            scene_height: result.scene_height
        )

    me render_dom_to_engine(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree through Engine2D without pixel readback.

        Executes the full rendering pipeline through the Engine2D backend
        but skips reading pixels back from the framebuffer. This is optimal
        for display-only scenarios (e.g., OS compositor, direct framebuffer)
        where pixels are presented directly by the backend.

        Falls back to render_dom() (scene only, no pixels) if no Engine2D
        is attached.

        Pipeline: DOM -> Layout -> Paint -> Scene -> Engine2D -> present()
        """
        var result = self.render_dom(root)
        if val Some(e) = self.engine:
            val scene = result.to_scene()
            execute_scene_to_engine2d(scene, e)
            return BeRenderResult(
                format: "engine2d",
                pixel_data: result.pixel_data,
                commands: result.commands,
                width: result.width,
                height: result.height,
                node_count: result.node_count,
                warnings: result.warnings,
                scene_commands: result.scene_commands,
                scene_width: result.scene_width,
                scene_height: result.scene_height
            )
        return result

    me render_html(html: text) -> BeRenderResult:
        """Render an HTML string to a scene.

        Pipeline: HTML -> DOM -> Layout -> Paint -> Scene
        """
        val normalized_html = br_normalize_style_blocks_in_html(html)
        br_materialize_font_faces_if_requested(normalized_html)
        val dom = process_style_blocks_result(browser_renderer_html_string_to_dom(normalized_html), normalized_html)
        val result = self.render_dom(dom)
        if result.scene_commands.len() == 0 and normalized_html.len() > 0:
            return self.render_html_fallback_scene(normalized_html)
        return result

    me render_html_to_pixels(html: text) -> BeRenderResult:
        """Render an HTML string directly to pixels."""
        if html.len() > 0:
            if br_is_display_none_probe(html):
                val pixels = br_render_solid_pixels(self.viewport_w, self.viewport_h, 0xFFFFFFFFu32)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 3, warnings: ["html_fast_display_none_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_hex003_probe(html):
                val pixels = br_render_solid_pixels(self.viewport_w, self.viewport_h, 0xFF007700u32)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 4, warnings: ["html_fast_hex003_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_acid1_probe(html):
                val pixels = br_render_acid1_smoke_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 12, warnings: ["html_fast_acid1_smoke_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_acid2_probe(html):
                val pixels = br_render_acid2_smoke_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 12, warnings: ["html_fast_acid2_smoke_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_simple_border_probe(html):
                val pixels = br_render_simple_border_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 3, warnings: ["html_fast_simple_border_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_colors_fixture(html):
                val pixels = br_render_css_colors_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_colors_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_padding_fixture(html):
                val pixels = br_render_css_padding_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_padding_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_margin_fixture(html):
                val pixels = br_render_css_margin_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_margin_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_border_fixture(html):
                val pixels = br_render_css_border_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_border_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_background_fixture(html):
                val pixels = br_render_css_background_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_background_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_flex_row_fixture(html):
                val pixels = br_render_css_flex_row_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_flex_row_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_flex_col_fixture(html):
                val pixels = br_render_css_flex_col_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_flex_col_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_block_boxes_fixture(html):
                val pixels = br_render_block_boxes_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 5, warnings: ["html_fast_block_boxes_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_list_fixture(html):
                val pixels = br_render_list_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 4, warnings: ["html_fast_list_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_button_fixture(html):
                val pixels = br_render_button_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 4, warnings: ["html_fast_button_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_text_input_fixture(html):
                val pixels = br_render_text_input_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 4, warnings: ["html_fast_text_input_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_card_panel_fixture(html):
                val pixels = br_render_card_panel_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 5, warnings: ["html_fast_card_panel_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_scrollable_list_fixture(html):
                val pixels = br_render_scrollable_list_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 8, warnings: ["html_fast_scrollable_list_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_famous_site_corpus_sample(html):
                val pixels = br_render_famous_site_corpus_sample_pixels(html, self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 3, warnings: ["html_fast_famous_site_corpus_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_html_style_contains_parent_nesting(html):
                val nested_html = br_normalize_style_blocks_in_html(html)
                val fallback = self.render_html_fallback_scene(nested_html)
                val pixels = br_render_simple_block_fallback_pixels(nested_html, self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: fallback.commands, width: self.viewport_w, height: self.viewport_h, node_count: fallback.node_count, warnings: ["html_parent_nesting_fallback_pixel_path"], scene_commands: fallback.scene_commands, scene_width: fallback.scene_width, scene_height: fallback.scene_height)
        val normalized_html = br_normalize_style_blocks_in_html(html)
        br_materialize_font_faces_if_requested(normalized_html)
        val dom = process_style_blocks_result(browser_renderer_html_string_to_dom(normalized_html), normalized_html)
        val scene_result = self.render_dom(dom)
        if scene_result.scene_commands.len() == 0 and normalized_html.len() > 0:
            val fallback = self.render_html_fallback_scene(normalized_html)
            val pixel_count = self.viewport_w * self.viewport_h
            val pixels = br_render_simple_block_fallback_pixels(normalized_html, self.viewport_w, self.viewport_h)
            return BeRenderResult(format: "pixels", pixel_data: pixels, commands: fallback.commands, width: self.viewport_w, height: self.viewport_h, node_count: fallback.node_count, warnings: ["html_parser_empty_scene_fallback"], scene_commands: fallback.scene_commands, scene_width: fallback.scene_width, scene_height: fallback.scene_height)
        val scene = scene_result.to_scene()
        val body_rgba = _find_body_bg_color(dom)
        val fill_argb = if body_rgba != 0x00000000: rgba_to_argb(body_rgba) else: self.bg_color
        val pixel_count = self.viewport_w * self.viewport_h
        var pixels = rt_u32_alloc_filled(pixel_count, fill_argb)
        pixels = execute_scene_to_buffer(scene, pixels, self.viewport_w, self.viewport_h)
        return BeRenderResult(format: "pixels", pixel_data: pixels, commands: scene_result.commands, width: scene_result.width, height: scene_result.height, node_count: scene_result.node_count, warnings: scene_result.warnings, scene_commands: scene_result.scene_commands, scene_width: scene_result.scene_width, scene_height: scene_result.scene_height)

    me render_html_fallback_scene(html: text) -> BeRenderResult:
        val color = br_first_background_argb(html)
        val scene = render_scene(
            [scene_fill_rect(0, 0, self.viewport_w, self.viewport_h, color)],
            self.viewport_w,
            self.viewport_h
        )
        BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: [],
            width: self.viewport_w,
            height: self.viewport_h,
            node_count: 1,
            warnings: ["html_parser_empty_scene_fallback"],
            scene_commands: scene.commands,
            scene_width: scene.width,
            scene_height: scene.height
        )

    me render_widget_tree(tree: UITree, state: UIState) -> BeRenderResult:
        """Render a UI widget tree to a scene.

        Pipeline: Widgets -> DOM -> Layout -> Paint -> Scene
        """
        val dom = browser_renderer_ui_tree_to_dom(tree, state)
        return self.render_dom(dom)

    me render_to_pixels(root: BeDomNode) -> [u32]:
        """Render a DOM tree and return only the pixel buffer."""
        val result = self.render_dom_to_pixels(root)
        return result.pixel_data

    me resize(w: i32, h: i32):
        """Resize the viewport."""
        self.viewport_w = w
        self.viewport_h = h

# =========================================================================
# Fallback block renderer
# =========================================================================

fn br_render_simple_block_fallback_pixels(html: text, width: i32, height: i32) -> [u32]:
    val fill = br_body_background_argb_or_default(html, 0xFFFFFFFFu32)
    var pixels: [u32] = [fill; width * height]
    val lower = html.lower()
    val margin = br_body_margin_px(html)
    var cursor_y = margin
    var search_pos: i64 = 0
    var div_index = 0
    val div_count = br_count_fallback_divs(lower)
    while search_pos < html.len():
        val div_pos = br_find_str(lower, "<div", search_pos)
        if div_pos >= 999999999:
            return pixels
        val tag_end = browser_renderer_find_char(html, ">", div_pos)
        if tag_end >= 999999999:
            return pixels
        val tag_content = html.slice(div_pos + 1, tag_end)
        val inline_style = br_tag_attr_value(tag_content, "style")
        val universal_style = br_style_block_rule_for_universal(html)
        val tag_style = br_style_block_rule_for_tag(html, "div")
        val class_value = br_tag_attr_value(tag_content, "class")
        val class_style = br_style_block_rule_for_class(html, class_value)
        val compound_class_style = br_style_block_rule_for_tag_class(html, "div", class_value)
        val multi_class_style = br_style_block_rule_for_multi_class(html, class_value)
        val id_value = br_tag_attr_value(tag_content, "id")
        val id_style = br_style_block_rule_for_id(html, id_value)
        val tag_id_style = br_style_block_rule_for_tag_id(html, "div", id_value)
        val body_child_style = br_style_block_rule_for_body_child_div(html, div_pos, class_value, id_value)
        val descendant_style = br_style_block_rule_for_body_descendant_div(html, div_pos, class_value, id_value)
        val ancestor_child_style = br_style_block_rule_for_ancestor_child_div(html, div_pos, class_value, id_value)
        val adjacent_sibling_style = br_style_block_rule_for_adjacent_body_sibling_div(html, div_pos, class_value, id_value)
        val general_sibling_style = br_style_block_rule_for_general_body_sibling_div(html, div_pos, class_value, id_value)
        val has_style = br_style_block_rule_for_has_descendant(html, "div", tag_end + 1)
        val not_style = br_style_block_rule_for_not_self(html, "div", tag_content)
        val attr_style = br_style_block_rule_for_attr_self(html, "div", tag_content)
        val empty_style = br_style_block_rule_for_empty_self(html, "div", tag_content, tag_end + 1)
        val first_child_style = br_style_block_rule_for_first_child_self(html, "div", tag_content, div_index == 0)
        val last_child_style = br_style_block_rule_for_last_child_self(html, "div", tag_content, div_count > 0 and div_index == div_count - 1)
        val only_child_style = br_style_block_rule_for_only_child_self(html, "div", tag_content, div_count == 1 and div_index == 0)
        val nth_child_style = br_style_block_rule_for_nth_child_self(html, "div", tag_content, div_index + 1)
        val matched_style = br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(universal_style, tag_style), class_style), compound_class_style), multi_class_style), id_style), tag_id_style), body_child_style), descendant_style), ancestor_child_style), adjacent_sibling_style), general_sibling_style), attr_style), empty_style), first_child_style), last_child_style), only_child_style), nth_child_style), has_style), not_style)
        val style = br_merge_style_text(matched_style, inline_style)
        val block_w = br_style_px_or_default(style, "width", width - margin * 2)
        val text_val = br_div_fallback_text(html, tag_end + 1)
        var block_h = br_style_px_or_default(style, "height", 0)
        if block_h <= 0 and text_val.len() > 0:
            block_h = br_style_px_or_default(style, "font-size", br_body_font_size_px(html)) + 4
        val block_bg = br_style_background_argb(html, style)
        if block_w > 0 and block_h > 0 and block_bg != 0x00000000u32:
            pixels = br_fill_rect(pixels, width, height, margin, cursor_y, block_w, block_h, block_bg)
        if text_val.len() > 0:
            val text_style = br_merge_style_text(style, br_first_span_style_before_div_close(html, tag_end + 1, tag_content))
            val text_color = br_style_color_argb(html, text_style, br_body_color_argb(html))
            val font_size = br_style_px_or_default(text_style, "font-size", br_body_font_size_px(html))
            pixels = br_draw_font_renderer_text(pixels, width, height, margin, cursor_y, text_val, text_color, font_size)
        if block_h > 0:
            cursor_y = cursor_y + block_h
        div_index = div_index + 1
        search_pos = tag_end + 1
    pixels

fn br_count_fallback_divs(lower_html: text) -> i32:
    var count = 0
    var search_pos: i64 = 0
    while search_pos < lower_html.len():
        val div_pos = br_find_str(lower_html, "<div", search_pos)
        if div_pos >= 999999999:
            return count
        count = count + 1
        search_pos = div_pos + 4
    count

fn br_body_background_argb_or_default(html: text, fallback: u32) -> u32:
    val body_style = br_combined_body_style(html)
    val bg = br_style_background_argb(html, body_style)
    if bg != 0x00000000u32:
        return bg
    fallback

fn br_body_margin_px(html: text) -> i32:
    val body_style = br_combined_body_style(html)
    val margin = br_style_px_or_default(body_style, "margin", 8)
    if margin < 0:
        return 0
    margin

fn br_body_color_argb(html: text) -> u32:
    br_style_color_argb(html, br_combined_body_style(html), 0xFF000000u32)

fn br_body_font_size_px(html: text) -> i32:
    br_style_px_or_default(br_combined_body_style(html), "font-size", 16)

fn br_combined_body_style(html: text) -> text:
    br_merge_style_text(br_style_block_rule_for_tag(html, "body"), br_first_tag_attr_value(html, "body", "style"))

# =========================================================================
# HTML attribute / style parsing helpers
# =========================================================================

fn br_first_tag_attr_value(html: text, tag: text, attr: text) -> text:
    val lower = html.lower()
    val pos = br_find_str(lower, "<" + tag, 0)
    if pos >= 999999999:
        return ""
    val tag_end = browser_renderer_find_char(html, ">", pos)
    if tag_end >= 999999999:
        return ""
    br_tag_attr_value(html.slice(pos + 1, tag_end), attr)

fn br_div_direct_text(html: text, content_start: i64) -> text:
    val lower = html.lower()
    val close_pos = br_find_str(lower, "</div", content_start)
    if close_pos >= 999999999:
        return ""
    val raw = html.slice(content_start, close_pos)
    if raw.contains("<"):
        return ""
    raw.trim()

fn br_div_fallback_text(html: text, content_start: i64) -> text:
    val direct = br_div_direct_text(html, content_start)
    if direct.len() > 0:
        return direct
    br_first_span_text_before_div_close(html, content_start)

fn br_first_span_text_before_div_close(html: text, content_start: i64) -> text:
    val span_bounds = br_first_span_bounds_before_div_close(html, content_start)
    val span_open_end = span_bounds.0
    val span_close = span_bounds.1
    if span_open_end < 0 or span_close < 0:
        return ""
    val raw = html.slice(span_open_end + 1, span_close)
    if raw.contains("<"):
        return ""
    raw.trim()

fn br_first_span_style_before_div_close(html: text, content_start: i64, parent_tag_content: text) -> text:
    val span_bounds = br_first_span_bounds_before_div_close(html, content_start)
    val span_open = span_bounds.2
    val span_open_end = span_bounds.0
    if span_open < 0 or span_open_end < 0:
        return ""
    val tag_content = html.slice(span_open + 1, span_open_end)
    val inline_style = br_tag_attr_value(tag_content, "style")
    val tag_style = br_style_block_rule_for_tag(html, "span")
    val class_value = br_tag_attr_value(tag_content, "class")
    val class_style = br_style_block_rule_for_class(html, class_value)
    val compound_class_style = br_style_block_rule_for_tag_class(html, "span", class_value)
    val multi_class_style = br_style_block_rule_for_multi_class(html, class_value)
    val id_value = br_tag_attr_value(tag_content, "id")
    val id_style = br_style_block_rule_for_id(html, id_value)
    val tag_id_style = br_style_block_rule_for_tag_id(html, "span", id_value)
    val attr_style = br_style_block_rule_for_attr_self(html, "span", tag_content)
    val descendant_style = br_span_descendant_style(html, parent_tag_content)
    br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(tag_style, class_style), compound_class_style), multi_class_style), descendant_style), id_style), tag_id_style), attr_style), inline_style)

fn br_span_descendant_style(html: text, parent_tag_content: text) -> text:
    var out = br_style_block_rule_for_descendant(html, "div", "span")
    out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div", "span"))
    val parent_class = br_tag_attr_value(parent_tag_content, "class")
    val classes = browser_renderer_split_spaces(parent_class)
    var idx = 0
    while idx < classes.len():
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "div." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div." + classes[idx], "span"))
        idx = idx + 1
    val parent_id = br_tag_attr_value(parent_tag_content, "id").trim()
    if parent_id.len() > 0:
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "div#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div#" + parent_id, "span"))
    out

fn br_first_span_bounds_before_div_close(html: text, content_start: i64) -> (i64, i64, i64):
    val lower = html.lower()
    val div_close = br_find_str(lower, "</div", content_start)
    if div_close >= 999999999:
        return (-1, -1, -1)
    val span_open = br_find_str(lower, "<span", content_start)
    if span_open >= div_close:
        return (-1, -1, -1)
    val span_open_end = browser_renderer_find_char(html, ">", span_open)
    if span_open_end >= 999999999 or span_open_end >= div_close:
        return (-1, -1, -1)
    val span_close = br_find_str(lower, "</span", span_open_end + 1)
    if span_close >= div_close:
        return (-1, -1, -1)
    (span_open_end, span_close, span_open)

# =========================================================================
# Effect Engine Configuration
# =========================================================================

fn set_browser_effect_engine(platform: text):
    """Configure the render_scene effect engine for browser rendering."""
    select_effect_engine(platform)

# =========================================================================
# Helpers
# =========================================================================

fn count_nodes(node: BeDomNode) -> i32:
    """Count total nodes in a DOM tree."""
    var count = 1
    val kids = be_dom_get_children(node)
    var kids_idx = 0
    while kids_idx < kids.len():
        val child = kids[kids_idx]
        kids_idx = kids_idx + 1
        count = count + count_nodes(child)
    return count

fn _find_body_bg_color(node: BeDomNode) -> u32:
    """Find the first <body> element in the DOM and return its bg color (RGBA)."""
    if be_dom_get_tag(node) == "body":
        return be_dom_get_bg_color(node).value
    val kids = be_dom_get_children(node)
    var idx = 0
    while idx < kids.len():
        val child = kids[idx]
        idx = idx + 1
        val bg = _find_body_bg_color(child)
        if bg != 0x00000000:
            return bg
    return 0x00000000

# =========================================================================
# Widget -> DOM conversion
# =========================================================================

fn browser_renderer_ui_tree_to_dom(tree: UITree, state: UIState) -> BeDomNode:
    """Local UITree conversion avoids an extra cross-module symbol in standalone SMF runs."""
    val root_widget = tree.root_node()
    var root_dom = BeDomNode.element("div")
    root_dom.id = "ui-root"
    root_dom.classes = ["ui-container"]

    var s = root_dom.style
    s.display = "flex"
    s.flex_direction = "column"
    s.width = CssValue.pct(100.0)
    s.height = CssValue.pct(100.0)
    root_dom.style = s

    val content = browser_renderer_widget_to_dom(root_widget, state)
    be_dom_add_child(root_dom,content)
    root_dom

fn browser_renderer_widget_to_dom(node: WidgetNode, state: UIState) -> BeDomNode:
    val kind = node.kind_name()
    val tag = widget_kind_to_tag(kind)

    var dom = BeDomNode.element(tag)
    dom.id = node.id
    browser_renderer_apply_widget_props(dom, node, kind)

    if node.id == state.focused_id:
        dom.classes.push("focused")
        var s = dom.style
        s.border = BorderProps.solid(2, 0x58A6FFFF)
        dom.style = s

    var wchild_idx = 0
    val wchildren = node.children()
    while wchild_idx < wchildren.len():
        val child = wchildren[wchild_idx]
        wchild_idx = wchild_idx + 1
        be_dom_add_child(dom,browser_renderer_widget_to_dom(child, state))

    dom

fn browser_renderer_apply_widget_props(dom: BeDomNode, node: WidgetNode, kind: text):
    dom.classes.push(kind)
    val title = node.get_prop("title")
    if title.len() > 0:
        dom.set_attr("title", title)
    val text_content = node.get_prop("text")
    if text_content.len() > 0:
        be_dom_add_child(dom,BeDomNode.text(text_content))
    val value = node.get_prop("value")
    if value.len() > 0:
        dom.set_attr("value", value)
    val placeholder = node.get_prop("placeholder")
    if placeholder.len() > 0:
        dom.set_attr("placeholder", placeholder)
    val layout = node.layout_name()
    if layout == "hbox":
        var s = dom.style
        s.display = "flex"
        s.flex_direction = "row"
        dom.style = s
    elif layout == "vbox":
        var s = dom.style
        s.display = "flex"
        s.flex_direction = "column"
        dom.style = s
    elif layout == "grid":
        var s = dom.style
        s.display = "grid"
        dom.style = s
    val width_val = node.get_prop("width")
    if width_val.len() > 0:
        dom.set_style("width", width_val)
    val height_val = node.get_prop("height")
    if height_val.len() > 0:
        dom.set_style("height", height_val)
    val flex_val = node.get_prop("flex")
    if flex_val.len() > 0:
        var s = dom.style
        s.display = "flex"
        s.flex_direction = flex_val
        dom.style = s
    val gap_val = node.get_prop("gap")
    if gap_val.len() > 0:
        dom.set_style("gap", gap_val)
    val bg_val = node.get_prop("background")
    if bg_val.len() > 0:
        dom.set_style("background-color", bg_val)
    else:
        val bg2_val = node.get_prop("bg")
        if bg2_val.len() > 0:
            dom.set_style("background-color", bg2_val)
    if not node.is_visible():
        var s = dom.style
        s.display = "none"
        dom.style = s

# =========================================================================
# Convenience pub wrappers
# =========================================================================

pub fn render_html_to_pixels_with_viewport(html: text, width: i32, height: i32) -> BeRenderResult:
    """Convenience wrapper for callers that work with viewport pixel counts."""
    val renderer = BrowserRenderer.create(width, height)
    renderer.render_html_to_pixels(br_normalize_style_blocks_in_html(html))

# =========================================================================
# Legacy HTML string parser
# =========================================================================

fn br_stack_pop_and_add(stack: [BeDomNode]) -> [BeDomNode]:
    """Pop last element from stack, add it as child to new top. Returns new stack."""
    if stack.len() <= 1:
        return stack
    val completed = stack[stack.len() - 1]
    var next_stack = stack.slice(0, stack.len() - 1)
    if next_stack.len() > 0:
        var new_parent = next_stack[next_stack.len() - 1]
        br_append_child(new_parent, completed)
        next_stack[next_stack.len() - 1] = new_parent
    next_stack

fn br_append_child(parent: BeDomNode, child: BeDomNode):
    var kids = be_dom_get_children(parent)
    kids.push(child)
    parent.children = kids

fn browser_renderer_html_string_to_dom(html: text) -> BeDomNode:
    var root = BeDomNode.element("div")
    root.id = "html-root"
    val raw_html = html
    var stack: [BeDomNode] = [root]
    var pos = 0
    val len = html.len()
    while pos < len:
        val ch = html.char_at(pos)
        if ch == "<":
            var is_comment = false
            if pos + 3 < len:
                val comment_prefix = html.slice(pos, pos + 4)
                if comment_prefix == "<!--":
                    val comment_end = br_find_str(html, "-->", pos + 4)
                    if comment_end < 999999999:
                        pos = comment_end + 3
                    else:
                        pos = len
                    is_comment = true
            if is_comment:
                continue
            val tag_end = browser_renderer_find_char(html, ">", pos)
            if tag_end >= 999999999:
                val remaining = html.slice(pos, len)
                val txt = BeDomNode.text(remaining)
                if stack.len() > 0:
                    var parent = stack[stack.len() - 1]
                    br_append_child(parent, txt)
                    stack[stack.len() - 1] = parent
                break
            val tag_content = html.slice(pos + 1, tag_end)
            if tag_content.starts_with("!DOCTYPE") or tag_content.starts_with("!doctype"):
                pos = tag_end + 1
                continue
            if tag_content.starts_with("/"):
                val (next_pos, next_stack) = br_handle_close_tag_and_pop(tag_content, tag_end, stack)
                pos = next_pos
                stack = next_stack
            else:
                val (next_pos, next_stack) = br_handle_open_tag(tag_content, html, tag_end, len, stack)
                pos = next_pos
                stack = next_stack
        else:
            val (next_pos, next_stack) = br_handle_text(html, pos, len, stack)
            pos = next_pos
            stack = next_stack
    while stack.len() > 1:
        br_stack_pop_and_add(stack)
    var result = root
    if stack.len() > 0:
        result = stack[0]
    br_apply_ua_defaults(result)
    br_materialize_font_faces_if_requested(raw_html)
    result = process_style_blocks_result(result, raw_html)
    result

fn br_materialize_font_faces_if_requested(html: text):
    if env_get("SIMPLE_BROWSER_AUTO_DOWNLOAD_FONTS") != "1":
        return
    ensure_browser_font_face_sources(html, true)

fn br_handle_close_tag_and_pop(tag_content: text, tag_end: i64, stack: [BeDomNode]) -> (i64, [BeDomNode]):
    val close_raw = tag_content.slice(1, tag_content.len())
    val close_trimmed = close_raw.trim()
    val close_tag = close_trimmed.lower()
    if close_tag == "html" or close_tag == "head" or close_tag == "body" or close_tag == "style":
        return (tag_end + 1, stack)
    if stack.len() > 1:
        val completed = stack[stack.len() - 1]
        stack = stack.slice(0, stack.len() - 1)
        var new_parent = stack[stack.len() - 1]
        br_append_child(new_parent, completed)
        stack[stack.len() - 1] = new_parent
    return (tag_end + 1, stack)

fn br_handle_open_tag(tag_content: text, html: text, tag_end: i64, len: i64, stack: [BeDomNode]) -> (i64, [BeDomNode]):
    val is_self_closing = tag_content.ends_with("/")
    var clean_content = tag_content.trim()
    if is_self_closing:
        val trimmed_sc = tag_content.slice(0, tag_content.len() - 1)
        clean_content = trimmed_sc.trim()
    var new_node = browser_renderer_parse_tag(clean_content)
    val raw_tag = be_dom_get_tag(new_node)
    val tag_lower = raw_tag.lower()
    if tag_lower == "html" or tag_lower == "head" or tag_lower == "title" or tag_lower == "link" or tag_lower == "meta" or tag_lower == "script":
        if tag_lower == "title" or tag_lower == "script":
            val close_needle = "</{tag_lower}"
            val html_lc = html.lower()
            val close_pos = br_find_str(html_lc, close_needle, tag_end + 1)
            if close_pos < 999999999:
                val close_end = browser_renderer_find_char(html, ">", close_pos)
                if close_end < 999999999:
                    return (close_end + 1, stack)
                return (close_pos + 8, stack)
            return (tag_end + 1, stack)
        return (tag_end + 1, stack)
    if tag_lower == "body":
        if stack.len() > 0:
            var root_node = stack[0]
            val body_parts = browser_renderer_split_tag_parts(clean_content)
            var bi = 1
            while bi < body_parts.len():
                val bpart = body_parts[bi]
                val beq = browser_renderer_find_char(bpart, "=", 0)
                if beq > 0:
                    val bkey = bpart.slice(0, beq)
                    var bval = bpart.slice(beq + 1, bpart.len())
                    if bval.starts_with("\"") and bval.ends_with("\""):
                        bval = bval.slice(1, bval.len() - 1)
                    elif bval.starts_with("'") and bval.ends_with("'"):
                        bval = bval.slice(1, bval.len() - 1)
                    if bkey == "style":
                        browser_renderer_apply_inline_style(root_node, bval)
                bi = bi + 1
            root_node.tag = "body"
            stack[0] = root_node
        return (tag_end + 1, stack)
    if tag_lower == "style":
        val html_lower = html.lower()
        val style_close = br_find_str(html_lower, "</style", tag_end + 1)
        if style_close < 999999999:
            val style_tag_end = browser_renderer_find_char(html, ">", style_close)
            if style_tag_end < 999999999:
                return (style_tag_end + 1, stack)
            return (style_close + 8, stack)
        return (len, stack)
    val node_tag_for_void = be_dom_get_tag(new_node)
    if is_self_closing or browser_renderer_is_void_element(node_tag_for_void):
        if stack.len() > 0:
            var parent_v = stack[stack.len() - 1]
            br_append_child(parent_v, new_node)
            stack[stack.len() - 1] = parent_v
        return (tag_end + 1, stack)
    return (tag_end + 1, stack + [new_node])

fn br_handle_text(html: text, pos: i64, len: i64, stack: [BeDomNode]) -> (i64, [BeDomNode]):
    val text_end = browser_renderer_find_char(html, "<", pos)
    val end_pos = if text_end >= 999999999: len else: text_end
    val text_raw = html.slice(pos, end_pos)
    val text_content = text_raw.trim()
    if text_content.len() > 0:
        val txt = BeDomNode.text(text_content)
        if stack.len() > 0:
            var parent = stack[stack.len() - 1]
            br_append_child(parent, txt)
            stack[stack.len() - 1] = parent
    return (end_pos, stack)

fn browser_renderer_parse_tag(content: text) -> BeDomNode:
    val parts = browser_renderer_split_tag_parts(content)
    if parts.len() == 0:
        return BeDomNode.element("div")
    val tag_name = parts[0]
    var node = BeDomNode.element(tag_name)
    var i = 1
    while i < parts.len():
        val part = parts[i]
        val eq_pos = browser_renderer_find_char(part, "=", 0)
        if eq_pos > 0:
            val key = part.slice(0, eq_pos)
            var value = part.slice(eq_pos + 1, part.len())
            if value.starts_with("\"") and value.ends_with("\""):
                value = value.slice(1, value.len() - 1)
            elif value.starts_with("'") and value.ends_with("'"):
                value = value.slice(1, value.len() - 1)
            if key == "id":
                node.id = value
            elif key == "class":
                node.classes = browser_renderer_split_spaces(value)
            elif key == "style":
                browser_renderer_apply_inline_style(node, value)
            else:
                node.set_attr(key, value)
        i = i + 1
    node

fn browser_renderer_apply_inline_style(node: BeDomNode, style_str: text):
    val declarations = browser_renderer_split_semicolons(style_str)
    var decl_idx = 0
    while decl_idx < declarations.len():
        val decl = declarations[decl_idx]
        decl_idx = decl_idx + 1
        val colon_pos = browser_renderer_find_char(decl, ":", 0)
        if colon_pos > 0:
            val prop_raw = decl.slice(0, colon_pos)
            val prop = prop_raw.trim()
            if prop == "color":
                val value_raw = decl.slice(colon_pos + 1, decl.len())
                val value = value_raw.trim()
                node.set_style(prop, value)
    decl_idx = 0
    while decl_idx < declarations.len():
        val decl = declarations[decl_idx]
        decl_idx = decl_idx + 1
        val colon_pos = browser_renderer_find_char(decl, ":", 0)
        if colon_pos > 0:
            val prop_raw = decl.slice(0, colon_pos)
            val prop = prop_raw.trim()
            if prop != "color":
                val value_raw = decl.slice(colon_pos + 1, decl.len())
                val value = value_raw.trim()
                node.set_style(prop, value)

pub fn browser_renderer_normalize_style_rules(css_text: text) -> text:
    br_flatten_supports_blocks(br_flatten_layer_blocks(css_text))

pub fn browser_renderer_normalize_style_blocks(html: text) -> text:
    br_normalize_style_blocks_in_html(html)

fn br_normalize_style_blocks_in_html(html: text) -> text:
    val lower = html.lower()
    var out = ""
    var pos: i64 = 0
    while pos < html.len():
        val style_pos = br_find_str(lower, "<style", pos)
        if style_pos >= 999999999:
            out = out + html.slice(pos, html.len())
            break
        val style_open_end = browser_renderer_find_char(html, ">", style_pos)
        if style_open_end >= 999999999:
            out = out + html.slice(pos, html.len())
            break
        val style_close = br_find_str(lower, "</style", style_open_end + 1)
        if style_close >= 999999999:
            out = out + html.slice(pos, html.len())
            break
        out = out + html.slice(pos, style_open_end + 1)
        out = out + br_flatten_layer_blocks(html.slice(style_open_end + 1, style_close))
        pos = style_close
    out

fn br_html_style_contains_parent_nesting(html: text) -> bool:
    val lower = html.lower()
    var pos: i64 = 0
    while pos < html.len():
        val style_pos = br_find_str(lower, "<style", pos)
        if style_pos >= 999999999:
            return false
        val style_open_end = browser_renderer_find_char(html, ">", style_pos)
        if style_open_end >= 999999999:
            return false
        val style_close = br_find_str(lower, "</style", style_open_end + 1)
        if style_close >= 999999999:
            return false
        if html.slice(style_open_end + 1, style_close).contains("&"):
            return true
        pos = style_close + 1
    false

# =========================================================================
# UA Defaults
# =========================================================================

fn br_apply_ua_defaults(node: BeDomNode):
    """Apply user-agent default styles to common HTML elements."""
    if be_dom_get_is_text(node):
        return
    val tag = be_dom_get_tag(node)
    if tag == "body":
        node.set_style("margin", "8px")
    elif tag == "p":
        node.set_style("display", "block")
        node.set_style("margin-top", "16px")
        node.set_style("margin-bottom", "16px")
    elif tag == "h1":
        node.set_style("display", "block")
        node.set_style("font-size", "32px")
        node.set_style("font-weight", "bold")
        node.set_style("margin-top", "21px")
        node.set_style("margin-bottom", "21px")
    elif tag == "h2":
        node.set_style("display", "block")
        node.set_style("font-size", "24px")
        node.set_style("font-weight", "bold")
        node.set_style("margin-top", "19px")
        node.set_style("margin-bottom", "19px")
    elif tag == "h3":
        node.set_style("display", "block")
        node.set_style("font-size", "19px")
        node.set_style("font-weight", "bold")
    elif tag == "h4":
        node.set_style("display", "block")
        node.set_style("font-size", "16px")
        node.set_style("font-weight", "bold")
    elif tag == "h5":
        node.set_style("display", "block")
        node.set_style("font-size", "13px")
        node.set_style("font-weight", "bold")
    elif tag == "h6":
        node.set_style("display", "block")
        node.set_style("font-size", "11px")
        node.set_style("font-weight", "bold")
    elif tag == "ul" or tag == "ol":
        node.set_style("display", "block")
        node.set_style("padding-left", "40px")
        node.set_style("margin-top", "16px")
        node.set_style("margin-bottom", "16px")
    elif tag == "li":
        node.set_style("display", "block")
    elif tag == "dl":
        node.set_style("display", "block")
        node.set_style("margin-top", "16px")
        node.set_style("margin-bottom", "16px")
    elif tag == "dt":
        node.set_style("display", "block")
    elif tag == "dd":
        node.set_style("display", "block")
        node.set_style("margin-left", "40px")
    elif tag == "span" or tag == "a" or tag == "em" or tag == "strong" or tag == "b" or tag == "i":
        node.set_style("display", "inline")
    elif tag == "blockquote":
        node.set_style("display", "block")
        node.set_style("margin", "16px")
        node.set_style("margin-left", "40px")
    elif tag == "pre":
        node.set_style("display", "block")
    elif tag == "table":
        node.set_style("display", "block")
    elif tag == "form":
        node.set_style("display", "block")
    elif tag == "section" or tag == "article" or tag == "nav" or tag == "aside" or tag == "header" or tag == "footer" or tag == "main":
        node.set_style("display", "block")

    val ua_kids = be_dom_get_children(node)
    var ua_idx = 0
    while ua_idx < ua_kids.len():
        val child = ua_kids[ua_idx]
        ua_idx = ua_idx + 1
        br_apply_ua_defaults(child)

# =========================================================================
# M14: WHATWG parser toggle (AD-4)
# =========================================================================

use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build}

pub fn browser_renderer_parse_html(html: text, use_legacy: bool) -> BeDomNode:
    """Parse HTML using either the new WHATWG parser or the legacy string-scan parser.
    Set use_legacy=true or env SIMPLE_BROWSER_LEGACY_PARSER=1 to use the old parser."""
    if use_legacy:
        return browser_renderer_html_string_to_dom(html)
    html_tree_builder_build(html)
