# @gc — module uses GC runtime
#
# NvfsClient transport for the streaming loader (Phase A3 transport).
#
# Round 5 implemented the streaming LOGIC (plan_stream + stream_pack) but left
# the bare `load_model_from_pack` returning NvfsUnavailable because nothing
# fetched the manifest text + chunk bytes off a filesystem. This module supplies
# that transport for an in-memory adapter:
#
#   MemNvfsClient        — a bring-up / test NvfsClient adapter that holds the
#                          manifest (as text) and each chunk (as bytes) in
#                          memory, keyed by object path. It is read-capable,
#                          unlike the std.fs bring-up adapter whose read_range
#                          returns Unsupported.
#   load_model_from_pack_via(client, pack_root, granule)
#                        — opens `<root>/manifest.sdn`, parses it to learn the
#                          chunk layout, reads each chunk's bytes, then drives
#                          the Round-5 streaming loader end to end.
#
# A real NvfsClient (native or std.fs-backed) uses a different entry shape:
# read_range reads byte ranges into registered BufHandle buffers rather than
# returning owned text or [u8] values. It is NOT a drop-in for MemNvfsClient
# and needs its own transport entry. Wiring one is the remaining transport work;
# see doc/08_tracking/feature/svllm_nvfs_transport_for_loader_2026-06-20.md.

use std.gc_async_mut.svllm.model_executor.model_loader.manifest.{parse_manifest, TensorPackManifest}
use std.gc_async_mut.svllm.model_executor.model_loader.loader.{LoadResult, LoaderError, load_model_from_pack_streamed}

# Adapter-local error. A real adapter surfaces nvfs_client.NvfsError; this
# in-memory bring-up adapter keeps its own minimal error to avoid a gc->nogc
# runtime-family boundary crossing on the contract enum.
enum MemNvfsError:
    NotFound

# One in-memory object: either a text payload (the manifest) or a byte payload
# (a chunk). Identified by its object path.
struct MemObj:
    path: text
    is_text: bool
    text_val: text
    bytes_val: [u8]

# In-memory NvfsClient adapter. Read-capable; holds objects by path. Construct
# via `mem_nvfs_image` (no incremental mutation) so it is a pure value.
struct MemNvfsClient:
    objs: [MemObj]

    static fn empty() -> MemNvfsClient:
        MemNvfsClient(objs: [])

    # Type-agnostic scan — used by has() only.
    fn _find(self, path: text) -> i64:
        var i = 0
        while i < self.objs.len():
            if self.objs[i].path == path:
                return i
            i = i + 1
        -1

    # Type-aware scan: finds the first object at path with is_text==true.
    # If the first match at path is a byte object, the scan continues so
    # that a text object stored after a same-path byte object is still found.
    fn _find_text(self, path: text) -> i64:
        var i = 0
        while i < self.objs.len():
            if self.objs[i].path == path:
                if self.objs[i].is_text == true:
                    return i
            i = i + 1
        -1

    # Type-aware scan: finds the first object at path with is_text==false.
    # If the first match at path is a text object, the scan continues so
    # that a byte object stored after a same-path text object is still found.
    fn _find_bytes(self, path: text) -> i64:
        var i = 0
        while i < self.objs.len():
            if self.objs[i].path == path:
                if self.objs[i].is_text == false:
                    return i
            i = i + 1
        -1

    # Read a text object (the manifest). Returns NotFound if no text object
    # exists at path (absent path OR only byte objects at that path).
    # Duplicate same-type paths return the first match.
    fn read_text(self, path: text) -> Result<text, MemNvfsError>:
        val idx = self._find_text(path)
        if idx < 0:
            return Err(MemNvfsError.NotFound)
        Ok(self.objs[idx].text_val)

    # Read a byte object (a chunk). Returns NotFound if no byte object
    # exists at path (absent path OR only text objects at that path).
    # Duplicate same-type paths return the first match.
    # When mem_nvfs_image is called with fewer chunk_bytes entries than
    # chunk_paths, the remaining chunk objects are stored with an empty
    # bytes_val ([]). read_bytes returns Ok([]) for those; stream_pack
    # will then report ChunkTooShort -> LoaderError.ChunkOpenFailed.
    fn read_bytes(self, path: text) -> Result<[u8], MemNvfsError>:
        val idx = self._find_bytes(path)
        if idx < 0:
            return Err(MemNvfsError.NotFound)
        Ok(self.objs[idx].bytes_val)

    # True if ANY object (text or byte) exists at path.
    fn has(self, path: text) -> bool:
        self._find(path) >= 0

# Build an in-memory pack image: `<pack_root>/manifest.sdn` holding the manifest
# text, plus one byte object per chunk at `<pack_root>/<chunk_paths[i]>`.
# chunk_paths[i] / chunk_bytes[i] correspond to the manifest's chunks in order
# (chunk_paths[i] is typically pack.chunks[i].relative_path).
#
# If chunk_bytes has fewer entries than chunk_paths, the remaining chunk objects
# are stored with an empty bytes buffer ([]). A subsequent read_bytes call still
# returns Ok([]) for those paths (the object exists), so stream_pack will detect
# the mismatch via ChunkTooShort and propagate LoaderError.ChunkOpenFailed.
fn mem_nvfs_image(pack_root: text, manifest_text: text, chunk_paths: [text], chunk_bytes: [[u8]]) -> MemNvfsClient:
    var objs: [MemObj] = []
    objs.push(MemObj(path: pack_root + "/manifest.sdn", is_text: true, text_val: manifest_text, bytes_val: []))
    var i = 0
    while i < chunk_paths.len():
        var cb: [u8] = []
        if i < chunk_bytes.len():
            cb = chunk_bytes[i]
        objs.push(MemObj(path: pack_root + "/" + chunk_paths[i], is_text: false, text_val: "", bytes_val: cb))
        i = i + 1
    MemNvfsClient(objs: objs)

# Transport entry: fetch the manifest + chunk bytes off the client and drive the
# Round-5 streaming loader. Error mapping:
#   manifest object absent           -> PackRootNotFound
#   manifest unparseable             -> ManifestInvalid (via the streamed path)
#   a chunk object absent            -> ChunkOpenFailed
# Otherwise delegates to load_model_from_pack_streamed (which re-parses, builds
# the TensorPack, plans, and stages).
#
# Notes:
#   - build_tensor_pack failures (e.g. TensorChunkMismatch from an
#     internally-inconsistent manifest) surface as LoaderError.ManifestInvalid
#     via the streamed path.
#   - StreamError.ChunkDataMissing -> ChunkOpenFailed is only reachable via
#     direct load_model_from_pack_streamed calls; this transport always supplies
#     exactly m.chunks.len() buffers so that branch is unreachable here.
fn load_model_from_pack_via(client: MemNvfsClient, pack_root: text, granule: i64) -> Result<LoadResult, LoaderError>:
    val manifest_path = pack_root + "/manifest.sdn"
    val mtext_r = client.read_text(manifest_path)
    if mtext_r.is_err():
        return Err(LoaderError.PackRootNotFound)
    val mtext = mtext_r.unwrap()
    # Parse once here to learn the chunk layout (relative paths) to fetch.
    val m_r = parse_manifest(mtext)
    if m_r.is_err():
        return Err(LoaderError.ManifestInvalid)
    val m = m_r.unwrap()
    var chunk_data: [[u8]] = []
    var i = 0
    while i < m.chunks.len():
        val chunk_path = pack_root + "/" + m.chunks[i].relative_path
        val cb_r = client.read_bytes(chunk_path)
        if cb_r.is_err():
            return Err(LoaderError.ChunkOpenFailed)
        chunk_data.push(cb_r.unwrap())
        i = i + 1
    load_model_from_pack_streamed(pack_root, mtext, granule, chunk_data)
