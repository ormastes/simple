# cc::Layer — base compositor layer with property-tree node indices

use std.skia.entity.geometry.{SkRect, SkPoint}

enum LayerKind:
    Root
    Picture
    Solid
    Surface

class Layer:
    id: i32
    parent_id: i32
    kind: LayerKind
    bounds: SkRect
    transform_id: i32
    clip_id: i32
    effect_id: i32
    scroll_id: i32
    contents_opaque: bool
    is_drawable: bool
    needs_display: bool

    static fn root(bounds: SkRect) -> Layer:
        Layer(
            id: 0,
            parent_id: -1,
            kind: LayerKind.Root,
            bounds: bounds,
            transform_id: 0,
            clip_id: 0,
            effect_id: 0,
            scroll_id: 0,
            contents_opaque: false,
            is_drawable: true,
            needs_display: false
        )

    static fn picture(parent_id: i32, bounds: SkRect, transform: i32, clip: i32, effect: i32) -> Layer:
        Layer(
            id: -1,
            parent_id: parent_id,
            kind: LayerKind.Picture,
            bounds: bounds,
            transform_id: transform,
            clip_id: clip,
            effect_id: effect,
            scroll_id: 0,
            contents_opaque: false,
            is_drawable: true,
            needs_display: true
        )

    me mark_needs_display():
        me.needs_display = true

    me clear_needs_display():
        me.needs_display = false
