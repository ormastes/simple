# Viewport3D — 3D camera with orbit, pan, dolly controls
#
# Provides an orbit camera for 3D scene editing, with spherical-coordinate
# positioning, field-of-view, clipping planes, and grid/axes toggles.

use std.common.engine.math3d.{Vec3}
use std.common.drawing.vector.{SkPoint}
use std.common.math.{MATH_PI, math_abs, math_clamp}
use std.nogc_sync_mut.editor.mode.{EditorMode}

# ============================================================================
# Trig helpers (Taylor-series, internal to this module)
# ============================================================================

fn approx_sin(x: f64) -> f64:
    """Taylor-series sine. Reduces x to [-pi, pi] first."""
    val two_pi = 6.28318530717959
    val pi = MATH_PI
    var a = x % two_pi
    if a > pi:
        a = a - two_pi
    if a < -pi:
        a = a + two_pi
    val x2 = a * a
    val x3 = a * x2
    val x5 = x3 * x2
    val x7 = x5 * x2
    a - x3 / 6.0 + x5 / 120.0 - x7 / 5040.0

fn approx_cos(x: f64) -> f64:
    """Taylor-series cosine via sine shift."""
    approx_sin(x + MATH_PI / 2.0)

# ============================================================================
# OrbitConfig — tuning parameters for orbit camera behaviour
# ============================================================================

struct OrbitConfig:
    min_distance: f64
    max_distance: f64
    orbit_speed: f64
    pan_speed: f64
    dolly_speed: f64
    min_pitch: f64
    max_pitch: f64

fn default_orbit_config() -> OrbitConfig:
    """Sensible defaults: distance 1-500, moderate speeds, pitch clamped to avoid flip."""
    OrbitConfig(
        min_distance: 1.0,
        max_distance: 500.0,
        orbit_speed: 0.005,
        pan_speed: 0.01,
        dolly_speed: 0.1,
        min_pitch: -1.4,
        max_pitch: 1.4
    )

# ============================================================================
# OrbitCamera — spherical-coordinate camera orbiting a target point
# ============================================================================

class OrbitCamera:
    target_x: f64
    target_y: f64
    target_z: f64
    distance: f64
    yaw: f64
    pitch: f64
    config: OrbitConfig

impl OrbitCamera:
    static fn new() -> OrbitCamera:
        """Camera at origin, distance 10, slight angle."""
        OrbitCamera(
            target_x: 0.0,
            target_y: 0.0,
            target_z: 0.0,
            distance: 10.0,
            yaw: 0.5,
            pitch: 0.3,
            config: default_orbit_config()
        )

    static fn looking_at(tx: f64, ty: f64, tz: f64, dist: f64) -> OrbitCamera:
        """Camera looking at a specific point from the given distance."""
        OrbitCamera(
            target_x: tx,
            target_y: ty,
            target_z: tz,
            distance: dist,
            yaw: 0.5,
            pitch: 0.3,
            config: default_orbit_config()
        )

    me orbit(delta_yaw: f64, delta_pitch: f64):
        """Rotate around target by the given angular deltas (scaled by orbit_speed)."""
        self.yaw = self.yaw + delta_yaw * self.config.orbit_speed
        val raw_pitch = self.pitch + delta_pitch * self.config.orbit_speed
        self.pitch = math_clamp(raw_pitch, self.config.min_pitch, self.config.max_pitch)

    me dolly(delta: f64):
        """Move closer/further from target (scaled by dolly_speed)."""
        val raw = self.distance + delta * self.config.dolly_speed
        self.distance = math_clamp(raw, self.config.min_distance, self.config.max_distance)

    me pan(dx: f64, dy: f64):
        """Pan the target in camera-local right and up directions."""
        val speed = self.config.pan_speed
        # Right direction: (cos(yaw), 0, -sin(yaw))
        val right_x = approx_cos(self.yaw)
        val right_z = -approx_sin(self.yaw)
        # Up is world Y
        self.target_x = self.target_x + right_x * dx * speed
        self.target_z = self.target_z + right_z * dx * speed
        self.target_y = self.target_y + dy * speed

    me focus_on(x: f64, y: f64, z: f64):
        """Snap the orbit target to the given position."""
        self.target_x = x
        self.target_y = y
        self.target_z = z

    me reset():
        """Reset camera to default state."""
        self.target_x = 0.0
        self.target_y = 0.0
        self.target_z = 0.0
        self.distance = 10.0
        self.yaw = 0.5
        self.pitch = 0.3

    fn eye_position(self) -> Vec3:
        """Compute camera position from spherical coordinates around target."""
        val cos_p = approx_cos(self.pitch)
        val sin_p = approx_sin(self.pitch)
        val cos_y = approx_cos(self.yaw)
        val sin_y = approx_sin(self.yaw)
        val ex = self.target_x + self.distance * cos_p * sin_y
        val ey = self.target_y + self.distance * sin_p
        val ez = self.target_z + self.distance * cos_p * cos_y
        Vec3(x: ex, y: ey, z: ez)

    fn forward_direction(self) -> Vec3:
        """Normalized direction from eye toward target."""
        val eye = self.eye_position()
        val dx = self.target_x - eye.x
        val dy = self.target_y - eye.y
        val dz = self.target_z - eye.z
        val len = (dx * dx + dy * dy + dz * dz) ** 0.5
        if len < 0.000001:
            return Vec3.forward()
        Vec3(x: dx / len, y: dy / len, z: dz / len)

    fn right_direction(self) -> Vec3:
        """Right direction via cross product of forward and world up (0,1,0)."""
        val fwd = self.forward_direction()
        # cross(fwd, up) = (fwd.z * 1 - fwd.y * 0, fwd.x * 0 - fwd.z * 0 ... wait
        # cross(fwd, (0,1,0)) = (fwd.y*0 - fwd.z*1, fwd.z*0 - fwd.x*0, fwd.x*1 - fwd.y*0)
        # Actually: cross(a, b) = (a.y*b.z - a.z*b.y, a.z*b.x - a.x*b.z, a.x*b.y - a.y*b.x)
        # cross(fwd, (0,1,0)) = (fwd.y*0 - fwd.z*1, fwd.z*0 - fwd.x*0, fwd.x*1 - fwd.y*0)
        val rx = -fwd.z
        val ry = 0.0
        val rz = fwd.x
        val len = (rx * rx + rz * rz) ** 0.5
        if len < 0.000001:
            return Vec3(x: 1.0, y: 0.0, z: 0.0)
        Vec3(x: rx / len, y: ry, z: rz / len)

# ============================================================================
# Viewport3D — 3D viewport with camera, FOV, clipping, and overlays
# ============================================================================

class Viewport3D:
    camera: OrbitCamera
    fov_degrees: f64
    near_clip: f64
    far_clip: f64
    screen_width: f64
    screen_height: f64
    show_grid: bool
    show_axes: bool

impl Viewport3D:
    static fn new(width: f64, height: f64) -> Viewport3D:
        """Create a 3D viewport with default camera and 60-degree FOV."""
        Viewport3D(
            camera: OrbitCamera.new(),
            fov_degrees: 60.0,
            near_clip: 0.1,
            far_clip: 1000.0,
            screen_width: width,
            screen_height: height,
            show_grid: true,
            show_axes: true
        )

    me resize(width: f64, height: f64):
        """Update viewport dimensions."""
        self.screen_width = width
        self.screen_height = height

    me toggle_grid():
        """Toggle ground-grid visibility."""
        self.show_grid = !self.show_grid

    me toggle_axes():
        """Toggle world-axes overlay visibility."""
        self.show_axes = !self.show_axes

    fn aspect_ratio(self) -> f64:
        """Width / height, guarded against zero."""
        if self.screen_height < 0.001:
            return 1.0
        self.screen_width / self.screen_height
