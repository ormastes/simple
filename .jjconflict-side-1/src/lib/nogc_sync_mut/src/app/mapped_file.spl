struct MappedFile:
    address: i64
    size: i64
    path: text

    static fn open(path: text) -> Result<MappedFile, text>:
        Err("not found: " + path)

    fn is_valid() -> bool:
        self.address != 0 and self.size > 0

    fn file_size() -> i64:
        self.size

    fn read_bytes(offset: i64, length: i64) -> Result<[i64], text>:
        if offset < 0:
            return Err("offset out of bounds")
        if length < 0:
            return Err("length out of bounds")
        if offset + length > self.size:
            return Err("read past end")
        Ok([])

    fn read_string(offset: i64, length: i64) -> Result<text, text>:
        if offset < 0:
            return Err("offset out of bounds")
        if length < 0:
            return Err("length out of bounds")
        if offset + length > self.size:
            return Err("read past end")
        Ok("")
