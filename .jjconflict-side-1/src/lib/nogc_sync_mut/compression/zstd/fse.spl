# zstd/fse.spl — Finite State Entropy (FSE) decoder (RFC 8878 §3.1.1.3.2.2)
#
# Implements:
#   - NCount (normalized distribution) decoding from a forward LSB reader
#   - FSE table construction from a normalized distribution
#   - FSE state machine: initialise state, decode symbol, advance state
#
# RFC 8878 NCount probability semantics (Known Issue #2 from state.md):
#   raw value 0  → run-of-zeros; next 2 bits = count of subsequent zero-prob symbols
#   raw value 1  → prob = -1 (less-than-1 / "low probability")
#   raw value N ≥ 2 → prob = N - 1
#
# Table builder (Known Issue #5 from state.md):
#   Symbols with prob = -1 occupy tail positions (tableSize-1, tableSize-2, ...).
#   They are skipped during the spread step.
#
# Predefined distributions (LL/ML/OF) are in fse_predefined.spl.

use std.common.compress.types.{CompressionError}
use std.nogc_sync_mut.compression.zstd.bit_reader.{
    ZstdBitReader, ZstdBitsResult,
    ZstdRevBitReader, ZstdRevBitsResult,
    zstd_br_read,
    zstd_rbr_read
}

# ---------------------------------------------------------------------------
# FSE table entry
# ---------------------------------------------------------------------------

struct FseTableEntry:
    symbol:    i64   # decoded symbol value
    num_bits:  i64   # number of bits to read for next state
    base_state: i64  # base for the next state

# ---------------------------------------------------------------------------
# FSE table
# ---------------------------------------------------------------------------

struct FseTable:
    entries:      [FseTableEntry]   # length = 1 << accuracy_log
    accuracy_log: i64

# ---------------------------------------------------------------------------
# NCount decode result
# ---------------------------------------------------------------------------

struct FseNCountResult:
    norm:         [i64]           # normalized probabilities (length = max_symbol + 1)
    max_symbol:   i64
    accuracy_log: i64
    reader:       ZstdBitReader

# ---------------------------------------------------------------------------
# FSE state result (decode one symbol)
# ---------------------------------------------------------------------------

struct FseSymbolResult:
    symbol: i64
    state:  i64
    reader: ZstdRevBitReader

# ---------------------------------------------------------------------------
# NCount: decode the normalized frequency table from a forward bit reader
#
# RFC 8878 §3.1.1.3.2.2:
#   First 4 bits → accuracy_log = 5 + those_4_bits
#   Then for each symbol until probabilities sum to tableSize:
#     Read ceil(log2(remaining+1)) bits → raw value
#     if raw == 0: repeat-zeros (read next 2 bits = count)
#     if raw == 1: prob = -1
#     else:        prob = raw - 1
# ---------------------------------------------------------------------------

fn fse_read_ncount(
    r: ZstdBitReader,
    max_accuracy_log: i64
) -> Result<FseNCountResult, CompressionError>:
    # Read accuracy_log (4 bits → accuracy_log = value + 5)
    val alr = zstd_br_read(r, 4)?
    val accuracy_log = alr.value + 5
    if accuracy_log > max_accuracy_log:
        return Err(CompressionError.CorruptData("zstd FSE accuracy_log too large"))
    if accuracy_log < 1:
        return Err(CompressionError.CorruptData("zstd FSE accuracy_log too small"))

    val table_size = 1 << accuracy_log
    # remaining tracks probability budget left; starts at tableSize + 1 (sentinel)
    var remaining = table_size + 1
    # nbits = number of bits to read = ceil(log2(remaining + 1))
    var nbits = accuracy_log + 1
    # threshold = 1 << (nbits - 1)
    var threshold = 1 << (nbits - 1)
    var cur = alr.reader

    var norm: [i64] = []
    var symbol = 0

    while remaining > 1:
        # RFC 8878 NCount variable-length encoding (from zstd FSE_readNCount):
        # Read nbits-1 bits first ("low"). Compute max = 2*threshold - 1 - remaining.
        # If low < max: consumed nbits-1 bits total, raw = low.
        # Else: read one more bit, raw = low | (extra << (nbits-1)); if raw >= threshold, raw -= max.
        val low_r = zstd_br_read(cur, nbits - 1)?
        val low = low_r.value
        cur = low_r.reader
        val vl_max = (threshold << 1) - 1 - remaining
        var raw = 0
        if low < vl_max:
            # Short code: nbits-1 bits consumed; do NOT read the extra bit.
            raw = low
            nbits = nbits - 1
            threshold = threshold >> 1
        else:
            # Full code: read one more bit.
            val extra_r = zstd_br_read(cur, 1)?
            cur = extra_r.reader
            val full = low | (extra_r.value << (nbits - 1))
            if full >= threshold:
                raw = full - vl_max
            else:
                raw = full
            # Reset for next symbol.
            nbits = accuracy_log + 1
            threshold = 1 << (nbits - 1)

        # Decode probability from raw value per RFC 8878 §3.1.1.3.2.2:
        #   raw == 0  → prob = 0 for this symbol, run-of-zeros follows (2 bits)
        #   raw == 1  → prob = -1 (less-than-1)
        #   raw >= 2  → prob = raw - 1
        if raw == 0:
            # prob = 0; next 2 bits = count of additional zero-prob symbols
            norm.push(0)
            symbol = symbol + 1
            val ror = zstd_br_read(cur, 2)?
            cur = ror.reader
            var zero_run = ror.value
            while zero_run > 0:
                norm.push(0)
                symbol = symbol + 1
                zero_run = zero_run - 1
        else:
            if raw == 1:
                # prob = -1 (less-than-1)
                norm.push(-1)
                remaining = remaining - 1
                symbol = symbol + 1
            else:
                # prob = raw - 1
                val prob = raw - 1
                norm.push(prob)
                remaining = remaining - prob
                symbol = symbol + 1

    val max_symbol = symbol - 1
    Ok(FseNCountResult(
        norm: norm,
        max_symbol: max_symbol,
        accuracy_log: accuracy_log,
        reader: cur
    ))

# ---------------------------------------------------------------------------
# FSE table builder
#
# Algorithm (RFC 8878 Appendix A):
#   1. Place less-than-1 (prob=-1) symbols at tail positions (tableSize-1 down).
#      Record highThreshold = last free index after tail allocation.
#   2. Spread normal-prob (prob>0) symbols via step walk, skipping pos > highThreshold.
#   3. For each cell: compute num_bits and base_state from that symbol's prob.
# ---------------------------------------------------------------------------

fn fse_build_table(
    norm: [i64],
    max_symbol: i64,
    accuracy_log: i64
) -> Result<FseTable, CompressionError>:
    val table_size = 1 << accuracy_log
    val mask = table_size - 1
    # step must be coprime to table_size (power of 2); zstd uses this formula:
    val step = (table_size >> 1) + (table_size >> 3) + 3

    # symbol_table[i] = which symbol occupies cell i; -1 = unassigned
    var symbol_table: [i64] = _fse_make_sentinel_array(table_size)

    # --- Step 1: Place less-than-1 (prob=-1) symbols at tail positions FIRST ---
    # RFC 8878 §3.1.1.3.2.2: symbols with prob=-1 occupy tail positions from
    # tableSize-1 downward BEFORE the spread step.  The spread step must then
    # skip those reserved positions.  highThreshold is the last free position.
    var tail_pos = table_size - 1
    var s = 0
    while s <= max_symbol:
        if s < norm.len():
            val prob = norm[s]
            if prob == -1:
                symbol_table = _fse_set(symbol_table, tail_pos, s)
                tail_pos = tail_pos - 1
        s = s + 1
    # highThreshold = index of the last tail slot filled; positions > highThreshold
    # are reserved for less-than-1 symbols and must be skipped during spread.
    val high_threshold = tail_pos

    # --- Step 2: Spread normal-prob symbols (prob > 0) via the step walk ---
    # RFC 8878 Appendix A: start at pos=0, advance by step (mod tableSize),
    # skipping any position > high_threshold (those are tail slots).
    var pos = 0
    s = 0
    while s <= max_symbol:
        if s < norm.len():
            val prob = norm[s]
            if prob > 0:
                var count = prob
                while count > 0:
                    # Skip positions reserved for less-than-1 symbols.
                    while pos > high_threshold:
                        pos = (pos + step) & mask
                    symbol_table = _fse_set(symbol_table, pos, s)
                    pos = (pos + step) & mask
                    count = count - 1
        s = s + 1

    # --- Step 3: Build FSE decode table entries ---
    # For each table cell, compute: symbol, num_bits, base_state.
    # Algorithm (RFC 8878 Appendix A):
    #   next_state_base[sym] starts at prob[sym] and increments per cell.
    #   nb(cell) = accuracy_log - floor(log2(next_state))
    #   base_state(cell) = (next_state << nb) - tableSize

    # Initialize next_state_base: for each symbol, start from its prob value.
    # For less-than-1 symbols (prob=-1), they get nb=accuracy_log, base=0-tableSize.
    var next_state_base: [i64] = _fse_make_zero_array(max_symbol + 1)
    s = 0
    while s <= max_symbol:
        if s < norm.len():
            val prob = norm[s]
            if prob > 0:
                next_state_base = _fse_set(next_state_base, s, prob)
            if prob == -1:
                # Less-than-1: next_state starts at 1 (they get exactly 1 cell)
                next_state_base = _fse_set(next_state_base, s, 1)
        s = s + 1

    var entries: [FseTableEntry] = []
    var i = 0
    while i < table_size:
        val sym = symbol_table[i]
        var entry_sym = 0
        var entry_num_bits = 0
        var entry_base = 0
        if sym >= 0 and sym <= max_symbol:
            entry_sym = sym
            val ns = next_state_base[sym]
            val nb = accuracy_log - _fse_log2(ns)
            entry_num_bits = nb
            entry_base = (ns << nb) - table_size
            next_state_base = _fse_set(next_state_base, sym, ns + 1)
        entries.push(FseTableEntry(
            symbol: entry_sym,
            num_bits: entry_num_bits,
            base_state: entry_base
        ))
        i = i + 1

    Ok(FseTable(entries: entries, accuracy_log: accuracy_log))

# ---------------------------------------------------------------------------
# FSE state machine
# ---------------------------------------------------------------------------

# Initialise the FSE state from the reverse bit reader.
# Reads `accuracy_log` bits to set the initial state.
fn fse_init_state(
    table: FseTable,
    r: ZstdRevBitReader
) -> Result<FseSymbolResult, CompressionError>:
    val sr = zstd_rbr_read(r, table.accuracy_log)?
    val state = sr.value
    # Return a dummy symbol (state not yet decoded — caller reads symbol after advance)
    Ok(FseSymbolResult(symbol: -1, state: state, reader: sr.reader))

# Decode symbol at current state and advance to next state.
# Returns the decoded symbol and the new state (after reading num_bits from r).
fn fse_decode_symbol(
    table: FseTable,
    state: i64,
    r: ZstdRevBitReader
) -> Result<FseSymbolResult, CompressionError>:
    if state < 0 or state >= table.entries.len():
        return Err(CompressionError.CorruptData("zstd FSE state out of range"))
    val entry = table.entries[state]
    val symbol = entry.symbol
    val nb = entry.num_bits
    var new_state = entry.base_state
    var new_reader = r
    if nb > 0:
        val br = zstd_rbr_read(r, nb)?
        new_state = new_state + br.value
        new_reader = br.reader
    Ok(FseSymbolResult(symbol: symbol, state: new_state, reader: new_reader))

# ---------------------------------------------------------------------------
# Helper: floor(log2(v)) for v >= 1
# ---------------------------------------------------------------------------

fn _fse_log2(v: i64) -> i64:
    if v <= 0:
        return 0
    var n = 0
    var x = v
    while x > 1:
        x = x >> 1
        n = n + 1
    n

# ---------------------------------------------------------------------------
# Helper: create array of `size` elements initialised to -1
# ---------------------------------------------------------------------------

fn _fse_make_sentinel_array(size: i64) -> [i64]:
    var arr: [i64] = []
    var i = 0
    while i < size:
        arr.push(-1)
        i = i + 1
    arr

# ---------------------------------------------------------------------------
# Helper: create array of `size` elements initialised to 0
# ---------------------------------------------------------------------------

fn _fse_make_zero_array(size: i64) -> [i64]:
    var arr: [i64] = []
    var i = 0
    while i < size:
        arr.push(0)
        i = i + 1
    arr

# ---------------------------------------------------------------------------
# Helper: immutable-style array set (returns new array with element changed)
# Simple arrays are mutable by ref in the interpreter; this wrapper provides
# a consistent pattern while remaining compatible with both modes.
# ---------------------------------------------------------------------------

fn _fse_set(arr: [i64], idx: i64, val_v: i64) -> [i64]:
    arr[idx] = val_v
    arr
