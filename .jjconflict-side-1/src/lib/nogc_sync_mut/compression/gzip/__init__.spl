# Public API for the gzip compression module.
# External callers: use std.nogc_sync_mut.compression.gzip.{gzip_compress, gzip_decompress}

# Core entry points (from compress.spl)
export gzip_compress, gzip_decompress

# Convenience wrappers (from compress.spl)
export gzip_compress_default, gzip_compress_best, gzip_compress_fast, gzip_compress_none

# Validation and metadata (from compress.spl)
export gzip_validate, gzip_get_metadata, gzip_is_compressed, gzip_extract_payload

# Checksum helpers (from crc.spl)
export crc32_calculate, crc32_verify, crc32_update, crc32_finalize, crc32_chunked

# Statistics helpers (from compress.spl)
export gzip_compression_ratio, gzip_space_savings, gzip_efficiency
export gzip_header_overhead, gzip_footer_overhead, gzip_total_overhead

# Analysis helpers (from compress.spl)
export gzip_analyze_data, gzip_suggest_level, gzip_estimate_size
