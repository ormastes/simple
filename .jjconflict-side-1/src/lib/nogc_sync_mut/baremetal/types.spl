# Baremetal Host Communication - Types
#
# Core type definitions: transport kinds, errors, and configuration.

# ============================================================================
# Transport Kind
# ============================================================================

enum TransportKind:
    Ssh
    Serial
    SerialFfi
    T32Semihost
    OpenocdSemihost
    Stlink
    DedicatedHw
    Loopback
    Dap

fn transport_kind_from_text(name: text) -> Result<TransportKind, text>:
    match name:
        "ssh": Ok(TransportKind.Ssh)
        "serial": Ok(TransportKind.Serial)
        "serial_ffi": Ok(TransportKind.SerialFfi)
        "t32_semihost": Ok(TransportKind.T32Semihost)
        "t32": Ok(TransportKind.T32Semihost)
        "openocd_semihost": Ok(TransportKind.OpenocdSemihost)
        "openocd": Ok(TransportKind.OpenocdSemihost)
        "stlink": Ok(TransportKind.Stlink)
        "dedicated_hw": Ok(TransportKind.DedicatedHw)
        "loopback": Ok(TransportKind.Loopback)
        "dap": Ok(TransportKind.Dap)
        _: Err("unknown transport kind: {name}")

fn transport_kind_to_text(kind: TransportKind) -> text:
    match kind:
        TransportKind.Ssh: "ssh"
        TransportKind.Serial: "serial"
        TransportKind.SerialFfi: "serial_ffi"
        TransportKind.T32Semihost: "t32_semihost"
        TransportKind.OpenocdSemihost: "openocd_semihost"
        TransportKind.Stlink: "stlink"
        TransportKind.DedicatedHw: "dedicated_hw"
        TransportKind.Loopback: "loopback"
        TransportKind.Dap: "dap"

# ============================================================================
# Communication Errors
# ============================================================================

enum CommError:
    NotConnected
    ConnectionFailed(reason: text)
    SendFailed(reason: text)
    ReceiveFailed(reason: text)
    Timeout
    ConfigError(reason: text)
    TransportError(reason: text)

fn comm_error_message(err: CommError) -> text:
    match err:
        CommError.NotConnected: "not connected"
        CommError.ConnectionFailed(reason): "connection failed: {reason}"
        CommError.SendFailed(reason): "send failed: {reason}"
        CommError.ReceiveFailed(reason): "receive failed: {reason}"
        CommError.Timeout: "operation timed out"
        CommError.ConfigError(reason): "config error: {reason}"
        CommError.TransportError(reason): "transport error: {reason}"

# ============================================================================
# Host Communication Config
# ============================================================================

struct HostCommConfig:
    transport: TransportKind
    timeout_ms: i64

    # SSH
    ssh_host: text
    ssh_port: i32
    ssh_user: text
    ssh_key_path: text

    # Serial
    serial_port: text
    baud_rate: i32
    data_bits: i32
    stop_bits: i32
    parity: text

    # TRACE32
    t32_host: text
    t32_port: i32
    t32rem_path: text

    # OpenOCD
    openocd_host: text
    openocd_telnet_port: i32
    openocd_cfg: text

    # STLink
    stlink_serial: text
    swo_freq: i64

    # Dedicated HW (UART adapter)
    hw_device: text
    hw_baud_rate: i32

    # Options
    log_enabled: bool
    echo_commands: bool
    line_ending: text

fn default_hostcomm_config() -> HostCommConfig:
    HostCommConfig(
        transport: TransportKind.Loopback,
        timeout_ms: 5000,
        ssh_host: "",
        ssh_port: 22,
        ssh_user: "",
        ssh_key_path: "",
        serial_port: "/dev/ttyUSB0",
        baud_rate: 115200,
        data_bits: 8,
        stop_bits: 1,
        parity: "none",
        t32_host: "localhost",
        t32_port: 20000,
        t32rem_path: "",
        openocd_host: "localhost",
        openocd_telnet_port: 4444,
        openocd_cfg: "",
        stlink_serial: "",
        swo_freq: 2000000,
        hw_device: "",
        hw_baud_rate: 115200,
        log_enabled: false,
        echo_commands: false,
        line_ending: "\n"
    )
