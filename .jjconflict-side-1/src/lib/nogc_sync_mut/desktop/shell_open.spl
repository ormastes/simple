# Host-OS shell integration: open URLs, paths, show in folder, trash, beep.
#
# Platform dispatch via rt_platform_name():
#   linux  — xdg-open, dbus FileManager1, gio trash, printf '\a'
#   macos  — open, open -R, osascript
#   other  — Err(NotSupported)

use common.ui.capability.{Capability, NotSupported}
use std.nogc_sync_mut.ffi.system.{process_run}

extern fn rt_platform_name() -> text

fn open_url(url: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val result = process_run("/bin/sh", ["-c", "xdg-open " + url])
        val exit_code = result.2
        Ok(exit_code == 0)
    elif platform == "macos":
        val result = process_run("/bin/sh", ["-c", "open " + url])
        Ok(result.2 == 0)
    else:
        Err(NotSupported.new("open_url not supported on " + platform))

fn open_path(path: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val result = process_run("/bin/sh", ["-c", "xdg-open " + path])
        Ok(result.2 == 0)
    elif platform == "macos":
        val result = process_run("/bin/sh", ["-c", "open " + path])
        Ok(result.2 == 0)
    else:
        Err(NotSupported.new("open_path not supported on " + platform))

fn show_in_folder(path: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val cmd = "dbus-send --session --print-reply --dest=org.freedesktop.FileManager1 --type=method_call /org/freedesktop/FileManager1 org.freedesktop.FileManager1.ShowItems array:string:\"file://" + path + "\" string:\"\""
        val result = process_run("/bin/sh", ["-c", cmd])
        Ok(result.2 == 0)
    elif platform == "macos":
        val result = process_run("/bin/sh", ["-c", "open -R " + path])
        Ok(result.2 == 0)
    else:
        Err(NotSupported.new("show_in_folder not supported on " + platform))

fn move_to_trash(path: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val result = process_run("/bin/sh", ["-c", "gio trash " + path])
        Ok(result.2 == 0)
    elif platform == "macos":
        val script = "tell application \"Finder\" to delete POSIX file \"" + path + "\""
        val result = process_run("osascript", ["-e", script])
        Ok(result.2 == 0)
    else:
        Err(NotSupported.new("move_to_trash not supported on " + platform))

fn beep() -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val result = process_run("/bin/sh", ["-c", "printf '\\a'"])
        Ok(result.2 == 0)
    elif platform == "macos":
        val result = process_run("osascript", ["-e", "beep"])
        Ok(result.2 == 0)
    else:
        Err(NotSupported.new("beep not supported on " + platform))
