use std.nogc_sync_mut.text_layout.font_types.{FontRenderBatch, FontRenderQuad}

# Apply the producer-resolved per-character advances to an already rasterized
# font batch. Atlas ownership stays in FontRenderer; only destination positions
# change, so Draw IR never owns transient atlas/cache material.
fn _font_character_index(byte_offsets: [i64], byte_offset: i64) -> i64:
    var low: i64 = 0
    var high = byte_offsets.len()
    while low < high:
        val middle = low + (high - low) / 2
        if byte_offsets[middle] < byte_offset:
            low = middle + 1
        else:
            high = middle
    if low < byte_offsets.len() and byte_offsets[low] == byte_offset:
        return low
    -1

fn font_batch_apply_advances(content: text, natural_advances: [i32], advance_widths: [i32], batch: FontRenderBatch) -> FontRenderBatch:
    var result = batch
    var byte_offsets: [i64] = []
    var shifts: [i32] = []
    var byte_offset: i64 = 0
    var target_x: i64 = 0
    var natural_x: i64 = 0
    var character_count: i64 = 0
    for ch in content:
        if character_count >= advance_widths.len() or character_count >= natural_advances.len():
            result.valid = false
            return result
        val advance = advance_widths[character_count]
        val natural_advance = natural_advances[character_count]
        if (advance < 0 or natural_advance < 0 or
            target_x > 2147483647 - advance.to_i64() or
            natural_x > 2147483647 - natural_advance.to_i64()):
            result.valid = false
            return result
        byte_offsets.push(byte_offset)
        shifts.push((target_x - natural_x).to_i32())
        byte_offset = byte_offset + ch.len()
        target_x = target_x + advance.to_i64()
        natural_x = natural_x + natural_advance.to_i64()
        character_count = character_count + 1
    if character_count != advance_widths.len() or character_count != natural_advances.len():
        result.valid = false
        return result

    var adjusted: [FontRenderQuad] = []
    for quad in result.quads:
        val character_index = _font_character_index(byte_offsets, quad.byte_offset)
        if character_index < 0:
            result.valid = false
            return result
        val shifted_x = quad.dst_x.to_i64() + shifts[character_index].to_i64()
        if shifted_x < -2147483648 or shifted_x > 2147483647:
            result.valid = false
            return result
        adjusted.push(FontRenderQuad(
            codepoint: quad.codepoint, byte_offset: quad.byte_offset,
            dst_x: shifted_x.to_i32(), dst_y: quad.dst_y,
            width: quad.width, height: quad.height,
            atlas_x: quad.atlas_x, atlas_y: quad.atlas_y,
            color: quad.color, cluster: quad.cluster
        ))
    result.quads = adjusted
    result
