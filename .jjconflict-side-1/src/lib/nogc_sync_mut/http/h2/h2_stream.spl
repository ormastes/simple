# HTTP/2 Stream Lifecycle and Flow Control — RFC 9113 §5
#
# Stream state machine + per-stream / connection-level flow-control accounting
# for the sync HTTP/2 tier. State and event values are int constants (not enums)
# per the sync-tier dispatch convention.
#
# NOTE: cross-module imported `val` constants resolve to 0 in the seed
# (BUG seed_imported_module_val_const_zero) — callers in other modules / specs
# MUST read the constants through the h2_state_* / h2_event_* accessor functions
# below, NOT by importing the `val`s directly. Functions in THIS module read the
# constants internally and return correct values.
#
# Scope:
#   - Stream state machine and transitions (RFC 9113 §5.1)
#   - Per-stream send/recv flow-control window accounting (RFC 9113 §5.2)

# ============================================================================
# Stream state constants — RFC 9113 §5.1
# ============================================================================

val H2_STREAM_IDLE: i64               = 0
val H2_STREAM_RESERVED_LOCAL: i64     = 1
val H2_STREAM_RESERVED_REMOTE: i64    = 2
val H2_STREAM_OPEN: i64               = 3
val H2_STREAM_HALF_CLOSED_LOCAL: i64  = 4
val H2_STREAM_HALF_CLOSED_REMOTE: i64 = 5
val H2_STREAM_CLOSED: i64             = 6

# ============================================================================
# Stream event constants — triggers for state transitions
# ============================================================================

val H2_EVENT_SEND_HEADERS: i64       = 0
val H2_EVENT_RECV_HEADERS: i64       = 1
val H2_EVENT_SEND_END_STREAM: i64    = 2
val H2_EVENT_RECV_END_STREAM: i64    = 3
val H2_EVENT_SEND_RST_STREAM: i64    = 4
val H2_EVENT_RECV_RST_STREAM: i64    = 5
val H2_EVENT_SEND_PUSH_PROMISE: i64  = 6
val H2_EVENT_RECV_PUSH_PROMISE: i64  = 7

# Default per-stream initial flow-control window (RFC 9113 §6.9.2).
val H2_DEFAULT_INITIAL_WINDOW_SIZE: i64 = 65535
# Maximum legal flow-control window value (RFC 9113 §6.9.1): 2^31 - 1.
val H2_MAX_WINDOW_SIZE: i64 = 2147483647

# ----------------------------------------------------------------------------
# Constant accessors (cross-module safe — see BUG note above)
# ----------------------------------------------------------------------------

fn h2_state_idle() -> i64:
    return H2_STREAM_IDLE
fn h2_state_reserved_local() -> i64:
    return H2_STREAM_RESERVED_LOCAL
fn h2_state_reserved_remote() -> i64:
    return H2_STREAM_RESERVED_REMOTE
fn h2_state_open() -> i64:
    return H2_STREAM_OPEN
fn h2_state_half_closed_local() -> i64:
    return H2_STREAM_HALF_CLOSED_LOCAL
fn h2_state_half_closed_remote() -> i64:
    return H2_STREAM_HALF_CLOSED_REMOTE
fn h2_state_closed() -> i64:
    return H2_STREAM_CLOSED

fn h2_event_send_headers() -> i64:
    return H2_EVENT_SEND_HEADERS
fn h2_event_recv_headers() -> i64:
    return H2_EVENT_RECV_HEADERS
fn h2_event_send_end_stream() -> i64:
    return H2_EVENT_SEND_END_STREAM
fn h2_event_recv_end_stream() -> i64:
    return H2_EVENT_RECV_END_STREAM
fn h2_event_send_rst_stream() -> i64:
    return H2_EVENT_SEND_RST_STREAM
fn h2_event_recv_rst_stream() -> i64:
    return H2_EVENT_RECV_RST_STREAM
fn h2_event_send_push_promise() -> i64:
    return H2_EVENT_SEND_PUSH_PROMISE
fn h2_event_recv_push_promise() -> i64:
    return H2_EVENT_RECV_PUSH_PROMISE

fn h2_default_initial_window_size() -> i64:
    return H2_DEFAULT_INITIAL_WINDOW_SIZE
fn h2_max_window_size() -> i64:
    return H2_MAX_WINDOW_SIZE

# ============================================================================
# Stream struct
# ============================================================================

class H2Stream:
    """Per-stream state and flow-control accounting. `state` is one of the
    H2_STREAM_* constants (read via h2_state_* accessors from other modules)."""
    id: i64
    state: i64
    send_window: i64
    recv_window: i64

# Create a new stream in the Idle state with the given initial window size.
fn h2_stream_new(id: i64, initial_window: i64) -> H2Stream:
    return H2Stream(
        id: id,
        state: H2_STREAM_IDLE,
        send_window: initial_window,
        recv_window: initial_window
    )

# ----------------------------------------------------------------------------
# State machine
# ----------------------------------------------------------------------------

# Compute the next state for `state` given `event`. Invalid transitions return
# the input state unchanged (caller / connection layer decides on error).
# RFC 9113 §5.1.
fn h2_stream_next_state(state: i64, event: i64) -> i64:
    # RST_STREAM in any non-idle state immediately closes the stream.
    if event == H2_EVENT_SEND_RST_STREAM or event == H2_EVENT_RECV_RST_STREAM:
        return H2_STREAM_CLOSED
    if event == H2_EVENT_SEND_HEADERS:
        if state == H2_STREAM_IDLE:
            return H2_STREAM_OPEN
        if state == H2_STREAM_RESERVED_LOCAL:
            return H2_STREAM_HALF_CLOSED_REMOTE
        return state
    if event == H2_EVENT_RECV_HEADERS:
        if state == H2_STREAM_IDLE:
            return H2_STREAM_OPEN
        if state == H2_STREAM_RESERVED_REMOTE:
            return H2_STREAM_HALF_CLOSED_LOCAL
        return state
    if event == H2_EVENT_SEND_END_STREAM:
        if state == H2_STREAM_OPEN:
            return H2_STREAM_HALF_CLOSED_LOCAL
        if state == H2_STREAM_HALF_CLOSED_REMOTE:
            return H2_STREAM_CLOSED
        return state
    if event == H2_EVENT_RECV_END_STREAM:
        if state == H2_STREAM_OPEN:
            return H2_STREAM_HALF_CLOSED_REMOTE
        if state == H2_STREAM_HALF_CLOSED_LOCAL:
            return H2_STREAM_CLOSED
        return state
    if event == H2_EVENT_SEND_PUSH_PROMISE:
        if state == H2_STREAM_IDLE:
            return H2_STREAM_RESERVED_LOCAL
        return state
    if event == H2_EVENT_RECV_PUSH_PROMISE:
        if state == H2_STREAM_IDLE:
            return H2_STREAM_RESERVED_REMOTE
        return state
    return state

# Apply a state-machine event to the stream, returning an updated stream.
fn h2_stream_transition(stream: H2Stream, event: i64) -> H2Stream:
    val next = h2_stream_next_state(stream.state, event)
    return H2Stream(
        id: stream.id,
        state: next,
        send_window: stream.send_window,
        recv_window: stream.recv_window
    )

# Predicate: is this state one in which the stream can still send/receive data?
fn h2_stream_is_active(state: i64) -> bool:
    return (state == H2_STREAM_OPEN or
            state == H2_STREAM_HALF_CLOSED_LOCAL or
            state == H2_STREAM_HALF_CLOSED_REMOTE)

fn h2_stream_is_closed(state: i64) -> bool:
    return state == H2_STREAM_CLOSED

# ----------------------------------------------------------------------------
# Per-stream flow control (RFC 9113 §5.2)
# ----------------------------------------------------------------------------

# Can `n` bytes of DATA be sent on this stream right now? (window must cover it)
fn h2_stream_can_send(stream: H2Stream, n: i64) -> bool:
    return n >= 0 and stream.send_window >= n

# Consume `n` bytes from the send window after emitting DATA.
fn h2_stream_consume_send(stream: H2Stream, n: i64) -> H2Stream:
    var nw = stream.send_window - n
    return H2Stream(
        id: stream.id,
        state: stream.state,
        send_window: nw,
        recv_window: stream.recv_window
    )

# Consume `n` bytes from the recv window after receiving DATA.
fn h2_stream_consume_recv(stream: H2Stream, n: i64) -> H2Stream:
    var nw = stream.recv_window - n
    return H2Stream(
        id: stream.id,
        state: stream.state,
        send_window: stream.send_window,
        recv_window: nw
    )

# Apply a received WINDOW_UPDATE: grow the send window by `increment`.
# Returns nil if the resulting window would overflow 2^31-1 (RFC 9113 §6.9.1
# FLOW_CONTROL_ERROR), or if increment is non-positive.
fn h2_stream_apply_window_update(stream: H2Stream, increment: i64) -> H2Stream?:
    if increment <= 0:
        return nil
    val nw = stream.send_window + increment
    if nw > H2_MAX_WINDOW_SIZE:
        return nil
    return Some(H2Stream(
        id: stream.id,
        state: stream.state,
        send_window: nw,
        recv_window: stream.recv_window
    ))

# Grow the local recv window (e.g. after the application consumed data and the
# implementation issues its own WINDOW_UPDATE to the peer).
fn h2_stream_grow_recv(stream: H2Stream, increment: i64) -> H2Stream:
    return H2Stream(
        id: stream.id,
        state: stream.state,
        send_window: stream.send_window,
        recv_window: stream.recv_window + increment
    )

export H2_STREAM_IDLE, H2_STREAM_RESERVED_LOCAL, H2_STREAM_RESERVED_REMOTE
export H2_STREAM_OPEN, H2_STREAM_HALF_CLOSED_LOCAL, H2_STREAM_HALF_CLOSED_REMOTE
export H2_STREAM_CLOSED
export H2_EVENT_SEND_HEADERS, H2_EVENT_RECV_HEADERS
export H2_EVENT_SEND_END_STREAM, H2_EVENT_RECV_END_STREAM
export H2_EVENT_SEND_RST_STREAM, H2_EVENT_RECV_RST_STREAM
export H2_EVENT_SEND_PUSH_PROMISE, H2_EVENT_RECV_PUSH_PROMISE
export H2_DEFAULT_INITIAL_WINDOW_SIZE, H2_MAX_WINDOW_SIZE
export h2_state_idle, h2_state_reserved_local, h2_state_reserved_remote
export h2_state_open, h2_state_half_closed_local, h2_state_half_closed_remote
export h2_state_closed
export h2_event_send_headers, h2_event_recv_headers
export h2_event_send_end_stream, h2_event_recv_end_stream
export h2_event_send_rst_stream, h2_event_recv_rst_stream
export h2_event_send_push_promise, h2_event_recv_push_promise
export h2_default_initial_window_size, h2_max_window_size
export H2Stream
export h2_stream_new, h2_stream_next_state, h2_stream_transition
export h2_stream_is_active, h2_stream_is_closed
export h2_stream_can_send, h2_stream_consume_send, h2_stream_consume_recv
export h2_stream_apply_window_update, h2_stream_grow_recv
