# MCP SDK - Lazy Tool Registry (T4b)
#
# Stores tool registrations; schema JSON is NOT constructed until the first
# call to registry_list_json().  Handlers are callable immediately via
# registry_call() without ever touching schema builders.
#
# Implements AC-2: schemas_built counter (instrumentation, not timing).

use std.mcp_sdk.core.json.{LB, RB, jp, js, jo1, jo2, jo3, escape_json}
use std.mcp_sdk.server.pagination.{paginate_tools_response, parse_cursor}

# Default page size for paginated listings
val REGISTRY_PAGE_SIZE = 50

# --- Module-level state (parallel arrays, same pattern as state.spl) ---

var REGISTRY_NAMES: [text] = []
var REGISTRY_DESCS: [text] = []
var REGISTRY_SCHEMA_BUILDERS: [fn() -> text] = []
var REGISTRY_HANDLERS: [fn(text) -> text] = []

# Memoised schema JSON strings (built on the first list_json that needs them)
var REGISTRY_SCHEMAS: [text] = []
var REGISTRY_SCHEMA_READY: [bool] = []
# True when every currently registered schema is memoised
var REGISTRY_BUILT = false
# Instrumentation counter: how many schemas have been constructed so far
var REGISTRY_SCHEMAS_BUILT_COUNT = 0

# --- Registration ---

# Register a tool.
#   name           — tool name (unique within this registry)
#   description    — human-readable description
#   schema_builder — closure returning the inputSchema JSON text; called at
#                    most once (on first tools/list)
#   handler        — closure taking the arguments JSON text, returning result
#                    text; called immediately on tools/call
fn registry_register(name: text, description: text, schema_builder: fn() -> text, handler: fn(text) -> text):
    var new_names: [text] = []
    for n in REGISTRY_NAMES:
        new_names.push(n)
    new_names.push(name)
    REGISTRY_NAMES = new_names

    var new_descs: [text] = []
    for d in REGISTRY_DESCS:
        new_descs.push(d)
    new_descs.push(description)
    REGISTRY_DESCS = new_descs

    var new_builders: [fn() -> text] = []
    for b in REGISTRY_SCHEMA_BUILDERS:
        new_builders.push(b)
    new_builders.push(schema_builder)
    REGISTRY_SCHEMA_BUILDERS = new_builders

    var new_handlers: [fn(text) -> text] = []
    for h in REGISTRY_HANDLERS:
        new_handlers.push(h)
    new_handlers.push(handler)
    REGISTRY_HANDLERS = new_handlers

    var new_schemas: [text] = []
    for s in REGISTRY_SCHEMAS:
        new_schemas.push(s)
    new_schemas.push("")
    REGISTRY_SCHEMAS = new_schemas

    var new_ready: [bool] = []
    for ready in REGISTRY_SCHEMA_READY:
        new_ready.push(ready)
    new_ready.push(false)
    REGISTRY_SCHEMA_READY = new_ready

    # New registrations leave existing schema memoization intact.
    REGISTRY_BUILT = false

# --- Query ---

# Return the number of registered tools.
fn registry_count() -> i64:
    REGISTRY_NAMES.len()

# Return the instrumentation counter: how many schema builders have been
# invoked in total across all list calls.
fn registry_schemas_built() -> i64:
    REGISTRY_SCHEMAS_BUILT_COUNT

# --- Schema build (lazy, memoised) ---

# Build one tool's full schema JSON from its name, description, and input
# schema produced by the builder closure.
fn registry_build_tool_json(name: text, description: text, input_schema: text) -> text:
    var r = LB()
    r = r + jp("name", js(name))
    r = r + "," + jp("description", js(escape_json(description)))
    r = r + "," + jp("inputSchema", input_schema)
    r = r + RB()
    r

# Ensure all schema builders have been called and results memoised.
# Increments REGISTRY_SCHEMAS_BUILT_COUNT once per builder invoked.
fn registry_ensure_built():
    if REGISTRY_BUILT:
        return
    var built: [text] = []
    var ready_flags: [bool] = []
    var i = 0
    val total = REGISTRY_NAMES.len()
    while i < total:
        if REGISTRY_SCHEMA_READY[i]:
            built.push(REGISTRY_SCHEMAS[i])
        else:
            val name = REGISTRY_NAMES[i]
            val desc = REGISTRY_DESCS[i]
            val builder = REGISTRY_SCHEMA_BUILDERS[i]
            val input_schema = builder()
            REGISTRY_SCHEMAS_BUILT_COUNT = REGISTRY_SCHEMAS_BUILT_COUNT + 1
            val tool_json = registry_build_tool_json(name, desc, input_schema)
            built.push(tool_json)
        ready_flags.push(true)
        i = i + 1
    REGISTRY_SCHEMAS = built
    REGISTRY_SCHEMA_READY = ready_flags
    REGISTRY_BUILT = true

# --- tools/list ---

# Return a paginated tools/list JSON-RPC response body (just the result
# object, not the full envelope) for use by A4 McpServer.
# cursor follows the "offset:N" convention from pagination.spl.
# Schemas are built and memoised on the FIRST call only.
fn registry_list_json(id: text, cursor: text) -> text:
    registry_ensure_built()
    paginate_tools_response(id, REGISTRY_SCHEMAS, cursor, REGISTRY_PAGE_SIZE)

# --- tools/call ---

# Dispatch a tools/call to the registered handler.
# Schemas are NEVER built here — pure dispatch path.
# Returns the handler result, or an error string if the tool is not found.
fn registry_call(name: text, args: text) -> text:
    var i = 0
    val total = REGISTRY_NAMES.len()
    while i < total:
        if REGISTRY_NAMES[i] == name:
            val h = REGISTRY_HANDLERS[i]
            return h(args)
        i = i + 1
    "error: tool not found: " + name

# --- Reset (for test isolation) ---

fn registry_reset():
    REGISTRY_NAMES = []
    REGISTRY_DESCS = []
    REGISTRY_SCHEMA_BUILDERS = []
    REGISTRY_HANDLERS = []
    REGISTRY_SCHEMAS = []
    REGISTRY_SCHEMA_READY = []
    REGISTRY_BUILT = false
    REGISTRY_SCHEMAS_BUILT_COUNT = 0

# --- Exports ---
