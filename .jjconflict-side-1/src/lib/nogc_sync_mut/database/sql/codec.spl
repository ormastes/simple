# Typed SQL Database Library - DbCodec Trait
#
# Trait for encoding/decoding Simple types to/from database rows.
# Implement this trait for each model type to enable typed repository
# operations (insert, find, update, delete) via Repository<T>.

use std.database.sql.types.{DbValue, DbRow, DbError}
use std.database.sql.schema.{TableSchema}

# ============================================================================
# DbCodec<T> — encode/decode between Simple types and database rows
# ============================================================================

trait DbCodec<T>:
    """Codec for converting between Simple types and database rows.

    Implement this trait for each model type to enable typed repository operations.

    ## Example

    ```simple
    class UserCodec with DbCodec<User>:
        fn table_name() -> text:
            "users"

        fn schema() -> TableSchema:
            var s = TableSchema.new("users")
            s = s.id_col()
            s = s.text_col("name")
            s = s.int_col("age")
            s

        fn columns() -> [text]:
            ["name", "age"]

        fn encode(entity: User) -> [DbValue]:
            [DbValue.Text(value: entity.name), DbValue.Integer(value: entity.age)]

        fn decode(row: DbRow) -> Result<User, DbError>:
            val name = row.get_text("name")
            val age = row.get_int("age")
            if val Some(n) = name:
                if val Some(a) = age:
                    return Ok(User(name: n, age: a))
            Err(DbError.TypeMismatch(column: "user", expected: "name+age", actual: "missing"))
    ```
    """

    fn table_name() -> text
        # Return the SQL table name for this entity type.

    fn schema() -> TableSchema
        # Return the full table schema definition including all columns
        # and constraints. Used by Repository.create_table().

    fn columns() -> [text]
        # Return column names for INSERT operations.
        # Typically excludes auto-increment primary key ("id").
        # The order must match the values returned by encode().

    fn encode(entity: T) -> [DbValue]
        # Encode entity fields to a DbValue array.
        # Values must be in the same order as columns().

    fn decode(row: DbRow) -> Result<T, DbError>
        # Decode a database row into entity T.
        # Returns Err(DbError.TypeMismatch) if required columns are missing
        # or have unexpected types.
