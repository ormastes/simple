# STM32H7 JIT HAL
#
# Minimal hardware abstraction layer for STM32H7 OpenOCD telnet control.

use std.io_runtime.{shell}
use std.nogc_sync_mut.jit.jit_util.{hex_0x_i64, hex_i32, parse_i64, parse_hex, parse_mdw_bytes, extract_reg_value}
use std.spec.env_detect.{is_interpreter}

fn stm32h7_ocd_cfg() -> text:
    "board/stm32h7x3i_eval.cfg"

fn stm32h7_ocd_gdb_port() -> i64:
    23333

fn stm32h7_ocd_telnet_port() -> i64:
    24444

fn stm32h7_ocd_tcl_port() -> i64:
    26666

fn stm32h7_stlink_serial() -> text:
    "002600213137510833333639"

fn stm32h7_connect() -> Result<i64, text>:
    val cmd = "openocd -f {stm32h7_ocd_cfg()} -c 'adapter serial {stm32h7_stlink_serial()}' -c 'gdb_port {stm32h7_ocd_gdb_port()}' -c 'telnet_port {stm32h7_ocd_telnet_port()}' -c 'tcl_port {stm32h7_ocd_tcl_port()}' >/dev/null 2>&1 & echo $!"
    val start = shell(cmd)
    val pid_text = start.stdout.trim()
    if pid_text == "":
        return Err("failed to launch OpenOCD")

    val pid = parse_i64(pid_text)
    if pid <= 0:
        return Err("failed to parse OpenOCD pid: {pid_text}")

    var tries = 0
    while tries < 25:
        shell("sleep 0.2")
        val halt = stm32h7_ocd_cmd("reset halt")
        if halt.contains("halted"):
            return Ok(pid)
        tries = tries + 1

    stm32h7_disconnect(pid)
    Err("OpenOCD telnet port did not become ready")

fn stm32h7_disconnect(pid: i64):
    if pid > 0:
        stm32h7_ocd_cmd("shutdown")
        shell("kill {pid} >/dev/null 2>&1 || true")
        shell("sleep 0.1")
        shell("kill -9 {pid} >/dev/null 2>&1 || true")

fn stm32h7_write_code(addr: i64, bytes: [i32]) -> Result<text, text>:
    var offset = 0
    while offset < bytes.len():
        val b0 = bytes[offset]
        val b1 = if offset + 1 < bytes.len(): bytes[offset + 1] else: 0
        val b2 = if offset + 2 < bytes.len(): bytes[offset + 2] else: 0
        val b3 = if offset + 3 < bytes.len(): bytes[offset + 3] else: 0
        val word = (b3 << 24) + (b2 << 16) + (b1 << 8) + b0
        val out = stm32h7_ocd_cmd("mww {hex_0x_i64(addr + offset)} {hex_i32(word)}")
        if out.lower().contains("error"):
            return Err(out.trim())
        offset = offset + 4
    Ok("wrote {bytes.len()} bytes")

fn stm32h7_read_code(addr: i64, size: i64) -> Result<[i32], text>:
    if is_interpreter():
        return Err("stm32h7_read_code: skipped in interpreter mode (no OpenOCD telnet)")
    var words = size / 4
    if (size % 4) != 0:
        words = words + 1
    val out = stm32h7_ocd_cmd("mdw {hex_0x_i64(addr)} {words}")
    if out.trim() == "":
        return Err("empty mdw response")
    val bytes = parse_mdw_bytes(out, size)
    if bytes.len() < size:
        return Err("short mdw response")
    Ok(bytes)

fn stm32h7_write_register(reg: i64, value: i64) -> Result<text, text>:
    val out = stm32h7_ocd_cmd("reg {arm_reg_name(reg)} {hex_0x_i64(value)}")
    if out.lower().contains("error"):
        return Err(out.trim())
    Ok(out)

fn stm32h7_read_register(reg: i64) -> Result<i64, text>:
    val name = arm_reg_name(reg)
    val out = stm32h7_ocd_cmd("reg {name}")
    val value = extract_reg_value(out)
    if value < 0:
        return Err("failed to parse register {name}: {out.trim()}")
    Ok(value)

fn stm32h7_resume() -> Result<text, text>:
    stm32h7_ocd_cmd("resume")
    Ok("running")

fn arm_reg_name(reg: i64) -> text:
    match reg:
        0: "r0"
        1: "r1"
        2: "r2"
        3: "r3"
        4: "r4"
        5: "r5"
        6: "r6"
        7: "r7"
        8: "r8"
        9: "r9"
        10: "r10"
        11: "r11"
        12: "r12"
        13: "sp"
        14: "lr"
        15: "pc"
        _: "r0"

fn stm32h7_ocd_cmd(cmd: text) -> text:
    val result = shell("echo '{cmd}' | nc -q 1 localhost {stm32h7_ocd_telnet_port()} 2>/dev/null")
    result.stdout

