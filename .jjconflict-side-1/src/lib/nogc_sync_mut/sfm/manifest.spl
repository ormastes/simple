# SFM Feature-Manifest model.
#
# `.sfm` is the primary Simple Feature Module container: a pure-Simple outer
# header that embeds an opaque SMF code payload plus this feature manifest.
# The manifest declares the exposed front-end / back-end layers, the module's
# security level, and the build version. See:
#   doc/04_architecture/language/simple_feature_module.md
#   src/lib/nogc_sync_mut/sfm/codec.spl  (byte layout)

# AC-2: the kinds of layers a feature module can expose.
#   Front* = front-end (UI) layers; Back* = back-end (DB / HW) layers.
enum LayerKind:
    FrontGui
    FrontTui
    FrontArgParser
    BackDb
    BackHw

# AC-5: the special security marker. `Trusted` gates privileged-layer access;
# an `Ordinary` module cannot enforce trusted gating.
enum SfmSecurityLevel:
    Ordinary
    Trusted

# AC-2: one exposed layer — its DI role, kind, entry symbol, and whether it is
# privileged (privileged layers are gated when the module is `Trusted`).
struct LayerDescriptor:
    role: text
    kind: LayerKind
    entry_symbol: text
    privileged: bool

# AC-1 / AC-12: the feature manifest embedded in every `.sfm`.
struct FeatureManifest:
    name: text
    version: text
    security_level: SfmSecurityLevel
    layers: [LayerDescriptor]

# Outer container header. `magic` is the literal "SFM1" bytes; the version
# pair is the container *format* version (not the module version).
struct SfmHeader:
    magic: [u8]
    version_major: i32
    version_minor: i32

# --- LayerKind <-> wire byte ---

fn layer_kind_to_byte(k: LayerKind) -> i32:
    match k:
        case FrontGui:       return 0
        case FrontTui:       return 1
        case FrontArgParser: return 2
        case BackDb:         return 3
        case BackHw:         return 4

fn layer_kind_from_byte(b: i32) -> LayerKind:
    match b:
        0 -> return LayerKind.FrontGui
        1 -> return LayerKind.FrontTui
        2 -> return LayerKind.FrontArgParser
        3 -> return LayerKind.BackDb
        _ -> return LayerKind.BackHw

fn security_level_to_byte(s: SfmSecurityLevel) -> i32:
    match s:
        case Ordinary: return 0
        case Trusted:  return 1

fn security_level_from_byte(b: i32) -> SfmSecurityLevel:
    match b:
        1 -> return SfmSecurityLevel.Trusted
        _ -> return SfmSecurityLevel.Ordinary
