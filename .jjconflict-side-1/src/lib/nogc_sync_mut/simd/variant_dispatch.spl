# variant_dispatch.spl — AC-4/AC-5: SIMD dispatch routing and runtime function selection
#
# AC-4: compiler dispatch routing based on active SIMD tier
# AC-5: runtime function selection based on active SIMD tier
#
# Classes:
#   DispatchRoute      — maps a function to its tier-specific variant
#   DispatchTable      — flat 8-slot map of functions to tier variants
#   RuntimeSelector    — selects runtime function based on active tier
#   CodegenTierRouter  — routes compiler codegen to the correct tier ISA/flags

# ---------------------------------------------------------------------------
# DispatchRoute
# ---------------------------------------------------------------------------

class DispatchRoute:
    fn_name: text
    tier_name: text
    variant_suffix: text
    is_available: bool

impl DispatchRoute:
    static fn create(fn_name: text, tier_name: text) -> DispatchRoute:
        var suffix = "_" + tier_name
        DispatchRoute(
            fn_name: fn_name,
            tier_name: tier_name,
            variant_suffix: suffix,
            is_available: true
        )

    me qualified_name() -> text:
        self.fn_name + self.variant_suffix

    me summary() -> text:
        "DispatchRoute fn=" + self.fn_name +
            " tier=" + self.tier_name +
            " variant=" + self.qualified_name() +
            " available=" + self.is_available.to_text()

# ---------------------------------------------------------------------------
# DispatchTable
# ---------------------------------------------------------------------------

class DispatchTable:
    f0_name: text
    f1_name: text
    f2_name: text
    f3_name: text
    f4_name: text
    f5_name: text
    f6_name: text
    f7_name: text
    f0_tier: text
    f1_tier: text
    f2_tier: text
    f3_tier: text
    f4_tier: text
    f5_tier: text
    f6_tier: text
    f7_tier: text
    f0_avail: bool
    f1_avail: bool
    f2_avail: bool
    f3_avail: bool
    f4_avail: bool
    f5_avail: bool
    f6_avail: bool
    f7_avail: bool
    entry_count: i32

impl DispatchTable:
    static fn create() -> DispatchTable:
        DispatchTable(
            f0_name: "", f1_name: "", f2_name: "", f3_name: "",
            f4_name: "", f5_name: "", f6_name: "", f7_name: "",
            f0_tier: "", f1_tier: "", f2_tier: "", f3_tier: "",
            f4_tier: "", f5_tier: "", f6_tier: "", f7_tier: "",
            f0_avail: false, f1_avail: false, f2_avail: false, f3_avail: false,
            f4_avail: false, f5_avail: false, f6_avail: false, f7_avail: false,
            entry_count: 0
        )

    me add(fn_name: text, tier: text, available: bool) -> bool:
        if self.entry_count == 0:
            self.f0_name = fn_name
            self.f0_tier = tier
            self.f0_avail = available
            self.entry_count = 1
            true
        elif self.entry_count == 1:
            self.f1_name = fn_name
            self.f1_tier = tier
            self.f1_avail = available
            self.entry_count = 2
            true
        elif self.entry_count == 2:
            self.f2_name = fn_name
            self.f2_tier = tier
            self.f2_avail = available
            self.entry_count = 3
            true
        elif self.entry_count == 3:
            self.f3_name = fn_name
            self.f3_tier = tier
            self.f3_avail = available
            self.entry_count = 4
            true
        elif self.entry_count == 4:
            self.f4_name = fn_name
            self.f4_tier = tier
            self.f4_avail = available
            self.entry_count = 5
            true
        elif self.entry_count == 5:
            self.f5_name = fn_name
            self.f5_tier = tier
            self.f5_avail = available
            self.entry_count = 6
            true
        elif self.entry_count == 6:
            self.f6_name = fn_name
            self.f6_tier = tier
            self.f6_avail = available
            self.entry_count = 7
            true
        elif self.entry_count == 7:
            self.f7_name = fn_name
            self.f7_tier = tier
            self.f7_avail = available
            self.entry_count = 8
            true
        else:
            false

    me best_for(fn_name: text) -> text:
        var result = ""
        if self.f7_name == fn_name and self.f7_avail == true:
            result = fn_name + "_" + self.f7_tier
        elif self.f6_name == fn_name and self.f6_avail == true:
            result = fn_name + "_" + self.f6_tier
        elif self.f5_name == fn_name and self.f5_avail == true:
            result = fn_name + "_" + self.f5_tier
        elif self.f4_name == fn_name and self.f4_avail == true:
            result = fn_name + "_" + self.f4_tier
        elif self.f3_name == fn_name and self.f3_avail == true:
            result = fn_name + "_" + self.f3_tier
        elif self.f2_name == fn_name and self.f2_avail == true:
            result = fn_name + "_" + self.f2_tier
        elif self.f1_name == fn_name and self.f1_avail == true:
            result = fn_name + "_" + self.f1_tier
        elif self.f0_name == fn_name and self.f0_avail == true:
            result = fn_name + "_" + self.f0_tier
        else:
            result = fn_name + "_scalar"
        result

    me summary() -> text:
        "DispatchTable entries=" + self.entry_count.to_text()

# ---------------------------------------------------------------------------
# RuntimeSelector
# ---------------------------------------------------------------------------

class RuntimeSelector:
    active_tier: text
    fallback_tier: text

impl RuntimeSelector:
    static fn create(active: text, fallback: text) -> RuntimeSelector:
        RuntimeSelector(
            active_tier: active,
            fallback_tier: fallback
        )

    me select(fn_name: text) -> text:
        fn_name + "_" + self.active_tier

    me select_with_fallback(fn_name: text, tier_available: bool) -> text:
        if tier_available == true:
            fn_name + "_" + self.active_tier
        else:
            fn_name + "_" + self.fallback_tier

    me summary() -> text:
        "RuntimeSelector active=" + self.active_tier +
            " fallback=" + self.fallback_tier

# ---------------------------------------------------------------------------
# CodegenTierRouter
# ---------------------------------------------------------------------------

class CodegenTierRouter:
    target_arch: text
    active_tier: text
    emit_multi_version: bool

impl CodegenTierRouter:
    static fn single(arch: text, tier: text) -> CodegenTierRouter:
        CodegenTierRouter(
            target_arch: arch,
            active_tier: tier,
            emit_multi_version: false
        )

    static fn multi(arch: text, tier: text) -> CodegenTierRouter:
        CodegenTierRouter(
            target_arch: arch,
            active_tier: tier,
            emit_multi_version: true
        )

    me instruction_set() -> text:
        if self.active_tier == "avx512":
            "avx512f"
        elif self.active_tier == "avx2":
            "avx2"
        elif self.active_tier == "sse4_2":
            "sse4.2"
        elif self.active_tier == "sse2":
            "sse2"
        elif self.active_tier == "neon":
            "neon"
        elif self.active_tier == "sve":
            "sve"
        elif self.active_tier == "sve2":
            "sve2"
        elif self.active_tier == "rvv":
            "rvv"
        elif self.active_tier == "wasm128":
            "simd128"
        else:
            "scalar"

    me codegen_flags() -> text:
        if self.active_tier == "avx512":
            "-mavx512f"
        elif self.active_tier == "avx2":
            "-mavx2"
        elif self.active_tier == "sse4_2":
            "-msse4.2"
        elif self.active_tier == "sse2":
            "-msse2"
        elif self.active_tier == "neon":
            "-march=armv8-a+neon"
        elif self.active_tier == "sve":
            "-march=armv8-a+sve"
        elif self.active_tier == "sve2":
            "-march=armv9-a+sve2"
        elif self.active_tier == "rvv":
            "-march=rv64gcv"
        elif self.active_tier == "wasm128":
            "-msimd128"
        else:
            ""

    me summary() -> text:
        "CodegenTierRouter arch=" + self.target_arch +
            " tier=" + self.active_tier +
            " isa=" + self.instruction_set() +
            " flags=" + self.codegen_flags() +
            " multi=" + self.emit_multi_version.to_text()
