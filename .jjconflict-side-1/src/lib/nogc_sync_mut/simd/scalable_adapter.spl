# ScalableAdapter — adapts a FixedVec pipeline to emit scalable-vector diagnostics
#
# Provides lowering diagnostics: given a target VLEN, report whether a
# FixedVec of a given lane count can be directly mapped, needs splitting,
# or needs padding.
#
# @tag:stdlib
# @tag:simd

# LoweringDiag describes how a fixed lane count maps onto a scalable target.
class LoweringDiag:
    kind: i32
    fixed_lanes: i32
    target_lanes: i32
    note: text

# kind constants
fn lowering_ok() -> i32:
    0

fn lowering_split() -> i32:
    1

fn lowering_pad() -> i32:
    2

fn lowering_diag_make(kind: i32, fixed_lanes: i32, target_lanes: i32, note: text) -> LoweringDiag:
    LoweringDiag(kind: kind, fixed_lanes: fixed_lanes, target_lanes: target_lanes, note: note)

fn scalable_lower_f32(fixed_lanes: i32, target_f32_lanes: i32) -> LoweringDiag:
    if fixed_lanes == target_f32_lanes:
        return lowering_diag_make(lowering_ok(), fixed_lanes, target_f32_lanes, "direct map")
    if fixed_lanes > target_f32_lanes:
        return lowering_diag_make(lowering_split(), fixed_lanes, target_f32_lanes, "split required")
    lowering_diag_make(lowering_pad(), fixed_lanes, target_f32_lanes, "padding required")

fn diag_is_ok(d: LoweringDiag) -> bool:
    d.kind == lowering_ok()

fn diag_is_split(d: LoweringDiag) -> bool:
    d.kind == lowering_split()

fn diag_is_pad(d: LoweringDiag) -> bool:
    d.kind == lowering_pad()

fn diag_note(d: LoweringDiag) -> text:
    d.note
