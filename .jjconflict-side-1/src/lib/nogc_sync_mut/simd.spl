# ============================================================================
# i32x4 Intrinsics (128-bit)
# ============================================================================

extern fn rt_simd_add_i32x4(a: Vec4i, b: Vec4i) -> Vec4i
extern fn rt_simd_sub_i32x4(a: Vec4i, b: Vec4i) -> Vec4i
extern fn rt_simd_mul_i32x4(a: Vec4i, b: Vec4i) -> Vec4i
extern fn rt_simd_xor_i32x4(a: Vec4i, b: Vec4i) -> Vec4i
extern fn rt_simd_and_i32x4(a: Vec4i, b: Vec4i) -> Vec4i
extern fn rt_simd_or_i32x4(a: Vec4i, b: Vec4i) -> Vec4i
extern fn rt_simd_shl_i32x4(a: Vec4i, n: i64) -> Vec4i
extern fn rt_simd_shr_i32x4(a: Vec4i, n: i64) -> Vec4i

fn simd_add_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Add two i32x4 vectors: a + b."""
    rt_simd_add_i32x4(a, b)

fn simd_sub_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Subtract two i32x4 vectors: a - b."""
    rt_simd_sub_i32x4(a, b)

fn simd_mul_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Multiply two i32x4 vectors (element-wise): a * b."""
    rt_simd_mul_i32x4(a, b)

fn simd_xor_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Bitwise XOR of two i32x4 vectors."""
    rt_simd_xor_i32x4(a, b)

fn simd_and_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Bitwise AND of two i32x4 vectors."""
    rt_simd_and_i32x4(a, b)

fn simd_or_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Bitwise OR of two i32x4 vectors."""
    rt_simd_or_i32x4(a, b)

fn simd_shl_i32x4(a: Vec4i, n: i64) -> Vec4i:
    """Logical left-shift each lane of an i32x4 vector by n bits (n masked to 0..31)."""
    rt_simd_shl_i32x4(a, n)

fn simd_shr_i32x4(a: Vec4i, n: i64) -> Vec4i:
    """Logical right-shift each lane of an i32x4 vector by n bits (zero-fill, n masked to 0..31)."""
    rt_simd_shr_i32x4(a, n)

fn simd_rotl_i32x4(a: Vec4i, n: i64) -> Vec4i:
    """Rotate-left each lane of an i32x4 vector by n bits. Pure-Simple wrapper over shl/shr/or.
    n is masked to 0..31; rotation by 0 or 32 is identity."""
    val m = n & 31
    simd_or_i32x4(simd_shl_i32x4(a, m), simd_shr_i32x4(a, 32 - m))

fn simd_rotr_i32x4(a: Vec4i, n: i64) -> Vec4i:
    """Rotate-right each lane of an i32x4 vector by n bits. Pure-Simple wrapper over shr/shl/or.
    n is masked to 0..31; rotation by 0 or 32 is identity."""
    val m = n & 31
    simd_or_i32x4(simd_shr_i32x4(a, m), simd_shl_i32x4(a, 32 - m))

