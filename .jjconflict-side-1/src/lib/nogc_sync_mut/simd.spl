# ============================================================================
# u32x4 Intrinsics (128-bit) — FR: doc/08_tracking/feature/simd_u32x4_i64x4_intrinsics_2026-05-02.md
#
# Vec4u32 = 4 × u32 lanes (128-bit); maps to __m128i (x86 SSE2) /
# uint32x4_t (AArch64 NEON). Wrapping arithmetic per-lane; carry does NOT
# propagate across lane boundaries.
# ============================================================================

"""
4-element u32 vector (128-bit SSE/NEON register).
Maps to __m128i (x86) or uint32x4_t (ARM).
"""
struct Vec4u32:
    x: u32
    y: u32
    z: u32
    w: u32

impl Vec4u32:
    static fn splat(value: u32) -> Vec4u32:
        """Create vector with all 4 lanes set to value."""
        Vec4u32(x: value, y: value, z: value, w: value)

    static fn from_array(arr: [u32]) -> Vec4u32:
        """Create from array (must have 4+ elements)."""
        Vec4u32(x: arr[0], y: arr[1], z: arr[2], w: arr[3])

    static fn zero() -> Vec4u32:
        """Zero vector."""
        Vec4u32(x: 0u32, y: 0u32, z: 0u32, w: 0u32)

    fn to_array() -> [u32]:
        """Convert to array."""
        [self.x, self.y, self.z, self.w]

extern fn rt_simd_add_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32
extern fn rt_simd_sub_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32
extern fn rt_simd_and_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32
extern fn rt_simd_or_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32
extern fn rt_simd_xor_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32

fn simd_add_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32:
    """Lane-wise wrapping add of two u32x4 vectors."""
    rt_simd_add_u32x4(a, b)

fn simd_sub_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32:
    """Lane-wise wrapping subtract of two u32x4 vectors."""
    rt_simd_sub_u32x4(a, b)

fn simd_and_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32:
    """Bitwise AND of two u32x4 vectors."""
    rt_simd_and_u32x4(a, b)

fn simd_or_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32:
    """Bitwise OR of two u32x4 vectors."""
    rt_simd_or_u32x4(a, b)

fn simd_xor_u32x4(a: Vec4u32, b: Vec4u32) -> Vec4u32:
    """Bitwise XOR of two u32x4 vectors."""
    rt_simd_xor_u32x4(a, b)

# ============================================================================
# i64x4 Intrinsics (256-bit AVX2) — FR: doc/08_tracking/feature/simd_u32x4_i64x4_intrinsics_2026-05-02.md
#
# Vec4i64 = 4 × i64 lanes (256-bit AVX2); maps to __m256i (x86 AVX2) /
# int64x2_t×2 (AArch64 NEON pair). Wrapping arithmetic per-lane.
# Requires AVX2 on x86_64 (has_avx2() == true); falls back to scalar on ARM.
# ============================================================================

"""
4-element i64 vector (256-bit AVX2 register).
Maps to __m256i (x86 AVX2). Falls back to scalar pair on ARM.
"""
struct Vec4i64:
    x: i64
    y: i64
    z: i64
    w: i64

impl Vec4i64:
    static fn splat(value: i64) -> Vec4i64:
        """Create vector with all 4 lanes set to value."""
        Vec4i64(x: value, y: value, z: value, w: value)

    static fn from_array(arr: [i64]) -> Vec4i64:
        """Create from array (must have 4+ elements)."""
        Vec4i64(x: arr[0], y: arr[1], z: arr[2], w: arr[3])

    static fn zero() -> Vec4i64:
        """Zero vector."""
        Vec4i64(x: 0, y: 0, z: 0, w: 0)

    fn to_array() -> [i64]:
        """Convert to array."""
        [self.x, self.y, self.z, self.w]

extern fn rt_simd_add_i64x4(a: Vec4i64, b: Vec4i64) -> Vec4i64
extern fn rt_simd_sub_i64x4(a: Vec4i64, b: Vec4i64) -> Vec4i64

fn simd_add_i64x4(a: Vec4i64, b: Vec4i64) -> Vec4i64:
    """Lane-wise wrapping add of two i64x4 vectors (AVX2 _mm256_add_epi64)."""
    rt_simd_add_i64x4(a, b)

fn simd_sub_i64x4(a: Vec4i64, b: Vec4i64) -> Vec4i64:
    """Lane-wise wrapping subtract of two i64x4 vectors (AVX2 _mm256_sub_epi64)."""
    rt_simd_sub_i64x4(a, b)

# ============================================================================
# Horizontal Operations
# ============================================================================

extern fn rt_simd_hadd_f32x4(a: Vec4f) -> f32
extern fn rt_simd_hmax_f32x4(a: Vec4f) -> f32
extern fn rt_simd_hmin_f32x4(a: Vec4f) -> f32

fn simd_hadd_f32x4(a: Vec4f) -> f32:
    """Horizontal add: sum all elements of vector."""
    rt_simd_hadd_f32x4(a)

fn simd_hmax_f32x4(a: Vec4f) -> f32:
    """Horizontal max: find maximum element of vector."""
    rt_simd_hmax_f32x4(a)

fn simd_hmin_f32x4(a: Vec4f) -> f32:
    """Horizontal min: find minimum element of vector."""
    rt_simd_hmin_f32x4(a)

