# DTLS wire parsing (RFC 6347 / RFC 9147).
#
# Parsers decode big-endian using a locally-constructed ByteReader (never a
# by-value ByteReader parameter -- that loses cursor propagation). Each returns
# Result<Struct, text>; truncated input yields Err.

use std.common.net.byte_cursor.{ByteReader}
use std.nogc_sync_mut.dtls.types.{DtlsRecord12, DtlsHandshakeFragment, DtlsRecord13}
use std.nogc_sync_mut.dtls.types.{DTLS13_FLAG_CID, DTLS13_FLAG_SEQ16, DTLS13_FLAG_LENGTH}

fn parse_dtls_record12(bytes: [u8]) -> Result<DtlsRecord12, text>:
    var r = ByteReader.new(bytes)
    val ct = match r.read_u8():
        case Ok(v): v
        case Err(_): return Err("dtls12: content_type")
    val ver = match r.read_u16():
        case Ok(v): v
        case Err(_): return Err("dtls12: version")
    val epoch = match r.read_u16():
        case Ok(v): v
        case Err(_): return Err("dtls12: epoch")
    val seq = match r.read_u48():
        case Ok(v): v
        case Err(_): return Err("dtls12: sequence_number")
    val lenv = match r.read_u16():
        case Ok(v): v
        case Err(_): return Err("dtls12: length")
    val frag = match r.read_bytes(lenv.to_u64()):
        case Ok(v): v
        case Err(_): return Err("dtls12: fragment truncated")
    Ok(DtlsRecord12.new(ct, ver, epoch, seq, frag))

fn parse_dtls_handshake_fragment(bytes: [u8]) -> Result<DtlsHandshakeFragment, text>:
    var r = ByteReader.new(bytes)
    val mt = match r.read_u8():
        case Ok(v): v
        case Err(_): return Err("dtls hs: msg_type")
    val length = match r.read_u24():
        case Ok(v): v
        case Err(_): return Err("dtls hs: length")
    val mseq = match r.read_u16():
        case Ok(v): v
        case Err(_): return Err("dtls hs: message_seq")
    val foff = match r.read_u24():
        case Ok(v): v
        case Err(_): return Err("dtls hs: fragment_offset")
    val flenv = match r.read_u24():
        case Ok(v): v
        case Err(_): return Err("dtls hs: fragment_length")
    val body = match r.read_bytes(flenv.to_u64()):
        case Ok(v): v
        case Err(_): return Err("dtls hs: body truncated")
    var frag = DtlsHandshakeFragment.new(mt, length, mseq, foff, body)
    Ok(frag)

# DTLS 1.3 unified header. The connection-id length is not self-describing on
# the wire, so the caller supplies cid_len (0 if none / flag clear).
fn parse_dtls_record13(bytes: [u8], cid_len: u64) -> Result<DtlsRecord13, text>:
    var r = ByteReader.new(bytes)
    val fv = match r.read_u8():
        case Ok(v): v
        case Err(_): return Err("dtls13: flags")
    var cid: [u8] = []
    if (fv & DTLS13_FLAG_CID) != 0:
        cid = match r.read_bytes(cid_len):
            case Ok(v): v
            case Err(_): return Err("dtls13: connection_id truncated")
    var seqv: u16 = 0
    if (fv & DTLS13_FLAG_SEQ16) != 0:
        seqv = match r.read_u16():
            case Ok(v): v
            case Err(_): return Err("dtls13: seq16")
    else:
        val seq8 = match r.read_u8():
            case Ok(v): v
            case Err(_): return Err("dtls13: seq8")
        seqv = seq8.to_u16()
    var bodylen: u64 = r.remaining()
    if (fv & DTLS13_FLAG_LENGTH) != 0:
        val ln = match r.read_u16():
            case Ok(v): v
            case Err(_): return Err("dtls13: length")
        bodylen = ln.to_u64()
    val body = match r.read_bytes(bodylen):
        case Ok(v): v
        case Err(_): return Err("dtls13: encrypted_record truncated")
    var rec = DtlsRecord13.new(fv, cid, seqv, body)
    Ok(rec)
