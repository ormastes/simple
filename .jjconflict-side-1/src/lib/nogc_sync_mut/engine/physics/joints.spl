# Physics2 — 2D Joint Types
#
# Joint constraints for connecting rigid bodies: distance, revolute (hinge),
# prismatic (slider), spring, and weld joints. Each joint computes forces
# to maintain its constraint during the physics step.

use std.common.math.{math_sqrt}

# --------------------------------------------------------------------------
# Identifiers
# --------------------------------------------------------------------------

struct JointId:
    id: i32

impl JointId:
    static fn null() -> JointId:
        JointId(id: -1)

    fn is_null(self) -> bool:
        self.id < 0

struct BodyRef:
    body_id: i32

# --------------------------------------------------------------------------
# Joint force result
# --------------------------------------------------------------------------

struct JointForce:
    fx: f64
    fy: f64
    torque_a: f64
    torque_b: f64

impl JointForce:
    static fn zero() -> JointForce:
        JointForce(fx: 0.0, fy: 0.0, torque_a: 0.0, torque_b: 0.0)

# --------------------------------------------------------------------------
# Distance Joint
# --------------------------------------------------------------------------

struct DistanceJoint:
    id: JointId
    body_a: BodyRef
    body_b: BodyRef
    anchor_a_x: f64
    anchor_a_y: f64
    anchor_b_x: f64
    anchor_b_y: f64
    rest_length: f64
    stiffness: f64
    damping: f64

impl DistanceJoint:
    static fn new(body_a: BodyRef, body_b: BodyRef, rest_length: f64) -> DistanceJoint:
        DistanceJoint(
            id: JointId.null(),
            body_a: body_a,
            body_b: body_b,
            anchor_a_x: 0.0, anchor_a_y: 0.0,
            anchor_b_x: 0.0, anchor_b_y: 0.0,
            rest_length: rest_length,
            stiffness: 1.0,
            damping: 0.0
        )

    fn compute_force(self, pos_a_x: f64, pos_a_y: f64, pos_b_x: f64, pos_b_y: f64) -> JointForce:
        val dx = (pos_b_x + self.anchor_b_x) - (pos_a_x + self.anchor_a_x)
        val dy = (pos_b_y + self.anchor_b_y) - (pos_a_y + self.anchor_a_y)
        val dist = math_sqrt(dx * dx + dy * dy)
        if dist < 0.0001:
            return JointForce.zero()
        val inv_dist = 1.0 / dist
        val nx = dx * inv_dist
        val ny = dy * inv_dist
        val stretch = dist - self.rest_length
        val force_mag = stretch * self.stiffness
        val fx = nx * force_mag
        val fy = ny * force_mag
        JointForce(fx: fx, fy: fy, torque_a: 0.0, torque_b: 0.0)

# --------------------------------------------------------------------------
# Revolute (Hinge) Joint
# --------------------------------------------------------------------------

struct RevoluteJoint:
    id: JointId
    body_a: BodyRef
    body_b: BodyRef
    anchor_x: f64
    anchor_y: f64
    enable_limit: bool
    lower_angle: f64
    upper_angle: f64
    enable_motor: bool
    motor_speed: f64
    max_motor_torque: f64

impl RevoluteJoint:
    static fn new(body_a: BodyRef, body_b: BodyRef, anchor_x: f64, anchor_y: f64) -> RevoluteJoint:
        RevoluteJoint(
            id: JointId.null(),
            body_a: body_a,
            body_b: body_b,
            anchor_x: anchor_x,
            anchor_y: anchor_y,
            enable_limit: false,
            lower_angle: 0.0,
            upper_angle: 0.0,
            enable_motor: false,
            motor_speed: 0.0,
            max_motor_torque: 0.0
        )

    static fn with_limits(body_a: BodyRef, body_b: BodyRef, anchor_x: f64, anchor_y: f64, lower: f64, upper: f64) -> RevoluteJoint:
        RevoluteJoint(
            id: JointId.null(),
            body_a: body_a,
            body_b: body_b,
            anchor_x: anchor_x,
            anchor_y: anchor_y,
            enable_limit: true,
            lower_angle: lower,
            upper_angle: upper,
            enable_motor: false,
            motor_speed: 0.0,
            max_motor_torque: 0.0
        )

    static fn with_motor(body_a: BodyRef, body_b: BodyRef, anchor_x: f64, anchor_y: f64, speed: f64, max_torque: f64) -> RevoluteJoint:
        RevoluteJoint(
            id: JointId.null(),
            body_a: body_a,
            body_b: body_b,
            anchor_x: anchor_x,
            anchor_y: anchor_y,
            enable_limit: false,
            lower_angle: 0.0,
            upper_angle: 0.0,
            enable_motor: true,
            motor_speed: speed,
            max_motor_torque: max_torque
        )

# --------------------------------------------------------------------------
# Prismatic (Slider) Joint
# --------------------------------------------------------------------------

struct PrismaticJoint:
    id: JointId
    body_a: BodyRef
    body_b: BodyRef
    anchor_x: f64
    anchor_y: f64
    axis_x: f64
    axis_y: f64
    enable_limit: bool
    lower_translation: f64
    upper_translation: f64
    enable_motor: bool
    motor_speed: f64
    max_motor_force: f64

impl PrismaticJoint:
    static fn new(body_a: BodyRef, body_b: BodyRef, anchor_x: f64, anchor_y: f64, axis_x: f64, axis_y: f64) -> PrismaticJoint:
        # Normalize the axis
        val len = math_sqrt(axis_x * axis_x + axis_y * axis_y)
        var norm_x = axis_x
        var norm_y = axis_y
        if len > 0.0001:
            norm_x = axis_x / len
            norm_y = axis_y / len
        PrismaticJoint(
            id: JointId.null(),
            body_a: body_a,
            body_b: body_b,
            anchor_x: anchor_x,
            anchor_y: anchor_y,
            axis_x: norm_x,
            axis_y: norm_y,
            enable_limit: false,
            lower_translation: 0.0,
            upper_translation: 0.0,
            enable_motor: false,
            motor_speed: 0.0,
            max_motor_force: 0.0
        )

# --------------------------------------------------------------------------
# Spring Joint
# --------------------------------------------------------------------------

struct SpringJoint:
    id: JointId
    body_a: BodyRef
    body_b: BodyRef
    anchor_a_x: f64
    anchor_a_y: f64
    anchor_b_x: f64
    anchor_b_y: f64
    rest_length: f64
    stiffness: f64
    damping: f64

impl SpringJoint:
    static fn new(body_a: BodyRef, body_b: BodyRef, stiffness: f64, damping: f64) -> SpringJoint:
        SpringJoint(
            id: JointId.null(),
            body_a: body_a,
            body_b: body_b,
            anchor_a_x: 0.0, anchor_a_y: 0.0,
            anchor_b_x: 0.0, anchor_b_y: 0.0,
            rest_length: 0.0,
            stiffness: stiffness,
            damping: damping
        )

    fn compute_spring_force(self, pos_a_x: f64, pos_a_y: f64, pos_b_x: f64, pos_b_y: f64) -> JointForce:
        val ax = pos_a_x + self.anchor_a_x
        val ay = pos_a_y + self.anchor_a_y
        val bx = pos_b_x + self.anchor_b_x
        val by = pos_b_y + self.anchor_b_y
        val dx = bx - ax
        val dy = by - ay
        val dist = math_sqrt(dx * dx + dy * dy)
        if dist < 0.0001:
            return JointForce.zero()
        val inv_dist = 1.0 / dist
        val nx = dx * inv_dist
        val ny = dy * inv_dist
        # Hooke's law: F = -k * (x - rest) - c * v_along_spring
        val stretch = dist - self.rest_length
        val spring_force = self.stiffness * stretch
        # Damping approximation (velocity would need body velocities;
        # here we apply pure positional spring force)
        val fx = nx * spring_force
        val fy = ny * spring_force
        JointForce(fx: fx, fy: fy, torque_a: 0.0, torque_b: 0.0)

# --------------------------------------------------------------------------
# Weld Joint
# --------------------------------------------------------------------------

struct WeldJoint:
    id: JointId
    body_a: BodyRef
    body_b: BodyRef
    anchor_x: f64
    anchor_y: f64
    reference_angle: f64
    stiffness: f64
    damping: f64

impl WeldJoint:
    static fn new(body_a: BodyRef, body_b: BodyRef, anchor_x: f64, anchor_y: f64) -> WeldJoint:
        WeldJoint(
            id: JointId.null(),
            body_a: body_a,
            body_b: body_b,
            anchor_x: anchor_x,
            anchor_y: anchor_y,
            reference_angle: 0.0,
            stiffness: 0.0,
            damping: 0.0
        )

# --------------------------------------------------------------------------
# Joint Type Enum & Registry
# --------------------------------------------------------------------------

enum JointType:
    DistanceType
    RevoluteType
    PrismaticType
    SpringType
    WeldType

struct JointEntry:
    joint_type: JointType
    joint_id: JointId
    body_a_id: i32
    body_b_id: i32
    active: bool

class JointRegistry:
    entries: [JointEntry]
    distances: [DistanceJoint]
    revolutes: [RevoluteJoint]
    prismatics: [PrismaticJoint]
    springs: [SpringJoint]
    welds: [WeldJoint]
    next_id: i32

impl JointRegistry:
    static fn new() -> JointRegistry:
        JointRegistry(
            entries: [],
            distances: [],
            revolutes: [],
            prismatics: [],
            springs: [],
            welds: [],
            next_id: 0
        )

    me add_distance(joint: DistanceJoint) -> JointId:
        val jid = JointId(id: self.next_id)
        self.next_id = self.next_id + 1
        var j = joint
        j = DistanceJoint(
            id: jid,
            body_a: j.body_a, body_b: j.body_b,
            anchor_a_x: j.anchor_a_x, anchor_a_y: j.anchor_a_y,
            anchor_b_x: j.anchor_b_x, anchor_b_y: j.anchor_b_y,
            rest_length: j.rest_length,
            stiffness: j.stiffness, damping: j.damping
        )
        self.distances.push(j)
        val entry = JointEntry(
            joint_type: JointType.DistanceType,
            joint_id: jid,
            body_a_id: joint.body_a.body_id,
            body_b_id: joint.body_b.body_id,
            active: true
        )
        self.entries.push(entry)
        jid

    me add_revolute(joint: RevoluteJoint) -> JointId:
        val jid = JointId(id: self.next_id)
        self.next_id = self.next_id + 1
        var j = joint
        j = RevoluteJoint(
            id: jid,
            body_a: j.body_a, body_b: j.body_b,
            anchor_x: j.anchor_x, anchor_y: j.anchor_y,
            enable_limit: j.enable_limit,
            lower_angle: j.lower_angle, upper_angle: j.upper_angle,
            enable_motor: j.enable_motor,
            motor_speed: j.motor_speed,
            max_motor_torque: j.max_motor_torque
        )
        self.revolutes.push(j)
        val entry = JointEntry(
            joint_type: JointType.RevoluteType,
            joint_id: jid,
            body_a_id: joint.body_a.body_id,
            body_b_id: joint.body_b.body_id,
            active: true
        )
        self.entries.push(entry)
        jid

    me add_prismatic(joint: PrismaticJoint) -> JointId:
        val jid = JointId(id: self.next_id)
        self.next_id = self.next_id + 1
        var j = joint
        j = PrismaticJoint(
            id: jid,
            body_a: j.body_a, body_b: j.body_b,
            anchor_x: j.anchor_x, anchor_y: j.anchor_y,
            axis_x: j.axis_x, axis_y: j.axis_y,
            enable_limit: j.enable_limit,
            lower_translation: j.lower_translation,
            upper_translation: j.upper_translation,
            enable_motor: j.enable_motor,
            motor_speed: j.motor_speed,
            max_motor_force: j.max_motor_force
        )
        self.prismatics.push(j)
        val entry = JointEntry(
            joint_type: JointType.PrismaticType,
            joint_id: jid,
            body_a_id: joint.body_a.body_id,
            body_b_id: joint.body_b.body_id,
            active: true
        )
        self.entries.push(entry)
        jid

    me add_spring(joint: SpringJoint) -> JointId:
        val jid = JointId(id: self.next_id)
        self.next_id = self.next_id + 1
        var j = joint
        j = SpringJoint(
            id: jid,
            body_a: j.body_a, body_b: j.body_b,
            anchor_a_x: j.anchor_a_x, anchor_a_y: j.anchor_a_y,
            anchor_b_x: j.anchor_b_x, anchor_b_y: j.anchor_b_y,
            rest_length: j.rest_length,
            stiffness: j.stiffness, damping: j.damping
        )
        self.springs.push(j)
        val entry = JointEntry(
            joint_type: JointType.SpringType,
            joint_id: jid,
            body_a_id: joint.body_a.body_id,
            body_b_id: joint.body_b.body_id,
            active: true
        )
        self.entries.push(entry)
        jid

    me add_weld(joint: WeldJoint) -> JointId:
        val jid = JointId(id: self.next_id)
        self.next_id = self.next_id + 1
        var j = joint
        j = WeldJoint(
            id: jid,
            body_a: j.body_a, body_b: j.body_b,
            anchor_x: j.anchor_x, anchor_y: j.anchor_y,
            reference_angle: j.reference_angle,
            stiffness: j.stiffness, damping: j.damping
        )
        self.welds.push(j)
        val entry = JointEntry(
            joint_type: JointType.WeldType,
            joint_id: jid,
            body_a_id: joint.body_a.body_id,
            body_b_id: joint.body_b.body_id,
            active: true
        )
        self.entries.push(entry)
        jid

    me remove_joint(id: JointId):
        var i = 0
        while i < self.entries.len():
            val e = self.entries[i]
            if e.joint_id.id == id.id:
                self.entries[i] = JointEntry(
                    joint_type: e.joint_type,
                    joint_id: e.joint_id,
                    body_a_id: e.body_a_id,
                    body_b_id: e.body_b_id,
                    active: false
                )
            i = i + 1

    me remove_joints_for_body(body_id: i32):
        var i = 0
        while i < self.entries.len():
            val e = self.entries[i]
            if (e.body_a_id == body_id or e.body_b_id == body_id) and e.active:
                self.entries[i] = JointEntry(
                    joint_type: e.joint_type,
                    joint_id: e.joint_id,
                    body_a_id: e.body_a_id,
                    body_b_id: e.body_b_id,
                    active: false
                )
            i = i + 1

    fn joints_for_body(self, body_id: i32) -> [JointEntry]:
        var result: [JointEntry] = []
        var i = 0
        while i < self.entries.len():
            val e = self.entries[i]
            if e.active and (e.body_a_id == body_id or e.body_b_id == body_id):
                result.push(e)
            i = i + 1
        result

    fn joint_count(self) -> i32:
        var count: i32 = 0
        var i = 0
        while i < self.entries.len():
            if self.entries[i].active:
                count = count + 1
            i = i + 1
        count
