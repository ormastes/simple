# Physics System — 2D Contact Resolution
#
# Impulse-based collision response with friction and restitution.
# Includes Baumgarte position correction to prevent sinking.
#
# Usage (internal):
#   resolve_contact(body_a, body_b, contact, 0.3, 0.4)

use std.common.engine.math2d.{Vec2}
use std.common.math.{math_abs}
use std.nogc_sync_mut.engine.physics.body2d.{InternalBody2D}
use std.nogc_sync_mut.engine.physics.collision2d.{Contact2D}

# ============================================================================
# resolve_contact — impulse-based collision response
# ============================================================================

fn resolve_contact(body_a: InternalBody2D, body_b: InternalBody2D, contact: Contact2D, restitution: f64, friction: f64):
    """Resolve a collision contact between two internal bodies.

    Applies normal impulse, tangent friction impulse (Coulomb clamped),
    and Baumgarte position correction. Mutates both bodies' velocities
    and positions.
    """
    # Skip if both bodies are immovable
    if body_a.inv_mass == 0.0 and body_b.inv_mass == 0.0:
        return

    val n = contact.normal

    # Relative velocity at contact point
    # For 2D with angular velocity we compute:
    #   v_contact = v_linear + omega x r
    # In 2D, omega x r = omega * (-ry, rx) where r is vector from center to contact
    val ra = contact.point.sub(body_a.position)
    val rb = contact.point.sub(body_b.position)

    # Cross product in 2D: omega x r = (-omega*ry, omega*rx)
    val va_x = body_a.velocity.x + (-body_a.angular_velocity * ra.y)
    val va_y = body_a.velocity.y + (body_a.angular_velocity * ra.x)
    val vb_x = body_b.velocity.x + (-body_b.angular_velocity * rb.y)
    val vb_y = body_b.velocity.y + (body_b.angular_velocity * rb.x)

    val rel_vx = vb_x - va_x
    val rel_vy = vb_y - va_y

    # Velocity along normal
    val v_along_n = rel_vx * n.x + rel_vy * n.y

    # Skip if separating
    if v_along_n > 0.0:
        return

    # Compute angular contribution: (r x n)^2 * inv_inertia
    val ra_cross_n = ra.x * n.y - ra.y * n.x
    val rb_cross_n = rb.x * n.y - rb.y * n.x

    val inv_mass_sum = body_a.inv_mass + body_b.inv_mass + ra_cross_n * ra_cross_n * body_a.inv_inertia + rb_cross_n * rb_cross_n * body_b.inv_inertia

    if inv_mass_sum == 0.0:
        return

    # Normal impulse magnitude
    val j = -(1.0 + restitution) * v_along_n / inv_mass_sum

    # Apply normal impulse
    val impulse_x = n.x * j
    val impulse_y = n.y * j
    val impulse = Vec2(x: impulse_x, y: impulse_y)
    val neg_impulse = Vec2(x: -impulse_x, y: -impulse_y)

    body_a.apply_impulse(neg_impulse)
    body_a.angular_velocity = body_a.angular_velocity - ra_cross_n * j * body_a.inv_inertia

    body_b.apply_impulse(impulse)
    body_b.angular_velocity = body_b.angular_velocity + rb_cross_n * j * body_b.inv_inertia

    # ------------------------------------------------------------------
    # Friction impulse (tangent direction)
    # ------------------------------------------------------------------
    val tangent_x = rel_vx - v_along_n * n.x
    val tangent_y = rel_vy - v_along_n * n.y
    val tangent_len = tangent_x * tangent_x + tangent_y * tangent_y

    if tangent_len > 0.0000001:
        # Normalize tangent using manual sqrt (import would add dependency)
        var tl = tangent_len
        var i = 0
        while i < 10:
            tl = (tl + tangent_len / tl) / 2.0
            i = i + 1
        val tx = tangent_x / tl
        val ty = tangent_y / tl

        # Tangent impulse
        val ra_cross_t = ra.x * ty - ra.y * tx
        val rb_cross_t = rb.x * ty - rb.y * tx
        val inv_mass_sum_t = body_a.inv_mass + body_b.inv_mass + ra_cross_t * ra_cross_t * body_a.inv_inertia + rb_cross_t * rb_cross_t * body_b.inv_inertia

        if inv_mass_sum_t > 0.0:
            val jt_raw = -(rel_vx * tx + rel_vy * ty) / inv_mass_sum_t

            # Coulomb clamp: |jt| <= |j| * friction
            val max_friction = math_abs(j) * friction
            var jt = jt_raw
            if jt > max_friction:
                jt = max_friction
            if jt < -max_friction:
                jt = -max_friction

            val friction_impulse = Vec2(x: tx * jt, y: ty * jt)
            val neg_friction_impulse = Vec2(x: -tx * jt, y: -ty * jt)

            body_a.apply_impulse(neg_friction_impulse)
            body_a.angular_velocity = body_a.angular_velocity - ra_cross_t * jt * body_a.inv_inertia

            body_b.apply_impulse(friction_impulse)
            body_b.angular_velocity = body_b.angular_velocity + rb_cross_t * jt * body_b.inv_inertia

    # ------------------------------------------------------------------
    # Baumgarte position correction (prevent sinking)
    # ------------------------------------------------------------------
    val slop = 0.01
    val correction_percent = 0.2

    if contact.penetration > slop:
        val correction_mag = (contact.penetration - slop) / (body_a.inv_mass + body_b.inv_mass) * correction_percent
        val correction = Vec2(x: n.x * correction_mag, y: n.y * correction_mag)

        if body_a.inv_mass > 0.0:
            val ca = correction.mul_scalar(body_a.inv_mass)
            body_a.position = body_a.position.sub(ca)

        if body_b.inv_mass > 0.0:
            val cb = correction.mul_scalar(body_b.inv_mass)
            body_b.position = body_b.position.add(cb)
