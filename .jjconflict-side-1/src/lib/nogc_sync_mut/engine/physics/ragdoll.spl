# Physics2 — Ragdoll System
#
# Ragdoll physics using the existing joints/physics infrastructure.
# Each ragdoll consists of bones (rigid bodies) connected by
# angle-constrained joints.

# --------------------------------------------------------------------------
# RagdollBone — a single bone in the ragdoll
# --------------------------------------------------------------------------

struct RagdollBone:
    name: text
    bone_index: i32
    body_id: i32
    mass: f64
    length: f64

# --------------------------------------------------------------------------
# RagdollJoint — constraint between two bones
# --------------------------------------------------------------------------

struct RagdollJoint:
    parent_bone: i32
    child_bone: i32
    min_angle: f64
    max_angle: f64

# --------------------------------------------------------------------------
# Ragdoll — bone/joint collection with activation state
# --------------------------------------------------------------------------

class Ragdoll:
    bones: [RagdollBone]
    joints: [RagdollJoint]
    active: bool
    name: text

impl Ragdoll:
    static fn new(name: text) -> Ragdoll:
        Ragdoll(
            bones: [],
            joints: [],
            active: false,
            name: name
        )

    me add_bone(name: text, bone_index: i32, body_id: i32, mass: f64, length: f64) -> i32:
        val idx: i32 = self.bones.len()
        val bone = RagdollBone(
            name: name,
            bone_index: bone_index,
            body_id: body_id,
            mass: mass,
            length: length
        )
        self.bones.push(bone)
        idx

    me add_joint(parent_bone: i32, child_bone: i32, min_angle: f64, max_angle: f64) -> i32:
        val idx: i32 = self.joints.len()
        val joint = RagdollJoint(
            parent_bone: parent_bone,
            child_bone: child_bone,
            min_angle: min_angle,
            max_angle: max_angle
        )
        self.joints.push(joint)
        idx

    me activate():
        self.active = true

    me deactivate():
        self.active = false

    fn is_active() -> bool:
        self.active

    fn bone_count() -> i32:
        self.bones.len()

    fn joint_count() -> i32:
        self.joints.len()

    fn get_bone(index: i32) -> RagdollBone?:
        if index < 0:
            return nil
        if index >= self.bones.len():
            return nil
        self.bones[index]

    fn total_mass() -> f64:
        var sum = 0.0
        var i = 0
        while i < self.bones.len():
            sum = sum + self.bones[i].mass
            i = i + 1
        sum
