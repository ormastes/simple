# Physics2 — Physics Materials
#
# Surface properties for collision response: friction, restitution, density.
# Includes preset materials and combine-rule logic for contact pair resolution.

# --------------------------------------------------------------------------
# Combine rule
# --------------------------------------------------------------------------

enum CombineRule:
    Average
    Minimum
    Maximum
    Multiply

# --------------------------------------------------------------------------
# Physics material
# --------------------------------------------------------------------------

struct PhysicsMaterial:
    friction: f64
    restitution: f64
    density: f64
    friction_combine: CombineRule
    restitution_combine: CombineRule

impl PhysicsMaterial:
    static fn default_material() -> PhysicsMaterial:
        PhysicsMaterial(
            friction: 0.3,
            restitution: 0.2,
            density: 1.0,
            friction_combine: CombineRule.Average,
            restitution_combine: CombineRule.Average
        )

    static fn ice() -> PhysicsMaterial:
        PhysicsMaterial(
            friction: 0.02,
            restitution: 0.1,
            density: 0.92,
            friction_combine: CombineRule.Minimum,
            restitution_combine: CombineRule.Average
        )

    static fn rubber() -> PhysicsMaterial:
        PhysicsMaterial(
            friction: 0.8,
            restitution: 0.8,
            density: 1.1,
            friction_combine: CombineRule.Maximum,
            restitution_combine: CombineRule.Maximum
        )

    static fn metal() -> PhysicsMaterial:
        PhysicsMaterial(
            friction: 0.4,
            restitution: 0.3,
            density: 7.8,
            friction_combine: CombineRule.Average,
            restitution_combine: CombineRule.Average
        )

    static fn wood() -> PhysicsMaterial:
        PhysicsMaterial(
            friction: 0.5,
            restitution: 0.4,
            density: 0.6,
            friction_combine: CombineRule.Average,
            restitution_combine: CombineRule.Average
        )

    static fn bouncy() -> PhysicsMaterial:
        PhysicsMaterial(
            friction: 0.3,
            restitution: 0.95,
            density: 1.0,
            friction_combine: CombineRule.Average,
            restitution_combine: CombineRule.Maximum
        )

# --------------------------------------------------------------------------
# Combine functions
# --------------------------------------------------------------------------

fn combine_values(a: f64, b: f64, rule: CombineRule) -> f64:
    if rule == CombineRule.Average:
        return (a + b) * 0.5
    if rule == CombineRule.Minimum:
        if a < b:
            return a
        return b
    if rule == CombineRule.Maximum:
        if a > b:
            return a
        return b
    # Multiply
    a * b

fn compute_contact_friction(mat_a: PhysicsMaterial, mat_b: PhysicsMaterial) -> f64:
    # Use the higher-priority combine rule between the two materials.
    # Priority order: Average < Minimum < Maximum < Multiply
    val rule = _higher_priority_rule(mat_a.friction_combine, mat_b.friction_combine)
    combine_values(mat_a.friction, mat_b.friction, rule)

fn compute_contact_restitution(mat_a: PhysicsMaterial, mat_b: PhysicsMaterial) -> f64:
    val rule = _higher_priority_rule(mat_a.restitution_combine, mat_b.restitution_combine)
    combine_values(mat_a.restitution, mat_b.restitution, rule)

fn _rule_priority(rule: CombineRule) -> i32:
    match rule:
        CombineRule.Average => 0
        CombineRule.Minimum => 1
        CombineRule.Maximum => 2
        CombineRule.Multiply => 3

fn _higher_priority_rule(a: CombineRule, b: CombineRule) -> CombineRule:
    val pa = _rule_priority(a)
    val pb = _rule_priority(b)
    if pa >= pb:
        a
    else:
        b
