# Physics System — 3D Core Types
#
# Data types for the 3D physics system. These map engine NodeIds
# to internal body/collider array indices for the pure Simple
# 3D physics engine (no FFI).
#
# Usage:
#   val config = default_physics_config_3d()
#   val body = PhysicsBody3D(node_id: my_node, body_index: 0, body_type_code: 2, gravity_scale: 1.0)

use std.common.engine.ids.{NodeId}
use std.common.engine.math3d.{Vec3}
use std.common.engine.units.{Seconds, Distance}

# ============================================================================
# PhysicsConfig3D — World simulation parameters
# ============================================================================

struct PhysicsConfig3D:
    gravity: Vec3
    fixed_timestep: Seconds
    sleep_enabled: bool

fn default_physics_config_3d() -> PhysicsConfig3D:
    PhysicsConfig3D(
        gravity: Vec3(x: 0.0, y: -9.81, z: 0.0),
        fixed_timestep: Seconds(value: 0.016666666666666666),
        sleep_enabled: true
    )

# ============================================================================
# PhysicsBody3D — Maps a scene node to an internal rigid body
# ============================================================================

struct PhysicsBody3D:
    node_id: NodeId
    body_index: i64
    body_type_code: i64      # 0 = static, 1 = kinematic, 2 = dynamic
    gravity_scale: f64

impl PhysicsBody3D:
    fn is_static() -> bool:
        self.body_type_code == 0

    fn is_kinematic() -> bool:
        self.body_type_code == 1

    fn is_dynamic() -> bool:
        self.body_type_code == 2

# ============================================================================
# PhysicsCollider3D — Maps a scene node to an internal collider shape
# ============================================================================

struct PhysicsCollider3D:
    node_id: NodeId
    collider_index: i64
    shape_code: i64     # 0 = sphere, 1 = box, 2 = capsule
    is_sensor: bool

# ============================================================================
# CollisionEvent3D — Emitted when two bodies contact or separate
# ============================================================================

struct CollisionEvent3D:
    node_a: NodeId
    node_b: NodeId
    normal: Vec3
    depth: Distance
    is_sensor: bool

impl CollisionEvent3D:
    fn to_string() -> text:
        val a_idx = self.node_a.to_index()
        val b_idx = self.node_b.to_index()
        val d = self.depth.value
        "CollisionEvent3D(a={a_idx}, b={b_idx}, depth={d})"

# ============================================================================
# RaycastHit3D — Result from a physics raycast query
# ============================================================================

struct RaycastHit3D:
    node_id: NodeId
    point: Vec3
    normal: Vec3
    distance: Distance

impl RaycastHit3D:
    fn to_string() -> text:
        val idx = self.node_id.to_index()
        val dist = self.distance.value
        "RaycastHit3D(node={idx}, dist={dist})"
