#![allow(unnamed_duplicate_typed_args)]
# Physics System — 3D Debug Drawing
#
# Generates wireframe geometry for all 3D physics colliders in the world.
# Reads body positions directly from internal bodies (no FFI).
# The caller can render these lines as an overlay for visual debugging.
#
# Usage:
#   val debug = physics_debug_draw_3d(world)
#   for line in debug.lines:
#       draw_line_3d(line.start, line.end_point, color_green)

use std.common.engine.math3d.{Vec3, Quaternion, _sin, _cos}
use std.common.math.{MATH_PI}
use std.nogc_sync_mut.engine.physics.world3d.{PhysicsWorld3D}

# ============================================================================
# Debug Draw Types
# ============================================================================

struct DebugLine3D:
    start: Vec3
    end_point: Vec3

impl DebugLine3D:
    fn to_string() -> text:
        "Line3D({self.start.x},{self.start.y},{self.start.z} -> {self.end_point.x},{self.end_point.y},{self.end_point.z})"

struct PhysicsDebugData3D:
    lines: [DebugLine3D]

impl PhysicsDebugData3D:
    fn line_count() -> i64:
        self.lines.len()

# ============================================================================
# Debug Draw Generation
# ============================================================================

val _CIRCLE_SEGMENTS_3D = 16

fn physics_debug_draw_3d(world: PhysicsWorld3D) -> PhysicsDebugData3D:
    """Generate wireframe lines for all 3D colliders in the physics world.

    Sphere: 3 orthogonal circles (XY, XZ, YZ planes), 16 segments each.
    Box: 12 edges from 8 corners.
    Capsule: cylinder wireframe + hemisphere outlines.
    """
    var lines: [DebugLine3D] = []

    for pb in world.bodies:
        val ib = world.internal_bodies[pb.body_index]
        val pos = ib.position
        val rot = ib.rotation

        # Find colliders for this body
        for col in world.colliders:
            if col.node_id.eq(pb.node_id):
                val shape = world.shapes[col.collider_index]

                if shape.is_sphere():
                    val sphere_lines = _draw_sphere(pos, rot, shape.sphere.radius)
                    for ln in sphere_lines:
                        lines.push(ln)

                if shape.is_box():
                    val box_lines = _draw_box_3d(pos, rot, shape.box_shape.half_x, shape.box_shape.half_y, shape.box_shape.half_z)
                    for ln in box_lines:
                        lines.push(ln)

                if shape.is_capsule():
                    val cap_lines = _draw_capsule(pos, rot, shape.capsule.radius, shape.capsule.half_height)
                    for ln in cap_lines:
                        lines.push(ln)

    PhysicsDebugData3D(lines: lines)

# ============================================================================
# Shape Wireframe Generators
# ============================================================================

fn _draw_circle_on_plane(center: Vec3, rot: Quaternion, radius: f64, axis1: Vec3, axis2: Vec3) -> [DebugLine3D]:
    """Draw a circle in the plane defined by two axes, rotated by quaternion."""
    var lines: [DebugLine3D] = []
    val step = 2.0 * MATH_PI / _CIRCLE_SEGMENTS_3D.to_f64()

    val r_axis1 = rot.rotate_vector(axis1)
    val r_axis2 = rot.rotate_vector(axis2)

    var prev = Vec3(
        x: center.x + r_axis1.x * radius,
        y: center.y + r_axis1.y * radius,
        z: center.z + r_axis1.z * radius
    )

    var i = 1
    while i <= _CIRCLE_SEGMENTS_3D:
        val angle = step * i.to_f64()
        val c = _cos(angle)
        val s = _sin(angle)
        val cur = Vec3(
            x: center.x + (r_axis1.x * c + r_axis2.x * s) * radius,
            y: center.y + (r_axis1.y * c + r_axis2.y * s) * radius,
            z: center.z + (r_axis1.z * c + r_axis2.z * s) * radius
        )
        lines.push(DebugLine3D(start: prev, end_point: cur))
        prev = cur
        i = i + 1

    lines

fn _draw_sphere(center: Vec3, rot: Quaternion, radius: f64) -> [DebugLine3D]:
    """Generate 3 orthogonal circles for sphere wireframe."""
    var lines: [DebugLine3D] = []

    # XY plane circle
    val xy_lines = _draw_circle_on_plane(center, rot, radius, Vec3(x: 1.0, y: 0.0, z: 0.0), Vec3(x: 0.0, y: 1.0, z: 0.0))
    for ln in xy_lines:
        lines.push(ln)

    # XZ plane circle
    val xz_lines = _draw_circle_on_plane(center, rot, radius, Vec3(x: 1.0, y: 0.0, z: 0.0), Vec3(x: 0.0, y: 0.0, z: 1.0))
    for ln in xz_lines:
        lines.push(ln)

    # YZ plane circle
    val yz_lines = _draw_circle_on_plane(center, rot, radius, Vec3(x: 0.0, y: 1.0, z: 0.0), Vec3(x: 0.0, y: 0.0, z: 1.0))
    for ln in yz_lines:
        lines.push(ln)

    lines

fn _draw_box_3d(center: Vec3, rot: Quaternion, hx: f64, hy: f64, hz: f64) -> [DebugLine3D]:
    """Generate 12 edges for a rotated 3D box."""
    var lines: [DebugLine3D] = []

    # 8 corners in local space
    val local_corners: [(f64, f64, f64)] = [
        (-hx, -hy, -hz), (hx, -hy, -hz), (hx, hy, -hz), (-hx, hy, -hz),
        (-hx, -hy, hz),  (hx, -hy, hz),  (hx, hy, hz),  (-hx, hy, hz)
    ]

    # Transform corners to world space
    var world_corners: [Vec3] = []
    var i = 0
    while i < 8:
        val lc = local_corners[i]
        val local = Vec3(x: lc.0, y: lc.1, z: lc.2)
        val rotated = rot.rotate_vector(local)
        val world = Vec3(x: center.x + rotated.x, y: center.y + rotated.y, z: center.z + rotated.z)
        world_corners.push(world)
        i = i + 1

    # 12 edges: 4 bottom, 4 top, 4 vertical
    # Bottom face: 0-1, 1-2, 2-3, 3-0
    lines.push(DebugLine3D(start: world_corners[0], end_point: world_corners[1]))
    lines.push(DebugLine3D(start: world_corners[1], end_point: world_corners[2]))
    lines.push(DebugLine3D(start: world_corners[2], end_point: world_corners[3]))
    lines.push(DebugLine3D(start: world_corners[3], end_point: world_corners[0]))
    # Top face: 4-5, 5-6, 6-7, 7-4
    lines.push(DebugLine3D(start: world_corners[4], end_point: world_corners[5]))
    lines.push(DebugLine3D(start: world_corners[5], end_point: world_corners[6]))
    lines.push(DebugLine3D(start: world_corners[6], end_point: world_corners[7]))
    lines.push(DebugLine3D(start: world_corners[7], end_point: world_corners[4]))
    # Vertical edges: 0-4, 1-5, 2-6, 3-7
    lines.push(DebugLine3D(start: world_corners[0], end_point: world_corners[4]))
    lines.push(DebugLine3D(start: world_corners[1], end_point: world_corners[5]))
    lines.push(DebugLine3D(start: world_corners[2], end_point: world_corners[6]))
    lines.push(DebugLine3D(start: world_corners[3], end_point: world_corners[7]))

    lines

fn _draw_capsule(center: Vec3, rot: Quaternion, radius: f64, half_height: f64) -> [DebugLine3D]:
    """Generate wireframe for a capsule (cylinder + hemisphere outlines)."""
    var lines: [DebugLine3D] = []

    # Capsule axis is local Y
    val axis = rot.rotate_vector(Vec3(x: 0.0, y: 1.0, z: 0.0))
    val top = Vec3(x: center.x + axis.x * half_height, y: center.y + axis.y * half_height, z: center.z + axis.z * half_height)
    val bottom = Vec3(x: center.x - axis.x * half_height, y: center.y - axis.y * half_height, z: center.z - axis.z * half_height)

    # Draw circles at top and bottom of cylinder
    val top_circle = _draw_circle_on_plane(top, rot, radius, Vec3(x: 1.0, y: 0.0, z: 0.0), Vec3(x: 0.0, y: 0.0, z: 1.0))
    for ln in top_circle:
        lines.push(ln)

    val bottom_circle = _draw_circle_on_plane(bottom, rot, radius, Vec3(x: 1.0, y: 0.0, z: 0.0), Vec3(x: 0.0, y: 0.0, z: 1.0))
    for ln in bottom_circle:
        lines.push(ln)

    # Draw 4 vertical lines connecting top and bottom circles
    val local_x = rot.rotate_vector(Vec3(x: 1.0, y: 0.0, z: 0.0))
    val local_z = rot.rotate_vector(Vec3(x: 0.0, y: 0.0, z: 1.0))

    val t0 = Vec3(x: top.x + local_x.x * radius, y: top.y + local_x.y * radius, z: top.z + local_x.z * radius)
    val b0 = Vec3(x: bottom.x + local_x.x * radius, y: bottom.y + local_x.y * radius, z: bottom.z + local_x.z * radius)
    lines.push(DebugLine3D(start: t0, end_point: b0))

    val t1 = Vec3(x: top.x - local_x.x * radius, y: top.y - local_x.y * radius, z: top.z - local_x.z * radius)
    val b1 = Vec3(x: bottom.x - local_x.x * radius, y: bottom.y - local_x.y * radius, z: bottom.z - local_x.z * radius)
    lines.push(DebugLine3D(start: t1, end_point: b1))

    val t2 = Vec3(x: top.x + local_z.x * radius, y: top.y + local_z.y * radius, z: top.z + local_z.z * radius)
    val b2 = Vec3(x: bottom.x + local_z.x * radius, y: bottom.y + local_z.y * radius, z: bottom.z + local_z.z * radius)
    lines.push(DebugLine3D(start: t2, end_point: b2))

    val t3 = Vec3(x: top.x - local_z.x * radius, y: top.y - local_z.y * radius, z: top.z - local_z.z * radius)
    val b3 = Vec3(x: bottom.x - local_z.x * radius, y: bottom.y - local_z.y * radius, z: bottom.z - local_z.z * radius)
    lines.push(DebugLine3D(start: t3, end_point: b3))

    # Draw hemisphere outlines (half-circles on XY and ZY planes at top and bottom)
    val hemi_top_xy = _draw_half_circle(top, rot, radius, Vec3(x: 1.0, y: 0.0, z: 0.0), Vec3(x: 0.0, y: 1.0, z: 0.0))
    for ln in hemi_top_xy:
        lines.push(ln)

    val hemi_top_zy = _draw_half_circle(top, rot, radius, Vec3(x: 0.0, y: 0.0, z: 1.0), Vec3(x: 0.0, y: 1.0, z: 0.0))
    for ln in hemi_top_zy:
        lines.push(ln)

    val hemi_bot_xy = _draw_half_circle(bottom, rot, radius, Vec3(x: 1.0, y: 0.0, z: 0.0), Vec3(x: 0.0, y: -1.0, z: 0.0))
    for ln in hemi_bot_xy:
        lines.push(ln)

    val hemi_bot_zy = _draw_half_circle(bottom, rot, radius, Vec3(x: 0.0, y: 0.0, z: 1.0), Vec3(x: 0.0, y: -1.0, z: 0.0))
    for ln in hemi_bot_zy:
        lines.push(ln)

    lines

fn _draw_half_circle(center: Vec3, rot: Quaternion, radius: f64, axis_horiz: Vec3, axis_vert: Vec3) -> [DebugLine3D]:
    """Draw a half circle (hemisphere outline) from axis_horiz through axis_vert."""
    var lines: [DebugLine3D] = []
    val segments = 8
    val step = MATH_PI / segments.to_f64()

    val r_horiz = rot.rotate_vector(axis_horiz)
    val r_vert = rot.rotate_vector(axis_vert)

    var prev = Vec3(
        x: center.x + r_horiz.x * radius,
        y: center.y + r_horiz.y * radius,
        z: center.z + r_horiz.z * radius
    )

    var i = 1
    while i <= segments:
        val angle = step * i.to_f64()
        val c = _cos(angle)
        val s = _sin(angle)
        val cur = Vec3(
            x: center.x + (r_horiz.x * c + r_vert.x * s) * radius,
            y: center.y + (r_horiz.y * c + r_vert.y * s) * radius,
            z: center.z + (r_horiz.z * c + r_vert.z * s) * radius
        )
        lines.push(DebugLine3D(start: prev, end_point: cur))
        prev = cur
        i = i + 1

    lines
