# std.nogc_sync_mut.engine.render.vulkan_backend3d — VulkanRenderBackend3D
#
# Real Vulkan graphics backend implementing RenderBackend3D.
# Uses a command-buffer recording pattern (following Skia VkCommand):
#   - Trait methods that issue draw/bind commands RECORD into self.cmds[]
#   - end_frame() drains self.cmds[] and submits via rt_vulkan_* externs
#   - create_* / init / shutdown call rt_vulkan_* externs immediately
#
# Graphics externs are separate from compute externs (gc_async sffi_vulkan.spl).

use std.nogc_sync_mut.engine.render.backend3d.{
    RenderBackend3D,
    PipelineHandle,
    BufferHandle,
    TextureHandle,
    RenderPassHandle,
    PipelineDesc3D,
    TextureFormat3D
}
use std.nogc_sync_mut.engine.render.capability3d.{
    RenderCapability3D,
    capability_vulkan_3d
}
use std.nogc_sync_mut.engine.render.vulkan_commands.{
    VulkanCommand3D,
    VulkanCommand3DKind,
    vk_cmd3d_begin_render_pass,
    vk_cmd3d_set_pipeline,
    vk_cmd3d_bind_vertex_buffer,
    vk_cmd3d_bind_index_buffer,
    vk_cmd3d_bind_texture,
    vk_cmd3d_bind_font_texture,
    vk_cmd3d_bind_uniform_buffer,
    vk_cmd3d_draw_indexed,
    vk_cmd3d_draw,
    vk_cmd3d_end_render_pass
}
use std.nogc_sync_mut.io.vulkan_sffi.{
    rt_vulkan_is_available, rt_vulkan_init, rt_vulkan_shutdown,
    rt_vulkan_device_count, rt_vulkan_select_device, rt_vulkan_get_device,
    rt_vulkan_selected_device_name, rt_vulkan_selected_device_type,
    rt_vulkan_selected_device_driver_identity,
    rt_vulkan_alloc_buffer, rt_vulkan_free_buffer, rt_vulkan_copy_to_buffer,
    rt_vulkan_compile_spirv, rt_vulkan_destroy_shader,
    rt_vulkan_create_offscreen_render_pass, rt_vulkan_destroy_render_pass,
    rt_vulkan_create_graphics_pipeline, rt_vulkan_destroy_graphics_pipeline,
    rt_vulkan_create_font_graphics_pipeline,
    rt_vulkan_create_font_world_graphics_pipeline,
    rt_vulkan_create_image, rt_vulkan_destroy_image,
    rt_vulkan_copy_to_image, rt_vulkan_copy_from_image,
    rt_vulkan_create_sampler, rt_vulkan_destroy_sampler,
    rt_vulkan_create_font_sampler,
    rt_vulkan_create_framebuffer, rt_vulkan_destroy_framebuffer,
    rt_vulkan_begin_graphics, rt_vulkan_end_graphics, rt_vulkan_discard_graphics_command,
    rt_vulkan_begin_render_pass_gfx, rt_vulkan_end_render_pass_gfx,
    rt_vulkan_bind_graphics_pipeline, rt_vulkan_bind_vertex_buffer,
    rt_vulkan_bind_index_buffer, rt_vulkan_set_viewport, rt_vulkan_set_scissor,
    rt_vulkan_bind_font_texture, rt_vulkan_draw, rt_vulkan_draw_indexed,
    rt_vulkan_fence_submission_supported,
    rt_vulkan_submit_graphics_and_wait_fence, rt_vulkan_wait_fence, rt_vulkan_destroy_fence,
    rt_vulkan_wait_idle
}

# ============================================================================
# Graphics ABI is owned by nogc_sync_mut.io.vulkan_sffi.  Keep this backend on
# that canonical handle-based ABI; do not duplicate declarations here.
# ============================================================================

# ============================================================================
# Format encoding helper — maps TextureFormat3D to a runtime integer code
# ============================================================================

fn _texture_format_to_i64(format: TextureFormat3D) -> i64:
    match format:
        TextureFormat3D.Rgba8Unorm => 37
        TextureFormat3D.Rgba8Srgb  => 43
        TextureFormat3D.R8Unorm    => 9
        TextureFormat3D.Depth32Float => 126

class VulkanBackend3DDeviceEvidence:
    status: text
    reason: text
    device_handle: i64
    device_name: text
    device_type: text
    driver_identity: text
    command_handle: i64
    submitted_command_handle: i64
    fence_handle: i64
    fence_waited: bool
    fence_destroyed: bool
    readback_bytes: i64
    color_image_handle: i64
    readback_source: text
    texture_binding_ready: bool

# ============================================================================
# VulkanRenderBackend3D
#
# Internal id tables: pipeline_ids[k] is the logical PipelineHandle.id
# and pipeline_native[k] is the GPU-native handle returned by the extern.
# Same pattern for buffers and textures.
# ============================================================================

class VulkanRenderBackend3D:
    cmds: [VulkanCommand3D]
    cap: RenderCapability3D
    # Pipeline id → native handle mapping (parallel arrays)
    pipeline_ids: [i64]
    pipeline_native: [i64]
    # Buffer id → native handle mapping
    buffer_ids: [i64]
    buffer_native: [i64]
    # Texture id → native handle mapping
    texture_ids: [i64]
    texture_native: [i64]
    framebuffer_native: [i64]
    framebuffer_texture_ids: [i64]
    framebuffer_depth_texture_ids: [i64]
    shader_native: [i64]
    device_handle: i64
    render_pass_handle: i64
    sampler_handle: i64
    command_handle: i64
    last_submitted_command_handle: i64
    last_color_image: i64
    last_readback_image: i64
    last_fence_handle: i64
    last_fence_waited: bool
    last_fence_destroyed: bool
    last_readback_bytes: i64
    last_readback_pixels: [u8]
    device_name: text
    device_type: text
    driver_identity: text
    initialized: bool
    owns_session: bool
    base_submit_ok: bool
    recording_blocked: bool
    completion_unknown: bool
    font_binding_submitted: bool
    font_draw_count: i64
    blocker_reason: text
    # Auto-incrementing logical id counter
    next_id: i64
    width: i64
    height: i64

    static fn create() -> VulkanRenderBackend3D:
        VulkanRenderBackend3D(
            cmds: [],
            cap: capability_vulkan_3d(),
            pipeline_ids: [],
            pipeline_native: [],
            buffer_ids: [],
            buffer_native: [],
            texture_ids: [],
            texture_native: [],
            framebuffer_native: [],
            framebuffer_texture_ids: [],
            framebuffer_depth_texture_ids: [],
            shader_native: [],
            device_handle: 0,
            render_pass_handle: 0,
            sampler_handle: 0,
            command_handle: 0,
            last_submitted_command_handle: 0,
            last_color_image: 0,
            last_readback_image: 0,
            last_fence_handle: 0,
            last_fence_waited: false,
            last_fence_destroyed: false,
            last_readback_bytes: 0,
            last_readback_pixels: [],
            device_name: "",
            device_type: "",
            driver_identity: "",
            initialized: false,
            owns_session: false,
            base_submit_ok: false,
            recording_blocked: false,
            completion_unknown: false,
            font_binding_submitted: false,
            font_draw_count: 0,
            blocker_reason: "texture-descriptor-layout-unavailable",
            next_id: 1,
            width: 0,
            height: 0
        )

# ============================================================================
# Internal lookup helpers (module-level to avoid chained-method issues)
# ============================================================================

fn _find_pipeline_native(ids: [i64], natives: [i64], id: i64) -> i64:
    var i: i64 = 0
    while i < ids.len():
        if ids[i] == id:
            return natives[i]
        i = i + 1
    0

fn _find_buffer_native(ids: [i64], natives: [i64], id: i64) -> i64:
    var i: i64 = 0
    while i < ids.len():
        if ids[i] == id:
            return natives[i]
        i = i + 1
    0

fn _find_texture_native(ids: [i64], natives: [i64], id: i64) -> i64:
    var i: i64 = 0
    while i < ids.len():
        if ids[i] == id:
            return natives[i]
        i = i + 1
    0

fn _find_framebuffer_native(texture_ids: [i64], depth_ids: [i64], natives: [i64], texture_id: i64, depth_id: i64) -> i64:
    var i: i64 = 0
    while i < texture_ids.len():
        if texture_ids[i] == texture_id and depth_ids[i] == depth_id:
            return natives[i]
        i = i + 1
    0

# ============================================================================
# impl RenderBackend3D for VulkanRenderBackend3D
#
# Recording methods record into self.cmds[].
# end_frame() drains self.cmds[] and calls the rt_vulkan_cmd_* externs.
# ============================================================================

impl RenderBackend3D for VulkanRenderBackend3D:

    fn capabilities(self) -> RenderCapability3D:
        self.cap

    fn init(self, width: i64, height: i64) -> bool:
        self.width = width
        self.height = height
        if not rt_vulkan_is_available():
            self.blocker_reason = "vulkan-runtime-unavailable"
            return false
        val borrowed_device = rt_vulkan_get_device()
        if borrowed_device > 0:
            self.device_handle = borrowed_device
            self.owns_session = false
        else:
            if not rt_vulkan_init():
                self.blocker_reason = "vulkan-device-unavailable"
                return false
            self.owns_session = true
            if rt_vulkan_device_count() <= 0 or not rt_vulkan_select_device(0):
                rt_vulkan_shutdown()
                self.owns_session = false
                self.blocker_reason = "vulkan-device-unavailable"
                return false
            self.device_handle = rt_vulkan_get_device()
        self.render_pass_handle = rt_vulkan_create_offscreen_render_pass(self.device_handle, 37, 126)
        self.sampler_handle = rt_vulkan_create_font_sampler(self.device_handle)
        if self.device_handle <= 0 or self.render_pass_handle <= 0 or self.sampler_handle <= 0:
            self.blocker_reason = "vulkan-base-resource-init-failed"
            if self.sampler_handle > 0:
                rt_vulkan_destroy_sampler(self.sampler_handle)
                self.sampler_handle = 0
            if self.render_pass_handle > 0:
                rt_vulkan_destroy_render_pass(self.render_pass_handle)
                self.render_pass_handle = 0
            if self.owns_session:
                rt_vulkan_shutdown()
                self.owns_session = false
            return false
        self.device_name = rt_vulkan_selected_device_name()
        self.device_type = rt_vulkan_selected_device_type()
        self.driver_identity = rt_vulkan_selected_device_driver_identity()
        self.initialized = true
        true

    fn create_pipeline(self, desc: PipelineDesc3D) -> PipelineHandle:
        val vs = rt_vulkan_compile_spirv(desc.vertex_shader_spirv)
        val fs = rt_vulkan_compile_spirv(desc.fragment_shader_spirv)
        val native = rt_vulkan_create_graphics_pipeline(
            self.device_handle, vs, fs, self.render_pass_handle,
            desc.vertex_stride, desc.depth_test, desc.depth_write,
            desc.cull_back_faces, desc.blend_mode, desc.topology
        )
        if vs > 0:
            self.shader_native.push(vs)
        if fs > 0:
            self.shader_native.push(fs)
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.pipeline_ids.push(id)
        self.pipeline_native.push(native)
        PipelineHandle(id: id)

    fn create_vertex_buffer(self, byte_count: i64) -> BufferHandle:
        # usage 0 = vertex buffer
        val native = rt_vulkan_alloc_buffer(byte_count, 0x43)
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.buffer_ids.push(id)
        self.buffer_native.push(native)
        BufferHandle(id: id)

    fn create_index_buffer(self, byte_count: i64) -> BufferHandle:
        # usage 1 = index buffer
        val native = rt_vulkan_alloc_buffer(byte_count, 0x23)
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.buffer_ids.push(id)
        self.buffer_native.push(native)
        BufferHandle(id: id)

    fn create_uniform_buffer(self, byte_count: i64) -> BufferHandle:
        # usage 2 = uniform buffer
        val native = rt_vulkan_alloc_buffer(byte_count, 0x12)
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.buffer_ids.push(id)
        self.buffer_native.push(native)
        BufferHandle(id: id)

    fn upload_buffer(self, buf: BufferHandle, data: [u8], offset: i64):
        val native = _find_buffer_native(self.buffer_ids, self.buffer_native, buf.id)
        rt_vulkan_copy_to_buffer(native, data, offset)

    fn create_texture(self, width: i64, height: i64, format: TextureFormat3D) -> TextureHandle:
        val fmt = _texture_format_to_i64(format)
        val usage = if format == TextureFormat3D.Depth32Float: 0x08 else: 0x35
        val native = rt_vulkan_create_image(self.device_handle, width, height, fmt, usage)
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.texture_ids.push(id)
        self.texture_native.push(native)
        TextureHandle(id: id)

    fn upload_texture(self, tex: TextureHandle, data: [u8]):
        val native = _find_texture_native(self.texture_ids, self.texture_native, tex.id)
        rt_vulkan_copy_to_image(native, data)

    fn begin_frame(self):
        self.cmds = []
        if self.completion_unknown:
            self.blocker_reason = "graphics-submission-completion-unknown"
            self.command_handle = 0
        else:
            if self.command_handle > 0:
                rt_vulkan_discard_graphics_command(self.command_handle)
            self.command_handle = if self.initialized: rt_vulkan_begin_graphics() else: 0
        self.base_submit_ok = false
        self.recording_blocked = false
        self.last_fence_handle = 0
        self.last_fence_waited = false
        self.last_fence_destroyed = false
        self.last_readback_bytes = 0
        self.last_readback_pixels = []
        self.last_submitted_command_handle = 0
        self.last_color_image = 0
        self.last_readback_image = 0
        self.font_binding_submitted = false
        self.font_draw_count = 0

    fn begin_render_pass(self, color_tex: TextureHandle, depth_tex: TextureHandle) -> RenderPassHandle:
        val color_native = _find_texture_native(self.texture_ids, self.texture_native, color_tex.id)
        val depth_native = _find_texture_native(self.texture_ids, self.texture_native, depth_tex.id)
        var framebuffer = _find_framebuffer_native(self.framebuffer_texture_ids, self.framebuffer_depth_texture_ids, self.framebuffer_native, color_tex.id, depth_tex.id)
        if framebuffer <= 0 and self.initialized:
            framebuffer = rt_vulkan_create_framebuffer(self.device_handle, self.render_pass_handle, color_native, depth_native, self.width, self.height)
        if framebuffer > 0:
            if _find_framebuffer_native(self.framebuffer_texture_ids, self.framebuffer_depth_texture_ids, self.framebuffer_native, color_tex.id, depth_tex.id) <= 0:
                self.framebuffer_texture_ids.push(color_tex.id)
                self.framebuffer_depth_texture_ids.push(depth_tex.id)
                self.framebuffer_native.push(framebuffer)
        else:
            self.blocker_reason = "framebuffer-create-failed"
            self.recording_blocked = true
        self.last_color_image = color_native
        val cmd = vk_cmd3d_begin_render_pass(framebuffer, 0)
        self.cmds.push(cmd)
        # Return a handle whose id encodes the index so end_frame can thread the pass handle
        val id = self.next_id
        self.next_id = self.next_id + 1
        RenderPassHandle(id: id)

    fn set_pipeline(self, rph: RenderPassHandle, pipeline: PipelineHandle):
        val pipeline_native = _find_pipeline_native(self.pipeline_ids, self.pipeline_native, pipeline.id)
        val cmd = vk_cmd3d_set_pipeline(pipeline_native)
        self.cmds.push(cmd)

    fn bind_vertex_buffer(self, rph: RenderPassHandle, buf: BufferHandle, slot: i64):
        val native = _find_buffer_native(self.buffer_ids, self.buffer_native, buf.id)
        val cmd = vk_cmd3d_bind_vertex_buffer(native, slot)
        self.cmds.push(cmd)

    fn bind_index_buffer(self, rph: RenderPassHandle, buf: BufferHandle):
        val native = _find_buffer_native(self.buffer_ids, self.buffer_native, buf.id)
        val cmd = vk_cmd3d_bind_index_buffer(native)
        self.cmds.push(cmd)

    fn bind_texture(self, rph: RenderPassHandle, tex: TextureHandle, slot: i64):
        # The runtime validates image/sampler handles but does not yet own a
        # combined-image-sampler descriptor layout. Keep this explicitly
        # unavailable instead of recording a draw that cannot sample.
        self.blocker_reason = "texture-descriptor-layout-unavailable"
        self.recording_blocked = true

    fn bind_uniform_buffer(self, rph: RenderPassHandle, buf: BufferHandle, slot: i64):
        val native = _find_buffer_native(self.buffer_ids, self.buffer_native, buf.id)
        val cmd = vk_cmd3d_bind_uniform_buffer(native, slot)
        self.cmds.push(cmd)

    fn draw_indexed(self, rph: RenderPassHandle, index_count: i64, base_vertex: i64):
        val cmd = vk_cmd3d_draw_indexed(index_count, base_vertex)
        self.cmds.push(cmd)

    fn end_render_pass(self, rph: RenderPassHandle):
        val cmd = vk_cmd3d_end_render_pass()
        self.cmds.push(cmd)

    # Drain the recorded command buffer and submit via rt_vulkan_cmd_* externs.
    # Maintains a current_pass i64 that tracks the active GPU render pass handle
    # opened by BeginRenderPass; all subsequent commands are issued against it.
    fn end_frame(self):
        if not self.initialized or self.command_handle <= 0:
            self.cmds = []
            return
        var pass_open = false
        var commands_ok = not self.recording_blocked
        var i: i64 = 0
        while (i < self.cmds.len() and commands_ok):
            val cmd = self.cmds[i]
            if cmd.kind == VulkanCommand3DKind.BeginRenderPass:
                commands_ok = commands_ok and rt_vulkan_begin_render_pass_gfx(
                    self.command_handle, self.render_pass_handle, cmd.color_image,
                    0.0, 0.0, 0.0, 0.0
                )
                commands_ok = commands_ok and rt_vulkan_set_viewport(self.command_handle, 0.0, 0.0, self.width as f64, self.height as f64)
                commands_ok = commands_ok and rt_vulkan_set_scissor(self.command_handle, 0, 0, self.width, self.height)
                pass_open = true
            elif cmd.kind == VulkanCommand3DKind.SetPipeline:
                commands_ok = commands_ok and rt_vulkan_bind_graphics_pipeline(self.command_handle, cmd.pipeline_id)
            elif cmd.kind == VulkanCommand3DKind.BindVertexBuffer:
                commands_ok = commands_ok and rt_vulkan_bind_vertex_buffer(self.command_handle, cmd.buffer_id)
            elif cmd.kind == VulkanCommand3DKind.BindIndexBuffer:
                commands_ok = commands_ok and rt_vulkan_bind_index_buffer(self.command_handle, cmd.buffer_id)
            elif cmd.kind == VulkanCommand3DKind.BindTexture:
                commands_ok = false
                self.blocker_reason = "texture-descriptor-layout-unavailable"
            elif cmd.kind == VulkanCommand3DKind.BindFontTexture:
                val bound = rt_vulkan_bind_font_texture(
                    self.command_handle, cmd.pipeline_id, cmd.image_id, cmd.buffer_id
                )
                commands_ok = commands_ok and bound
                if commands_ok:
                    self.font_binding_submitted = true
            elif cmd.kind == VulkanCommand3DKind.BindUniformBuffer:
                commands_ok = false
                self.blocker_reason = "graphics-uniform-descriptor-layout-unavailable"
            elif cmd.kind == VulkanCommand3DKind.DrawIndexed:
                commands_ok = commands_ok and rt_vulkan_draw_indexed(self.command_handle, cmd.index_count)
            elif cmd.kind == VulkanCommand3DKind.Draw:
                val drawn = cmd.index_count > 0 and rt_vulkan_draw(self.command_handle, cmd.index_count)
                commands_ok = commands_ok and drawn
                if drawn:
                    self.font_draw_count = self.font_draw_count + cmd.index_count
            elif cmd.kind == VulkanCommand3DKind.EndRenderPass:
                commands_ok = commands_ok and rt_vulkan_end_render_pass_gfx(self.command_handle)
                pass_open = false
            i = i + 1
        if pass_open and commands_ok:
            commands_ok = commands_ok and rt_vulkan_end_render_pass_gfx(self.command_handle)
        self.cmds = []
        val command_ended = rt_vulkan_end_graphics(self.command_handle)
        commands_ok = commands_ok and command_ended
        if not commands_ok or not rt_vulkan_fence_submission_supported():
            if not self.recording_blocked:
                self.blocker_reason = if commands_ok: "fenced-submit-unavailable" else: "graphics-command-recording-failed"
            rt_vulkan_discard_graphics_command(self.command_handle)
            self.command_handle = 0
            return
        self.last_submitted_command_handle = self.command_handle
        val fence = rt_vulkan_submit_graphics_and_wait_fence(self.command_handle)
        self.last_fence_handle = fence
        if fence < 0:
            self.completion_unknown = true
            self.blocker_reason = "graphics-submission-completion-unknown"
        self.last_fence_waited = fence > 0 and rt_vulkan_wait_fence(fence, 1000000000)
        self.last_fence_destroyed = fence > 0 and rt_vulkan_destroy_fence(fence)
        self.base_submit_ok = fence > 0 and self.last_fence_waited and self.last_fence_destroyed
        if self.base_submit_ok:
            self.last_readback_pixels = self._capture_last_color_rgba8()
            self.last_readback_bytes = self.last_readback_pixels.len()
            if self.last_readback_bytes == self.width * self.height * 4:
                self.last_readback_image = self.last_color_image
        self.command_handle = 0

    fn present(self):
        pass_dn

    fn shutdown(self):
        if self.completion_unknown:
            if not rt_vulkan_wait_idle():
                self.blocker_reason = "graphics-submission-still-in-flight"
                return
            self.completion_unknown = false
        if self.command_handle > 0:
            rt_vulkan_discard_graphics_command(self.command_handle)
            self.command_handle = 0
        var i: i64 = 0
        while i < self.framebuffer_native.len():
            rt_vulkan_destroy_framebuffer(self.framebuffer_native[i])
            i = i + 1
        i = 0
        while i < self.pipeline_native.len():
            rt_vulkan_destroy_graphics_pipeline(self.pipeline_native[i])
            i = i + 1
        i = 0
        while i < self.shader_native.len():
            rt_vulkan_destroy_shader(self.shader_native[i])
            i = i + 1
        i = 0
        while i < self.buffer_native.len():
            if self.buffer_native[i] > 0:
                rt_vulkan_free_buffer(self.buffer_native[i])
            i = i + 1
        i = 0
        while i < self.texture_native.len():
            rt_vulkan_destroy_image(self.texture_native[i])
            i = i + 1
        if self.sampler_handle > 0:
            rt_vulkan_destroy_sampler(self.sampler_handle)
        if self.render_pass_handle > 0:
            rt_vulkan_destroy_render_pass(self.render_pass_handle)
        if self.owns_session:
            rt_vulkan_shutdown()
        self.cmds = []
        self.pipeline_ids = []
        self.pipeline_native = []
        self.buffer_ids = []
        self.buffer_native = []
        self.texture_ids = []
        self.texture_native = []
        self.framebuffer_native = []
        self.framebuffer_texture_ids = []
        self.framebuffer_depth_texture_ids = []
        self.shader_native = []
        self.device_handle = 0
        self.render_pass_handle = 0
        self.sampler_handle = 0
        self.last_submitted_command_handle = 0
        self.last_color_image = 0
        self.last_readback_image = 0
        self.next_id = 1
        self.width = 0
        self.height = 0
        self.initialized = false
        self.owns_session = false

impl VulkanRenderBackend3D:
    fn pipeline_native_handle(pipeline: PipelineHandle) -> i64:
        _find_pipeline_native(self.pipeline_ids, self.pipeline_native, pipeline.id)

    fn texture_native_handle(texture: TextureHandle) -> i64:
        _find_texture_native(self.texture_ids, self.texture_native, texture.id)

    me upload_buffer_checked(buf: BufferHandle, data: [u8], offset: i64) -> bool:
        val native = _find_buffer_native(self.buffer_ids, self.buffer_native, buf.id)
        native > 0 and rt_vulkan_copy_to_buffer(native, data, offset)

    me upload_texture_checked(tex: TextureHandle, data: [u8]) -> bool:
        val native = _find_texture_native(self.texture_ids, self.texture_native, tex.id)
        native > 0 and rt_vulkan_copy_to_image(native, data)

    me destroy_buffer(buf: BufferHandle):
        var i: i64 = 0
        while i < self.buffer_ids.len():
            if self.buffer_ids[i] == buf.id and self.buffer_native[i] > 0:
                rt_vulkan_free_buffer(self.buffer_native[i])
                self.buffer_native[i] = 0
                return
            i = i + 1

    me create_font_pipeline(vertex_shader_spirv: [u8], fragment_shader_spirv: [u8]) -> PipelineHandle:
        val vs = rt_vulkan_compile_spirv(vertex_shader_spirv)
        val fs = rt_vulkan_compile_spirv(fragment_shader_spirv)
        val native = rt_vulkan_create_font_graphics_pipeline(
            self.device_handle, vs, fs, self.render_pass_handle
        )
        if vs > 0:
            self.shader_native.push(vs)
        if fs > 0:
            self.shader_native.push(fs)
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.pipeline_ids.push(id)
        self.pipeline_native.push(native)
        PipelineHandle(id: id)

    me create_font_world_pipeline(vertex_shader_spirv: [u8], fragment_shader_spirv: [u8]) -> PipelineHandle:
        val vs = rt_vulkan_compile_spirv(vertex_shader_spirv)
        val fs = rt_vulkan_compile_spirv(fragment_shader_spirv)
        val native = rt_vulkan_create_font_world_graphics_pipeline(
            self.device_handle, vs, fs, self.render_pass_handle
        )
        if vs > 0:
            self.shader_native.push(vs)
        if fs > 0:
            self.shader_native.push(fs)
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.pipeline_ids.push(id)
        self.pipeline_native.push(native)
        PipelineHandle(id: id)

    me bind_font_texture(rph: RenderPassHandle, pipeline: PipelineHandle, tex: TextureHandle):
        val pipeline_native = _find_pipeline_native(self.pipeline_ids, self.pipeline_native, pipeline.id)
        val image_native = _find_texture_native(self.texture_ids, self.texture_native, tex.id)
        self.cmds.push(vk_cmd3d_bind_font_texture(pipeline_native, image_native, self.sampler_handle))

    me draw_font_vertices(rph: RenderPassHandle, vertex_count: i64):
        self.cmds.push(vk_cmd3d_draw(vertex_count))

    fn _capture_last_color_rgba8() -> [u8]:
        if not self.base_submit_ok or self.last_color_image <= 0:
            return []
        val byte_count = self.width * self.height * 4
        var pixels: [u8] = []
        var i: i64 = 0
        while i < byte_count:
            pixels.push(0u8)
            i = i + 1
        if not rt_vulkan_copy_from_image(pixels, self.last_color_image):
            return []
        pixels

    fn readback_last_color_rgba8() -> [u8]:
        self.last_readback_pixels

    fn owns_vulkan_session() -> bool:
        self.owns_session

    fn cached_framebuffer_count() -> i64:
        self.framebuffer_native.len()

    me device_evidence() -> VulkanBackend3DDeviceEvidence:
        val readback_bytes = self.last_readback_pixels.len()
        self.last_readback_bytes = readback_bytes
        val expected_bytes = self.width * self.height * 4
        val readback_ready = (self.last_submitted_command_handle > 0 and
            self.last_readback_image > 0 and self.last_readback_image == self.last_color_image and
            expected_bytes > 0 and readback_bytes == expected_bytes)
        val base_ready = self.initialized and self.base_submit_ok and readback_ready
        val font_ready = base_ready and self.font_binding_submitted and self.font_draw_count > 0
        VulkanBackend3DDeviceEvidence(
            status: if font_ready: "font-ready" else: if base_ready: "base-ready" else: "unavailable",
            reason: if font_ready: "" else: if base_ready: "font-draw-not-submitted" else: self.blocker_reason,
            device_handle: self.device_handle,
            device_name: self.device_name,
            device_type: self.device_type,
            driver_identity: self.driver_identity,
            command_handle: self.command_handle,
            submitted_command_handle: self.last_submitted_command_handle,
            fence_handle: self.last_fence_handle,
            fence_waited: self.last_fence_waited,
            fence_destroyed: self.last_fence_destroyed,
            readback_bytes: readback_bytes,
            color_image_handle: self.last_readback_image,
            readback_source: if readback_ready: "device_image_readback" else: "unavailable",
            texture_binding_ready: font_ready
        )
