# Texture Atlas — Shelf-based sub-image packing
#
# Packs multiple small textures into one large backing texture.
# Uses a simple shelf (row) algorithm: each shelf has a fixed height,
# images are placed left-to-right, new shelves created at the bottom.
#
# Adapted from the browser's texture_cache pattern.
#
# Usage:
#   var atlas = TextureAtlas.create(512, 512)
#   val region = atlas.pack(32, 32, my_pixels)
#   if val Some(r) = region:
#       print "Packed at UV ({r.u0}, {r.v0}) to ({r.u1}, {r.v1})"
#   val backing = atlas.get_texture()

use std.common.engine.color.{EngineColor}
use std.nogc_sync_mut.engine.sprite.texture.{Texture, pack_color, unpack_color}

# ============================================================================
# AtlasRegion — A rectangular region within the atlas
# ============================================================================

class AtlasRegion:
    """A packed region in the atlas with pixel coordinates and normalized UVs.

    Pixel coordinates (x, y, width, height) locate the region in the
    backing texture. UV coordinates (u0, v0) to (u1, v1) are normalized
    [0.0, 1.0] for sampling.
    """
    x: i64
    y: i64
    width: i64
    height: i64
    u0: f64
    v0: f64
    u1: f64
    v1: f64

# ============================================================================
# Shelf — A horizontal row in the atlas
# ============================================================================

class Shelf:
    """A single shelf (row) in the shelf-packing algorithm.

    Each shelf has a fixed Y position and height. Images are placed
    left-to-right starting from next_x.
    """
    y: i64
    height: i64
    next_x: i64

# ============================================================================
# TextureAtlas
# ============================================================================

class TextureAtlas:
    """Shelf-based texture atlas for packing sub-images.

    Maintains a single backing Texture and a list of shelves.
    Regions are packed by finding a shelf with enough horizontal
    and vertical space, or creating a new shelf at the bottom.
    """
    texture: Texture
    shelves: [Shelf]
    padding: i64
    regions: [AtlasRegion]

impl TextureAtlas:
    static fn create(width: i64, height: i64) -> TextureAtlas:
        """Create an empty atlas with the given dimensions and default padding of 1."""
        val tex = Texture.create(width, height)
        TextureAtlas(
            texture: tex,
            shelves: [],
            padding: 1,
            regions: []
        )

    me pack(width: i64, height: i64, pixels: [i64]) -> AtlasRegion?:
        """Pack a sub-image into the atlas.

        Finds a shelf with enough space (or creates a new one), copies
        pixels into the backing texture, computes normalized UVs, and
        returns the region. Returns nil if no space remains.

        Args:
            width: Sub-image width in pixels
            height: Sub-image height in pixels
            pixels: Row-major RGBA packed pixel data (width * height entries)

        Returns:
            The packed AtlasRegion, or nil if atlas is full
        """
        val atlas_w = self.texture.width
        val atlas_h = self.texture.height
        val padded_w = width + self.padding
        val padded_h = height + self.padding

        # Try to find an existing shelf with enough space
        var shelf_idx = -1
        var i = 0
        while i < self.shelves.len():
            val s = self.shelves[i]
            val fits_height = s.height >= height
            val fits_width = s.next_x + padded_w <= atlas_w
            if fits_height and fits_width:
                shelf_idx = i
                i = self.shelves.len()  # break
            else:
                i = i + 1

        # No existing shelf fits — create a new one
        if shelf_idx < 0:
            # Compute Y for the new shelf: below all existing shelves
            var new_y = 0
            var j = 0
            while j < self.shelves.len():
                val s = self.shelves[j]
                val shelf_bottom = s.y + s.height + self.padding
                if shelf_bottom > new_y:
                    new_y = shelf_bottom
                j = j + 1

            # Check if new shelf fits vertically
            if new_y + padded_h > atlas_h:
                return nil

            # Check if image fits horizontally
            if padded_w > atlas_w:
                return nil

            val new_shelf = Shelf(y: new_y, height: height + self.padding, next_x: 0)
            self.shelves.push(new_shelf)
            shelf_idx = self.shelves.len() - 1

        # Place the image on the shelf
        val shelf = self.shelves[shelf_idx]
        val place_x = shelf.next_x
        val place_y = shelf.y

        # Update shelf next_x
        self.shelves[shelf_idx] = Shelf(
            y: shelf.y,
            height: shelf.height,
            next_x: shelf.next_x + padded_w
        )

        # Copy pixels into the backing texture
        var py = 0
        while py < height:
            var px = 0
            while px < width:
                val src_idx = py * width + px
                val dst_idx = (place_y + py) * atlas_w + (place_x + px)
                if src_idx < pixels.len():
                    self.texture.pixels[dst_idx] = pixels[src_idx]
                px = px + 1
            py = py + 1

        # Compute normalized UV coordinates
        val u0 = place_x * 1.0 / atlas_w
        val v0 = place_y * 1.0 / atlas_h
        val u1 = (place_x + width) * 1.0 / atlas_w
        val v1 = (place_y + height) * 1.0 / atlas_h

        val region = AtlasRegion(
            x: place_x,
            y: place_y,
            width: width,
            height: height,
            u0: u0,
            v0: v0,
            u1: u1,
            v1: v1
        )
        self.regions.push(region)
        region

    fn get_region(index: i64) -> AtlasRegion?:
        """Get a packed region by its index. Returns nil if out of bounds."""
        if index < 0 or index >= self.regions.len():
            return nil
        self.regions[index]

    fn region_count() -> i64:
        """Number of packed regions in the atlas."""
        self.regions.len()

    fn get_texture() -> Texture:
        """Get the backing texture containing all packed sub-images."""
        self.texture
