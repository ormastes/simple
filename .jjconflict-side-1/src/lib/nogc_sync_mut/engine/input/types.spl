# Input System — Types
#
# Core types for the game engine input system.
# Provides button state tracking, mouse state, and action binding definitions.

use std.common.engine.units.{KeyCode, MouseButtonId}

# ============================================================================
# ButtonState — tracks per-frame button transitions
# ============================================================================

enum ButtonState:
    Released
    JustPressed
    Held
    JustReleased

impl ButtonState:
    fn is_pressed() -> bool:
        """True when button is currently down (JustPressed or Held)."""
        match self:
            JustPressed: true
            Held: true
            _: false

    fn is_just_pressed() -> bool:
        """True only on the frame the button was first pressed."""
        match self:
            JustPressed: true
            _: false

    fn is_just_released() -> bool:
        """True only on the frame the button was released."""
        match self:
            JustReleased: true
            _: false

    fn to_text() -> text:
        match self:
            Released: "Released"
            JustPressed: "JustPressed"
            Held: "Held"
            JustReleased: "JustReleased"

# ============================================================================
# MouseState — aggregate mouse position, delta, wheel, and button states
# ============================================================================

class MouseState:
    x: f64
    y: f64
    delta_x: f64
    delta_y: f64
    wheel_x: f64
    wheel_y: f64
    left: ButtonState
    right: ButtonState
    middle: ButtonState

impl MouseState:
    static fn initial() -> MouseState:
        """Create a zeroed-out mouse state with all buttons released."""
        MouseState(
            x: 0.0,
            y: 0.0,
            delta_x: 0.0,
            delta_y: 0.0,
            wheel_x: 0.0,
            wheel_y: 0.0,
            left: ButtonState.Released,
            right: ButtonState.Released,
            middle: ButtonState.Released
        )

# ============================================================================
# ActionBinding — maps an action name to input sources
# ============================================================================

class ActionBinding:
    action_name: text
    key_codes: [KeyCode]         # Virtual keycodes that trigger this action
    mouse_buttons: [MouseButtonId]     # Mouse buttons (0=left, 1=right, 2=middle)
    gamepad_buttons: [i64]   # Gamepad button codes
    deadzone: f64            # For axis-based triggers (default 0.15)

impl ActionBinding:
    static fn key_only(name: text, keycode: KeyCode) -> ActionBinding:
        """Convenience: binding for a single keycode."""
        ActionBinding(
            action_name: name,
            key_codes: [keycode],
            mouse_buttons: [],
            gamepad_buttons: [],
            deadzone: 0.15
        )

    static fn keys(name: text, codes: [KeyCode]) -> ActionBinding:
        """Convenience: binding for multiple keycodes."""
        ActionBinding(
            action_name: name,
            key_codes: codes,
            mouse_buttons: [],
            gamepad_buttons: [],
            deadzone: 0.15
        )
