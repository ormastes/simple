# Asset Suggester — Asset Catalog Search & Suggestion
#
# Searches an asset catalog and suggests matching assets for user
# descriptions. Supports search by tag, category, name, and combined
# relevance-scored suggestions.
#
# Usage:
#   var suggester = AssetSuggester.new()
#   var asset = AssetEntry.new("hero_sprite", "texture", "assets/hero.png")
#   asset.add_tag("character")
#   suggester.add_asset(asset)
#   val results = suggester.search_by_tag("character")

# ============================================================================
# AssetEntry — catalog entry with metadata and tags
# ============================================================================

struct AssetEntry:
    name: text
    category: text
    tags: [text]
    path: text

impl AssetEntry:
    static fn new(name: text, category: text, path: text) -> AssetEntry:
        """Create a new asset entry."""
        AssetEntry(
            name: name,
            category: category,
            tags: [],
            path: path
        )

    me add_tag(tag: text):
        """Add a tag to this asset."""
        self.tags.push(tag)

    fn has_tag(tag: text) -> bool:
        """Check if this asset has a specific tag."""
        var i = 0
        while i < self.tags.len():
            if self.tags[i] == tag:
                return true
            i = i + 1
        false

# ============================================================================
# AssetSuggestion — search result with relevance score
# ============================================================================

struct AssetSuggestion:
    asset: AssetEntry
    relevance: f64

# ============================================================================
# AssetSuggester — asset catalog search engine
# ============================================================================

class AssetSuggester:
    catalog: [AssetEntry]

impl AssetSuggester:
    static fn new() -> AssetSuggester:
        """Create an empty asset suggester."""
        AssetSuggester(catalog: [])

    me add_asset(asset: AssetEntry):
        """Add an asset to the catalog."""
        self.catalog.push(asset)

    fn search_by_tag(tag: text) -> [AssetEntry]:
        """Return all assets that have this tag."""
        var results: [AssetEntry] = []
        var i = 0
        while i < self.catalog.len():
            if self.catalog[i].has_tag(tag):
                results.push(self.catalog[i])
            i = i + 1
        results

    fn search_by_category(category: text) -> [AssetEntry]:
        """Return all assets matching this category."""
        var results: [AssetEntry] = []
        var i = 0
        while i < self.catalog.len():
            if self.catalog[i].category == category:
                results.push(self.catalog[i])
            i = i + 1
        results

    fn search_by_name(query: text) -> [AssetEntry]:
        """Return assets whose name contains the query (substring match)."""
        var results: [AssetEntry] = []
        var i = 0
        while i < self.catalog.len():
            if self.catalog[i].name.contains(query):
                results.push(self.catalog[i])
            i = i + 1
        results

    fn suggest(query: text) -> [AssetSuggestion]:
        """Search by tag and name, combine with relevance scores."""
        var suggestions: [AssetSuggestion] = []
        var seen_names: [text] = []

        # Tag matches get relevance 1.0
        val tag_results = self.search_by_tag(query)
        var i = 0
        while i < tag_results.len():
            suggestions.push(AssetSuggestion(
                asset: tag_results[i],
                relevance: 1.0
            ))
            seen_names.push(tag_results[i].name)
            i = i + 1

        # Name matches get relevance 0.5 (skip duplicates)
        val name_results = self.search_by_name(query)
        var j = 0
        while j < name_results.len():
            var already_seen = false
            var k = 0
            while k < seen_names.len():
                if seen_names[k] == name_results[j].name:
                    already_seen = true
                k = k + 1
            if !already_seen:
                suggestions.push(AssetSuggestion(
                    asset: name_results[j],
                    relevance: 0.5
                ))
            j = j + 1

        suggestions

    fn catalog_size() -> i32:
        """Return number of assets in the catalog."""
        self.catalog.len().to_i32()
