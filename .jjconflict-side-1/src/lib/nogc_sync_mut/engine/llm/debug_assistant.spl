# Debug Assistant
#
# Inspects engine state and generates diagnostic reports.
# Checks common issues with physics, scene, and performance.
#
# Usage:
#   var assistant = DebugAssistant.new()
#   val report = assistant.diagnose_physics(10, true, false)
#   if report.has_warnings():
#       print(report.to_text())

# ============================================================================
# DiagnosticEntry — single diagnostic finding
# ============================================================================

struct DiagnosticEntry:
    category: text
    issue: text
    severity: text
    suggestion: text

# ============================================================================
# DiagnosticReport — collection of diagnostic findings
# ============================================================================

struct DiagnosticReport:
    entries: [DiagnosticEntry]
    summary: text

impl DiagnosticReport:
    static fn new(summary: text) -> DiagnosticReport:
        """Create a new diagnostic report."""
        DiagnosticReport(entries: [], summary: summary)

    me add_entry(entry: DiagnosticEntry):
        """Add a diagnostic entry to the report."""
        self.entries.push(entry)

    fn entry_count() -> i32:
        """Return number of diagnostic entries."""
        self.entries.len().to_i32()

    fn has_errors() -> bool:
        """Check if any entry has severity 'error'."""
        var i = 0
        while i < self.entries.len():
            if self.entries[i].severity == "error":
                return true
            i = i + 1
        false

    fn has_warnings() -> bool:
        """Check if any entry has severity 'warning'."""
        var i = 0
        while i < self.entries.len():
            if self.entries[i].severity == "warning":
                return true
            i = i + 1
        false

    fn to_text() -> text:
        """Format report as readable text."""
        var result = "=== Diagnostic Report ===\n"
        result = result + self.summary + "\n\n"
        var i = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            result = result + "[" + entry.severity + "] " + entry.category + ": " + entry.issue + "\n"
            result = result + "  -> " + entry.suggestion + "\n"
            i = i + 1
        result

# ============================================================================
# DebugAssistant — diagnoses common engine issues
# ============================================================================

class DebugAssistant:
    known_issues: [text]

impl DebugAssistant:
    static fn new() -> DebugAssistant:
        """Create a new debug assistant."""
        DebugAssistant(known_issues: [])

    me add_known_issue(issue: text):
        """Register a known issue pattern."""
        self.known_issues.push(issue)

    fn diagnose_physics(body_count: i64, has_gravity: bool, has_colliders: bool) -> DiagnosticReport:
        """Check common physics configuration issues."""
        var report = DiagnosticReport.new("Physics diagnostics")
        if body_count == 0:
            report.add_entry(DiagnosticEntry(
                category: "physics",
                issue: "No physics bodies in scene",
                severity: "warning",
                suggestion: "Add RigidBody or StaticBody nodes"
            ))
        if !has_gravity:
            report.add_entry(DiagnosticEntry(
                category: "physics",
                issue: "Gravity is disabled",
                severity: "info",
                suggestion: "Enable gravity in project settings if needed"
            ))
        if body_count > 0 and !has_colliders:
            report.add_entry(DiagnosticEntry(
                category: "physics",
                issue: "Physics bodies exist but no colliders found",
                severity: "error",
                suggestion: "Add CollisionShape to physics bodies"
            ))
        report

    fn diagnose_scene(node_count: i64, orphan_count: i64) -> DiagnosticReport:
        """Check scene tree issues."""
        var report = DiagnosticReport.new("Scene diagnostics")
        if node_count == 0:
            report.add_entry(DiagnosticEntry(
                category: "scene",
                issue: "Scene is empty",
                severity: "warning",
                suggestion: "Add nodes to the scene tree"
            ))
        if orphan_count > 0:
            report.add_entry(DiagnosticEntry(
                category: "scene",
                issue: "Found " + orphan_count.to_text() + " orphan nodes",
                severity: "warning",
                suggestion: "Attach orphan nodes to the scene tree or free them"
            ))
        if node_count > 10000:
            report.add_entry(DiagnosticEntry(
                category: "scene",
                issue: "Very large scene with " + node_count.to_text() + " nodes",
                severity: "warning",
                suggestion: "Consider splitting into sub-scenes or using LOD"
            ))
        report

    fn diagnose_performance(fps: f64, draw_calls: i64, triangle_count: i64) -> DiagnosticReport:
        """Check performance issues."""
        var report = DiagnosticReport.new("Performance diagnostics")
        if fps < 30.0:
            report.add_entry(DiagnosticEntry(
                category: "performance",
                issue: "FPS below 30",
                severity: "error",
                suggestion: "Profile and optimize draw calls or reduce scene complexity"
            ))
        if fps < 60.0 and fps >= 30.0:
            report.add_entry(DiagnosticEntry(
                category: "performance",
                issue: "FPS below 60",
                severity: "warning",
                suggestion: "Consider batching draw calls or reducing triangle count"
            ))
        if draw_calls > 1000:
            report.add_entry(DiagnosticEntry(
                category: "performance",
                issue: "High draw call count: " + draw_calls.to_text(),
                severity: "warning",
                suggestion: "Use batching or instancing to reduce draw calls"
            ))
        if triangle_count > 1000000:
            report.add_entry(DiagnosticEntry(
                category: "performance",
                issue: "High triangle count: " + triangle_count.to_text(),
                severity: "warning",
                suggestion: "Use LOD or reduce mesh complexity"
            ))
        report

    fn known_issue_count() -> i64:
        """Return number of known issues."""
        self.known_issues.len().to_i64()
