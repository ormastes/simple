/// Typed bulk-allocation externs for NDArray factory methods.
///
/// PERF-SUGAR-001 (scilib_port_perf_sugar.md, T-PERFSUGAR-06):
/// Per-element interpreter `push` is O(n²) on large buffers.
/// These externs allocate a zero-filled typed Vec in a single Rust call.
///
/// Use instead of push loops in `zeros`, `ones`, `from_seq`, etc.
/// Must be `nogc_sync_mut` or `common` scope — NOT `gc_async_mut`.

extern fn rt_f64_array_alloc(len: i64) -> [f64]
extern fn rt_f32_array_alloc(len: i64) -> [f32]
extern fn rt_i64_array_alloc(len: i64) -> [i64]
extern fn rt_i32_array_alloc(len: i64) -> [i32]
