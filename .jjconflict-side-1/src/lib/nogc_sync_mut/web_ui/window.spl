# Window manager for web_ui.
# Manages SDL2 windows with associated render bridges.

use std.nogc_sync_mut.io.window_ffi.{
    EventLoop, Window,
    window_create_event_loop,
    window_destroy_event_loop,
    window_create,
    rt_sdl2_destroy_window,
    rt_sdl2_set_window_title,
    rt_sdl2_present_rgba
}
use std.nogc_sync_mut.web_ui.bridge.{RenderBridge}
use examples.browser.shared.logging.{Logger}

# A managed window with its own render bridge.
class WebUIWindow:
    label: text
    window: Window
    bridge: RenderBridge
    width: i64
    height: i64

    static fn create(label: text, window: Window, bridge: RenderBridge, width: i64, height: i64) -> WebUIWindow:
        WebUIWindow(
            label: label,
            window: window,
            bridge: bridge,
            width: width,
            height: height
        )

    # Set HTML content for this window.
    me set_html(html: text):
        self.bridge.set_html(html)

    # Render if dirty and present to SDL2.
    me present():
        if self.bridge.is_dirty():
            self.bridge.render()
        val pixels = self.bridge.get_packed_pixels()
        rt_sdl2_present_rgba(self.window.handle, pixels, self.width, self.height)

    # Handle resize.
    me resize(width: i64, height: i64):
        self.width = width
        self.height = height
        self.bridge.resize(width, height)

# Manages multiple windows and the shared SDL2 event loop.
class WindowManager:
    event_loop: EventLoop
    windows: List<WebUIWindow>
    logger: Logger

    static fn create(logger: Logger) -> WindowManager:
        val event_loop = window_create_event_loop()
        WindowManager(
            event_loop: event_loop,
            windows: List<WebUIWindow>(),
            logger: logger
        )

    # Create a new managed window with HTML content.
    me create_window(label: text, title: text, width: i64, height: i64, html: text) -> WebUIWindow:
        val win = window_create(self.event_loop, width, height, title)
        val bridge = RenderBridge.create(width, height, self.logger)
        bridge.set_html(html)
        val web_win = WebUIWindow.create(label, win, bridge, width, height)
        self.windows.push(web_win)
        web_win

    # Get window by label.
    fn get_window(label: text) -> Option<WebUIWindow>:
        for w in self.windows:
            if w.label == label:
                return Some(w)
        nil

    # Get all window labels.
    fn labels() -> List<text>:
        var result = List<text>()
        for w in self.windows:
            result.push(w.label)
        result

    # Get window count.
    fn window_count() -> i64:
        self.windows.len()

    # Destroy a single window by label.
    me destroy_window(label: text):
        var kept = List<WebUIWindow>()
        for w in self.windows:
            if w.label == label:
                rt_sdl2_destroy_window(w.window.handle)
            else:
                kept.push(w)
        self.windows = kept

    # Destroy all windows and the event loop.
    me destroy_all():
        for w in self.windows:
            rt_sdl2_destroy_window(w.window.handle)
        self.windows = List<WebUIWindow>()
        window_destroy_event_loop(self.event_loop)

    # Present all windows (render dirty + blit).
    me present_all():
        for w in self.windows:
            w.present()
