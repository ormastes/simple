#![allow(primitive_api)]
# ARM Cortex-M Target Definition
# Register layout, calling convention, and debug hardware info for Cortex-M4/M7.

use std.nogc_sync_mut.debug.remote.types.{Architecture, Endianness}

class ArmCortexMTarget:
    _registers: [text]
    _hw_bp_count: i32
    _hw_wp_count: i32
    _core_name: text

impl ArmCortexMTarget:
    # Create a Cortex-M7 target (STM32H7 class)
    static fn cortex_m7() -> ArmCortexMTarget:
        ArmCortexMTarget(
            _registers: arm_cortex_m_registers(),
            _hw_bp_count: 6,
            _hw_wp_count: 4,
            _core_name: "Cortex-M7"
        )

    # Create a Cortex-M33 target (STM32U5 class, ARMv8-M Mainline)
    static fn cortex_m33() -> ArmCortexMTarget:
        ArmCortexMTarget(
            _registers: arm_cortex_m_registers(),
            _hw_bp_count: 8,
            _hw_wp_count: 4,
            _core_name: "Cortex-M33"
        )

    # Create a Cortex-M4 target (STM32WB/F4 class)
    static fn cortex_m4() -> ArmCortexMTarget:
        ArmCortexMTarget(
            _registers: arm_cortex_m_registers(),
            _hw_bp_count: 4,
            _hw_wp_count: 4,
            _core_name: "Cortex-M4"
        )

    fn name() -> text:
        "ARM {self._core_name}"

    fn core_name() -> text:
        self._core_name

    fn arch() -> Architecture:
        Architecture.Arm32

    fn endianness() -> Endianness:
        Endianness.Little

    fn register_count() -> i32:
        self._registers.len()

    fn register_name(index: i32) -> text:
        if index >= 0 and index < self._registers.len():
            self._registers[index]
        else:
            "unknown"

    fn register_index(name: text) -> i32:
        var i = 0
        while i < self._registers.len():
            if self._registers[i] == name:
                return i
            i = i + 1
        -1

    fn register_size(index: i32) -> i32:
        val _ = index
        4

    # ARM AAPCS: r0-r3 for arguments
    fn arg_registers() -> [i32]:
        [0, 1, 2, 3]

    # ARM AAPCS: r4-r11 callee-saved
    fn callee_saved_registers() -> [i32]:
        [4, 5, 6, 7, 8, 9, 10, 11]

    # PC is r15
    fn pc_register_index() -> i32:
        val _ = self._registers.len()
        15

    # SP is r13
    fn sp_register_index() -> i32:
        val _ = self._registers.len()
        13

    # FP is r11 (or r7 in Thumb mode, but r11 is standard for Cortex-M)
    fn fp_register_index() -> i32:
        val _ = self._registers.len()
        11

    # Return value in r0
    fn return_register_index() -> i32:
        val _ = self._registers.len()
        0

    fn hw_breakpoint_count() -> i32:
        self._hw_bp_count

    fn hw_watchpoint_count() -> i32:
        self._hw_wp_count

    fn supports_single_step() -> bool:
        val _ = self._registers.len()
        true

    # Thumb BKPT instruction (0xBE00)
    fn breakpoint_instruction() -> [i32]:
        [0x00, 0xBE]

    # Thumb BKPT as raw bytes
    fn thumb_bkpt_instruction() -> [i32]:
        [0x00, 0xBE]

    fn word_size() -> i32:
        val _ = self._registers.len()
        4

# Shared register list for all Cortex-M variants
fn arm_cortex_m_registers() -> [text]:
    [
        "r0", "r1", "r2", "r3", "r4", "r5", "r6", "r7",
        "r8", "r9", "r10", "r11", "r12", "sp", "lr", "pc",
        "xPSR", "CONTROL", "PRIMASK", "FAULTMASK", "BASEPRI"
    ]
