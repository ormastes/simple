#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.feature.features.FeatureId

fn main():
    describe("Expression evaluation design"):
        it("FeatureId has EvaluateExpression"):
            val feat = FeatureId.EvaluateExpression
            expect(feat.to_string()).to_equal("EvaluateExpression")

        it("placeholder string is not in evaluate error message"):
            val error_msg = "expression eval requires compiled mode or GDB backend"
            expect(error_msg.contains("eval not yet connected")).to_equal(false)

        it("not-attached error is descriptive"):
            val error_msg = "not attached — cannot evaluate expressions"
            expect(error_msg.contains("not attached")).to_equal(true)

        it("evaluate error does not use placeholder"):
            val error_msg = "not attached - cannot evaluate expressions"
            expect(error_msg.contains("eval not yet connected")).to_equal(false)

        it("FeatureId ReadLocals exists for variable lookup"):
            val feat = FeatureId.ReadLocals
            expect(feat.to_string()).to_equal("ReadLocals")

        it("FeatureId ReadGlobals exists for variable lookup"):
            val feat = FeatureId.ReadGlobals
            expect(feat.to_string()).to_equal("ReadGlobals")

        it("FeatureId ReadArguments exists"):
            val feat = FeatureId.ReadArguments
            expect(feat.to_string()).to_equal("ReadArguments")

        it("evaluate fallback mentions compiled mode"):
            val error_msg = "expression eval requires compiled mode or GDB backend"
            expect(error_msg.contains("compiled mode")).to_equal(true)
