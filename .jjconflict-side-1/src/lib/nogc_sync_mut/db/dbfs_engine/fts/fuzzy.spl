# FTS Fuzzy Search — Levenshtein edit distance and fuzzy matching.
#
# Exports: fts_levenshtein, fts_fuzzy_match

use std.io_runtime

# ── Levenshtein edit distance ──────────────────────────────────────────────────
#
# Classic DP using a flat [i64] array simulating a 2D (m+1) x (n+1) matrix.
# matrix[i * (n+1) + j] = edit distance between a[0..i] and b[0..j].

fn fts_levenshtein(a: text, b: text) -> i64:
    val m = a.len() as i64
    val n = b.len() as i64

    if m == 0:
        return n
    if n == 0:
        return m

    # Build flat matrix of size (m+1)*(n+1)
    val cols = n + 1
    val total = (m + 1) * cols
    var matrix: [i64] = []

    # Initialize all cells to 0
    var init_idx: i64 = 0
    while init_idx < total:
        matrix.push(0)
        init_idx = init_idx + 1

    # Initialize first column: matrix[i][0] = i
    var ri: i64 = 0
    while ri <= m:
        matrix[(ri * cols) as i32] = ri
        ri = ri + 1

    # Initialize first row: matrix[0][j] = j
    var ci: i64 = 0
    while ci <= n:
        matrix[ci as i32] = ci
        ci = ci + 1

    # Fill matrix
    var i: i64 = 1
    while i <= m:
        var j: i64 = 1
        while j <= n:
            val a_ch = a.char_at((i - 1) as i32)
            val b_ch = b.char_at((j - 1) as i32)
            var cost: i64 = 1
            if a_ch == b_ch:
                cost = 0
            val del_cost = matrix[((i - 1) * cols + j) as i32] + 1
            val ins_cost = matrix[(i * cols + j - 1) as i32] + 1
            val sub_cost = matrix[((i - 1) * cols + j - 1) as i32] + cost

            var min_cost = del_cost
            if ins_cost < min_cost:
                min_cost = ins_cost
            if sub_cost < min_cost:
                min_cost = sub_cost

            matrix[(i * cols + j) as i32] = min_cost
            j = j + 1
        i = i + 1

    matrix[(m * cols + n) as i32]

# ── Fuzzy match ────────────────────────────────────────────────────────────────

fn fts_fuzzy_match(query: text, candidates: [text], max_distance: i64) -> [text]:
    var matches: [text] = []
    var ci: i32 = 0
    while ci < candidates.len() as i32:
        val dist = fts_levenshtein(query, candidates[ci])
        if dist <= max_distance:
            matches.push(candidates[ci])
        ci = ci + 1
    matches
