# DBFS Checkpoint — snapshot record management.
#
# Wraps CheckpointRing to provide checkpoint_now() and latest_clean().
# Used by recovery (D5) to find the last clean checkpoint.
#
# Maps to: AC-3, AC-5, AC-9, D5.

use std.io_runtime
use std.db.dbfs_engine.checkpoint_ring.{CheckpointRing, RingSlot}
use std.db.dbfs_engine.pager.{PageId}
use std.storage.storage_class.{StorageClass}

struct CheckpointInfo:
    """Result of checkpoint_now() — what was checkpointed."""
    gen:             i64
    btree_root_page: i64
    clean:           bool

struct CheckpointEngine:
    """High-level checkpoint manager backed by a CheckpointRing."""
    ring:        CheckpointRing
    current_gen: i64
    write_pos:   i64

    static fn new() -> CheckpointEngine:
        CheckpointEngine(
            ring:        CheckpointRing.new_persistent(),
            current_gen: 0,
            write_pos:   0
        )

    static fn reopen() -> CheckpointEngine:
        val ring = CheckpointRing.reopen()
        val latest = ring.latest_clean()
        val gen = match latest:
            case None: 0
            case Some(s): s.gen
        CheckpointEngine(
            ring:        ring,
            current_gen: gen,
            write_pos:   0
        )

    me fn checkpoint_now(btree_root_page: i64) -> Result<CheckpointInfo, text>:
        """Write a new clean checkpoint entry and return its info."""
        self.current_gen = self.current_gen + 1
        val slot = RingSlot(
            gen:             self.current_gen,
            clean:           true,
            btree_root_page: btree_root_page
        )
        CheckpointRing.persist_slot(self.write_pos, slot)
        self.write_pos = (self.write_pos + 1) % self.ring.ring_size()
        Ok(CheckpointInfo(
            gen:             self.current_gen,
            btree_root_page: btree_root_page,
            clean:           true
        ))

    fn latest_clean() -> Option<CheckpointInfo>:
        """Return the latest clean checkpoint, or None if none exist."""
        match self.ring.latest_clean():
            case None: None
            case Some(s):
                Some(CheckpointInfo(
                    gen:             s.gen,
                    btree_root_page: s.btree_root_page,
                    clean:           s.clean
                ))

    fn checkpoint_generation() -> i64:
        """Return the current checkpoint generation."""
        self.current_gen

# --- High-level checkpoint API used by specs ---

struct CheckpointRoot:
    """Snapshot descriptor: B-tree root pointer + generation."""
    btree_root: PageId
    gen:        i64

struct CheckpointEntry:
    """Ring entry exposed to callers."""
    gen:             i64
    btree_root_page: i64
    clean:           bool

struct PendingPublish:
    """In-progress publish that can be aborted."""
    root:      CheckpointRoot
    aborted:   bool

    me fn abort():
        """Abort the pending publish; ring is not modified."""
        self.aborted = true

struct DbfsCheckpoint:
    """High-level checkpoint facade: publish / begin_publish / current_root / ring_entries."""
    ring:         CheckpointRing
    current_root: Option<CheckpointRoot>
    write_pos:    i64

    static fn new() -> DbfsCheckpoint:
        DbfsCheckpoint(
            ring:         CheckpointRing.new_persistent(),
            current_root: None,
            write_pos:    0
        )

    me fn publish(root: CheckpointRoot) -> Result<(), text>:
        """Atomically publish a new checkpoint root to the ring.

        Writes directly to the module-static persistent store via CheckpointRing.persist_slot
        to avoid the interpreter value-semantics limitation where me fn on a field copy
        does not propagate the mutation back to self.ring.
        """
        val slot = RingSlot(
            gen:             root.gen,
            clean:           true,
            btree_root_page: root.btree_root.id
        )
        CheckpointRing.persist_slot(self.write_pos, slot)
        self.write_pos = (self.write_pos + 1) % self.ring.ring_size()
        self.current_root = Some(root)
        Ok(())

    fn begin_publish(root: CheckpointRoot) -> PendingPublish:
        """Begin a new publish without committing. Call abort() to cancel."""
        PendingPublish(root: root, aborted: false)

    fn current_root() -> Result<CheckpointRoot, text>:
        """Return the last committed checkpoint root."""
        match self.current_root:
            case None: Err("checkpoint: no root published yet")
            case Some(r): Ok(r)

    fn ring_entries() -> Result<[CheckpointEntry], text>:
        """Return all ring entries as CheckpointEntry list.

        Reads from the persistent store directly to handle cases where
        me fn mutations on self.ring are not visible (interpreter value semantics).
        """
        var result: [CheckpointEntry] = []
        val store = self.ring.current_store()
        var i: i32 = 0
        while i < (store.len() as i32):
            val entry = store[i]
            result.push(CheckpointEntry(
                gen:             entry.slot.gen,
                btree_root_page: entry.slot.btree_root_page,
                clean:           entry.slot.clean
            ))
            i = i + 1
        Ok(result)

    fn last_write_storage_class() -> StorageClass:
        """Return the storage class used by checkpoint writes."""
        StorageClass.MetaDurable
