# GuiRenderer — backend-isolated GUI window facade (backend-isolation Gap A).
#
# Fronts a real OS window (create / poll_events / present_rgba / close) for
# app-layer code WITHOUT any rt_winit_* extern declarations. The deployed
# self-hosted binary does not register that extern family, so this facade
# reaches the winit backend through the sanctioned SFFI sibling-cdylib
# pattern: spl_dlopen("build/sffi/libspl_winit.<ext>") + cached fn pointers +
# spl_wffi_call_i64. Build the cdylib with scripts/build/build_spl_winit.shs.
#
# Engines:
#   "winit" / "auto" — dlopen'd winit+softbuffer cdylib (provenance "winit-dyn")
#   "electron"       — API stub only; returns nil with an honest log line
#
# Boundary rules (why the shape is what it is):
#   * All dlopen'd calls cross as int64 scalars (spl_wffi_call_i64); the window
#     title crosses as a C-string pointer (spl_str_ptr); fractional mouse and
#     wheel coordinates cross as milli-units (x1000 integers).
#   * Pixels never cross inline: the cdylib owns a staging buffer
#     (rt_winit_window_staging_ptr) that present_rgba fills two pixels per
#     rt_ptr_write_i64 poke, then rt_winit_window_present_staged blits it.
#   * Symbols are resolved ONCE at create and cached as fn-pointer fields.
#
# macOS: callers must run with SIMPLE_GUI=1 so the interpreter is on the
# process main thread (winit requirement); the cdylib performs explicit
# NSApplication activation so the window is frontmost and receives input.

use std.sffi.dynamic.{DynLib}

extern fn spl_wffi_call_i64(fptr: i64, args: [i64], nargs: i64) -> i64
extern fn spl_str_ptr(s: text) -> i64
extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64)
extern fn rt_ptr_write_i32(addr: i64, offset: i64, value: i64)
extern fn rt_env_get(key: text) -> text

# Event kind codes — identical to the seed interpreter's winit_sffi constants.
val GUI_EVT_NONE: i64 = 0
val GUI_EVT_RESIZED: i64 = 1
val GUI_EVT_MOVED: i64 = 2
val GUI_EVT_CLOSE: i64 = 3
val GUI_EVT_FOCUSED: i64 = 5
val GUI_EVT_UNFOCUSED: i64 = 6
val GUI_EVT_SCALE_CHANGED: i64 = 7
val GUI_EVT_KEYBOARD: i64 = 10
val GUI_EVT_MOUSE_BUTTON: i64 = 20
val GUI_EVT_MOUSE_MOVED: i64 = 21
val GUI_EVT_MOUSE_WHEEL: i64 = 22

# Typed event record. kind == GUI_EVT_NONE means "no event pending".
class GuiEvent:
    kind: i64
    scancode: i64
    keycode: i64
    btn: i64
    pressed: bool
    x: f64
    y: f64

impl GuiEvent:
    static fn none() -> GuiEvent:
        GuiEvent(kind: GUI_EVT_NONE, scancode: 0, keycode: 0, btn: 0, pressed: false, x: 0.0, y: 0.0)

class GuiRenderer:
    engine: text
    el: i64
    win: i64
    width: i64
    height: i64
    fp_poll: i64
    fp_type: i64
    fp_key_scancode: i64
    fp_key_keycode: i64
    fp_key_pressed: i64
    fp_mouse_button: i64
    fp_mouse_pressed: i64
    fp_mouse_x: i64
    fp_mouse_y: i64
    fp_wheel_x: i64
    fp_wheel_y: i64
    fp_staging: i64
    fp_stage_clear: i64
    fp_stage_fill_rect: i64
    fp_present: i64
    fp_event_free: i64
    fp_window_free: i64
    fp_loop_free: i64

# Candidate library paths, tried in order by actual dlopen attempt (platform
# detection via env vars is unreliable — OSTYPE is usually not exported).
fn gui_renderer_lib_candidates() -> [text]:
    var out: [text] = []
    val override = rt_env_get("SIMPLE_SPL_WINIT_PATH") ?? ""
    if override != "":
        out.push(override)
    out.push("build/sffi/libspl_winit.dylib")
    out.push("build/sffi/libspl_winit.so")
    out.push("build/sffi/libspl_winit.dll")
    out

impl GuiRenderer:
    # Sentinel instance (win == 0) for non-optional storage slots.
    static fn empty() -> GuiRenderer:
        GuiRenderer(
            engine: "", el: 0, win: 0, width: 0, height: 0,
            fp_poll: 0, fp_type: 0,
            fp_key_scancode: 0, fp_key_keycode: 0, fp_key_pressed: 0,
            fp_mouse_button: 0, fp_mouse_pressed: 0,
            fp_mouse_x: 0, fp_mouse_y: 0, fp_wheel_x: 0, fp_wheel_y: 0,
            fp_staging: 0, fp_stage_clear: 0, fp_stage_fill_rect: 0, fp_present: 0,
            fp_event_free: 0, fp_window_free: 0, fp_loop_free: 0
        )

    # Open a real window. Returns nil (with one clear log line) on failure.
    static fn create(engine: text, w: i32, h: i32, title: text) -> GuiRenderer?:
        if engine == "electron":
            print "GuiRenderer: engine 'electron' is an API stub (not implemented) — no window opened"
            return nil
        if engine != "winit" and engine != "auto" and engine != "":
            print "GuiRenderer: unknown engine '{engine}' (supported: winit, auto, electron-stub)"
            return nil

        val candidates = gui_renderer_lib_candidates()
        var l = DynLib(handle: 0, path: "")
        var i = 0
        while i < candidates.len() and l.handle == 0:
            val attempt = DynLib.open(candidates[i])
            if attempt.handle != 0:
                l = attempt
            i = i + 1
        if l.handle == 0:
            print "GuiRenderer: cannot load build/sffi/libspl_winit.<dylib|so|dll> — build it with: sh scripts/build/build_spl_winit.shs (or set SIMPLE_SPL_WINIT_PATH)"
            return nil

        val fp_loop_new = l.sym("rt_winit_event_loop_new")
        val fp_window_new = l.sym("rt_winit_window_new")
        if fp_loop_new == 0 or fp_window_new == 0:
            print "GuiRenderer: '{l.path}' is missing rt_winit_* exports — rebuild with scripts/build/build_spl_winit.shs"
            return nil
        val el = spl_wffi_call_i64(fp_loop_new, [], 0)
        if el == 0:
            print "GuiRenderer: event loop creation failed (macOS needs SIMPLE_GUI=1 for main-thread execution)"
            return nil
        val title_ptr = spl_str_ptr(title)
        val win = spl_wffi_call_i64(fp_window_new, [el, w.to_i64(), h.to_i64(), title_ptr], 4)
        if win == 0:
            print "GuiRenderer: window creation failed"
            return nil
        GuiRenderer(
            engine: "winit-dyn",
            el: el,
            win: win,
            width: w.to_i64(),
            height: h.to_i64(),
            fp_poll: l.sym("rt_winit_event_loop_poll_events"),
            fp_type: l.sym("rt_winit_event_get_type"),
            fp_key_scancode: l.sym("rt_winit_event_key_scancode"),
            fp_key_keycode: l.sym("rt_winit_event_key_keycode"),
            fp_key_pressed: l.sym("rt_winit_event_key_pressed"),
            fp_mouse_button: l.sym("rt_winit_event_mouse_button"),
            fp_mouse_pressed: l.sym("rt_winit_event_mouse_pressed"),
            fp_mouse_x: l.sym("rt_winit_event_mouse_x_milli"),
            fp_mouse_y: l.sym("rt_winit_event_mouse_y_milli"),
            fp_wheel_x: l.sym("rt_winit_event_wheel_x_milli"),
            fp_wheel_y: l.sym("rt_winit_event_wheel_y_milli"),
            fp_staging: l.sym("rt_winit_window_staging_ptr"),
            fp_stage_clear: l.sym("rt_winit_window_stage_clear"),
            fp_stage_fill_rect: l.sym("rt_winit_window_stage_fill_rect"),
            fp_present: l.sym("rt_winit_window_present_staged"),
            fp_event_free: l.sym("rt_winit_event_free"),
            fp_window_free: l.sym("rt_winit_window_free"),
            fp_loop_free: l.sym("rt_winit_event_loop_free")
        )

    # Provenance label for honest evidence trails.
    fn engine_label() -> text:
        self.engine

    fn is_open() -> bool:
        self.win != 0

    # Poll one pending event. kind == GUI_EVT_NONE when the queue is empty.
    # The native event handle is freed before returning — callers only ever
    # see the typed record.
    fn poll_event() -> GuiEvent:
        if self.win == 0:
            return GuiEvent.none()
        val ev = spl_wffi_call_i64(self.fp_poll, [self.el, 1], 2)
        if ev == 0:
            return GuiEvent.none()
        val ty = spl_wffi_call_i64(self.fp_type, [ev], 1)
        var out = GuiEvent.none()
        if ty == GUI_EVT_KEYBOARD:
            val sc = spl_wffi_call_i64(self.fp_key_scancode, [ev], 1)
            val kc = spl_wffi_call_i64(self.fp_key_keycode, [ev], 1)
            val kp = spl_wffi_call_i64(self.fp_key_pressed, [ev], 1)
            out = GuiEvent(kind: ty, scancode: sc, keycode: kc, btn: 0, pressed: kp == 1, x: 0.0, y: 0.0)
        elif ty == GUI_EVT_MOUSE_BUTTON:
            val btn = spl_wffi_call_i64(self.fp_mouse_button, [ev], 1)
            val mp = spl_wffi_call_i64(self.fp_mouse_pressed, [ev], 1)
            out = GuiEvent(kind: ty, scancode: 0, keycode: 0, btn: btn, pressed: mp == 1, x: 0.0, y: 0.0)
        elif ty == GUI_EVT_MOUSE_MOVED:
            val mx = spl_wffi_call_i64(self.fp_mouse_x, [ev], 1)
            val my = spl_wffi_call_i64(self.fp_mouse_y, [ev], 1)
            out = GuiEvent(kind: ty, scancode: 0, keycode: 0, btn: 0, pressed: false, x: mx.to_f64() / 1000.0, y: my.to_f64() / 1000.0)
        elif ty == GUI_EVT_MOUSE_WHEEL:
            val wx = spl_wffi_call_i64(self.fp_wheel_x, [ev], 1)
            val wy = spl_wffi_call_i64(self.fp_wheel_y, [ev], 1)
            out = GuiEvent(kind: ty, scancode: 0, keycode: 0, btn: 0, pressed: false, x: wx.to_f64() / 1000.0, y: wy.to_f64() / 1000.0)
        else:
            out = GuiEvent(kind: ty, scancode: 0, keycode: 0, btn: 0, pressed: false, x: 0.0, y: 0.0)
        spl_wffi_call_i64(self.fp_event_free, [ev], 1)
        out

    # Present an XRGB frame (one i64 per pixel, 0x00RRGGBB). The staging
    # buffer is filled two pixels per poke, then blitted by the cdylib.
    fn present_rgba(w: i64, h: i64, pixels: [i64]) -> bool:
        if self.win == 0:
            return false
        val sp = spl_wffi_call_i64(self.fp_staging, [self.win, w, h], 3)
        if sp == 0:
            return false
        val count = pixels.len()
        var i = 0
        while i + 1 < count:
            val packed = pixels[i] + pixels[i + 1] * 4294967296
            rt_ptr_write_i64(sp, (i * 4).to_i64(), packed)
            i = i + 2
        if i < count:
            rt_ptr_write_i32(sp, (i * 4).to_i64(), pixels[i])
        spl_wffi_call_i64(self.fp_present, [self.win, w, h], 3) == 1

    fn present_argb_u32(w: i64, h: i64, pixels: [u32]) -> bool:
        if self.win == 0:
            return false
        val sp = spl_wffi_call_i64(self.fp_staging, [self.win, w, h], 3)
        if sp == 0:
            return false
        val count = pixels.len()
        var i = 0
        while i + 1 < count:
            val packed = pixels[i].to_i64() + pixels[i + 1].to_i64() * 4294967296
            rt_ptr_write_i64(sp, (i * 4).to_i64(), packed)
            i = i + 2
        if i < count:
            rt_ptr_write_i32(sp, (i * 4).to_i64(), pixels[i].to_i64())
        spl_wffi_call_i64(self.fp_present, [self.win, w, h], 3) == 1

    fn stage_blit_argb_u32(x: i64, y: i64, w: i64, h: i64, dst_w: i64, dst_h: i64, pixels: [u32]) -> bool:
        if self.win == 0:
            return false
        val sp = spl_wffi_call_i64(self.fp_staging, [self.win, dst_w, dst_h], 3)
        if sp == 0 or w <= 0 or h <= 0:
            return false
        val src_len = pixels.len().to_i64()
        var row: i64 = 0
        while row < h:
            val dy = y + row
            if dy >= 0 and dy < dst_h:
                var col0: i64 = if x < 0: 0 - x else: 0
                var col1: i64 = w
                if x + col1 > dst_w:
                    col1 = dst_w - x
                var col = col0
                var src_idx = row * w + col0
                var dst_idx = dy * dst_w + x + col0
                while col < col1:
                    if src_idx >= 0 and src_idx < src_len and dst_idx >= 0:
                        rt_ptr_write_i32(sp, dst_idx * 4, pixels[src_idx.to_i32()].to_i64())
                    src_idx = src_idx + 1
                    dst_idx = dst_idx + 1
                    col = col + 1
            row = row + 1
        true

    fn stage_clear(w: i64, h: i64, color: u32) -> bool:
        if self.win == 0 or self.fp_stage_clear == 0:
            return false
        spl_wffi_call_i64(self.fp_stage_clear, [self.win, w, h, color.to_i64()], 4) == 1

    fn stage_fill_rect(x: i64, y: i64, w: i64, h: i64, color: u32) -> bool:
        if self.win == 0 or self.fp_stage_fill_rect == 0:
            return false
        spl_wffi_call_i64(self.fp_stage_fill_rect, [self.win, x, y, w, h, color.to_i64()], 6) == 1

    fn present_staged(w: i64, h: i64) -> bool:
        if self.win == 0:
            return false
        spl_wffi_call_i64(self.fp_present, [self.win, w, h], 3) == 1

    # Destroy the window and event loop. Safe to call twice.
    me close():
        if self.win != 0:
            spl_wffi_call_i64(self.fp_window_free, [self.win], 1)
            self.win = 0
        if self.el != 0:
            spl_wffi_call_i64(self.fp_loop_free, [self.el], 1)
            self.el = 0

export GUI_EVT_NONE
export GUI_EVT_RESIZED
export GUI_EVT_MOVED
export GUI_EVT_CLOSE
export GUI_EVT_FOCUSED
export GUI_EVT_UNFOCUSED
export GUI_EVT_SCALE_CHANGED
export GUI_EVT_KEYBOARD
export GUI_EVT_MOUSE_BUTTON
export GUI_EVT_MOUSE_MOVED
export GUI_EVT_MOUSE_WHEEL
