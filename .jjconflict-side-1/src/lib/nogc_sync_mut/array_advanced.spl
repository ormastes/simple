# @alloc
# Array Advanced Collection Utilities
#
# Extracted from array.spl. Contains:
# - group_consecutive, transpose, cartesian_product
# - frequencies, mode, median
# - intersect, difference, union, is_subset
# - starts_with, ends_with, index_of_subarray, contains_subarray

# ============================================================================
# Advanced Collection Utilities (from collection_utils.spl)
# ============================================================================

fn array_group_consecutive(arr: [Any]):
    """Group consecutive equal elements.

    Example:
        array_group_consecutive([1,1,2,2,2,3,1])
        # [[1,1], [2,2,2], [3], [1]]
    """
    if arr.len() == 0:
        return []

    var result = []
    var current_group = [arr[0]]

    var i = 1
    while i < arr.len():
        if arr[i] == arr[i-1]:
            current_group.push(arr[i])
        else:
            result.push(current_group)
            current_group = [arr[i]]
        i = i + 1

    result.push(current_group)
    result

fn array_transpose(matrix: [[Any]]):
    """Transpose a 2D array (matrix).

    Example:
        array_transpose([[1,2,3], [4,5,6]])
        # [[1,4], [2,5], [3,6]]
    """
    if matrix.len() == 0:
        return []

    val rows = matrix.len()
    val cols = matrix[0].len()
    var row_check = 0
    while row_check < rows:
        if matrix[row_check].len() != cols:
            return []
        row_check = row_check + 1

    var result = []
    var col = 0
    while col < cols:
        var new_row = []
        var row = 0
        while row < rows:
            new_row.push(matrix[row][col])
            row = row + 1
        result.push(new_row)
        col = col + 1

    result

fn array_cartesian_product(arr1: [Any], arr2: [Any]):
    """Cartesian product of two arrays.

    Returns array of tuples representing all pairs.

    Example:
        array_cartesian_product([1,2], [3,4])
        # [(1,3), (1,4), (2,3), (2,4)]
    """
    var result = []

    for a in arr1:
        for b in arr2:
            result.push((a, b))

    result

fn array_frequencies(arr: [Any]):
    """Count element frequencies.

    Returns array of (element, count) tuples.

    Example:
        array_frequencies([1,2,2,3,3,3])
        # [(1,1), (2,2), (3,3)]
    """
    var counts = []

    for item in arr:
        var found = false
        var idx = 0
        while idx < counts.len():
            val (elem, count) = counts[idx]
            if elem == item:
                counts[idx] = (elem, count + 1)
                found = true
                break
            idx = idx + 1

        if not found:
            counts.push((item, 1))

    counts

fn array_mode(arr: [Any]):
    """Find most common element.

    Returns the element that appears most frequently.
    If multiple elements tie, returns the first one encountered.

    Returns nil for empty array.
    """
    if arr.len() == 0:
        return nil

    val freqs = array_frequencies(arr)

    var max_count = 0
    var mode_elem = nil

    for (elem, count) in freqs:
        if count > max_count:
            max_count = count
            mode_elem = elem

    mode_elem

fn array_median(arr: [Any]):
    """Find median value of sorted numeric array.

    Array must be sorted for correct result.
    Returns nil for empty array.
    """
    if arr.len() == 0:
        return nil

    val mid = arr.len() / 2
    if arr.len() % 2 == 1:
        return arr[mid]

    (arr[mid - 1] + arr[mid]) / 2

fn array_intersect(arr1: [Any], arr2: [Any]):
    """Find common elements (set intersection).

    Returns elements that appear in both arrays.
    Duplicates are removed.

    Example:
        array_intersect([1,2,3], [2,3,4])  # [2,3]
    """
    var result = []
    var right_seen = {}
    var added = {}

    for item in arr2:
        right_seen["{item}"] = true

    for item in arr1:
        val key = "{item}"
        if right_seen.has(key) and not added.has(key):
            result.push(item)
            added[key] = true

    result

fn array_difference(arr1: [Any], arr2: [Any]):
    """Find elements in arr1 but not in arr2 (set difference).

    Example:
        array_difference([1,2,3,4], [2,4])  # [1,3]
    """
    var result = []
    var right_seen = {}
    var added = {}

    for item in arr2:
        right_seen["{item}"] = true

    for item in arr1:
        val key = "{item}"
        if not right_seen.has(key) and not added.has(key):
            result.push(item)
            added[key] = true

    result

fn array_union(arr1: [Any], arr2: [Any]):
    """Combine unique elements from both arrays (set union).

    Example:
        array_union([1,2,3], [3,4,5])  # [1,2,3,4,5]
    """
    var result = []
    var seen = {}

    for item in arr1:
        val key = "{item}"
        if not seen.has(key):
            result.push(item)
            seen[key] = true

    for item in arr2:
        val key = "{item}"
        if not seen.has(key):
            result.push(item)
            seen[key] = true

    result

fn array_is_subset(arr1: [Any], arr2: [Any]):
    """Check if arr1 is a subset of arr2.

    Returns true if all elements of arr1 are in arr2.
    """
    var right_seen = {}
    for item in arr2:
        right_seen["{item}"] = true

    for item in arr1:
        if not right_seen.has("{item}"):
            return false

    true

fn array_starts_with(arr: [Any], prefix: [Any]):
    """Check if array starts with given prefix array.

    Example:
        array_starts_with([1,2,3,4], [1,2])  # true
    """
    if prefix.len() > arr.len():
        return false

    var i = 0
    while i < prefix.len():
        if arr[i] != prefix[i]:
            return false
        i = i + 1

    true

fn array_ends_with(arr: [Any], suffix: [Any]):
    """Check if array ends with given suffix array.

    Example:
        array_ends_with([1,2,3,4], [3,4])  # true
    """
    if suffix.len() > arr.len():
        return false

    val offset = arr.len() - suffix.len()
    var i = 0
    while i < suffix.len():
        if arr[offset + i] != suffix[i]:
            return false
        i = i + 1

    true

fn array_index_of_subarray(arr: [Any], subarray: [Any]):
    """Find index of first occurrence of subarray.

    Returns -1 if not found.

    Example:
        array_index_of_subarray([1,2,3,2,3], [2,3])  # 1
    """
    if subarray.len() == 0 or subarray.len() > arr.len():
        return -1

    var i = 0
    while i <= arr.len() - subarray.len():
        var match = true
        var j = 0
        while j < subarray.len():
            if arr[i + j] != subarray[j]:
                match = false
                break
            j = j + 1

        if match:
            return i

        i = i + 1

    -1

fn array_contains_subarray(arr: [Any], subarray: [Any]):
    """Check if array contains subarray.

    Example:
        array_contains_subarray([1,2,3,4], [2,3])  # true
    """
    array_index_of_subarray(arr, subarray) >= 0
