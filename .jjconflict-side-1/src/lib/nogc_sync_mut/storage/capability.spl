# Capability — optional device features probed at mount.
#
# Every capability is optional; NVFS maintains a generic fallback path for
# every backend. The probe table is filled at mount time and spostgre /
# other consumers consult it to pick the fast path when available.
#
# Source: doc/05_design/nvfs_design.md §6, doc/05_design/nvfs/from_spostgre.md §S5.

enum Capability:
    """Optional NVMe / block device capabilities.

    ZNS                    — Zoned Namespace Command Set (zone append).
    FDP                    — Flexible Data Placement (PID per stream).
    CMB                    — Controller Memory Buffer (host-visible SRAM).
    PMR                    — Persistent Memory Region (byte-addressable).
    Flush                  — NVMe Flush command supported.
    FUA                    — Force Unit Access bit per write.
    CompareAndWrite        — atomic compare-and-write for pmap publish.
    MultipleAtomicityMode  — multiple NAWUN / NAWUPF modes visible.
    CopyOffload            — Simple Copy Command for clone_range.
    DatasetManagement      — DSM trim / deallocate.
    """
    ZNS
    FDP
    CMB
    PMR
    Flush
    FUA
    CompareAndWrite
    MultipleAtomicityMode
    CopyOffload
    DatasetManagement

impl Capability:
    fn to_string() -> text:
        match self:
            case ZNS: "ZNS"
            case FDP: "FDP"
            case CMB: "CMB"
            case PMR: "PMR"
            case Flush: "Flush"
            case FUA: "FUA"
            case CompareAndWrite: "CompareAndWrite"
            case MultipleAtomicityMode: "MultipleAtomicityMode"
            case CopyOffload: "CopyOffload"
            case DatasetManagement: "DatasetManagement"

trait CapabilityProbe:
    """Probe a backend for an optional capability.

    Implementations live in the NVFS driver shim (examples/nvfs/src/driver/)
    and in test doubles. Callers MUST treat absence as the default and only
    fast-path when `has(cap)` returns true.
    """
    fn has(cap: Capability) -> bool
    fn preferred_granule_bytes() -> i64
    fn atomic_write_unit_bytes() -> i64
