# ============================================================================
# game_net/predictor.spl — client-side prediction
#
# Netcode plan P2: apply local input immediately (no waiting for the
# server), advance the predicted tick ahead of the last confirmed server
# tick, and buffer every applied input so the reconciler can replay it once
# an authoritative snapshot arrives.
# ============================================================================

use std.nogc_sync_mut.game_net.demo_sim.{SimState, sim_state_new, sim_step}
use std.nogc_sync_mut.game_net.wire.{InputFrame}
use std.nogc_sync_mut.game_net.input_buffer.{InputBuffer}

class Predictor:
    state: SimState
    local_tick: u32
    server_tick: u32
    seq_counter: u32
    inputs: InputBuffer

impl Predictor:
    static fn new(entity_id: u32) -> Predictor:
        Predictor(
            state: sim_state_new(entity_id), local_tick: 0u32, server_tick: 0u32,
            seq_counter: 0u32, inputs: InputBuffer.new()
        )

    me apply_input(move_x: f32, move_y: f32, dt: f32) -> InputFrame:
        """Predict immediately: advance local_tick, step the sim, buffer the
        input for later replay."""
        self.seq_counter = self.seq_counter + 1u32
        self.local_tick = self.local_tick + 1u32
        val frame = InputFrame(seq: self.seq_counter, tick: self.local_tick, move_x: move_x, move_y: move_y)
        self.inputs.push(frame)
        self.state = sim_step(self.state, move_x, move_y, dt)
        frame

    fn prediction_ahead() -> u32:
        """local_tick - server_tick: how many ticks ahead of the last
        confirmed authority this client is currently predicting."""
        self.local_tick - self.server_tick

export Predictor
