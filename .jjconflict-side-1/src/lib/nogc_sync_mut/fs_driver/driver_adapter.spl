# Driver-framework adapter for the FAT32 wrapper.
#
# The adapter probes registered stdlib-local FAT32-like block devices and
# returns a local handle-table slot on attach.

use std.driver.error.{DriverError}
use std.driver.manifest.{DriverManifest, DRVS_ABI_REV}
use std.driver.registry.{DriverOps}
use std.driver.static_table.{register_static_driver}
use std.driver.types.{DriverClass, DriverHandle, DriverContext, DeviceId,
                      IoctlCmd, PowerState, ProbeResult}
use std.fs_driver.fat32_core.{fat32_test_device_mount, fat32_test_device_probe,
                              fat32_test_device_unmount}

var __fat32_handle_slots: [i64] = []

fn __fat32_alloc_handle(device_slot: i64) -> i32:
    var i: i32 = 0
    while i < __fat32_handle_slots.len().to_i32():
        if __fat32_handle_slots[i] < 0:
            __fat32_handle_slots[i] = device_slot
            return i
        i = i + 1
    __fat32_handle_slots.push(device_slot)
    return __fat32_handle_slots.len().to_i32() - 1

fn __fat32_free_handle(idx: i32) -> bool:
    if idx < 0 or idx >= __fat32_handle_slots.len().to_i32():
        return false
    if __fat32_handle_slots[idx] < 0:
        return false
    __fat32_handle_slots[idx] = -1
    true

fn fat32_abi_rev() -> i32:
    return DRVS_ABI_REV

fn fat32_init(ctx: DriverContext) -> Result<(), DriverError>:
    return Result.Ok(())

fn fat32_probe(dev: DeviceId) -> Result<ProbeResult, DriverError>:
    if dev.dclass != DriverClass.Block:
        return Result.Ok(ProbeResult.Reject)
    val probe = fat32_test_device_probe(dev)
    if probe.is_err():
        return Result.Ok(ProbeResult.Reject)
    if probe.unwrap():
        return Result.Ok(ProbeResult.Accept)
    return Result.Ok(ProbeResult.Reject)

fn fat32_attach(dev: DeviceId) -> Result<DriverHandle, DriverError>:
    if dev.dclass != DriverClass.Block:
        return Result.Err(DriverError.BadArg)
    val probe = fat32_test_device_probe(dev)
    if probe.is_err() or not probe.unwrap():
        return Result.Err(DriverError.NoDevice)
    val mount_rc = fat32_test_device_mount(dev)
    if mount_rc.is_err():
        return Result.Err(DriverError.BadConfig)
    val slot = __fat32_alloc_handle(dev.value)
    return Result.Ok(DriverHandle(value: slot as i64))

fn fat32_detach(h: DriverHandle) -> Result<(), DriverError>:
    val idx = h.value as i32
    if idx < 0 or idx >= __fat32_handle_slots.len().to_i32():
        return Result.Err(DriverError.BadArg)
    val device_slot = __fat32_handle_slots[idx]
    if device_slot < 0:
        return Result.Err(DriverError.BadArg)
    val unmount_rc = fat32_test_device_unmount(DeviceId(value: device_slot, dclass: DriverClass.Block))
    if unmount_rc.is_err():
        return Result.Err(DriverError.BadConfig)
    val ok: bool = __fat32_free_handle(idx)
    if not ok:
        return Result.Err(DriverError.BadArg)
    return Result.Ok(())

fn fat32_suspend(h: DriverHandle, s: PowerState) -> Result<(), DriverError>:
    return Result.Ok(())

fn fat32_resume(h: DriverHandle) -> Result<(), DriverError>:
    return Result.Ok(())

fn fat32_ioctl(h: DriverHandle, cmd: IoctlCmd) -> Result<i64, DriverError>:
    return Result.Err(DriverError.NotSupported)

fn register_fat32_driver() -> Result<i32, DriverError>:
    val m: DriverManifest = DriverManifest.for_driver(
        "fat32_stub", "0.1", DriverClass.Fs, 0, [0])
    val ops: DriverOps = DriverOps(
        self_ptr: 0,
        manifest_abi: fat32_abi_rev,
        init_fn:   fat32_init,
        probe_fn:  fat32_probe,
        attach_fn: fat32_attach,
        detach_fn: fat32_detach,
        suspend_fn: fat32_suspend,
        resume_fn:  fat32_resume,
        ioctl_fn:   fat32_ioctl,
    )
    return register_static_driver(m, ops)
