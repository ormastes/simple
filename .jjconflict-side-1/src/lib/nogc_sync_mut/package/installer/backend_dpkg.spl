# dpkg-deb Backend
#
# Native Debian package builder using dpkg-deb.
# Zero external dependencies beyond dpkg-deb (standard on Debian/Ubuntu).
# Used as fallback when FPM is not available.
#
# Refactored from: src/compiler/80.driver/build/build_deb.spl

use std.io_runtime (process_run, file_exists, file_write, dir_create, is_dir, dir_remove)

use lib.nogc_sync_mut.package.installer.types (InstallerConfig, InstallerResult, InstallerPlatform)
use lib.nogc_sync_mut.package.installer.staging (create_staging_dir, clean_staging_dir, staging_dir)


fn build_with_dpkg(config: InstallerConfig) -> InstallerResult:
    """Build a .deb package using dpkg-deb directly."""

    val platform = InstallerPlatform.Deb

    # Create staging directory with unix layout
    val staging_result = create_staging_dir(config, platform)
    if staging_result.is_err():
        return InstallerResult(
            platform: platform,
            success: false,
            output_path: "",
            message: staging_result.err()
        )

    val staging_path = staging_result.ok()

    # Ensure output directory exists
    dir_create(config.output_dir, recursive: true)

    # Create DEBIAN control directory
    dir_create("{staging_path}/DEBIAN", recursive: true)

    # Create control file
    create_control_file(config, staging_path)

    # Create maintainer scripts
    create_postinst(config, staging_path)
    create_postrm(config, staging_path)

    # Build package
    val output_file = "{config.output_dir}/{config.package_name}_{config.version}_{config.architecture}.deb"

    val (stdout, stderr, code) = process_run("dpkg-deb",
        ["--build", "--root-owner-group", staging_path, output_file])

    # Clean up staging
    clean_staging_dir(config, platform)

    if code != 0:
        return InstallerResult(
            platform: platform,
            success: false,
            output_path: "",
            message: "dpkg-deb failed (exit {code}): {stderr}"
        )

    InstallerResult(
        platform: platform,
        success: true,
        output_path: output_file,
        message: "Built Debian package successfully (dpkg-deb)"
    )


fn create_control_file(config: InstallerConfig, staging_path: text):
    """Create DEBIAN/control file."""
    # Calculate installed size
    val (size_out, _, _) = process_run("du", ["-sk", "{staging_path}/usr"])
    val size = size_out.split("\t")[0].trim()

    var control = "Package: {config.package_name}\n"
    control = control + "Version: {config.version}\n"
    control = control + "Section: devel\n"
    control = control + "Priority: optional\n"
    control = control + "Architecture: {config.architecture}\n"
    control = control + "Maintainer: {config.maintainer}\n"
    control = control + "Homepage: {config.homepage}\n"
    control = control + "Description: {config.description}\n"
    control = control + " The Simple programming language - a modern, fast, and expressive language\n"
    control = control + " designed for clarity and productivity.\n"
    control = control + "Depends: libc6 (>= 2.31)\n"
    control = control + "Installed-Size: {size}\n"

    file_write("{staging_path}/DEBIAN/control", control)


fn create_postinst(config: InstallerConfig, staging_path: text):
    """Create post-installation script."""
    var script = "#!/bin/bash\n"
    script = script + "set -e\n\n"
    script = script + "mkdir -p /var/cache/simple\n"
    script = script + "chmod 755 /var/cache/simple\n\n"
    script = script + "if [ -x \"$(command -v ldconfig)\" ]; then\n"
    script = script + "    ldconfig\n"
    script = script + "fi\n\n"
    script = script + "echo \"Simple Language {config.version} installed successfully!\"\n"

    file_write("{staging_path}/DEBIAN/postinst", script)
    val (_, _, _) = process_run("chmod", ["755", "{staging_path}/DEBIAN/postinst"])


fn create_postrm(config: InstallerConfig, staging_path: text):
    """Create post-removal script."""
    var script = "#!/bin/bash\n"
    script = script + "set -e\n\n"
    script = script + "if [ \"$1\" = \"purge\" ]; then\n"
    script = script + "    rm -rf /var/cache/simple\n"
    script = script + "fi\n"

    file_write("{staging_path}/DEBIAN/postrm", script)
    val (_, _, _) = process_run("chmod", ["755", "{staging_path}/DEBIAN/postrm"])
