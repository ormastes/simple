"""
# Active Model

Wraps a Repository<T> with model-level validations and pagination.
Validates before saving/updating and returns structured errors.

## Usage

```simple
var model = ActiveModel.new(repo)
model = model.validates_presence("name")
model = model.validates_length("name", 2, 100)

val result = model.save(User(name: "Alice", age: 30))
match result:
    Ok(id): print "Created with id {id}"
    Err(msg): print "Validation failed: {msg}"

val page = model.paginate(1, 25)?
```
"""

use std.database.sql.repository.{Repository}
use std.database.sql.types.{DbError}
use std.web_framework.pagination.{Paginator, PagedResult}

# ============================================================================
# Model Validation
# ============================================================================

class ModelValidation:
    """A single model-level validation rule."""
    field: text
    rule_type: text
    min_val: i64
    max_val: i64

fn make_presence_validation(field: text) -> ModelValidation:
    """Create a presence validation rule."""
    ModelValidation(field: field, rule_type: "presence", min_val: 0, max_val: 0)

fn make_length_validation(field: text, min: i64, max: i64) -> ModelValidation:
    """Create a length validation rule."""
    ModelValidation(field: field, rule_type: "length", min_val: min, max_val: max)

fn make_format_validation(field: text, format: text) -> ModelValidation:
    """Create a format validation rule (e.g., 'email')."""
    ModelValidation(field: field, rule_type: format, min_val: 0, max_val: 0)

# ============================================================================
# ActiveModel
# ============================================================================

class ActiveModel<T>:
    """Model wrapper with validations and pagination over Repository<T>.

    Adds validation logic around the raw repository CRUD operations.
    """
    repo: Repository<T>
    validations: [ModelValidation]

impl ActiveModel<T>:
    static fn new(repo: Repository<T>) -> ActiveModel<T>:
        """Create an ActiveModel with no validations."""
        ActiveModel(repo: repo, validations: [])

    me validates_presence(field: text) -> ActiveModel<T>:
        """Add a presence validation for a field.

        The field must be non-empty when saving/updating.

        Args:
            field: Field name to validate

        Returns:
            Self for chaining
        """
        self.validations.push(make_presence_validation(field))
        self

    me validates_length(field: text, min: i64, max: i64) -> ActiveModel<T>:
        """Add a length validation for a field.

        The field value length must be between min and max (inclusive).

        Args:
            field: Field name to validate
            min: Minimum length
            max: Maximum length

        Returns:
            Self for chaining
        """
        self.validations.push(make_length_validation(field, min, max))
        self

    me validates_format(field: text, format: text) -> ActiveModel<T>:
        """Add a format validation (e.g., 'email', 'numeric').

        Args:
            field: Field name to validate
            format: Format type string

        Returns:
            Self for chaining
        """
        self.validations.push(make_format_validation(field, format))
        self

    me save(entity: T) -> Result<i64, text>:
        """Validate and insert an entity.

        Runs all validations first. If any fail, returns Err with
        comma-separated error messages.

        Args:
            entity: Entity to insert

        Returns:
            Ok(id) of inserted row, or Err with validation errors
        """
        val errors = run_validations(self.validations)
        if errors.len() > 0:
            return Err(errors.join(", "))

        val result = self.repo.insert(entity)
        match result:
            Ok(id): Ok(id)
            Err(e): Err("Database error on save")

    me update_record(id: i64, entity: T) -> Result<(), text>:
        """Validate and update an entity by ID.

        Args:
            id: Row ID to update
            entity: Updated entity data

        Returns:
            Ok(()) on success, Err on validation or DB failure
        """
        val errors = run_validations(self.validations)
        if errors.len() > 0:
            return Err(errors.join(", "))

        val result = self.repo.update(id, entity)
        match result:
            Ok(_): Ok(())
            Err(e): Err("Database error on update")

    me destroy(id: i64) -> Result<(), text>:
        """Delete an entity by ID.

        Args:
            id: Row ID to delete

        Returns:
            Ok(()) on success
        """
        val result = self.repo.delete_by_id(id)
        match result:
            Ok(_): Ok(())
            Err(e): Err("Database error on delete")

    fn find(id: i64) -> Result<T?, text>:
        """Find an entity by ID.

        Args:
            id: Row ID to find

        Returns:
            Ok(Some(entity)) if found, Ok(nil) if not, Err on failure
        """
        val result = self.repo.find_by_id(id)
        match result:
            Ok(entity): Ok(entity)
            Err(e): Err("Database error on find")

    fn all() -> Result<[T], text>:
        """Get all entities.

        Returns:
            Ok(list) of all entities
        """
        val result = self.repo.find_all()
        match result:
            Ok(entities): Ok(entities)
            Err(e): Err("Database error on find_all")

    fn count() -> Result<i64, text>:
        """Count all entities.

        Returns:
            Ok(count) total number of entities
        """
        val result = self.repo.count()
        match result:
            Ok(n): Ok(n)
            Err(e): Err("Database error on count")

    fn paginate(page: i64, per_page: i64) -> Result<PagedResult<T>, text>:
        """Get a paginated list of entities.

        Fetches total count, creates a Paginator, then fetches
        items for the current page.

        Args:
            page: Page number (1-based)
            per_page: Items per page

        Returns:
            Ok(PagedResult) with items and paginator
        """
        val total_result = self.repo.count()
        val total = match total_result:
            Ok(n): n
            Err(e): return Err("Database error on count for pagination")

        val paginator = Paginator.new(page, per_page, total)

        # Fetch all and slice (Repository does not have offset/limit yet)
        val all_result = self.repo.find_all()
        val all_items = match all_result:
            Ok(items): items
            Err(e): return Err("Database error on find_all for pagination")

        val offset = paginator.offset()
        var page_items: [T] = []
        var i = offset
        while i < all_items.len() and i < offset + per_page:
            page_items.push(all_items[i])
            i = i + 1

        Ok(PagedResult(items: page_items, paginator: paginator))

# ============================================================================
# Validation Runner
# ============================================================================

fn run_validations(validations: [ModelValidation]) -> [text]:
    """Run all model validations and collect error messages.

    Note: Model validations currently check field metadata only.
    In a full implementation, the entity would be introspected
    for field values. This provides the framework for validation.

    Returns:
        List of error messages (empty if all pass)
    """
    var errors: [text] = []
    # Model-level validations check structural constraints.
    # Field-value validation is done at the controller level
    # using the form_validation module before calling save().
    errors
