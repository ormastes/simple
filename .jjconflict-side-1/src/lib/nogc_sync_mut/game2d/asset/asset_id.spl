# std.game2d.asset.id — typed AssetId<T> (Wave B, AC-6)
#
# Generic typed handle keyed by a string ID and backed by a u32 raw index.
# `AssetId<Image>` and `AssetId<Sound>` are the canonical handle types
# wired by `AssetTable.lookup_image / lookup_sound`. The phantom `<T>` is
# the spec contract from Phase-3 §B even though Simple does not enforce
# the parameter at runtime — the type-checker still uses it for matching.

class AssetId<T>:
    key: text
    raw: i64

    static fn invalid() -> AssetId<T>:
        AssetId(key: "", raw: 0)

    static fn new(key: text, raw: i64) -> AssetId<T>:
        AssetId(key: key, raw: raw)

    fn is_valid() -> bool:
        self.raw != 0 and self.key.len() > 0

    fn eq(other: AssetId<T>) -> bool:
        self.key == other.key and self.raw == other.raw
