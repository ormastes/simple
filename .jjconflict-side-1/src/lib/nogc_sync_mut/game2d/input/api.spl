# Game2D Input API (AC-3) — `g.input.*` accessor wrappers.
#
# These are thin wrappers over the *current* frame's `InputSnapshot`. The
# snapshot is set by `LoopDriver` (Wave B) before each `App.*` callback. User
# code calls these instead of touching SDL/InputManager directly — the
# archtest spec asserts `examples/game2d/**` never references `rt_sdl2_*`.
#
# Wave-A: holds a module-level `_current` snapshot, defaulting to empty until
# `set_current(...)` is called by the loop driver.

use std.common.engine.math2d.{Vec2}
use std.common.engine.units.{KeyCode, MouseButtonId}
use std.nogc_sync_mut.game2d.input.snapshot.{InputSnapshot}

var _current: InputSnapshot = InputSnapshot(
    keys_down: [],
    keys_pressed: [],
    mouse_pos: Vec2(x: 0.0, y: 0.0),
    mouse_buttons: []
)

fn set_current(snap: InputSnapshot):
    """LoopDriver-only: install the per-frame frozen snapshot."""
    _current = snap

fn current() -> InputSnapshot:
    """Return the current frame's frozen InputSnapshot."""
    _current

fn key_down(k: KeyCode) -> bool:
    """True if `k` is held in the current frozen snapshot."""
    _current.key_down(k)

fn key_pressed_this_frame(k: KeyCode) -> bool:
    """True if `k` press-edged on this frame."""
    _current.key_pressed_this_frame(k)

fn mouse_pos() -> Vec2:
    """Current frozen mouse position."""
    _current.mouse_position()

fn mouse_down(b: MouseButtonId) -> bool:
    """True if mouse button `b` is held."""
    _current.mouse_down(b)
