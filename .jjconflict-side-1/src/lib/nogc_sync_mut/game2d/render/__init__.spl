# std.game2d.render — Wave B + sprite-batch rendering pipeline
#
# Re-exports the public render surface for `import std.game2d.render`:
#   - `Canvas`        — frame-builder around RenderCommandBuffer
#   - `Image`         — typed image handle (thin wrapper around engine Sprite)
#   - `Font`          — typed font handle (Wave-B software stub)
#   - `DrawMode`      — Fill / Stroke (re-exported from game2d/math/__init__.spl)
#   - `SpriteBatch`   — groups DrawSprite commands by texture_id; flush to RenderCommandBuffer
#   - `SpriteEntry`   — one pending sprite submission held by SpriteBatch
#   - `TextureAtlas2D`— shelf-pack 2D atlas; maps TextureId → pixel + UV region
#   - `AtlasRegion`   — packed region descriptor (pixel AABB + normalised UVs)
#   - `DrawBatcher`   — frame-scoped coordinator: submit → end_frame → BatchStats
#   - `BatchStats`    — per-frame draw-call counters

use std.nogc_sync_mut.game2d.render.canvas.{Canvas}
use std.nogc_sync_mut.game2d.render.image.{Image}
use std.nogc_sync_mut.game2d.render.font.{Font}
use std.nogc_sync_mut.game2d.math.{DrawMode}
use std.nogc_sync_mut.game2d.render.sprite_batch.{SpriteBatch, SpriteEntry}
use std.nogc_sync_mut.game2d.render.texture_atlas.{TextureAtlas2D, AtlasRegion}
use std.nogc_sync_mut.game2d.render.draw_batcher.{DrawBatcher, BatchStats}

export Canvas
export Image
export Font
export DrawMode
export SpriteBatch
export SpriteEntry
export TextureAtlas2D
export AtlasRegion
export DrawBatcher
export BatchStats
