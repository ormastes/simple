# NvfsPosixOps — POSIX-specific helper trait for the NVFS POSIX shim.
#
# This trait captures helpers beyond the core FsDriver surface that are
# specific to POSIX emulation. The heavy lifting is in the submodule
# implementation (examples/nvfs/src/posix/fs_driver_impl.spl).
#
# Phase 9 B2 — doc/05_design/nvfs_posix_wrapper.md §3.

use std.fs_driver.error.{FsError}
use std.fs_driver.types.{FileHandle, Path}

# FdId — opaque file-descriptor index used internally by the shim.
struct FdId:
    """Opaque index into the shim's fd_table. Do not construct outside posix shim."""
    idx: u32

    static fn null() -> FdId:
        FdId(idx: 0)

    fn is_null() -> bool:
        self.idx == 0

# NvfsPosixOps — supplemental trait with POSIX-shim-specific operations.
#
# Implementations are in examples/nvfs/src/posix/fs_driver_impl.spl.
# The core I/O surface (open/read/write/...) is provided by FsDriver.
trait NvfsPosixOps:
    """POSIX-specific extension helpers for NvfsPosixDriver.

    dup      — duplicate an open file descriptor.
    set_nonblock — toggle non-blocking flag (stub for B2; pass_todo for real impl).
    shim_name    — human-readable identifier for this shim instance.
    """

    fn dup(handle: FileHandle) -> Result<FileHandle, FsError>
    """Duplicate handle; both share the same underlying fd_table entry (refcount++)."""

    fn set_nonblock(handle: FileHandle, enable: bool) -> Result<(), FsError>
    """Set or clear O_NONBLOCK on handle. Stub for B2; real async path is pass_todo."""

    fn shim_name() -> text
    """Return the shim instance name (e.g. 'nvfs-posix-v1')."""
