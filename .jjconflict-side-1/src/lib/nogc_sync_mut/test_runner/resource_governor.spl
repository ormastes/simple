# Resource Governor — Limits parallel test runner to a percentage of system resources
#
# Two separate controls:
#   1. resource_limit_pct (default 75%) — budget: max CPU cores and memory the runner may use
#   2. MIN_FREE_PCT (fixed 25%) — safety floor: block spawning when free mem or CPU < 25%
#
# The safety floor is always enforced regardless of resource_limit_pct.

use std.test_runner.system_monitor.{get_system_resources, get_system_memory_total_mb}
use std.io.sysinfo_ops.{cpu_count}

extern fn rt_thread_sleep(millis: i64)

# Safety floor: always keep at least 25% of memory and CPU free
val MIN_FREE_PCT = 25.0

# ============================================================================
# Resource Governor
# ============================================================================

struct ResourceGovernor:
    max_memory_mb: i64
    max_cpu_cores: i64
    poll_interval_ms: i64
    resource_limit_pct: i64

# ============================================================================
# Constructor
# ============================================================================

fn governor_create(resource_limit_pct: i64) -> ResourceGovernor:
    val total_mb = get_system_memory_total_mb()
    val max_memory_mb = total_mb * resource_limit_pct / 100
    val cores = cpu_count()
    var max_cores = cores * resource_limit_pct / 100
    if max_cores < 1:
        max_cores = 1
    ResourceGovernor(
        max_memory_mb: max_memory_mb,
        max_cpu_cores: max_cores,
        poll_interval_ms: 50,
        resource_limit_pct: resource_limit_pct
    )

# ============================================================================
# Spawn Decision
# ============================================================================

fn governor_can_spawn(gov: ResourceGovernor, active_count: i64) -> bool:
    # Hard limit: don't exceed core count budget
    if active_count >= gov.max_cpu_cores:
        return false

    # Safety floor: block when free system resources drop below 25%
    val res = get_system_resources()
    val free_mem_pct = 100.0 - res.memory_percent
    val free_cpu_pct = 100.0 - res.cpu_percent
    if free_mem_pct < MIN_FREE_PCT:
        return false
    if free_cpu_pct < MIN_FREE_PCT:
        return false

    true

# ============================================================================
# Blocking Wait
# ============================================================================

fn governor_wait_until_ready(gov: ResourceGovernor, active_count: i64):
    var delay_ms = gov.poll_interval_ms
    var iteration = 0
    while not governor_can_spawn(gov, active_count):
        rt_thread_sleep(delay_ms)
        iteration = iteration + 1
        # Exponential backoff: 50 -> 100 -> 200 -> 500ms cap
        if delay_ms < 100:
            delay_ms = 100
        elif delay_ms < 200:
            delay_ms = 200
        elif delay_ms < 500:
            delay_ms = 500
        # Log status every 5th iteration
        if iteration % 5 == 0:
            val res = get_system_resources()
            val free_mem = 100.0 - res.memory_percent
            val free_cpu = 100.0 - res.cpu_percent
            print "  [governor] waiting for resources (free mem: {free_mem}%, free cpu: {free_cpu}%, active: {active_count}, min_free: {MIN_FREE_PCT}%)"

# ============================================================================
# Exports
# ============================================================================

