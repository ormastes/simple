@allow(unnamed_duplicate_typed_args) # reason: pipeline stage APIs use positional i64 params
# RV64 Instruction Fetch (IF) Stage
#
# Fetches a 32-bit instruction from memory at the current PC and produces
# an IF/ID latch output. Handles PC increment (PC+4) and branch target
# override from later stages.
#
# Feature IDs: #HW-RV64-PIPE-IF
# Category: Hardware / RTL Simulation
# Status: Implemented

use std.hardware.rv64.pipeline.types.{
    Rv64Memory, Rv64IfIdLatch, create_if_id_latch
}

# ============================================================================
# Instruction Fetch Stage
# ============================================================================

struct Rv64IfStage:
    """Instruction Fetch stage state.

    Holds the program counter and produces IF/ID latch data each cycle.
    """
    pc: i64

fn create_rv64_if_stage(start_pc: i64) -> Rv64IfStage:
    """Create an IF stage with the given starting PC."""
    Rv64IfStage(pc: start_pc)

impl Rv64IfStage:
    me tick(mem: Rv64Memory, branch_taken: bool, branch_target: i64) -> Rv64IfIdLatch:
        """Execute one clock cycle of the IF stage.

        Args:
            mem: Instruction memory to fetch from.
            branch_taken: If true, override PC with branch_target.
            branch_target: Target address when branch_taken is true.

        Returns:
            IF/ID latch containing the fetched instruction and PC.
        """
        if branch_taken:
            self.pc = branch_target

        val instruction = mem.read_word32(self.pc)
        val current_pc = self.pc

        # Advance PC to next sequential instruction
        self.pc = self.pc + 4

        Rv64IfIdLatch(
            pc: current_pc,
            instruction: instruction,
            valid: true
        )

    fn get_pc() -> i64:
        """Return current PC value."""
        self.pc

    me set_pc(new_pc: i64):
        """Override PC (e.g. for exception or reset)."""
        self.pc = new_pc
