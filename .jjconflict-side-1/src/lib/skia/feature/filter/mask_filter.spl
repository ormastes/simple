# SkMaskFilter — alpha-channel-only filters.
#
# Applied to a coverage mask (alpha bitmap) before color modulation.
# Use cases: glow effects, soft shadows, emboss, inner-glow.
#
# Kinds:
#   - Blur: gaussian blur of the alpha channel
#   - Emboss: directional shadow computed from alpha gradient
#   - Shadow: translated + blurred copy of alpha composited under input
#
# Mirrors Skia's SkMaskFilter: filters that operate on the coverage (alpha)
# mask BEFORE color modulation, in contrast to SkImageFilter which composes
# AFTER color rendering. Input bitmaps are expected to be RGBA8888 with the
# alpha channel carrying the coverage signal; RGB channels of the source are
# ignored (treated as opaque white when meaningful).

use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.feature.filter.blur.{BlurFilter, blur_filter_new, apply_blur}

# ----------------------------------------------------------------------------
# Math helpers (local — keep module self-contained)
# ----------------------------------------------------------------------------

fn _mf_clamp_u8_from_f64(v: f64) -> u8:
    val c = if v < 0.0: 0.0 else: if v > 255.0: 255.0 else: v
    c as u8

fn _mf_clamp_f64(v: f64, lo: f64, hi: f64) -> f64:
    if v < lo: lo else: if v > hi: hi else: v

fn _mf_floor_i64(v: f64) -> i64:
    val iv = v as i64
    if (iv as f64) > v: iv - 1 else: iv

# ----------------------------------------------------------------------------
# MaskFilterKind — discriminates which mask filter operation to run.
# ----------------------------------------------------------------------------

enum MaskFilterKind:
    Identity
    Blur
    Emboss
    Shadow

# ----------------------------------------------------------------------------
# MaskFilter — parameter object mirroring SkMaskFilter.
#
# Fields are present for all kinds (only the relevant ones are used per kind):
#   blur_sigma   — gaussian sigma for Blur kind
#   emboss_dx/dy — light-direction vector for Emboss kind
#   shadow_dx/dy — translation offset for Shadow kind
#   shadow_sigma — gaussian sigma for Shadow blur
# ----------------------------------------------------------------------------

class MaskFilter:
    kind: MaskFilterKind
    blur_sigma: f64
    emboss_dx: f64
    emboss_dy: f64
    shadow_dx: f64
    shadow_dy: f64
    shadow_sigma: f64

# ----------------------------------------------------------------------------
# Constructors
# ----------------------------------------------------------------------------

fn mask_filter_identity() -> MaskFilter:
    MaskFilter(
        kind: MaskFilterKind.Identity,
        blur_sigma: 0.0,
        emboss_dx: 0.0,
        emboss_dy: 0.0,
        shadow_dx: 0.0,
        shadow_dy: 0.0,
        shadow_sigma: 0.0,
    )

fn mask_filter_blur(sigma: f64) -> MaskFilter:
    val s = if sigma < 0.0: 0.0 else: sigma
    MaskFilter(
        kind: MaskFilterKind.Blur,
        blur_sigma: s,
        emboss_dx: 0.0,
        emboss_dy: 0.0,
        shadow_dx: 0.0,
        shadow_dy: 0.0,
        shadow_sigma: 0.0,
    )

fn mask_filter_emboss(dx: f64, dy: f64) -> MaskFilter:
    MaskFilter(
        kind: MaskFilterKind.Emboss,
        blur_sigma: 0.0,
        emboss_dx: dx,
        emboss_dy: dy,
        shadow_dx: 0.0,
        shadow_dy: 0.0,
        shadow_sigma: 0.0,
    )

fn mask_filter_shadow(dx: f64, dy: f64, sigma: f64) -> MaskFilter:
    val s = if sigma < 0.0: 0.0 else: sigma
    MaskFilter(
        kind: MaskFilterKind.Shadow,
        blur_sigma: 0.0,
        emboss_dx: 0.0,
        emboss_dy: 0.0,
        shadow_dx: dx,
        shadow_dy: dy,
        shadow_sigma: s,
    )

# ----------------------------------------------------------------------------
# _identity_copy — return a byte-for-byte copy of src.
# ----------------------------------------------------------------------------

fn _mf_identity_copy(src: Bitmap) -> Bitmap:
    val w = src.width
    val h = src.height
    val out = Bitmap.zeros(w, h)
    val total = w * h * 4
    var idx = 0 as i64
    while idx < total:
        out.pixels[idx] = src.pixels[idx]
        idx = idx + 1
    out

# ----------------------------------------------------------------------------
# _alpha_at — sample alpha (coverage) at (x, y) with clamp-to-edge.
# ----------------------------------------------------------------------------

fn _mf_alpha_at(src: Bitmap, x: i64, y: i64) -> f64:
    val w = src.width
    val h = src.height
    var cx = x
    var cy = y
    if cx < 0: cx = 0
    if cx >= w: cx = w - 1
    if cy < 0: cy = 0
    if cy >= h: cy = h - 1
    val idx = (cy * w + cx) * 4 + 3
    src.pixels[idx] as f64

# ----------------------------------------------------------------------------
# _apply_blur_alpha — blur ONLY the alpha channel of src, returning a bitmap
# whose RGB tracks alpha (so the mask is visualizable) and whose alpha is the
# blurred coverage.
# ----------------------------------------------------------------------------

fn _mf_apply_blur_alpha(src: Bitmap, sigma: f64) -> Bitmap:
    val w = src.width
    val h = src.height
    # Build an alpha-only bitmap (R=G=B=A=src.alpha) so that apply_blur's
    # uniform per-channel box blur produces an identical blur on alpha.
    val mask = Bitmap.zeros(w, h)
    var idx = 0 as i64
    val total = w * h
    while idx < total:
        val a = src.pixels[idx * 4 + 3]
        mask.pixels[idx * 4]     = a
        mask.pixels[idx * 4 + 1] = a
        mask.pixels[idx * 4 + 2] = a
        mask.pixels[idx * 4 + 3] = a
        idx = idx + 1
    val bf = blur_filter_new(sigma, sigma)
    apply_blur(mask, bf)

# ----------------------------------------------------------------------------
# _apply_emboss — directional shading from the alpha gradient.
#
# For each pixel:
#   da/dx ≈ (alpha(x+1,y) - alpha(x-1,y)) / 2   (in [-127.5, 127.5])
#   da/dy ≈ (alpha(x,y+1) - alpha(x,y-1)) / 2
#   height = clamp(dx*da/dx + dy*da/dy, -1, 1)   (after normalising to ±1)
#   out_a  = 0.5 + 0.5 * height                  (in [0, 1])
# Output is written into all four channels for visualisation; the alpha
# channel carries the embossed signal.
# ----------------------------------------------------------------------------

fn _mf_apply_emboss(src: Bitmap, dx: f64, dy: f64) -> Bitmap:
    val w = src.width
    val h = src.height
    val out = Bitmap.zeros(w, h)
    var y = 0 as i64
    while y < h:
        var x = 0 as i64
        while x < w:
            val ax_p = _mf_alpha_at(src, x + 1, y)
            val ax_m = _mf_alpha_at(src, x - 1, y)
            val ay_p = _mf_alpha_at(src, x, y + 1)
            val ay_m = _mf_alpha_at(src, x, y - 1)
            # Normalise gradient from u8 difference (-255..255) to ~(-1..1).
            val gx = (ax_p - ax_m) / 510.0
            val gy = (ay_p - ay_m) / 510.0
            val raw_height = dx * gx + dy * gy
            val height = _mf_clamp_f64(raw_height, 0.0 - 1.0, 1.0)
            val a01 = 0.5 + 0.5 * height
            val a8 = _mf_clamp_u8_from_f64(a01 * 255.0)
            val oidx = (y * w + x) * 4
            out.pixels[oidx]     = a8
            out.pixels[oidx + 1] = a8
            out.pixels[oidx + 2] = a8
            out.pixels[oidx + 3] = a8
            x = x + 1
        y = y + 1
    out

# ----------------------------------------------------------------------------
# _apply_shadow — translated + blurred copy of the alpha mask.
#
# Allocates a new bitmap large enough to contain both the original extent and
# the shifted copy (extra room of |dx|, |dy|). Copies src.alpha at offset
# (dx, dy), then gaussian-blurs the alpha channel by shadow_sigma.
# ----------------------------------------------------------------------------

fn _mf_apply_shadow(src: Bitmap, dx: f64, dy: f64, sigma: f64) -> Bitmap:
    val w = src.width
    val h = src.height
    val abs_dx = if dx < 0.0: 0.0 - dx else: dx
    val abs_dy = if dy < 0.0: 0.0 - dy else: dy
    val pad_x = _mf_floor_i64(abs_dx + 0.5)
    val pad_y = _mf_floor_i64(abs_dy + 0.5)
    val ow = w + pad_x
    val oh = h + pad_y
    val out = Bitmap.zeros(ow, oh)
    # Compute integer offset where src.alpha lands inside out.
    val off_x = _mf_floor_i64(dx + 0.5)
    val off_y = _mf_floor_i64(dy + 0.5)
    var sy = 0 as i64
    while sy < h:
        var sx = 0 as i64
        while sx < w:
            val tx = sx + off_x
            val ty = sy + off_y
            if tx >= 0 and tx < ow and ty >= 0 and ty < oh:
                val sidx = (sy * w + sx) * 4 + 3
                val a = src.pixels[sidx]
                val tidx = (ty * ow + tx) * 4
                out.pixels[tidx]     = a
                out.pixels[tidx + 1] = a
                out.pixels[tidx + 2] = a
                out.pixels[tidx + 3] = a
            sx = sx + 1
        sy = sy + 1
    val bf = blur_filter_new(sigma, sigma)
    apply_blur(out, bf)

# ----------------------------------------------------------------------------
# apply_mask_filter — dispatcher.
#
# Identity: passes through (returns a copy).
# Blur:     gaussian blur of the alpha channel via apply_blur.
# Emboss:   directional shading from finite-difference alpha gradient.
# Shadow:   translated + blurred alpha copy in a padded bitmap.
# ----------------------------------------------------------------------------

fn apply_mask_filter(src_alpha: Bitmap, filter: MaskFilter) -> Bitmap:
    if filter.kind == MaskFilterKind.Identity:
        return _mf_identity_copy(src_alpha)
    if filter.kind == MaskFilterKind.Blur:
        return _mf_apply_blur_alpha(src_alpha, filter.blur_sigma)
    if filter.kind == MaskFilterKind.Emboss:
        return _mf_apply_emboss(src_alpha, filter.emboss_dx, filter.emboss_dy)
    if filter.kind == MaskFilterKind.Shadow:
        return _mf_apply_shadow(src_alpha, filter.shadow_dx, filter.shadow_dy, filter.shadow_sigma)
    _mf_identity_copy(src_alpha)
