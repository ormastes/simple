# Skia feature codec — simple bitmap codecs for tests/snapshots.
#
# Re-exports the raw-RGBA codec. This is NOT a real image format; it exists
# purely to persist Bitmap instances for golden tests and snapshot debugging.

use std.skia.feature.codec.raw_rgba.{
    encode_raw_rgba,
    decode_raw_rgba,
    RAW_RGBA_MAGIC
}

pub use encode_raw_rgba
pub use decode_raw_rgba
pub use RAW_RGBA_MAGIC
