# Image resampling — bitmap scale/resize with selectable filter.
#
# Mirrors SkImage::makeScaled and SkSamplingOptions filter modes:
#   - Nearest: point sample (blocky but fast)
#   - Bilinear: 2x2 kernel (smooth for moderate scale)
#   - Bicubic: 4x4 Mitchell-Netravali kernel with B=C=1/3 (smooth + sharpness)

use std.skia.backend.cpu.raster_prims.{Bitmap}

# ============================================================================
# SamplingFilter — enumeration of supported resampling filters
# ============================================================================

enum SamplingFilter:
    Nearest
    Bilinear
    Bicubic

# ============================================================================
# Mitchell-Netravali kernel constants (B = C = 1/3)
# ============================================================================

val MITCHELL_B: f64 = 1.0 / 3.0
val MITCHELL_C: f64 = 1.0 / 3.0

# ============================================================================
# Internal math helpers
# ============================================================================

fn _abs_f64(x: f64) -> f64:
    if x < 0.0: 0.0 - x else: x

fn _clamp_f64(v: f64, lo: f64, hi: f64) -> f64:
    if v < lo: lo else: if v > hi: hi else: v

fn _clamp_i64(v: i64, lo: i64, hi: i64) -> i64:
    if v < lo: lo else: if v > hi: hi else: v

fn _floor_i64(v: f64) -> i64:
    val iv = v as i64
    if (iv as f64) > v: iv - 1 else: iv

fn _clamp_u8(v: f64) -> u8:
    val c = _clamp_f64(v, 0.0, 255.0)
    c as u8

# ============================================================================
# Pixel fetch with clamp-to-edge from a Bitmap (RGBA u8 row-major)
# ============================================================================

fn _fetch_clamped(src: Bitmap, x: i64, y: i64) -> (f64, f64, f64, f64):
    val cx = _clamp_i64(x, 0, src.width - 1)
    val cy = _clamp_i64(y, 0, src.height - 1)
    val idx = (cy * src.width + cx) * 4
    val r = (src.pixels[idx] as f64) / 255.0
    val g = (src.pixels[idx + 1] as f64) / 255.0
    val b = (src.pixels[idx + 2] as f64) / 255.0
    val a = (src.pixels[idx + 3] as f64) / 255.0
    (r, g, b, a)

# ============================================================================
# _sample_nearest — point sample at (u, v), clamp-to-edge
# ============================================================================

fn _sample_nearest(src: Bitmap, u: f64, v: f64) -> (f64, f64, f64, f64):
    val px = _floor_i64(u)
    val py = _floor_i64(v)
    _fetch_clamped(src, px, py)

# ============================================================================
# _sample_bilinear — 2x2 kernel blend, clamp-to-edge
# ============================================================================

fn _sample_bilinear(src: Bitmap, u: f64, v: f64) -> (f64, f64, f64, f64):
    # Align sample center: pixel centers live at (i + 0.5)
    val fu = u - 0.5
    val fv = v - 0.5
    val x0 = _floor_i64(fu)
    val y0 = _floor_i64(fv)
    val x1 = x0 + 1
    val y1 = y0 + 1
    val tx = fu - (x0 as f64)
    val ty = fv - (y0 as f64)
    val c00 = _fetch_clamped(src, x0, y0)
    val c10 = _fetch_clamped(src, x1, y0)
    val c01 = _fetch_clamped(src, x0, y1)
    val c11 = _fetch_clamped(src, x1, y1)
    val r0 = c00.0 + (c10.0 - c00.0) * tx
    val g0 = c00.1 + (c10.1 - c00.1) * tx
    val b0 = c00.2 + (c10.2 - c00.2) * tx
    val a0 = c00.3 + (c10.3 - c00.3) * tx
    val r1 = c01.0 + (c11.0 - c01.0) * tx
    val g1 = c01.1 + (c11.1 - c01.1) * tx
    val b1 = c01.2 + (c11.2 - c01.2) * tx
    val a1 = c01.3 + (c11.3 - c01.3) * tx
    val r = r0 + (r1 - r0) * ty
    val g = g0 + (g1 - g0) * ty
    val b = b0 + (b1 - b0) * ty
    val a = a0 + (a1 - a0) * ty
    (r, g, b, a)

# ============================================================================
# Mitchell-Netravali weight function
#
#   w(t) = ((12 - 9B - 6C) * |t|^3
#         + (-18 + 12B + 6C) * |t|^2
#         + (6 - 2B)) / 6                          for |t| < 1
#
#   w(t) = ((-B - 6C) * |t|^3
#         + (6B + 30C) * |t|^2
#         + (-12B - 48C) * |t|
#         + (8B + 24C)) / 6                        for 1 <= |t| < 2
#
#   w(t) = 0                                       for |t| >= 2
# ============================================================================

fn _mitchell_weight(t: f64) -> f64:
    val at = _abs_f64(t)
    val b = MITCHELL_B
    val c = MITCHELL_C
    if at < 1.0:
        val t2 = at * at
        val t3 = t2 * at
        val k3 = 12.0 - 9.0 * b - 6.0 * c
        val k2 = 0.0 - 18.0 + 12.0 * b + 6.0 * c
        val k0 = 6.0 - 2.0 * b
        (k3 * t3 + k2 * t2 + k0) / 6.0
    else:
        if at < 2.0:
            val t2 = at * at
            val t3 = t2 * at
            val k3 = 0.0 - b - 6.0 * c
            val k2 = 6.0 * b + 30.0 * c
            val k1 = 0.0 - 12.0 * b - 48.0 * c
            val k0 = 8.0 * b + 24.0 * c
            (k3 * t3 + k2 * t2 + k1 * at + k0) / 6.0
        else:
            0.0

# ============================================================================
# _sample_bicubic — 4x4 Mitchell-Netravali kernel (B = C = 1/3), clamp-to-edge
# ============================================================================

fn _sample_bicubic(src: Bitmap, u: f64, v: f64) -> (f64, f64, f64, f64):
    val fu = u - 0.5
    val fv = v - 0.5
    val ix = _floor_i64(fu)
    val iy = _floor_i64(fv)
    val fx = fu - (ix as f64)
    val fy = fv - (iy as f64)
    var sum_r = 0.0
    var sum_g = 0.0
    var sum_b = 0.0
    var sum_a = 0.0
    var sum_w = 0.0
    var dy = 0 - 1
    while dy <= 2:
        val wy = _mitchell_weight((dy as f64) - fy)
        var dx = 0 - 1
        while dx <= 2:
            val wx = _mitchell_weight((dx as f64) - fx)
            val w = wx * wy
            val p = _fetch_clamped(src, ix + dx, iy + dy)
            sum_r = sum_r + p.0 * w
            sum_g = sum_g + p.1 * w
            sum_b = sum_b + p.2 * w
            sum_a = sum_a + p.3 * w
            sum_w = sum_w + w
            dx = dx + 1
        dy = dy + 1
    # Normalize (weight sum should be ~1 but float error can drift); then clamp
    # to [0,1] because bicubic kernels can overshoot on sharp edges.
    val inv = if sum_w == 0.0: 1.0 else: 1.0 / sum_w
    val r = _clamp_f64(sum_r * inv, 0.0, 1.0)
    val g = _clamp_f64(sum_g * inv, 0.0, 1.0)
    val b = _clamp_f64(sum_b * inv, 0.0, 1.0)
    val a = _clamp_f64(sum_a * inv, 0.0, 1.0)
    (r, g, b, a)

# ============================================================================
# scale_bitmap — resize a Bitmap to (dst_w, dst_h) using the given filter
# ============================================================================

fn scale_bitmap(src: Bitmap, dst_w: i64, dst_h: i64, filter: SamplingFilter) -> Bitmap:
    val dst = Bitmap.zeros(dst_w, dst_h)
    if dst_w <= 0 or dst_h <= 0 or src.width <= 0 or src.height <= 0:
        dst
    else:
        val sw = src.width.to_f64()
        val sh = src.height.to_f64()
        val dw = dst_w.to_f64()
        val dh = dst_h.to_f64()
        var y = 0 as i64
        while y < dst_h:
            var x = 0 as i64
            while x < dst_w:
                val u = ((x as f64) + 0.5) * sw / dw
                val v = ((y as f64) + 0.5) * sh / dh
                val rgba = match filter:
                    SamplingFilter.Nearest:
                        _sample_nearest(src, u, v)
                    SamplingFilter.Bilinear:
                        _sample_bilinear(src, u, v)
                    SamplingFilter.Bicubic:
                        _sample_bicubic(src, u, v)
                val idx = (y * dst_w + x) * 4
                dst.pixels[idx]     = _clamp_u8(rgba.0 * 255.0)
                dst.pixels[idx + 1] = _clamp_u8(rgba.1 * 255.0)
                dst.pixels[idx + 2] = _clamp_u8(rgba.2 * 255.0)
                dst.pixels[idx + 3] = _clamp_u8(rgba.3 * 255.0)
                x = x + 1
            y = y + 1
        dst
