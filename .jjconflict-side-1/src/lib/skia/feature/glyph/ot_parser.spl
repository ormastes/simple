# OpenType table parser — shared types, BE readers, offset table
# Satellites: ot_parser_cmap, ot_parser_metrics, ot_parser_glyf,
#             ot_parser_cff, ot_parser_layout, ot_parser_fvar, ot_parser_gvar

use std.skia.entity.path.{SkPath, SkPathVerb, sk_path_new}
use std.skia.entity.geometry.{SkRect}
use std.skia.feature.glyph.outline.{GlyphOutline, GlyphMetrics}

# ===== utility big-endian readers =====

fn read_u16_be(buf: [u8], offset: i64) -> u32:
    if offset + 1 >= buf.len():
        return 0
    val hi = buf[offset] as u32
    val lo = buf[offset + 1] as u32
    (hi << 8) | lo

fn read_i16_be(buf: [u8], offset: i64) -> i32:
    val raw = read_u16_be(buf, offset)
    if raw >= 32768:
        (raw as i32) - 65536
    else:
        raw as i32

fn read_u32_be(buf: [u8], offset: i64) -> u32:
    if offset + 3 >= buf.len():
        return 0
    val b0 = buf[offset] as u32
    val b1 = buf[offset + 1] as u32
    val b2 = buf[offset + 2] as u32
    val b3 = buf[offset + 3] as u32
    (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

fn read_fixed_1616(buf: [u8], offset: i64) -> f64:
    val raw = read_u32_be(buf, offset)
    val integer_part = (raw >> 16) as f64
    val frac_part = (raw & 0xFFFF) as f64
    integer_part + (frac_part / 65536.0)

fn read_f2dot14(buf: [u8], offset: i64) -> f64:
    read_i16_be(buf, offset) as f64 / 16384.0

# ===== table record / offset table =====

class OtTable:
    tag: u32
    offset: u32
    length: u32

class OtFont:
    blob: [u8]
    tables: [OtTable]

fn parse_offset_table(blob: [u8]) -> Option<OtFont>:
    if blob.len() < 12:
        return None
    val sfnt_version = read_u32_be(blob, 0)
    # Valid sfnt versions: 0x00010000 (TrueType), 0x4F54544F (OTTO/CFF), 0x74727565 (true), 0x74797031 (typ1)
    val is_truetype = sfnt_version == 65536
    val is_otto = sfnt_version == 1330926671
    val is_true = sfnt_version == 1953658213
    val is_typ1 = sfnt_version == 1954115633
    if (not is_truetype) and (not is_otto) and (not is_true) and (not is_typ1):
        return None
    val num_tables = read_u16_be(blob, 4) as i64
    if blob.len() < (12 + num_tables * 16) as i64:
        return None
    var tables: [OtTable] = []
    var i: i64 = 0
    while i < num_tables:
        val rec_off = 12 + i * 16
        val tag = read_u32_be(blob, rec_off)
        val tbl_offset = read_u32_be(blob, rec_off + 8)
        val tbl_length = read_u32_be(blob, rec_off + 12)
        val tbl = OtTable(tag: tag, offset: tbl_offset, length: tbl_length)
        tables.append(tbl)
        i = i + 1
    Some(OtFont(blob: blob, tables: tables))

fn find_table(font: OtFont, tag: u32) -> Option<OtTable>:
    var i: i64 = 0
    while i < font.tables.len():
        val tbl = font.tables[i]
        if tbl.tag == tag:
            return Some(tbl)
        i = i + 1
    None
