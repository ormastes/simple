# COLRv1 color emoji layer-list decoder.
# Decodes COLR table header (v1), layer-list structure, paint subtable
# records, and provides the shaper entry point (route_color_glyph).

use std.skia.feature.glyph.ot_parser.{read_u16_be, read_u32_be}

# ===== COLR v1 header =====

class ColrV1Header:
    version: u16
    num_base_glyph_records: u16
    layer_list_offset: u32
    clip_list_offset: u32
    var_index_map_offset: u32

# parse_colr_header reads the COLR table header from a raw blob.
# Returns None if blob is too short or version != 1.
fn parse_colr_header(blob: [u8]) -> Option<ColrV1Header>:
    # Minimum COLR v1 header is 20 bytes:
    # 2  version
    # 2  numBaseGlyphRecords
    # 4  baseGlyphRecordsOffset
    # 4  layersOffset  (layer_list_offset)
    # 4  numLayers (or clip_list_offset in v1 extended form)
    # 4  varIndexMapOffset
    # We require at least 20 bytes for a v1 header.
    if blob.len() < 20:
        return None
    val version_raw = read_u16_be(blob, 0) as u16
    if version_raw != 1:
        return None
    val num_base = read_u16_be(blob, 2) as u16
    # offset 4: baseGlyphRecordsOffset (4 bytes) — skip, not stored
    val layer_off = read_u32_be(blob, 8)
    val clip_off = read_u32_be(blob, 12)
    val var_off = read_u32_be(blob, 16)
    Some(ColrV1Header(
        version: version_raw,
        num_base_glyph_records: num_base,
        layer_list_offset: layer_off,
        clip_list_offset: clip_off,
        var_index_map_offset: var_off
    ))

# ===== Layer list =====

class ColrLayer:
    glyph_id: u32
    paint_offset: u32

# parse_layer_list reads the layer list from the COLR blob using the header.
# Returns [] if layer_list_offset is 0 or the region is too short.
fn parse_layer_list(blob: [u8], header: ColrV1Header) -> [ColrLayer]:
    val off = header.layer_list_offset as i64
    if off == 0:
        return []
    # layer list starts with numLayers u32, then each record: glyphId u16, paintOffset u32
    # record size = 6 bytes
    if off + 4 > blob.len() as i64:
        return []
    val num_layers = read_u32_be(blob, off) as i64
    val data_start = off + 4
    if data_start + num_layers * 6 > blob.len() as i64:
        return []
    var layers: [ColrLayer] = []
    var i: i64 = 0
    while i < num_layers:
        val rec = data_start + i * 6
        val gid = read_u16_be(blob, rec) as u32
        val paint_off = read_u32_be(blob, rec + 2)
        val layer = ColrLayer(glyph_id: gid, paint_offset: paint_off)
        layers.append(layer)
        i = i + 1
    layers

# ===== Paint kind enum =====

enum PaintKind:
    Solid
    LinearGradient
    RadialGradient
    SweepGradient
    Glyph
    ColrLayers
    Transform
    Translate
    Rotate
    Scale
    Skew
    Composite

# ===== Paint node =====

class PaintNode:
    kind: PaintKind
    palette_index: u16
    # alpha in 2.14 fixed-point (0x4000 == 1.0)
    alpha_fixed: i32

# decode_paint_subtable reads one paint record from blob at the given offset.
# Dispatches on the format byte; unknown formats return a safe Solid fallback.
# Returns None if offset is out of bounds.
fn decode_paint_subtable(blob: [u8], offset: u32) -> Option<PaintNode>:
    val off = offset as i64
    if off >= blob.len() as i64:
        return None
    val fmt = blob[off] as u32
    # COLRv1 paint format values (OpenType spec §COLRv1)
    # 2/3  = PaintSolid / PaintVarSolid
    # 4/5  = PaintLinearGradient / PaintVarLinearGradient
    # 6/7  = PaintRadialGradient / PaintVarRadialGradient
    # 8/9  = PaintSweepGradient / PaintVarSweepGradient
    # 10   = PaintGlyph
    # 11   = PaintColrLayers
    # 12/13= PaintTransform / PaintVarTransform
    # 14/15= PaintTranslate / PaintVarTranslate
    # 16/17= PaintRotate / PaintVarRotate
    # 18/19= PaintScale / PaintVarScale
    # 20/21= PaintSkew / PaintVarSkew
    # 32   = PaintComposite
    if fmt == 2 or fmt == 3:
        # PaintSolid / PaintVarSolid record layout (OpenType spec §COLRv1):
        #   [format(1)] [paletteIndex(2)] [alpha(2, F2Dot14)]
        # F2Dot14: 0x4000 = 1.0. Minimum record length = 5 bytes.
        if off + 5 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.Solid, palette_index: 0, alpha_fixed: 16384))
        val pal_idx = read_u16_be(blob, off + 1) as u16
        # alpha is a signed F2Dot14 stored as two bytes (big-endian i16)
        val alpha_hi = blob[off + 3] as i32
        val alpha_lo = blob[off + 4] as i32
        val alpha_raw = (alpha_hi << 8) or alpha_lo
        # Clamp to [0, 0x4000]
        val alpha_clamped = if alpha_raw < 0: 0 else: if alpha_raw > 16384: 16384 else: alpha_raw
        Some(PaintNode(kind: PaintKind.Solid, palette_index: pal_idx, alpha_fixed: alpha_clamped))
    else if fmt == 4 or fmt == 5:
        # PaintLinearGradient / PaintVarLinearGradient record layout:
        #   [format(1)] [colorLineOffset(3, u24 BE)] [x0(2)] [y0(2)] [x1(2)] [y1(2)] [x2(2)] [y2(2)]
        # We store the first palette index from the color line as palette_index.
        # Minimum to reach colorLineOffset field: 4 bytes.
        if off + 4 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.LinearGradient, palette_index: 0, alpha_fixed: 16384))
        val cl_b0 = blob[off + 1] as u32
        val cl_b1 = blob[off + 2] as u32
        val cl_b2 = blob[off + 3] as u32
        val color_line_off = (off + ((cl_b0 << 16) or (cl_b1 << 8) or cl_b2) as i64)
        # Read first color stop palette index from color line (offset 2 within color line = first stop paletteIndex)
        val first_pal = if color_line_off + 4 <= blob.len() as i64:
            read_u16_be(blob, color_line_off + 2) as u16
        else:
            0 as u16
        Some(PaintNode(kind: PaintKind.LinearGradient, palette_index: first_pal, alpha_fixed: 16384))
    else if fmt == 6 or fmt == 7:
        # PaintRadialGradient / PaintVarRadialGradient record layout:
        #   [format(1)] [colorLineOffset(3, u24 BE)] [x0(2)] [y0(2)] [r0(2)] [x1(2)] [y1(2)] [r1(2)]
        if off + 4 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.RadialGradient, palette_index: 0, alpha_fixed: 16384))
        val cl_b0 = blob[off + 1] as u32
        val cl_b1 = blob[off + 2] as u32
        val cl_b2 = blob[off + 3] as u32
        val color_line_off = (off + ((cl_b0 << 16) or (cl_b1 << 8) or cl_b2) as i64)
        val first_pal = if color_line_off + 4 <= blob.len() as i64:
            read_u16_be(blob, color_line_off + 2) as u16
        else:
            0 as u16
        Some(PaintNode(kind: PaintKind.RadialGradient, palette_index: first_pal, alpha_fixed: 16384))
    else if fmt == 8 or fmt == 9:
        # PaintSweepGradient / PaintVarSweepGradient record layout:
        #   [format(1)] [colorLineOffset(3, u24 BE)] [centerX(2)] [centerY(2)] [startAngle(2, F2Dot14)] [endAngle(2, F2Dot14)]
        if off + 4 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.SweepGradient, palette_index: 0, alpha_fixed: 16384))
        val cl_b0 = blob[off + 1] as u32
        val cl_b1 = blob[off + 2] as u32
        val cl_b2 = blob[off + 3] as u32
        val color_line_off = (off + ((cl_b0 << 16) or (cl_b1 << 8) or cl_b2) as i64)
        val first_pal = if color_line_off + 4 <= blob.len() as i64:
            read_u16_be(blob, color_line_off + 2) as u16
        else:
            0 as u16
        Some(PaintNode(kind: PaintKind.SweepGradient, palette_index: first_pal, alpha_fixed: 16384))
    else if fmt == 10:
        # PaintGlyph record layout:
        #   [format(1)] [paintOffset(3, u24 BE)] [glyphID(2)]
        # We store the glyph_id in palette_index (repurposed field) so the
        # compose_paint_graph branch can read it without a schema change.
        if off + 6 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.Glyph, palette_index: 0, alpha_fixed: 16384))
        val glyph_id_u16 = read_u16_be(blob, off + 4) as u16
        Some(PaintNode(kind: PaintKind.Glyph, palette_index: glyph_id_u16, alpha_fixed: 16384))
    else if fmt == 11:
        # PaintColrLayers record layout:
        #   [format(1)] [numLayers(1)] [firstLayerIndex(4, u32 BE)]
        # Minimum length: 6 bytes. No extra fields to extract into PaintNode;
        # compose_paint_graph reads num_layers and first_layer_index directly.
        if off + 6 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.ColrLayers, palette_index: 0, alpha_fixed: 16384))
        Some(PaintNode(kind: PaintKind.ColrLayers, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 12 or fmt == 13:
        # PaintTransform / PaintVarTransform record layout:
        #   [format(1)] [paintOffset(3, u24 BE)] [transformOffset(3, u24 BE)]
        # The 2×3 affine matrix lives at transformOffset relative to record start.
        # No matrix fields stored in PaintNode; compose_paint_graph reads them.
        if off + 7 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.Transform, palette_index: 0, alpha_fixed: 16384))
        Some(PaintNode(kind: PaintKind.Transform, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 14 or fmt == 15:
        # PaintTranslate / PaintVarTranslate record layout:
        #   [format(1)] [paintOffset(3, u24 BE)] [dx(2, i16 BE)] [dy(2, i16 BE)]
        if off + 8 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.Translate, palette_index: 0, alpha_fixed: 16384))
        Some(PaintNode(kind: PaintKind.Translate, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 16 or fmt == 17:
        # PaintRotate / PaintVarRotate record layout:
        #   [format(1)] [paintOffset(3, u24 BE)] [angle(2, F2Dot14 BE)]
        if off + 6 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.Rotate, palette_index: 0, alpha_fixed: 16384))
        Some(PaintNode(kind: PaintKind.Rotate, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 18 or fmt == 19:
        # PaintScale / PaintVarScale record layout:
        #   [format(1)] [paintOffset(3, u24 BE)] [scaleX(2, F2Dot14)] [scaleY(2, F2Dot14)]
        if off + 8 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.Scale, palette_index: 0, alpha_fixed: 16384))
        Some(PaintNode(kind: PaintKind.Scale, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 20 or fmt == 21:
        # PaintSkew / PaintVarSkew record layout:
        #   [format(1)] [paintOffset(3, u24 BE)] [xSkewAngle(2, F2Dot14)] [ySkewAngle(2, F2Dot14)]
        if off + 8 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.Skew, palette_index: 0, alpha_fixed: 16384))
        Some(PaintNode(kind: PaintKind.Skew, palette_index: 0, alpha_fixed: 16384))
    else if fmt == 32:
        # PaintComposite record layout:
        #   [format(1)] [sourcePaintOffset(3, u24 BE)] [compositeMode(1)] [backdropPaintOffset(3, u24 BE)]
        # compose_paint_graph reads source/backdrop offsets and mode directly from blob.
        if off + 8 > blob.len() as i64:
            return Some(PaintNode(kind: PaintKind.Composite, palette_index: 0, alpha_fixed: 16384))
        Some(PaintNode(kind: PaintKind.Composite, palette_index: 0, alpha_fixed: 16384))
    else:
        # Unknown format — safe Solid fallback, alpha=1.0 (0x4000)
        Some(PaintNode(kind: PaintKind.Solid, palette_index: 0, alpha_fixed: 16384))

# ===== BaseGlyph v1 record search =====

# find_base_glyph_v1 scans the BaseGlyph v1 records for glyph_id.
# BaseGlyph v1 record: glyphId (u16) + paintOffset (u32) = 6 bytes each.
# The records start at baseGlyphRecordsOffset (bytes 4-7 in the COLR table).
# Returns Some(paint_offset) or None if not found.
fn find_base_glyph_v1(blob: [u8], header: ColrV1Header, glyph_id: u32) -> Option<u32>:
    # BaseGlyphRecordsOffset is at blob offset 4 (not stored in header; re-read it)
    if blob.len() < 8:
        return None
    val base_off = read_u32_be(blob, 4) as i64
    if base_off == 0:
        return None
    val count = header.num_base_glyph_records as i64
    if base_off + count * 6 > blob.len() as i64:
        return None
    # Linear scan (BaseGlyph records are sorted by glyph_id; binary search possible but linear is simpler)
    var i: i64 = 0
    while i < count:
        val rec = base_off + i * 6
        val gid = read_u16_be(blob, rec) as u32
        if gid == glyph_id:
            val paint_off = read_u32_be(blob, rec + 2)
            return Some(paint_off)
        i = i + 1
    None

# ===== Shaper entry point =====

# route_color_glyph is called by the shaper to produce a layer breakdown
# for a color glyph from the raw COLR table blob.
# Returns None if the blob is empty, has no v1 header, or the glyph isn't found.
fn route_color_glyph(shaper_glyph_id: u32, colr_blob: [u8]) -> Option<[ColrLayer]>:
    if colr_blob.len() == 0:
        return None
    val maybe_header = parse_colr_header(colr_blob)
    if maybe_header == None:
        return None
    val header = maybe_header.unwrap()
    val maybe_paint_off = find_base_glyph_v1(colr_blob, header, shaper_glyph_id)
    if maybe_paint_off == None:
        return None
    val paint_off = maybe_paint_off.unwrap()
    # Walk the paint graph rooted at paint_off and collect all reachable
    # paint nodes as a flat ColrLayer list (glyph_id=shaper_glyph_id, paint_offset=each node's offset).
    # We perform a simple iterative BFS over paint offsets to avoid deep recursion.
    var visited_offsets: [u32] = []
    var work_queue: [u32] = []
    work_queue.append(paint_off)
    var result_layers: [ColrLayer] = []
    var steps: i64 = 0
    val max_steps: i64 = 512
    while work_queue.len() > 0 and steps < max_steps:
        val cur_off = work_queue[0]
        # Remove first element
        var new_queue: [u32] = []
        var qi: i64 = 1
        while qi < work_queue.len() as i64:
            new_queue.append(work_queue[qi])
            qi = qi + 1
        work_queue = new_queue
        # Skip if already visited
        var already = false
        var vi: i64 = 0
        while vi < visited_offsets.len() as i64:
            if visited_offsets[vi] == cur_off:
                already = true
            vi = vi + 1
        if already:
            steps = steps + 1
            continue
        visited_offsets.append(cur_off)
        val layer = ColrLayer(glyph_id: shaper_glyph_id, paint_offset: cur_off)
        result_layers.append(layer)
        # Decode node to discover child paint offsets
        val maybe_node = decode_paint_subtable(colr_blob, cur_off)
        if maybe_node != None:
            val node = maybe_node.unwrap()
            val node_off = cur_off as i64
            # PaintColrLayers (fmt 11): child offsets come from layer list entries
            if node.kind == PaintKind.ColrLayers:
                if node_off + 6 <= colr_blob.len() as i64:
                    val num_layers = colr_blob[node_off + 1] as i64
                    val first_idx = read_u32_be(colr_blob, node_off + 2) as i64
                    var li: i64 = 0
                    while li < num_layers:
                        val entry_off = (first_idx + li) * 4
                        if entry_off + 4 <= colr_blob.len() as i64:
                            val child_off = read_u32_be(colr_blob, entry_off)
                            work_queue.append(child_off)
                        li = li + 1
            # PaintComposite (fmt 32): source + backdrop paint offsets
            else if node.kind == PaintKind.Composite:
                if node_off + 8 <= colr_blob.len() as i64:
                    val src_b0 = colr_blob[node_off + 1] as u32
                    val src_b1 = colr_blob[node_off + 2] as u32
                    val src_b2 = colr_blob[node_off + 3] as u32
                    val src_off = cur_off + ((src_b0 << 16) or (src_b1 << 8) or src_b2)
                    val bd_b0 = colr_blob[node_off + 5] as u32
                    val bd_b1 = colr_blob[node_off + 6] as u32
                    val bd_b2 = colr_blob[node_off + 7] as u32
                    val bd_off = cur_off + ((bd_b0 << 16) or (bd_b1 << 8) or bd_b2)
                    work_queue.append(src_off)
                    work_queue.append(bd_off)
            # PaintGlyph (fmt 10): single child paint offset (u24 BE at off+1)
            else if node.kind == PaintKind.Glyph:
                if node_off + 4 <= colr_blob.len() as i64:
                    val pb0 = colr_blob[node_off + 1] as u32
                    val pb1 = colr_blob[node_off + 2] as u32
                    val pb2 = colr_blob[node_off + 3] as u32
                    val child_off = cur_off + ((pb0 << 16) or (pb1 << 8) or pb2)
                    work_queue.append(child_off)
            # Transform-family (fmt 12-21): single child paint offset at off+1 (u24 BE)
            else if (node.kind == PaintKind.Transform or node.kind == PaintKind.Translate
                     or node.kind == PaintKind.Rotate or node.kind == PaintKind.Scale
                     or node.kind == PaintKind.Skew):
                if node_off + 4 <= colr_blob.len() as i64:
                    val tb0 = colr_blob[node_off + 1] as u32
                    val tb1 = colr_blob[node_off + 2] as u32
                    val tb2 = colr_blob[node_off + 3] as u32
                    val child_off = cur_off + ((tb0 << 16) or (tb1 << 8) or tb2)
                    work_queue.append(child_off)
            # Solid and gradient paints are leaf nodes — no child offsets
        steps = steps + 1
    if result_layers.len() == 0:
        None
    else:
        Some(result_layers)
