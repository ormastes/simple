# Skia Paint
#
# SkPaint — drawing attributes: color, style, stroke width, etc.

use std.skia.entity.enums.{SkPaintStyle, SkPaintCap, SkPaintJoin, SkBlendMode}
use std.skia.entity.color.{SkColor, SkColor4f, sk_color_black}

# ============================================================================
# SkPaint
# ============================================================================

class SkPaint:
    color: SkColor
    style: SkPaintStyle
    stroke_width: f64
    stroke_miter: f64
    stroke_cap: SkPaintCap
    stroke_join: SkPaintJoin
    blend_mode: SkBlendMode
    anti_alias: bool

fn sk_paint_new() -> SkPaint:
    SkPaint(
        color: sk_color_black(),
        style: SkPaintStyle.Fill,
        stroke_width: 0.0,
        stroke_miter: 4.0,
        stroke_cap: SkPaintCap.Butt,
        stroke_join: SkPaintJoin.Miter,
        blend_mode: SkBlendMode.SrcOver,
        anti_alias: false
    )

fn sk_paint_fill(color: SkColor) -> SkPaint:
    SkPaint(
        color: color,
        style: SkPaintStyle.Fill,
        stroke_width: 0.0,
        stroke_miter: 4.0,
        stroke_cap: SkPaintCap.Butt,
        stroke_join: SkPaintJoin.Miter,
        blend_mode: SkBlendMode.SrcOver,
        anti_alias: true
    )

fn sk_paint_stroke(color: SkColor, width: f64) -> SkPaint:
    SkPaint(
        color: color,
        style: SkPaintStyle.Stroke,
        stroke_width: width,
        stroke_miter: 4.0,
        stroke_cap: SkPaintCap.Butt,
        stroke_join: SkPaintJoin.Miter,
        blend_mode: SkBlendMode.SrcOver,
        anti_alias: true
    )

impl SkPaint:
    fn with_color(c: SkColor) -> SkPaint:
        SkPaint(
            color: c,
            style: self.style,
            stroke_width: self.stroke_width,
            stroke_miter: self.stroke_miter,
            stroke_cap: self.stroke_cap,
            stroke_join: self.stroke_join,
            blend_mode: self.blend_mode,
            anti_alias: self.anti_alias
        )

    fn with_style(s: SkPaintStyle) -> SkPaint:
        SkPaint(
            color: self.color,
            style: s,
            stroke_width: self.stroke_width,
            stroke_miter: self.stroke_miter,
            stroke_cap: self.stroke_cap,
            stroke_join: self.stroke_join,
            blend_mode: self.blend_mode,
            anti_alias: self.anti_alias
        )

    fn with_stroke_width(w: f64) -> SkPaint:
        SkPaint(
            color: self.color,
            style: self.style,
            stroke_width: w,
            stroke_miter: self.stroke_miter,
            stroke_cap: self.stroke_cap,
            stroke_join: self.stroke_join,
            blend_mode: self.blend_mode,
            anti_alias: self.anti_alias
        )

    fn with_anti_alias(aa: bool) -> SkPaint:
        SkPaint(
            color: self.color,
            style: self.style,
            stroke_width: self.stroke_width,
            stroke_miter: self.stroke_miter,
            stroke_cap: self.stroke_cap,
            stroke_join: self.stroke_join,
            blend_mode: self.blend_mode,
            anti_alias: aa
        )

    fn with_blend_mode(bm: SkBlendMode) -> SkPaint:
        SkPaint(
            color: self.color,
            style: self.style,
            stroke_width: self.stroke_width,
            stroke_miter: self.stroke_miter,
            stroke_cap: self.stroke_cap,
            stroke_join: self.stroke_join,
            blend_mode: bm,
            anti_alias: self.anti_alias
        )

    fn is_fill() -> bool:
        self.style == SkPaintStyle.Fill

    fn is_stroke() -> bool:
        self.style == SkPaintStyle.Stroke

    fn to_string() -> text:
        "SkPaint(style:{self.style} aa:{self.anti_alias} sw:{self.stroke_width})"
