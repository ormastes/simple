# Skia ColorFilter
#
# SkColorFilter — per-pixel color transform applied during painting.

use std.skia.entity.enums.{SkBlendMode}
use std.skia.entity.color.{SkColor}

# ============================================================================
# SkColorFilterKind
# ============================================================================

enum SkColorFilterKind:
    Blend
    Matrix
    LinearToSrgbGamma
    SrgbToLinearGamma
    HighContrast
    Luma
    Compose
    Empty

# ============================================================================
# SkColorFilter
# ============================================================================

class SkColorFilter:
    kind: SkColorFilterKind
    color: SkColor
    blend_mode: SkBlendMode
    # 5x4 color matrix (20 floats) stored as flat list
    matrix: [f64]

fn sk_color_filter_blend(color: SkColor, blend_mode: SkBlendMode) -> SkColorFilter:
    SkColorFilter(
        kind: SkColorFilterKind.Blend,
        color: color,
        blend_mode: blend_mode,
        matrix: []
    )

fn sk_color_filter_matrix(matrix: [f64]) -> SkColorFilter:
    SkColorFilter(
        kind: SkColorFilterKind.Matrix,
        color: 0,
        blend_mode: SkBlendMode.SrcOver,
        matrix: matrix
    )

fn sk_color_filter_linear_to_srgb() -> SkColorFilter:
    SkColorFilter(
        kind: SkColorFilterKind.LinearToSrgbGamma,
        color: 0,
        blend_mode: SkBlendMode.SrcOver,
        matrix: []
    )

fn sk_color_filter_srgb_to_linear() -> SkColorFilter:
    SkColorFilter(
        kind: SkColorFilterKind.SrgbToLinearGamma,
        color: 0,
        blend_mode: SkBlendMode.SrcOver,
        matrix: []
    )

impl SkColorFilter:
    fn is_alpha_unchanged() -> bool:
        pass_todo

    fn affects_transparent_black() -> bool:
        pass_todo
