# Skia Color Type
#
# SkColor4f — four-component float RGBA used throughout Skia.
# We wrap the stdlib Color for conversion but define SkColor4f as primary.

use std.common.color.types.{Color}

# ============================================================================
# SkColor4f — float RGBA [0.0, 1.0]
# ============================================================================

class SkColor4f:
    r: f64
    g: f64
    b: f64
    a: f64

fn sk_color4f(r: f64, g: f64, b: f64, a: f64) -> SkColor4f:
    SkColor4f(r: r, g: g, b: b, a: a)

fn sk_color4f_from_color(c: Color) -> SkColor4f:
    SkColor4f(
        r: c.r.to_f64() / 255.0,
        g: c.g.to_f64() / 255.0,
        b: c.b.to_f64() / 255.0,
        a: c.a.to_f64() / 255.0
    )

# ============================================================================
# SkColor — packed 32-bit ARGB (u32 equivalent via i64)
# ============================================================================

# Packed color as i64 (upper 8 bits = alpha, then R, G, B)
type SkColor = i64

fn sk_color_argb(a: i64, r: i64, g: i64, b: i64) -> SkColor:
    (a & 0xFF) << 24 | (r & 0xFF) << 16 | (g & 0xFF) << 8 | (b & 0xFF)

fn sk_color_rgb(r: i64, g: i64, b: i64) -> SkColor:
    sk_color_argb(255, r, g, b)

fn sk_color_alpha(c: SkColor) -> i64:
    (c >> 24) & 0xFF

fn sk_color_red(c: SkColor) -> i64:
    (c >> 16) & 0xFF

fn sk_color_green(c: SkColor) -> i64:
    (c >> 8) & 0xFF

fn sk_color_blue(c: SkColor) -> i64:
    c & 0xFF

# Named color constants
fn sk_color_black() -> SkColor: sk_color_argb(255, 0, 0, 0)
fn sk_color_white() -> SkColor: sk_color_argb(255, 255, 255, 255)
fn sk_color_red() -> SkColor: sk_color_argb(255, 255, 0, 0)
fn sk_color_green() -> SkColor: sk_color_argb(255, 0, 128, 0)
fn sk_color_blue() -> SkColor: sk_color_argb(255, 0, 0, 255)
fn sk_color_transparent() -> SkColor: sk_color_argb(0, 0, 0, 0)

impl SkColor4f:
    fn to_sk_color() -> SkColor:
        val a = (self.a * 255.0).to_i64() & 0xFF
        val r = (self.r * 255.0).to_i64() & 0xFF
        val g = (self.g * 255.0).to_i64() & 0xFF
        val b = (self.b * 255.0).to_i64() & 0xFF
        sk_color_argb(a, r, g, b)

    fn to_string() -> text:
        "SkColor4f(r:{self.r} g:{self.g} b:{self.b} a:{self.a})"
