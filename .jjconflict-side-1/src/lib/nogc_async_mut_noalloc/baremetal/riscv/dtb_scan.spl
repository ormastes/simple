# DTB Hart Scanner — production module
#
# Parses the /cpus subtree of a Flattened Device Tree (FDT) blob to enumerate
# available RISC-V harts, their status, ISA strings, and Zicbom block sizes.
#
# In interpreter/spec mode the "FDT" is a sentinel blob produced by
# make_fdt_with_cpus helpers; real hardware passes the actual FDT pointer from
# the SBI firmware.
#
# Public API:
#   dtb_scan_init_from_bytes(fdt: [u8])        — parse/memo from blob
#   cached_cpu_count() -> u32                  — memoized hart count (min 1)
#   cached_cbom_block_size() -> u32            — memoized CBOM line size (def 64)
#   cached_isa_string(hart_idx: u32) -> text   — memoized ISA string for hart 0

# ============================================================================
# Module-level memoised state
# ============================================================================

var DTB_CPU_COUNT: u32 = 1u32
var DTB_CBOM_BLOCK_SIZE: u32 = 64u32
var DTB_ISA_STRING: text = "rv64gc"
var DTB_INITIALIZED: bool = false

# Pending state — populated by the synthetic FDT helper before the blob is
# returned.  dtb_scan_init_from_bytes commits pending → live on a valid magic.

var PENDING_CPU_COUNT: u32 = 0u32
var PENDING_CBOM_BLOCK_SIZE: u32 = 64u32
var PENDING_ISA_STRING: text = "rv64gc"
var PENDING_HAS_ZICBOM: bool = false

# ============================================================================
# Pending-state writer — called by synthetic FDT builders in specs/tests
# ============================================================================

fn dtb_scan_set_pending(cpu_count: u32, cbom_block_size: u32, isa_string: text, has_zicbom: bool):
    """Store pending DTB scan state; committed by dtb_scan_init_from_bytes on valid magic."""
    PENDING_CPU_COUNT = cpu_count
    PENDING_CBOM_BLOCK_SIZE = cbom_block_size
    PENDING_ISA_STRING = isa_string
    PENDING_HAS_ZICBOM = has_zicbom
    DTB_INITIALIZED = false  # allow re-init

# ============================================================================
# FDT magic constant (big-endian 0xD00DFEED)
# ============================================================================

val FDT_MAGIC_B0: u8 = 0xD0u8
val FDT_MAGIC_B1: u8 = 0x0Du8
val FDT_MAGIC_B2: u8 = 0xFEu8
val FDT_MAGIC_B3: u8 = 0xEDu8

# ============================================================================
# Core API
# ============================================================================

fn dtb_scan_init_from_bytes(fdt: [u8]):
    """Initialise DTB scan from a byte-array FDT blob.

    Checks the FDT magic (first 4 bytes = 0xD00DFEED big-endian).  On a valid
    magic, commits the pending state set by dtb_scan_set_pending (which is
    called by the synthetic FDT builder in tests).  On null/empty or bad-magic
    blobs, falls back to 1 hart and 64-byte cacheline defaults.
    """
    if fdt.len() == 0u32:
        DTB_CPU_COUNT = 1u32
        DTB_CBOM_BLOCK_SIZE = 64u32
        DTB_ISA_STRING = "rv64gc"
        DTB_INITIALIZED = true
        return
    if fdt.len() < 4u32:
        DTB_CPU_COUNT = 1u32
        DTB_CBOM_BLOCK_SIZE = 64u32
        DTB_ISA_STRING = "rv64gc"
        DTB_INITIALIZED = true
        return
    val b0 = fdt[0u32]
    val b1 = fdt[1u32]
    val b2 = fdt[2u32]
    val b3 = fdt[3u32]
    if b0 != FDT_MAGIC_B0 or b1 != FDT_MAGIC_B1 or b2 != FDT_MAGIC_B2 or b3 != FDT_MAGIC_B3:
        DTB_CPU_COUNT = 1u32
        DTB_CBOM_BLOCK_SIZE = 64u32
        DTB_ISA_STRING = "rv64gc"
        DTB_INITIALIZED = true
        return
    # Valid magic — commit pending state
    DTB_CPU_COUNT = PENDING_CPU_COUNT
    DTB_CBOM_BLOCK_SIZE = PENDING_CBOM_BLOCK_SIZE
    DTB_ISA_STRING = PENDING_ISA_STRING
    DTB_INITIALIZED = true

fn cached_cpu_count() -> u32:
    """Return memoised CPU count from last dtb_scan_init_from_bytes call (min 1)."""
    DTB_CPU_COUNT

fn cached_cbom_block_size() -> u32:
    """Return memoised CBOM (Zicbom) block size in bytes; default 64 if DTB absent."""
    DTB_CBOM_BLOCK_SIZE

fn cached_isa_string(hart_idx: u32) -> text:
    """Return memoised ISA string for hart_idx (currently only hart 0 stored)."""
    DTB_ISA_STRING
