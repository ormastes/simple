# No-Alloc TLS 1.3 Client for Baremetal Targets
#
# Pure Simple TLS 1.3 client with fixed-size buffers.
# No heap allocation, no OS dependencies.
#
# Single cipher suite: TLS_AES_128_GCM_SHA256 (0x1301)
# Single key exchange: X25519
# Certificate validation: SHA-256 fingerprint against embedded root CA hash
#
# Typical usage:
#   val cfg = TlsConfig(hostname: "example.com", root_ca_hash: root_hash_bytes)
#   var client = TlsClient.new(cfg, my_transport, ephemeral_privkey)
#   client = tls_do_handshake(client, random_bytes)?
#   client = tls_send(client, payload)?
#   val (client2, data) = tls_recv(client)?
#
# Design constraints:
#   @no_gc: all storage is stack or static
#   alloc_allowed: false (conceptual — dynamic arrays used with push, no rt_array_new_with_cap)
#   No OS — cooperative scheduling only
#   Transport is pluggable via BaremetalTransport trait

