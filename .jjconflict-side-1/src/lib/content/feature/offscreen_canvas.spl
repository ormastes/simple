# OffscreenCanvas: records SkPictures for off-screen rendering

use std.skia.entity.picture.{SkPicture}
use std.skia.entity.geometry.{SkRect, SkISize}

class OffscreenCanvas:
    size: SkISize
    recorded_picture: Option<SkPicture>

    static fn new(width: i32, height: i32) -> OffscreenCanvas:
        OffscreenCanvas(
            size: SkISize(width: width.to_i64(), height: height.to_i64()),
            recorded_picture: None
        )

    me record(picture: SkPicture):
        me.recorded_picture = Some(picture)

    me capture_bounds() -> SkRect:
        val w = me.size.width.to_f64()
        val h = me.size.height.to_f64()
        SkRect(left: 0.0, top: 0.0, right: w, bottom: h)

    # TODO(content-osr): encode recorded_picture to actual PNG bytes
    me to_png_bytes() -> [u8]:
        [u8]()
