# Web Contents — navigation and document state for a browser tab/frame.
#
# Provides: WebContents.

enum WebContentsState:
    Initializing
    Loading
    Ready
    Error

class WebContents:
    id: i32
    url: text
    title: text
    state: WebContentsState
    error_text: text

    static fn new(id: i32) -> WebContents:
        WebContents(
            id: id,
            url: "",
            title: "",
            state: WebContentsState.Initializing,
            error_text: ""
        )

    me navigate(url: text):
        me.url = url
        me.state = WebContentsState.Loading
        me.title = url

    me on_load_committed(title: text):
        me.title = title
        me.state = WebContentsState.Ready

    me on_load_error(error: text):
        me.error_text = error
        me.state = WebContentsState.Error

    fn is_ready() -> bool:
        match me.state:
            case Ready: true
            case _: false
