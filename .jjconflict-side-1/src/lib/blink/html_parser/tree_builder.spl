# HTML tree builder — consumes HtmlToken stream → DomTree.
#
# Mirrors Blink's HTMLTreeBuilder. Implements a minimal subset of the
# HTML5 tree-construction algorithm:
#   - Initial / BeforeHtml / BeforeHead / InHead / InBody / AfterBody / AfterHtml
#   - Open element stack (simple list)
#   - Auto-closing of self-closing tags (br, img, input, etc.)
#   - Text nodes appended as characters accumulate between tags
#
# Out of scope: scripting, foster parenting, active formatting elements,
# document.write re-entry, template, select/table fragment parsing.

use std.blink.html_parser.{HtmlToken, HtmlTokenKind, HtmlAttribute}
use std.blink.dom.node.{
    DomTree,
    DomNode,
    NodeType,
    Attribute,
    dom_tree_new,
    dom_node_new,
    attribute_new
}

# ============================================================================
# InsertionMode — mirrors Blink's HTMLTreeBuilder insertion mode enum.
# Only the happy-path modes are modeled.
# ============================================================================

enum InsertionMode:
    Initial
    BeforeHtml
    BeforeHead
    InHead
    InBody
    AfterBody
    AfterHtml

# ============================================================================
# _is_void_element — returns true for HTML void elements that must not have
# children (per HTML5 §13.1.2).  Self-closing syntax (/>) is also accepted
# but these tags are popped even without it.
# ============================================================================

fn _is_void_element(name: String) -> bool:
    name == "br" or name == "img" or name == "input" or name == "meta"
        or name == "link" or name == "hr" or name == "area" or name == "base"
        or name == "col" or name == "embed" or name == "param"
        or name == "source" or name == "track" or name == "wbr"

# ============================================================================
# TreeBuilderState — mutable driver for tree construction.
# ============================================================================

class TreeBuilderState:
    tree: DomTree
    open_elements: [i64]
    insertion_mode: InsertionMode
    head_id: i64
    body_id: i64
    text_buffer: String

impl TreeBuilderState:
    # -----------------------------------------------------------------------
    # flush_text — materialise accumulated character data as a Text node
    # appended under the current top-of-stack element.
    # -----------------------------------------------------------------------
    me flush_text():
        if self.text_buffer.len() == 0:
            return
        val parent_id = self.open_elements[self.open_elements.len() - 1]
        val text_id = self.tree.create_text(self.text_buffer)
        self.tree.append_child(parent_id, text_id)
        self.text_buffer = ""

    # -----------------------------------------------------------------------
    # _current — id of the current open element (top of stack).
    # -----------------------------------------------------------------------
    me _current() -> i64:
        self.open_elements[self.open_elements.len() - 1]

    # -----------------------------------------------------------------------
    # emit_start_tag — process a StartTag token.
    # -----------------------------------------------------------------------
    me emit_start_tag(name: String, attributes: [HtmlAttribute], self_closing: bool):
        self.flush_text()

        val elem_id = self.tree.create_element(name)

        # Copy attributes onto the new element node.
        var ai = 0
        while ai < attributes.len():
            self.tree.set_attribute(elem_id, attributes[ai].name, attributes[ai].value)
            ai = ai + 1

        # Append to current stack top.
        val parent_id = self._current()
        self.tree.append_child(parent_id, elem_id)

        # Update insertion mode for structural elements.
        if name == "html":
            if self.insertion_mode == InsertionMode.Initial
                    or self.insertion_mode == InsertionMode.BeforeHtml:
                self.insertion_mode = InsertionMode.BeforeHead
        else:
            if name == "head":
                self.head_id = elem_id
                self.insertion_mode = InsertionMode.InHead
            else:
                if name == "body":
                    self.body_id = elem_id
                    self.insertion_mode = InsertionMode.InBody

        # Push onto the open-element stack unless void / self-closing.
        if self_closing or _is_void_element(name):
            pass_dn
        else:
            self.open_elements.push(elem_id)

    # -----------------------------------------------------------------------
    # emit_end_tag — process an EndTag token.
    # Pop elements until the matching tag is found (simple stack discipline).
    # -----------------------------------------------------------------------
    me emit_end_tag(name: String):
        self.flush_text()

        # Walk stack from top looking for the matching tag name.
        var idx = self.open_elements.len() - 1
        while idx > 0:
            val nid = self.open_elements[idx]
            val node_opt = self.tree.get_node(nid)
            match node_opt:
                Some(node):
                    if node.tag_name == name:
                        # Pop everything down to and including this node.
                        while self.open_elements.len() > idx:
                            self.open_elements.pop()
                        # Transition insertion mode.
                        if name == "body":
                            self.insertion_mode = InsertionMode.AfterBody
                        else:
                            if name == "html":
                                self.insertion_mode = InsertionMode.AfterHtml
                        return
                None:
                    pass_dn
            idx = idx - 1

    # -----------------------------------------------------------------------
    # emit_character — accumulate text data.
    # -----------------------------------------------------------------------
    me emit_character(data: String):
        self.text_buffer = self.text_buffer + data

    # -----------------------------------------------------------------------
    # emit_comment — create a Comment node under the current open element.
    # -----------------------------------------------------------------------
    me emit_comment(data: String):
        self.flush_text()
        val parent_id = self._current()
        val new_id = self.tree.next_id
        val comment_node = dom_node_new(new_id, NodeType.Comment)
        comment_node.text_content = data
        self.tree.nodes.push(comment_node)
        self.tree.next_id = new_id + 1
        self.tree.append_child(parent_id, new_id)

    # -----------------------------------------------------------------------
    # emit_doctype — noted but requires no state change in this subset.
    # -----------------------------------------------------------------------
    me emit_doctype(name: String):
        pass_dn

    # -----------------------------------------------------------------------
    # finish — flush pending text, return the completed DomTree.
    # -----------------------------------------------------------------------
    me finish() -> DomTree:
        self.flush_text()
        self.tree

# ============================================================================
# tree_builder_new — construct the initial TreeBuilderState.
# The open_elements stack starts with the DocumentNode root (id 0).
# ============================================================================

fn tree_builder_new() -> TreeBuilderState:
    val tree = dom_tree_new()
    val stack: [i64] = []
    stack.push(0)
    TreeBuilderState(
        tree: tree,
        open_elements: stack,
        insertion_mode: InsertionMode.Initial,
        head_id: -1,
        body_id: -1,
        text_buffer: ""
    )

# ============================================================================
# build_html_tree — public entry point.
# Accepts a token stream (as produced by tokenize_html) and returns a DomTree.
# ============================================================================

fn build_html_tree(tokens: [HtmlToken]) -> DomTree:
    var state = tree_builder_new()
    var i = 0
    while i < tokens.len():
        val tok = tokens[i]
        match tok.kind:
            HtmlTokenKind.StartTag:
                state.emit_start_tag(tok.name, tok.attributes, tok.self_closing)
            HtmlTokenKind.EndTag:
                state.emit_end_tag(tok.name)
            HtmlTokenKind.Character:
                state.emit_character(tok.data)
            HtmlTokenKind.Comment:
                state.emit_comment(tok.data)
            HtmlTokenKind.Doctype:
                state.emit_doctype(tok.name)
            HtmlTokenKind.Eof:
                pass_dn
        i = i + 1
    state.finish()
