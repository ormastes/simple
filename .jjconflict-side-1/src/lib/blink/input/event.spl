# Input event — keyboard / mouse / touch event for Blink renderer.
#
# Mirrors blink::WebInputEvent. Carries source timestamp, modifier flags,
# per-type payload (mouse coords, key code, touch list). The dispatcher
# walks the hit-tested target and its ancestors running handlers.

# ============================================================================
# EventType — kind of input event
# ============================================================================

enum EventType:
    MouseDown
    MouseUp
    MouseMove
    MouseWheel
    MouseEnter
    MouseLeave
    KeyDown
    KeyUp
    Char
    TouchStart
    TouchMove
    TouchEnd
    TouchCancel
    Focus
    Blur
    Unknown

# ============================================================================
# ModifierFlags — bitfield values for keyboard modifier state
# ============================================================================

enum ModifierFlags:
    NoModifier = 0
    Shift = 1
    Ctrl = 2
    Alt = 4
    Meta = 8
    AltGr = 16

# ============================================================================
# Point — 2D coordinate in device-independent pixels
# ============================================================================

class Point:
    x: f64
    y: f64

fn point(x: f64, y: f64) -> Point:
    Point(x: x, y: y)

fn point_zero() -> Point:
    Point(x: 0.0, y: 0.0)

# ============================================================================
# TouchPoint — one finger in a multi-touch event
# ============================================================================

class TouchPoint:
    id: i64
    position: Point
    radius_x: f64
    radius_y: f64
    pressure: f64

fn touch_point(id: i64, x: f64, y: f64) -> TouchPoint:
    TouchPoint(
        id: id,
        position: Point(x: x, y: y),
        radius_x: 1.0,
        radius_y: 1.0,
        pressure: 1.0,
    )

# ============================================================================
# InputEvent — unified envelope over mouse/key/touch/wheel/focus events
# ============================================================================

class InputEvent:
    event_type: EventType
    timestamp: f64
    modifiers: i64
    position: Point
    key_code: i64
    char_code: i64
    wheel_delta_x: f64
    wheel_delta_y: f64
    touches: [TouchPoint]
    handled: bool

impl InputEvent:
    fn has_modifier(flag: i64) -> bool:
        (self.modifiers & flag) != 0

    fn is_touch() -> bool:
        self.event_type == EventType.TouchStart
            or self.event_type == EventType.TouchMove
            or self.event_type == EventType.TouchEnd
            or self.event_type == EventType.TouchCancel

    fn is_mouse() -> bool:
        self.event_type == EventType.MouseDown
            or self.event_type == EventType.MouseUp
            or self.event_type == EventType.MouseMove
            or self.event_type == EventType.MouseWheel
            or self.event_type == EventType.MouseEnter
            or self.event_type == EventType.MouseLeave

    fn is_keyboard() -> bool:
        self.event_type == EventType.KeyDown
            or self.event_type == EventType.KeyUp
            or self.event_type == EventType.Char

    fn mark_handled():
        self.handled = true

# ============================================================================
# Free constructors — concise builders for each event flavour
# ============================================================================

fn mouse_event(
    kind: EventType,
    x: f64,
    y: f64,
    timestamp: f64,
    modifiers: i64,
) -> InputEvent:
    InputEvent(
        event_type: kind,
        timestamp: timestamp,
        modifiers: modifiers,
        position: Point(x: x, y: y),
        key_code: 0,
        char_code: 0,
        wheel_delta_x: 0.0,
        wheel_delta_y: 0.0,
        touches: [],
        handled: false,
    )

fn key_event(
    kind: EventType,
    key_code: i64,
    timestamp: f64,
    modifiers: i64,
) -> InputEvent:
    InputEvent(
        event_type: kind,
        timestamp: timestamp,
        modifiers: modifiers,
        position: Point(x: 0.0, y: 0.0),
        key_code: key_code,
        char_code: 0,
        wheel_delta_x: 0.0,
        wheel_delta_y: 0.0,
        touches: [],
        handled: false,
    )

fn char_event(char_code: i64, timestamp: f64, modifiers: i64) -> InputEvent:
    InputEvent(
        event_type: EventType.Char,
        timestamp: timestamp,
        modifiers: modifiers,
        position: Point(x: 0.0, y: 0.0),
        key_code: 0,
        char_code: char_code,
        wheel_delta_x: 0.0,
        wheel_delta_y: 0.0,
        touches: [],
        handled: false,
    )

fn touch_event(
    kind: EventType,
    touches: [TouchPoint],
    timestamp: f64,
) -> InputEvent:
    InputEvent(
        event_type: kind,
        timestamp: timestamp,
        modifiers: 0,
        position: Point(x: 0.0, y: 0.0),
        key_code: 0,
        char_code: 0,
        wheel_delta_x: 0.0,
        wheel_delta_y: 0.0,
        touches: touches,
        handled: false,
    )

fn wheel_event(
    x: f64,
    y: f64,
    delta_x: f64,
    delta_y: f64,
    timestamp: f64,
    modifiers: i64,
) -> InputEvent:
    InputEvent(
        event_type: EventType.MouseWheel,
        timestamp: timestamp,
        modifiers: modifiers,
        position: Point(x: x, y: y),
        key_code: 0,
        char_code: 0,
        wheel_delta_x: delta_x,
        wheel_delta_y: delta_y,
        touches: [],
        handled: false,
    )
