# core.collections — List<T> shim
# Re-implements List<T> locally so module 'core.collections' exports it directly.

class List<T>:
    items: [T]

    static fn new() -> List<T>:
        List(items: [])

    me push(item: T):
        self.items.push(item)

    me append(item: T):
        self.items.push(item)

    fn len() -> i64:
        self.items.len()

    fn get(i: i64) -> T:
        self.items[i]

    me clear():
        self.items = []

    fn is_empty() -> bool:
        self.items.len() == 0

export List
