# FS Encoder — encode WindowRecord into an FsTree for publication.
#
# Provides: FsEntry, FsTree, FsEncoder trait, DefaultFsEncoder, encode_record.

use std.common.win_fs.window_record.{WindowRecord}

struct FsEntry:
    path: text
    content: [u8]

class FsTree:
    entries: [FsEntry]

    static fn empty() -> FsTree:
        FsTree(entries: [])

    me add(path: text, content: [u8]):
        me.entries.push(FsEntry(path: path, content: content))

trait FsEncoder:
    fn encode(rec: WindowRecord) -> FsTree

class DefaultFsEncoder:
    pass_dn

impl FsEncoder for DefaultFsEncoder:
    fn encode(rec: WindowRecord) -> FsTree:
        encode_record(rec)

fn encode_record(rec: WindowRecord) -> FsTree:
    val tree = FsTree.empty()
    val wid_text = rec.wid.to_text()
    val meta = "wid={wid_text};generation={rec.generation};app={rec.app};title={rec.title};acl={rec.acl_id_path}"
    tree.add("/win/{wid_text}/meta", meta.bytes())
    tree.add("/win/{wid_text}/state", rec.state.to_text().bytes())
    tree
