use common.encoding.utf16.{utf8_to_utf16}

# Deterministic signed 32-bit text hash matching Claude Code's djb2Hash helper.
# This is the JavaScript `(hash * 31 + charCode) | 0` behavior over UTF-16 code units.

fn _signed_i32(value: i64) -> i64:
    val masked = value & 4294967295
    if masked >= 2147483648:
        masked - 4294967296
    else:
        masked

fn djb2_hash_text(value: text) -> i64:
    var hash = 0
    val bytes = value.bytes()
    var utf8_bytes: [i64] = []
    var i: i64 = 0
    while i < bytes.len():
        utf8_bytes.push(bytes[i].to_i64())
        i = i + 1
    val units = utf8_to_utf16(utf8_bytes)
    var j: i64 = 0
    while j < units.len():
        hash = _signed_i32(((hash << 5) - hash) + units[j])
        j = j + 1
    hash

export djb2_hash_text
