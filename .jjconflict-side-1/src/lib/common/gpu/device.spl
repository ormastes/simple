# Common GPU device types shared across all tiers.

enum GpuBackend:
    Cuda
    Vulkan
    Rocm
    Oneapi
    Metal
    None_

class Gpu:
    backend: GpuBackend
    device_id: i64

fn gpu_cuda(device_id: i64) -> Gpu:
    Gpu(backend: GpuBackend.Cuda, device_id: device_id)

fn gpu_vulkan(device_id: i64) -> Gpu:
    Gpu(backend: GpuBackend.Vulkan, device_id: device_id)

fn gpu_rocm(device_id: i64) -> Gpu:
    Gpu(backend: GpuBackend.Rocm, device_id: device_id)

fn gpu_oneapi(device_id: i64) -> Gpu:
    Gpu(backend: GpuBackend.Oneapi, device_id: device_id)

fn gpu_metal(device_id: i64) -> Gpu:
    Gpu(backend: GpuBackend.Metal, device_id: device_id)

fn gpu_none() -> Gpu:
    Gpu(backend: GpuBackend.None_, device_id: -1)

export GpuBackend, Gpu
export gpu_cuda, gpu_vulkan, gpu_rocm, gpu_oneapi, gpu_metal, gpu_none
