# Draw IR Draw.io mxGraph interchange skin.
#
# Draw IR remains the typed source of truth. mxGraph is only an import/export
# skin for diagram inspection and handoff.

use common.ui.draw_ir.{
    DRAW_IR_BACKEND_CPU,
    DRAW_IR_COMMAND_EDGE,
    DRAW_IR_COMMAND_RECT,
    DRAW_IR_EDGE_ORTHOGONAL,
    DrawEdge,
    DrawIrCommand,
    DrawIrComposition,
    DrawIrStyleProp,
    draw_edge,
    draw_ir_batch_with_source,
    draw_ir_composition,
    draw_ir_edge_command,
    draw_ir_embedding_config,
    draw_ir_no_rect,
    draw_ir_source_manual,
    draw_ir_style_prop
}

fn _draw_ir_xml_escape(value: text) -> text:
    var escaped = value.replace("&", "&amp;")
    escaped = escaped.replace("<", "&lt;")
    escaped = escaped.replace(">", "&gt;")
    escaped = escaped.replace("\"", "&quot;")
    escaped

fn _draw_ir_xml_unescape(value: text) -> text:
    var unescaped = value.replace("&quot;", "\"")
    unescaped = unescaped.replace("&gt;", ">")
    unescaped = unescaped.replace("&lt;", "<")
    unescaped.replace("&amp;", "&")

fn _draw_ir_mx_attr(source: text, name: text) -> text:
    val marker = "{name}=\""
    val start = source.index_of(marker) ?? -1
    if start < 0:
        return ""
    val body_start = start + marker.len()
    val rest = source.substring(body_start, source.len())
    val end = rest.index_of("\"") ?? -1
    if end < 0:
        return ""
    _draw_ir_xml_unescape(rest.substring(0, end))

fn _draw_ir_mx_i32(source: text, name: text) -> i32:
    val value = _draw_ir_mx_attr(source, name)
    value.parse_i32() ?? 0

fn _draw_ir_mx_style_props(style: text) -> [DrawIrStyleProp]:
    var props: [DrawIrStyleProp] = []
    for raw_item in style.split(";"):
        val item = raw_item.trim()
        val eq = item.index_of("=") ?? -1
        if eq > 0:
            props = props.push(draw_ir_style_prop(item.substring(0, eq), item.substring(eq + 1, item.len())))
    props

fn _draw_ir_mx_style_text(props: [DrawIrStyleProp]) -> text:
    var style = ""
    for prop in props:
        if prop.key != "":
            style = style + _draw_ir_xml_escape(prop.key) + "=" + _draw_ir_xml_escape(prop.value) + ";"
    style

fn _draw_ir_mx_geometry_source(cell: text) -> text:
    val start = cell.index_of("<mxGeometry") ?? -1
    if start < 0:
        return ""
    val rest = cell.substring(start, cell.len())
    val end = rest.index_of(">") ?? -1
    if end < 0:
        return rest
    rest.substring(0, end + 1)

fn _draw_ir_mx_box_command(id: text, parent_id: text, x: i32, y: i32, width: i32, height: i32, style: [DrawIrStyleProp]) -> DrawIrCommand:
    DrawIrCommand(
        kind: DRAW_IR_COMMAND_RECT,
        component_id: id,
        x: x,
        y: y,
        width: width,
        height: height,
        color: 0u32,
        text_value: "",
        border_rect: draw_ir_no_rect(),
        content_rect: draw_ir_no_rect(),
        hit_rect: draw_ir_no_rect(),
        clip_rect: draw_ir_no_rect(),
        computed_style: style,
        edge: nil,
        parent_id: parent_id,
        image_uri: "",
        points: []
    )

fn _draw_ir_mx_emit_vertex(command: DrawIrCommand) -> text:
    val style = _draw_ir_mx_style_text(command.computed_style)
    var parent = command.parent_id
    if parent == "":
        parent = "1"
    "<mxCell id=\"{_draw_ir_xml_escape(command.component_id)}\" value=\"\" style=\"{style}\" parent=\"{_draw_ir_xml_escape(parent)}\" vertex=\"1\"><mxGeometry x=\"{command.x}\" y=\"{command.y}\" width=\"{command.width}\" height=\"{command.height}\" as=\"geometry\"/></mxCell>"

fn _draw_ir_mx_emit_edge(edge: DrawEdge, fallback_style: [DrawIrStyleProp]) -> text:
    var style_props = edge.style
    if style_props.len() == 0:
        style_props = fallback_style
    val style = _draw_ir_mx_style_text(style_props)
    "<mxCell id=\"{_draw_ir_xml_escape(edge.id)}\" value=\"\" style=\"{style}\" parent=\"1\" source=\"{_draw_ir_xml_escape(edge.source)}\" target=\"{_draw_ir_xml_escape(edge.target)}\" edge=\"1\"><mxGeometry relative=\"1\" as=\"geometry\"/></mxCell>"

fn draw_ir_to_mxgraph(composition: DrawIrComposition) -> text:
    var lines: [text] = []
    lines = lines.push("<mxGraphModel dx=\"0\" dy=\"0\" grid=\"1\" gridSize=\"10\" guides=\"1\"><root>")
    lines = lines.push("<mxCell id=\"0\"/>")
    lines = lines.push("<mxCell id=\"1\" parent=\"0\"/>")
    for batch in composition.batches:
        for command in batch.commands:
            if command.kind == DRAW_IR_COMMAND_EDGE and command.edge != nil:
                lines = lines.push(_draw_ir_mx_emit_edge(command.edge, command.computed_style))
            elif command.kind == DRAW_IR_COMMAND_RECT:
                lines = lines.push(_draw_ir_mx_emit_vertex(command))
    lines = lines.push("</root></mxGraphModel>")
    lines.join("\n")

fn _draw_ir_mx_parse_cell(cell: text) -> DrawIrCommand?:
    val id = _draw_ir_mx_attr(cell, "id")
    if id == "" or id == "0" or id == "1":
        return nil
    val style = _draw_ir_mx_style_props(_draw_ir_mx_attr(cell, "style"))
    if _draw_ir_mx_attr(cell, "edge") == "1":
        val edge = draw_edge(
            id,
            _draw_ir_mx_attr(cell, "source"),
            _draw_ir_mx_attr(cell, "target"),
            DRAW_IR_EDGE_ORTHOGONAL,
            [],
            style
        )
        return draw_ir_edge_command(edge)
    if _draw_ir_mx_attr(cell, "vertex") == "1":
        val geometry = _draw_ir_mx_geometry_source(cell)
        return _draw_ir_mx_box_command(
            id,
            _draw_ir_mx_attr(cell, "parent"),
            _draw_ir_mx_i32(geometry, "x"),
            _draw_ir_mx_i32(geometry, "y"),
            _draw_ir_mx_i32(geometry, "width"),
            _draw_ir_mx_i32(geometry, "height"),
            style
        )
    nil

fn mxgraph_to_draw_ir(source: text) -> DrawIrComposition:
    var commands: [DrawIrCommand] = []
    for chunk in source.split("<mxCell "):
        val parsed = _draw_ir_mx_parse_cell(chunk)
        if parsed != nil:
            commands = commands.push(parsed)
    val batch = draw_ir_batch_with_source(
        "mxgraph",
        DRAW_IR_BACKEND_CPU,
        draw_ir_embedding_config("mxgraph", "mxgraph-root", 0, 0, 0, 0, 0, 1000, false),
        commands,
        draw_ir_source_manual()
    )
    draw_ir_composition("mxgraph", "mxgraph", DRAW_IR_BACKEND_CPU, [batch])
