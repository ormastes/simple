# Adaptive Layout Scaffolds
#
# High-level layout scaffolds that select structure based on FormFactorProfile.
# Two scaffolds:
#   - adaptive_nav_scaffold: bottom-bar / rail / sidebar navigation
#   - list_detail_scaffold: single-pane / two-pane list+detail
#
# Navigation pattern selection:
#   - Width Compact AND height Compact (landscape phone) → "rail"
#   - Width Compact (portrait phone)                    → "bottom"
#   - Width Regular (tablet portrait)                   → "rail"
#   - Width Expanded (tablet landscape / desktop)       → "sidebar"
#
# See doc/01_research/ui/responsive_layout/responsive_layout_platforms.md

use common.ui.form_factor.{FormFactorProfile, DeviceClass, min_touch_target}
use common.ui.profile.{SizeClass, Orientation}
use common.ui.widget.{WidgetNode}
use common.ui.builder.{
    column, row, button, label,
    with_flex, with_width
}

# =========================================================================
# NavItem
# =========================================================================

struct NavItem:
    id:     text
    label:  text
    icon:   text
    action: text

# =========================================================================
# Internal helpers
# =========================================================================

fn _nav_item_button(item: NavItem, min_h: i32) -> WidgetNode:
    """Build a single nav item button node with min_height and action props."""
    var btn = button(item.id, item.label, item.action)
    btn = btn.set_prop("min_height", "{min_h}")
    btn = btn.set_prop("icon", item.icon)
    return btn

fn _choose_nav_pattern(ff: FormFactorProfile) -> text:
    """Select the navigation pattern string from FormFactorProfile.

    Priority:
      1. Phone device in Landscape orientation → rail (landscape phone)
      2. Width Compact                         → bottom
      3. Width Regular                         → rail
      4. Width Expanded                        → sidebar
    """
    # Landscape phone: Phone device + landscape orientation → rail not bottom
    if ff.device == DeviceClass.Phone and ff.layout.orientation == Orientation.Landscape:
        return "rail"
    if ff.layout.horizontal == SizeClass.Compact:
        return "bottom"
    if ff.layout.horizontal == SizeClass.Regular:
        return "rail"
    return "sidebar"

# =========================================================================
# adaptive_nav_scaffold
# =========================================================================

fn adaptive_nav_scaffold(id: text, items: [NavItem], content: WidgetNode, ff: FormFactorProfile) -> WidgetNode:
    """Build an adaptive navigation scaffold selecting bottom / rail / sidebar
    based on the FormFactorProfile.

    - bottom (Compact width, portrait): column([content, nav row of item buttons])
    - rail   (Compact+landscape, Regular): row([narrow icon column (~72), content])
    - sidebar (Expanded): row([full-label column (~240), content])

    Root node gets prop nav_pattern = "bottom"|"rail"|"sidebar".
    Each nav item button gets min_height from min_touch_target(ff.device, ff.platform).
    """
    val pattern = _choose_nav_pattern(ff)
    val min_h = min_touch_target(ff.device, ff.platform)

    var item_buttons: [WidgetNode] = []
    for item in items:
        val btn = _nav_item_button(item, min_h)
        item_buttons = item_buttons + [btn]

    var root = if pattern == "bottom":
        # column([content with_flex 1, nav row])
        val nav_bar = row("{id}_nav_bar", item_buttons)
        val content_flex = with_flex(content, 1)
        column(id, [content_flex, nav_bar])
    elif pattern == "rail":
        # row([narrow icon column ~72, content with_flex 1])
        val nav_col = with_width(column("{id}_nav_rail", item_buttons), 72)
        val content_flex = with_flex(content, 1)
        row(id, [nav_col, content_flex])
    else:
        # sidebar: row([full-label column ~240, content with_flex 1])
        val nav_col = with_width(column("{id}_nav_sidebar", item_buttons), 240)
        val content_flex = with_flex(content, 1)
        row(id, [nav_col, content_flex])

    root = root.set_prop("nav_pattern", pattern)
    return root

# =========================================================================
# list_detail_scaffold
# =========================================================================

fn list_detail_scaffold(id: text, list: WidgetNode, detail: WidgetNode, ff: FormFactorProfile, show_detail: bool) -> WidgetNode:
    """Build a list/detail scaffold.

    - Expanded width → two_pane: row([list with_flex 1, detail with_flex 2])
    - Compact/Regular width:
        - show_detail=false → single_list: column([list])
        - show_detail=true  → single_detail: column([detail]) with detail.back_nav="true"

    Root node gets prop list_detail = "two_pane"|"single_list"|"single_detail".
    """
    if ff.layout.horizontal == SizeClass.Expanded:
        val list_flex   = with_flex(list, 1)
        val detail_flex = with_flex(detail, 2)
        var root = row(id, [list_flex, detail_flex])
        root = root.set_prop("list_detail", "two_pane")
        return root
    if show_detail:
        var detail_nav = detail.set_prop("back_nav", "true")
        var root = column(id, [detail_nav])
        root = root.set_prop("list_detail", "single_detail")
        return root
    var root = column(id, [list])
    root = root.set_prop("list_detail", "single_list")
    return root
