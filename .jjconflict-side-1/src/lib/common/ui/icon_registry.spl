# Icon Registry — Unified Graphical Icon Definitions
#
# Stores RLE-encoded icon data for system and applications.
# Colors are sourced from glass_numeric_tokens to maintain theme consistency.

# Phase 1: removed dead glass_numeric_tokens import — see RFC §3.3

struct IconDefinition:
    name: text
    width: i32
    height: i32
    # RLE data: [count, color_u32, count, color_u32, ...]
    # 0x00000000 color is interpreted as transparent.
    rle_data: [u32]

impl IconDefinition:
    static fn terminal() -> IconDefinition:
        # 16x16 terminal icon with prompt
        IconDefinition(
            name: "terminal",
            width: 16, height: 16,
            rle_data: [
                16, 0x00000000,
                1, 0x00000000, 14, 0xFF2D2D30, 1, 0x00000000,
                1, 0x00000000, 14, 0xFF2D2D30, 1, 0x00000000,
                1, 0x00000000, 2, 0xFF2D2D30, 3, 0xFF44FF44, 9, 0xFF2D2D30, 1, 0x00000000,
                1, 0x00000000, 14, 0xFF2D2D30, 1, 0x00000000,
                1, 0x00000000, 14, 0xFF2D2D30, 1, 0x00000000,
                208, 0x00000000 
            ]
        )

    static fn folder() -> IconDefinition:
        # 16x16 folder icon
        IconDefinition(
            name: "folder",
            width: 16, height: 16,
            rle_data: [
                32, 0x00000000,
                2, 0x00000000, 6, 0xFF4A90D9, 8, 0x00000000,
                1, 0x00000000, 14, 0xFF4A90D9, 1, 0x00000000,
                1, 0x00000000, 14, 0xFF5DADE2, 1, 0x00000000,
                1, 0x00000000, 14, 0xFF5DADE2, 1, 0x00000000,
                1, 0x00000000, 14, 0xFF5DADE2, 1, 0x00000000,
                1, 0x00000000, 14, 0xFF5DADE2, 1, 0x00000000,
                1, 0x00000000, 14, 0xFF5DADE2, 1, 0x00000000,
                16, 0x00000000
            ]
        )

    static fn document() -> IconDefinition:
        # 16x16 document icon
        IconDefinition(
            name: "document",
            width: 16, height: 16,
            rle_data: [
                16, 0x00000000,
                3, 0x00000000, 10, 0xFFECF0F1, 3, 0x00000000,
                1, 0x00000000, 14, 0xFFECF0F1, 1, 0x00000000,
                1, 0x00000000, 3, 0xFFECF0F1, 8, 0xFFBDC3C7, 3, 0xFFECF0F1, 1, 0x00000000,
                192, 0xFFECF0F1,
                16, 0x00000000
            ]
        )

    static fn search() -> IconDefinition:
        IconDefinition(name: "search", width: 16, height: 16, rle_data: [256, 0xFFE3E0F3])
    static fn wifi() -> IconDefinition:
        IconDefinition(name: "wifi", width: 16, height: 16, rle_data: [256, 0xFFE3E0F3])
    static fn battery() -> IconDefinition:
        IconDefinition(name: "battery", width: 16, height: 16, rle_data: [256, 0xFF30D158])
    static fn close() -> IconDefinition:
        IconDefinition(name: "close", width: 16, height: 16, rle_data: [256, 0xFFFF5F57])
    static fn minimize() -> IconDefinition:
        IconDefinition(name: "minimize", width: 16, height: 16, rle_data: [256, 0xFFFFBD2E])
    static fn maximize() -> IconDefinition:
        IconDefinition(name: "maximize", width: 16, height: 16, rle_data: [256, 0xFF28CA41])
    static fn calculator() -> IconDefinition:
        IconDefinition(name: "calculator", width: 16, height: 16, rle_data: [256, 0xFFE74C3C])
    static fn editor() -> IconDefinition:
        IconDefinition(name: "editor", width: 16, height: 16, rle_data: [256, 0xFFFFFFFF])
    static fn paint() -> IconDefinition:
        IconDefinition(name: "paint", width: 16, height: 16, rle_data: [256, 0xFFF1C40F])
    static fn minesweeper() -> IconDefinition:
        IconDefinition(name: "minesweeper", width: 16, height: 16, rle_data: [256, 0xFF333333])
    static fn tetris() -> IconDefinition:
        IconDefinition(name: "tetris", width: 16, height: 16, rle_data: [256, 0xFF3498DB])
    static fn pencil() -> IconDefinition:
        IconDefinition(name: "pencil", width: 16, height: 16, rle_data: [256, 0xFFF1C40F])
    static fn line() -> IconDefinition:
        IconDefinition(name: "line", width: 16, height: 16, rle_data: [256, 0xFF3498DB])
    static fn rect() -> IconDefinition:
        IconDefinition(name: "rect", width: 16, height: 16, rle_data: [256, 0xFFE74C3C])
    static fn circle() -> IconDefinition:
        IconDefinition(name: "circle", width: 16, height: 16, rle_data: [256, 0xFF2ECC71])
    static fn fill() -> IconDefinition:
        IconDefinition(name: "fill", width: 16, height: 16, rle_data: [256, 0xFF9B59B6])
    static fn eraser() -> IconDefinition:
        IconDefinition(name: "eraser", width: 16, height: 16, rle_data: [256, 0xFFFF79C6])
    static fn mine() -> IconDefinition:
        IconDefinition(name: "mine", width: 16, height: 16, rle_data: [256, 0xFF333333])
    static fn flag() -> IconDefinition:
        IconDefinition(name: "flag", width: 16, height: 16, rle_data: [256, 0xFFFF0000])
    static fn settings() -> IconDefinition:
        IconDefinition(name: "settings", width: 16, height: 16, rle_data: [256, 0xFF8E8E93])
    static fn activity() -> IconDefinition:
        IconDefinition(name: "activity", width: 16, height: 16, rle_data: [256, 0xFFFF3B30])
    static fn clock() -> IconDefinition:
        IconDefinition(name: "clock", width: 16, height: 16, rle_data: [256, 0xFFFFFFFF])
    static fn calendar() -> IconDefinition:
        IconDefinition(name: "calendar", width: 16, height: 16, rle_data: [256, 0xFFFF2D55])
    static fn disk() -> IconDefinition:
        IconDefinition(name: "disk", width: 16, height: 16, rle_data: [256, 0xFF555555])
    static fn image() -> IconDefinition:
        IconDefinition(name: "image", width: 16, height: 16, rle_data: [256, 0xFF4CD964])

# Global registry lookup
fn get_icon_definition(id: text) -> IconDefinition?:
    if id == "terminal": return IconDefinition.terminal()
    if id == "folder": return IconDefinition.folder()
    if id == "document": return IconDefinition.document()
    if id == "search": return IconDefinition.search()
    if id == "wifi": return IconDefinition.wifi()
    if id == "battery": return IconDefinition.battery()
    if id == "close": return IconDefinition.close()
    if id == "minimize": return IconDefinition.minimize()
    if id == "maximize": return IconDefinition.maximize()
    if id == "calculator": return IconDefinition.calculator()
    if id == "editor": return IconDefinition.editor()
    if id == "paint": return IconDefinition.paint()
    if id == "minesweeper": return IconDefinition.minesweeper()
    if id == "tetris": return IconDefinition.tetris()
    if id == "pencil": return IconDefinition.pencil()
    if id == "line": return IconDefinition.line()
    if id == "rect": return IconDefinition.rect()
    if id == "circle": return IconDefinition.circle()
    if id == "fill": return IconDefinition.fill()
    if id == "eraser": return IconDefinition.eraser()
    if id == "mine": return IconDefinition.mine()
    if id == "flag": return IconDefinition.flag()
    if id == "settings": return IconDefinition.settings()
    if id == "activity": return IconDefinition.activity()
    if id == "clock": return IconDefinition.clock()
    if id == "calendar": return IconDefinition.calendar()
    if id == "disk": return IconDefinition.disk()
    if id == "image": return IconDefinition.image()
    nil
