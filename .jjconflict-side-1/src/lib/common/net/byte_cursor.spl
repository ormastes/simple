# ============================================================================
# common/net/byte_cursor.spl — big-endian wire codec foundation
#
# ByteReader/ByteWriter for the typed network layer (bgp, dtls, ipsec, ldap,
# os netstack, game_net). Network byte order (big-endian) throughout.
# Reads return Result<_, text>; truncated input yields Err, never a panic.
#
# NOTE: cross-module by-value receiver mutation does not propagate
# (BUG byvalue_reader_cursor_no_advance_cross_module_2026-06-15) — construct
# the ByteReader locally in each parse function and read inline.
# ============================================================================

struct ByteReader:
    """Cursor over an immutable byte buffer. `pos` advances on each read."""
    data: [u8]
    pos: u64

impl ByteReader:
    static fn new(data: [u8]) -> ByteReader:
        ByteReader(data: data, pos: 0)

    fn remaining() -> u64:
        self.data.len().to_u64() - self.pos

    fn offset() -> u64:
        self.pos

    fn len() -> u64:
        self.data.len().to_u64()

    me read_u8() -> Result<u8, text>:
        if self.pos + 1 > self.data.len().to_u64():
            return Err("byte_cursor: read_u8 past end (pos {self.pos}, len {self.data.len()})")
        val b = self.data[self.pos]
        self.pos = self.pos + 1
        Ok(b)

    me read_u16() -> Result<u16, text>:
        val v = self.read_be(2)?
        Ok(v.to_u16())

    me read_u24() -> Result<u32, text>:
        val v = self.read_be(3)?
        Ok(v.to_u32())

    me read_u32() -> Result<u32, text>:
        val v = self.read_be(4)?
        Ok(v.to_u32())

    me read_u48() -> Result<u64, text>:
        self.read_be(6)

    me read_u64() -> Result<u64, text>:
        self.read_be(8)

    me read_bytes(n: u64) -> Result<[u8], text>:
        if self.pos + n > self.data.len().to_u64():
            return Err("byte_cursor: read_bytes({n}) past end (pos {self.pos}, len {self.data.len()})")
        var out: [u8] = []
        var i: u64 = 0
        while i < n:
            out.push(self.data[self.pos + i])
            i = i + 1
        self.pos = self.pos + n
        Ok(out)

    me read_be(n: u64) -> Result<u64, text>:
        """Read n big-endian bytes into a u64 (n <= 8)."""
        if self.pos + n > self.data.len().to_u64():
            return Err("byte_cursor: read past end (need {n}, pos {self.pos}, len {self.data.len()})")
        var v: u64 = 0
        var i: u64 = 0
        while i < n:
            v = (v << 8) | self.data[self.pos + i].to_u64()
            i = i + 1
        self.pos = self.pos + n
        Ok(v)

struct ByteWriter:
    """Append-only big-endian byte buffer."""
    buf: [u8]

impl ByteWriter:
    static fn new() -> ByteWriter:
        ByteWriter(buf: [])

    fn len() -> u64:
        self.buf.len().to_u64()

    me write_u8(v: u8):
        self.buf.push(v)

    me write_u16(v: u16):
        self.write_be(v.to_u64(), 2)

    me write_u24(v: u32):
        self.write_be(v.to_u64(), 3)

    me write_u32(v: u32):
        self.write_be(v.to_u64(), 4)

    me write_u48(v: u64):
        self.write_be(v, 6)

    me write_u64(v: u64):
        self.write_be(v, 8)

    me write_bytes(bytes: [u8]):
        var i: u64 = 0
        while i < bytes.len().to_u64():
            self.buf.push(bytes[i])
            i = i + 1

    me write_be(v: u64, n: u64):
        """Append the low n bytes of v, most significant first (n <= 8)."""
        var i: u64 = 0
        while i < n:
            val shift = (n - 1 - i) * 8
            self.buf.push(((v >> shift) & 0xFF).to_u8())
            i = i + 1

    fn to_bytes() -> [u8]:
        self.buf

export ByteReader, ByteWriter
