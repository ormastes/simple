# ============================================================================
# common/net/oid.spl — dotted-decimal object identifier (ldap consumer)
# ============================================================================

struct Oid:
    """Object identifier in dotted-decimal text form (e.g. "1.2.840.113556.1.4.319")."""
    value: text

impl Oid:
    static fn new(v: text) -> Oid:
        Oid(value: v)

export Oid
