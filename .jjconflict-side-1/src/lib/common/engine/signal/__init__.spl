# Engine Signal/Event System
#
# Provides a decoupled signal/event system for the 2D game engine.
# Signals are the core building block; the EventBus adds a named registry
# for cross-system communication.

# Re-exported from types.spl
export SignalConnectionId, SignalConnection

# Re-exported from signal.spl
export Signal

# Re-exported from event_bus.spl
export EventBus
