# Office Search Helpers
#
# Shared search/replace helpers for Office apps.

struct SearchOptions:
    case_sensitive: bool

fn default_search_options() -> SearchOptions:
    SearchOptions(case_sensitive: true)

fn replace_first(content: text, needle: text, replacement: text, start_index: i64, options: SearchOptions) -> text:
    """Replace the first matching occurrence at or after start_index."""
    if needle == "":
        return content
    var haystack = content
    var query = needle
    if not options.case_sensitive:
        haystack = content.lower()
        query = needle.lower()
    var idx = haystack.slice(start_index, haystack.len()).index_of(query)
    if idx < 0:
        return content
    idx = idx + start_index
    content.slice(0, idx) + replacement + content.slice(idx + needle.len(), content.len())
