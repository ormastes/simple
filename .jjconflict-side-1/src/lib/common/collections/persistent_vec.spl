# Persistent Vector - Chunked with tail optimization
#
# Immutable vector with structural sharing.
# Every mutation returns a NEW vector — original is never modified.
#
# Uses a chunked approach: items stored in fixed-size chunks (32 elements).
# push/pop only copy the tail chunk; earlier chunks are shared.
#
# Performance vs naive array-copy:
#   push:  O(1) amortized vs O(n) — only copies tail chunk
#   pop:   O(1) amortized vs O(n) — only copies tail chunk
#   get:   O(1) vs O(1)           — same
#   set:   O(chunk) vs O(n)       — only copies affected chunk

val PV_CHUNK_SIZE: i64 = 32

class PersistentVec:
    chunks: []      # Array of chunk arrays
    pv_size: i64    # Total element count

    fn len() -> i64:
        self.pv_size

    fn is_empty() -> bool:
        self.pv_size == 0

    fn push(element) -> PersistentVec:
        if self.chunks.len() == 0:
            return PersistentVec(chunks: [[element]], pv_size: 1)
        val last_idx = self.chunks.len() - 1
        val last_chunk = self.chunks[last_idx]
        if last_chunk.len() < PV_CHUNK_SIZE:
            # Append to tail chunk (copy only this chunk)
            var new_chunk = []
            for item in last_chunk:
                new_chunk.push(item)
            new_chunk.push(element)
            var new_chunks = []
            var i = 0
            for c in self.chunks:
                if i == last_idx:
                    new_chunks.push(new_chunk)
                else:
                    new_chunks.push(c)
                i = i + 1
            PersistentVec(chunks: new_chunks, pv_size: self.pv_size + 1)
        else:
            # Tail chunk full — start new chunk
            var new_chunks = []
            for c in self.chunks:
                new_chunks.push(c)
            new_chunks.push([element])
            PersistentVec(chunks: new_chunks, pv_size: self.pv_size + 1)

    fn pop() -> PersistentVec:
        if self.pv_size == 0:
            return PersistentVec(chunks: [], pv_size: 0)
        val last_idx = self.chunks.len() - 1
        val last_chunk = self.chunks[last_idx]
        if last_chunk.len() == 1:
            # Remove entire tail chunk
            var new_chunks = []
            var i = 0
            for c in self.chunks:
                if i < last_idx:
                    new_chunks.push(c)
                i = i + 1
            PersistentVec(chunks: new_chunks, pv_size: self.pv_size - 1)
        else:
            # Remove last element from tail chunk
            var new_chunk = []
            val end_idx = last_chunk.len() - 1
            var j = 0
            for item in last_chunk:
                if j < end_idx:
                    new_chunk.push(item)
                j = j + 1
            var new_chunks = []
            var i = 0
            for c in self.chunks:
                if i == last_idx:
                    new_chunks.push(new_chunk)
                else:
                    new_chunks.push(c)
                i = i + 1
            PersistentVec(chunks: new_chunks, pv_size: self.pv_size - 1)

    fn get(index: i64):
        val n = self.pv_size
        if n == 0:
            return nil
        var idx = index
        if idx < 0:
            idx = n + idx
        if idx < 0:
            return nil
        if idx >= n:
            return nil
        # Find chunk and offset
        val chunk_idx = idx / PV_CHUNK_SIZE
        val offset = idx % PV_CHUNK_SIZE
        self.chunks[chunk_idx][offset]

    fn set(index: i64, value) -> PersistentVec:
        val n = self.pv_size
        var idx = index
        if idx < 0:
            idx = n + idx
        if idx < 0:
            return self.copy()
        if idx >= n:
            return self.copy()
        val chunk_idx = idx / PV_CHUNK_SIZE
        val offset = idx % PV_CHUNK_SIZE
        # Copy only the affected chunk
        val old_chunk = self.chunks[chunk_idx]
        var new_chunk = []
        var j = 0
        for item in old_chunk:
            if j == offset:
                new_chunk.push(value)
            else:
                new_chunk.push(item)
            j = j + 1
        var new_chunks = []
        var i = 0
        for c in self.chunks:
            if i == chunk_idx:
                new_chunks.push(new_chunk)
            else:
                new_chunks.push(c)
            i = i + 1
        PersistentVec(chunks: new_chunks, pv_size: self.pv_size)

    fn first():
        if self.pv_size == 0:
            return nil
        self.chunks[0][0]

    fn last():
        if self.pv_size == 0:
            return nil
        val last_chunk = self.chunks[self.chunks.len() - 1]
        last_chunk[last_chunk.len() - 1]

    fn contains(element) -> bool:
        for chunk in self.chunks:
            for item in chunk:
                if item == element:
                    return true
        false

    fn concat(other: PersistentVec) -> PersistentVec:
        var result = PersistentVec(chunks: self.chunks, pv_size: self.pv_size)
        for chunk in other.chunks:
            for item in chunk:
                result = result.push(item)
        result

    fn map(f: fn()) -> PersistentVec:
        var new_chunks = []
        for chunk in self.chunks:
            var new_chunk = []
            for item in chunk:
                new_chunk.push(f(item))
            new_chunks.push(new_chunk)
        PersistentVec(chunks: new_chunks, pv_size: self.pv_size)

    fn filter(pred: fn()) -> PersistentVec:
        var result = PersistentVec.empty()
        for chunk in self.chunks:
            for item in chunk:
                if pred(item):
                    result = result.push(item)
        result

    fn fold(init, f: fn()):
        var acc = init
        for chunk in self.chunks:
            for item in chunk:
                acc = f(acc, item)
        acc

    fn take(n: i64) -> PersistentVec:
        var result = PersistentVec.empty()
        var count = 0
        for chunk in self.chunks:
            for item in chunk:
                if count < n:
                    result = result.push(item)
                count = count + 1
        result

    fn drop(n: i64) -> PersistentVec:
        var result = PersistentVec.empty()
        var count = 0
        for chunk in self.chunks:
            for item in chunk:
                if count >= n:
                    result = result.push(item)
                count = count + 1
        result

    fn slice(start_idx: i64, end_idx: i64) -> PersistentVec:
        var result = PersistentVec.empty()
        var count = 0
        for chunk in self.chunks:
            for item in chunk:
                val in_range = count >= start_idx and count < end_idx
                if in_range:
                    result = result.push(item)
                count = count + 1
        result

    fn reverse() -> PersistentVec:
        var result = PersistentVec.empty()
        val n = self.pv_size
        var i = n - 1
        while i >= 0:
            result = result.push(self.get(i))
            i = i - 1
        result

    fn to_array():
        var result = []
        for chunk in self.chunks:
            for item in chunk:
                result.push(item)
        result

    fn copy() -> PersistentVec:
        PersistentVec(chunks: self.chunks, pv_size: self.pv_size)

    static fn of(arr) -> PersistentVec:
        PersistentVec.from_array(arr)

    static fn from_array(arr) -> PersistentVec:
        var chunks = []
        var current_chunk = []
        for item in arr:
            current_chunk.push(item)
            if current_chunk.len() == PV_CHUNK_SIZE:
                chunks.push(current_chunk)
                current_chunk = []
        if current_chunk.len() > 0:
            chunks.push(current_chunk)
        var size = 0
        for chunk in chunks:
            size = size + chunk.len()
        PersistentVec(chunks: chunks, pv_size: size)

    static fn empty() -> PersistentVec:
        PersistentVec(chunks: [], pv_size: 0)
