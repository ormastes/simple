# GPU Protocol — shared types for GPU resource management and commands.
#
# Defines the vocabulary for VirtIO-GPU style resource creation, backing
# attachment, transfer, flush, and scanout operations.  Used by the GPU
# driver, display service, and compositor.

# ============================================================================
# Constants — GPU command kinds
# ============================================================================

val GPU_CMD_CREATE_RESOURCE: u32 = 1
val GPU_CMD_DESTROY_RESOURCE: u32 = 2
val GPU_CMD_ATTACH_BACKING: u32 = 3
val GPU_CMD_DETACH_BACKING: u32 = 4
val GPU_CMD_TRANSFER: u32 = 5
val GPU_CMD_FLUSH: u32 = 6
val GPU_CMD_SET_SCANOUT: u32 = 7
val GPU_CMD_GET_DISPLAY: u32 = 8

# ============================================================================
# Constants — GPU error codes
# ============================================================================

val GPU_OK: u32 = 0
val GPU_ERR_INVALID: u32 = 1
val GPU_ERR_NO_MEMORY: u32 = 2
val GPU_ERR_DEVICE: u32 = 3

# ============================================================================
# GPU resource identifier
# ============================================================================

struct GpuResourceId:
    """Opaque handle to a GPU-managed resource (texture, buffer, etc.)."""
    id: u32

# ============================================================================
# GPU buffer descriptor
# ============================================================================

struct GpuBufferDesc:
    """Describes a GPU-backed pixel buffer (2D resource)."""
    resource_id: u32
    width: u32
    height: u32
    format: u32
    size: u64

# ============================================================================
# GPU fence identifier
# ============================================================================

struct GpuFenceId:
    """Fence for GPU command synchronization."""
    id: u64

# ============================================================================
# GPU error
# ============================================================================

struct GpuError:
    """Error returned from GPU operations."""
    code: u32
    message: text

# ============================================================================
# Helper constructors
# ============================================================================

fn gpu_resource(id: u32) -> GpuResourceId:
    """Create a GpuResourceId from a raw id."""
    GpuResourceId(id: id)

fn gpu_buffer(rid: u32, w: u32, h: u32, fmt: u32, sz: u64) -> GpuBufferDesc:
    """Create a GpuBufferDesc."""
    GpuBufferDesc(resource_id: rid, width: w, height: h, format: fmt, size: sz)

fn gpu_fence(id: u64) -> GpuFenceId:
    """Create a GpuFenceId."""
    GpuFenceId(id: id)

fn gpu_error(code: u32, msg: text) -> GpuError:
    """Create a GpuError."""
    GpuError(code: code, message: msg)

fn gpu_ok_error() -> GpuError:
    """Create a success (no-error) GpuError."""
    GpuError(code: GPU_OK, message: "")

fn gpu_buffer_size_bytes(w: u32, h: u32, bpp: u32) -> u64:
    """Calculate buffer size in bytes for a given resolution and bits-per-pixel."""
    val row_bytes = w.to_u64() * (bpp.to_u64() / 8)
    row_bytes * h.to_u64()
