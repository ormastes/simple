# Display Protocol — shared types for display modes, surfaces, and damage regions.
#
# These types form the common vocabulary between the display service,
# compositor, GPU driver, and any client that needs to describe display
# geometry or pixel-format metadata.

# ============================================================================
# Constants — pixel formats
# ============================================================================

val PIXEL_FORMAT_BGRA8: u32 = 1
val PIXEL_FORMAT_RGBA8: u32 = 2
val PIXEL_FORMAT_RGB565: u32 = 3

# ============================================================================
# Constants — display events
# ============================================================================

val DISPLAY_EVENT_DAMAGE: u32 = 1
val DISPLAY_EVENT_MODE_CHANGE: u32 = 2
val DISPLAY_EVENT_HOTPLUG: u32 = 3

# ============================================================================
# Display mode descriptor
# ============================================================================

struct DisplayMode:
    """Describes a display output configuration (resolution + format + refresh)."""
    width: u32
    height: u32
    format: u32
    refresh_hz: u32

# ============================================================================
# Damage rectangle
# ============================================================================

struct DamageRect:
    """Axis-aligned rectangle marking a dirty display region."""
    x: u32
    y: u32
    width: u32
    height: u32

# ============================================================================
# Surface descriptor
# ============================================================================

struct SurfaceDesc:
    """Describes a compositable surface backed by a pixel buffer."""
    id: u32
    width: u32
    height: u32
    format: u32
    buffer_virt: u64
    buffer_phys: u64
    buffer_size: u64

# ============================================================================
# Display event
# ============================================================================

struct DisplayEvent:
    """Event produced by the display subsystem (damage, mode change, hotplug)."""
    kind: u32
    surface_id: u32
    x: u32
    y: u32
    width: u32
    height: u32

# ============================================================================
# Helper constructors
# ============================================================================

fn display_mode(w: u32, h: u32, fmt: u32) -> DisplayMode:
    """Create a DisplayMode with a default 60 Hz refresh rate."""
    DisplayMode(width: w, height: h, format: fmt, refresh_hz: 60)

fn display_mode_with_refresh(w: u32, h: u32, fmt: u32, hz: u32) -> DisplayMode:
    """Create a DisplayMode with an explicit refresh rate."""
    DisplayMode(width: w, height: h, format: fmt, refresh_hz: hz)

fn damage_rect(x: u32, y: u32, w: u32, h: u32) -> DamageRect:
    """Create a damage rectangle at the given position and size."""
    DamageRect(x: x, y: y, width: w, height: h)

fn full_damage(mode: DisplayMode) -> DamageRect:
    """Create a damage rectangle covering the entire display mode."""
    DamageRect(x: 0, y: 0, width: mode.width, height: mode.height)

fn surface_desc(id: u32, w: u32, h: u32, fmt: u32, virt: u64, phys: u64, size: u64) -> SurfaceDesc:
    """Create a SurfaceDesc with the given parameters."""
    SurfaceDesc(id: id, width: w, height: h, format: fmt,
                buffer_virt: virt, buffer_phys: phys, buffer_size: size)

fn display_event(kind: u32, sid: u32, x: u32, y: u32, w: u32, h: u32) -> DisplayEvent:
    """Create a DisplayEvent."""
    DisplayEvent(kind: kind, surface_id: sid, x: x, y: y, width: w, height: h)

fn display_event_damage(sid: u32, rect: DamageRect) -> DisplayEvent:
    """Convenience: create a DISPLAY_EVENT_DAMAGE event from a DamageRect."""
    DisplayEvent(kind: DISPLAY_EVENT_DAMAGE, surface_id: sid,
                 x: rect.x, y: rect.y, width: rect.width, height: rect.height)
