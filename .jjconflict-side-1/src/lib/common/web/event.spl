"""
Web Event Backend Interface

Provides EventBackend trait, WebEvent, and WebEventType used by
web_ui's dom_backend and bridge to route input events to DOM listeners.
"""

# ============================================================================
# WebEventType
# ============================================================================

enum WebEventType:
    """DOM event type discriminant for listener registration."""
    Click
    DblClick
    MouseDown
    MouseUp
    MouseMove
    MouseEnter
    MouseLeave
    KeyDown
    KeyUp
    KeyPress
    Input
    Change
    Submit
    Focus
    Blur
    Scroll
    Resize
    Load
    Unload
    Custom

fn event_type_from_text(name: text) -> WebEventType:
    """Parse an event type name string into WebEventType."""
    if name == "click": return WebEventType.Click
    if name == "dblclick": return WebEventType.DblClick
    if name == "mousedown": return WebEventType.MouseDown
    if name == "mouseup": return WebEventType.MouseUp
    if name == "mousemove": return WebEventType.MouseMove
    if name == "mouseenter": return WebEventType.MouseEnter
    if name == "mouseleave": return WebEventType.MouseLeave
    if name == "keydown": return WebEventType.KeyDown
    if name == "keyup": return WebEventType.KeyUp
    if name == "keypress": return WebEventType.KeyPress
    if name == "input": return WebEventType.Input
    if name == "change": return WebEventType.Change
    if name == "submit": return WebEventType.Submit
    if name == "focus": return WebEventType.Focus
    if name == "blur": return WebEventType.Blur
    if name == "scroll": return WebEventType.Scroll
    if name == "resize": return WebEventType.Resize
    if name == "load": return WebEventType.Load
    if name == "unload": return WebEventType.Unload
    WebEventType.Custom

# ============================================================================
# WebEvent
# ============================================================================

class WebEvent:
    """A browser event dispatched to a registered listener."""
    event_type: WebEventType
    target_id: i64
    # Pointer position (for mouse events)
    client_x: f64
    client_y: f64
    button: i64
    # Keyboard data
    key: text
    key_code: i64
    modifiers: i64   # 0x01=Shift, 0x02=Ctrl, 0x04=Alt, 0x08=Meta
    # Input value (for input/change events)
    value: text
    default_prevented: bool

impl WebEvent:
    static fn mouse(event_type: WebEventType, target_id: i64,
                    x: f64, y: f64, button: i64) -> WebEvent:
        """Construct a mouse event."""
        WebEvent(
            event_type: event_type,
            target_id: target_id,
            client_x: x,
            client_y: y,
            button: button,
            key: "",
            key_code: 0,
            modifiers: 0,
            value: "",
            default_prevented: false
        )

    static fn keyboard(event_type: WebEventType, target_id: i64,
                       key: text, key_code: i64, modifiers: i64) -> WebEvent:
        """Construct a keyboard event."""
        WebEvent(
            event_type: event_type,
            target_id: target_id,
            client_x: 0.0,
            client_y: 0.0,
            button: 0,
            key: key,
            key_code: key_code,
            modifiers: modifiers,
            value: "",
            default_prevented: false
        )

    fn prevent_default():
        self.default_prevented = true

# ============================================================================
# EventBackend trait
# ============================================================================

trait EventBackend:
    """Abstract interface for event dispatch registration."""
    fn add_event_listener(element_id: i64, event_type: WebEventType,
                          handler: fn(WebEvent))
    fn remove_event_listener(element_id: i64, event_type: WebEventType)
    fn dispatch_event(event: WebEvent)
