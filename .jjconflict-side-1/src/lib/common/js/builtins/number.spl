#![allow(unnamed_duplicate_typed_args)]
# Number and Math built-ins for the JS engine.
# Implements Number.* and Math.* methods.

val MATH_PI: f64 = 3.141592653589793
val MATH_E: f64 = 2.718281828459045
val MATH_LN2: f64 = 0.6931471805599453
val MATH_LN10: f64 = 2.302585092994046
val MATH_SQRT2: f64 = 1.4142135623730951
val NUMBER_MAX_SAFE_INTEGER: f64 = 9007199254740991.0
val NUMBER_MIN_SAFE_INTEGER: f64 = -9007199254740991.0
val NAN_MARKER: f64 = 0.0  # Placeholder — real NaN needs runtime support

# --- Number methods ---

fn number_isNaN(value: f64) -> bool:
    # NaN is the only value not equal to itself
    value != value

fn number_isFinite(value: f64) -> bool:
    val is_nan = number_isNaN(value)
    if is_nan:
        return false
    # Check for infinity by comparison with max bounds
    val abs_val = math_abs(value)
    abs_val < 1.7976931348623157e308

fn number_isInteger(value: f64) -> bool:
    if number_isNaN(value):
        return false
    if not number_isFinite(value):
        return false
    val truncated = math_trunc(value)
    value == truncated

fn number_parseInt(s: text, radix: i64) -> f64:
    if radix == 10 or radix == 0:
        # Simple decimal parsing
        var result: f64 = 0.0
        var i = 0
        val len = s.len()
        var negative = false
        if len > 0:
            val first = s[0:1]
            if first == "-":
                negative = true
                i = 1
            else if first == "+":
                i = 1
        var found_digit = false
        while i < len:
            val ch = s[i:i + 1]
            val digit = _char_to_digit(ch)
            if digit < 0 or digit >= 10:
                break
            found_digit = true
            result = result * 10.0 + digit.to_f64()
            i = i + 1
        if not found_digit:
            return NAN_MARKER
        if negative:
            return 0.0 - result
        result
    else:
        # Non-decimal radix parsing
        var result: f64 = 0.0
        var i = 0
        val len = s.len()
        var negative = false
        if len > 0:
            val first = s[0:1]
            if first == "-":
                negative = true
                i = 1
            else if first == "+":
                i = 1
        # Skip 0x prefix for hex
        if radix == 16 and i + 1 < len:
            val prefix = s[i:i + 2]
            if prefix == "0x" or prefix == "0X":
                i = i + 2
        var found_digit = false
        while i < len:
            val ch = s[i:i + 1]
            val digit = _char_to_digit_radix(ch, radix)
            if digit < 0:
                break
            found_digit = true
            result = result * radix.to_f64() + digit.to_f64()
            i = i + 1
        if not found_digit:
            return NAN_MARKER
        if negative:
            return 0.0 - result
        result

fn number_parseFloat(s: text) -> f64:
    # Simplified: delegate to parseInt for integer portion, then handle decimal
    var result: f64 = 0.0
    var i = 0
    val len = s.len()
    var negative = false
    # Skip leading whitespace
    while i < len:
        val ch = s[i:i + 1]
        if ch != " " and ch != "\t" and ch != "\n":
            break
        i = i + 1
    if i < len:
        val first = s[i:i + 1]
        if first == "-":
            negative = true
            i = i + 1
        else if first == "+":
            i = i + 1
    # Integer part
    var found_digit = false
    while i < len:
        val ch = s[i:i + 1]
        val digit = _char_to_digit(ch)
        if digit < 0:
            break
        found_digit = true
        result = result * 10.0 + digit.to_f64()
        i = i + 1
    # Fractional part
    if i < len:
        val dot = s[i:i + 1]
        if dot == ".":
            i = i + 1
            var frac: f64 = 0.0
            var frac_div: f64 = 10.0
            while i < len:
                val ch = s[i:i + 1]
                val digit = _char_to_digit(ch)
                if digit < 0:
                    break
                found_digit = true
                frac = frac + digit.to_f64() / frac_div
                frac_div = frac_div * 10.0
                i = i + 1
            result = result + frac
    if not found_digit:
        return NAN_MARKER
    if negative:
        return 0.0 - result
    result

fn number_toFixed(value: f64, digits: i64) -> text:
    # Simple fixed-point representation
    if digits <= 0:
        val rounded = math_round(value)
        return "{rounded.to_i64()}"
    val multiplier = math_pow(10.0, digits.to_f64())
    val rounded = math_round(value * multiplier)
    val int_part = (rounded / multiplier).to_i64()
    val frac_part_raw = math_abs(rounded - int_part.to_f64() * multiplier)
    var frac_str = "{frac_part_raw.to_i64()}"
    # Pad with leading zeros
    while frac_str.len() < digits:
        frac_str = "0" + frac_str
    "{int_part}.{frac_str}"

fn number_toPrecision(value: f64, precision: i64) -> text:
    # Format number with specified total significant digits
    if precision <= 0:
        return "{value}"
    # Use toFixed with adjusted digits after decimal point
    val abs_val = math_abs(value)
    if abs_val == 0.0:
        var result = "0"
        if precision > 1:
            result = result + "."
            var p = 1
            while p < precision:
                result = result + "0"
                p = p + 1
        return result
    # Count digits before decimal point
    var int_digits = 0
    var temp = abs_val
    if temp >= 1.0:
        while temp >= 1.0:
            temp = temp / 10.0
            int_digits = int_digits + 1
    else:
        int_digits = 1
    val frac_digits = precision - int_digits
    if frac_digits < 0:
        # More integer digits than precision — round
        val divisor = math_pow(10.0, (int_digits - precision).to_f64())
        val rounded = math_round(value / divisor) * divisor
        return "{rounded.to_i64()}"
    number_toFixed(value, frac_digits)

fn number_toExponential(value: f64, digits: i64) -> text:
    # Format number in exponential notation
    var v = value
    var negative = false
    if v < 0.0:
        negative = true
        v = 0.0 - v
    if v == 0.0:
        var result = "0"
        if digits > 0:
            result = result + "."
            var d = 0
            while d < digits:
                result = result + "0"
                d = d + 1
        result = result + "e+0"
        if negative:
            result = "-" + result
        return result
    # Find exponent
    var exp_val = 0
    var mantissa = v
    if mantissa >= 10.0:
        while mantissa >= 10.0:
            mantissa = mantissa / 10.0
            exp_val = exp_val + 1
    else if mantissa < 1.0:
        while mantissa < 1.0:
            mantissa = mantissa * 10.0
            exp_val = exp_val - 1
    val mantissa_str = number_toFixed(mantissa, digits)
    var exp_sign = "+"
    var exp_abs = exp_val
    if exp_val < 0:
        exp_sign = "-"
        exp_abs = 0 - exp_val
    var result = mantissa_str + "e" + exp_sign + "{exp_abs}"
    if negative:
        result = "-" + result
    result

fn number_toString(value: f64, radix: i64) -> text:
    if radix == 10 or radix == 0:
        return "{value}"
    # Integer conversion to other radix
    val int_val = value.to_i64()
    var n = int_val
    var negative = false
    if n < 0:
        negative = true
        n = 0 - n
    if n == 0:
        return "0"
    var result = ""
    while n > 0:
        val remainder = n % radix
        result = _digit_to_char(remainder) + result
        n = n / radix
    if negative:
        result = "-" + result
    result

# --- Math methods ---

fn math_abs(x: f64) -> f64:
    if x < 0.0:
        return 0.0 - x
    x

fn math_floor(x: f64) -> f64:
    val i = x.to_i64()
    val f = i.to_f64()
    if f > x:
        return (i - 1).to_f64()
    f

fn math_ceil(x: f64) -> f64:
    val i = x.to_i64()
    val f = i.to_f64()
    if f < x:
        return (i + 1).to_f64()
    f

fn math_round(x: f64) -> f64:
    math_floor(x + 0.5)

fn math_max(a: f64, b: f64) -> f64:
    if a >= b: a else: b

fn math_min(a: f64, b: f64) -> f64:
    if a <= b: a else: b

fn math_pow(base: f64, exp: f64) -> f64:
    # Integer exponent fast path
    if number_isInteger(exp) and exp >= 0.0:
        var result: f64 = 1.0
        var e = exp.to_i64()
        var b = base
        while e > 0:
            if e % 2 == 1:
                result = result * b
            b = b * b
            e = e / 2
        return result
    # Negative integer exponent
    if number_isInteger(exp) and exp < 0.0:
        val pos_result = math_pow(base, 0.0 - exp)
        return 1.0 / pos_result
    # Non-integer exponents: use exp(exp * ln(base)) approximation
    # For now, use repeated sqrt decomposition for common cases
    if base <= 0.0:
        return NAN_MARKER
    # Approximate: base^exp = e^(exp * ln(base))
    val ln_base = math_log(base)
    val product = exp * ln_base
    _math_exp(product)

fn math_sqrt(x: f64) -> f64:
    if x < 0.0:
        return NAN_MARKER
    if x == 0.0:
        return 0.0
    # Newton's method
    var guess = x / 2.0
    var i = 0
    while i < 50:
        val next = (guess + x / guess) / 2.0
        val diff = math_abs(next - guess)
        if diff < 0.0000000001:
            return next
        guess = next
        i = i + 1
    guess

fn math_random() -> f64:
    # Simple linear congruential generator (LCG) PRNG
    # Uses module-level state via a counter workaround since closures can't mutate outer vars.
    # Returns a pseudo-random number in [0, 1). Deterministic seed.
    # In a real implementation, seed from runtime clock.
    0.5  # Stub: returns fixed value; real PRNG needs mutable module state or FFI

fn math_sign(x: f64) -> f64:
    if x > 0.0:
        return 1.0
    if x < 0.0:
        return -1.0
    0.0

fn math_trunc(x: f64) -> f64:
    val i = x.to_i64()
    i.to_f64()

fn math_log(x: f64) -> f64:
    # Natural logarithm using Taylor series around 1: ln(x) for x > 0
    # Uses the identity: ln(x) = 2 * atanh((x-1)/(x+1)) for faster convergence
    if x <= 0.0:
        return NAN_MARKER
    if x == 1.0:
        return 0.0
    # Reduce to range [1, 2) by extracting exponent
    var reduced = x
    var exp_count = 0
    while reduced >= 2.0:
        reduced = reduced / 2.0
        exp_count = exp_count + 1
    while reduced < 1.0:
        reduced = reduced * 2.0
        exp_count = exp_count - 1
    # Now reduced is in [1, 2). Use series: ln(reduced) = 2 * sum((t^(2k+1))/(2k+1))
    # where t = (reduced - 1) / (reduced + 1)
    val t = (reduced - 1.0) / (reduced + 1.0)
    val t2 = t * t
    var term = t
    var result = t
    var k = 1
    while k < 30:
        term = term * t2
        result = result + term / (2.0 * k.to_f64() + 1.0)
        k = k + 1
    result = 2.0 * result
    # Add back the exponent: ln(x) = ln(reduced) + exp_count * ln(2)
    result + exp_count.to_f64() * MATH_LN2

# --- Math.exp helper ---

fn _math_exp(x: f64) -> f64:
    # e^x using Taylor series: sum(x^k / k!) for k = 0..n
    if x == 0.0:
        return 1.0
    var result = 1.0
    var term = 1.0
    var k = 1
    while k < 40:
        term = term * x / k.to_f64()
        result = result + term
        if math_abs(term) < 0.0000000000001:
            break
        k = k + 1
    result

fn math_clamp(x: f64, min_val: f64, max_val: f64) -> f64:
    if x < min_val:
        return min_val
    if x > max_val:
        return max_val
    x

fn math_hypot(a: f64, b: f64) -> f64:
    math_sqrt(a * a + b * b)

# --- Internal helpers ---

fn _char_to_digit(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    -1

fn _char_to_digit_radix(ch: text, radix: i64) -> i64:
    val d = _char_to_digit(ch)
    if d >= 0 and d < radix:
        return d
    # Hex letters
    val lower = ch.to_lower()
    if lower == "a" and radix > 10: return 10
    if lower == "b" and radix > 11: return 11
    if lower == "c" and radix > 12: return 12
    if lower == "d" and radix > 13: return 13
    if lower == "e" and radix > 14: return 14
    if lower == "f" and radix > 15: return 15
    -1

fn _digit_to_char(d: i64) -> text:
    if d == 0: return "0"
    if d == 1: return "1"
    if d == 2: return "2"
    if d == 3: return "3"
    if d == 4: return "4"
    if d == 5: return "5"
    if d == 6: return "6"
    if d == 7: return "7"
    if d == 8: return "8"
    if d == 9: return "9"
    if d == 10: return "a"
    if d == 11: return "b"
    if d == 12: return "c"
    if d == 13: return "d"
    if d == 14: return "e"
    if d == 15: return "f"
    "?"
