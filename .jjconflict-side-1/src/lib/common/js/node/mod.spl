# Node.js-compatible runtime modules for the JS engine
# Each module provides a JsValue.Object with standard Node.js API methods.

use std.js.node.fs_module.{create_fs_module}
use std.js.node.path_module.{create_path_module}
use std.js.node.process_module.{create_process_module}
use std.js.node.http_module.{create_http_module}
use std.js.node.child_process_module.{create_child_process_module}
use std.js.node.crypto_module.{create_crypto_module}
use std.js.node.os_module.{create_os_module}
