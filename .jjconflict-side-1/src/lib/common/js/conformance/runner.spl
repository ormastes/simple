# ECMAScript Conformance Test Runner
# Executes JS source snippets and compares results to expected values.

use std.js.engine.js_error.{Logger, LogLevel}
use std.js.engine.parser.{JsParser}
use std.js.engine.interpreter.{JsInterpreter}
use std.js.types.js_types.{JsValue}

class TestResult:
    name: text
    passed: bool
    expected: text
    actual: text
    category: text

class ConformanceRunner:
    pass_count: i64
    fail_count: i64
    results: [TestResult]
    logger: Logger

    static fn new() -> ConformanceRunner:
        ConformanceRunner(
            pass_count: 0,
            fail_count: 0,
            results: [],
            logger: Logger.new("conformance", LogLevel.Error)
        )

    me check(name: text, code: text, expected: text, category: text) -> bool:
        """Run JS code, compare result to expected string."""
        val actual = _eval_js(code, self.logger)
        # Normalize float display
        var norm_actual = actual
        if norm_actual.ends_with(".0"):
            var trimmed = ""
            var i = 0
            while i < norm_actual.len() - 2:
                trimmed = trimmed + norm_actual[i]
                i = i + 1
            norm_actual = trimmed
        val passed = norm_actual == expected
        val result = TestResult(
            name: name, passed: passed,
            expected: expected, actual: norm_actual,
            category: category
        )
        self.results.push(result)
        if passed:
            self.pass_count = self.pass_count + 1
        else:
            self.fail_count = self.fail_count + 1
        passed

    fn total() -> i64:
        self.pass_count + self.fail_count

    fn pass_rate() -> text:
        val total = self.total()
        if total == 0:
            return "0.0"
        val pct = (self.pass_count * 1000 / total) / 10
        "{pct}"

fn _eval_js(source: text, logger: Logger) -> text:
    """Parse and execute JS, return string result."""
    val parser = JsParser.new(source, logger)
    val program = parser.parse_program()
    match program:
        Ok(stmts):
            val interp = JsInterpreter.new(logger)
            val result = interp.execute(stmts)
            match result:
                Ok(value):
                    return _display(value)
                Err(e):
                    return "Error: {e.message}"
        Err(e):
            return "SyntaxError: {e.message}"

fn _display(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n): "{n}"
        JsValue.String(s): s
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"
