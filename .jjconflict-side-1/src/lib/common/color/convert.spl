# Source-backed color conversion helpers for browser/style/raster tests.

use std.common.color.types.{Color, from_rgb, from_rgba, black}

pub fn abs(value: i64) -> i64:
    if value < 0:
        return 0 - value
    value

pub fn max3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b > m:
        m = b
    if c > m:
        m = c
    m

pub fn min3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b < m:
        m = b
    if c < m:
        m = c
    m

fn _normalize_hex(value: text) -> text:
    if value.len() > 0 and value[0:1] == "#":
        return value[1:value.len()]
    value

pub fn hex_char_to_int(ch: text) -> i64:
    val c = ch.to_upper()
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    if c == "A": return 10
    if c == "B": return 11
    if c == "C": return 12
    if c == "D": return 13
    if c == "E": return 14
    if c == "F": return 15
    0

pub fn hex_to_int(hex: text) -> i64:
    var value = 0
    var i = 0
    while i < hex.len():
        value = value * 16 + hex_char_to_int(hex[i:i + 1])
        i = i + 1
    value

pub fn int_to_hex_char(value: i64) -> text:
    if value == 0: return "0"
    if value == 1: return "1"
    if value == 2: return "2"
    if value == 3: return "3"
    if value == 4: return "4"
    if value == 5: return "5"
    if value == 6: return "6"
    if value == 7: return "7"
    if value == 8: return "8"
    if value == 9: return "9"
    if value == 10: return "A"
    if value == 11: return "B"
    if value == 12: return "C"
    if value == 13: return "D"
    if value == 14: return "E"
    if value == 15: return "F"
    "0"

fn _clamp_percent(value: i64) -> i64:
    if value < 0:
        return 0
    if value > 100:
        return 100
    value

fn _normalize_hue(h: i64) -> i64:
    var hue = h % 360
    if hue < 0:
        hue = hue + 360
    hue

fn _round_byte(value: f64) -> i64:
    from_rgb(value.to_i64(), 0, 0).r

fn _round_percent(value: f64) -> i64:
    _clamp_percent(value.to_i64())

fn _fmax(a: f64, b: f64) -> f64:
    if a > b:
        return a
    b

fn _fmin(a: f64, b: f64) -> f64:
    if a < b:
        return a
    b

fn _hue_to_rgb(p: f64, q: f64, t_in: f64) -> f64:
    var t = t_in
    if t < 0.0:
        t = t + 1.0
    if t > 1.0:
        t = t - 1.0
    if t < 1.0 / 6.0:
        return p + (q - p) * 6.0 * t
    if t < 1.0 / 2.0:
        return q
    if t < 2.0 / 3.0:
        return p + (q - p) * (2.0 / 3.0 - t) * 6.0
    p

pub fn int_to_hex(value: i64) -> text:
    val hi = (value / 16) % 16
    val lo = value % 16
    int_to_hex_char(hi) + int_to_hex_char(lo)

fn _hex_pair(hex: text, offset: i64) -> i64:
    hex_to_int(hex[offset:offset + 2])

fn _hex_nibble_pair(hex: text, offset: i64) -> i64:
    val v = hex_char_to_int(hex[offset:offset + 1])
    v * 16 + v

pub fn from_hex(value: text) -> Color:
    val hex = _normalize_hex(value)
    if hex.len() == 3:
        return from_rgb(_hex_nibble_pair(hex, 0), _hex_nibble_pair(hex, 1), _hex_nibble_pair(hex, 2))
    if hex.len() == 4:
        return from_rgba(_hex_nibble_pair(hex, 0), _hex_nibble_pair(hex, 1), _hex_nibble_pair(hex, 2), _hex_nibble_pair(hex, 3))
    if hex.len() == 6:
        return from_rgb(_hex_pair(hex, 0), _hex_pair(hex, 2), _hex_pair(hex, 4))
    if hex.len() == 8:
        return from_rgba(_hex_pair(hex, 0), _hex_pair(hex, 2), _hex_pair(hex, 4), _hex_pair(hex, 6))
    black()

pub fn from_name(name: text) -> Color:
    val n = name.to_lower()
    if n == "black": return from_rgb(0, 0, 0)
    if n == "white": return from_rgb(255, 255, 255)
    if n == "red": return from_rgb(255, 0, 0)
    if n == "green": return from_rgb(0, 128, 0)
    if n == "blue": return from_rgb(0, 0, 255)
    if n == "yellow": return from_rgb(255, 255, 0)
    if n == "cyan": return from_rgb(0, 255, 255)
    if n == "magenta": return from_rgb(255, 0, 255)
    if n == "orange": return from_rgb(255, 165, 0)
    if n == "purple": return from_rgb(128, 0, 128)
    if n == "pink": return from_rgb(255, 192, 203)
    if n == "brown": return from_rgb(165, 42, 42)
    if n == "gray": return from_rgb(128, 128, 128)
    if n == "grey": return from_rgb(128, 128, 128)
    if n == "lime": return from_rgb(0, 255, 0)
    if n == "navy": return from_rgb(0, 0, 128)
    if n == "teal": return from_rgb(0, 128, 128)
    if n == "olive": return from_rgb(128, 128, 0)
    if n == "maroon": return from_rgb(128, 0, 0)
    if n == "silver": return from_rgb(192, 192, 192)
    if n == "gold": return from_rgb(255, 215, 0)
    if n == "indigo": return from_rgb(75, 0, 130)
    if n == "violet": return from_rgb(238, 130, 238)
    if n == "turquoise": return from_rgb(64, 224, 208)
    if n == "coral": return from_rgb(255, 127, 80)
    if n == "salmon": return from_rgb(250, 128, 114)
    if n == "crimson": return from_rgb(220, 20, 60)
    if n == "tan": return from_rgb(210, 180, 140)
    if n == "khaki": return from_rgb(240, 230, 140)
    if n == "lavender": return from_rgb(230, 230, 250)
    black()

pub fn to_hex(color: Color) -> text:
    "#" + int_to_hex(color.r) + int_to_hex(color.g) + int_to_hex(color.b)

pub fn to_hex_alpha(color: Color) -> text:
    to_hex(color) + int_to_hex(color.a)

pub fn to_css(color: Color) -> text:
    if color.a >= 255:
        return "rgb({color.r}, {color.g}, {color.b})"
    "rgba({color.r}, {color.g}, {color.b}, {color.a})"

pub fn rgb_to_hsl(color: Color):
    val r = color.r.to_f64() / 255.0
    val g = color.g.to_f64() / 255.0
    val b = color.b.to_f64() / 255.0
    val max_v = _fmax(r, _fmax(g, b))
    val min_v = _fmin(r, _fmin(g, b))
    val delta = max_v - min_v
    val light = (max_v + min_v) / 2.0
    if delta == 0.0:
        return (0, 0, _round_percent(light * 100.0))
    var hue = 0.0
    if max_v == r:
        hue = (g - b) / delta
        if g < b:
            hue = hue + 6.0
    else if max_v == g:
        hue = (b - r) / delta + 2.0
    else:
        hue = (r - g) / delta + 4.0
    hue = hue * 60.0
    var sat = 0.0
    if light < 0.5:
        sat = delta / (max_v + min_v)
    else:
        sat = delta / (2.0 - max_v - min_v)
    (_normalize_hue(hue.to_i64()), _round_percent(sat * 100.0), _round_percent(light * 100.0))

pub fn hsl_to_rgb(h: i64, s: i64, l: i64) -> Color:
    val hue = _normalize_hue(h).to_f64() / 360.0
    val sat = _clamp_percent(s).to_f64() / 100.0
    val light = _clamp_percent(l).to_f64() / 100.0
    if sat == 0.0:
        val gray = _round_byte(light * 255.0)
        return from_rgb(gray, gray, gray)
    var q = 0.0
    if light < 0.5:
        q = light * (1.0 + sat)
    else:
        q = light + sat - light * sat
    val p = 2.0 * light - q
    val r = _hue_to_rgb(p, q, hue + 1.0 / 3.0)
    val g = _hue_to_rgb(p, q, hue)
    val b = _hue_to_rgb(p, q, hue - 1.0 / 3.0)
    from_rgb(_round_byte(r * 255.0), _round_byte(g * 255.0), _round_byte(b * 255.0))

pub fn from_hsl(h: i64, s: i64, l: i64) -> Color:
    hsl_to_rgb(h, s, l)

pub fn rgb_to_hsv(color: Color):
    val r = color.r.to_f64() / 255.0
    val g = color.g.to_f64() / 255.0
    val b = color.b.to_f64() / 255.0
    val max_v = _fmax(r, _fmax(g, b))
    val min_v = _fmin(r, _fmin(g, b))
    val delta = max_v - min_v
    if max_v == 0.0:
        return (0, 0, 0)
    if delta == 0.0:
        return (0, 0, _round_percent(max_v * 100.0))
    var hue = 0.0
    if max_v == r:
        hue = (g - b) / delta
        if g < b:
            hue = hue + 6.0
    else if max_v == g:
        hue = (b - r) / delta + 2.0
    else:
        hue = (r - g) / delta + 4.0
    hue = hue * 60.0
    val sat = delta / max_v
    (_normalize_hue(hue.to_i64()), _round_percent(sat * 100.0), _round_percent(max_v * 100.0))

pub fn hsv_to_rgb(h: i64, s: i64, v: i64) -> Color:
    val hue = _normalize_hue(h)
    val sat = _clamp_percent(s).to_f64() / 100.0
    val value = _clamp_percent(v).to_f64() / 100.0
    if sat == 0.0:
        val gray = _round_byte(value * 255.0)
        return from_rgb(gray, gray, gray)
    val sector = hue / 60
    val f = (hue % 60).to_f64() / 60.0
    val p = value * (1.0 - sat)
    val q = value * (1.0 - sat * f)
    val t = value * (1.0 - sat * (1.0 - f))
    if sector == 0:
        return from_rgb(_round_byte(value * 255.0), _round_byte(t * 255.0), _round_byte(p * 255.0))
    if sector == 1:
        return from_rgb(_round_byte(q * 255.0), _round_byte(value * 255.0), _round_byte(p * 255.0))
    if sector == 2:
        return from_rgb(_round_byte(p * 255.0), _round_byte(value * 255.0), _round_byte(t * 255.0))
    if sector == 3:
        return from_rgb(_round_byte(p * 255.0), _round_byte(q * 255.0), _round_byte(value * 255.0))
    if sector == 4:
        return from_rgb(_round_byte(t * 255.0), _round_byte(p * 255.0), _round_byte(value * 255.0))
    from_rgb(_round_byte(value * 255.0), _round_byte(p * 255.0), _round_byte(q * 255.0))

pub fn from_hsv(h: i64, s: i64, v: i64) -> Color:
    hsv_to_rgb(h, s, v)
