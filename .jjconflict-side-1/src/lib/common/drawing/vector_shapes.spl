# Vector Shape Model + SVG Renderer (LibreOffice Draw)
#
# A vector-graphics model for the Draw component. The existing `vector.spl`
# Skia primitives (SkPoint/SkRect) are f64 and hit the f64 toolchain bug
# (doc/08_tracking/bug/interp_f64_nested_struct_payload_zero_2026-06-14.md), so
# this model uses INTEGER coordinates, which the toolchain handles reliably, and
# renders shapes to SVG — the natural "render like a real draw tool" output.

enum DrawShape:
    Rect(x: i32, y: i32, w: i32, h: i32, fill: text)
    Line(x1: i32, y1: i32, x2: i32, y2: i32, stroke: text)
    Circle(cx: i32, cy: i32, r: i32, fill: text)
    Label(x: i32, y: i32, content: text)

struct DrawCanvas:
    width: i32
    height: i32
    shapes: [DrawShape]

fn empty_canvas(width: i32, height: i32) -> DrawCanvas:
    """An empty draw canvas of the given pixel size."""
    DrawCanvas(width: width, height: height, shapes: [])

fn add_shape(canvas: DrawCanvas, shape: DrawShape) -> DrawCanvas:
    """Return a new canvas with one shape appended."""
    var shapes: [DrawShape] = []
    for s in canvas.shapes:
        shapes.push(s)
    shapes.push(shape)
    DrawCanvas(width: canvas.width, height: canvas.height, shapes: shapes)

fn canvas_shape_count(canvas: DrawCanvas) -> i32:
    """Number of shapes on the canvas."""
    canvas.shapes.len()

fn shape_to_svg(shape: DrawShape) -> text:
    """Render a single shape as an SVG element."""
    match shape:
        case Rect(x, y, w, h, fill):
            return "<rect x=\"{x}\" y=\"{y}\" width=\"{w}\" height=\"{h}\" fill=\"{fill}\"/>"
        case Line(x1, y1, x2, y2, stroke):
            return "<line x1=\"{x1}\" y1=\"{y1}\" x2=\"{x2}\" y2=\"{y2}\" stroke=\"{stroke}\"/>"
        case Circle(cx, cy, r, fill):
            return "<circle cx=\"{cx}\" cy=\"{cy}\" r=\"{r}\" fill=\"{fill}\"/>"
        case Label(x, y, content):
            return "<text x=\"{x}\" y=\"{y}\">{content}</text>"

fn canvas_to_svg(canvas: DrawCanvas) -> text:
    """Render the whole canvas as an SVG document."""
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{canvas.width}\" height=\"{canvas.height}\">"
    for s in canvas.shapes:
        out = "{out}{shape_to_svg(s)}"
    "{out}</svg>"
