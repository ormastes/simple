# Proton Runtime Subsystems — non-Wine Proton runtime evidence model.
#
# Provides: ProtonNonWineRuntimeEvidence,
#           proton_fixture_non_wine_runtime_evidence,
#           proton_non_wine_feature_evidence,
#           proton_non_wine_runtime_gate.

class ProtonNonWineRuntimeEvidence:
    pressure_vessel: bool
    container_rootfs: bool
    namespace_pid: bool
    namespace_fs: bool
    namespace_ipc: bool
    namespace_net: bool
    namespace_capability: bool
    runtime_version: text

    static fn new(runtime_version: text) -> ProtonNonWineRuntimeEvidence:
        ProtonNonWineRuntimeEvidence(
            pressure_vessel: false,
            container_rootfs: false,
            namespace_pid: false,
            namespace_fs: false,
            namespace_ipc: false,
            namespace_net: false,
            namespace_capability: false,
            runtime_version: runtime_version
        )

    static fn all_verified(runtime_version: text) -> ProtonNonWineRuntimeEvidence:
        ProtonNonWineRuntimeEvidence(
            pressure_vessel: true,
            container_rootfs: true,
            namespace_pid: true,
            namespace_fs: true,
            namespace_ipc: true,
            namespace_net: true,
            namespace_capability: true,
            runtime_version: runtime_version
        )

# Returns a fixture instance with all subsystems verified.
fn proton_fixture_non_wine_runtime_evidence() -> ProtonNonWineRuntimeEvidence:
    ProtonNonWineRuntimeEvidence.all_verified("proton-fixture-8.0")

# Returns a human-readable feature evidence string for planning.
fn proton_non_wine_feature_evidence(ev: ProtonNonWineRuntimeEvidence) -> text:
    var parts: [text] = []
    if ev.pressure_vessel:
        parts.push("pressure_vessel=verified")
    if ev.container_rootfs:
        parts.push("container_rootfs=verified")
    if ev.namespace_pid:
        parts.push("namespace_pid=verified")
    if ev.namespace_fs:
        parts.push("namespace_fs=verified")
    if ev.namespace_ipc:
        parts.push("namespace_ipc=verified")
    if ev.namespace_net:
        parts.push("namespace_net=verified")
    if ev.namespace_capability:
        parts.push("namespace_capability=verified")
    parts.join(" ")

# Gate check: returns "ready" if all required subsystems are verified.
fn proton_non_wine_runtime_gate(ev: ProtonNonWineRuntimeEvidence) -> text:
    if not ev.pressure_vessel:
        return "pressure_vessel_missing"
    if not ev.container_rootfs:
        return "container_rootfs_missing"
    "ready"
