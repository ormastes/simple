# EasyFix Rules - Lint Rules
#
# Lint-style rules for code quality checks:
#   L:print_in_test_spec         — Replace print() with expect() in test specs
#   L:unnamed_duplicate_typed_args — Add distinct param names for duplicate types
#   L:resource_leak              — Wrap resource in `with` block
#   L:spipe_missing_docstrings   — Add template docstring to describe/context
#   L:spipe_manual_assertions    — Replace manual if/fail with expect()

use std.common.tooling.easy_fix.types.{EasyFix, FixConfidence, Replacement}

struct DuplicateTypedArgSignature:
    name: text
    line_num: i64
    decl_paren_start: i64
    decl_paren_end: i64
    decl_column: i64
    arg_count: i64
    param_names: [text]
    new_params_text: text
    has_decl_rewrite: bool
    can_rewrite_calls: bool

# ============================================================================
# Rule 1: print_in_test_spec
# Detects print(...) calls in _spec.spl files and suggests expect().
# Confidence: Likely
# ============================================================================

fn check_print_in_test_spec(source: String, file: String) -> [EasyFix]:
    # Only applies to spec files
    if not file.ends_with("_spec.spl"):
        return []

    var fixes: [EasyFix] = []
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        if trimmed.starts_with("print(") or trimmed.starts_with("print "):
            val start = byte_offset + indent
            val end = byte_offset + line.len()

            var arg = ""
            if trimmed.starts_with("print("):
                val inner = trimmed.slice(6)
                if inner.ends_with(")"):
                    arg = inner.slice(0, inner.len() - 1)
                else:
                    arg = inner

            if arg.len() > 0:
                var fix = EasyFix.create(
                    id: "L:print_in_test_spec:{line_num}",
                    description: "replace print() with expect() in test spec",
                    confidence: FixConfidence.Likely
                )
                val spaces = " ".repeat(indent)
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: start,
                    end: end,
                    line: line_num,
                    column: indent + 1,
                    new_text: "{spaces}expect({arg}).to_be_truthy()"
                ))
                fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

# ============================================================================
# Rule 2: unnamed_duplicate_typed_args
# Detects fn signatures with duplicate types that lack distinct names.
# Confidence: Uncertain
# ============================================================================

fn check_unnamed_duplicate_typed_args(source: String, file: String) -> [EasyFix]:
    val signatures = _collect_duplicate_typed_arg_signatures(source)
    var fixes: [EasyFix] = []

    for sig in signatures:
        var replacements: [Replacement] = []

        if sig.has_decl_rewrite:
            replacements.push(Replacement.create(
                file: file,
                start: sig.decl_paren_start,
                end: sig.decl_paren_end,
                line: sig.line_num,
                column: sig.decl_column,
                new_text: sig.new_params_text
            ))

        if sig.can_rewrite_calls and _is_unique_call_target(signatures, sig):
            val call_replacements = _collect_call_replacements_for_signature(source, file, sig)
            for rep in call_replacements:
                replacements.push(rep)

        if not replacements.is_empty():
            val description = if sig.has_decl_rewrite:
                "add distinct parameter names for duplicate types"
            else:
                "rewrite positional duplicate-typed arguments as named calls"
            var fix = EasyFix.create(
                id: "L:unnamed_duplicate_typed_args:{sig.line_num}",
                description: description,
                confidence: FixConfidence.Uncertain
            )
            for rep in replacements:
                fix.add_replacement(rep)
            fixes.push(fix)

    fixes

fn _collect_duplicate_typed_arg_signatures(source: text) -> [DuplicateTypedArgSignature]:
    var signatures: [DuplicateTypedArgSignature] = []
    val lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0
    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()
        val sig = _parse_duplicate_typed_arg_signature(line_num, byte_offset, indent, trimmed)
        match sig:
            case Some(found):
                signatures.push(found)
            case nil:
                pass
        byte_offset = byte_offset + line.len() + 1
    signatures

fn _parse_duplicate_typed_arg_signature(line_num: i64, byte_offset: i64, indent: i64, trimmed: text) -> Option<DuplicateTypedArgSignature>:
    if not _is_fn_sig(trimmed):
        return nil
    if not trimmed.contains("("):
        return nil

    val paren_start = trimmed.find("(") ?? -1
    if paren_start < 0:
        return nil
    val paren_end = _find_matching_paren_on_line(trimmed, paren_start)
    if paren_end <= paren_start:
        return nil

    val name = _extract_sig_name(trimmed, paren_start)
    if name == "":
        return nil

    val params_str = trimmed.slice(paren_start + 1, paren_end)
    val params = _split_top_level_csv(params_str)
    if params.is_empty():
        return nil

    var raw_names: [text] = []
    var raw_types: [text] = []
    var normalized_types: [text] = []
    var has_unnamed = false

    for param in params:
        val trimmed_param = param.trim()
        if trimmed_param == "":
            continue
        val colon_pos = _find_top_level_colon(trimmed_param)
        if colon_pos >= 0:
            raw_names.push(trimmed_param.slice(0, colon_pos).trim())
            raw_types.push(trimmed_param.slice(colon_pos + 1).trim())
        else:
            raw_names.push("")
            raw_types.push(trimmed_param)
            has_unnamed = true
        normalized_types.push(raw_types[raw_types.len() - 1].trim())

    if raw_types.len() < 2:
        return nil

    var type_counts: Dict<text, i64> = {}
    var has_duplicate_types = false
    for ty in normalized_types:
        val count = type_counts[ty] ?? 0
        type_counts[ty] = count + 1
        if count + 1 >= 2:
            has_duplicate_types = true
    if not has_duplicate_types:
        return nil

    var resolved_names: [text] = []
    var rewritten_params: [text] = []
    var generated_counts: Dict<text, i64> = {}
    var i = 0
    while i < raw_types.len():
        val param_name = raw_names[i]
        val param_type = raw_types[i]
        var resolved_name = param_name
        if resolved_name == "":
            val key = normalized_types[i]
            val next_count = (generated_counts[key] ?? 0) + 1
            generated_counts[key] = next_count
            resolved_name = "{_type_name_to_identifier(param_type)}{next_count}"
        rewritten_params.push("{resolved_name}: {param_type}")
        resolved_names.push(resolved_name)
        i = i + 1

    var stable_names = true
    var seen_names: Dict<text, bool> = {}
    i = 0
    while i < resolved_names.len():
        if type_counts[normalized_types[i]] >= 2:
            val name_i = resolved_names[i]
            if name_i == "" or name_i == "_" or name_i.starts_with("_"):
                stable_names = false
            elif seen_names.has(name_i):
                stable_names = false
            else:
                seen_names[name_i] = true
        i = i + 1

    Some(DuplicateTypedArgSignature(
        name: name,
        line_num: line_num,
        decl_paren_start: byte_offset + indent + paren_start + 1,
        decl_paren_end: byte_offset + indent + paren_end,
        decl_column: paren_start + 2,
        arg_count: resolved_names.len(),
        param_names: resolved_names,
        new_params_text: rewritten_params.join(", "),
        has_decl_rewrite: has_unnamed,
        can_rewrite_calls: stable_names
    ))

fn _collect_call_replacements_for_signature(source: text, file: text, sig: DuplicateTypedArgSignature) -> [Replacement]:
    var replacements: [Replacement] = []
    val lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val line_replacements = _collect_line_call_replacements(line, file, sig, line_num, byte_offset)
        for rep in line_replacements:
            replacements.push(rep)
        byte_offset = byte_offset + line.len() + 1

    replacements

fn _collect_line_call_replacements(line: text, file: text, sig: DuplicateTypedArgSignature, line_num: i64, byte_offset: i64) -> [Replacement]:
    var replacements: [Replacement] = []
    var i = 0
    while i < line.len():
        if not _matches_identifier_at(line, i, sig.name):
            i = i + 1
            continue
        if _is_definition_context(line, i):
            i = i + sig.name.len()
            continue
        val open_paren = _find_call_open_paren(line, i + sig.name.len())
        if open_paren < 0:
            i = i + sig.name.len()
            continue
        val close_paren = _find_matching_paren_on_line(line, open_paren)
        if close_paren <= open_paren:
            i = i + sig.name.len()
            continue
        val args_str = line.slice(open_paren + 1, close_paren)
        val args = _split_top_level_csv(args_str)
        if args.len() != sig.arg_count or _args_have_named_entries(args):
            i = close_paren + 1
            continue
        var named_args: [text] = []
        var arg_index = 0
        while arg_index < args.len():
            named_args.push("{sig.param_names[arg_index]}: {args[arg_index].trim()}")
            arg_index = arg_index + 1
        replacements.push(Replacement.create(
            file: file,
            start: byte_offset + open_paren + 1,
            end: byte_offset + close_paren,
            line: line_num,
            column: open_paren + 2,
            new_text: named_args.join(", ")
        ))
        i = close_paren + 1
    replacements

fn _is_unique_call_target(signatures: [DuplicateTypedArgSignature], sig: DuplicateTypedArgSignature) -> bool:
    var matches = 0
    for candidate in signatures:
        if candidate.can_rewrite_calls and candidate.name == sig.name and candidate.arg_count == sig.arg_count:
            matches = matches + 1
    matches == 1

fn _extract_sig_name(trimmed: text, paren_start: i64) -> text:
    val before = trimmed.slice(0, paren_start).trim()
    val parts = before.split(" ")
    if parts.is_empty():
        return ""
    parts[parts.len() - 1].trim()

fn _split_top_level_csv(text: text) -> [text]:
    var parts: [text] = []
    var start = 0
    var i = 0
    var paren_depth = 0
    var bracket_depth = 0
    var brace_depth = 0
    var angle_depth = 0
    var in_string = false

    while i < text.len():
        val ch = text.slice(i, i + 1)
        if ch == "\"":
            in_string = not in_string
        elif not in_string:
            if ch == "(":
                paren_depth = paren_depth + 1
            elif ch == ")":
                paren_depth = paren_depth - 1
            elif ch == "[":
                bracket_depth = bracket_depth + 1
            elif ch == "]":
                bracket_depth = bracket_depth - 1
            elif ch == "{":
                brace_depth = brace_depth + 1
            elif ch == "}":
                brace_depth = brace_depth - 1
            elif ch == "<":
                angle_depth = angle_depth + 1
            elif ch == ">":
                angle_depth = angle_depth - 1
            elif ch == "," and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 and angle_depth == 0:
                parts.push(text.slice(start, i).trim())
                start = i + 1
        i = i + 1

    val tail = text.slice(start).trim()
    if tail != "":
        parts.push(tail)
    parts

fn _find_top_level_colon(text: text) -> i64:
    var i = 0
    var paren_depth = 0
    var bracket_depth = 0
    var brace_depth = 0
    var angle_depth = 0
    var in_string = false

    while i < text.len():
        val ch = text.slice(i, i + 1)
        if ch == "\"":
            in_string = not in_string
        elif not in_string:
            if ch == "(":
                paren_depth = paren_depth + 1
            elif ch == ")":
                paren_depth = paren_depth - 1
            elif ch == "[":
                bracket_depth = bracket_depth + 1
            elif ch == "]":
                bracket_depth = bracket_depth - 1
            elif ch == "{":
                brace_depth = brace_depth + 1
            elif ch == "}":
                brace_depth = brace_depth - 1
            elif ch == "<":
                angle_depth = angle_depth + 1
            elif ch == ">":
                angle_depth = angle_depth - 1
            elif ch == ":" and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 and angle_depth == 0:
                return i
        i = i + 1
    -1

fn _find_matching_paren_on_line(text: text, open_paren: i64) -> i64:
    var i = open_paren
    var depth = 0
    var in_string = false
    while i < text.len():
        val ch = text.slice(i, i + 1)
        if ch == "\"":
            in_string = not in_string
        elif not in_string:
            if ch == "(":
                depth = depth + 1
            elif ch == ")":
                depth = depth - 1
                if depth == 0:
                    return i
        i = i + 1
    -1

fn _type_name_to_identifier(text: text) -> text:
    var out = ""
    var prev_underscore = false
    var i = 0
    while i < text.len():
        val ch = text.slice(i, i + 1).lower()
        if _is_identifier_char(ch):
            out = out + ch
            prev_underscore = false
        elif not prev_underscore:
            out = out + "_"
            prev_underscore = true
        i = i + 1
    while out.starts_with("_"):
        out = out.slice(1)
    while out.ends_with("_"):
        out = out.slice(0, out.len() - 1)
    if out == "":
        return "arg"
    if _is_digit_char(out.slice(0, 1)):
        return "arg_{out}"
    out

fn _matches_identifier_at(line: text, start: i64, name: text) -> bool:
    if start < 0 or start + name.len() > line.len():
        return false
    if line.slice(start, start + name.len()) != name:
        return false
    if start > 0 and _is_identifier_char(line.slice(start - 1, start)):
        return false
    val end = start + name.len()
    if end < line.len() and _is_identifier_char(line.slice(end, end + 1)):
        return false
    true

fn _is_definition_context(line: text, token_start: i64) -> bool:
    val before = line.slice(0, token_start).trim()
    before.ends_with("fn") or before.ends_with("me")

fn _find_call_open_paren(line: text, start: i64) -> i64:
    var i = start
    while i < line.len():
        val ch = line.slice(i, i + 1)
        if ch == " " or ch == "\t":
            i = i + 1
            continue
        if ch == "(":
            return i
        return -1
    -1

fn _args_have_named_entries(args: [text]) -> bool:
    for arg in args:
        if _find_top_level_colon(arg.trim()) >= 0:
            return true
    false

fn _is_identifier_char(ch: text) -> bool:
    if ch == "_":
        return true
    (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or _is_digit_char(ch)

fn _is_digit_char(ch: text) -> bool:
    ch >= "0" and ch <= "9"

# ============================================================================
# Rule 3: resource_leak
# Detects open()/connect() calls not wrapped in `with` blocks.
# Confidence: Uncertain
# ============================================================================

fn check_resource_leak(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        # Detect val x = open(...) or val x = connect(...) not inside with
        val is_resource_open = trimmed.contains("= open(") or trimmed.contains("= connect(") or trimmed.contains("= File.open(")
        if is_resource_open and trimmed.starts_with("val ") and not trimmed.starts_with("with"):
            val eq_pos = trimmed.find("=")
            if eq_pos > 4:
                val var_name = trimmed.slice(4, eq_pos).trim()
                val expr = trimmed.slice(eq_pos + 1).trim()

                val start = byte_offset + indent
                val end = byte_offset + line.len()

                val spaces = " ".repeat(indent)
                val inner_spaces = " ".repeat(indent + 4)
                val new_text = "{spaces}with {var_name} = {expr}:\n{inner_spaces}# TODO: use {var_name} here"

                var fix = EasyFix.create(
                    id: "L:resource_leak:{line_num}",
                    description: "wrap resource in `with` block to ensure cleanup",
                    confidence: FixConfidence.Uncertain
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: start,
                    end: end,
                    line: line_num,
                    column: indent + 1,
                    new_text: new_text
                ))
                fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

# ============================================================================
# Rule 4: spipe_missing_docstrings
# Detects describe/context blocks without docstrings.
# Confidence: Safe
# ============================================================================

fn check_spipe_missing_docstrings(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []

    if not file.ends_with("_spec.spl"):
        return fixes

    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()

        val is_describe = trimmed.starts_with("describe ")
        val is_context = trimmed.starts_with("context ")

        if is_describe or is_context:
            val keyword = if is_describe: "describe" else: "context"

            # Extract the name string
            val kw_len = keyword.len()
            val after_kw_raw = trimmed.slice(kw_len)
            val after_kw = after_kw_raw.trim()
            var block_name = after_kw
            if after_kw.starts_with("\""):
                val after_kw_inner = after_kw.slice(1)
                val close_quote = after_kw_inner.find("\"") ?? -1
                if close_quote >= 0:
                    block_name = after_kw.slice(1, close_quote + 1)

            # Check if next non-empty line is a docstring (""")
            var next_idx = line_num  # 0-indexed for next line
            var has_docstring = false
            var check_offset = byte_offset + line.len() + 1

            if next_idx < lines.len():
                val next_line = lines[next_idx]
                val next_trimmed = next_line.trim()
                if next_trimmed.starts_with("\"\"\""):
                    has_docstring = true

            if not has_docstring:
                val indent = line.len() - trimmed.len()
                val insert_pos = byte_offset + line.len() + 1  # After newline
                val spaces = " ".repeat(indent + 4)
                val header = if is_describe: "##" else: "###"
                val scenario = if is_describe: "" else: "Scenario: "
                val docstring = "{spaces}\"\"\"\n{spaces}{header} {scenario}{block_name}\n{spaces}\n{spaces}Description of this {keyword} block.\n{spaces}\"\"\"\n"

                var fix = EasyFix.create(
                    id: "L:spipe_missing_docstrings:{line_num}",
                    description: "add template docstring to {keyword} block",
                    confidence: FixConfidence.Safe
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: insert_pos,
                    end: insert_pos,
                    line: line_num + 1,
                    column: 1,
                    new_text: docstring
                ))
                fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

# ============================================================================
# Rule 5: spipe_manual_assertions
# Detects `if condition: fail(...)` and suggests `expect(condition)`.
# Confidence: Likely
# ============================================================================

fn check_spipe_manual_assertions(source: String, file: String) -> [EasyFix]:
    if not file.ends_with("_spec.spl"):
        return []

    var fixes: [EasyFix] = []
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        if trimmed.starts_with("if ") and trimmed.contains("fail("):
            val colon_pos = trimmed.find(":") ?? -1
            if colon_pos > 3:
                val condition = trimmed.slice(3, colon_pos).trim()
                val after_colon = trimmed.slice(colon_pos + 1).trim()

                if after_colon.starts_with("fail("):
                    val start = byte_offset + indent
                    val end = byte_offset + line.len()
                    val spaces = " ".repeat(indent)
                    val expect_expr = if condition.starts_with("not "): "expect({condition.slice(4).trim()}).to_be_truthy()" else: "expect({condition}).to_be_falsy()"

                    var fix = EasyFix.create(
                        id: "L:spipe_manual_assertions:{line_num}",
                        description: "replace manual if/fail with expect()",
                        confidence: FixConfidence.Likely
                    )
                    fix.add_replacement(Replacement.create(
                        file: file,
                        start: start,
                        end: end,
                        line: line_num,
                        column: indent + 1,
                        new_text: "{spaces}{expect_expr}"
                    ))
                    fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

# ============================================================================
# Rule 12: stub_impl
# Detects function signatures followed by trivial body expressions.
# Confidence: Likely
# ============================================================================

# Trivial return values — text patterns for single-line bodies
fn _trivial_bodies() -> [text]:
    ["0", "\"\"", "false", "nil", "[]", "()", "true",
     "return 0", "return \"\"", "return false", "return nil",
     "return []", "return ()", "return true",
     "Ok(nil)", "Ok(0)", "return Ok(nil)", "return Ok(0)"]

fn check_stub_impl_text(source: text, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        # Pattern 1: Single-line fn with trivial body
        if _is_fn_sig(trimmed):
            val colon_body = _extract_inline_body(trimmed)
            if colon_body != "" and _is_trivial(colon_body) and _has_params(trimmed):
                var fix = EasyFix.create(
                    id: "L:stub_impl:{line_num}",
                    description: "function with params returns trivial '{colon_body}' — possible stub",
                    confidence: FixConfidence.Likely
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: byte_offset,
                    end: byte_offset + line.len(),
                    line: line_num,
                    column: 1,
                    new_text: line
                ))
                fixes.push(fix)

        # Pattern 2: Multi-line fn — header, then trivial body
        if _is_fn_sig_header(trimmed) and _has_params(trimmed):
            if line_num < lines.len():
                val next_line = lines[line_num]
                val next_trimmed = next_line.trim()
                val next_indent = next_line.len() - next_trimmed.len()
                if next_indent > indent and _is_trivial(next_trimmed):
                    var is_single = true
                    if line_num + 1 < lines.len():
                        val after_next = lines[line_num + 1]
                        val after_trimmed = after_next.trim()
                        val after_indent = after_next.len() - after_trimmed.len()
                        if after_trimmed != "" and after_indent > indent:
                            is_single = false
                    if is_single:
                        var fix = EasyFix.create(
                            id: "L:stub_impl:{line_num}",
                            description: "function with params returns trivial '{next_trimmed}' — possible stub",
                            confidence: FixConfidence.Likely
                        )
                        fix.add_replacement(Replacement.create(
                            file: file,
                            start: byte_offset,
                            end: byte_offset + line.len(),
                            line: line_num,
                            column: 1,
                            new_text: line
                        ))
                        fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

fn _is_fn_sig(trimmed: text) -> bool:
    trimmed.starts_with("fn ")
        or trimmed.starts_with("me ")
        or trimmed.starts_with("static fn ")
        or trimmed.starts_with("pub fn ")
        or trimmed.starts_with("pub me ")
        or trimmed.starts_with("pub static fn ")

fn _is_fn_sig_header(trimmed: text) -> bool:
    _is_fn_sig(trimmed) and trimmed.ends_with(":")

fn _has_params(trimmed: text) -> bool:
    if not trimmed.contains("(") or not trimmed.contains(")"):
        return false
    val paren_parts = trimmed.split("(")
    if paren_parts.len() < 2:
        return false
    val after_open = paren_parts[1]
    if not after_open.contains(")"):
        return false
    val close_parts = after_open.split(")")
    val inner = close_parts[0].trim()
    inner.len() > 0

fn _extract_inline_body(trimmed: text) -> text:
    if not trimmed.contains(")"):
        return ""
    val paren_parts = trimmed.split(")")
    if paren_parts.len() < 2:
        return ""
    val after = paren_parts[1]
    if not after.contains(":"):
        return ""
    val colon_parts = after.split(":")
    if colon_parts.len() < 2:
        return ""
    val body_raw = colon_parts[1]
    body_raw.trim()

fn _is_trivial(body: text) -> bool:
    if body.starts_with("pass_todo") or body.starts_with("pass_do_nothing") or body.starts_with("pass_dn"):
        return false
    for p in _trivial_bodies():
        if body == p:
            return true
    if body == "pass":
        return true
    false
