# JSON Serializer
#
# Serialize JSON values to text and reformat JSON text.
#
# Value model (see lib.json.types):
#   ("null", nil) | ("boolean", bool) | ("number", f64)
#   ("string", text) | ("array", [any]) | ("object", {text: any})

use lib.json.types.{json_get_type}
use lib.json.parser.{json_parse_with_error}

fn json_indent(level: i64, size: i64) -> text:
    """Build an indentation string of `level` steps, `size` spaces each."""
    if level <= 0:
        return ""
    var out = ""
    var i = 0
    val total = level * size
    while i < total:
        out = out + " "
        i = i + 1
    out

fn json_escape_string(s: text) -> text:
    """Escape special characters so `s` is safe inside a JSON string literal."""
    var out = s.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\t", "\\t")
    out = out.replace("\r", "\\r")
    out

fn _json_join(parts: [text], sep: text) -> text:
    var out = ""
    var i = 0
    while i < parts.len():
        if i > 0:
            out = out + sep
        out = out + parts[i]
        i = i + 1
    out

fn json_serialize(value: any) -> text:
    """Serialize a JSON value to compact text."""
    if value == nil:
        return "null"
    val t = json_get_type(value)
    if t == "null":
        return "null"
    if t == "boolean":
        if value.1:
            return "true"
        return "false"
    if t == "number":
        return "{value.1}"
    if t == "string":
        return "\"" + json_escape_string(value.1) + "\""
    if t == "array":
        return _json_serialize_array(value.1)
    if t == "object":
        return _json_serialize_object(value.1)
    "null"

fn _json_serialize_array(items: any) -> text:
    if items == nil:
        return "[]"
    var parts = []
    for item in items:
        parts.push(json_serialize(item))
    "[" + _json_join(parts, ",") + "]"

fn _json_serialize_object(pairs: any) -> text:
    if pairs == nil:
        return "{}"
    var parts = []
    for key in pairs.keys():
        parts.push("\"" + json_escape_string(key) + "\":" + json_serialize(pairs.get(key)))
    "{" + _json_join(parts, ",") + "}"

fn json_stringify(value: any) -> text:
    """Alias for `json_serialize`."""
    json_serialize(value)

fn json_format(value: any, level: i64, size: i64) -> text:
    """Serialize a JSON value with newline/indent formatting."""
    if value == nil:
        return "null"
    val t = json_get_type(value)
    if t == "array":
        return _json_format_array(value.1, level, size)
    if t == "object":
        return _json_format_object(value.1, level, size)
    json_serialize(value)

fn _json_format_array(items: any, level: i64, size: i64) -> text:
    if items == nil:
        return "[]"
    if items.len() == 0:
        return "[]"
    val inner = json_indent(level + 1, size)
    val close = json_indent(level, size)
    var parts = []
    for item in items:
        parts.push(inner + json_format(item, level + 1, size))
    "[\n" + _json_join(parts, ",\n") + "\n" + close + "]"

fn _json_format_object(pairs: any, level: i64, size: i64) -> text:
    if pairs == nil:
        return "{}"
    val keys = pairs.keys()
    if keys.len() == 0:
        return "{}"
    val inner = json_indent(level + 1, size)
    val close = json_indent(level, size)
    var parts = []
    for key in keys:
        parts.push(inner + "\"" + json_escape_string(key) + "\": " + json_format(pairs.get(key), level + 1, size))
    "{\n" + _json_join(parts, ",\n") + "\n" + close + "}"

fn json_pretty(value: any) -> text:
    """Serialize a JSON value with 2-space indentation."""
    json_format(value, 0, 2)

fn json_minify(src: text) -> text:
    """Reparse JSON text and re-serialize compactly; return input unchanged if invalid."""
    val parsed = json_parse_with_error(src)
    if parsed.1 != "":
        return src
    json_serialize(parsed.0)

fn json_beautify(src: text) -> text:
    """Reparse JSON text and pretty-print; return input unchanged if invalid."""
    val parsed = json_parse_with_error(src)
    if parsed.1 != "":
        return src
    json_pretty(parsed.0)
