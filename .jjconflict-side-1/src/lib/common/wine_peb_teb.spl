"""Bounded PEB/TEB initialization evidence for Wine NT startup probes."""

use common.wine_kernel32_critical_section.{WineKernel32CriticalSectionTable, wine_kernel32_execute_critical_section}
use common.wine_vm_adapter.{WineVmSpace, wine_vm_access_gate, wine_vm_read_bytes, wine_vm_write_bytes}

class WinePebTebInitEvidence:
    process_id: i64
    thread_id: i64
    peb_address: i64
    teb_address: i64
    image_base: i64
    stack_base: i64
    stack_limit: i64
    tls_vector_address: i64
    process_parameters_address: i64
    evidence: text

class WinePebTebInitResult:
    ok: bool
    state: text
    process_id: i64
    thread_id: i64
    peb_address: i64
    teb_address: i64
    image_base: i64
    stack_base: i64
    stack_limit: i64
    tls_vector_address: i64
    process_parameters_address: i64
    operations: text

class WinePebTebMemoryWriteResult:
    ok: bool
    state: text
    process_id: i64
    thread_id: i64
    write_count: i64
    operations: text

class WinePebTebLayoutWriteRecord:
    area: text
    field_name: text
    address: i64
    offset: i64
    width: i64
    value: i64

class WinePebTebLayoutWritePlan:
    ok: bool
    state: text
    process_id: i64
    thread_id: i64
    record_count: i64
    operations: text
    records: [WinePebTebLayoutWriteRecord]

class WinePebTebLayoutByteWrite:
    area: text
    field_name: text
    address: i64
    bytes: [u8]

class WinePebTebLayoutByteWriteResult:
    ok: bool
    state: text
    process_id: i64
    thread_id: i64
    write_count: i64
    byte_count: i64
    operations: text
    writes: [WinePebTebLayoutByteWrite]

class WinePebTebVmWriteResult:
    ok: bool
    state: text
    process_id: i64
    thread_id: i64
    write_count: i64
    byte_count: i64
    operations: text
    space: WineVmSpace

fn _init(process_id: i64, thread_id: i64, peb_address: i64, teb_address: i64, image_base: i64, stack_base: i64, stack_limit: i64, tls_vector_address: i64, process_parameters_address: i64, evidence: text) -> WinePebTebInitEvidence:
    WinePebTebInitEvidence(process_id: process_id, thread_id: thread_id, peb_address: peb_address, teb_address: teb_address, image_base: image_base, stack_base: stack_base, stack_limit: stack_limit, tls_vector_address: tls_vector_address, process_parameters_address: process_parameters_address, evidence: evidence)

fn _result(ok: bool, state: text, init: WinePebTebInitEvidence, operations: text) -> WinePebTebInitResult:
    WinePebTebInitResult(ok: ok, state: state, process_id: init.process_id, thread_id: init.thread_id, peb_address: init.peb_address, teb_address: init.teb_address, image_base: init.image_base, stack_base: init.stack_base, stack_limit: init.stack_limit, tls_vector_address: init.tls_vector_address, process_parameters_address: init.process_parameters_address, operations: operations)

fn _write_result(ok: bool, state: text, init: WinePebTebInitEvidence, write_count: i64, operations: text) -> WinePebTebMemoryWriteResult:
    WinePebTebMemoryWriteResult(ok: ok, state: state, process_id: init.process_id, thread_id: init.thread_id, write_count: write_count, operations: operations)

fn _layout_record(area: text, field_name: text, base: i64, offset: i64, width: i64, value: i64) -> WinePebTebLayoutWriteRecord:
    WinePebTebLayoutWriteRecord(area: area, field_name: field_name, address: base + offset, offset: offset, width: width, value: value)

fn _layout_plan(ok: bool, state: text, init: WinePebTebInitEvidence, operations: text, records: [WinePebTebLayoutWriteRecord]) -> WinePebTebLayoutWritePlan:
    WinePebTebLayoutWritePlan(ok: ok, state: state, process_id: init.process_id, thread_id: init.thread_id, record_count: records.len(), operations: operations, records: records)

fn _layout_byte_result(ok: bool, state: text, plan: WinePebTebLayoutWritePlan, operations: text, writes: [WinePebTebLayoutByteWrite]) -> WinePebTebLayoutByteWriteResult:
    var byte_count = 0
    for write in writes:
        byte_count = byte_count + write.bytes.len()
    WinePebTebLayoutByteWriteResult(ok: ok, state: state, process_id: plan.process_id, thread_id: plan.thread_id, write_count: writes.len(), byte_count: byte_count, operations: operations, writes: writes)

fn _vm_write_result(ok: bool, state: text, bytes: WinePebTebLayoutByteWriteResult, write_count: i64, byte_count: i64, operations: text, space: WineVmSpace) -> WinePebTebVmWriteResult:
    WinePebTebVmWriteResult(ok: ok, state: state, process_id: bytes.process_id, thread_id: bytes.thread_id, write_count: write_count, byte_count: byte_count, operations: operations, space: space)

fn _u64_le_bytes(value: i64) -> [u8]:
    var out: [u8] = []
    var remaining = value
    var i = 0
    while i < 8:
        out.push((remaining % 256) as u8)
        remaining = remaining / 256
        i = i + 1
    out

fn _layout_byte_write(record: WinePebTebLayoutWriteRecord) -> WinePebTebLayoutByteWrite:
    WinePebTebLayoutByteWrite(area: record.area, field_name: record.field_name, address: record.address, bytes: _u64_le_bytes(record.value))

pub fn wine_peb_teb_required_evidence() -> [text]:
    [
        "simpleos-process-identity",
        "simpleos-thread-identity",
        "simpleos-address-space",
        "simpleos-stack-bounds",
        "simpleos-process-parameters",
        "simpleos-tls-vector",
        "simpleos-mdsoc-process-port",
        "simpleos-mdsoc-thread-port"
    ]

pub fn wine_peb_teb_fixture_evidence() -> text:
    "simpleos-process-identity simpleos-thread-identity simpleos-address-space " +
        "simpleos-stack-bounds simpleos-process-parameters simpleos-tls-vector " +
        "simpleos-mdsoc-process-port simpleos-mdsoc-thread-port"

pub fn wine_peb_teb_init_default() -> WinePebTebInitEvidence:
    _init(10, 20, 0x7ffdf000, 0x7ffde000, 0x400000, 0x7ffef000, 0x7ffee000, 0x7ffdd000, 0x7ffdc000, wine_peb_teb_fixture_evidence())

fn _aligned_pointer(address: i64) -> bool:
    address > 0 and address % 16 == 0

fn _required_evidence_gate(evidence: text) -> text:
    for item in wine_peb_teb_required_evidence():
        if not evidence.contains(item):
            return "missing-" + item
    "ready"

pub fn wine_peb_teb_init_gate(init: WinePebTebInitEvidence) -> WinePebTebInitResult:
    val evidence_state = _required_evidence_gate(init.evidence)
    if evidence_state != "ready":
        return _result(false, evidence_state, init, "")
    if init.process_id <= 0:
        return _result(false, "invalid-process-id", init, "")
    if init.thread_id <= 0:
        return _result(false, "invalid-thread-id", init, "")
    if not _aligned_pointer(init.peb_address):
        return _result(false, "invalid-peb-address", init, "")
    if not _aligned_pointer(init.teb_address):
        return _result(false, "invalid-teb-address", init, "")
    if not _aligned_pointer(init.image_base):
        return _result(false, "invalid-image-base", init, "")
    if not _aligned_pointer(init.stack_base):
        return _result(false, "invalid-stack-base", init, "")
    if not _aligned_pointer(init.stack_limit):
        return _result(false, "invalid-stack-limit", init, "")
    if init.stack_limit >= init.stack_base:
        return _result(false, "invalid-stack-bounds", init, "")
    if not _aligned_pointer(init.tls_vector_address):
        return _result(false, "invalid-tls-vector", init, "")
    if not _aligned_pointer(init.process_parameters_address):
        return _result(false, "invalid-process-parameters", init, "")
    _result(true, "ready", init, "PEB TEB TLS ProcessParameters")

pub fn wine_peb_teb_init_with_loader_lock(init: WinePebTebInitEvidence, symbols: [text], table: WineKernel32CriticalSectionTable) -> WinePebTebInitResult:
    val locked = wine_kernel32_execute_critical_section(symbols, table, "loader-lock")
    if not locked.ok:
        return _result(false, "loader-lock:" + locked.error, init, locked.operations)
    val initialized = wine_peb_teb_init_gate(init)
    if not initialized.ok:
        return initialized
    _result(true, "ready", init, initialized.operations + " LoaderLock")

pub fn wine_peb_teb_memory_write_gate(init: WinePebTebInitEvidence, space: WineVmSpace) -> WinePebTebMemoryWriteResult:
    val initialized = wine_peb_teb_init_gate(init)
    if not initialized.ok:
        return _write_result(false, "init:" + initialized.state, init, 0, initialized.operations)
    val peb = wine_vm_access_gate(space, init.peb_address, "write")
    if peb != "ready":
        return _write_result(false, "peb-write:" + peb, init, 0, initialized.operations)
    val teb = wine_vm_access_gate(space, init.teb_address, "write")
    if teb != "ready":
        return _write_result(false, "teb-write:" + teb, init, 1, initialized.operations + " PEBWrite")
    val tls = wine_vm_access_gate(space, init.tls_vector_address, "write")
    if tls != "ready":
        return _write_result(false, "tls-vector-write:" + tls, init, 2, initialized.operations + " PEBWrite TEBWrite")
    val params = wine_vm_access_gate(space, init.process_parameters_address, "write")
    if params != "ready":
        return _write_result(false, "process-parameters-write:" + params, init, 3, initialized.operations + " PEBWrite TEBWrite TLSVectorWrite")
    _write_result(true, "ready", init, 4, initialized.operations + " PEBWrite TEBWrite TLSVectorWrite ProcessParametersWrite")

pub fn wine_peb_teb_layout_write_plan(init: WinePebTebInitEvidence, writes: WinePebTebMemoryWriteResult) -> WinePebTebLayoutWritePlan:
    if not writes.ok:
        return _layout_plan(false, "write:" + writes.state, init, writes.operations, [])
    if writes.write_count != 4:
        return _layout_plan(false, "write-count-mismatch", init, writes.operations, [])
    if writes.process_id != init.process_id or writes.thread_id != init.thread_id:
        return _layout_plan(false, "write-identity-mismatch", init, writes.operations, [])

    val initialized = wine_peb_teb_init_gate(init)
    if not initialized.ok:
        return _layout_plan(false, "init:" + initialized.state, init, initialized.operations, [])

    val records = [
        _layout_record("TEB", "NtTib.StackBase", init.teb_address, 0x08, 8, init.stack_base),
        _layout_record("TEB", "NtTib.StackLimit", init.teb_address, 0x10, 8, init.stack_limit),
        _layout_record("TEB", "ThreadLocalStoragePointer", init.teb_address, 0x58, 8, init.tls_vector_address),
        _layout_record("TEB", "ProcessEnvironmentBlock", init.teb_address, 0x60, 8, init.peb_address),
        _layout_record("PEB", "ImageBaseAddress", init.peb_address, 0x10, 8, init.image_base),
        _layout_record("PEB", "ProcessParameters", init.peb_address, 0x20, 8, init.process_parameters_address)
    ]
    _layout_plan(true, "ready", init, writes.operations + " PEBTEBLayoutWritePlan", records)

pub fn wine_peb_teb_layout_byte_writes(plan: WinePebTebLayoutWritePlan) -> WinePebTebLayoutByteWriteResult:
    if not plan.ok:
        return _layout_byte_result(false, "layout:" + plan.state, plan, plan.operations, [])
    if plan.record_count != 6:
        return _layout_byte_result(false, "layout-count-mismatch", plan, plan.operations, [])

    var writes: [WinePebTebLayoutByteWrite] = []
    for record in plan.records:
        if record.width != 8:
            return _layout_byte_result(false, "unsupported-layout-width:" + record.field_name, plan, plan.operations, writes)
        writes.push(_layout_byte_write(record))
    _layout_byte_result(true, "ready", plan, plan.operations + " PEBTEBLayoutBytesWritten", writes)

pub fn wine_peb_teb_apply_layout_byte_writes(space: WineVmSpace, bytes: WinePebTebLayoutByteWriteResult) -> WinePebTebVmWriteResult:
    if not bytes.ok:
        return _vm_write_result(false, "bytes:" + bytes.state, bytes, 0, 0, bytes.operations, space)
    if bytes.write_count != 6:
        return _vm_write_result(false, "byte-write-count-mismatch", bytes, 0, 0, bytes.operations, space)

    var current = space
    var write_count = 0
    var byte_count = 0
    for write in bytes.writes:
        val written = wine_vm_write_bytes(current, write.address, write.bytes)
        if not written.ok:
            return _vm_write_result(false, "vm-write:" + write.field_name + ":" + written.state, bytes, write_count, byte_count, bytes.operations + " " + written.operations, current)
        val read = wine_vm_read_bytes(written.space, write.address, write.bytes.len())
        if not read.ok:
            return _vm_write_result(false, "vm-readback:" + write.field_name + ":" + read.state, bytes, write_count, byte_count, bytes.operations + " " + written.operations + " " + read.operations, written.space)
        var i = 0
        while i < write.bytes.len():
            if read.bytes[i] != write.bytes[i]:
                return _vm_write_result(false, "vm-readback-mismatch:" + write.field_name, bytes, write_count, byte_count, bytes.operations + " " + written.operations + " " + read.operations, written.space)
            i = i + 1
        current = written.space
        write_count = write_count + 1
        byte_count = byte_count + write.bytes.len()
    _vm_write_result(true, "ready", bytes, write_count, byte_count, bytes.operations + " PEBTEBLayoutVMBytesWritten PEBTEBLayoutVMReadback", current)
