# SDN Value — Simple Data Notation value types.
#
# Provides: SdnValue, Span.

# Source location span for error reporting.
pub class Span:
    line: i64
    column: i64

    static fn empty() -> Span:
        Span(line: 0, column: 0)

    static fn at(line: i64, column: i64) -> Span:
        Span(line: line, column: column)

# The core SDN value type.
pub enum SdnValue:
    Null
    Bool(bool)
    Int(i64)
    Float(f64)
    String(text)
    Array([SdnValue])
    Dict(Dict<text, SdnValue>)
    Table(headers: [text], rows: [[SdnValue]])

pub fn sdn_value_to_text(v: SdnValue) -> text:
    match v:
        case Null: "null"
        case Bool(b): if b: "true" else: "false"
        case Int(i): i.to_text()
        case Float(f): f.to_text()
        case String(s): s
        case Array(_): "[...]"
        case Dict(_): "{...}"
        case Table(_, _): "[[...]]"

pub fn sdn_value_is_null(v: SdnValue) -> bool:
    match v:
        case Null: true
        case _: false
