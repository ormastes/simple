# codex-impl
# Host-side validation of a guest receipt correlated with QMP or board capture.

struct SimpleOsRenderTargetEvidence:
    runtime_kind: text
    architecture: text
    board_id: text
    board_model: text
    board_revision: text
    board_serial_hash: text
    firmware_hash: text
    boot_transport: text
    display_controller: text
    driver_id: text
    scanout_id: i64
    resource_id: i64
    dma_mode: text
    cache_mode: text
    iommu_mode: text
    width: i64
    height: i64
    stride: i64
    format: text
    surface_handle: i64
    present_sequence: i64
    frame_complete: bool
    guest_readback_source: text
    guest_pixel_hash: text
    serial_log_path: text
    serial_log_hash: text
    capture_kind: text
    capture_path: text
    capture_hash: text
    capture_tool: text
    boot_id: text
    frame_id: text
    oracle_hash: text
    oracle_mismatch_count: i64

struct SimpleOsRenderTargetValidation:
    valid: bool
    code: text
    path: text

fn _simpleos_target_invalid(code: text, path: text) -> SimpleOsRenderTargetValidation:
    SimpleOsRenderTargetValidation(valid: false, code: code, path: path)

fn _simpleos_sha256(value: text) -> bool:
    if value.len() != 64:
        return false
    val allowed = "0123456789abcdef"
    var i = 0
    while i < value.len():
        if not allowed.contains(value[i].to_text()):
            return false
        i = i + 1
    true

fn validate_simpleos_render_target_evidence(evidence: SimpleOsRenderTargetEvidence) -> SimpleOsRenderTargetValidation:
    if evidence.runtime_kind != "qemu" and evidence.runtime_kind != "physical-board":
        return _simpleos_target_invalid("invalid-runtime", "runtime_kind")
    if evidence.architecture != "x86_64" and evidence.architecture != "aarch64" and evidence.architecture != "rv64":
        return _simpleos_target_invalid("invalid-architecture", "architecture")
    if not _simpleos_sha256(evidence.firmware_hash):
        return _simpleos_target_invalid("invalid-firmware-hash", "firmware_hash")
    if evidence.boot_id == "" or evidence.frame_id == "":
        return _simpleos_target_invalid("missing-correlation", "boot_id")
    if evidence.width <= 0 or evidence.height <= 0 or evidence.stride < evidence.width * 4:
        return _simpleos_target_invalid("invalid-dimensions", "stride")
    if evidence.surface_handle <= 0 or evidence.present_sequence <= 0 or not evidence.frame_complete:
        return _simpleos_target_invalid("incomplete-frame", "frame_complete")
    if evidence.serial_log_path == "" or not _simpleos_sha256(evidence.serial_log_hash):
        return _simpleos_target_invalid("missing-serial-evidence", "serial_log_path")
    if evidence.capture_kind == "" or evidence.capture_path == "" or not _simpleos_sha256(evidence.capture_hash):
        return _simpleos_target_invalid("missing-capture-evidence", "capture_path")
    if not _simpleos_sha256(evidence.oracle_hash) or evidence.oracle_mismatch_count != 0:
        return _simpleos_target_invalid("oracle-mismatch", "oracle_mismatch_count")
    if evidence.guest_pixel_hash != "" and evidence.guest_pixel_hash != evidence.capture_hash:
        return _simpleos_target_invalid("guest-capture-mismatch", "guest_pixel_hash")
    if evidence.runtime_kind == "physical-board":
        if evidence.board_id == "" or evidence.board_model == "" or evidence.board_revision == "" or not _simpleos_sha256(evidence.board_serial_hash):
            return _simpleos_target_invalid("missing-board-identity", "board_id")
        if evidence.boot_transport == "" or evidence.capture_tool == "":
            return _simpleos_target_invalid("missing-board-boot-capture", "boot_transport")
    SimpleOsRenderTargetValidation(valid: true, code: "pass", path: "")

fn simpleos_render_target_status(evidence: SimpleOsRenderTargetEvidence) -> text:
    val validation = validate_simpleos_render_target_evidence(evidence)
    if not validation.valid:
        return "fail"
    if evidence.runtime_kind == "physical-board":
        return "board-verified"
    "qemu-verified"
