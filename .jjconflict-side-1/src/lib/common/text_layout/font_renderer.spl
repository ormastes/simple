# Compatibility facade: common.text_layout.font_renderer
#   -> std.nogc_sync_mut.text_layout.font_renderer (canonical implementation)
#
# See font_rasterizer.spl in this directory for why the canonical code lives in
# the nogc_sync_mut tier. This facade re-exports it under the tier-neutral
# `common.text_layout` name used by shared specs and consumers.
export use std.nogc_sync_mut.text_layout.font_renderer.*
