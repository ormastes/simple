# Compatibility facade: common.text_layout.font_rasterizer
#   -> std.nogc_sync_mut.text_layout.font_rasterizer (canonical implementation)
#
# `common.text_layout` is the tier-neutral name shared specs and consumers use
# for the text-layout rasterizer. The real code lives in the nogc_sync_mut tier
# (it uses SFFI font handles, so it is not pure-`common`); this facade re-exports
# it so `use common.text_layout.font_rasterizer` resolves.
export use std.nogc_sync_mut.text_layout.font_rasterizer.*
