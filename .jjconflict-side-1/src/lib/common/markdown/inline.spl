# Common Markdown inline helpers.

# Single-pass inline scanner: handles **bold**, *italic*, `code`,
# escaped \*, and unbalanced markers (treated as literal text).
# Code spans protect their content from further interpretation.
fn markdown_inline_text(value: text) -> text:
    if value.len() == 0:
        return ""
    var out = ""
    var i = 0
    val n = value.len()
    while i < n:
        val ch = value.char_at(i)
        # Escaped character: backslash before * or `
        if ch == "\\" and i + 1 < n:
            val next = value.char_at(i + 1)
            if next == "*" or next == "`" or next == "\\":
                out = out + next
                i = i + 2
            else:
                out = out + ch
                i = i + 1
        # Code span: find closing backtick, protect interior
        elif ch == "`":
            var j = i + 1
            var found_close = false
            while j < n:
                if value.char_at(j) == "`":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                val interior = value.slice(i + 1, j)
                out = out + "<code>" + interior + "</code>"
                i = j + 1
            else:
                # Unbalanced backtick — emit as literal
                out = out + ch
                i = i + 1
        # Bold: **text**
        elif ch == "*" and i + 1 < n and value.char_at(i + 1) == "*":
            var j = i + 2
            var found_close = false
            while j + 1 < n:
                if value.char_at(j) == "*" and value.char_at(j + 1) == "*":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                val interior = value.slice(i + 2, j)
                out = out + "<strong>" + interior + "</strong>"
                i = j + 2
            else:
                # Unbalanced ** — emit as literal
                out = out + "**"
                i = i + 2
        # Italic: *text*
        elif ch == "*":
            var j = i + 1
            var found_close = false
            while j < n:
                if value.char_at(j) == "*":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                val interior = value.slice(i + 1, j)
                out = out + "<em>" + interior + "</em>"
                i = j + 1
            else:
                # Unbalanced * — emit as literal
                out = out + ch
                i = i + 1
        else:
            out = out + ch
            i = i + 1
    out

# Escape HTML special characters including quote chars for attribute-context safety.
fn markdown_escape_html(value: text) -> text:
    if value.len() == 0:
        return ""
    var out = value.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out = out.replace("\"", "&quot;")
    out.replace("'", "&#39;")

# Strip inline markers to produce plain text (for TOC, alt-text, etc.).
# Uses the single-pass scanner so code spans protect their content.
fn markdown_plain_inline(value: text) -> text:
    if value.len() == 0:
        return ""
    var out = ""
    var i = 0
    val n = value.len()
    while i < n:
        val ch = value.char_at(i)
        # Escaped marker: skip the backslash, keep the char
        if ch == "\\" and i + 1 < n:
            val next = value.char_at(i + 1)
            if next == "*" or next == "`" or next == "\\":
                out = out + next
                i = i + 2
            else:
                out = out + ch
                i = i + 1
        # Code span: keep interior, skip backticks
        elif ch == "`":
            var j = i + 1
            var found_close = false
            while j < n:
                if value.char_at(j) == "`":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                out = out + value.slice(i + 1, j)
                i = j + 1
            else:
                # Unbalanced — drop the lone backtick
                i = i + 1
        # Bold **
        elif ch == "*" and i + 1 < n and value.char_at(i + 1) == "*":
            var j = i + 2
            var found_close = false
            while j + 1 < n:
                if value.char_at(j) == "*" and value.char_at(j + 1) == "*":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                out = out + value.slice(i + 2, j)
                i = j + 2
            else:
                # Unbalanced — drop the **
                i = i + 2
        # Italic *
        elif ch == "*":
            var j = i + 1
            var found_close = false
            while j < n:
                if value.char_at(j) == "*":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                out = out + value.slice(i + 1, j)
                i = j + 1
            else:
                # Unbalanced — drop the lone *
                i = i + 1
        else:
            out = out + ch
            i = i + 1
    out
