"""
# RV64 Memory Bus Interface

Abstract bus interface for memory operations. Implementations provide
concrete memory-mapped access (RAM, MMIO devices).

Since Simple uses composition (no inheritance), this module defines the
interface contract as documentation. Concrete implementations (Rv64Bus,
Rv64Ram) implement these methods directly.
"""

# Memory access widths
val MEM_BYTE: i64 = 1
val MEM_HALF: i64 = 2
val MEM_WORD: i64 = 4
val MEM_DOUBLE: i64 = 8

# Memory access result
class MemResult:
    value: i64
    fault: bool
    fault_cause: i64

fn mem_ok(value: i64) -> MemResult:
    """Create a successful memory result."""
    MemResult(value: value, fault: false, fault_cause: 0)

fn mem_fault(cause: i64) -> MemResult:
    """Create a faulted memory result."""
    MemResult(value: 0, fault: true, fault_cause: cause)

# Bus interface methods (contract):
#   fn read8(addr: i64) -> MemResult
#   fn read16(addr: i64) -> MemResult
#   fn read32(addr: i64) -> MemResult
#   fn read64(addr: i64) -> MemResult
#   me write8(addr: i64, value: i64) -> MemResult
#   me write16(addr: i64, value: i64) -> MemResult
#   me write32(addr: i64, value: i64) -> MemResult
#   me write64(addr: i64, value: i64) -> MemResult
