"""
# RV64 CSR Address Map

Complete CSR addresses for M-mode, S-mode, U-mode, and FP CSRs.
"""

# Machine-mode CSRs (0x3xx)
val CSR_MSTATUS: i64 = 0x300
val CSR_MISA: i64 = 0x301
val CSR_MEDELEG: i64 = 0x302
val CSR_MIDELEG: i64 = 0x303
val CSR_MIE: i64 = 0x304
val CSR_MTVEC: i64 = 0x305
val CSR_MCOUNTEREN: i64 = 0x306
val CSR_MSCRATCH: i64 = 0x340
val CSR_MEPC: i64 = 0x341
val CSR_MCAUSE: i64 = 0x342
val CSR_MTVAL: i64 = 0x343
val CSR_MIP: i64 = 0x344

# Machine counters
val CSR_MCYCLE: i64 = 0xB00
val CSR_MINSTRET: i64 = 0xB02
val CSR_MHARTID: i64 = 0xF14

# PMP CSRs
val CSR_PMPCFG0: i64 = 0x3A0
val CSR_PMPADDR0: i64 = 0x3B0

# Supervisor-mode CSRs (0x1xx)
val CSR_SSTATUS: i64 = 0x100
val CSR_SIE: i64 = 0x104
val CSR_STVEC: i64 = 0x105
val CSR_SCOUNTEREN: i64 = 0x106
val CSR_SSCRATCH: i64 = 0x140
val CSR_SEPC: i64 = 0x141
val CSR_SCAUSE: i64 = 0x142
val CSR_STVAL: i64 = 0x143
val CSR_SIP: i64 = 0x144
val CSR_SATP: i64 = 0x180

# FP CSRs (0x0xx)
val CSR_FFLAGS: i64 = 0x001
val CSR_FRM: i64 = 0x002
val CSR_FCSR: i64 = 0x003

# mstatus bit masks
val MSTATUS_SIE: i64 = 0x2
val MSTATUS_MIE: i64 = 0x8
val MSTATUS_SPIE: i64 = 0x20
val MSTATUS_MPIE: i64 = 0x80
val MSTATUS_SPP: i64 = 0x100
val MSTATUS_MPP_MASK: i64 = 0x1800
val MSTATUS_MPP_SHIFT: i64 = 11
val MSTATUS_FS: i64 = 0x6000
val MSTATUS_TW: i64 = 0x200000

# sstatus mask: fields visible from S-mode
val SSTATUS_MASK: i64 = 0x800DE133

# misa: RV64GC = MXL=2 | I | M | A | F | D | C
# MXL=2 (bits 63:62), I=bit8, M=bit12, A=bit0, F=bit5, D=bit3, C=bit2
val MISA_RV64GC: i64 = 0x800000000014112D
