"""
# RV64 Zicsr — CSR Instruction Helpers

CSR access permission checks and instruction dispatch.
"""

use hardware.rv64gc.pkg.rv64_types_pkg.{PrivilegeMode, priv_to_i64}
use hardware.rv64gc.pkg.rv64_csr_addrs.*

# ---------------------------------------------------------------------------
# Permission checks
# ---------------------------------------------------------------------------

fn csr_min_priv(addr: i64) -> i64:
    """Get minimum privilege level required to access a CSR.
    CSR address bits [9:8] encode the minimum privilege level."""
    (addr >> 8) and 0x3

fn csr_is_read_only(addr: i64) -> bool:
    """Check if a CSR is read-only. Bits [11:10] == 0b11 means read-only."""
    ((addr >> 10) and 0x3) == 0x3

fn check_csr_access(addr: i64, priv_mode: PrivilegeMode, is_write: bool) -> bool:
    """Check if CSR access is permitted. Returns true if access is allowed."""
    val mode_level = priv_to_i64(priv_mode)
    val required = csr_min_priv(addr)

    if mode_level < required:
        false  # Insufficient privilege
    elif is_write and csr_is_read_only(addr):
        false  # Write to read-only CSR
    else:
        true

# ---------------------------------------------------------------------------
# CSR instruction dispatch
# ---------------------------------------------------------------------------

fn csr_op_read_write(old_val: i64, new_val: i64) -> i64:
    """CSRRW/CSRRWI: swap old and new."""
    new_val

fn csr_op_read_set(old_val: i64, mask: i64) -> i64:
    """CSRRS/CSRRSI: set bits."""
    old_val or mask

fn csr_op_read_clear(old_val: i64, mask: i64) -> i64:
    """CSRRC/CSRRCI: clear bits."""
    old_val and (mask xor 0xFFFFFFFFFFFFFFFF)
