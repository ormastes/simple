"""
# RV64 Zifencei — Instruction-Fetch Fence

FENCE.I implementation. In a software emulator this is minimal since
there is no hardware instruction cache, but we track the invalidation
state so higher-level components can respond (e.g., flush JIT caches).
"""

class FenceIState:
    icache_invalid: bool

    static fn create() -> FenceIState:
        FenceIState(icache_invalid: false)

    me fence_i():
        """Execute FENCE.I: mark instruction cache as invalid.
        The pipeline/hart should check this flag and re-fetch."""
        self.icache_invalid = true

    me acknowledge():
        """Acknowledge the fence. Called after the pipeline has flushed."""
        self.icache_invalid = false

    fn needs_flush() -> bool:
        """Check if an instruction cache flush is pending."""
        self.icache_invalid
