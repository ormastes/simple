"""
# RV32 CLINT
"""

class Rv32Clint:
    mtime: i64
    msip: [i64]
    mtimecmp: [i64]
    num_harts: i64

    static fn create(num_harts: i64) -> Rv32Clint:
        var msip: [i64] = []
        var mtimecmp: [i64] = []
        var idx = 0
        while idx < num_harts:
            msip.push(0)
            mtimecmp.push(0x7FFFFFFF)
            idx = idx + 1
        Rv32Clint(mtime: 0, msip: msip, mtimecmp: mtimecmp, num_harts: num_harts)

    fn read(offset: i64) -> i64:
        if offset < (self.num_harts * 4):
            return self.msip[offset / 4]
        if offset >= 0x4000 and offset < (0x4000 + self.num_harts * 8):
            return self.mtimecmp[(offset - 0x4000) / 8]
        if offset == 0xBFF8:
            return self.mtime
        0

    me write(offset: i64, value: i64):
        if offset < (self.num_harts * 4):
            self.msip[offset / 4] = value and 1
        elif offset >= 0x4000 and offset < (0x4000 + self.num_harts * 8):
            self.mtimecmp[(offset - 0x4000) / 8] = value and 0xFFFFFFFF
        elif offset == 0xBFF8:
            self.mtime = value and 0xFFFFFFFF

    me tick():
        self.mtime = self.mtime + 1

    fn get_msip(hart: i64) -> bool:
        hart >= 0 and hart < self.num_harts and self.msip[hart] != 0

    fn get_mtip(hart: i64) -> bool:
        hart >= 0 and hart < self.num_harts and self.mtime >= self.mtimecmp[hart]
