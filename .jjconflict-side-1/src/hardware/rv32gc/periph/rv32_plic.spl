"""
# RV32 PLIC
"""

class Rv32Plic:
    pending: Dict<i64, i64>
    enables: Dict<i64, i64>
    contexts: i64

    static fn create(contexts: i64) -> Rv32Plic:
        Rv32Plic(pending: {}, enables: {}, contexts: contexts)

    fn read(offset: i64) -> i64:
        if self.pending.contains(offset):
            return self.pending[offset]
        if self.enables.contains(offset):
            return self.enables[offset]
        0

    me write_reg(offset: i64, value: i64):
        if offset < 0x2000:
            self.pending[offset] = value and 0xFFFFFFFF
        else:
            self.enables[offset] = value and 0xFFFFFFFF

    fn has_pending(context: i64) -> bool:
        if context < 0 or context >= self.contexts:
            return false
        for key in self.pending.keys():
            if self.pending[key] != 0:
                return true
        false
