"""
# RV32 Register File
"""

class Rv32RegFile:
    regs: [i64]

    static fn create() -> Rv32RegFile:
        var regs: [i64] = []
        var idx = 0
        while idx < 32:
            regs.push(0)
            idx = idx + 1
        Rv32RegFile(regs: regs)

    fn read(index: i64) -> i64:
        if index <= 0 or index >= 32:
            return 0
        self.regs[index]

    me write(index: i64, value: i64):
        if index <= 0 or index >= 32:
            return
        self.regs[index] = value and 0xFFFFFFFF

    me reset():
        var idx = 0
        while idx < 32:
            self.regs[idx] = 0
            idx = idx + 1
