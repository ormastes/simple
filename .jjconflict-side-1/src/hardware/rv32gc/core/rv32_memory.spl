"""
# RV32 Memory Bus Interface
"""

val MEM_BYTE: i64 = 1
val MEM_HALF: i64 = 2
val MEM_WORD: i64 = 4

class MemResult:
    value: i64
    fault: bool
    fault_cause: i64

fn mem_ok(value: i64) -> MemResult:
    MemResult(value: value, fault: false, fault_cause: 0)

fn mem_fault(cause: i64) -> MemResult:
    MemResult(value: 0, fault: true, fault_cause: cause)
