# Force LF line endings for Simple language source files.
# CRLF breaks the indentation-sensitive parser.
*.spl text eol=lf
*.shs text eol=lf
*.sdn text eol=lf

# Do not include local development caches or compatibility blobs in git archive exports.
src/app/vscode_extension/node_modules export-ignore
src/app/vscode_extension/.vscode-test export-ignore
src/compiler_rust/target export-ignore
build export-ignore
config/t32/libXp.so.6 export-ignore
config/t32/libjpeg.so.62.0.0 export-ignore
