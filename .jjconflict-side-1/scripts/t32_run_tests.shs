#!/usr/bin/env bash
# TRACE32 remote test runner — load ELF test fixtures, run via semihosting,
# parse PASS/FAIL markers from AREA output.
#
# Usage:
#   scripts/t32_run_tests.shs [--board stm32wb|stm32h7] [--timeout 30] [test_elf...]
#   scripts/t32_run_tests.shs --default   # run built-in embedded test suite

set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=scripts/t32_host_bootstrap.shs
. "$SCRIPT_DIR/t32_host_bootstrap.shs"

t32_resolve_bin
t32_env_setup

T32REM="${T32REM:-$T32_BASE/t32rem}"
HOST="${T32_HOST:-localhost}"
PORT="${T32_PORT:-20000}"
BOARD="stm32wb"
TIMEOUT=30
USE_DEFAULT=0
TEST_ELFS=()

usage() {
    cat >&2 <<'EOF'
Usage: scripts/t32_run_tests.shs [--board stm32wb|stm32h7] [--timeout N] [test_elf...]
       scripts/t32_run_tests.shs --default [--board stm32wb|stm32h7]

Run ELF test fixtures on TRACE32 via semihosting and report PASS/FAIL.
EOF
    exit 2
}

while [ "${1:-}" != "" ]; do
    case "$1" in
        --board)
            BOARD="${2:-}"
            shift 2
            ;;
        --timeout)
            TIMEOUT="${2:-30}"
            shift 2
            ;;
        --default)
            USE_DEFAULT=1
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            TEST_ELFS+=("$1")
            shift
            ;;
    esac
done

case "$BOARD" in
    stm32wb) CPU="cortex-m4" ;;
    stm32h7) CPU="cortex-m7" ;;
    *)
        echo "unsupported board: $BOARD" >&2
        exit 1
        ;;
esac

# ─── Build default test suite ───────────────────────────────────────────────

TMPDIR="$(mktemp -d /tmp/t32_run_tests.XXXXXX)"

build_elf() {
    local asm="$1"
    local name
    name="$(basename "$asm" .s)"
    local elf="$TMPDIR/${name}_${BOARD}.elf"
    local ld_file="$REPO_ROOT/test/fixtures/baremetal/${name}.ld"

    if [ ! -f "$ld_file" ]; then
        # Use default linker script if specific one missing
        ld_file="$REPO_ROOT/test/fixtures/baremetal/stm_semihost_smoke.ld"
    fi

    clang \
        --target=armv7m-none-eabi \
        -mcpu="$CPU" \
        -mthumb \
        -nostdlib \
        -fuse-ld=lld \
        -Wl,-T,"$ld_file" \
        -Wl,-e,_start \
        -Wl,--gc-sections \
        -o "$elf" \
        "$asm" 2>/dev/null

    printf '%s' "$elf"
}

if [ "$USE_DEFAULT" = "1" ] && [ ${#TEST_ELFS[@]} -eq 0 ]; then
    # Build all .s fixtures under test/fixtures/baremetal/
    for asm in "$REPO_ROOT"/test/fixtures/baremetal/*.s; do
        [ -f "$asm" ] || continue
        elf="$(build_elf "$asm")"
        if [ -f "$elf" ]; then
            TEST_ELFS+=("$elf")
        else
            echo "WARNING: failed to build $asm" >&2
        fi
    done
fi

if [ ${#TEST_ELFS[@]} -eq 0 ]; then
    echo "ERROR: no test ELFs specified. Use --default or provide paths." >&2
    usage
fi

# t32_remote() is provided by t32_host_bootstrap.shs with MCI mode guard.

# ─── Lifecycle ───────────────────────────────────────────────────────────────

CFG_PATH="$REPO_ROOT/config/t32_stm_linux_hidden.t32"

cleanup() {
    t32_lifecycle_off
    rm -rf "$TMPDIR"
}
trap cleanup EXIT INT TERM

LIFECYCLE_RC=0
t32_lifecycle_on "$CFG_PATH" || LIFECYCLE_RC=$?

if [ "$LIFECYCLE_RC" -eq 2 ]; then
    echo "T32 test runner SKIPPED: MCI-only mode (t32rem unavailable)" >&2
    echo "Upgrade to PowerView >=2015 or run with a real X11 display." >&2
    exit 2
elif [ "$LIFECYCLE_RC" -ne 0 ]; then
    echo "T32 test runner FAILED: lifecycle startup error (rc=$LIFECYCLE_RC)" >&2
    exit 1
fi

# ─── Run each test ──────────────────────────────────────────────────────────

TOTAL=0
PASSED=0
FAILED=0
RESULTS=()

run_test() {
    local elf="$1"
    local name
    name="$(basename "$elf" .elf)"
    TOTAL=$((TOTAL + 1))

    echo "--- [$TOTAL] $name ---"

    # Set up semihost AREA
    t32_remote "AREA.Create T32TEST" >/dev/null 2>&1 || true
    t32_remote "AREA.Select T32TEST" >/dev/null 2>&1 || true
    t32_remote "AREA.CLEAR T32TEST" >/dev/null 2>&1 || true
    t32_remote "SYStem.Option SemiHost ON" >/dev/null 2>&1 || true

    # Load and run
    if ! t32_remote "Data.LOAD.Elf $elf" >/dev/null 2>&1; then
        echo "  FAIL: could not load ELF"
        FAILED=$((FAILED + 1))
        RESULTS+=("FAIL  $name (load error)")
        return
    fi

    if ! t32_remote "Go" >/dev/null 2>&1; then
        echo "  FAIL: Go command failed"
        FAILED=$((FAILED + 1))
        RESULTS+=("FAIL  $name (Go failed)")
        return
    fi
    sleep "$TIMEOUT"
    t32_remote "Break" >/dev/null 2>&1 || true

    # Read AREA output
    local area_output
    area_output="$(t32_remote "WinPrint.AREA T32TEST" 2>&1)" || {
        echo "  FAIL: WinPrint.AREA failed"
        FAILED=$((FAILED + 1))
        RESULTS+=("FAIL  $name (read failed)")
        return
    }

    # Check for test markers
    if printf '%s\n' "$area_output" | grep -qi "PASS\|simple-stm-smoke"; then
        echo "  PASS"
        PASSED=$((PASSED + 1))
        RESULTS+=("PASS  $name")
    elif printf '%s\n' "$area_output" | grep -qi "FAIL\|ERROR"; then
        echo "  FAIL"
        FAILED=$((FAILED + 1))
        RESULTS+=("FAIL  $name")
    else
        echo "  FAIL: no PASS/FAIL marker found in output"
        FAILED=$((FAILED + 1))
        RESULTS+=("FAIL  $name (no marker)")
    fi
}

for elf in "${TEST_ELFS[@]}"; do
    run_test "$elf"
done

# ─── Summary ────────────────────────────────────────────────────────────────

echo ""
echo "════════════════════════════════════════════"
echo "  T32 Test Summary: $PASSED passed, $FAILED failed, $TOTAL total"
echo "════════════════════════════════════════════"
for r in "${RESULTS[@]}"; do
    echo "  $r"
done

if [ "$FAILED" -gt 0 ]; then
    exit 1
fi
exit 0
