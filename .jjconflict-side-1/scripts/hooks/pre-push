#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

if [ -n "${SIMPLE_BIN:-}" ]; then
    SIMPLE="$SIMPLE_BIN"
elif [ -x src/compiler_rust/target/debug/simple ]; then
    SIMPLE="src/compiler_rust/target/debug/simple"
else
    SIMPLE="./bin/simple"
fi

if [ ! -x "$SIMPLE" ]; then
    echo "tracking pre-push: $SIMPLE is not executable" >&2
    exit 1
fi

"$SIMPLE" check-dbs --strict
"$SIMPLE" tracking check --kind=feature
"$SIMPLE" traceability-check --scope=all

spec_count="$(find doc/06_spec -name '*_spec.spl' | wc -l | tr -d ' ')"
if [ "$spec_count" != "0" ]; then
    echo "tracking pre-push: doc/06_spec contains executable *_spec.spl files ($spec_count)" >&2
    exit 1
fi

echo "tracking pre-push: clean"
