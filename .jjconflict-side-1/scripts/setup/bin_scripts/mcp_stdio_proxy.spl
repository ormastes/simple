# MCP stdio framing proxy
#
# Bridges between strict Content-Length clients and MCP servers that read
# JSON lines from stdin. Forwards stdin to subprocess stdin and subprocess
# stdout back to client, adapting framing as needed.
#
# Usage: bin/simple run bin/mcp_stdio_proxy.spl <server-cmd> [args...]

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_cli_get_args() -> [text]
extern fn rt_env_get(key: text) -> text
extern fn rt_exit(code: i32)

fn main():
    val args = rt_cli_get_args()

    if args.len() < 2:
        print "usage: bin/simple run bin/mcp_stdio_proxy.spl <server-cmd> [args...]"
        rt_exit(2)

    # Build the server command from remaining args
    var cmd_parts: [text] = []
    var i = 1
    while i < args.len():
        cmd_parts = cmd_parts + [args[i]]
        i = i + 1
    val server_cmd = cmd_parts.join(" ")

    # Run the server with stdin/stdout passthrough via shell pipe
    val (_, _, code) = rt_process_run("sh", ["-c", "cat | " + server_cmd])
    rt_exit(code)
