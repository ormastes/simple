#!/bin/sh
# Build a Linux RenderDoc tree for ANGLE/Vulkan browser capture diagnostics.
#
# Chromium/ANGLE on Linux can stall inside RenderDoc's EGL hook path. This
# wrapper builds RenderDoc with Vulkan enabled and GL/GLES/EGL disabled so the
# browser RenderDoc gates can point RDOC_HOME at a reproducible local tree.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
MODE="${1:---check}"
REF="${RENDERDOC_REF:-v1.44}"
SRC_DIR="${RENDERDOC_SRC_DIR:-$ROOT_DIR/build/tools/renderdoc-src}"
BUILD_DIR="${RENDERDOC_BUILD_DIR:-$ROOT_DIR/build/tools/renderdoc-linux-vulkan-only-build}"
INSTALL_DIR="${RENDERDOC_INSTALL_DIR:-$ROOT_DIR/build/tools/renderdoc-linux-vulkan-only}"
EVIDENCE_ENV="${RENDERDOC_BUILD_EVIDENCE_ENV:-$BUILD_DIR/evidence.env}"
LOCAL_SYSROOT="${RENDERDOC_LOCAL_SYSROOT:-$ROOT_DIR/build/tools/renderdoc-local-sysroot}"
JOBS="${JOBS:-$(getconf _NPROCESSORS_ONLN 2>/dev/null || printf '4')}"

usage() {
    cat <<'EOF'
usage: scripts/setup/build-renderdoc-linux-vulkan-only.shs [--check|--print-deps|--fetch|--configure|--build|--install|--all]

  --check       Record prerequisites and current output state.
  --print-deps Print Ubuntu/Debian packages needed for this local build.
  --fetch       Clone/update RenderDoc source under build/tools/renderdoc-src.
  --configure   Run CMake with Vulkan on and GL/GLES/EGL off.
  --build       Build the configured tree.
  --install     Install into build/tools/renderdoc-linux-vulkan-only.
  --all         Fetch, configure, build, install, then check.

Set RENDERDOC_REF to override the default tag/branch.
After a successful install:
  RDOC_HOME=build/tools/renderdoc-linux-vulkan-only scripts/tool/renderdoc-evidence.shs capture-html
EOF
}

have() {
    command -v "$1" >/dev/null 2>&1
}

append_kv() {
    mkdir -p "$(dirname -- "$EVIDENCE_ENV")"
    printf '%s=%s\n' "$1" "${2:-}" >>"$EVIDENCE_ENV"
}

local_sysroot_cmake_args() {
    if [ -d "$LOCAL_SYSROOT/usr/include" ]; then
        printf ' -DCMAKE_C_FLAGS=%s' "-I$LOCAL_SYSROOT/usr/include"
        printf ' -DCMAKE_CXX_FLAGS=%s' "-I$LOCAL_SYSROOT/usr/include"
    fi
    if [ -d "$LOCAL_SYSROOT/usr/lib/x86_64-linux-gnu" ]; then
        printf ' -DCMAKE_EXE_LINKER_FLAGS=%s' "-L$LOCAL_SYSROOT/usr/lib/x86_64-linux-gnu"
        printf ' -DCMAKE_SHARED_LINKER_FLAGS=%s' "-L$LOCAL_SYSROOT/usr/lib/x86_64-linux-gnu"
    fi
}

with_local_sysroot_env() {
    if [ -d "$LOCAL_SYSROOT/usr/lib/x86_64-linux-gnu/pkgconfig" ]; then
        PKG_CONFIG_SYSROOT_DIR="$LOCAL_SYSROOT" \
        PKG_CONFIG_PATH="$LOCAL_SYSROOT/usr/lib/x86_64-linux-gnu/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}" \
        "$@"
    else
        "$@"
    fi
}

print_deps() {
    cat <<'EOF'
Ubuntu/Debian:
  sudo apt-get update
  sudo apt-get install git cmake ninja-build build-essential python3 python3-dev pkg-config libvulkan-dev vulkan-tools libx11-dev libx11-xcb-dev libxcb1-dev libxcb-keysyms1-dev libxcb-randr0-dev libxcb-xfixes0-dev libxcb-sync-dev libxcb-icccm4-dev libxcb-image0-dev libxcb-render-util0-dev libxkbcommon-dev libxkbcommon-x11-dev

This wrapper configures RenderDoc with:
  -DENABLE_GL=OFF -DENABLE_GLES=OFF -DENABLE_EGL=OFF -DENABLE_VULKAN=ON -DENABLE_QRENDERDOC=OFF -DENABLE_PYRENDERDOC=OFF
EOF
}

require_linux() {
    uname_s="$(uname -s 2>/dev/null || echo unknown)"
    if [ "$uname_s" != "Linux" ]; then
        echo "build-renderdoc-linux-vulkan-only: Linux host required, got $uname_s" >&2
        exit 2
    fi
}

check_tool_status() {
    tool="$1"
    if have "$tool"; then
        append_kv "renderdoc_vulkan_only_tool_${tool}_status" "pass"
        append_kv "renderdoc_vulkan_only_tool_${tool}" "$(command -v "$tool")"
    else
        append_kv "renderdoc_vulkan_only_tool_${tool}_status" "missing"
        append_kv "renderdoc_vulkan_only_tool_${tool}" ""
    fi
}

write_check() {
    rm -f "$EVIDENCE_ENV"
    append_kv "renderdoc_vulkan_only_status" "checked"
    append_kv "renderdoc_vulkan_only_ref" "$REF"
    append_kv "renderdoc_vulkan_only_src_dir" "$SRC_DIR"
    append_kv "renderdoc_vulkan_only_build_dir" "$BUILD_DIR"
    append_kv "renderdoc_vulkan_only_install_dir" "$INSTALL_DIR"
    check_tool_status git
    check_tool_status cmake
    check_tool_status ninja
    check_tool_status make
    append_kv "renderdoc_vulkan_only_src_status" "$([ -d "$SRC_DIR/.git" ] && printf present || printf missing)"
    append_kv "renderdoc_vulkan_only_build_status" "$([ -f "$BUILD_DIR/CMakeCache.txt" ] && printf configured || printf missing)"
    append_kv "renderdoc_vulkan_only_renderdoccmd" "$INSTALL_DIR/bin/renderdoccmd"
    append_kv "renderdoc_vulkan_only_renderdoccmd_status" "$([ -x "$INSTALL_DIR/bin/renderdoccmd" ] && printf pass || printf missing)"
    append_kv "renderdoc_vulkan_only_layer_manifest" "$INSTALL_DIR/etc/vulkan/implicit_layer.d/renderdoc_capture.json"
    append_kv "renderdoc_vulkan_only_layer_manifest_status" "$([ -s "$INSTALL_DIR/etc/vulkan/implicit_layer.d/renderdoc_capture.json" ] && printf pass || printf missing)"
    append_kv "renderdoc_vulkan_only_rdoc_home" "$INSTALL_DIR"
    append_kv "renderdoc_vulkan_only_cmake_options" "-DENABLE_GL=OFF -DENABLE_GLES=OFF -DENABLE_EGL=OFF -DENABLE_VULKAN=ON -DENABLE_QRENDERDOC=OFF -DENABLE_PYRENDERDOC=OFF -DVULKAN_LAYER_FOLDER=$INSTALL_DIR/etc/vulkan/implicit_layer.d"
    append_kv "renderdoc_vulkan_only_local_sysroot" "$LOCAL_SYSROOT"
    append_kv "renderdoc_vulkan_only_local_sysroot_status" "$([ -d "$LOCAL_SYSROOT/usr/include" ] && printf present || printf missing)"
    append_kv "renderdoc_vulkan_only_dependency_hint" "scripts/setup/build-renderdoc-linux-vulkan-only.shs --print-deps"
    cat "$EVIDENCE_ENV"
}

fetch_source() {
    require_linux
    if ! have git; then
        echo "missing git; run --print-deps" >&2
        exit 1
    fi
    mkdir -p "$(dirname -- "$SRC_DIR")"
    if [ ! -d "$SRC_DIR/.git" ]; then
        git clone https://github.com/baldurk/renderdoc.git "$SRC_DIR"
    fi
    git -C "$SRC_DIR" fetch --tags origin
    git -C "$SRC_DIR" checkout "$REF"
    git -C "$SRC_DIR" submodule update --init --recursive
}

configure_build() {
    require_linux
    if ! have cmake; then
        echo "missing cmake; run --print-deps" >&2
        exit 1
    fi
    generator=""
    if have ninja; then
        generator="-G Ninja"
    fi
    sysroot_args="$(local_sysroot_cmake_args)"
    # shellcheck disable=SC2086
    with_local_sysroot_env cmake -S "$SRC_DIR" -B "$BUILD_DIR" $generator \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="$INSTALL_DIR" \
        -DENABLE_GL=OFF \
        -DENABLE_GLES=OFF \
        -DENABLE_EGL=OFF \
        -DENABLE_VULKAN=ON \
        -DENABLE_RENDERDOCCMD=ON \
        -DENABLE_QRENDERDOC=OFF \
        -DENABLE_PYRENDERDOC=OFF \
        -DVULKAN_LAYER_FOLDER="$INSTALL_DIR/etc/vulkan/implicit_layer.d" \
        $sysroot_args
}

build_tree() {
    require_linux
    with_local_sysroot_env cmake --build "$BUILD_DIR" --parallel "$JOBS"
}

install_tree() {
    require_linux
    with_local_sysroot_env cmake --install "$BUILD_DIR"
}

case "$MODE" in
    --help|-h)
        usage
        ;;
    --print-deps)
        print_deps
        ;;
    --check)
        write_check
        ;;
    --fetch)
        fetch_source
        write_check
        ;;
    --configure)
        configure_build
        write_check
        ;;
    --build)
        build_tree
        write_check
        ;;
    --install)
        install_tree
        write_check
        ;;
    --all)
        fetch_source
        configure_build
        build_tree
        install_tree
        write_check
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
