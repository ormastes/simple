#!/bin/sh
# Launch a Chromium GPU process under RenderDoc.
set -eu

if [ "$#" -eq 0 ]; then
    echo "renderdoc-gpu-launcher: missing GPU process command" >&2
    exit 2
fi

rdoc_cmd="${RDOC_GPU_LAUNCHER_RENDERDOCCMD:-renderdoccmd}"
capture_prefix="${RDOC_GPU_LAUNCHER_CAPTURE_PREFIX:-build/renderdoc/gpu-process}"
log_path="${RDOC_GPU_LAUNCHER_LOG:-}"
autocapture="${RDOC_GPU_LAUNCHER_AUTOCAPTURE:-0}"
layer_only="${RDOC_GPU_LAUNCHER_LAYER_ONLY:-0}"
clear_renderdoc_layer="${RDOC_GPU_LAUNCHER_CLEAR_RENDERDOC_LAYER:-0}"
clear_instance_layers="${RDOC_GPU_LAUNCHER_CLEAR_INSTANCE_LAYERS:-0}"
clear_renderdoc_enable="${RDOC_GPU_LAUNCHER_CLEAR_RENDERDOC_ENABLE:-0}"
delay_trigger="${RDOC_GPU_LAUNCHER_DELAY_TRIGGER:-0}"
delay_trigger_mode="${RDOC_GPU_LAUNCHER_DELAY_TRIGGER_MODE:-start-end}"
script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
root_dir="$(CDPATH= cd -- "$script_dir/../.." && pwd)"

if [ "$log_path" != "" ]; then
    mkdir -p "$(dirname -- "$log_path")"
    {
        echo "renderdoc_gpu_launcher_command=$*"
        echo "renderdoc_gpu_launcher_executable=$1"
        echo "renderdoc_gpu_launcher_argc=$#"
        echo "renderdoc_gpu_launcher_pid=$$"
        echo "renderdoc_gpu_launcher_capture_prefix=$capture_prefix"
        echo "renderdoc_gpu_launcher_autocapture=$autocapture"
        echo "renderdoc_gpu_launcher_layer_only=$layer_only"
        echo "renderdoc_gpu_launcher_delay_trigger=$delay_trigger"
        echo "renderdoc_gpu_launcher_delay_trigger_mode=$delay_trigger_mode"
        echo "renderdoc_gpu_launcher_clear_renderdoc_layer=$clear_renderdoc_layer"
        echo "renderdoc_gpu_launcher_clear_instance_layers=$clear_instance_layers"
        echo "renderdoc_gpu_launcher_clear_renderdoc_enable=$clear_renderdoc_enable"
        echo "renderdoc_gpu_launcher_initial_vk_layer_path=${VK_LAYER_PATH:-}"
        echo "renderdoc_gpu_launcher_initial_vk_implicit_layer_path=${VK_IMPLICIT_LAYER_PATH:-}"
        echo "renderdoc_gpu_launcher_initial_vk_instance_layers=${VK_INSTANCE_LAYERS:-}"
        echo "renderdoc_gpu_launcher_initial_enable_vulkan_renderdoc_capture=${ENABLE_VULKAN_RENDERDOC_CAPTURE:-}"
        echo "renderdoc_gpu_launcher_initial_ld_preload=${LD_PRELOAD:-}"
        echo "renderdoc_gpu_launcher_delay_start_ms=${RDOC_GPU_LAUNCHER_DELAY_START_MS:-0}"
        echo "renderdoc_gpu_launcher_delay_duration_ms=${RDOC_GPU_LAUNCHER_DELAY_DURATION_MS:-500}"
        echo "renderdoc_gpu_launcher_delay_target_device=${RDOC_GPU_LAUNCHER_DELAY_TARGET_DEVICE:-0}"
        echo "renderdoc_gpu_launcher_allow_dlopen=${RDOC_GPU_LAUNCHER_ALLOW_DLOPEN:-0}"
        echo "renderdoc_gpu_launcher_preload_renderdoc=${RDOC_GPU_LAUNCHER_PRELOAD_RENDERDOC:-0}"
        echo "renderdoc_gpu_launcher_disable_dlsym_wrap=${RDOC_GPU_LAUNCHER_DISABLE_DLSYM_WRAP:-0}"
        echo "renderdoc_gpu_launcher_disable_egl_wrap=${RDOC_GPU_LAUNCHER_DISABLE_EGL_WRAP:-0}"
        echo "renderdoc_gpu_launcher_no_dlopen_fallback=${RDOC_GPU_LAUNCHER_NO_DLOPEN_FALLBACK:-0}"
        echo "renderdoc_gpu_launcher_trigger_only=${RDOC_GPU_LAUNCHER_TRIGGER_ONLY:-0}"
        echo "renderdoc_gpu_launcher_capfile=$capture_prefix"
        echo "renderdoc_gpu_launcher_capopts=${RDOC_GPU_LAUNCHER_CAPOPTS:-${RENDERDOC_CAPOPTS:-}}"
        echo "renderdoc_gpu_launcher_debug_log_file=${RDOC_GPU_LAUNCHER_DEBUG_LOG_FILE:-$capture_prefix-renderdoc.log}"
    } >>"$log_path"
fi

if [ "$layer_only" = "1" ]; then
    export ENABLE_VULKAN_RENDERDOC_CAPTURE=1
    export RENDERDOC_CAPFILE="$capture_prefix"
    if [ "$clear_renderdoc_layer" = "1" ]; then
        unset VK_INSTANCE_LAYERS
        unset ENABLE_VULKAN_RENDERDOC_CAPTURE
    elif [ "$clear_instance_layers" = "1" ]; then
        unset VK_INSTANCE_LAYERS
    fi
    if [ "$clear_renderdoc_enable" = "1" ]; then
        unset ENABLE_VULKAN_RENDERDOC_CAPTURE
    fi
    export RENDERDOC_DEBUG_LOG_FILE="${RDOC_GPU_LAUNCHER_DEBUG_LOG_FILE:-$capture_prefix-renderdoc.log}"
    if [ "${RDOC_GPU_LAUNCHER_CAPOPTS:-${RENDERDOC_CAPOPTS:-}}" != "" ]; then
        export RENDERDOC_CAPOPTS="${RDOC_GPU_LAUNCHER_CAPOPTS:-${RENDERDOC_CAPOPTS:-}}"
    fi
    if [ "$log_path" != "" ]; then
        {
            echo "renderdoc_gpu_launcher_layer_only_exported_enable=1"
            echo "renderdoc_gpu_launcher_layer_only_clear_renderdoc_layer=$clear_renderdoc_layer"
            echo "renderdoc_gpu_launcher_layer_only_clear_instance_layers=$clear_instance_layers"
            echo "renderdoc_gpu_launcher_layer_only_clear_renderdoc_enable=$clear_renderdoc_enable"
            echo "renderdoc_gpu_launcher_layer_only_exported_capfile=$RENDERDOC_CAPFILE"
            echo "renderdoc_gpu_launcher_layer_only_exported_capopts=${RENDERDOC_CAPOPTS:-}"
            echo "renderdoc_gpu_launcher_layer_only_exported_debug_log_file=$RENDERDOC_DEBUG_LOG_FILE"
            echo "renderdoc_gpu_launcher_layer_only_exec_pid=$$"
            echo "renderdoc_gpu_launcher_layer_only_vk_layer_path=${VK_LAYER_PATH:-}"
            echo "renderdoc_gpu_launcher_layer_only_vk_implicit_layer_path=${VK_IMPLICIT_LAYER_PATH:-}"
            echo "renderdoc_gpu_launcher_layer_only_vk_instance_layers=${VK_INSTANCE_LAYERS:-}"
        } >>"$log_path"
    fi
    if [ "$log_path" != "" ]; then
        echo "renderdoc_gpu_launcher_child_output=begin" >>"$log_path"
        exec "$@" >>"$log_path" 2>&1
    fi
    exec "$@"
fi

if [ "$autocapture" = "1" ]; then
    renderdoc_home="${RDOC_HOME:-/opt/renderdoc}"
    renderdoc_lib="${RDOC_GPU_LAUNCHER_RENDERDOC_LIB:-$renderdoc_home/lib}"
    shim_dir="${RDOC_GPU_LAUNCHER_SHIM_DIR:-$root_dir/build/renderdoc/autocapture-shim}"
    if [ "$delay_trigger" = "1" ]; then
        shim="$shim_dir/renderdoc-delay-trigger.so"
        shim_src="$script_dir/renderdoc-delay-trigger.c"
    else
        shim="$shim_dir/renderdoc-vulkan-autocapture.so"
        shim_src="$script_dir/renderdoc-vulkan-autocapture.c"
    fi
    mkdir -p "$shim_dir"
    if [ ! -s "$shim" ] || [ "$shim_src" -nt "$shim" ]; then
        cc -shared -fPIC \
            -I"$renderdoc_home/include" \
            -o "$shim" \
            "$shim_src" \
            -ldl -pthread
    fi
    export LD_LIBRARY_PATH="$renderdoc_lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    if [ "${RDOC_GPU_LAUNCHER_PRELOAD_RENDERDOC:-0}" = "1" ]; then
        export LD_PRELOAD="$shim $renderdoc_lib/librenderdoc.so${LD_PRELOAD:+ $LD_PRELOAD}"
    else
        export LD_PRELOAD="$shim${LD_PRELOAD:+ $LD_PRELOAD}"
    fi
    export ENABLE_VULKAN_RENDERDOC_CAPTURE=1
    export RENDERDOC_CAPFILE="$capture_prefix"
    if [ "$clear_renderdoc_layer" = "1" ]; then
        unset VK_INSTANCE_LAYERS
        unset ENABLE_VULKAN_RENDERDOC_CAPTURE
    elif [ "$clear_instance_layers" = "1" ]; then
        unset VK_INSTANCE_LAYERS
    fi
    if [ "$clear_renderdoc_enable" = "1" ]; then
        unset ENABLE_VULKAN_RENDERDOC_CAPTURE
    fi
    if [ "${RDOC_GPU_LAUNCHER_CAPOPTS:-${RENDERDOC_CAPOPTS:-}}" != "" ]; then
        export RENDERDOC_CAPOPTS="${RDOC_GPU_LAUNCHER_CAPOPTS:-${RENDERDOC_CAPOPTS:-}}"
    fi
    export RDOC_AUTOCAPTURE_FILE="$capture_prefix"
    export RDOC_AUTOCAPTURE_RENDERDOC_LIB="$renderdoc_lib/librenderdoc.so"
    export RDOC_AUTOCAPTURE_ALLOW_DLOPEN="${RDOC_GPU_LAUNCHER_ALLOW_DLOPEN:-0}"
    export RDOC_AUTOCAPTURE_START_ON_DLSYM="${RDOC_GPU_LAUNCHER_START_ON_DLSYM:-0}"
    export RDOC_AUTOCAPTURE_DELAY_START_MS="${RDOC_GPU_LAUNCHER_DELAY_START_MS:-0}"
    export RDOC_AUTOCAPTURE_DELAY_DURATION_MS="${RDOC_GPU_LAUNCHER_DELAY_DURATION_MS:-500}"
    export RDOC_AUTOCAPTURE_DISABLE_DLSYM_WRAP="${RDOC_GPU_LAUNCHER_DISABLE_DLSYM_WRAP:-0}"
    export RDOC_AUTOCAPTURE_DISABLE_EGL_WRAP="${RDOC_GPU_LAUNCHER_DISABLE_EGL_WRAP:-0}"
    export RDOC_AUTOCAPTURE_NO_DLOPEN_FALLBACK="${RDOC_GPU_LAUNCHER_NO_DLOPEN_FALLBACK:-0}"
    export RDOC_AUTOCAPTURE_TRIGGER_ONLY="${RDOC_GPU_LAUNCHER_TRIGGER_ONLY:-0}"
    export RDOC_DELAY_TRIGGER_ENABLE="$delay_trigger"
    export RDOC_DELAY_TRIGGER_RENDERDOC_LIB="$renderdoc_lib/librenderdoc.so"
    export RDOC_DELAY_TRIGGER_MODE="$delay_trigger_mode"
    export RDOC_DELAY_TRIGGER_TARGET_DEVICE="${RDOC_GPU_LAUNCHER_DELAY_TARGET_DEVICE:-0}"
    export RDOC_DELAY_TRIGGER_START_MS="${RDOC_GPU_LAUNCHER_DELAY_START_MS:-2000}"
    export RDOC_DELAY_TRIGGER_DURATION_MS="${RDOC_GPU_LAUNCHER_DELAY_DURATION_MS:-2000}"
    if [ "$log_path" != "" ]; then
        export RDOC_AUTOCAPTURE_LOG="$log_path"
        export RDOC_DELAY_TRIGGER_LOG="$log_path"
        {
            echo "renderdoc_gpu_launcher_shim=$shim"
            echo "renderdoc_gpu_launcher_ld_preload=$LD_PRELOAD"
            echo "renderdoc_gpu_launcher_ld_library_path=$LD_LIBRARY_PATH"
            echo "renderdoc_gpu_launcher_vk_layer_path=${VK_LAYER_PATH:-}"
            echo "renderdoc_gpu_launcher_vk_implicit_layer_path=${VK_IMPLICIT_LAYER_PATH:-}"
            echo "renderdoc_gpu_launcher_vk_instance_layers=${VK_INSTANCE_LAYERS:-}"
            echo "renderdoc_gpu_launcher_enable_vulkan_renderdoc_capture=${ENABLE_VULKAN_RENDERDOC_CAPTURE:-}"
            echo "renderdoc_gpu_launcher_renderdoc_capfile=$RENDERDOC_CAPFILE"
            echo "renderdoc_gpu_launcher_renderdoc_lib=$renderdoc_lib/librenderdoc.so"
        } >>"$log_path"
    fi
    if [ "$log_path" != "" ]; then
        echo "renderdoc_gpu_launcher_child_output=begin" >>"$log_path"
        exec "$@" >>"$log_path" 2>&1
    fi
    exec "$@"
fi

exec "$rdoc_cmd" capture -w -c "$capture_prefix" "$@"
