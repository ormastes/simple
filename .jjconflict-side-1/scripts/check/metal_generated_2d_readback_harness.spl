# Metal Generated 2D Readback Harness
#
# Compiles the same MSL kernels generated by check-portable-compute-toolchains.shs
# and dispatches fill/copy/alpha/scroll on the Metal GPU, then reads back results
# to compute checksums.  Output is line-based key=value for the shell wrapper.
#
# Run with:
#   SIMPLE_EXECUTION_MODE=interpret bin/simple run \
#     scripts/check/metal_generated_2d_readback_harness.spl --mode=interpreter
#
# Output lines (on success):
#   submit_attempted=true
#   readback_available=true
#   fill_hash=<N>           # gate value: position-mixing FNV-1a over (pixel, index)
#   copy_hash=<N>
#   alpha_hash=<N>
#   scroll_hash=<N>
#   fill_hash_expected=<N>
#   copy_hash_expected=<N>
#   alpha_hash_expected=<N>
#   scroll_hash_expected=<N>
#   fill_sum=<N>            # telemetry only: legacy order-independent 32-bit sum
#   copy_sum=<N>
#   alpha_sum=<N>
#   scroll_sum=<N>
#   fill_sum_expected=<N>
#   copy_sum_expected=<N>
#   alpha_sum_expected=<N>
#   scroll_sum_expected=<N>
#   fill_checksum=<N>       # compat alias of fill_hash (consumed by
#   copy_checksum=<N>       # check-metal-generated-2d-readback.shs, which
#   alpha_checksum=<N>      # forwards these keys into evidence.env)
#   scroll_checksum=<N>
#   fill_expected=<N>       # compat alias of fill_hash_expected
#   copy_expected=<N>
#   alpha_expected=<N>
#   scroll_expected=<N>
#   status=pass
#
# The gate values are position-mixing FNV-1a (per pixel: h = (h XOR pixel) *
# prime; h = (h XOR index) * prime, in 64-bit wrapping arithmetic), so a
# swapped/duplicated/shifted pixel changes the value — unlike the old
# order-independent masked sum, which is kept only as *_sum telemetry.
# Emitted hashes are masked to 63 bits so the shell gates' unsigned-decimal
# validators accept them.
#
# Output on failure:
#   submit_attempted=false|true
#   readback_available=false
#   error=<message>
#   status=fail

# ============================================================================
# Raw FFI
# ============================================================================

use compiler.backend.gpu_portable_compute.{PortableComputeTarget, emit_portable_2d_optimization_module}
use std.nogc_sync_mut.io.metal_sffi.{metal_sffi_compile_shader}

extern fn rt_metal_is_available() -> i64
extern fn rt_metal_init() -> i64
extern fn rt_metal_device_count() -> i64
extern fn rt_metal_create_device(idx: i64) -> i64
extern fn rt_metal_destroy_device(dev: i64) -> i64
extern fn rt_metal_create_command_queue(dev: i64) -> i64
extern fn rt_metal_destroy_command_queue(q: i64) -> i64
extern fn rt_metal_alloc_buffer(dev: i64, size: i64) -> i64
extern fn rt_metal_free_buffer(buf: i64) -> i64
extern fn rt_metal_destroy_shader(shader: i64) -> i64
extern fn rt_metal_create_compute_pipeline(dev: i64, shader: i64, entry: text) -> i64
extern fn rt_metal_destroy_pipeline(pipe: i64) -> i64
extern fn rt_metal_create_command_buffer(queue: i64) -> i64
extern fn rt_metal_commit_command_buffer(cmd: i64) -> i64
extern fn rt_metal_wait_completed(cmd: i64) -> i64
extern fn rt_metal_create_compute_encoder(cmd: i64) -> i64
extern fn rt_metal_end_compute_encoder(enc: i64) -> i64
extern fn rt_metal_set_buffer(enc: i64, buf: i64, offset: i64, index: i64) -> i64
extern fn rt_metal_set_bytes(enc: i64, data_ptr: i64, length: i64, index: i64) -> i64
extern fn rt_metal_dispatch_compute(enc: i64, pipe: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64) -> i64
extern fn rt_metal_buffer_download(data_ptr: i64, buffer: i64, size: i64) -> i64
extern fn rt_metal_buffer_upload(buffer: i64, data_ptr: i64, size: i64) -> i64
extern fn rt_metal_get_last_error() -> text
extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64) -> i64
extern fn rt_ptr_write_i32(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_read_i64(ptr: i64, offset: i64) -> i64

# ============================================================================
# MSL source — identical to write_metal_source in check-portable-compute-toolchains.shs
# ============================================================================

# val MSL_SRC: text = "#include <metal_stdlib>\nusing namespace metal;\nkernel void simple_2d_fill_u32(device uint* dst [[buffer(0)]], constant uint& value [[buffer(1)]], constant uint& count [[buffer(2)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) { return; }\n    dst[gid] = value;\n}\nkernel void simple_2d_copy_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& count [[buffer(2)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) { return; }\n    dst[gid] = src[gid];\n}\nkernel void simple_2d_alpha_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& alpha [[buffer(2)]], constant uint& count [[buffer(3)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) { return; }\n    uint s = src[gid];\n    uint d = dst[gid];\n    uint inv = 255u - alpha;\n    uint rb = (((s & 0x00ff00ffu) * alpha) + ((d & 0x00ff00ffu) * inv)) >> 8;\n    uint g = (((s & 0x0000ff00u) * alpha) + ((d & 0x0000ff00u) * inv)) >> 8;\n    dst[gid] = 0xff000000u | (rb & 0x00ff00ffu) | (g & 0x0000ff00u);\n}\nkernel void simple_2d_scroll_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& width [[buffer(2)]], constant uint& height [[buffer(3)]], constant int& delta_y [[buffer(4)]], uint gid [[thread_position_in_grid]]) {\n    uint count = width * height;\n    if (gid >= count) { return; }\n    uint x = gid % width;\n    uint y = gid / width;\n    int sy = (int)y - delta_y;\n    if (sy < 0 || sy >= (int)height) { dst[gid] = 0u; return; }\n    dst[gid] = src[(uint)sy * width + x];\n}\n"

# ============================================================================
# Constants
# ============================================================================

val N: i64 = 64
val BYTES: i64 = 256   # N * 4

# Fill constants
val FILL_COLOR: i64 = 0xAABBCCDD

# Alpha constants — src=0xFFFF0000 (opaque red), dst=0xFF0000FF (opaque blue), alpha=128
val ALPHA_SRC: i64 = 0xFFFF0000
val ALPHA_DST: i64 = 0xFF0000FF
val ALPHA_VAL: i64 = 128

# Scroll constants — 8x8, shift down by 2
val SCROLL_W: i64 = 8
val SCROLL_H: i64 = 8
val SCROLL_DELTA: i64 = 2
val SCROLL_BYTES: i64 = 256   # 8*8*4

# ============================================================================
# Position-mixing FNV-1a hash (gate value)
#
# Standard FNV-1a 64-bit constants (offset basis 0xcbf29ce484222325 as signed
# i64, prime 0x100000001b3) — same constants as std.hash (see
# src/lib/nogc_async_mut_noalloc/hash/mod.spl) and the wrapping-multiply
# helper mirrors wrapping_mul_i64 in src/lib/nogc_sync_mut/src/hash.spl.
# Per pixel: h = (h XOR pixel_u32) * prime; h = (h XOR index) * prime.
# ============================================================================

val FNV_OFFSET_BASIS: i64 = -3750763034362895579  # 0xcbf29ce484222325
val FNV_PRIME: i64 = 1099511628211                # 0x100000001b3

fn fnv_wrapping_mul(left: i64, right: i64) -> i64:
    ((left as u64) * (right as u64)) as i64

fn fnv_mix_pixel(h: i64, pixel: i64, index: i64) -> i64:
    var x = h ^ (pixel & 0xFFFFFFFF)
    x = fnv_wrapping_mul(x, FNV_PRIME)
    x = x ^ index
    fnv_wrapping_mul(x, FNV_PRIME)

# Mask to 63 bits so the value prints as an unsigned decimal (the shell gates
# validate ^[0-9]+$). Applied identically to expected and actual.
fn fnv_mask(h: i64) -> i64:
    h & 0x7FFFFFFFFFFFFFFF

# ============================================================================
# CPU reference computations
# ============================================================================

# Compute the alpha-blend result pixel on the CPU (same math as the kernel)
fn cpu_alpha_pixel() -> i64:
    val s = ALPHA_SRC & 0xFFFFFFFF
    val d = ALPHA_DST & 0xFFFFFFFF
    val a = ALPHA_VAL & 0xFF
    val inv = (255 - a) & 0xFF
    val s_rb = s & 0x00FF00FF
    val d_rb = d & 0x00FF00FF
    val s_g  = s & 0x0000FF00
    val d_g  = d & 0x0000FF00
    val rb = ((s_rb * a) + (d_rb * inv)) >> 8
    val g  = ((s_g  * a) + (d_g  * inv)) >> 8
    val pixel = (0xFF000000 as i64) | (rb & 0x00FF00FF) | (g & 0x0000FF00)
    pixel & 0xFFFFFFFF

# --- Expected position-mixing hashes (gate values) ---

fn expected_uniform_hash(pixel: i64, count: i64) -> i64:
    # Every pixel has the same expected value; the hash still mixes in the
    # index so it cannot be computed analytically as count * pixel.
    var h: i64 = FNV_OFFSET_BASIS
    val p = pixel & 0xFFFFFFFF
    var i: i64 = 0
    while i < count:
        h = fnv_mix_pixel(h, p, i)
        i = i + 1
    fnv_mask(h)

fn cpu_fill_hash() -> i64:
    expected_uniform_hash(FILL_COLOR, N)

fn cpu_copy_hash() -> i64:
    var h: i64 = FNV_OFFSET_BASIS
    var i: i64 = 0
    while i < N:
        h = fnv_mix_pixel(h, copy_pattern_pixel(i), i)
        i = i + 1
    fnv_mask(h)

fn copy_pattern_pixel(index: i64) -> i64:
    (0xFF000000 | ((index * 37) & 0x00FFFFFF)) & 0xFFFFFFFF

fn cpu_alpha_hash() -> i64:
    expected_uniform_hash(cpu_alpha_pixel(), N)

fn cpu_scroll_hash() -> i64:
    # 8x8 grid, scroll down by 2: dst rows 0,1 are 0 (black), rows 2..7 get
    # src rows 0..5 (all FILL_COLOR). Hash over the expected per-pixel value.
    var h: i64 = FNV_OFFSET_BASIS
    var y: i64 = 0
    while y < SCROLL_H:
        val sy = y - SCROLL_DELTA
        var x: i64 = 0
        while x < SCROLL_W:
            val pixel = if (sy < 0 or sy >= SCROLL_H): 0 else: FILL_COLOR & 0xFFFFFFFF
            h = fnv_mix_pixel(h, pixel, y * SCROLL_W + x)
            x = x + 1
        y = y + 1
    fnv_mask(h)

# --- Legacy order-independent sums (telemetry only, NOT the gate) ---

fn cpu_fill_sum() -> i64:
    # All N pixels = FILL_COLOR; sum = N * color (mod 2^32 wrapped)
    val color32 = FILL_COLOR & 0xFFFFFFFF
    (color32 * N) & 0xFFFFFFFF

fn cpu_copy_sum() -> i64:
    var sum: i64 = 0
    var i: i64 = 0
    while i < N:
        sum = (sum + copy_pattern_pixel(i)) & 0xFFFFFFFF
        i = i + 1
    sum

fn cpu_alpha_sum() -> i64:
    # alpha=128 blend: src=0xFFFF0000, dst=0xFF0000FF
    (cpu_alpha_pixel() * N) & 0xFFFFFFFF

fn cpu_scroll_sum() -> i64:
    var sum: i64 = 0
    var y: i64 = 0
    while y < SCROLL_H:
        val sy = y - SCROLL_DELTA
        var x: i64 = 0
        while x < SCROLL_W:
            val pixel = if (sy < 0 or sy >= SCROLL_H): 0 else: FILL_COLOR & 0xFFFFFFFF
            sum = (sum + pixel) & 0xFFFFFFFF
            x = x + 1
        y = y + 1
    sum

# ============================================================================
# Dispatch helper: 1D kernel with one GPU buffer at index 0
# and setBytes scalars at higher indices
# ============================================================================

# Allocate a 4-byte param block, write a u32 value, return the ptr
fn alloc_u32_param(value: i64) -> i64:
    val p = rt_alloc(4)
    if p != 0:
        rt_ptr_write_i32(p, 0, value)
    p

# Legacy order-independent sum over a downloaded host buffer (telemetry only)
fn host_checksum(host: i64, count: i64) -> i64:
    var sum: i64 = 0
    var i: i64 = 0
    while i < count / 2:
        val pair = rt_ptr_read_i64(host, i * 8)
        val lo = pair & 0xFFFFFFFF
        val hi = (pair >> 32) & 0xFFFFFFFF
        sum = (sum + lo + hi) & 0xFFFFFFFF
        i = i + 1
    if count % 2 != 0:
        val pair = rt_ptr_read_i64(host, (count - 1) * 4)
        val lo = pair & 0xFFFFFFFF
        sum = (sum + lo) & 0xFFFFFFFF
    sum

# Position-mixing FNV-1a over a downloaded host buffer (gate value)
fn host_hash(host: i64, count: i64) -> i64:
    var h: i64 = FNV_OFFSET_BASIS
    var i: i64 = 0
    while i < count / 2:
        val pair = rt_ptr_read_i64(host, i * 8)
        val lo = pair & 0xFFFFFFFF
        val hi = (pair >> 32) & 0xFFFFFFFF
        h = fnv_mix_pixel(h, lo, i * 2)
        h = fnv_mix_pixel(h, hi, i * 2 + 1)
        i = i + 1
    if count % 2 != 0:
        val pair = rt_ptr_read_i64(host, (count - 1) * 4)
        val lo = pair & 0xFFFFFFFF
        h = fnv_mix_pixel(h, lo, count - 1)
    fnv_mask(h)

# ============================================================================
# Main
# ============================================================================

fn main() -> i64:
    if rt_metal_is_available() == 0:
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Metal not available on this host")
        print("status=fail")
        return 1

    rt_metal_init()
    if rt_metal_device_count() <= 0:
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=No Metal devices found")
        print("status=fail")
        return 1

    val dev = rt_metal_create_device(0)
    if dev == 0:
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Metal device creation failed")
        print("status=fail")
        return 1

    val queue = rt_metal_create_command_queue(dev)
    if queue == 0:
        rt_metal_destroy_device(dev)
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Metal command queue creation failed")
        print("status=fail")
        return 1

    val generated_shader = emit_portable_2d_optimization_module(PortableComputeTarget.Metal)
    if generated_shader.source.trim() == "":
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=generated Metal shader source is empty")
        print("status=fail")
        return 1
    val shader = metal_sffi_compile_shader(dev, generated_shader.source)
    if shader == 0:
        val err = rt_metal_get_last_error()
        rt_metal_destroy_command_queue(queue)
        rt_metal_destroy_device(dev)
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=MSL compile failed: {err}")
        print("status=fail")
        return 1

    val pipe_fill   = rt_metal_create_compute_pipeline(dev, shader, "simple_2d_fill_u32")
    val pipe_copy   = rt_metal_create_compute_pipeline(dev, shader, "simple_2d_copy_u32")
    val pipe_alpha  = rt_metal_create_compute_pipeline(dev, shader, "simple_2d_alpha_u32")
    val pipe_scroll = rt_metal_create_compute_pipeline(dev, shader, "simple_2d_scroll_u32")

    if (pipe_fill == 0 or pipe_copy == 0 or pipe_alpha == 0 or pipe_scroll == 0):
        val err = rt_metal_get_last_error()
        if pipe_fill != 0: rt_metal_destroy_pipeline(pipe_fill)
        if pipe_copy != 0: rt_metal_destroy_pipeline(pipe_copy)
        if pipe_alpha != 0: rt_metal_destroy_pipeline(pipe_alpha)
        if pipe_scroll != 0: rt_metal_destroy_pipeline(pipe_scroll)
        rt_metal_destroy_shader(shader)
        rt_metal_destroy_command_queue(queue)
        rt_metal_destroy_device(dev)
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Pipeline creation failed: {err}")
        print("status=fail")
        return 1

    # Allocate GPU buffers
    val buf_fill   = rt_metal_alloc_buffer(dev, BYTES)
    val buf_src    = rt_metal_alloc_buffer(dev, BYTES)
    val buf_dst    = rt_metal_alloc_buffer(dev, BYTES)
    val buf_scroll_src = rt_metal_alloc_buffer(dev, SCROLL_BYTES)
    val buf_scroll_dst = rt_metal_alloc_buffer(dev, SCROLL_BYTES)
    val host_mem   = rt_alloc(BYTES + 8)

    if (buf_fill == 0 or buf_src == 0 or buf_dst == 0 or buf_scroll_src == 0 or buf_scroll_dst == 0 or host_mem == 0):
        if buf_fill != 0: rt_metal_free_buffer(buf_fill)
        if buf_src != 0: rt_metal_free_buffer(buf_src)
        if buf_dst != 0: rt_metal_free_buffer(buf_dst)
        if buf_scroll_src != 0: rt_metal_free_buffer(buf_scroll_src)
        if buf_scroll_dst != 0: rt_metal_free_buffer(buf_scroll_dst)
        if host_mem != 0: rt_free(host_mem)
        rt_metal_destroy_pipeline(pipe_fill)
        rt_metal_destroy_pipeline(pipe_copy)
        rt_metal_destroy_pipeline(pipe_alpha)
        rt_metal_destroy_pipeline(pipe_scroll)
        rt_metal_destroy_shader(shader)
        rt_metal_destroy_command_queue(queue)
        rt_metal_destroy_device(dev)
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Buffer allocation failed")
        print("status=fail")
        return 1

    var submit_attempted = false

    # ---- Fill: simple_2d_fill_u32(dst[0], value[1], count[2]) ----
    var fill_hash: i64 = -1
    var fill_sum: i64 = -1
    val p_fill_value = alloc_u32_param(FILL_COLOR)
    val p_fill_count = alloc_u32_param(N)
    if (p_fill_value != 0 and p_fill_count != 0):
        val fill_cmd = rt_metal_create_command_buffer(queue)
        if fill_cmd != 0:
            val fill_enc = rt_metal_create_compute_encoder(fill_cmd)
            if fill_enc != 0:
                val buf_fill_local = buf_fill
                val fill_bound = rt_metal_set_buffer(fill_enc, buf_fill_local, 0, 0) != 0 and rt_metal_set_bytes(fill_enc, p_fill_value, 4, 1) != 0 and rt_metal_set_bytes(fill_enc, p_fill_count, 4, 2) != 0
                val pipe_fill_local = pipe_fill
                val fill_dispatched = fill_bound and rt_metal_dispatch_compute(fill_enc, pipe_fill_local, N, 1, 1, 64, 1, 1) != 0
                val fill_ended = fill_dispatched and rt_metal_end_compute_encoder(fill_enc) != 0
                val fill_committed = fill_ended and rt_metal_commit_command_buffer(fill_cmd) != 0
                if fill_committed:
                    submit_attempted = true
                val fill_waited = fill_committed and rt_metal_wait_completed(fill_cmd) != 0
                if fill_waited:
                    val host_fill = rt_alloc(BYTES + 8)
                    if host_fill != 0:
                        val dl_ok = rt_metal_buffer_download(host_fill, buf_fill_local, BYTES)
                        if dl_ok != 0:
                            fill_hash = host_hash(host_fill, N)
                            fill_sum = host_checksum(host_fill, N)
                        rt_free(host_fill)
    if p_fill_value != 0: rt_free(p_fill_value)
    if p_fill_count != 0: rt_free(p_fill_count)

    # ---- Copy: upload a non-uniform host pattern, copy on GPU, download ----
    # This is the explicit host -> GPU -> GPU kernel -> host round-trip proof.
    var copy_hash: i64 = -1
    var copy_sum: i64 = -1
    val host_copy_upload = rt_alloc(BYTES + 8)
    var upload_ok = false
    if host_copy_upload != 0:
        var upload_i: i64 = 0
        while upload_i < N:
            rt_ptr_write_i32(host_copy_upload, upload_i * 4, copy_pattern_pixel(upload_i))
            upload_i = upload_i + 1
        upload_ok = rt_metal_buffer_upload(buf_src, host_copy_upload, BYTES) != 0
        rt_free(host_copy_upload)

    # Now copy buf_src -> buf_dst
    val p_copy_count = alloc_u32_param(N)
    if p_copy_count != 0 and upload_ok:
        val copy_cmd = rt_metal_create_command_buffer(queue)
        if copy_cmd != 0:
            val copy_enc = rt_metal_create_compute_encoder(copy_cmd)
            if copy_enc != 0:
                val buf_src_lc = buf_src
                val buf_dst_lc = buf_dst
                val copy_bound = rt_metal_set_buffer(copy_enc, buf_src_lc, 0, 0) != 0 and rt_metal_set_buffer(copy_enc, buf_dst_lc, 0, 1) != 0 and rt_metal_set_bytes(copy_enc, p_copy_count, 4, 2) != 0
                val pipe_copy_l = pipe_copy
                val copy_dispatched = copy_bound and rt_metal_dispatch_compute(copy_enc, pipe_copy_l, N, 1, 1, 64, 1, 1) != 0
                val copy_ended = copy_dispatched and rt_metal_end_compute_encoder(copy_enc) != 0
                val copy_committed = copy_ended and rt_metal_commit_command_buffer(copy_cmd) != 0
                if copy_committed:
                    submit_attempted = true
                val copy_waited = copy_committed and rt_metal_wait_completed(copy_cmd) != 0
                if copy_waited:
                    val host_copy = rt_alloc(BYTES + 8)
                    if host_copy != 0:
                        val dl_ok2 = rt_metal_buffer_download(host_copy, buf_dst_lc, BYTES)
                        if dl_ok2 != 0:
                            copy_hash = host_hash(host_copy, N)
                            copy_sum = host_checksum(host_copy, N)
                        rt_free(host_copy)
        rt_free(p_copy_count)

    # ---- Alpha blend: src=ALPHA_SRC into dst=ALPHA_DST with alpha=128 ----
    # First populate src buffer with ALPHA_SRC and dst buffer with ALPHA_DST
    var alpha_hash: i64 = -1
    var alpha_sum: i64 = -1
    val p_asrc_v = alloc_u32_param(ALPHA_SRC)
    val p_asrc_c = alloc_u32_param(N)
    val p_adst_v = alloc_u32_param(ALPHA_DST)
    val p_adst_c = alloc_u32_param(N)
    if (p_asrc_v != 0 and p_asrc_c != 0 and p_adst_v != 0 and p_adst_c != 0):
        # fill buf_src with ALPHA_SRC
        val asrc_cmd = rt_metal_create_command_buffer(queue)
        if asrc_cmd != 0:
            val asrc_enc = rt_metal_create_compute_encoder(asrc_cmd)
            if asrc_enc != 0:
                val buf_src_la = buf_src
                val asrc_bound = rt_metal_set_buffer(asrc_enc, buf_src_la, 0, 0) != 0 and rt_metal_set_bytes(asrc_enc, p_asrc_v, 4, 1) != 0 and rt_metal_set_bytes(asrc_enc, p_asrc_c, 4, 2) != 0
                val pipe_fill_la = pipe_fill
                val asrc_dispatched = asrc_bound and rt_metal_dispatch_compute(asrc_enc, pipe_fill_la, N, 1, 1, 64, 1, 1) != 0
                val asrc_ended = asrc_dispatched and rt_metal_end_compute_encoder(asrc_enc) != 0
                val asrc_committed = asrc_ended and rt_metal_commit_command_buffer(asrc_cmd) != 0
                if asrc_committed: submit_attempted = true
                val asrc_waited = asrc_committed and rt_metal_wait_completed(asrc_cmd) != 0
        # fill buf_dst with ALPHA_DST
        val adst_cmd = rt_metal_create_command_buffer(queue)
        if adst_cmd != 0:
            val adst_enc = rt_metal_create_compute_encoder(adst_cmd)
            if adst_enc != 0:
                val buf_dst_la = buf_dst
                val adst_bound = rt_metal_set_buffer(adst_enc, buf_dst_la, 0, 0) != 0 and rt_metal_set_bytes(adst_enc, p_adst_v, 4, 1) != 0 and rt_metal_set_bytes(adst_enc, p_adst_c, 4, 2) != 0
                val pipe_fill_lb = pipe_fill
                val adst_dispatched = adst_bound and rt_metal_dispatch_compute(adst_enc, pipe_fill_lb, N, 1, 1, 64, 1, 1) != 0
                val adst_ended = adst_dispatched and rt_metal_end_compute_encoder(adst_enc) != 0
                val adst_committed = adst_ended and rt_metal_commit_command_buffer(adst_cmd) != 0
                if adst_committed: submit_attempted = true
                val adst_waited = adst_committed and rt_metal_wait_completed(adst_cmd) != 0
        # alpha blend buf_src into buf_dst
        val p_alpha_v = alloc_u32_param(ALPHA_VAL)
        val p_alpha_c = alloc_u32_param(N)
        if (p_alpha_v != 0 and p_alpha_c != 0):
            val alpha_cmd = rt_metal_create_command_buffer(queue)
            if alpha_cmd != 0:
                val alpha_enc = rt_metal_create_compute_encoder(alpha_cmd)
                if alpha_enc != 0:
                    val buf_src_laa = buf_src
                    val buf_dst_laa = buf_dst
                    val alpha_bound = rt_metal_set_buffer(alpha_enc, buf_src_laa, 0, 0) != 0 and rt_metal_set_buffer(alpha_enc, buf_dst_laa, 0, 1) != 0 and rt_metal_set_bytes(alpha_enc, p_alpha_v, 4, 2) != 0 and rt_metal_set_bytes(alpha_enc, p_alpha_c, 4, 3) != 0
                    val pipe_alpha_l = pipe_alpha
                    val alpha_dispatched = alpha_bound and rt_metal_dispatch_compute(alpha_enc, pipe_alpha_l, N, 1, 1, 64, 1, 1) != 0
                    val alpha_ended = alpha_dispatched and rt_metal_end_compute_encoder(alpha_enc) != 0
                    val alpha_committed = alpha_ended and rt_metal_commit_command_buffer(alpha_cmd) != 0
                    if alpha_committed: submit_attempted = true
                    val alpha_waited = alpha_committed and rt_metal_wait_completed(alpha_cmd) != 0
                    if alpha_waited:
                        val host_alpha = rt_alloc(BYTES + 8)
                        if host_alpha != 0:
                            val dl_ok3 = rt_metal_buffer_download(host_alpha, buf_dst_laa, BYTES)
                            if dl_ok3 != 0:
                                alpha_hash = host_hash(host_alpha, N)
                                alpha_sum = host_checksum(host_alpha, N)
                            rt_free(host_alpha)
            if p_alpha_v != 0: rt_free(p_alpha_v)
            if p_alpha_c != 0: rt_free(p_alpha_c)
    if p_asrc_v != 0: rt_free(p_asrc_v)
    if p_asrc_c != 0: rt_free(p_asrc_c)
    if p_adst_v != 0: rt_free(p_adst_v)
    if p_adst_c != 0: rt_free(p_adst_c)

    # ---- Scroll: fill 8x8 src with FILL_COLOR, scroll down by SCROLL_DELTA ----
    var scroll_hash: i64 = -1
    var scroll_sum: i64 = -1
    val p_ssrc_v = alloc_u32_param(FILL_COLOR)
    val p_ssrc_c = alloc_u32_param(SCROLL_W * SCROLL_H)
    if (p_ssrc_v != 0 and p_ssrc_c != 0):
        # fill scroll src
        val ss_cmd = rt_metal_create_command_buffer(queue)
        if ss_cmd != 0:
            val ss_enc = rt_metal_create_compute_encoder(ss_cmd)
            if ss_enc != 0:
                val buf_ss = buf_scroll_src
                val ss_bound = rt_metal_set_buffer(ss_enc, buf_ss, 0, 0) != 0 and rt_metal_set_bytes(ss_enc, p_ssrc_v, 4, 1) != 0 and rt_metal_set_bytes(ss_enc, p_ssrc_c, 4, 2) != 0
                val pipe_fill_lss = pipe_fill
                val ss_dispatched = ss_bound and rt_metal_dispatch_compute(ss_enc, pipe_fill_lss, SCROLL_W * SCROLL_H, 1, 1, 64, 1, 1) != 0
                val ss_ended = ss_dispatched and rt_metal_end_compute_encoder(ss_enc) != 0
                val ss_committed = ss_ended and rt_metal_commit_command_buffer(ss_cmd) != 0
                if ss_committed: submit_attempted = true
                val ss_waited = ss_committed and rt_metal_wait_completed(ss_cmd) != 0
        # scroll
        val p_scroll_w = alloc_u32_param(SCROLL_W)
        val p_scroll_h = alloc_u32_param(SCROLL_H)
        val p_scroll_d = alloc_u32_param(SCROLL_DELTA)
        if (p_scroll_w != 0 and p_scroll_h != 0 and p_scroll_d != 0):
            val scroll_cmd = rt_metal_create_command_buffer(queue)
            if scroll_cmd != 0:
                val scroll_enc = rt_metal_create_compute_encoder(scroll_cmd)
                if scroll_enc != 0:
                    val buf_sss = buf_scroll_src
                    val buf_ssd = buf_scroll_dst
                    val scroll_bound = rt_metal_set_buffer(scroll_enc, buf_sss, 0, 0) != 0 and rt_metal_set_buffer(scroll_enc, buf_ssd, 0, 1) != 0 and rt_metal_set_bytes(scroll_enc, p_scroll_w, 4, 2) != 0 and rt_metal_set_bytes(scroll_enc, p_scroll_h, 4, 3) != 0 and rt_metal_set_bytes(scroll_enc, p_scroll_d, 4, 4) != 0
                    val pipe_scroll_l = pipe_scroll
                    val scroll_dispatched = scroll_bound and rt_metal_dispatch_compute(scroll_enc, pipe_scroll_l, SCROLL_W * SCROLL_H, 1, 1, 64, 1, 1) != 0
                    val scroll_ended = scroll_dispatched and rt_metal_end_compute_encoder(scroll_enc) != 0
                    val scroll_committed = scroll_ended and rt_metal_commit_command_buffer(scroll_cmd) != 0
                    if scroll_committed: submit_attempted = true
                    val scroll_waited = scroll_committed and rt_metal_wait_completed(scroll_cmd) != 0
                    if scroll_waited:
                        val host_scroll = rt_alloc(SCROLL_BYTES + 8)
                        if host_scroll != 0:
                            val dl_ok4 = rt_metal_buffer_download(host_scroll, buf_ssd, SCROLL_BYTES)
                            if dl_ok4 != 0:
                                scroll_hash = host_hash(host_scroll, SCROLL_W * SCROLL_H)
                                scroll_sum = host_checksum(host_scroll, SCROLL_W * SCROLL_H)
                            rt_free(host_scroll)
        if p_scroll_w != 0: rt_free(p_scroll_w)
        if p_scroll_h != 0: rt_free(p_scroll_h)
        if p_scroll_d != 0: rt_free(p_scroll_d)
    if p_ssrc_v != 0: rt_free(p_ssrc_v)
    if p_ssrc_c != 0: rt_free(p_ssrc_c)

    # ---- Cleanup ----
    rt_metal_free_buffer(buf_fill)
    rt_metal_free_buffer(buf_src)
    rt_metal_free_buffer(buf_dst)
    rt_metal_free_buffer(buf_scroll_src)
    rt_metal_free_buffer(buf_scroll_dst)
    rt_free(host_mem)
    rt_metal_destroy_pipeline(pipe_fill)
    rt_metal_destroy_pipeline(pipe_copy)
    rt_metal_destroy_pipeline(pipe_alpha)
    rt_metal_destroy_pipeline(pipe_scroll)
    rt_metal_destroy_shader(shader)
    rt_metal_destroy_command_queue(queue)
    rt_metal_destroy_device(dev)

    # ---- Output ----
    val readback_ok = (fill_hash >= 0 and copy_hash >= 0 and alpha_hash >= 0 and scroll_hash >= 0)
    val fill_exp = cpu_fill_hash()
    val copy_exp = cpu_copy_hash()
    val alpha_exp = cpu_alpha_hash()
    val scroll_exp = cpu_scroll_hash()
    val fill_sum_exp = cpu_fill_sum()
    val copy_sum_exp = cpu_copy_sum()
    val alpha_sum_exp = cpu_alpha_sum()
    val scroll_sum_exp = cpu_scroll_sum()

    print("submit_attempted={submit_attempted}")
    print("host_upload_available={upload_ok}")
    print("readback_available={readback_ok}")
    # Gate values: position-mixing FNV-1a hashes
    print("fill_hash={fill_hash}")
    print("copy_hash={copy_hash}")
    print("alpha_hash={alpha_hash}")
    print("scroll_hash={scroll_hash}")
    print("fill_hash_expected={fill_exp}")
    print("copy_hash_expected={copy_exp}")
    print("alpha_hash_expected={alpha_exp}")
    print("scroll_hash_expected={scroll_exp}")
    # Telemetry: legacy order-independent masked sums (NOT the gate)
    print("fill_sum={fill_sum}")
    print("copy_sum={copy_sum}")
    print("alpha_sum={alpha_sum}")
    print("scroll_sum={scroll_sum}")
    print("fill_sum_expected={fill_sum_exp}")
    print("copy_sum_expected={copy_sum_exp}")
    print("alpha_sum_expected={alpha_sum_exp}")
    print("scroll_sum_expected={scroll_sum_exp}")
    # Compat aliases carrying the hash values: check-metal-generated-2d-readback.shs
    # greps these keys and forwards them into evidence.env for the render-log gate.
    print("fill_checksum={fill_hash}")
    print("copy_checksum={copy_hash}")
    print("alpha_checksum={alpha_hash}")
    print("scroll_checksum={scroll_hash}")
    print("fill_expected={fill_exp}")
    print("copy_expected={copy_exp}")
    print("alpha_expected={alpha_exp}")
    print("scroll_expected={scroll_exp}")

    val hashes_match = (fill_hash == fill_exp and copy_hash == copy_exp and alpha_hash == alpha_exp and scroll_hash == scroll_exp)
    if readback_ok and hashes_match:
        print("status=pass")
        return 0

    if not readback_ok:
        print("status=fail")
        print("error=Metal operation or readback failed: {rt_metal_get_last_error()}")
        return 1

    print("status=fail")
    print("error=hash mismatch: fill={fill_hash} vs {fill_exp}, copy={copy_hash} vs {copy_exp}, alpha={alpha_hash} vs {alpha_exp}, scroll={scroll_hash} vs {scroll_exp}")
    return 1

describe "Metal generated 2D host/device readback":
    it "submits generated kernels and verifies downloaded pixels":
        expect(main()).to_equal(0)
