#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_feature_db_reference_integrity}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_feature_db_reference_integrity_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
SURFACE_MANIFEST="$BUILD_DIR/feature_db_reference_surface_manifest.tsv"
FEATURE_DB="doc/08_tracking/feature/feature_db.sdn"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH" "$SURFACE_MANIFEST"

artifact_size() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        wc -c <"$path" | tr -d ' '
    else
        printf '%s\n' "0"
    fi
}

artifact_sha256() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        if command -v sha256sum >/dev/null 2>&1; then
            sha256sum "$path" | awk '{print $1}'
        elif command -v shasum >/dev/null 2>&1; then
            shasum -a 256 "$path" | awk '{print $1}'
        else
            printf '%s\n' "unavailable"
        fi
    else
        printf '%s\n' "missing"
    fi
}

{
    for path in \
        scripts/check/check-llm-feature-db-reference-integrity.shs \
        doc/08_tracking/feature/feature_db.sdn
    do
        printf '%s\t%s\t%s\n' "$path" "$(artifact_size "$path")" "$(artifact_sha256 "$path")"
    done
} >"$SURFACE_MANIFEST"

surface_manifest_count="$(wc -l <"$SURFACE_MANIFEST" | tr -d ' ')"
surface_manifest_size="$(artifact_size "$SURFACE_MANIFEST")"
surface_manifest_sha256="$(artifact_sha256 "$SURFACE_MANIFEST")"

if ! command -v python3 >/dev/null 2>&1; then
    {
        printf '%s\n' "llm_feature_db_reference_integrity_status=fail"
        printf '%s\n' "llm_feature_db_reference_integrity_reason=python3_unavailable"
        printf '%s\n' "llm_feature_db_reference_integrity_blocked_gates=python3"
        printf '%s\n' "llm_feature_db_reference_integrity_primary_blocked_gate=python3"
        printf '%s\n' "llm_feature_db_reference_integrity_surface_manifest=$SURFACE_MANIFEST"
        printf '%s\n' "llm_feature_db_reference_integrity_surface_manifest_count=$surface_manifest_count"
        printf '%s\n' "llm_feature_db_reference_integrity_surface_manifest_size=$surface_manifest_size"
        printf '%s\n' "llm_feature_db_reference_integrity_surface_manifest_sha256=$surface_manifest_sha256"
    } >"$OUT_ENV"
    {
        printf '# LLM Feature DB Reference Integrity\n\n'
        printf '%s\n' "- status: \`fail\`"
        printf '%s\n' "- reason: \`python3_unavailable\`"
        printf '%s\n' "- env: \`$OUT_ENV\`"
    } >"$REPORT_PATH"
    echo "STATUS: FAIL llm-feature-db-reference-integrity reason=python3_unavailable"
    exit 1
fi

python3 - "$FEATURE_DB" "$OUT_ENV" "$REPORT_PATH" "$SURFACE_MANIFEST" "$surface_manifest_count" "$surface_manifest_size" "$surface_manifest_sha256" <<'PY'
import csv
import os
import sys

feature_db, out_env, report_path, surface_manifest, manifest_count, manifest_size, manifest_sha = sys.argv[1:]
prefixes = ("doc/", "test/", "src/", "scripts/", ".spipe/", "examples/")
stale_paths = {
    "doc/06_spec/01_unit/lib/gc_async_mut/svllm/model_loader_streaming_readiness_spec.md",
    "doc/06_spec/01_unit/lib/gc_async_mut/svllm/nvfs_client/std_fs_spec.md",
}

rows_checked = 0
paths_checked = 0
missing = []
stale = []

with open(feature_db, "r", encoding="utf-8") as f:
    for lineno, line in enumerate(f, 1):
        stripped = line.strip()
        if not stripped.startswith('"'):
            continue
        if not (
            stripped.startswith('"FR-LLM')
            or stripped.startswith('"FR-SPIPE-LLM')
            or "kairos_like_simple_mcp_llm_dashboard" in stripped
        ):
            continue
        candidate = stripped
        if candidate.endswith(",true"):
            candidate = candidate[:-5] + "true"
        try:
            row = next(csv.reader([candidate], skipinitialspace=True))
        except Exception as exc:
            missing.append(f"{lineno}:csv_parse:{exc}")
            continue
        rows_checked += 1
        feature_id = row[0] if row else f"line-{lineno}"
        for col_i, cell in enumerate(row):
            for raw in cell.split(";"):
                path = raw.strip().strip("`")
                if path.endswith(",") or path.endswith("."):
                    path = path[:-1]
                if not path or " " in path:
                    continue
                if not path.startswith(prefixes):
                    continue
                if "*" in path or path.endswith("/"):
                    continue
                paths_checked += 1
                if path in stale_paths:
                    stale.append(f"{lineno}:{feature_id}:col{col_i}:{path}")
                if not os.path.exists(path):
                    missing.append(f"{lineno}:{feature_id}:col{col_i}:{path}")

blocked = []
if missing:
    blocked.append("missing_paths")
if stale:
    blocked.append("stale_svllm_generated_spec_paths")

status = "pass" if not blocked else "fail"
reason = "feature_db_references_exist" if status == "pass" else "feature_db_reference_gap"
blocked_gates = "|".join(blocked) if blocked else "none"
primary = blocked[0] if blocked else "none"
next_action = "feature DB LLM references are current" if status == "pass" else "fix missing or stale LLM feature DB references"

with open(out_env, "w", encoding="utf-8") as f:
    f.write(f"llm_feature_db_reference_integrity_status={status}\n")
    f.write(f"llm_feature_db_reference_integrity_reason={reason}\n")
    f.write("llm_feature_db_reference_integrity_scope=llm_feature_db_local_paths\n")
    f.write("llm_feature_db_reference_integrity_required_gates=all_referenced_paths_exist,stale_svllm_generated_spec_paths_absent\n")
    f.write(f"llm_feature_db_reference_integrity_blocked_gates={blocked_gates}\n")
    f.write(f"llm_feature_db_reference_integrity_primary_blocked_gate={primary}\n")
    f.write(f"llm_feature_db_reference_integrity_rows_checked={rows_checked}\n")
    f.write(f"llm_feature_db_reference_integrity_paths_checked={paths_checked}\n")
    f.write(f"llm_feature_db_reference_integrity_missing_count={len(missing)}\n")
    f.write(f"llm_feature_db_reference_integrity_stale_svllm_path_count={len(stale)}\n")
    f.write(f"llm_feature_db_reference_integrity_surface_manifest={surface_manifest}\n")
    f.write(f"llm_feature_db_reference_integrity_surface_manifest_count={manifest_count}\n")
    f.write(f"llm_feature_db_reference_integrity_surface_manifest_size={manifest_size}\n")
    f.write(f"llm_feature_db_reference_integrity_surface_manifest_sha256={manifest_sha}\n")
    f.write(f"llm_feature_db_reference_integrity_next_action={next_action}\n")
    if missing:
        f.write("llm_feature_db_reference_integrity_missing_paths=" + "|".join(missing) + "\n")
    if stale:
        f.write("llm_feature_db_reference_integrity_stale_svllm_paths=" + "|".join(stale) + "\n")

with open(report_path, "w", encoding="utf-8") as f:
    f.write("# LLM Feature DB Reference Integrity\n\n")
    f.write(f"- status: `{status}`\n")
    f.write(f"- reason: `{reason}`\n")
    f.write("- scope: `llm_feature_db_local_paths`\n")
    f.write("- required_gates: `all_referenced_paths_exist,stale_svllm_generated_spec_paths_absent`\n")
    f.write(f"- blocked_gates: `{blocked_gates}`\n")
    f.write(f"- primary_blocked_gate: `{primary}`\n")
    f.write(f"- rows_checked: `{rows_checked}`\n")
    f.write(f"- paths_checked: `{paths_checked}`\n")
    f.write(f"- missing_count: `{len(missing)}`\n")
    f.write(f"- stale_svllm_path_count: `{len(stale)}`\n")
    f.write(f"- surface_manifest: `{surface_manifest}`\n")
    f.write(f"- surface_manifest_count: `{manifest_count}`\n")
    f.write(f"- surface_manifest_size: `{manifest_size}`\n")
    f.write(f"- surface_manifest_sha256: `{manifest_sha}`\n")
    f.write(f"- next_action: `{next_action}`\n")
    f.write(f"- env: `{out_env}`\n")
    if missing:
        f.write("\n## Missing Paths\n\n")
        for item in missing:
            f.write(f"- `{item}`\n")
    if stale:
        f.write("\n## Stale svLLM Paths\n\n")
        for item in stale:
            f.write(f"- `{item}`\n")
    f.write("\nThis evidence verifies that LLM-related feature database rows reference existing local repository paths and that the known svLLM generated-spec docs stay on their real `doc/06_spec/test/01_unit/...` locations.\n")

print(f"STATUS: {status.upper()} llm-feature-db-reference-integrity rows_checked={rows_checked} paths_checked={paths_checked} missing_count={len(missing)} stale_svllm_path_count={len(stale)}")
sys.exit(0 if status == "pass" else 1)
PY
