# Validate the x86_64 SimpleOS Glass Window Manager QEMU framebuffer PPM.
#
# Parses the P6 PPM captured from the guest std-VGA linear framebuffer
# (pmemsave 0xfd000000, BGRA -> RGB) after wm_entry.spl painted its glass
# desktop, and asserts real rendered pixels at scene anchors:
#   - wallpaper background (full-screen gradient)
#   - window 0/1/2 title-bar centers (glass window cards)
#   - taskbar/dock strip near the bottom
# PASS requires substantial non-black coverage AND every anchor non-black.
# Real values are printed so the evidence is inspectable, not asserted blind.

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?

struct PpmHeader:
    magic: i64
    width: i64
    height: i64
    max_value: i64
    data_offset: i64
    ok: bool

struct NumParse:
    value: i64
    next: i64
    ok: bool

fn byte_at(data: [u8], idx: i64) -> i64:
    if idx < 0 or idx >= data.len():
        return 0
    data[idx] as i64

fn is_ws(b: i64) -> bool:
    b == 32 or b == 9 or b == 10 or b == 13

fn is_digit(b: i64) -> bool:
    b >= 48 and b <= 57

fn skip_ws_comments(data: [u8], pos: i64) -> i64:
    var i = pos
    var again = true
    while again:
        again = false
        while i < data.len() and is_ws(byte_at(data, i)):
            i = i + 1
        if i < data.len() and byte_at(data, i) == 35:
            while i < data.len() and byte_at(data, i) != 10 and byte_at(data, i) != 13:
                i = i + 1
            again = true
    i

fn parse_num(data: [u8], pos: i64) -> NumParse:
    var i = skip_ws_comments(data, pos)
    if i >= data.len() or not is_digit(byte_at(data, i)):
        return NumParse(value: 0, next: i, ok: false)
    var value: i64 = 0
    while i < data.len() and is_digit(byte_at(data, i)):
        value = (value * 10) + (byte_at(data, i) - 48)
        i = i + 1
    NumParse(value: value, next: i, ok: true)

fn parse_header(data: [u8]) -> PpmHeader:
    var pos = skip_ws_comments(data, 0)
    if pos + 1 >= data.len() or byte_at(data, pos) != 80:
        return PpmHeader(magic: 0, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    val magic = byte_at(data, pos + 1)
    if magic != 54:
        return PpmHeader(magic: magic, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    pos = pos + 2
    val width = parse_num(data, pos)
    if not width.ok:
        return PpmHeader(magic: magic, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    val height = parse_num(data, width.next)
    if not height.ok:
        return PpmHeader(magic: magic, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    val maxv = parse_num(data, height.next)
    if not maxv.ok:
        return PpmHeader(magic: magic, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    var data_offset = maxv.next
    while data_offset < data.len() and is_ws(byte_at(data, data_offset)):
        data_offset = data_offset + 1
    PpmHeader(magic: magic, width: width.value, height: height.value, max_value: maxv.value, data_offset: data_offset, ok: true)

fn count_nonblack(data: [u8], start: i64, total_values: i64) -> i64:
    var count: i64 = 0
    var i = start
    val end = start + total_values
    while i < end:
        if byte_at(data, i) != 0 or byte_at(data, i + 1) != 0 or byte_at(data, i + 2) != 0:
            count = count + 1
        i = i + 3
    count

fn anchor_nonblack(data: [u8], data_offset: i64, width: i64, x: i64, y: i64, label: text) -> bool:
    val i = data_offset + ((y * width + x) * 3)
    val r = byte_at(data, i)
    val g = byte_at(data, i + 1)
    val b = byte_at(data, i + 2)
    val nonblack = r != 0 or g != 0 or b != 0
    print "simpleos_x86_64_wm_anchor_{label}=x{x},y{y},rgb({r},{g},{b}),nonblack={nonblack.to_string()}"
    nonblack

fn main() -> i32:
    val path = rt_env_get("SIMPLEOS_X86_64_WM_PPM") ?? ""
    if path == "":
        print "simpleos_x86_64_wm_ppm_status=fail"
        print "simpleos_x86_64_wm_ppm_reason=no-ppm-path-env"
        return 0
    val data = rt_file_read_bytes(path) ?? []
    val header = parse_header(data)
    if not header.ok or header.width != 1024 or header.height != 768 or header.max_value != 255:
        print "simpleos_x86_64_wm_ppm_status=fail"
        print "simpleos_x86_64_wm_ppm_reason=bad-header"
        print "simpleos_x86_64_wm_ppm_header_ok={header.ok.to_string()}"
        print "simpleos_x86_64_wm_ppm_width={header.width.to_string()}"
        print "simpleos_x86_64_wm_ppm_height={header.height.to_string()}"
        print "simpleos_x86_64_wm_ppm_maxval={header.max_value.to_string()}"
        return 0
    val total_values = header.width * header.height * 3
    if data.len() - header.data_offset < total_values:
        print "simpleos_x86_64_wm_ppm_status=fail"
        print "simpleos_x86_64_wm_ppm_reason=truncated-pixels"
        print "simpleos_x86_64_wm_ppm_have={(data.len() - header.data_offset).to_string()}"
        print "simpleos_x86_64_wm_ppm_need={total_values.to_string()}"
        return 0
    val nonblack = count_nonblack(data, header.data_offset, total_values)
    # Scene anchors (glass WM): wallpaper corners/center, window title bars, dock.
    val a_bg_tl = anchor_nonblack(data, header.data_offset, header.width, 20, 20, "wallpaper_tl")
    val a_bg_tr = anchor_nonblack(data, header.data_offset, header.width, 1000, 20, "wallpaper_tr")
    val a_bg_ctr = anchor_nonblack(data, header.data_offset, header.width, 512, 384, "wallpaper_center")
    val a_win0 = anchor_nonblack(data, header.data_offset, header.width, 270, 82, "win0_titlebar")
    val a_win1 = anchor_nonblack(data, header.data_offset, header.width, 510, 182, "win1_titlebar")
    val a_win2 = anchor_nonblack(data, header.data_offset, header.width, 750, 322, "win2_titlebar")
    val a_dock = anchor_nonblack(data, header.data_offset, header.width, 512, 730, "dock_strip")
    val all_anchors = a_bg_tl and a_bg_tr and a_bg_ctr and a_win0 and a_win1 and a_win2 and a_dock
    val coverage_ok = nonblack > 100000
    var status = "fail"
    if coverage_ok and all_anchors:
        status = "pass"
    print "simpleos_x86_64_wm_ppm_nonblack={nonblack.to_string()}"
    print "simpleos_x86_64_wm_ppm_coverage_ok={coverage_ok.to_string()}"
    print "simpleos_x86_64_wm_ppm_all_anchors={all_anchors.to_string()}"
    print "simpleos_x86_64_wm_ppm_status={status}"
    0
