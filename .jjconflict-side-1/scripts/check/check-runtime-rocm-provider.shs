#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

CC="${CC:-cc}"
BUILD_DIR="${ROCM_MOCK_BUILD_DIR:-build/check/runtime-rocm-mock}"
mkdir -p "$BUILD_DIR"

"$CC" -std=c11 -D_GNU_SOURCE -Wall -Wextra -Werror -fPIC -shared \
    scripts/check/runtime_rocm_mock.c -o "$BUILD_DIR/libamdhip64.so"
cp "$BUILD_DIR/libamdhip64.so" "$BUILD_DIR/libhiprtc.so"
for name in libamdhip64.so.6 libamdhip64.so.5 libhiprtc.so.6 libhiprtc.so.5; do
    case "$name" in libamdhip64*) target=libamdhip64.so ;; *) target=libhiprtc.so ;; esac
    ln -sf "$target" "$BUILD_DIR/$name"
done
"$CC" -std=c11 -Wall -Wextra -Werror -c \
    src/runtime/runtime_hosted_gpu_stubs.c -o "$BUILD_DIR/runtime_hosted_gpu_stubs.o"
ar rcs "$BUILD_DIR/libruntime_hosted_gpu_stubs.a" "$BUILD_DIR/runtime_hosted_gpu_stubs.o"
"$CC" -std=c11 -D_GNU_SOURCE -Wall -Wextra -Werror -Isrc/runtime \
    scripts/check/runtime_rocm_driver.c "$BUILD_DIR/libruntime_hosted_gpu_stubs.a" \
    src/runtime/runtime_rocm.c \
    -o "$BUILD_DIR/runtime_rocm_driver" -ldl -lpthread

LD_LIBRARY_PATH="$BUILD_DIR${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
    "$BUILD_DIR/runtime_rocm_driver"
