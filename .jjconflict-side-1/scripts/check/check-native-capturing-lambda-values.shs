#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BINARY="${SIMPLE_BINARY:-bin/simple}"
WORK_DIR="${WORK_DIR:-/tmp/check-native-capturing-lambda-values.$$}"
FIXTURE="test/fixtures/native_capturing_lambda_values/main.spl"
EXPECTED="84270"

test -x "$SIMPLE_BINARY"
mkdir -p "$WORK_DIR"
trap 'rm -rf "$WORK_DIR"' EXIT HUP INT TERM

for runtime in hosted simple-core; do
    for backend in default-llvm cranelift; do
        binary="$WORK_DIR/capturing-lambda-$runtime-$backend"
        log="$WORK_DIR/capturing-lambda-$runtime-$backend.log"
        backend_arg=""
        if [ "$backend" = cranelift ]; then
            backend_arg="--backend=cranelift"
        fi
        runtime_arg=""
        core_runtime_path=""
        if [ "$runtime" = simple-core ]; then
            core_dir="$WORK_DIR/simple-core-$backend"
            archive_log="$WORK_DIR/simple-core-$backend.log"
            env ARCHIVE_ONLY=1 SIMPLE_BINARY="$SIMPLE_BINARY" \
                SIMPLE_CORE_BACKEND="${backend#default-}" \
                BUILD_DIR="$WORK_DIR/simple-core-build-$backend" \
                SIMPLE_CORE_BUILD_DIR="$core_dir" \
                sh scripts/check/check-simple-core-runtime-smoke.shs >"$archive_log" 2>&1
            core_runtime_path="$core_dir/libsimple_runtime.a"
            test -f "$core_runtime_path"
            runtime_arg="--runtime-bundle=simple-core"
        fi
        if [ "$runtime" = simple-core ]; then
            env -u SIMPLE_BOOTSTRAP SIMPLE_NO_STUB_FALLBACK=1 \
                SIMPLE_CORE_RUNTIME_PATH="$core_runtime_path" \
                "$SIMPLE_BINARY" native-build $backend_arg $runtime_arg \
                --source test/fixtures --entry-closure --entry "$FIXTURE" \
                --cache-dir "$WORK_DIR/cache-$runtime-$backend" --output "$binary" >"$log" 2>&1
        else
            env -u SIMPLE_BOOTSTRAP SIMPLE_NO_STUB_FALLBACK=1 \
                "$SIMPLE_BINARY" native-build $backend_arg \
                --source test/fixtures --entry-closure --entry "$FIXTURE" \
                --cache-dir "$WORK_DIR/cache-$runtime-$backend" --output "$binary" >"$log" 2>&1
        fi
        actual="$(timeout 20 "$binary" 2>>"$log")"
        test "$actual" = "$EXPECTED"
    done
done

echo "native-capturing-lambda-values: pass"
