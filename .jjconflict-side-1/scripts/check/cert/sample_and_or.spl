# Sample program with a compound decision: a and (b or c)
fn decide(a: bool, b: bool, c: bool) -> bool:
    if a and (b or c):
        return true
    return false

fn main():
    # MC/DC-adequate vector set for a and (b or c)
    decide(false, false, false)
    decide(true, true, false)
    decide(true, false, true)
    decide(true, false, false)

main()
