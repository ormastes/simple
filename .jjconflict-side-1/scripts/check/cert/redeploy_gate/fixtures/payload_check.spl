# redeploy-gate fixture: enum-payload (guards #109 wrong-value-unwrap regression)
# A correctly-redeployed binary unwraps the real payload and prints 42.
# The frozen/broken deployed binary prints 5 (the #109 regression) — that is
# exactly the discriminator this check exists to catch.
# EXPECT stdout: 42
fn get_it() -> Result<i64, text>:
    return Ok(42)

fn main():
    val r = get_it()
    match r:
        case Ok(v):
            print(v)
        case Err(e):
            print("err")
