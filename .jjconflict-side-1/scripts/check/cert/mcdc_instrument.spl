# MC/DC source-to-source instrumenter (cert C1).
#
# Given a Simple source file, rewrites every compound boolean DECISION in an
# `if` / `elif` / `while` header into a single `mcdc_eval(id, [atoms...])` call
# and prepends the decision registrations, so that running the instrumented
# program automatically records MC/DC evidence via std.mcdc and prints a
# per-decision coverage report at exit.
#
# Usage:
#   simple scripts/check/cert/mcdc_instrument.spl <input.spl> > <instrumented.spl>
#   simple <instrumented.spl>        # runs program, then prints MC/DC report
#
# The instrumented source is written to STDOUT (the frozen runtime's file-write
# path is currently non-functional; stdout redirection is used instead).
#
# Supported decision grammar (boolean subset):
#   decision := or_expr
#   or_expr  := and_expr ("or"  and_expr)*
#   and_expr := not_expr ("and" not_expr)*
#   not_expr := "not" not_expr | primary
#   primary  := "(" or_expr ")" | ATOM
#   ATOM     := run of tokens containing no parentheses and none of and/or/not
# Only block-form headers (trimmed line ends with ':') whose condition has at
# least two atoms (a compound decision) are instrumented; everything else is
# emitted unchanged. Atoms must not contain parentheses (no call expressions).

use std.nogc_sync_mut.io_runtime.*

extern fn rt_cli_get_args() -> [text]

# --- parser state (module vars: mutation persists across recursive calls) ---
var _toks: [text] = []
var _pos: i64 = 0
var _atoms: [text] = []
var _nodes: [text] = []

fn _reset_parser():
    _toks = []
    _pos = 0
    _atoms = []
    _nodes = []

fn _tokenize(expr: text):
    var toks: [text] = []
    var buf = ""
    var i = 0
    val n = expr.len()
    while i < n:
        val ch = expr.char_at(i)
        if ch == " ":
            if buf != "":
                toks.push(buf)
                buf = ""
        elif ch == "(" or ch == ")":
            if buf != "":
                toks.push(buf)
                buf = ""
            toks.push(ch)
        else:
            buf = buf + ch
        i = i + 1
    if buf != "":
        toks.push(buf)
    _toks = toks

fn _peek() -> text:
    if _pos < _toks.len():
        return _toks[_pos]
    ""

fn _advance():
    _pos = _pos + 1

fn _emit(src: text) -> i64:
    _nodes.push(src)
    _nodes.len() - 1

fn _is_keyword(t: text) -> bool:
    t == "and" or t == "or" or t == "not"

fn _parse_primary() -> i64:
    val t = _peek()
    if t == "(":
        _advance()
        val n = _parse_or()
        if _peek() == ")":
            _advance()
        return n
    var parts: [text] = []
    var cont = true
    while cont:
        val p = _peek()
        if p == "" or p == "(" or p == ")" or _is_keyword(p):
            cont = false
        else:
            parts.push(p)
            _advance()
    var atom = ""
    for k in 0..parts.len():
        if k > 0:
            atom = atom + " "
        atom = atom + parts[k]
    val idx = _atoms.len()
    _atoms.push(atom)
    _emit("mcdc_atom({idx})")

fn _parse_not() -> i64:
    if _peek() == "not":
        _advance()
        val c = _parse_not()
        return _emit("mcdc_not({c})")
    _parse_primary()

fn _parse_and() -> i64:
    var n = _parse_not()
    while _peek() == "and":
        _advance()
        val r = _parse_not()
        n = _emit("mcdc_and({n}, {r})")
    n

fn _parse_or() -> i64:
    var n = _parse_and()
    while _peek() == "or":
        _advance()
        val r = _parse_and()
        n = _emit("mcdc_or({n}, {r})")
    n

struct DecisionParse:
    matched: bool
    new_line: text
    reg_nodes: text
    reg_call: text

fn _leading_ws(line: text) -> text:
    var i = 0
    val n = line.len()
    var cont = true
    while cont:
        if i < n and line.char_at(i) == " ":
            i = i + 1
        else:
            cont = false
    line.substring(0, i)

fn _keyword_len(trimmed: text) -> i64:
    if trimmed.len() >= 3:
        val p3 = trimmed.substring(0, 3)
        if p3 == "if ":
            return 3
    if trimmed.len() >= 5:
        val p5 = trimmed.substring(0, 5)
        if p5 == "elif ":
            return 5
    if trimmed.len() >= 6:
        val p6 = trimmed.substring(0, 6)
        if p6 == "while ":
            return 6
    0

fn _quote_list(items: [text]) -> text:
    var s = "["
    for k in 0..items.len():
        if k > 0:
            s = s + ", "
        s = s + "\"" + items[k] + "\""
    s + "]"

fn _join(items: [text], sep: text) -> text:
    var s = ""
    for k in 0..items.len():
        if k > 0:
            s = s + sep
        s = s + items[k]
    s

fn _escape(s: text) -> text:
    s.replace("\"", "'")

fn _no_match() -> DecisionParse:
    DecisionParse { matched: false, new_line: "", reg_nodes: "", reg_call: "" }

fn try_decision(line: text, file: text, lineno: i64, id: i64) -> DecisionParse:
    val trimmed = line.trim()
    if trimmed.len() == 0:
        return _no_match()
    val last = trimmed.substring(trimmed.len() - 1, trimmed.len())
    if last != ":":
        return _no_match()
    val kwlen = _keyword_len(trimmed)
    if kwlen == 0:
        return _no_match()
    val kw = trimmed.substring(0, kwlen)
    val expr = trimmed.substring(kwlen, trimmed.len() - 1).trim()
    _reset_parser()
    _tokenize(expr)
    val root = _parse_or()
    # Only instrument compound decisions (2+ conditions).
    if _atoms.len() < 2:
        return _no_match()
    # A well-formed parse consumes all tokens; bail out on leftovers (e.g. an
    # atom containing parentheses) rather than emit a broken rewrite.
    if _pos != _toks.len():
        return _no_match()
    val lead = _leading_ws(line)
    val values = _join(_atoms, ", ")
    val new_line = lead + kw + "mcdc_eval(" + int_to_text(id) + ", [" + values + "]):"
    val reg_nodes = "    val __mcdc_nodes_" + int_to_text(id) + " = [" + _join(_nodes, ", ") + "]"
    val reg_call = "    register_decision_tree(\"" + _escape(expr) + "\", " + _quote_list(_atoms) + ", \"mixed\", \"" + file + "\", " + int_to_text(lineno) + ", __mcdc_nodes_" + int_to_text(id) + ")"
    DecisionParse { matched: true, new_line: new_line, reg_nodes: reg_nodes, reg_call: reg_call }

fn int_to_text(n: i64) -> text:
    "{n}"

fn _is_main_decl(trimmed: text) -> bool:
    if trimmed.len() < 8:
        return false
    trimmed.substring(0, 8) == "fn main("

fn instrument(path: text):
    val content = read_file(path)
    val lines = content.split("\n")
    var out: [text] = []
    var reg_nodes: [text] = []
    var reg_calls: [text] = []
    var count = 0
    var has_main = false
    for li in 0..lines.len():
        val line = lines[li]
        val res = try_decision(line, path, li + 1, count)
        if res.matched:
            out.push(res.new_line)
            reg_nodes.push(res.reg_nodes)
            reg_calls.push(res.reg_call)
            count = count + 1
        else:
            val trimmed = line.trim()
            if _is_main_decl(trimmed):
                has_main = true
                out.push(line.replace("fn main(", "fn __user_main("))
            else:
                out.push(line)
    # --- emit instrumented source to stdout ---
    # A `main` function is auto-invoked by the runtime and loose top-level
    # statements are then ignored. So when the target defines `main`, rename it
    # and drive it from a wrapper `main`; otherwise the target runs via loose
    # top-level statements and we bracket them with init/report calls directly.
    print "use std.nogc_sync_mut.mcdc.*"
    print "fn __mcdc_init():"
    print "    enable_mcdc_tag()"
    print "    clear_mcdc_data()"
    print "    clear_mcdc_trees()"
    for i in 0..count:
        print reg_nodes[i]
        print reg_calls[i]
    print "fn __mcdc_report():"
    print "    print \"=== MC/DC Report ===\""
    for d in 0..count:
        print "    print format_decision_report(" + int_to_text(d) + ")"
    if has_main:
        print "fn main():"
        print "    __mcdc_init()"
        print "    __user_main()"
        print "    __mcdc_report()"
        for k in 0..out.len():
            print out[k]
    else:
        print "__mcdc_init()"
        for k in 0..out.len():
            print out[k]
        print "__mcdc_report()"

fn main():
    val args = rt_cli_get_args()
    if args.len() < 3:
        print "usage: simple mcdc_instrument.spl <input.spl>"
        return
    instrument(args[2])

main()
