# Audit compiler diagnostic code literals for stable public shapes.

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_exit(code: i32) -> void

fn is_digit_char(ch: text) -> bool:
    ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9"

fn is_upper_char(ch: text) -> bool:
    ch == "A" or ch == "B" or ch == "C" or ch == "D" or ch == "E" or ch == "F" or ch == "G" or ch == "H" or ch == "I" or ch == "J" or ch == "K" or ch == "L" or ch == "M" or ch == "N" or ch == "O" or ch == "P" or ch == "Q" or ch == "R" or ch == "S" or ch == "T" or ch == "U" or ch == "V" or ch == "W" or ch == "X" or ch == "Y" or ch == "Z"

fn is_public_code(code: text) -> bool:
    if code.len() != 5:
        return false
    val prefix = code.substring(0, 1)
    if prefix != "E" and prefix != "W":
        return false
    is_digit_char(code.substring(1, 2)) and is_digit_char(code.substring(2, 3)) and is_digit_char(code.substring(3, 4)) and is_digit_char(code.substring(4, 5))

fn is_three_digit_suffix(code: text, start: i64) -> bool:
    if code.len() != start + 3:
        return false
    is_digit_char(code.substring(start, start + 1)) and is_digit_char(code.substring(start + 1, start + 2)) and is_digit_char(code.substring(start + 2, start + 3))

fn is_allowed_l_tool_code(code: text) -> bool:
    if not code.starts_with("L-"):
        return false
    var dash = -1
    var i = 2
    while i < code.len():
        val ch = code.substring(i, i + 1)
        if ch == "-":
            dash = i
            break
        if not is_upper_char(ch):
            return false
        i = i + 1
    if dash <= 2:
        return false
    is_three_digit_suffix(code, dash + 1)

fn is_allowed_sec_code(code: text) -> bool:
    if not code.starts_with("SEC-"):
        return false
    if code.len() <= 7:
        return false
    var digit_start = code.len() - 3
    if digit_start <= 4:
        return false
    var i = 4
    while i < digit_start:
        if not is_upper_char(code.substring(i, i + 1)):
            return false
        i = i + 1
    is_three_digit_suffix(code, digit_start)

fn is_allowed_game_code(code: text) -> bool:
    if not code.starts_with("GAME-"):
        return false
    var dash = -1
    var i = 5
    while i < code.len():
        val ch = code.substring(i, i + 1)
        if ch == "-":
            dash = i
            break
        if not is_upper_char(ch):
            return false
        i = i + 1
    if dash <= 5:
        return false
    is_three_digit_suffix(code, dash + 1)

fn is_allowed_code(code: text) -> bool:
    is_public_code(code) or is_allowed_l_tool_code(code) or is_allowed_sec_code(code) or is_allowed_game_code(code)

fn quoted_value_after(line: text, marker: text) -> text:
    val marker_idx = line.index_of(marker) ?? -1
    if marker_idx < 0:
        return ""
    val rest = line.substring(marker_idx + marker.len())
    val first_quote = rest.index_of("\"") ?? -1
    if first_quote < 0:
        return ""
    val after_quote = rest.substring(first_quote + 1)
    val second_quote = after_quote.index_of("\"") ?? -1
    if second_quote < 0:
        return ""
    after_quote.substring(0, second_quote)

fn code_literals_from_line(line: text) -> [text]:
    var codes: [text] = []
    val error_code = quoted_value_after(line, "error_code:")
    if error_code != "":
        codes = codes.push(error_code)
    val warning_code = quoted_value_after(line, "warning_code:")
    if warning_code != "":
        codes = codes.push(warning_code)
    val rust_code = quoted_value_after(line, "code: Some(")
    if rust_code != "":
        codes = codes.push(rust_code)
    codes

fn scan_file(path: text) -> [text]:
    val source = rt_file_read_text(path) ?? ""
    var violations: [text] = []
    val lines = source.split("\n")
    var idx = 0
    while idx < lines.len():
        val codes = code_literals_from_line(lines[idx])
        for code in codes:
            if not is_allowed_code(code):
                violations = violations.push(path + ":" + (idx + 1).to_string() + ": " + code)
        idx = idx + 1
    violations

fn list_scan_files() -> [text]:
    val command = "find src/compiler src/app src/compiler_rust/driver/src/cli -type f \\( -name '*.spl' -o -name '*.rs' \\) 2>/dev/null | sort"
    val result = rt_process_run("/bin/sh", ["-c", command])
    if result.2 != 0:
        print("Diagnostic Code Audit")
        print("=====================")
        print("find failed:")
        print(result.1)
        rt_exit(1)
    var files: [text] = []
    for raw in result.0.split("\n"):
        val path = raw.trim()
        if path != "" and not path.contains("/vendor/"):
            files = files.push(path)
    files

val files = list_scan_files()
var violations: [text] = []
for path in files:
    for violation in scan_file(path):
        violations = violations.push(violation)

print("Diagnostic Code Audit")
print("=====================")
print("Scanned " + files.len().to_string() + " files")
if violations.len() == 0:
    print("All diagnostic code literals use stable public shapes")
    rt_exit(0)

print("Invalid diagnostic code literals:")
var shown = 0
while shown < violations.len() and shown < 50:
    print("  - " + violations[shown])
    shown = shown + 1
if violations.len() > 50:
    print("  ... " + (violations.len() - 50).to_string() + " more")
rt_exit(1)
