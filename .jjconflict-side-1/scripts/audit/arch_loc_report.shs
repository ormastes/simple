#!/usr/bin/env sh
# arch_loc_report.shs — emit per-arch LoC numbers for AC-3 audit.
#
# Runs as part of `bin/simple build check` per Phase 7. Walks
# src/os/kernel/arch/<arch>/ for each of the six locked triples, counts
# owned-code .spl LoC, and writes build/multiarch/arch_loc_report.json.
#
# Phase 5 turns this RED stub into a real walker. Today it just emits
# a placeholder so the spec asserts can be wired up cleanly.
#
# Baseline LoC (Phase 2, locked in arch §4.1):
#   x86_64=2746  x86_32=1760  arm32=1806  arm64=1801
#   riscv64=2644 riscv32=1533

set -e

OUT_DIR="build/multiarch"
OUT_FILE="${OUT_DIR}/arch_loc_report.json"

mkdir -p "${OUT_DIR}"

# Phase 5 will replace this with a real walker that:
#   1. Counts .spl LoC per arch dir.
#   2. Subtracts shared lifts under arch/common/.
#   3. Computes delta_pct vs baseline.
#   4. Sets *_meets_floor when delta_pct >= 40 (or >= 25 with documented walker rationale).
#   5. Greps arch-neutral kernel files for direct `import os.kernel.arch.<arch>` and counts them.
#   6. Greps simpleos_cxxabi.spl for any `0xDEADBEEF` literal (residual_c counter context).

cat > "${OUT_FILE}" <<'EOF'
{
  "generated_by": "scripts/audit/arch_loc_report.shs",
  "phase": "red-stub",
  "baseline": {
    "x86_64":  2746,
    "x86_32":  1760,
    "arm32":   1806,
    "arm64":   1801,
    "riscv64": 2644,
    "riscv32": 1533
  },
  "current": {
    "x86_64":  null,
    "x86_32":  null,
    "arm32":   null,
    "arm64":   null,
    "riscv64": null,
    "riscv32": null
  },
  "delta_pct": {
    "x86_64":  null,
    "x86_32":  null,
    "arm32":   null,
    "arm64":   null,
    "riscv64": null,
    "riscv32": null
  },
  "x86_64_meets_floor": false,
  "all_archs_meet_floor": false,
  "direct_arch_imports_outside_arch": null,
  "residual_c_count": null
}
EOF

echo "wrote ${OUT_FILE} (red-stub)"
