attempt:
  attempt_id: "llm_backed_app_server_dry_run_retry4"
  goal: "License and data access gate before real QLoRA rerun"
  app_or_server_target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"

research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process.md"
  data_sources:
    - name: "licensed-kormedmcqa-fixed-format"
      source: "external medical QA dataset pending access approval"
      license: "missing license approval; do not train"
      download_command: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs llm_backed_app_server_dry_run_retry4"
      checksum: "not-available-before-license"
      cache_path: "not-created"

requirements:
  feature_option: "local-qlora-medical-domain-retry"
  nfr_option: "accuracy-target-90-percent-with-604-sample-eval"
  selected_by: "retry3 decision handoff"
  selection_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"

process_docs:
  requirements_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"
  nfr_doc: "doc/02_requirements/nfr/spipe_llm_finetune_process.md"
  plan_doc: "doc/03_plan/ml/spipe_llm_finetune_process.md"
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_process.md"
  design_doc: "doc/05_design/app/spipe/spipe_llm_finetune_process.md"

model_research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
  candidate_model: "google/medgemma-4b-it"
  license: "Health AI community license plus dataset license review required before training"
  context_length: "deployment context window must be reverified before serving"
  fit: "medical-domain base model remains candidate after retry3 dry-run handoff"
  constraints: "retry4 blocks real QLoRA until licensed fixed-format data and license approval exist"
  decision: "hold-medgemma-candidate-behind-license-gate"

model_architecture:
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  model_family: "MedGemma"
  data_strategy: "licensed fixed-format medical QA data required before training"
  training_strategy: "do not run QLoRA until license and cache evidence are present"
  deployment_target: "local app/server only after target-reaching eval and accepted decision"
  fallback: "switch to retrieval/tool strategy or alternate dataset/model if license cannot be cleared"

model:
  base_model: "google/medgemma-4b-it"
  base_model_revision: "not-pinned-before-license-gate"
  base_model_reason: "Keep prior candidate while gating training on licensed data access."
  deployment_target: "local app/server after accepted eval"

tuning:
  method: "local-qlora"
  training_script: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs"
  training_command: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs llm_backed_app_server_dry_run_retry4"
  model_artifact: "not-created"

evaluation:
  eval_command: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs llm_backed_app_server_dry_run_retry4"
  metrics: "license_review=missing; data_access=missing; training_allowed=false; model_accuracy=not-run"
  target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"
  result: "BLOCKED_LICENSED_DATA_NOT_AVAILABLE"

decision:
  status: "retry-data-research"
  retry_target: "obtain licensed fixed-format data access, checksum/cache evidence, and license approval before QLoRA"
  next_attempt: "llm_backed_app_server_dry_run_retry5"
  notes: "Retry4 is a license/data-access gate only; do not train or accept until data/license evidence exists."

app_handoff:
  app_target: "medgemma_korean"
  usage: "do not deploy; retry4 has no licensed data cache, trained artifact, or target eval"
  handoff_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  license_constraints: "Health AI community license plus dataset license review required; distribution not approved"
  safety_eval: "not-run; refusal, boundary behavior, and clinical-disclaimer checks required before deployment"
  deployment_evidence: "not-deployable; licensed data cache, trained artifact, target eval, and runtime/memory/latency/fallback evidence pending"

retune:
  reason: "licensed fixed-format data and license approval are missing"
  source_eval: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs"
  next_attempt: "llm_backed_app_server_dry_run_retry5"
  retry_target: "licensed data acquisition and cache/checksum verification"
