"""
Strict lint lane model for the Simple CI workflow.

Represents the authoritative Simple lint lane introduced by REQ-WARN-002.
The lane runs selected warning/allow cleanup canaries with --deny-all.
"""

class StrictLintLane:
    workflow_name: text
    deny_all: bool
    canaries: [text]

static fn new_default() -> StrictLintLane:
    val canaries = [
        "test/code_quality/allow_suppressions_spec.spl",
        "test/code_quality/bare_bool_lint_spec.spl",
        "test/code_quality/primitive_api_lint_spec.spl",
        "test/code_quality/warning_allow_root_cause_cleanup_spec.spl"
    ]
    StrictLintLane(
        workflow_name: "simple-strict-lints.yml",
        deny_all: true,
        canaries: canaries
    )

me is_strict() -> bool:
    self.deny_all

me canary_count() -> i64:
    self.canaries.len()

me includes_canary(name: text) -> bool:
    for c in self.canaries:
        if c.contains(name):
            return true
    false

me add_canary(path: text):
    self.canaries.push(path)
