"""
Decorator whitelist for the Simple strict-lint lane.

Tracks known decorator names used in stdlib and owned source trees.
REQ-WARN-005: adds @variant, @immutable, @no_gc to the known list.
"""

class DecoratorWhitelist:
    names: [text]

static fn new_default() -> DecoratorWhitelist:
    val base = [
        "async", "pure", "io", "net", "fs", "unsafe", "verify", "trusted",
        "ghost", "auto_lean", "bounds", "extern", "simd", "inline", "test",
        "property_test", "snapshot_test", "deprecated", "generated_by",
        "Lib", "inject", "sys_inject", "naked", "noreturn", "interrupt",
        "entry", "align", "gpu_intrinsic",
        "variant", "immutable", "no_gc"
    ]
    DecoratorWhitelist(names: base)

me add(name: text):
    self.names.push(name)

me is_known(name: text) -> bool:
    for n in self.names:
        if n == name:
            return true
    false

me size() -> i64:
    self.names.len()

me contains_all_stdlib() -> bool:
    val required = ["variant", "immutable", "no_gc"]
    for r in required:
        if not self.is_known(r):
            return false
    true
